[{"id":"01963de1-7780-73f5-b891-0c9a755fe2b2","parentId":null,"rootId":null,"fromId":1039,"content":"创业型公司，今年在扩张，目前来说，扁平化管理，领导们都还不错，没有日报周报一类烦人的事情","createdAt":"2023-04-19T11:43:48"},{"id":"01963de1-77d6-710e-8bc7-aedf593f1db8","parentId":null,"rootId":null,"fromId":1039,"content":"单双休，目前来说，研发除了发版日期需要加班，其他时间基本上不加班","createdAt":"2023-04-19T14:16:23"},{"id":"01963de1-7824-72e5-8964-1b8349ed2656","parentId":null,"rootId":null,"fromId":1049,"content":"一三五六加班","createdAt":"2024-01-18T17:05:35"},{"id":"01963de1-77cc-7284-a727-9b6b42b20b9c","parentId":null,"rootId":null,"fromId":6682,"content":"现在全齐了","createdAt":"2024-02-20T00:26:40"},{"id":"01963de1-788d-739e-89b3-bf43fc09218e","parentId":null,"rootId":null,"fromId":6682,"content":"最新：\n1.加班无加班费（事实依据，问过财务去年10月份之后就没有了）\n2.私自变更工作时间（大小周变为，上六休一，劳动法最高时间44小时哦）\n3.管理混乱，经常开会（宣传公司核心思想，还有考核？！过不了还扣钱，真是笑死）\n4.业务混乱，经常就是一拍脑袋就要上功能\n5.主打一个不画饼直接加压（认清现实赶紧跑路吧）\n6.公司感觉没一个懂法的（劳动法和他家写的一样，直接无视规定啊，也就是规定的罚款力度轻否则早拉倒了）\n7.基础工资特别低（五险一金有倒是有，多少？最低档）\n总结：\n按照近况来说，除非你是要饿死的那种，否则还是别来了","createdAt":"2024-02-20T00:36:43"},{"id":"01963de1-78d3-72a0-83c6-6ed7dc3649a6","parentId":null,"rootId":null,"fromId":1049,"content":"说的太对了，公司摇摇欲坠了","createdAt":"2024-02-29T10:19:41"},{"id":"01963de1-78d8-7089-b217-a9632492e02f","parentId":null,"rootId":null,"fromId":6737,"content":"不是已经改成大小周了，但是一月份工资没有发,说是回款慢？","createdAt":"2024-02-29T11:23:15"},{"id":"01963de1-77d1-7237-b9fc-b772045af6b9","parentId":null,"rootId":null,"fromId":1039,"content":"收回我的评论，现在真是全都齐了","createdAt":"2024-02-29T11:39:34"},{"id":"01963de1-78dc-72de-8b15-8890f159522a","parentId":null,"rootId":null,"fromId":1039,"content":"欠薪欠薪欠薪","createdAt":"2024-06-05T10:46:47"},{"id":"01963de1-7923-7068-bd95-8d2088158c85","parentId":null,"rootId":null,"fromId":7708,"content":"就会画饼，整天这考核那考核玩的那个花哟，薪资都不发，考核鸡毛","createdAt":"2024-06-05T10:51:21"}]