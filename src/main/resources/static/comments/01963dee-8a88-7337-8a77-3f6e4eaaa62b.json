[{"id":"01963dee-8afd-70b1-abe0-59365d7437c2","parentId":null,"rootId":null,"fromId":7665,"content":"这家公司听说不错的，公金积交的高，工资没有一次发迟到过，自研的产品不是外包，加班很少","createdAt":"2024-05-28T17:27:47"},{"id":"01963dee-8b49-71c9-bf78-e331addb3998","parentId":null,"rootId":null,"fromId":7666,"content":"之前在爱维待过4年，是中维世纪的子公司，团队人不多，也就30-50人左右，氛围还不错，沟通起来比较顺畅，平时不怎么加班，偶尔有紧急项目或任务会有加班，工资发的还是比较及时的，是每个月15号发；我在的时候是大小周，现在好像是已经双休了。","createdAt":"2024-05-28T17:39:19"},{"id":"01963dee-8b8d-724b-89cf-fc423d7b3bcd","parentId":null,"rootId":null,"fromId":22013,"content":"哥们，面试难度大么？","createdAt":"2025-02-08T15:07:01"}]