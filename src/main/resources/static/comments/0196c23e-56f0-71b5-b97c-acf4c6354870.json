[{"id":"0196c27a-3310-738f-9bd1-f5f74b9bcac7","parentId":null,"rootId":null,"fromId":7735,"content":"周六随便找几个园区，去车棚看看电动车停了多少","createdAt":"2025-05-12T11:11:50"},{"id":"0196c285-69cd-7193-81ea-e4a9a3f5f88f","parentId":null,"rootId":null,"fromId":21267,"content":"仅凭几个路口的观察就能洞悉整座城市的劳动状况，济南900多万人口，你的本事快敢上统计局了，要不你在傍晚闲的没事的时候溜达到软件园和浪潮去看看都关灯了吗，或者对比一下早高峰时段的上班的牛马数量 ？或者说你觉得工作环境差的标准是要把下班高峰期延后3小时才算是真差？只怕到时候你自己也被剥削的连骨头都不剩了。","createdAt":"2025-05-12T11:24:05"},{"id":"0196c285-9fd9-72e1-aed5-7a3ae3dc9c3d","parentId":null,"rootId":null,"fromId":21948,"content":"你也说了  只是你发现","createdAt":"2025-05-12T11:24:19"},{"id":"0196c296-4818-726a-9a3d-5926a4e0e1bc","parentId":null,"rootId":null,"fromId":23274,"content":"只是你发现罢了，再说软件行业占比才多少","createdAt":"2025-05-12T11:42:30"},{"id":"0196c34c-c465-703b-abe8-368b4b5d7346","parentId":null,"rootId":null,"fromId":2246,"content":"济南不好混是真的，你说的现象也是真的，加班的人多吗，很多，但不是全民。这种现象北上广也一样。","createdAt":"2025-05-12T15:01:50"},{"id":"0196c34e-81fb-7043-9221-105fac34f53a","parentId":null,"rootId":null,"fromId":2246,"content":"济南又不是什么多大的城市，产业就集中在几个地区，根据这几个地区的路口基本就够了。还有浪潮，浪潮有人没人都开着灯，这个说明不了啥。","createdAt":"2025-05-12T15:03:44"},{"id":"0196c385-c62d-739e-af6b-d9858ceeee39","parentId":null,"rootId":null,"fromId":6423,"content":"说实话，周末真没几个上班的，工作日上下班骑电车堵成狗，周六偶尔加个班，那叫个一路畅通","createdAt":"2025-05-12T16:04:06"},{"id":"0196c39c-876b-702f-bc6a-5730ef44eed0","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-05-12T16:28:57"},{"id":"0196c72a-c9a3-712b-8c99-9f5f38a1017c","parentId":null,"rootId":null,"fromId":6827,"content":"因为周六叫“加班”，加班能和正常上班的一样吗？","createdAt":"2025-05-13T09:03:12"},{"id":"0196c7a9-ea13-70a6-b18f-bf8769bf4be7","parentId":null,"rootId":null,"fromId":21642,"content":"都说双休的单位少，我每个月会有一两个周六到公司加班开会，发现上班高峰期车真不多，基本不堵车","createdAt":"2025-05-13T11:22:03"},{"id":"0196f0ed-150d-7303-a0ae-b1bb2f1d0d0c","parentId":null,"rootId":null,"fromId":460,"content":"对吧  还是双休多吧 周六早高峰 基本路上没有人","createdAt":"2025-05-21T11:39:51"}]