[{"id":"01963de0-cca9-72cf-bc30-929649c17e67","parentId":null,"rootId":null,"fromId":875,"content":"压两个月工资啥意思，这个月发1月的？","createdAt":"2023-03-28T18:52:59"},{"id":"01963de0-ccee-7162-8b2f-341a4850b4f9","parentId":null,"rootId":null,"fromId":2082,"content":"第一家公司就是在这，环保科技园那边的环境都很差","createdAt":"2023-03-29T09:23:15"},{"id":"01963de0-cd34-7232-a6f8-7c0e8554e9cd","parentId":null,"rootId":null,"fromId":3123,"content":"MLGB活干完了要转正了被部门经理压工资，装的一副人摸狗样背地里就是舔狗","createdAt":"2023-03-29T13:13:22"},{"id":"01963de0-cd83-70ad-a88e-e3362359df07","parentId":null,"rootId":null,"fromId":1150,"content":"啊 怎么政通老板成女的了？","createdAt":"2023-03-30T08:39:20"},{"id":"01963de0-cdd2-7343-803c-ffbe54c9d7b9","parentId":null,"rootId":null,"fromId":3150,"content":"加不完的班，没有加班工资，节假日也加班。","createdAt":"2023-03-30T16:18:35"},{"id":"01963de0-ce17-7108-8b11-cc1e858e16d3","parentId":null,"rootId":null,"fromId":2704,"content":"老板换成老董事长她闺女了。抠得很。\n压两个月工资是，三月底发二月份的工资，是月底哦，不到月底最后一天不发。","createdAt":"2023-03-30T16:18:38"},{"id":"01963de0-ce60-733d-b38d-1f4145a61b02","parentId":null,"rootId":null,"fromId":3150,"content":"是不是被老娘们看到了，提前一天发了工资","createdAt":"2023-03-30T16:23:40"},{"id":"01963de0-cea4-70bf-8b5b-421d9a1d325e","parentId":null,"rootId":null,"fromId":3152,"content":"转正被压工资？还有这么不讲武德的，那还干个屁！","createdAt":"2023-03-30T16:24:48"},{"id":"01963de0-cee8-716a-9e0f-fb1c5b1056bd","parentId":null,"rootId":null,"fromId":3169,"content":"真实情况并非如此，请客观评价，诽谤和夸张是没有意义的。老板很敬业，刚接手需要时间料理。","createdAt":"2023-03-31T20:57:02"},{"id":"01963de0-cf30-7243-8e56-c4b0270670ba","parentId":null,"rootId":null,"fromId":3150,"content":"对，9楼说的太对了，老板很敬业，不过就是违反劳动法，克扣工资，月底发工资，而已。","createdAt":"2023-04-01T10:33:17"},{"id":"01963de0-cf76-72cc-90c5-d751412a4443","parentId":null,"rootId":null,"fromId":3164,"content":"办公环境差我认同，环保科技园设施太旧了，上个厕所蹲个坑都难受","createdAt":"2023-04-03T21:51:33"},{"id":"01963de0-cfbd-72e2-91cc-a9b05b746366","parentId":null,"rootId":null,"fromId":21,"content":"待了一天就走了，这办公环境还不如厕所","createdAt":"2023-04-04T10:15:17"},{"id":"01963de0-d006-