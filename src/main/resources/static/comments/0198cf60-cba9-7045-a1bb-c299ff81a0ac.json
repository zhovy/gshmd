[{"id":"0198cf77-039e-70dc-8ac6-be5ae42c60dd","parentId":null,"rootId":null,"fromId":6747,"content":"他都怎么骚扰？电话不接不就完了\n上门了直接报警","createdAt":"2025-08-22T09:49:00"},{"id":"0198cf7b-a537-7104-9d51-0dda07c0d428","parentId":null,"rootId":null,"fromId":21818,"content":"屏蔽陌生人电话，慢慢就少了，后期一个月就一两个电话","createdAt":"2025-08-22T09:54:03"},{"id":"0198cf7c-e8af-73fa-a06d-586a407b1f0a","parentId":null,"rootId":null,"fromId":1049,"content":"你觉得祂们会管吗","createdAt":"2025-08-22T09:55:26"},{"id":"0198cf99-996d-70d8-b914-4ad82dbb8dde","parentId":null,"rootId":null,"fromId":7124,"content":"这个“祂” 很传神啊","createdAt":"2025-08-22T10:26:46"},{"id":"0198cf9a-ca77-723c-8a59-fe68ed28f64b","parentId":null,"rootId":null,"fromId":7124,"content":"不知道从哪儿得知的信息，直接打电话联系公司了，非说我是借款本人。这算不算污蔑，个人信息泄露","createdAt":"2025-08-22T10:28:04"},{"id":"0198cf9e-e833-7150-91cd-99d8ac318aca","parentId":null,"rootId":null,"fromId":7124,"content":"极高","createdAt":"2025-08-22T10:32:34"},{"id":"0198cfa1-5fb4-71e4-8261-41df705c3784","parentId":null,"rootId":null,"fromId":23274,"content":"一般进入社会，被上完第一课报叔叔帽子后，帽子叔叔会给你上社会第二课","createdAt":"2025-08-22T10:35:16"},{"id":"0198cfa2-84b4-7129-b388-65e1443b6d0b","parentId":null,"rootId":null,"fromId":6747,"content":"如果他跟公司说是你借款，那不就成了敲诈勒索？\n现在主要看公司的态度，能配合你报警是最好，不配合不提供可能是找借口裁你，\n我理解的重点是，说你是借款本人这个事到底是真实的还是公司编的。","createdAt":"2025-08-22T10:36:31"},{"id":"0198cfab-50a0-70e9-add6-7bec4f437cc5","parentId":null,"rootId":null,"fromId":1421,"content":"没用，如果是信用卡直接去金融投诉平台小程序投诉就可以，网贷不清楚","createdAt":"2025-08-22T10:46:07"},{"id":"0198cfb3-37ea-72e9-ab65-2b9299795b28","parentId":null,"rootId":null,"fromId":7124,"content":"公司没有裁人的意向，只是向我了解事实，我也提供了征信报告，但是第三方催债就是一直在骚扰","createdAt":"2025-08-22T10:54:45"},{"id":"0198cfb7-1bdf-71e9-b750-77ce49f4c938","parentId":null,"rootId":null,"fromId":21818,"content":"催债老套路了，什么都不管，就疯狂给你施压。","createdAt":"2025-08-22T10:59:00"},{"id":"0198cfcb-dd99-71f4-8503-d9993dedd9c3","parentId":null,"rootId":null,"fromId":6747,"content":"那就跟公司摊牌，你要报警让公司提供证据，这个事不就变成了以你的工作为威胁，让你向第三人施压让其转账。甚至是让你转账。\n如果说他当时借款的事你知道甚至是你本人确认过担保过就没办法了。\n最好是下次打电话让对方讲清楚诉求，是找人、代替还钱还是其他的，但是你全程别说你认识这人或者知道这事","createdAt":"2025-08-22T11:21:41"},{"id":"0198d0ae-ef92-71f4-8c6e-0e11b614ea67","parentId":null,"rootId":null,"fromId":1720,"content":"说句不好听的，你就是手机被偷了，人家都不管，这种小事就更不会管了","createdAt":"2025-08-22T15:29:42"},{"id":"0198d0cf-5d6c-7054-b6a8-93a45e5b23ae","parentId":null,"rootId":null,"fromId":5480,"content":"说点关键的， 你为什么被设置为紧急联系人？是故意的还是不小心？\n如果是故意的，帽子叔叔根本不会搭理你。\n如果是不小心，帽子叔叔就更没工夫搭理你了，你总不能指着帽子叔叔替你去找催收的吧。","createdAt":"2025-08-22T16:05:07"},{"id":"0198d0d2-b17b-70f6-8e30-0b33fb523621","parentId":null,"rootId":null,"fromId":1421,"content":"都这样了，告知联系人实际情况，谁没手头紧张的时候，无所谓了","createdAt":"2025-08-22T16:08:45"},{"id":"0198d4c1-0328-717e-9950-5039775e58f0","parentId":null,"rootId":null,"fromId":926,"content":"催收的都是短信、电话轰炸，有的还会上门，这些都不用搭理他们","createdAt":"2025-08-23T10:27:55"},{"id":"0198dc79-fd2f-713c-9c15-fa20b1ddda82","parentId":null,"rootId":null,"fromId":7170,"content":"这种情况，一般 我都直接开骂。欠钱的又不是我，怕啥","createdAt":"2025-08-24T22:27:18"}]