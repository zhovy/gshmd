[{"id":"01963de5-19aa-73e6-b7a5-ea20392ba300","parentId":null,"rootId":null,"fromId":3365,"content":"boss上职位好久了只减不增","createdAt":"2023-07-18T15:34:54"},{"id":"01963de5-19ee-7024-a0b3-5b2c2525b21f","parentId":null,"rootId":null,"fromId":2921,"content":"公司都只减不增，何况是职位。做好七年打算吧","createdAt":"2023-07-18T16:09:17"},{"id":"01963de5-19f2-71b9-b25f-00ed92d0ce49","parentId":null,"rootId":null,"fromId":2821,"content":"七年？","createdAt":"2023-07-18T16:14:00"},{"id":"01963de5-19f6-703e-8115-014150e3e037","parentId":null,"rootId":null,"fromId":2197,"content":"找了俩月了，都没几个能投简历的工作，看看别的城市还有几个，看看济南真是心都凉透了\n","createdAt":"2023-07-18T16:45:50"},{"id":"01963de5-1a3e-7179-b7d3-deed215cba11","parentId":null,"rootId":null,"fromId":4016,"content":"先把这网站的黑名单过滤掉，然后，就没了","createdAt":"2023-07-18T17:09:41"},{"id":"01963de5-1a4b-70f6-b8d9-e3550131c3bc","parentId":null,"rootId":null,"fromId":875,"content":"济南公司都是干啥的，干几个国企项目倒不了而且，一个一个的都上不了市，哪里有钱招人","createdAt":"2023-07-18T18:16:46"},{"id":"01963de5-1a42-71a6-93d7-e35cabf04e30","parentId":null,"rootId":null,"fromId":2197,"content":"黑名单里边的有的还可以考虑，但是像那种热门的：泰山、人人人阳等拖工资乱扣钱啥的好多人都说坑的肯定就pass了","createdAt":"2023-07-18T18:33:25"},{"id":"01963de5-1aa7-71e3-8837-bb3f6364d26f","parentId":null,"rootId":null,"fromId":414,"content":"今年真是太难了，找了一个半月了，boss都不想翻了","createdAt":"2023-07-18T18:52:35"},{"id":"01963de5-1b0d-70bb-af54-837b8a5a5621","parentId":null,"rootId":null,"fromId":1261,"content":"两年最少10k，少了再找","createdAt":"2023-07-18T20:02:55"},{"id":"01963de5-1b53-7156-b2ef-9397b6514eb4","parentId":null,"rootId":null,"fromId":1398,"content":"你说的是济南吗\n","createdAt":"2023-07-18T21:49:06"},{"id":"01963de5-1af5-70f3-9ba2-fa142f84fc44","parentId":null,"rootId":null,"fromId":1398,"content":"你一般工资都要多少啊","createdAt":"2023-07-18T21:49:28"},{"id":"01963de5-1af9-7022-9319-41dbc78e7a0b","parentId":null,"rootId":null,"fromId":414,"content":"还不到工资那一步，是几乎没有可以值得投递的公司","createdAt":"2023-07-18T22:05:23"},{"id":"01963de5-1b5c-7356-8d4c-72e7ff78ee34","parentId":null,"rootId":null,"fromId":875,"content":"不在济南找了，我要去给马斯克打工去，1.5倍绩效，一年17薪，在济南给私企老板当牛做马，到头来落下来啥，每月两百公积金，最低基数社保，没有年假，没有餐补，周六无偿加班……醒醒吧，还不如人家特斯拉厂里的工人福利好，工资高\nIT之家 7 月 18 日消息，日前，特斯拉上海超级工厂有多位员工表示，他们最近获得的 2023 年第二季度绩效奖金大幅增加，达到月度基本工资的 1.5 倍。\n\n\n\n据上海证券报报道，今日特斯拉中国有关人士回应称，特斯拉上海超级工厂员工人数众多，目前还无法对加薪的相关情况予以回应。\n\nIT之家注意到，今年早些时候，有上海工厂工人曾向特斯拉创始人、CEO 埃隆・马斯克投诉对奖金的不满。对此，马斯克表示将进行调查。但值得一提的是，特斯拉在第二季度交付了 24.7 万辆中国产电动汽车，这是其上海工厂开业以来的最高水平。\n\n此前有特斯拉工作人员透露，一名特斯拉上海工厂一线普通工人，每月基本工资超过 5 千，其他收入有奖金、津贴、加班费等，1 年 17 薪，平均下来月收入接近 1 万元。此外还有 7% 的五险一金，5% 的住房公积金，免费工作餐，免费班车，全家免费商业保险等等。马斯克此前感叹，中国工人完全配得起月薪上万的待遇。","createdAt":"2023-07-18T22:50:16"},{"id":"01963de5-1ba9-73d1-abd5-13790c942266","parentId":null,"rootId":null,"fromId":460,"content":"明末那时候，清朝的优厚条件倒打开了明朝的关宁锦防线，明朝满饷不能敌，南下打明朝江山的基本上也是明兵居多。","createdAt":"2023-07-19T08:08:20"},{"id":"01963de5-1bf4-710d-8fe9-2fa296f4bd51","parentId":null,"rootId":null,"fromId":3801,"content":"今年济南IT就业形势严峻，我周围除了大厂没招应届生的，稍微优质点的公司，优质点的岗位，只要招聘优先走内推，大量社招的要不就是公司不行，离职率高，要不就是外包！","createdAt":"2023-07-19T08:23:15"},{"id":"01963de5-1afe-70c2-8149-2e4bf659c19e","parentId":null,"rootId":null,"fromId":2197,"content":"和我一样啊，各个招聘软件翻遍了，没有几个能投的，济南真是愁死人了","createdAt":"2023-07-19T08:24:14"},{"id":"01963de5-1c37-72e8-b080-06ed508b59c2","parentId":null,"rootId":null,"fromId":875,"content":"赶紧去北上广捞钱呀","createdAt":"2023-07-19T08:32:52"},{"id":"01963de5-1c3b-73cd-8c28-275173b0906c","parentId":null,"rootId":null,"fromId":3801,"content":"据北京、广州的朋友反馈，他们那边形势也不好，招聘市场还不如疫情期间，现在都是提高招聘门槛，降低招聘工资，减少不必要的岗位。上海的行情不了解，没有认识的朋友。","createdAt":"2023-07-19T08:39:57"},{"id":"01963de5-1bef-72e0-9fd0-c1d9f7858f8d","parentId":null,"rootId":null,"fromId":1225,"content":"很正常啊，说明老百姓务实，不傻。","createdAt":"2023-07-19T08:44:42"},{"id":"01963de5-1b04-73ef-a150-945521d4ba25","parentId":null,"rootId":null,"fromId":576,"content":"你几年啊 找这么久   我咋裸辞10天就找到了呢","createdAt":"2023-07-19T09:08:09"},{"id":"01963de5-1b58-710b-8cc6-02ab708af312","parentId":null,"rootId":null,"fromId":793,"content":"我觉得不是","createdAt":"2023-07-19T09:26:04"},{"id":"01963de5-1c40-7315-9939-1f723d8cc198","parentId":null,"rootId":null,"fromId":576,"content":"emmmmm，我感觉还行啊  我还是裸辞找的","createdAt":"2023-07-19T09:28:44"},{"id":"01963de5-1b08-723f-b613-6b56ce215bd8","parentId":null,"rootId":null,"fromId":414,"content":"你找的是外包吗，我是测试，几乎全是外包在招聘，主要是浪潮和城商行联盟的外包","createdAt":"2023-07-19T10:05:36"},{"id":"01963de5-1c8b-7379-9ad3-4af5bf822f00","parentId":null,"rootId":null,"fromId":875,"content":"你找工作难，企业招个人更难，所以不要怕，工资要多要，高薪捡漏就趁现在","createdAt":"2023-07-19T19:26:10"},{"id":"01963de5-1a47-7362-8222-3906ad2db7e6","parentId":null,"rootId":null,"fromId":576,"content":"然后就没了   哈哈哈哈","createdAt":"2023-07-24T10:25:56"},{"id":"01963de5-1ccf-701a-b13c-e32cc0eac537","parentId":null,"rootId":null,"fromId":2478,"content":"boss和智联上90%的招聘的都是外包，其中鲁软中泰中心的又能占90%，最近不好找工作，我也一直在看，没啥好工作","createdAt":"2023-07-26T16:17:52"},{"id":"01963de5-1c86-7238-810e-3122b66396c5","parentId":null,"rootId":null,"fromId":2478,"content":"啥公司，推荐下","createdAt":"2023-07-26T16:18:15"}]