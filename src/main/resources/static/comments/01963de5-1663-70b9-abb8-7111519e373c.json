[{"id":"01963de5-16ca-7130-b916-916670a838a4","parentId":null,"rootId":null,"fromId":3801,"content":"包装简历，简历太简单了一般都是直接进回收站，据我认识的人事说，一个岗位现在收到几百份简历，学历筛一批、经历筛一批，剩下的再通知面试。实在不行换城市试试！","createdAt":"2023-07-19T10:03:20"},{"id":"01963de5-1714-70e2-9e32-113b258e2ab9","parentId":null,"rootId":null,"fromId":4037,"content":"在济南，如果你的简历上没有学历。经验，年限的亮度，确实很难约到面试","createdAt":"2023-07-19T13:27:49"},{"id":"01963de5-175a-72a6-bc8e-d242e753cade","parentId":null,"rootId":null,"fromId":4143,"content":"换城市\n找前同事推荐\n去小公司，外包","createdAt":"2023-07-20T10:23:27"},{"id":"01963de5-179f-70e2-a168-c77d4fc3f77a","parentId":null,"rootId":null,"fromId":4030,"content":"短短几个字，提供了好多方法","createdAt":"2023-07-20T11:13:55"}]