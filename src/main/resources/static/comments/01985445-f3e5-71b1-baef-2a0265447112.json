[{"id":"01985449-da33-702b-a83f-d00a8e20d959","parentId":null,"rootId":null,"fromId":7074,"content":"卷王们赶紧都去青岛吧","createdAt":"2025-07-29T11:46:22"},{"id":"01985466-2d90-7113-aad2-e76f3e24c430","parentId":null,"rootId":null,"fromId":1421,"content":"在济南待了三年去年来的青岛，青岛这边确实好点，济南都是围绕几个电力能源高速的企业来做项目，要不就是做浪潮神思之类的分包项目，青岛虽然也有海尔海信这样的分包项目，但是青岛的中型企业(目前我这个做物流的企业)这类型企业济南感觉没多少，这些企业支撑了很多软件就业人数，感觉如果不是这些年省会城市整合了一些国企资源GDP这个指标其实很难看","createdAt":"2025-07-29T12:17:19"},{"id":"019854e3-5887-709b-8d58-6ea12f966485","parentId":null,"rootId":null,"fromId":25953,"content":"青岛确实不错，好多互联网企业","createdAt":"2025-07-29T14:34:02"},{"id":"019854eb-606d-7190-aa9c-e96f91365469","parentId":null,"rootId":null,"fromId":2056,"content":"确实，济南就没几个这种高新技术企业。找工作都是外包。岗位少薪资低","createdAt":"2025-07-29T14:42:48"},{"id":"019854f1-d33b-7054-81f1-17924ad473e8","parentId":null,"rootId":null,"fromId":5755,"content":"国企/事业单位一卡预算，济南的软件行业直接凉了一半","createdAt":"2025-07-29T14:49:51"},{"id":"019854f8-5f22-71ff-a7f4-ac415914ae79","parentId":null,"rootId":null,"fromId":21396,"content":"去年已经润青岛来了，现在待得很舒服","createdAt":"2025-07-29T14:57:00"},{"id":"01985564-73d2-706b-98d1-278ed1548553","parentId":null,"rootId":null,"fromId":2246,"content":"你呆一段时间再说吧，看看他俩谁更垃圾","createdAt":"2025-07-29T16:55:03"},{"id":"019856ba-0d89-73fb-99a0-ff2a833ccc7f","parentId":null,"rootId":null,"fromId":267,"content":"济南试用期不交社保不交公积金的很多","createdAt":"2025-07-29T23:08:10"},{"id":"01985907-c100-7233-b675-9c116222b689","parentId":null,"rootId":null,"fromId":21434,"content":"青岛也一般，知道你是济南来的，就会说青岛的薪资待遇比不上济南来忽悠你","createdAt":"2025-07-30T09:52:17"},{"id":"0199092e-e3cc-736c-a170-748ee4e89770","parentId":null,"rootId":null,"fromId":1538,"content":"青岛会不会花销更高呀,房子不得老贵了","createdAt":"2025-09-02T14:48:11"},{"id":"01990988-012a-732d-ba23-3d7f584adf9c","parentId":null,"rootId":null,"fromId":2056,"content":"跟济南差不多","createdAt":"2025-09-02T16:25:32"}]