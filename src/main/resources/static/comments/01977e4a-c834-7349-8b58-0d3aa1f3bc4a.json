[{"id":"01977fe9-e6bf-7159-9ea7-5c026a62e60b","parentId":null,"rootId":null,"fromId":24615,"content":"水硕的话建议去北上广大城市找工作，来济南没啥好找的","createdAt":"2025-06-18T06:02:04"},{"id":"0197806c-108e-7004-8bf0-997f368f7ea7","parentId":null,"rootId":null,"fromId":460,"content":"济南这头猪，吃不了你这个细糠。在济南大专够用了","createdAt":"2025-06-18T08:24:15"},{"id":"0197808b-55a6-7306-90c2-de85d2eb380a","parentId":null,"rootId":null,"fromId":23684,"content":"别来济南了","createdAt":"2025-06-18T08:58:24"},{"id":"0197808c-f1f6-704b-b91b-5f74c1d92409","parentId":null,"rootId":null,"fromId":6221,"content":"济南缅北收不收你还两说呢，建议你还是回到你的头部零售","createdAt":"2025-06-18T09:00:10"},{"id":"01978090-a198-7345-8049-4d90741ebad1","parentId":null,"rootId":null,"fromId":21267,"content":"别来，济南不需要你，不是讽刺你，是济南配不上你，济南每年往外边流失很多人，你来不属于逆水行舟了嘛","createdAt":"2025-06-18T09:04:11"},{"id":"01978092-a137-73bc-b130-f86871153299","parentId":null,"rootId":null,"fromId":414,"content":"济南真的很烂，法外之地，公司基本都是小作坊，不守法的地方非常多，我媳妇就是上海回来的，回来两年多了还是不适应","createdAt":"2025-06-18T09:06:22"},{"id":"01978095-5f10-70f2-a2d2-348d73c66068","parentId":null,"rootId":null,"fromId":414,"content":"济南比较大的公司，浪潮，中孚，山大华天，海康，中创等等，都很卷，各种要求加班，薪资也不是很高，其他福利项也是几乎可以忽略，然后各种恶心人的制度和细节吧，总之从一线来的，需要适应很久","createdAt":"2025-06-18T09:09:22"},{"id":"0197809e-8263-71fa-9999-332cb769bda6","parentId":null,"rootId":null,"fromId":1049,"content":"我这济南的本地人都受不了济南的就业环境，跑出去了。。。","createdAt":"2025-06-18T09:19:21"},{"id":"0197809f-2aa8-70e7-886c-fe508e2f3c9c","parentId":null,"rootId":null,"fromId":6517,"content":"华天也是大公司了吗，我还以为是小公司","createdAt":"2025-06-18T09:20:04"},{"id":"019780ac-1adb-7072-9146-e6bfd51215e0","parentId":null,"rootId":null,"fromId":414,"content":"我是根据人数评定的，济南稍大点的公司就那么几个","createdAt":"2025-06-18T09:34:12"},{"id":"01979aaa-e6f6-7224-9de6-75f39687818e","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-06-23T10:43:00"},{"id":"01979bfb-56c6-7050-9bad-65965c2f8fa6","parentId":null,"rootId":null,"fromId":3346,"content":"中孚参保人数216，认真的吗？","createdAt":"2025-06-23T16:50:29"},{"id":"01979f99-3907-7285-bdab-e4c070ce2896","parentId":null,"rootId":null,"fromId":23300,"content":"尽量别选择济南，济南大部分，上规模的企业基本都是那种纯国企，事业单位，招聘非常之卷，这种单位社招都开始博士起步了，研究生起步都得找关系那种，剩下的那些个国资控股，私企，家庭作坊，待遇和人文环境，工作环境，一个比一个感人，基本就是屎坑里找糖，如果你能够忍受就行。别指望改革春风能尽快刮过来，几千年的主副陪，鱼头朝哪的文化到现在都没灭亡。。。","createdAt":"2025-06-24T09:41:48"},{"id":"0197fd56-5c1c-73f6-8f2b-f44a7e16d18e","parentId":null,"rootId":null,"fromId":25777,"content":"还是再回上海吧","createdAt":"2025-07-12T14:33:04"}]