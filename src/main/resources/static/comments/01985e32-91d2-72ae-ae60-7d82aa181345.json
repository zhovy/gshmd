[{"id":"01985e39-9aa9-72f7-bfb7-ad5d20098ec6","parentId":null,"rootId":null,"fromId":6435,"content":"你这是要去我们镇上干活吗","createdAt":"2025-07-31T10:04:50"},{"id":"01985e3c-c9f1-7362-80ac-b002f300b37e","parentId":null,"rootId":null,"fromId":5559,"content":"哈哈  有猎头在推   在济南机会实在不多。不知道里面咋样   有欠薪之类的吗   加班狠不狠","createdAt":"2025-07-31T10:08:18"},{"id":"01985e49-0e75-720a-afe1-4e3ca2c29581","parentId":null,"rootId":null,"fromId":6435,"content":"技术岗我不知道，但其他普通岗位，之前的话欠薪是常态，欠半年以上是正常操作，现在我不清楚了","createdAt":"2025-07-31T10:21:42"},{"id":"01985e59-6906-7098-857e-1b7a52186d94","parentId":null,"rootId":null,"fromId":25236,"content":"欠薪是常态，领导也贼恶心，不讲理，别去","createdAt":"2025-07-31T10:39:34"},{"id":"01985f93-f2e6-70b3-b25c-a00b94429e1e","parentId":null,"rootId":null,"fromId":3450,"content":"九羊去年就在挖我，前两天又来挖，看来是去年招的人都跑光了","createdAt":"2025-07-31T16:23:08"},{"id":"01986109-c97f-73af-aecb-78b4c13bd880","parentId":null,"rootId":null,"fromId":267,"content":"人员流动太频繁了吧，感觉预示着管理混乱呢","createdAt":"2025-07-31T23:11:28"},{"id":"0198644b-0b9c-7251-8ac5-878e6afd502c","parentId":null,"rootId":null,"fromId":5559,"content":"现在总共20多个人   几个主管   十几个开发人员,  不知道里面人员变动频不频繁","createdAt":"2025-08-01T14:21:36"},{"id":"01986830-011c-71c6-bb5b-bbcffc722be6","parentId":null,"rootId":null,"fromId":5559,"content":"这两年有入职九羊信息化的兄弟吗    可以说说真实情况","createdAt":"2025-08-02T08:30:33"},{"id":"0198c1a1-7bfa-72e8-9c2f-f896945b69b9","parentId":null,"rootId":null,"fromId":22580,"content":"这个公司给我打了三次电话了，我都拒绝了。。。太偏僻了","createdAt":"2025-08-19T17:20:42"},{"id":"0198c587-3bd5-70b6-9165-fb2beb26ef39","parentId":null,"rootId":null,"fromId":1049,"content":"九羊那个面试官挺SB的，他开的那点薪资，在南方轻轻松松的拿，如探囊取物","createdAt":"2025-08-20T11:30:30"},{"id":"0198c591-e2ad-7286-a233-9bc9f2384085","parentId":null,"rootId":null,"fromId":1421,"content":"不加班不欠薪，工资不高但是在这消费也不高，由于位置原因流动性确实大","createdAt":"2025-08-20T11:42:09"},{"id":"0198c599-6dd0-722c-853b-4ec88fda4517","parentId":null,"rootId":null,"fromId":1421,"content":"各位伙伴，我看了大家在帖子里的讨论，在这里统一做个说明：\n其一，截至目前，九羊公司信息岗位招聘从未借助猎头开展人才寻访工作。\n其二，关于薪资，我们公司的工资从未出现过拖欠情况，请大家放心。另外，在薪资对比上，大家不要简单地将三四线城市岗位与一二线城市岗位相提并论。","createdAt":"2025-08-20T11:50:23"}]