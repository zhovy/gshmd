[{"id":"01963df4-85dd-71a5-ac53-47ec5b49fe98","parentId":null,"rootId":null,"fromId":3341,"content":"全称 是思路智园吗？或者说是思路智圆的分公司？","createdAt":"2024-11-11T09:25:28"},{"id":"01963df4-8620-738a-89bb-ff9152f7fb2d","parentId":null,"rootId":null,"fromId":22226,"content":"应该是，这公司怎么样呢？","createdAt":"2024-11-11T09:42:52"},{"id":"01963df4-8625-719d-bd8e-c24f9dc49f81","parentId":null,"rootId":null,"fromId":4101,"content":"在济南开分公司了吗这是，也是我老东家，当时公司在北京，做智慧园区的，福利待遇可以，工资没拖欠或者延迟发放过，没怎么加过班，除了比较急的那几天，还挺不错（仅限于我离职之前，现在不知道啥情况）","createdAt":"2024-11-11T10:34:03"},{"id":"01963df4-8668-72a2-a88c-be9eb59670ef","parentId":null,"rootId":null,"fromId":22226,"content":"那听起来还不错，我看到他们有招聘安全岗位，准备试试","createdAt":"2024-11-11T19:15:36"},{"id":"01963df4-866c-729d-9cf9-5a738acd03bb","parentId":null,"rootId":null,"fromId":22229,"content":"这个公司项目助理咋样啊，他说基本都要出差，在化工厂吗？","createdAt":"2024-11-12T08:12:30"},{"id":"01963df4-867e-7216-97ce-0c9bf71feadf","parentId":null,"rootId":null,"fromId":22229,"content":"你去面了吗老哥","createdAt":"2024-11-12T08:12:44"},{"id":"01963df4-8671-7098-8032-d66aa2765758","parentId":null,"rootId":null,"fromId":4101,"content":"这个就不知道了，以前也做过智慧工厂的业务，会有一些厂商之类去出差过，当时项目经理以及产品出差多一点，研发就一直在公司待着，可以试试，出差有补助，当月就能报销，工资年终反正没有拖欠过","createdAt":"2024-11-12T16:08:03"},{"id":"01963df4-8675-722a-a07b-3d8030f47c41","parentId":null,"rootId":null,"fromId":4101,"content":"对了，他们对员工陪养机制比较完善，不会过分压榨，一般入职都会有有人带着熟悉项目业务啥的，还有培训，","createdAt":"2024-11-12T16:09:45"},{"id":"01963df4-867a-7310-8f7f-c61ad66591cd","parentId":null,"rootId":null,"fromId":4101,"content":"当然，现在具体以济南这边公司为准了，肯定会有些差别的","createdAt":"2024-11-12T16:10:32"},{"id":"01963df4-86c5-725e-a698-1996a93ddfef","parentId":null,"rootId":null,"fromId":6274,"content":"哈哈 非常不认同前面说的","createdAt":"2024-11-14T09:45:52"},{"id":"01963df4-8709-710a-be86-726cb8059237","parentId":null,"rootId":null,"fromId":22258,"content":"兄弟，刚面过，此话怎讲，可以详细说下嘛","createdAt":"2024-11-14T19:08:41"},{"id":"01963df4-870d-7250-be2b-813060cce521","parentId":null,"rootId":null,"fromId":22226,"content":"怎么呢哥？能详细说说吗？","createdAt":"2024-11-15T17:29:42"},{"id":"01963df4-8712-7393-a1ec-bae55135674c","parentId":null,"rootId":null,"fromId":22282,"content":"智园科技挺好的啊 突然看见我的前公司了  济南算是总部了现在人都在济南比较多  我是去年离职的 但是我是因为家里给找了关系的工作才走的   你如果面试通过了能入职就珍惜吧 现在找个靠谱的公司多难啊  哪有完美的公司","createdAt":"2024-11-19T07:31:40"},{"id":"01963df4-8756-73bf-bbfe-c183d1995f8d","parentId":null,"rootId":null,"fromId":21956,"content":"不错的，推荐，做化工智慧工业园区，比我前司好，选对公司很重要","createdAt":"2024-11-19T07:53:33"},{"id":"01963df4-879a-721c-917b-151bacecd646","parentId":null,"rootId":null,"fromId":600,"content":"公司是个好公司 奈何环境确实差 导致挺困难","createdAt":"2024-12-02T15:50:23"},{"id":"01963df4-87e7-73ec-bfeb-b3c01f403c07","parentId":null,"rootId":null,"fromId":22629,"content":"别来","createdAt":"2025-01-17T11:47:07"},{"id":"01983bd7-b5ff-72c0-833e-51292192fe4f","parentId":null,"rootId":null,"fromId":22629,"content":"别来","createdAt":"2025-07-24T17:50:49"},{"id":"0198acf6-cd76-73b0-9720-a990c9022d9c","parentId":null,"rootId":null,"fromId":22547,"content":"前一段时间工资缓发15%，最近补发了，又开始全员降薪均降15%，不接受降薪的只能n+1补偿走人","createdAt":"2025-08-15T17:01:52"},{"id":"0198b13d-7878-7138-9e3c-47d977f03691","parentId":null,"rootId":null,"fromId":23223,"content":"给n+1走人算是还不差了，有些公司年轻人多的，直接糊弄人劝退，一分不赔，毕竟山东人老实","createdAt":"2025-08-16T12:57:32"},{"id":"0198bb45-fa74-7112-ade0-386087e3cda9","parentId":null,"rootId":null,"fromId":22547,"content":"是啊，大老板和二老板经营策略不一致，降薪就是逼人走，每个月都有几个优化人的名额，就为了降低经营成本","createdAt":"2025-08-18T11:43:02"}]