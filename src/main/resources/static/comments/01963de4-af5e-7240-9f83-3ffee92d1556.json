[{"id":"01963de4-afcb-7287-a2b6-1349ddd5cac9","parentId":null,"rootId":null,"fromId":875,"content":"济南普通人是没有机会的，趁着年轻早点考公务员，不然35只能开滴滴送外卖","createdAt":"2023-07-08T21:45:03"},{"id":"01963de4-b00f-73df-b5c0-6ca585c44f1c","parentId":null,"rootId":null,"fromId":4014,"content":"今年工作不好找，工资要不动","createdAt":"2023-07-08T22:18:09"},{"id":"01963de4-b054-70a2-a279-ad4061327c74","parentId":null,"rootId":null,"fromId":1401,"content":"干公务员也一样，不论那个行业，八面玲珑的人都能吃的开","createdAt":"2023-07-09T09:33:14"},{"id":"01963de4-b09a-7105-8205-3d9ef237460d","parentId":null,"rootId":null,"fromId":875,"content":"说的对，要不怎么说济南干销售的一个个年薪三十多万，写代码的的二十万的都不多","createdAt":"2023-07-09T10:35:54"},{"id":"01963de4-b0e4-7035-9135-bdd2d59fff6b","parentId":null,"rootId":null,"fromId":875,"content":"关键是得会舔","createdAt":"2023-07-10T20:22:29"},{"id":"01963de4-b0e8-7221-a50e-41d304a7c40f","parentId":null,"rootId":null,"fromId":4010,"content":"是的，本人在一线几个大公司待过几年，那边更看重技术成长，平时技术分享跨部门的评级考核一样不少，面试难度也很高。济南这边公司不看重技术，就是单纯能做东西就行，要求比较低；另外公司氛围不一样，北京部门领导和员工一般情况下处的像朋友一样，氛围比较轻松，济南这边比较官僚主义，官大一级压死人，另外就是你说的这边是人情社会，会溜须拍马的混得好，攀关系的也多，任人唯亲比较常见","createdAt":"2023-07-14T15:35:12"},{"id":"01963de4-b131-704f-9adb-44e20e56ac5d","parentId":null,"rootId":null,"fromId":2436,"content":"还是没有技术环境，外面都实现扁平化管理多少年了，济南依旧官僚。嘲笑山东人考公的大概是不知道私企的情况，既然环境差不多为什么不选个更好的途径——考公","createdAt":"2023-07-14T15:39:55"},{"id":"01963de4-b136-711a-9299-1157e0a61907","parentId":null,"rootId":null,"fromId":4010,"content":"还是管理方式思维方式的问题，管理人员思想保守迂腐，没有实际感受过一线互联网的工作氛围，上行下效，济南这种工作氛围需要更多一线互联网公司回来的人带队才能解决","createdAt":"2023-07-14T16:21:44"}]