[{"id":"019b24d2-6f63-72c3-a92b-2e4b93825b9c","parentId":null,"rootId":null,"fromId":5635,"content":"能者多劳吗，并不是，巴不得让你一个人干三个人的活","createdAt":"2025-12-16T09:42:09"},{"id":"019b24ef-7be6-70b9-ab18-f62fc8dda0a8","parentId":null,"rootId":null,"fromId":7078,"content":"能干的人多干吗","createdAt":"2025-12-16T10:13:53"},{"id":"019b2527-c590-71d3-95b8-5a2ba0078598","parentId":null,"rootId":null,"fromId":5480,"content":"不能者，不见得比你拿的少，多劳少劳，正常应当跟收入挂钩，而不是能与不能，关系亲疏。不过社会现状就是这样，没法改变","createdAt":"2025-12-16T11:15:22"},{"id":"019b25e1-b14c-7001-95a1-85348ad09bbd","parentId":null,"rootId":null,"fromId":27118,"content":"能者多劳是真的，多劳多得是假的","createdAt":"2025-12-16T14:38:26"},{"id":"019b263f-8406-70d0-946a-6bd276064b11","parentId":null,"rootId":null,"fromId":3279,"content":"这个社会是能者多得，而且只有多得才证明你是能者。&lt;br /&gt; 如果你觉得自己是能者，多劳了但是没多得，证明你不是能者。&lt;br /&gt; 或者换个更简单的问题，这个社会还讲多劳多得吗？当然是否。","createdAt":"2025-12-16T16:20:55"},{"id":"019b2645-9adb-70ea-9d61-872a93f3bcce","parentId":null,"rootId":null,"fromId":6091,"content":"叽里呱啦得说得啥玩意","createdAt":"2025-12-16T16:27:34"}]