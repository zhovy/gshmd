[{"id":"01963de4-56c4-7277-b9c1-6d9cdcd4fe79","parentId":null,"rootId":null,"fromId":52,"content":"济南神博信息技术有限公司\n神博(山东)安防科技公司 的法人又换了一家公司 叫 山东松鋆安全技术有限公司","createdAt":"2023-11-30T17:35:48"},{"id":"01963de4-5708-7152-b924-bdf3eafb5b01","parentId":null,"rootId":null,"fromId":7284,"content":"文档没了","createdAt":"2024-04-25T22:49:12"},{"id":"01963de4-574d-710c-8a7c-a001a7c48870","parentId":null,"rootId":null,"fromId":7280,"content":"加一个   山东家齐科技有限公司，还有山东赛威尔信息工程，这两个是一家，垃圾公司","createdAt":"2024-04-28T16:27:00"},{"id":"01963de4-5792-71b8-95d9-17b2a7ec3240","parentId":null,"rootId":null,"fromId":7460,"content":"幼吾幼，庙小妖风大，给钱少活多内部有斗争，时刻准备换人，主打一个你不干有人干，你不接受就再见","createdAt":"2024-05-23T12:18:59"},{"id":"01963de4-57d6-735a-838b-ac6f55a5e008","parentId":null,"rootId":null,"fromId":21315,"content":"山东大盾信息科技有限公司 山东大盾知识产权运营有限公司 山东大盾科创集团 大盾科创中心，一个老板开的，老板骗子一个！","createdAt":"2024-07-11T08:18:51"},{"id":"01963de4-581b-7226-a02d-dc55059b6f2e","parentId":null,"rootId":null,"fromId":3971,"content":"中星智慧云企，跟张乐有关系的这俩都欠薪","createdAt":"2024-07-19T09:33:57"},{"id":"01963de4-5862-72b4-8acd-774a5ee0cfca","parentId":null,"rootId":null,"fromId":5874,"content":"山东遨博智能科技有限公司","createdAt":"2024-10-13T17:26:06"},{"id":"01963de4-58a6-7039-b2e4-5b8ee4811c0c","parentId":null,"rootId":null,"fromId":22604,"content":"加一个永熙科技 地址祥泰广场，克扣工作，欠薪都是常态，PUA你到抑郁，你能正常转正算你厉害。公司秉承用新人原则。你若想来还有幸让你成为法人哦！","createdAt":"2025-01-10T16:12:10"},{"id":"01963de4-58ee-707f-b8cd-e6321ba9ea78","parentId":null,"rootId":null,"fromId":22604,"content":"真的是神一般的公司，要账报警、员工仲裁，欠薪，凭心情扣工资，老板怀疑猜忌。老板绝对是前无古人后无来者。","createdAt":"2025-01-10T16:15:31"},{"id":"01963de4-58f2-708c-a61d-94d1a72d29e5","parentId":null,"rootId":null,"fromId":22452,"content":"山东中思信息科技","createdAt":"2025-01-24T14:30:56"},{"id":"01963de4-5937-7089-a7f7-098c441e738a","parentId":null,"rootId":null,"fromId":22452,"content":"+1","createdAt":"2025-01-24T14:31:21"},{"id":"01963de4-593c-70ae-8775-e825df4cfa6d","parentId":null,"rootId":null,"fromId":22452,"content":"压缩研发周期","createdAt":"2025-01-24T14:32:00"},{"id":"01963de4-5940-71d2-8459-e9669fb75dfe","parentId":null,"rootId":null,"fromId":22670,"content":"13123444123","createdAt":"2025-02-06T18:05:58"},{"id":"01963de4-5985-71fe-938d-1b9e292187a2","parentId":null,"rootId":null,"fromId":22670,"content":"那家教育好的要死","createdAt":"2025-02-06T18:06:09"},{"id":"01963de4-59c9-7045-b1f8-790936f5fa1d","parentId":null,"rootId":null,"fromId":22670,"content":"那家教育这个公司，我是最有发言权的了，跟大家聊一下。\n本人在那家教育工作了20天整，在第19天的时候，贵公司HR以我刷智联的名义，把我辞退，我问公司有哪一项规定不允许别人刷BOSS和智联？最后还是辞退了，最后结算工资的时候，贵公司以我不满15个工作日为由，只支付工资的百分之50，让人大跌眼镜真是没一点格局，我说我已经入职20天了，贵公司说工作日是上班的天数，不包含法定节假日和调休，公司真是这个?。结算工资的HR一副欠了他钱，偷她电瓶车电瓶的狗模样，跟我阴阳怪气大哥大哥的叫，真是不害臊，奉劝各位找工作的时候提前问一下如果不满多少个工作日，工资结算多少，不然有某公司故意卡你入职时间辞退你，不点名了。","createdAt":"2025-02-06T18:12:15"},{"id":"01963de4-5a0b-7397-a58f-6544642a4f6d","parentId":null,"rootId":null,"fromId":7727,"content":"楼主申诉一下文档，被封了不能看了","createdAt":"2025-02-07T15:05:46"},{"id":"01963de4-5a50-71ab-9d02-5f230b78e2f6","parentId":null,"rootId":null,"fromId":6170,"content":"楼主申诉下文档，被封了，不能看了","createdAt":"2025-02-09T16:36:14"},{"id":"0196659c-ea73-73f3-9f99-e2341793f646","parentId":null,"rootId":null,"fromId":23692,"content":"黑名单还能补吗？大佬们谁有备份再发一份","createdAt":"2025-04-24T10:25:04"},{"id":"01966b9c-3c96-726a-8b7a-d2d741828a04","parentId":null,"rootId":null,"fromId":23735,"content":"山东承天信息科技 房清侠 日常拖欠工资 天天开会 强制大小周 节假日值班 老板就是一煞笔","createdAt":"2025-04-25T14:22:03"},{"id":"0196c86e-e5e0-729d-8a5e-15096af24ac5","parentId":null,"rootId":null,"fromId":801,"content":"加一个山东通广电子,济南通慧公司是它的子公司,槽点可以直接搜索公司名看,只能说是招纯牛马,服从性高的","createdAt":"2025-05-13T14:57:13"},{"id":"0196cd1b-00ea-711e-ad1d-b56bc5d67670","parentId":null,"rootId":null,"fromId":6170,"content":"文档封了，老哥能给发一份吗  2453720047@qq.com","createdAt":"2025-05-14T12:43:41"},{"id":"0196cd92-47bc-72be-9442-e0c6fcdaa10f","parentId":null,"rootId":null,"fromId":801,"content":"我也没有文档,老哥","createdAt":"2025-05-14T14:53:58"},{"id":"01999b38-9e59-7264-a1aa-e97df881ba68","parentId":null,"rootId":null,"fromId":7741,"content":"加一个-深蓝智谱数字科技\n1.此公司每年都会聘一些前后端，说是双休加班补偿，实际上什么都没有，单休每天都有硬性要求加班到8点才能走即使是没有工作的情况，\n2.里面管理层非常混乱内斗不断，关系户很多，舔狗忠犬非常多(放个p都得说是香的那种)，想提升自己晋升的在这就别考虑了。\n3.长期996，平时加班没有任何补贴（餐补，加班费都没）周六加班只能换调休，如果你不服从会被谈话降薪。\n4.老板极度会画饼，天天说团建什么的一直拿着忙当理由鸽着，嘴上说着做人要诚实守信真是搞笑。\n4.如果你是新员工,当公司活少的时候部门会各种找理由（例如说有人检举你工作慢，bug多什么的硬扣帽子）把人给裁掉，并且想方设法威胁你不让你走N+1失业补偿。\nps:总之过来人提醒无论是你毕业生还是工作3年以上的老码农千万不要来这公司浪费时间。","createdAt":"2025-09-30T23:23:23"}]