[{"id":"01963ddd-2d32-72c0-aaef-28e4813103f3","parentId":null,"rootId":null,"fromId":2034,"content":"1楼在说什么？","createdAt":"2022-10-21T11:18:03"},{"id":"01963ddd-2d79-72dc-b9b1-df8276eb5ba0","parentId":null,"rootId":null,"fromId":65,"content":"楼主，华云三维面试不是挺难的，要求比较高","createdAt":"2022-10-21T16:25:35"},{"id":"01963ddd-2dbf-7338-b612-1434dc5cfae7","parentId":null,"rootId":null,"fromId":2034,"content":"还行吧，一共三轮","createdAt":"2022-10-22T09:05:27"},{"id":"01963ddd-2e04-7119-9531-92cc50f8ac52","parentId":null,"rootId":null,"fromId":65,"content":"请问楼主入职了吗，感觉怎么样","createdAt":"2022-10-27T09:57:34"},{"id":"01963ddd-2e49-7160-a05c-14a3eb33182b","parentId":null,"rootId":null,"fromId":1629,"content":"面试难吗, 问项目多还是问八股多. 有无手撕算法","createdAt":"2022-11-03T13:05:29"},{"id":"01963ddd-2e8d-71a2-85a1-290c3380d29f","parentId":null,"rootId":null,"fromId":1629,"content":"我擦本来打电话问我约面试的, 怎么后来不理我了","createdAt":"2022-11-04T15:30:39"},{"id":"01963ddd-2ed0-7005-8ab6-369827980336","parentId":null,"rootId":null,"fromId":1039,"content":"公司不错，在济南大环境来说，五险低，但是公积金12%，氛围也可以，但是卷不倦，说实话，现在这个就业环境，不卷的都在投简历","createdAt":"2023-01-04T14:40:34"},{"id":"01963ddd-2f5c-710c-ab9f-4ffa7fa93e27","parentId":null,"rootId":null,"fromId":1039,"content":"不知道9楼为什么要吵，我不否认年终奖发的少，因为但凡设计到年终奖的全发的少，我发完还私底下骂公司画饼\n但是公积金，至少去年七月之前只有1%，一个月几十，现在公积金一个月一千多，双方两千多，这也要喷么，咱不知道变相涨工资也要喷一下","createdAt":"2023-02-08T16:29:52"},{"id":"01963ddd-2fff-70a3-a534-a7db34a7c335","parentId":null,"rootId":null,"fromId":1039,"content":"1.最近裁人，还舍不得给补偿，n+1就给了n，请后面的人坚持要n+1，不行就仲裁\n2.行政一天溜达八百回，看到有玩手机的，聊天的直接开除，还不给补偿，理由是违反公司规定，不知道公司规定是否大于劳动法","createdAt":"2023-03-03T00:00:45"},{"id":"01963ddd-304c-7363-abf3-4bf55becd8eb","parentId":null,"rootId":null,"fromId":2900,"content":"华云三维也裁人？本来也没多少人吧","createdAt":"2023-03-14T01:01:20"},{"id":"01963ddd-308e-716c-aea2-d255d2031144","parentId":null,"rootId":null,"fromId":2466,"content":"华天和华云是两个公司，虽然是附属关系，但是华云没有华天那么严格目前","createdAt":"2023-07-19T14:16:46"},{"id":"01963ddd-30d5-7279-b948-0cc5b267593c","parentId":null,"rootId":null,"fromId":6197,"content":"老哥在华云吗","createdAt":"2023-11-29T10:26:47"},{"id":"01963ddd-30d9-72c6-ae2c-12a2039c7239","parentId":null,"rootId":null,"fromId":6197,"content":"想了解一下这公司","createdAt":"2023-11-29T10:27:12"},{"id":"01963ddd-3045-7015-90cb-29556db91c14","parentId":null,"rootId":null,"fromId":21676,"content":"想了解一下为啥要裁人，今年秋招我这边挺多人报名的，感觉他们需求量挺大呀","createdAt":"2024-11-28T10:33:47"}]