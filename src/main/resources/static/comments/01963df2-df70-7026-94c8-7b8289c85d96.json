[{"id":"01963df2-dfd1-72cc-92eb-12503b6bcfc4","parentId":null,"rootId":null,"fromId":3341,"content":"因为他们的父亲去世了 伤心难过没空回复","createdAt":"2024-09-05T09:26:38"},{"id":"01963df2-e01a-7083-bdab-34ff109fa2ca","parentId":null,"rootId":null,"fromId":6939,"content":"因为压根就不缺人，好多挂着岗位是给领导看的，HR也要有业绩，boss好几个月不登录的话，领导不就一眼看出了么，每天上班打开招聘网站，浏览浏览信息，随机挑选几个问问，记录一下今天的工作，下班走人！","createdAt":"2024-09-05T10:03:49"},{"id":"01963df2-e016-7302-b740-b518b336a8f8","parentId":null,"rootId":null,"fromId":7708,"content":"省流：没爹","createdAt":"2024-09-06T09:19:43"},{"id":"01963df2-e05e-714b-86bb-a8c97dfa67f0","parentId":null,"rootId":null,"fromId":875,"content":"说的对","createdAt":"2024-09-06T12:54:27"},{"id":"01963df2-e062-7131-a772-0d1715c315d9","parentId":null,"rootId":null,"fromId":6939,"content":"哎，看上了甲方某科技公司的岗位，问了几次已读不回，正好有个邻居是里面的，人家说压根就没缺口，就是因为人事没活干，董事长点名批评了，做样子的。","createdAt":"2024-09-06T16:18:34"}]