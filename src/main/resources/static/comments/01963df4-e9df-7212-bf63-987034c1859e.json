[{"id":"01963df4-ea4e-700c-bae7-149c200abfd9","parentId":null,"rootId":null,"fromId":1376,"content":"不要想了，济南都找不到了，还去章丘","createdAt":"2024-11-22T16:34:13"},{"id":"01963df4-ea92-71f5-8dd3-08af77594da0","parentId":null,"rootId":null,"fromId":521,"content":"转行吧，觉得这么多年都白费了。不转吧，实在不想加班当孙子赚窝囊费。。。。","createdAt":"2024-11-22T16:39:20"},{"id":"01963df4-ea97-7382-a465-76d96efb5fe0","parentId":null,"rootId":null,"fromId":3892,"content":"章丘软件开发只有山大地纬吧","createdAt":"2024-11-22T16:58:25"},{"id":"01963df4-eadb-70ae-a4a8-d6d2ed564dd4","parentId":null,"rootId":null,"fromId":7074,"content":"章丘除了工厂，就是月薪1500-2500，不交社保的”公司”吧","createdAt":"2024-11-22T17:16:41"},{"id":"01963df4-eae0-70cb-94f7-ad8e96eae6ca","parentId":null,"rootId":null,"fromId":1376,"content":"说实话现在不得不考虑转行了，我们注定是时代的一粒沙，年龄永远迈不过去，未来大学生一年比一年多，这得持续20年","createdAt":"2024-11-25T09:18:00"},{"id":"01963df4-eb28-7145-a80b-b012733bdf16","parentId":null,"rootId":null,"fromId":455,"content":"在21年我就打算从章丘找开发的，根本找不到","createdAt":"2024-11-25T09:27:31"},{"id":"01963df4-eb79-7074-9eb8-1c73650b8828","parentId":null,"rootId":null,"fromId":7124,"content":"今年年初的时候在章丘找了一个，大学城对面那个园区，叫什么曦来着，记不太清了月薪6k，干了3天，济南offer来了，就走了","createdAt":"2024-11-25T15:03:20"},{"id":"01963df4-ebbd-72dd-be71-646b31aa6e60","parentId":null,"rootId":null,"fromId":77,"content":"凯曦","createdAt":"2025-01-03T15:01:47"},{"id":"01963df4-ebc1-71be-a4e0-fd7077965816","parentId":null,"rootId":null,"fromId":6208,"content":"章丘就章丘地纬了","createdAt":"2025-01-03T16:16:46"},{"id":"01963df4-ec05-73af-aea1-e31ed1559b16","parentId":null,"rootId":null,"fromId":521,"content":"专升本，人家看不上。。。","createdAt":"2025-01-16T17:02:54"},{"id":"01963df4-ec09-70e8-81cd-5aa0099ea3d1","parentId":null,"rootId":null,"fromId":21585,"content":"每天从章丘到济南通勤上班的人超级多，903,971都是满满的，哦对，还有301","createdAt":"2025-01-16T18:05:53"},{"id":"01963df4-ec4f-7368-bd11-f9e2217733fd","parentId":null,"rootId":null,"fromId":521,"content":"现在我就是，每天通勤来回四个小时。痛苦ing...","createdAt":"2025-02-20T09:38:39"},{"id":"01963df4-ec54-725d-9842-bbb9e8275c80","parentId":null,"rootId":null,"fromId":521,"content":"之前面了两家，一家伊莱特、一家章丘重型锻造。\n第一家工资比现在低4000，双休变单休。五险最低额度，问就是马上上市。\n第二家工资比现在低2000，同样是单休，外加节假日不放假（可以请假但扣工资），招且只招一个人，整个公司关于程序员就一个人。需求很简单（仅看到的部分），平时下班以后肯定会有事联系\n其实第二家离家是真的近，真的动心。他哪怕是双休，我都当工贼咬咬牙去了。节假日我就当自己给自己放假也能忍，单休是真的受不了。\n我是属于不会要工资的那种，本来在同事里工资就低。。","createdAt":"2025-02-20T09:45:23"}]