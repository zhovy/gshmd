[{"id":"01970fcb-6238-727e-a227-db3b7b5e0626","parentId":null,"rootId":null,"fromId":24443,"content":"1.代码毫无规范性可言，全是新人赶工出来的屎山\n2.996都算好的，忙的时候直接连轴转；弹性工作 上班时间固定  下班不固定\n3.年终奖、项目奖金都是虚的  一个月忙成狗给你多发五百就很不错了\n4.千万不要听信薪资  绩效制度，来了以后说你产出达不到标准，工作一年差不多能拿到他说的工资\n5.框架是springmvc+jsp 工作一段时间跳槽都跳不出去  如果有其他选择千万不要考虑","createdAt":"2025-05-27T11:31:16"},{"id":"0197102a-4b69-7098-a011-2e4ead98190c","parentId":null,"rootId":null,"fromId":21984,"content":"别去，来众阳吧","createdAt":"2025-05-27T13:14:56"},{"id":"019710db-21ed-73aa-9cff-f7b016fcb363","parentId":null,"rootId":null,"fromId":5506,"content":"叫不醒装睡的人，这个网站右上角有个功能叫搜索","createdAt":"2025-05-27T16:28:05"},{"id":"019710e1-7e58-70ec-9e56-e6e18a4660bb","parentId":null,"rootId":null,"fromId":21626,"content":"我只能说，在济南互联网公司里边能排的上号的差劲","createdAt":"2025-05-27T16:35:02"},{"id":"019710e3-41e4-718a-921a-31662bf982b0","parentId":null,"rootId":null,"fromId":24507,"content":"大胆点，是数一数二的差劲?","createdAt":"2025-05-27T16:36:58"},{"id":"019714ad-3fc2-7034-800e-df2f0fad318a","parentId":null,"rootId":null,"fromId":24556,"content":"数据治理岗呢","createdAt":"2025-05-28T10:16:27"},{"id":"01971654-b6bf-7310-b00a-92b10e6b7f33","parentId":null,"rootId":null,"fromId":24507,"content":"纯牛马","createdAt":"2025-05-28T17:59:00"},{"id":"01971655-2a18-720c-8d7e-88070b6d7861","parentId":null,"rootId":null,"fromId":24507,"content":"只能说，除非不来这家公司你就会饿死，那就别来","createdAt":"2025-05-28T17:59:29"},{"id":"01971b2c-8182-70f5-86a3-3037a418c258","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-05-29T16:33:11"}]