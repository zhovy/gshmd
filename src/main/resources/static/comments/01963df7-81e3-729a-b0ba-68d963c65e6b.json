[{"id":"01963df7-824b-73d1-97bb-655d8baf3bf7","parentId":null,"rootId":null,"fromId":22256,"content":"华云就是 华天的子公司吧，首选国企","createdAt":"2025-03-03T10:00:52"},{"id":"01963df7-8291-71fa-a42b-130a55eaece9","parentId":null,"rootId":null,"fromId":21676,"content":"对，是他的那个子公司","createdAt":"2025-03-03T10:48:09"},{"id":"01963df7-8294-733e-834e-a50f598df5f1","parentId":null,"rootId":null,"fromId":4140,"content":"应届生，哪个能学到东西，给钱多的去哪，别想着长时间干，不管怎么样都得跳槽的","createdAt":"2025-03-03T13:04:16"},{"id":"01963df7-82d8-7059-9db8-d9bbf63432f1","parentId":null,"rootId":null,"fromId":21676,"content":"好的，烽火哥","createdAt":"2025-03-03T13:12:30"},{"id":"01963df7-82dc-7295-a582-942e16aff550","parentId":null,"rootId":null,"fromId":875,"content":"应届生不应该去国企吗，毕竟过了这个村就没这个店了，非应届生进国企清一色外包","createdAt":"2025-03-03T23:05:32"},{"id":"01963df7-82df-73a7-aa47-1f8a4c5a5129","parentId":null,"rootId":null,"fromId":4140,"content":"我毕业就去了一个国企，一个月到手5500，公积金700，双休，一点不加班，也学不到一点东西，你要是认命这辈子稳稳的赚这点钱，你可以去，而且，去了之后千万别心里不平衡，人家专科毕业的工资比你高，你也别酸，人家也有能力，交际能力","createdAt":"2025-03-04T08:57:18"},{"id":"01963df7-82e3-7135-ab6c-53d63ce79e71","parentId":null,"rootId":null,"fromId":59,"content":"现在的环境  国企是真的稳定\n错过了应届生再去国企很难很难\n安安稳稳的一个月四五千  公积金两三千，过节福利拉满\n末尾淘汰不用太担心，每年自离职什么的会背这个名额的\n出来干了几年活 更加希望进国企了，稳定福利好\n\n你去华天，那边裁员更严重，而且压力还大，不如国企","createdAt":"2025-03-06T13:59:09"},{"id":"01963df7-832d-7108-9f49-5cc480fbf7fa","parentId":null,"rootId":null,"fromId":21676,"content":"谢谢哥的指点，最近也有在好好地思考，准备回老家享受人生了。\n另外，华云三维是华天的子公司，也裁员很严重吗》》","createdAt":"2025-03-06T14:48:55"},{"id":"01963df7-8332-71ee-a5fa-a8faf4dfb295","parentId":null,"rootId":null,"fromId":5913,"content":"说国企好的都不是国企里面的","createdAt":"2025-03-06T15:03:02"},{"id":"01963df7-837d-72f3-91f4-81845963199d","parentId":null,"rootId":null,"fromId":22454,"content":"哥们后端还是前端啊","createdAt":"2025-03-11T11:30:39"},{"id":"01963df7-83c1-70d8-82a5-4a948e4236de","parentId":null,"rootId":null,"fromId":1039,"content":"裁员不裁员和是不是子公司没关系，说实话，现在华云三维还不盈利，纯靠母公司输血，他不定期裁员谁裁","createdAt":"2025-03-11T11:45:03"},{"id":"01963df7-8406-706f-9898-d2a0412226c6","parentId":null,"rootId":null,"fromId":21676,"content":"好的大哥","createdAt":"2025-03-11T13:19:10"},{"id":"01963df7-840b-7065-813d-46e25ae0c6d2","parentId":null,"rootId":null,"fromId":22539,"content":"闭着眼选国企，毕竟考虑35的魔咒是存在的。","createdAt":"2025-03-11T18:21:41"}]