[{"id":"01963df7-eafd-70b2-9b7f-8d1ca8d0ea7b","parentId":null,"rootId":null,"fromId":22256,"content":"网站不是很多这个公司的恶心事情吗，我没面试过，我都知道了","createdAt":"2025-03-20T09:23:16"},{"id":"01963df7-eb42-71ee-bcd5-a4b8586a4b95","parentId":null,"rootId":null,"fromId":22220,"content":"去个勾吧   有多远跑多远","createdAt":"2025-03-20T09:26:44"},{"id":"01963df7-eb8e-70fc-8f33-987bca4a1d6b","parentId":null,"rootId":null,"fromId":22157,"content":"研究生，入职写的6-8，干了好几年还是6多点，来的第一年都不长，之后业绩超额完成就说公司效益不好不涨，耽误青春来喂狗了","createdAt":"2025-03-20T10:29:17"},{"id":"01963df7-ebd4-73eb-9b15-8f48a8987229","parentId":null,"rootId":null,"fromId":22676,"content":"别来，我部门昨天刚被裁了个，人家入职还不到一年呢。","createdAt":"2025-03-20T16:35:20"},{"id":"01963df7-ec81-724c-8ff8-a85be62176b9","parentId":null,"rootId":null,"fromId":7263,"content":"入职三个月就是老员工了","createdAt":"2025-03-24T16:45:35"},{"id":"01963df7-ecce-7022-8c10-82a26159fc09","parentId":null,"rootId":null,"fromId":22902,"content":"销售岗位还是可以的，别的岗位，没有太多的技术含量。","createdAt":"2025-03-27T16:38:46"},{"id":"01963df7-ed18-717c-8c9b-8c841bf7bcf4","parentId":null,"rootId":null,"fromId":22399,"content":"大家如何看待df在盛和早自习关于稻盛哲学、阿米巴经营、水库经营的分享？","createdAt":"2025-04-06T08:31:38"},{"id":"01963df7-ed5e-7385-a4ef-6377e9bf300b","parentId":null,"rootId":null,"fromId":21912,"content":"就听了一会，听不下去，盛和塾就是资本家的交流罢了，风评都烂大街了，无非就是画饼之类，这个年代骗不了人了，有没有料实不实在，一言一行都给出卖了，待遇低能说成是水库式经营还理直气壮，属实看乐了。不过确实有本事，pua一流，答非所问口是心非，主持人都憋不住了，再说好人谁学小日子和遥遥领先那套，天天读书分享大家都有数的","createdAt":"2025-04-06T21:46:52"},{"id":"01963df7-ed62-7396-a9a8-db4e8e393c32","parentId":null,"rootId":null,"fromId":22902,"content":"每个企业都要有企业文化，对中上层讲文化+待遇，普通员工多讲待遇，文化可以提少点。","createdAt":"2025-04-14T18:54:39"}]