[{"id":"01963de1-2521-7202-b046-7bffe6c381bd","parentId":null,"rootId":null,"fromId":270,"content":"几年前面试的时候说6个月试用期，但是工作上加班不多","createdAt":"2023-04-07T21:46:56"},{"id":"01963de1-2565-71b8-9124-8dc7fbf7a104","parentId":null,"rootId":null,"fromId":2495,"content":"面试官让人不舒服","createdAt":"2023-04-08T12:45:19"},{"id":"01963de1-25a9-724b-98f5-bbaf249a49f5","parentId":null,"rootId":null,"fromId":557,"content":"面试官是个装逼分子","createdAt":"2023-04-10T14:09:52"},{"id":"01963de1-25f0-7317-ae88-4b2061f2fcc0","parentId":null,"rootId":null,"fromId":414,"content":"2、3楼，你们说的面试官是二轮的时候的那个经理吗，貌似是戴眼镜，从浪潮出来的，我也去面过，那人挺装逼的，一副对人不屑一顾的样子，问的问题也很傻逼","createdAt":"2023-04-10T15:32:58"},{"id":"01963de1-2655-7072-b780-bc03c95b0ea9","parentId":null,"rootId":null,"fromId":557,"content":"带没戴眼镜，忘记了。身高大概也就160到170吧。反正挺壮逼得，对什么都不屑。问问题，简历上写的一个也不问。一直吹他们的项目20w/s的并发，一直在装逼。问的问题，不是为了了解人，是为了恶心人，一副牛逼轰轰的姿态。","createdAt":"2023-04-16T17:12:51"},{"id":"01963de1-26a4-73e1-8635-a6736fc33ef2","parentId":null,"rootId":null,"fromId":3295,"content":"约好面试，但是去了说已经通知没有面试安排了，boss上和手机上均没有，boss里根本就没发消息，短信则是发错了手机号，去了就做了一套题，然后就没下文了","createdAt":"2023-04-17T21:47:23"},{"id":"01963de1-26f0-70b2-818a-5341acdc9e7e","parentId":null,"rootId":null,"fromId":3336,"content":"朋友你报的是什么岗位？","createdAt":"2023-04-21T09:30:43"},{"id":"01963de1-269c-7203-b851-018b6f4ed0fd","parentId":null,"rootId":null,"fromId":3336,"content":"求联系方式 想问问具体的情况","createdAt":"2023-04-21T09:31:06"},{"id":"01963de1-26a0-73e1-af09-7761194af667","parentId":null,"rootId":null,"fromId":557,"content":"我只是去面试过，没入职。所以也没有更多的信息可以提供给你了。","createdAt":"2023-04-25T15:48:56"}]