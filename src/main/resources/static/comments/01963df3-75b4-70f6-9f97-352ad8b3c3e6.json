[{"id":"01963df3-7618-7086-b751-7da1d5f10e41","parentId":null,"rootId":null,"fromId":1039,"content":"失业超过6个月的都和环境没关系","createdAt":"2024-09-29T21:32:23"},{"id":"01963df3-7667-72e8-94ee-975ed0102226","parentId":null,"rootId":null,"fromId":1398,"content":"现在的环境确实非常难，找工作的人也多","createdAt":"2024-09-29T21:35:43"},{"id":"01963df3-7662-7303-b0f6-e58c391f1432","parentId":null,"rootId":null,"fromId":21818,"content":"哈哈哈哈，确实！没老婆孩子的，只要不是一点不存钱，真不着急找工作","createdAt":"2024-09-29T23:25:46"},{"id":"01963df3-76be-701f-87d6-8c1d2d3986f0","parentId":null,"rootId":null,"fromId":875,"content":"失业一年还在济南找，只能说是英雄，替济南两套房四套房的房东中介谢谢你，怪不得房租还那么贵","createdAt":"2024-09-30T07:44:48"},{"id":"01963df3-7706-7049-963f-bd3981be99fe","parentId":null,"rootId":null,"fromId":3341,"content":"一年找不到 要么人不行 要么眼高手低 认不到现实","createdAt":"2024-09-30T09:16:06"},{"id":"01963df3-774c-7247-901a-0dc298cb10d4","parentId":null,"rootId":null,"fromId":6580,"content":"都一年了，大概率是和环境没什么关系了吧，高不成低不就","createdAt":"2024-09-30T09:19:06"},{"id":"01963df3-7795-72c2-90a2-f0e39aed564e","parentId":null,"rootId":null,"fromId":875,"content":"市场很好，很热，好多一线城市都开始扩招，给员工加工资了，3250了，创业板又","createdAt":"2024-09-30T11:51:22"},{"id":"01963df3-77da-725b-8604-64962876f066","parentId":null,"rootId":null,"fromId":875,"content":"缩短非京籍家庭购房所需缴纳社保或个税年限。对非京籍家庭购买五环内住房的，社保或个税缴纳年限由“购房之日前连续缴纳满5年及以上”调减为“购房之日前连续缴纳满3年及以上”；购买五环外住房的，进一步调减为“购房之日前连续缴纳满2年及以上”。符合本市经济社会发展需要的高层次和急需紧缺人才购房，明确为“购房之日前连续缴纳满1年及以上","createdAt":"2024-10-01T07:32:34"},{"id":"01963df3-7820-73ee-b5f3-17576d853bb5","parentId":null,"rootId":null,"fromId":875,"content":"北京公积金可以贷160万了，冲呀，股市刚满仓赚了大把大把的钱，公积金又可以贷款160万在北京买房子了，北京真好","createdAt":"2024-10-03T11:44:38"},{"id":"01963df3-786c-715a-8794-e4d2c4018d09","parentId":null,"rootId":null,"fromId":880,"content":"2021年8月离职---23年3月，中间有在两家公司工作，分别干了一个正月，和12天。。。。这算一年以上的失业吗","createdAt":"2024-10-04T15:01:05"},{"id":"01963df3-78af-7267-bda6-fb8103a73cb9","parentId":null,"rootId":null,"fromId":2408,"content":"算","createdAt":"2024-10-04T15:10:35"},{"id":"01963df3-78b4-7338-90b1-5cc108811c05","parentId":null,"rootId":null,"fromId":875,"content":"这还用问","createdAt":"2024-10-04T20:09:39"},{"id":"01963df3-78b8-7361-a4b7-e5d3ca210e39","parentId":null,"rootId":null,"fromId":875,"content":"感觉没有比基金经理再好干的职业了，一个基金经理管理二三十个基金，基金最近三年亏成狗，管理费一分不少，亏的越多，年终奖越多，牛市一来，小学没毕业都能干，年薪百万还需要985的，我上我也行，赶紧考从业资格证去","createdAt":"2024-10-07T10:42:27"},{"id":"01963df3-78fd-71c8-a377-714b91c42ac4","parentId":null,"rootId":null,"fromId":6939,"content":"大概率只是你不想工作，懒的上班.","createdAt":"2024-10-08T17:05:45"}]