[{"id":"01963ddd-022b-73d4-ad68-5f4222276bac","parentId":null,"rootId":null,"fromId":1486,"content":"1、不交社保是违法的；2、劝退行为是可以拒绝的，只要企业方拿不出不符合录用条件的证据则属于违法辞退，应该给予赔偿金；如果需要维权/仲裁咨询可以加VX“zyzg0531”，公益为大家提供咨询帮助。","createdAt":"2022-10-19T20:23:02"},{"id":"01963ddd-026e-7382-9a00-dd7be02227b3","parentId":null,"rootId":null,"fromId":2013,"content":"听朋友说她以前入职一年才给交社保 干了半年的就离职了","createdAt":"2022-10-20T00:09:36"},{"id":"01963ddd-02b1-72cc-b260-29dafcbb14b0","parentId":null,"rootId":null,"fromId":1985,"content":"这个公司神操作太多了，好多实习生在转正前被劝退，还没有补偿，吸员工的血、奉劝各位积极避坑","createdAt":"2022-10-22T16:58:33"},{"id":"01963ddd-02f3-71bb-9665-2ed9d6cdddd1","parentId":null,"rootId":null,"fromId":3120,"content":"而且面试很随意，他会说对你的很满意，还有试岗期","createdAt":"2023-03-29T10:44:14"}]