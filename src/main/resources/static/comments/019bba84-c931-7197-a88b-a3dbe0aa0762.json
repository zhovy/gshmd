[{"id":"019bba86-755d-705a-b8e1-77d20f880829","parentId":null,"rootId":null,"fromId":21302,"content":"退休了没有人舔，没有人上人感觉，钱再多有什么用？","createdAt":"2026-01-14T11:22:12"},{"id":"019bba91-9eeb-73c0-adf2-a7b85250fa20","parentId":null,"rootId":null,"fromId":2846,"content":"退休这么早？怎么建设社会主义？","createdAt":"2026-01-14T11:34:24"},{"id":"019bba97-d13b-7075-b0e5-46f3fbf2383f","parentId":null,"rootId":null,"fromId":24428,"content":"这么早退休还能有退休金？想多了吧","createdAt":"2026-01-14T11:41:10"},{"id":"019bbaea-0e91-7155-8313-44dc88aba000","parentId":null,"rootId":null,"fromId":3341,"content":"到了退休年龄工作除了退休金收入没啥其他保障，有孩子的话孩子刚到结婚年龄 正要花钱呢","createdAt":"2026-01-14T13:10:59"},{"id":"019bbaef-bd65-72bc-990c-3887352e6f67","parentId":null,"rootId":null,"fromId":5480,"content":"屌用没有，上面不发话，你以为这玩意能通过？指着牛马有啥用，之前放假调休这么一个小事，嚷嚷了多少年都没改善，你觉得你说的这个有用？除非你上位，否则别想了","createdAt":"2026-01-14T13:17:12"},{"id":"019bbb16-eeae-7331-a79f-9cbec3e800f5","parentId":null,"rootId":null,"fromId":26671,"content":"他上位了以后，就会用上位者的角度重新看待这个问题，而不是牛马的角度，依然不会通过","createdAt":"2026-01-14T14:00:00"},{"id":"019bbb18-716a-7362-bea2-ce292f732bbc","parentId":null,"rootId":null,"fromId":24428,"content":"扎心了，老铁","createdAt":"2026-01-14T14:01:39"},{"id":"019bbb88-57c8-732e-8acc-d98ab266f8ab","parentId":null,"rootId":null,"fromId":28087,"content":"屠龙少年终成恶龙","createdAt":"2026-01-14T16:03:53"},{"id":"019bbc1d-0894-71ba-9993-eaa283da0bb2","parentId":null,"rootId":null,"fromId":5584,"content":"你不会自己干点其他的或是自己干点小生意","createdAt":"2026-01-14T18:46:18"},{"id":"019bbc1d-9179-7330-833a-363a39ab92b6","parentId":null,"rootId":null,"fromId":5584,"content":"等你老胳膊老腿了 想出去都走不动的时候 再退休吗","createdAt":"2026-01-14T18:46:53"},{"id":"019bbf93-f08c-71d3-b369-362fcd453a14","parentId":null,"rootId":null,"fromId":2846,"content":"既然你不想老胳膊老腿的退休，现在不上班就行了，前提是你有能养活自己的手段，就像马云那样，不用到60岁就退休。如果你没有这么多本事，作为普通人不就是上班，或者自己创业，你生活在一个已经设计好的制度世界里，想改变制度？不可能的，下辈子别来人间就行了","createdAt":"2026-01-15T10:55:02"}]