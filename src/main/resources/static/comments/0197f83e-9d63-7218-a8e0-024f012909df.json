[{"id":"0197f841-293c-71ae-a276-42452f8abd12","parentId":null,"rootId":null,"fromId":3925,"content":"感觉上来说，压力不会太大，哪怕是失业，压力只能说会有但是没那么大","createdAt":"2025-07-11T14:51:49"},{"id":"0197f841-ee5f-7134-9d7c-c3f192be6310","parentId":null,"rootId":null,"fromId":3925,"content":"我一个同学一个月房贷2000多块钱吧，他两口子工资加一起1万都不到应该是，日子还是照样过，现在孩子都有了","createdAt":"2025-07-11T14:52:39"},{"id":"0197f843-0c19-70c7-b10b-4de639b2d98d","parentId":null,"rootId":null,"fromId":21234,"content":"目前是丝毫压力没有哈哈哈，过得很滋润哈哈哈哈，如果失业那可能就完犊子了","createdAt":"2025-07-11T14:53:53"},{"id":"0197f845-63c6-71cc-8247-dba380998379","parentId":null,"rootId":null,"fromId":21234,"content":"漏了一个问题，租车位好 还是买车位好，如果租的话一般是多少钱，济南东边的小区","createdAt":"2025-07-11T14:56:26"},{"id":"0197f84b-f345-730b-9f3a-a384c24d89a8","parentId":null,"rootId":null,"fromId":2246,"content":"失业的问题要看你们啥行业了","createdAt":"2025-07-11T15:03:36"},{"id":"0197f84d-4f41-736f-a31e-1d179b6c13e8","parentId":null,"rootId":null,"fromId":21234,"content":"老公是程序员，我是hr","createdAt":"2025-07-11T15:05:05"},{"id":"0197f86c-8869-707f-af8e-9dacbef128e7","parentId":null,"rootId":null,"fromId":3925,"content":"看你买房的时候车位多钱了，东边普遍情况应该是2500左右一年","createdAt":"2025-07-11T15:39:11"},{"id":"0197f878-77b7-73e9-9ef9-84fc27560f3b","parentId":null,"rootId":null,"fromId":5755,"content":"如果你生了孩子还能回去上班就可以考虑一下","createdAt":"2025-07-11T15:52:14"},{"id":"0197f8bc-f40a-703b-8bf9-ac4bf519e149","parentId":null,"rootId":null,"fromId":926,"content":"压力很小，放心冲，不是有那个保障性住房吗，可以看看那个，性价比很高","createdAt":"2025-07-11T17:07:02"},{"id":"0197f8ca-8206-737b-a73d-68bd7f38f820","parentId":null,"rootId":null,"fromId":23684,"content":"房子买就行","createdAt":"2025-07-11T17:21:50"},{"id":"0197f8ca-84ba-7293-b47b-3e33c9aaef21","parentId":null,"rootId":null,"fromId":24640,"content":"抢不着啊","createdAt":"2025-07-11T17:21:51"},{"id":"0197fc9f-b036-7175-94cb-b67a804bfdf6","parentId":null,"rootId":null,"fromId":22024,"content":"地下室得买，很难租，租金低没人出租","createdAt":"2025-07-12T11:13:33"},{"id":"0197fd36-2155-7156-a849-c62e1b594039","parentId":null,"rootId":null,"fromId":926,"content":"先排上再说，你们这没压力","createdAt":"2025-07-12T13:57:52"},{"id":"01980652-1a47-7291-9078-cbaf5d2acb66","parentId":null,"rootId":null,"fromId":24162,"content":"搞个相对好点的学区二手，价格便宜点（具体什么价格我还真不知道，哪怕同价格应该比新房位置好），剩下的 钱攒着。真就攒着。生完孩子想法或许不一样了，手里有钱做啥都有底气。    家庭好，父母能提供帮助那另说。。。","createdAt":"2025-07-14T08:25:00"},{"id":"019806a6-4f61-727f-8485-279e6b85f731","parentId":null,"rootId":null,"fromId":6423,"content":"看你们背景介绍，俩人存款60w，每个月算上公积金到手差不多有2w，在济南应该算是不错的收入了。\n        分配是否合理：后续家人支持装修、税费维修基金等费用，只需要承担月供，可能遇到最大的问题就是失业风险，应当预留一年的生活费用+房贷支出，结合明年备孕，各项产前检查费用，生育后生活费用会显著提升，储备应急金额应在15w以上。\n        什么时候买：看济南近两年房价趋势，非核心地段二手房降价在10%-15%但仍然不好出手，新房也有大幅度的下降，目前这个势头没有停止的意思，所以，非必要没有必要买，等等更划算。房子的本质就是住所，租和买是一样的，它的额外价值可能就是学区名额，但等到孩子小学还得7-8年，目前这形式，还是把钱抓手里更有安全感","createdAt":"2025-07-14T09:56:59"},{"id":"019806b1-20c9-7073-b469-5dca8c577d1a","parentId":null,"rootId":null,"fromId":6423,"content":"现在买房车位不都送吗？ 买不买车位要看供需关系，如果价格低于6w，且车位紧张，那就买。其他情况一概不买","createdAt":"2025-07-14T10:08:48"},{"id":"01980b8a-140a-72f1-ba36-6bdd111211ff","parentId":null,"rootId":null,"fromId":21234,"content":"新东站和雪山怎么选，新东站靠着地铁，雪山环境不错","createdAt":"2025-07-15T08:44:15"},{"id":"01980bc1-dec1-73eb-aa5a-3d8dc0e3b1a4","parentId":null,"rootId":null,"fromId":6423,"content":"看你买房的具体需求了，户型、价格、位置、交通、配套、教育、环境，像我主打性价比，最看重户型和价格，其他方面分量轻，主打性价比，综合考虑吧","createdAt":"2025-07-15T09:45:11"},{"id":"019909c0-83a5-72a8-861e-dd95b4cd9be8","parentId":null,"rootId":null,"fromId":1538,"content":"那怕鸡毛事业, 你先进去,然后把你老公招进去","createdAt":"2025-09-02T17:27:15"}]