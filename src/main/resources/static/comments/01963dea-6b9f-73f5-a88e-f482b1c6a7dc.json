[{"id":"01963dea-6c0c-7341-a5d8-d816756c78d6","parentId":null,"rootId":null,"fromId":4140,"content":"算错了>_<，不小心把个人社保算进去了，全额总成本16.68w，差3.1572w","createdAt":"2023-12-28T13:47:44"},{"id":"01963dea-6c55-7160-873f-a317dc95c725","parentId":null,"rootId":null,"fromId":933,"content":"没什么毛病，就是发工资的时候少，一万全额五险一金到手不到8000","createdAt":"2023-12-28T13:53:53"},{"id":"01963dea-6c9f-7146-a4d4-165e2cafce5f","parentId":null,"rootId":null,"fromId":6380,"content":"对于不到30岁的年轻人而言，五险一金也就医保和公积金有意义了，占大头的社保40年后还能轮得到我们领吗？","createdAt":"2023-12-28T16:00:33"},{"id":"01963dea-6ce4-7247-b281-5fef9e19e141","parentId":null,"rootId":null,"fromId":875,"content":"等你退休就知道了，人家一月七八千退休金，你一个月两千块都不到","createdAt":"2023-12-28T19:21:15"},{"id":"01963dea-6cf1-7223-ac45-16b7d5c54be5","parentId":null,"rootId":null,"fromId":875,"content":"全额缴纳社保公积金，国企跳私企，月薪一万五，私企至少得要两万才不亏","createdAt":"2023-12-28T19:24:21"},{"id":"01963dea-6d35-728c-b225-0b8d63b8d709","parentId":null,"rootId":null,"fromId":576,"content":"国企1w5还跳个p啊","createdAt":"2023-12-28T20:32:04"},{"id":"01963dea-6c9b-7077-8ef7-795f7fbd42ef","parentId":null,"rootId":null,"fromId":721,"content":"现行的退休金制度好像98年才开始的，等咱们退休不知道又要改革成啥样了。要为了以后虚无缥缈的7k每个月多交这么多？","createdAt":"2023-12-29T08:47:32"},{"id":"01963dea-6ce8-71b5-ad77-791d9a81cace","parentId":null,"rootId":null,"fromId":508,"content":"对，公积金越高越好。社保是税，公司缴得多不代表自己能拿的就多，还不知道能不能活到退休呢。","createdAt":"2023-12-29T09:29:24"},{"id":"01963dea-6ced-72bc-ad8e-70beb8804bf5","parentId":null,"rootId":null,"fromId":4140,"content":"社保该交一定得交，交个最低档就行，国家不会出现没钱发社保的情况，这放心吧，没人交社保，我就多收消费税，多收别的税反正最终肯定能发下来的","createdAt":"2023-12-29T11:02:46"},{"id":"01963dea-6d3a-7060-be33-566d47ccc0c6","parentId":null,"rootId":null,"fromId":3446,"content":"国企全额没问题，不加班纯粹是臆想，国企的稳定是优点也是束缚，都是围城，得不到的才是最好的","createdAt":"2023-12-29T14:08:44"}]