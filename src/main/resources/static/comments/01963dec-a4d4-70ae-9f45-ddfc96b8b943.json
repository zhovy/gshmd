[{"id":"01963dec-a569-70df-81bb-d20673de9658","parentId":null,"rootId":null,"fromId":6938,"content":"去面试过。说让我等领导来了二面 然后当了半个月也没来 直接明确说可能会有拖欠工资的情况","createdAt":"2024-03-15T16:48:03"},{"id":"01963dec-a5b0-7118-881e-c6720ebe8084","parentId":null,"rootId":null,"fromId":2056,"content":"压四个月工资","createdAt":"2024-03-20T15:55:55"},{"id":"01963dec-a5f8-73b4-a370-2f94d851e9cf","parentId":null,"rootId":null,"fromId":4087,"content":"不是说半年工资吗","createdAt":"2024-03-27T10:38:36"},{"id":"01963dec-a5fc-7324-879a-811ca920b116","parentId":null,"rootId":null,"fromId":6374,"content":"上午面了一下，人事都直接说拖欠一两个月工资了，人事是不是说的保守了？不敢去","createdAt":"2024-04-16T17:39:33"},{"id":"01963dec-a657-731f-ad01-a8a5677cb41a","parentId":null,"rootId":null,"fromId":6374,"content":"有没有在云天的老哥，出来分享下最新信息呀","createdAt":"2024-04-19T10:18:21"},{"id":"01963dec-a6b2-717d-ad16-e2286fcb9462","parentId":null,"rootId":null,"fromId":6727,"content":"拖欠工资，谨慎入坑","createdAt":"2024-04-19T12:12:20"},{"id":"01963dec-a649-707f-8b13-5d6035e39a03","parentId":null,"rootId":null,"fromId":6727,"content":"面的什么岗位","createdAt":"2024-04-19T12:15:12"},{"id":"01963dec-a6f8-7097-b642-e9acfd08839c","parentId":null,"rootId":null,"fromId":6374,"content":"拖欠多久了啊老哥","createdAt":"2024-04-22T12:54:43"},{"id":"01963dec-a64e-71c1-a46b-cd89e7fbd213","parentId":null,"rootId":null,"fromId":6374,"content":"Python岗","createdAt":"2024-04-22T19:33:13"},{"id":"01963dec-a652-71ad-bedb-721b1503a415","parentId":null,"rootId":null,"fromId":6374,"content":"Python岗","createdAt":"2024-04-22T19:33:18"},{"id":"01963dec-a6fc-715c-9604-64e8587c0652","parentId":null,"rootId":null,"fromId":7329,"content":"真的吗，老哥，刚面试了，还能去吗","createdAt":"2024-04-25T18:22:26"},{"id":"01963dec-a701-72d8-ba2a-35aac845c4d6","parentId":null,"rootId":null,"fromId":6374,"content":"日报、周报、月总结；无补卡机会；缺卡第一次50元，第二次100元，第三次150元，第四次按旷工半天； 迟到早退，5元/分钟；节假日加班不可调休，据说算进绩效里面去， 工作日晚上不算加班；工资的25%作为绩效浮动薪资；请假次数多了，扣绩效；  办公环境有些差，感觉特像外包，通风较差，味道久了就习惯了；同事间沟通声音非常洪亮，脑仁疼；接口基本没有文档；","createdAt":"2024-05-31T19:35:41"},{"id":"01963dec-a745-7100-a4ff-571cc9367a4b","parentId":null,"rootId":null,"fromId":6374,"content":"据说二月份工资好多没发的","createdAt":"2024-05-31T19:36:48"}]