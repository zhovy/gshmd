[{"id":"01963dec-44db-7289-8165-1648097aa493","parentId":null,"rootId":null,"fromId":6731,"content":"目前还没见不卡的","createdAt":"2024-03-08T09:07:40"},{"id":"01963dec-451f-7141-a4cd-e5a70c2470b6","parentId":null,"rootId":null,"fromId":5913,"content":"一般都卡双一流","createdAt":"2024-03-08T09:09:29"},{"id":"01963dec-4564-7395-aaac-8dcec06d0d68","parentId":null,"rootId":null,"fromId":3341,"content":"相对而言极少部分卡双一流  大部分卡统招本","createdAt":"2024-03-08T09:13:43"},{"id":"01963dec-4568-714c-984c-5720ec265943","parentId":null,"rootId":null,"fromId":1398,"content":"举个例子，哪家公司，我好避坑","createdAt":"2024-03-08T09:14:24"},{"id":"01963dec-45c5-70f5-ba4b-c8a27de14c9b","parentId":null,"rootId":null,"fromId":1003,"content":"国企都卡研究生了   去年还招本科","createdAt":"2024-03-08T09:21:06"},{"id":"01963dec-45ac-73ad-843b-b74d2693ad50","parentId":null,"rootId":null,"fromId":3801,"content":"比如，联通的子公司：联通数字科技、联通研究院等，山东产业技术研究院相关的子公司，山东农信，山东高速等等，感觉公司越优质卡的越厉害。","createdAt":"2024-03-08T10:12:29"},{"id":"01963dec-45b0-736f-94cb-073fadc7301d","parentId":null,"rootId":null,"fromId":3892,"content":"你说的这几个公司有社招吗，不都是校招？","createdAt":"2024-03-08T10:13:52"},{"id":"01963dec-45b4-7157-bc3f-2c669f5f7ce0","parentId":null,"rootId":null,"fromId":3801,"content":"有社招的，我了解联通数字科技和联通研究院，只是要求比较高，学历敲门，能力决定能不能进去，内推的话也得满足学历要求才能推。山东产业技术研究院的一些子公司也有社招，要求和联通差不多。农信的话社招很少，一出来名额，一般都是乙方转甲方了。","createdAt":"2024-03-08T10:19:40"},{"id":"01963dec-45b8-702e-bf4b-979fada5fdf4","parentId":null,"rootId":null,"fromId":1049,"content":"这几个得卡到什么程度？研究生？双一流？","createdAt":"2024-03-08T10:25:10"},{"id":"01963dec-45bd-7312-b00c-17972abff52e","parentId":null,"rootId":null,"fromId":6939,"content":"我同事是联通下边哪个公司的忘了，福利待遇确实好，普本社招进去的，那几年要求还不是很严格，现在确实要求非常严格了。","createdAt":"2024-03-08T10:25:28"},{"id":"01963dec-45c1-73a2-acbf-38c710daf371","parentId":null,"rootId":null,"fromId":6939,"content":"研发好像要求985,211以上，其他岗位不清楚。","createdAt":"2024-03-08T10:27:16"},{"id":"01963dec-4609-70a3-828e-9f427d738454","parentId":null,"rootId":null,"fromId":6939,"content":"虽然都骂浪潮垃圾，但是浪潮社招已经要求双一流了。","createdAt":"2024-03-08T10:32:01"},{"id":"01963dec-464d-731d-8b2c-a040311fc66e","parentId":null,"rootId":null,"fromId":5954,"content":"别骂这个那个的了，先找个工作干着吧。人家还不一定能看上你呢。浪潮都985,211了，二本都不要了。认清形势啊！","createdAt":"2024-03-08T10:53:08"},{"id":"01963dec-4693-7382-ba7c-eb74c039ca04","parentId":null,"rootId":null,"fromId":3801,"content":"浪潮也是研发学历卡的比较厉害，实施岗或者售前岗的话稍微能放开点，但是工资比研发低，还需要经常出差。","createdAt":"2024-03-08T10:58:46"},{"id":"01963dec-46d7-70c1-9cf7-f353efe6551e","parentId":null,"rootId":null,"fromId":6186,"content":"不到20人的小微企业都卡笑死我了看boos","createdAt":"2024-03-15T16:14:06"},{"id":"01963dec-4721-700b-93a7-e2b4826fb0d9","parentId":null,"rootId":null,"fromId":6268,"content":"卡学历咱理解，你麻痹 5年经验 给6K  提前说行吧，浪费人时间面试","createdAt":"2024-03-15T16:26:32"},{"id":"01963dec-4726-72d9-a6f0-d299757c56c6","parentId":null,"rootId":null,"fromId":1049,"content":"真特娘的离了个特朗普，保安队长也得6k吧","createdAt":"2024-03-15T16:32:28"},{"id":"01963dec-472a-7070-b939-0cd65ca330d8","parentId":null,"rootId":null,"fromId":6939,"content":"5年经验 给6K明显就是不想用人给的借口 这种公司你面试的时候 就该直接怼他们一顿","createdAt":"2024-03-15T16:33:46"}]