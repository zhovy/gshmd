[{"id":"019b3412-7532-7212-9f94-c8e75581e691","parentId":null,"rootId":null,"fromId":557,"content":"好像是烟花爆竹 爆炸了，死伤了不少","createdAt":"2025-12-19T08:46:23"},{"id":"019b3427-3c16-70a4-b585-d235e0335d43","parentId":null,"rootId":null,"fromId":455,"content":"章丘 君悦华府，物业屯的爆竹，想着过年卖呢，爆炸了，县医院死了5个了，还有去北京治疗的，我朋友他老婆在县医院急救中心，挺惨的，有个女的都炸碎了","createdAt":"2025-12-19T09:09:05"},{"id":"019b3453-0638-71dd-ae0a-489d19ef4fc1","parentId":null,"rootId":null,"fromId":2921,"content":"细说碎了","createdAt":"2025-12-19T09:56:54"},{"id":"019b3624-49dc-708c-9f66-0d611a9c0569","parentId":null,"rootId":null,"fromId":28081,"content":"别的群里传有一个糊到天花板上了，不知道真假","createdAt":"2025-12-19T18:25:06"},{"id":"019b4370-29fc-7359-bf44-bd8eff8956f8","parentId":null,"rootId":null,"fromId":455,"content":"明水古城烟花秀都取消了，整个章丘今年肯定全部禁放，我镇里都下通知了，举报奖励100-1000块钱，微信卖爆仗的都把朋友圈删了，今年买卖准不大好干，反正我看有卖的 我直接举报 哈哈","createdAt":"2025-12-22T08:23:02"},{"id":"019b43bb-0997-716e-8e29-4c47cfff40e0","parentId":null,"rootId":null,"fromId":22250,"content":"孩子举报父母，父母举报爷爷，爸妈举报孩子，哈哈哈，红卫小将们，嗨起来","createdAt":"2025-12-22T09:44:49"},{"id":"019b44e7-6124-7358-8cf7-4f28e7fbeac5","parentId":null,"rootId":null,"fromId":7495,"content":"看通报还有天然气的事，是烟花爆炸引起天然气爆炸了吗","createdAt":"2025-12-22T15:12:53"}]