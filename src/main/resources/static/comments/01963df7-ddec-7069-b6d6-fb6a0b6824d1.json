[{"id":"01963df7-de4e-734e-b483-667a61d7742d","parentId":null,"rootId":null,"fromId":4140,"content":"他们的仓储MES系统还是我做的，这个公司管理反正挺混乱的，但是挺有实力的，给钱挺舍得","createdAt":"2025-03-18T11:43:46"},{"id":"01963df7-de91-7029-a026-8cd3d9dd1bec","parentId":null,"rootId":null,"fromId":21810,"content":"面试难不难呀 大佬","createdAt":"2025-03-18T11:51:27"},{"id":"01963df7-de95-7046-8298-55fd02a59f88","parentId":null,"rootId":null,"fromId":21810,"content":"大佬现在还在里面吗","createdAt":"2025-03-18T11:54:31"},{"id":"01963df7-de99-7322-ac59-163bcd5ce077","parentId":null,"rootId":null,"fromId":4140,"content":"我是乙方身份给他们做的，不在里面，具体不清楚，反正听说他们跟我们对接人工资挺高，面试啥的不清楚","createdAt":"2025-03-18T12:00:54"},{"id":"01963df7-de9d-726e-b828-3340f318d753","parentId":null,"rootId":null,"fromId":21810,"content":"好吧  感谢大佬","createdAt":"2025-03-18T12:05:16"},{"id":"01963df7-dea1-7019-935c-7ea3bcccc5b9","parentId":null,"rootId":null,"fromId":2598,"content":"昨天面的，技术团队那个屋就三个人，他说六个人呢。第一年签三方协议，8000一个月。后面再和集团签，说是后面可能发工资不及时，两三个月一次，怕新员工不愿意，所以和三方签","createdAt":"2025-03-18T12:12:22"},{"id":"01963df7-dee4-7311-a33f-0e527842597b","parentId":null,"rootId":null,"fromId":2422,"content":"去了没有技术面，单纯聊天，说是总部需要再筛简历。然后就没后续了。","createdAt":"2025-03-18T12:33:57"},{"id":"01963df7-dee9-7126-93b7-a6783798e925","parentId":null,"rootId":null,"fromId":21810,"content":"后续你同意了没有 给你发offer没","createdAt":"2025-03-18T15:04:08"},{"id":"01963df7-deee-72fb-a3e6-57774f93809f","parentId":null,"rootId":null,"fromId":22256,"content":"集团员工欠薪很久，应该是社保拖欠很久了，主要是被恒大坑惨了（我亲戚说的，也是国企建筑行业）","createdAt":"2025-03-18T15:24:08"},{"id":"01963df7-df33-7362-9db4-21529a24ebd1","parentId":null,"rootId":null,"fromId":21810,"content":"我现在这个公司欠薪快一年了","createdAt":"2025-03-18T16:35:31"},{"id":"01976824-3391-715c-86ef-1b0fcb29eb3b","parentId":null,"rootId":null,"fromId":793,"content":"同问","createdAt":"2025-06-13T15:14:52"},{"id":"0197884c-4eb5-7067-90a4-4998432189cf","parentId":null,"rootId":null,"fromId":7627,"content":"怎么样，有最近入职的吗，问就是8000能接受吗","createdAt":"2025-06-19T21:06:31"},{"id":"01979aa3-d3fb-70ce-8d07-7ed0239f0447","parentId":null,"rootId":null,"fromId":4092,"content":"接不接受看你自己，听说每个周六上午都要上班，五险一金也是最低","createdAt":"2025-06-23T10:35:17"}]