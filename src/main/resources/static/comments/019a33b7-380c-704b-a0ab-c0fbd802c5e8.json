[{"id":"019a3418-3b6e-700e-972b-fb98531e4710","parentId":null,"rootId":null,"fromId":22809,"content":"你不了解怎么知道讨人嫌， 细说","createdAt":"2025-10-30T15:49:54"},{"id":"019a37d3-94f7-708e-894a-e1758bc0c0c9","parentId":null,"rootId":null,"fromId":23300,"content":"这个B相当的阴险，人品出了名的差，在职的离职的没一个说这个B好的，小人得志，新松瞎眼有这么个B，老鼠屎一个。","createdAt":"2025-10-31T09:13:24"},{"id":"019a37d6-5eb3-731a-b9bf-317832620ff3","parentId":null,"rootId":null,"fromId":23300,"content":"这个专科逼没什么背景的，就会嗷嗷叫，不用担心，干他就完了","createdAt":"2025-10-31T09:16:27"},{"id":"019a37db-b6c1-73fa-b08d-2132e3e58bae","parentId":null,"rootId":null,"fromId":22809,"content":"带专啊，那就合理了（没恶意）","createdAt":"2025-10-31T09:22:17"},{"id":"019a38ba-d5c9-7224-8843-5a863efdcef6","parentId":null,"rootId":null,"fromId":1401,"content":"你哪个部门的？","createdAt":"2025-10-31T13:25:59"},{"id":"019a4e2b-6be5-7168-ab9a-8ac8a5326ca4","parentId":null,"rootId":null,"fromId":916,"content":"肯定跟这个逼一个部门啊，不然他讨厌也影响不到我","createdAt":"2025-11-04T17:20:59"},{"id":"019a4e2f-528f-7162-8360-eb23821e403a","parentId":null,"rootId":null,"fromId":21813,"content":"本人去年7月底离职，9月份入职了这个公司。刚入职，这个人跟我聊，说是先给我一个项目看看能力，如果可以的话后边让我带团队。接触项目后，发现这个项目一点资料没有。有一个长期出差驻场的同时，跟我对接。做一个APS，要用到算法（本人能力确实差点，算法这方面怎么弄也是不入门）。至于项目资料，有一个领域专家的角色，给我说了下大概情况，然后就嘱咐我赶紧做吧。然后一天已催，后来是一个周六，我孩子正好是百日宴，在群里发消息催我，说是赶紧推进，有问题及时沟通，这个时间其实也是入职后的第一个周末。就觉得很烦，本身自己也不会算法，当下就提出能力不行，离职了。感觉这个公司的研发部门就跟闹着玩一样，很草率。这个王经理，也是挺忙一天见不到人。其实最受不了的还是他们的50%绩效，觉得早晚得靠这个逼人走","createdAt":"2025-11-04T17:25:15"},{"id":"019a529a-6942-7182-a0af-68a54b80ddd1","parentId":null,"rootId":null,"fromId":916,"content":"这个小矮子就是个大忽悠，自己能力也不行，手底下人没一个不烦他的","createdAt":"2025-11-05T14:00:42"},{"id":"019a5323-4916-71cb-8ee6-5e7cd7299c32","parentId":null,"rootId":null,"fromId":1401,"content":"都是草台班子","createdAt":"2025-11-05T16:30:12"},{"id":"019a5d58-94c1-71b1-a618-b77c459a6ffe","parentId":null,"rootId":null,"fromId":21385,"content":"是个阴险的小人，小胳膊小腿儿小心眼，跟山东大汉的形象一点也不沾","createdAt":"2025-11-07T16:04:37"},{"id":"019a5d9d-b66b-7022-ad56-4920c788682e","parentId":null,"rootId":null,"fromId":916,"content":"绝对是阴险小人，不是个正经玩意，成天想着怎么整我们，不是个好东西","createdAt":"2025-11-07T17:20:08"},{"id":"019a9b65-9b5a-70b1-a7b2-e178b846c759","parentId":null,"rootId":null,"fromId":21385,"content":"有白癜风","createdAt":"2025-11-19T17:15:18"},{"id":"019aa953-8eb0-7000-bd14-a00c7d03e5a3","parentId":null,"rootId":null,"fromId":916,"content":"嗯，遭报应了","createdAt":"2025-11-22T10:10:16"},{"id":"019ac887-1f89-7230-b829-f63b8ecb591b","parentId":null,"rootId":null,"fromId":23300,"content":"人在做，天在看，不是不报，时候未到。纯活该。。","createdAt":"2025-11-28T11:34:49"},{"id":"019add1e-eb80-72b6-a41f-f5757b69db83","parentId":null,"rootId":null,"fromId":6517,"content":"听说龙哥 买别墅了。。是真的吗","createdAt":"2025-12-02T11:33:02"}]