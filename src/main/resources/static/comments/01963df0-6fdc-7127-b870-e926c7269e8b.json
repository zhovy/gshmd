[{"id":"01963df0-7045-7108-9259-0a4a6bd3e804","parentId":null,"rootId":null,"fromId":7709,"content":"那个公司的  亚*有个收钱宝，给移动做的","createdAt":"2024-06-06T10:22:26"},{"id":"01963df0-7091-7393-a88c-cfac0b4bf58d","parentId":null,"rootId":null,"fromId":7777,"content":"那跟我现在公司差不多了…也是聚合支付转外包","createdAt":"2024-06-06T11:04:29"},{"id":"01963df0-709a-72e9-b5b8-5aaa698dd90a","parentId":null,"rootId":null,"fromId":5602,"content":"是自研的，待遇还凑合，试用期不打折，社保公积金按全额工资的5%缴纳，加班早9晚8，目前只招高级工程师以上的职位","createdAt":"2024-06-11T16:26:34"},{"id":"01963df0-70de-71d7-9abe-2b30d4c02390","parentId":null,"rootId":null,"fromId":7777,"content":"意思是收钱吧在济南有分部？","createdAt":"2024-06-12T08:04:35"},{"id":"01963df0-70e3-73c4-a017-850a98ed22fa","parentId":null,"rootId":null,"fromId":5602,"content":"嗯嗯，4月份创立的分公司，研发部门","createdAt":"2024-06-12T09:28:09"},{"id":"01963df0-70f0-7269-8fae-8fd0655d5fa3","parentId":null,"rootId":null,"fromId":122,"content":"待遇偏低 可能后端较好吧  连我两年前的薪资都给不到  纳闷哪来的底气只招高级工程师 还是默认济南都是黑奴？","createdAt":"2024-06-13T10:46:15"},{"id":"01963df0-7134-7032-a056-02ca05ec70eb","parentId":null,"rootId":null,"fromId":122,"content":"自研 团队较小且没有高级人员驻场  后期有业务调整风险","createdAt":"2024-06-13T10:48:05"},{"id":"01963df0-7141-731c-976b-b4cf7a96ca77","parentId":null,"rootId":null,"fromId":6721,"content":"是自研的，个人面试完后综合感觉可以一试\n缺点：缺点写在前面，面试50分钟左右比较严格，问的技术问题比较有深（建议去面试前多刷刷技术原理性的面试题）。济南初创团队规模较小刚起步，是风险也是机会吧。存在加班的情况。\n优点：待遇在济南环境应该还算不错（看面试评价），说是有绩效奖和午晚餐补，剩下的跟2楼说的差不多。\n环境：办公环境看着还可以。据说现有人员都是大厂出身，也算是有学习和成长的空间。","createdAt":"2024-06-13T22:03:10"},{"id":"01963df0-7138-7025-bbf2-68952b0211c3","parentId":null,"rootId":null,"fromId":7777,"content":"可以说下年限+那边给的薪资吗","createdAt":"2024-06-14T16:34:02"},{"id":"01963df0-7188-70f0-8dbc-35cb7e2880b5","parentId":null,"rootId":null,"fromId":7777,"content":"这种一线来的非外包公司一般比本地公司要好很多","createdAt":"2024-06-14T16:34:41"},{"id":"01963df0-7095-71f9-8b7c-2d07385af92d","parentId":null,"rootId":null,"fromId":21000,"content":"据我了解，济南研发团队不做聚合支付","createdAt":"2024-06-18T09:51:36"},{"id":"01963df0-713d-7297-ad24-743ac