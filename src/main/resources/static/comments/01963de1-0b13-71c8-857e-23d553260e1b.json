[{"id":"01963de1-0b95-73f3-af86-9dda380a5d28","parentId":null,"rootId":null,"fromId":1656,"content":"都说了长期出差，就看你接受不接受了。","createdAt":"2023-04-04T14:09:55"},{"id":"01963de1-0c32-7123-97ec-908b94e42669","parentId":null,"rootId":null,"fromId":1656,"content":"没工作？是没经验吗？","createdAt":"2023-04-04T14:10:11"},{"id":"01963de1-0c78-702a-9be1-818946375ea1","parentId":null,"rootId":null,"fromId":3158,"content":"出差咋样啊，出差加班多吗？我是去年考研没考上现在找工作","createdAt":"2023-04-04T14:13:12"},{"id":"01963de1-0cbf-7287-8dff-1f6e79e5e496","parentId":null,"rootId":null,"fromId":2738,"content":"看项目组，有的项目组不当人用，有的还可以。出差的条件待遇会差一些，这是普联老传统了，实在找不到工作可以去，普联不是最差的，但也谈不上好的，应急干一年。自己努努力，一年以后跳，今年就业形势不太好","createdAt":"2023-04-04T14:19:05"},{"id":"01963de1-0d04-7081-be7f-a1c449022dcd","parentId":null,"rootId":null,"fromId":1492,"content":"我觉着还是看你想不想考研，考研就别去了，住宿舍什么的人多，你也学不下去。不考研了，就干干试试","createdAt":"2023-04-04T14:23:37"},{"id":"01963de1-0d4d-729f-bd2a-743982e90e8b","parentId":null,"rootId":null,"fromId":2830,"content":"长期出差北京，还不如直接去北京找呢","createdAt":"2023-04-04T14:25:00"},{"id":"01963de1-0d9a-711e-8a59-b3634716542f","parentId":null,"rootId":null,"fromId":933,"content":"我是普联的，你是啥岗位啊，才7k，还有是哪个部门哪个项目组，北京出差压力一般不小。","createdAt":"2023-04-04T14:26:08"},{"id":"01963de1-0de4-727a-91ba-236d217df719","parentId":null,"rootId":null,"fromId":1656,"content":"工资还行啊，没经验给7k，只能说长期出差是真滴累","createdAt":"2023-04-04T14:26:26"},{"id":"01963de1-0e29-70bf-98b8-19b093286690","parentId":null,"rootId":null,"fromId":3158,"content":"ETL开发，油田事业部没经验","createdAt":"2023-04-04T14:27:50"},{"id":"01963de1-0e6d-716f-93cd-0fb23a901456","parentId":null,"rootId":null,"fromId":1656,"content":"反正黑名单里有，我朋友在里面待过不是你这个部门，不需要出差，你这个部门不清楚，听说出差北京的挺累","createdAt":"2023-04-04T14:35:06"},{"id":"01963de1-0eb3-739a-a761-156e2213d889","parentId":null,"rootId":null,"fromId":1977,"content":"都长期出差了，为啥直接去北京找个double的呢","createdAt":"2023-04-04T14:39:39"},{"id":"01963de1-0ef8-73f6-b5f2-2900793160b6","parentId":null,"rootId":null,"fromId":3181,"content":"观点同7L一样，长期出差北京，不如找个北京公司 然后出差去全国各地，收入最大化。当然可以先干着，骑驴找马。","createdAt":"2023-04-04T14:40:05"},{"id":"01963de1-0f3e-729f-86ec-68aea1e2d890","parentId":null,"rootId":null,"fromId":3196,"content":"这公司用的他们自己封装的低代码平台，有没有经验都一样。出差得看运气，之前一同事出差啥任务都不分配就坐着玩凑人头数的，也有天天加班到12点的。如果长期在济南这边办公倒还可以考虑，起码基本不加班还有双休，适合摆烂人士","createdAt":"2023-04-04T15:01:56"},{"id":"01963de1-0f83-7192-9555-ea9ff17bdbfe","parentId":null,"rootId":null,"fromId":3196,"content":"再补充一点，这家公司有的项目组编码很混乱。数据库列名全拼音缩写，也没有注释。后台代码是面向过程的，没有分层结构，从数据库查的东西全扔map里往前台传，没有类的概念。sql语句动不动写2kb的文本大小，很难理解逻辑，也没法维护","createdAt":"2023-04-04T15:15:59"},{"id":"01963de1-0fcb-734b-aad2-f666331cffe6","parentId":null,"rootId":null,"fromId":3158,"content":"纠结，我面的岗位就是写sql的","createdAt":"2023-04-04T17:45:17"},{"id":"01963de1-1015-724c-bb9d-e5dc2fecbc67","parentId":null,"rootId":null,"fromId":1177,"content":"建议直接去北京","createdAt":"2023-04-04T17:48:15"},{"id":"01963de1-1059-70f1-aff5-8c5a60e5cded","parentId":null,"rootId":null,"fromId":875,"content":"附议，干嘛不去北京拿双倍工资，拿济南的工资在北京干活？","createdAt":"2023-04-04T18:15:32"},{"id":"01963de1-109e-704b-b066-4d55a36abe7f","parentId":null,"rootId":null,"fromId":2198,"content":"北京比济南好找工作吗","createdAt":"2023-04-04T20:11:45"},{"id":"01963de1-10e6-73d5-bdc8-0d11ea7be92b","parentId":null,"rootId":null,"fromId":2846,"content":"北京好找工作？","createdAt":"2023-04-04T20:14:30"},{"id":"01963de1-1133-7155-a643-015cebd442f4","parentId":null,"rootId":null,"fromId":3158,"content":"在北京拿不到14k啊?","createdAt":"2023-04-04T20:32:05"},{"id":"01963de1-1177-702b-ae8a-d997ecbd1697","parentId":null,"rootId":null,"fromId":3205,"content":"直接别去，去了保准后悔，如果是低代码开发基本上啥东西学不到，加班到十点以后是常态，有时到12点","createdAt":"2023-04-04T22:38:52"},{"id":"01963de1-11bd-72bc-acdb-497cac8a6db1","parentId":null,"rootId":null,"fromId":875,"content":"公积金基数5600比例12%知足吧，我们公积金基数2000比例5%……","createdAt":"2023-04-05T00:04:02"},{"id":"01963de1-1201-7194-b860-c700087ec8ef","parentId":null,"rootId":null,"fromId":2241,"content":"站里有关于普联的帖子 其中很多都是油田事业部的吐槽 可以去看下了解下","createdAt":"2023-04-06T13:46:23"},{"id":"01963de1-1246-72b8-92e9-8b444ae62c4a","parentId":null,"rootId":null,"fromId":455,"content":"低代码开发，加班极其严重","createdAt":"2023-04-07T15:43:12"},{"id":"01963de1-128b-73bb-b21a-51236d45720f","parentId":null,"rootId":null,"fromId":2782,"content":"工作几个月，楼上吐槽的都是真的","createdAt":"2023-04-07T16:58:52"},{"id":"01963de1-0d95-73f0-a2ff-0f6c5cac2c31","parentId":null,"rootId":null,"fromId":3335,"content":"确实，北京的钱可不是济南能比的。半年的外包都能拿11K","createdAt":"2023-05-16T16:48:42"},{"id":"01963de1-12d2-728e-a74b-95585e522030","parentId":null,"rootId":null,"fromId":3892,"content":"楼主现在怎么样了？","createdAt":"2023-08-24T10:54:21"},{"id":"01963de1-0de0-70a3-90e0-d7eab409611d","parentId":null,"rootId":null,"fromId":3892,"content":"老哥，干了多长时间了？感觉怎么样啊？","createdAt":"2023-08-29T09:55:27"},{"id":"01963de1-1316-73d0-a611-6095a3776e33","parentId":null,"rootId":null,"fromId":3158,"content":"很舒服","createdAt":"2023-09-20T16:42:36"},{"id":"01963de1-131b-70c1-b0a7-d0c76f286638","parentId":null,"rootId":null,"fromId":5997,"content":"楼主现在咋样，我差不多也是ETL方向应届，能细聊吗","createdAt":"2023-10-24T13:54:05"},{"id":"01963de1-135f-7052-a4e6-93316f4d43a5","parentId":null,"rootId":null,"fromId":3158,"content":"还行不出差，项目忙时加班","createdAt":"2023-11-10T15:02:41"},{"id":"01963de1-1364-724c-a006-56d51bdfb8d9","parentId":null,"rootId":null,"fromId":21077,"content":"楼主也在油田事业部吗，我现在收到了油田事业部的Java实习岗offer，目前大三，请问这个部门怎么样，值得去吗","createdAt":"2024-06-27T17:27:22"},{"id":"01963de1-13ec-719a-ba94-37803d32b7b5","parentId":null,"rootId":null,"fromId":21673,"content":"有30楼这种人才，各位还敢来吗？\n注：该公司收录于github热门项目 996 ICU","createdAt":"2024-08-15T22:58:32"}]