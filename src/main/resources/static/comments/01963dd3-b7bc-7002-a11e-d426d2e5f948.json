[{"id":"01963dd3-b872-717e-883a-4da6d1a09df9","parentId":null,"rootId":null,"fromId":355,"content":"现在在博晶大厦9楼  一群nt","createdAt":"2022-05-12T17:13:17"},{"id":"01963dd3-b8b6-71f2-84c8-3dcddf827cdc","parentId":null,"rootId":null,"fromId":355,"content":"跟人事谈话 要开录音","createdAt":"2022-05-12T17:33:19"},{"id":"01963dd3-b8fa-73ce-a24b-a5fb90880232","parentId":null,"rootId":null,"fromId":258,"content":"二笔公司，约我去面试等了一个多时候到午饭点才给面试，面试官也是装逼","createdAt":"2022-05-23T13:59:44"},{"id":"01963dd3-b93e-7117-9d9f-007b601ea770","parentId":null,"rootId":null,"fromId":203,"content":"面试官很能装逼","createdAt":"2022-05-23T23:45:42"},{"id":"01963dd3-b983-73f5-bf65-dd0b8facd567","parentId":null,"rootId":null,"fromId":576,"content":"哈哈哈,我过了也没去这家.真是浪费大家试用期时间了","createdAt":"2022-06-01T11:22:33"},{"id":"01963dd3-b9c7-7163-b5e3-44f3c8c7da0a","parentId":null,"rootId":null,"fromId":634,"content":"CEO只会画大饼，公司员工一直就那个数，自己衡量，农业项目没什么前途的","createdAt":"2022-06-02T00:13:04"},{"id":"01963dd3-ba0c-7002-95af-5a87bdf8d509","parentId":null,"rootId":null,"fromId":677,"content":"这公司面试就和玩一样，去面试等了一个小时，最后连技术总监的面也没见到。这不是耽误别人时间嘛。一看也不是什么好公司。幸好没面","createdAt":"2022-06-03T14:52:41"},{"id":"01963dd3-ba50-701a-b80b-96e3483cfe0c","parentId":null,"rootId":null,"fromId":456,"content":"面试官确实是很装逼，一副自己很屌的样子，狗瘠薄不是","createdAt":"2022-06-09T09:01:02"},{"id":"01963dd3-ba9b-7267-a4c5-0f40212a01be","parentId":null,"rootId":null,"fromId":456,"content":"最牛逼的是面试了2个小时，一直到中午12.30才面试完，然后就没动静了。。。。。","createdAt":"2022-06-09T09:03:54"},{"id":"01963dd3-bae1-73d3-b086-882e6453489e","parentId":null,"rootId":null,"fromId":203,"content":"傻逼公司，面试官很能装逼，感觉自己很牛逼的样子","createdAt":"2022-06-10T13:58:58"},{"id":"01963dd3-bb26-7088-adbf-c376b8a580c4","parentId":null,"rootId":null,"fromId":847,"content":"这家面试很搞笑，就是一个xx公司，人生建议不要去，面试都没必要去，面试做脑筋转弯题，连个技术面试也没给安排，在那干等了一个小时，最后通知我你走吧。太傻吊了。","createdAt":"2022-07-01T11:29:38"},{"id":"01963dd3-bb6a-732d-b71e-795e1f69f0ce","parentId":null,"rootId":null,"fromId":999,"content":"我想知道，试用期这个五险一金是怎么回事，楼主能留个方式聊聊嘛","createdAt":"2022-07-18T16:01:50"},{"id":"01963dd3-bbb2-709c-8d11-fb99310b9acc","parentId":null,"rootId":null,"fromId":999,"content":"能讲下为啥NT嘛","createdAt":"2022-07-18T16:28:39"},{"id":"01963dd3-bbf8-72fd-8bbf-d1d3741fb38b","parentId":null,"rootId":null,"fromId":999,"content":"真的很无语，建议别去","createdAt":"2022-07-27T10:04:34"},{"id":"01963dd3-bc49-7038-9ead-058b2e82088f","parentId":null,"rootId":null,"fromId":353,"content":"我也去面试了，就几个人，很不稳定，不推荐去","createdAt":"2022-07-27T10:53:09"},{"id":"01963dd3-bc9e-715f-a2ef-ea733850912f","parentId":null,"rootId":null,"fromId":1078,"content":"HR特别不专业 面试放鸽子 \n本来约好了线上面试，时间是周五下午2点，说会给我发会议邀请，一直没发。\n然后下午1点我问 是不是时间没变，过了十几分钟 hr回复说  去确认一下  。然后这个确认就再也没有回复。哈哈哈  也太不专业了，庆幸的是约的线上  没约线上。","createdAt":"2022-08-03T18:39:01"},{"id":"01963dd3-bce3-718f-9445-0d8eff92d025","parentId":null,"rootId":null,"fromId":1462,"content":"技术面试的时候问了一大队技术问题，最后技术和人事一块过来谈话，说我们不需要技术很强的，最多给你6K，你考虑考虑吧，真是笑了","createdAt":"2022-08-24T10:25:13"},{"id":"01963dd3-bd29-72d0-9c00-21e6d2169c2d","parentId":null,"rootId":null,"fromId":1554,"content":"我之前联系过面试，说我工作经验不到5年，不要我","createdAt":"2022-09-23T13:45:11"},{"id":"01963dd3-bd7d-72a4-8c7d-67dc7a421f2a","parentId":null,"rootId":null,"fromId":1930,"content":"千万别来！千万别来！千万别来！\n我现在在里面上班，马上就会走，等走了我会单独开贴讲讲这个丧良心的公司。","createdAt":"2022-10-11T11:51:34"},{"id":"01963dd3-bdcb-73a4-b8f5-d35617b2af4c","parentId":null,"rootId":null,"fromId":1934,"content":"11楼的小伙子，三道题，第一道是考基础逻辑，第二道是考穷举法，第三道题考递归。\n在你来看只是脑筋急转弯。\n年轻就不要太信口雌黄。","createdAt":"2022-10-11T15:16:57"},{"id":"01963dd3-be10-718d-8cdb-9d4528f06c98","parentId":null,"rootId":null,"fromId":1934,"content":"能问下什么岗位的面试官比较装逼吗","createdAt":"2022-10-12T15:04:57"},{"id":"01963dd3-be56-73f3-ab9d-2fbe19f16eb0","parentId":null,"rootId":null,"fromId":2249,"content":"2023年2月8日，该公司搞些培训，导致家属至今没回家。","createdAt":"2023-02-08T19:55:37"},{"id":"01963dd3-be9d-728d-9f64-0a24208b940e","parentId":null,"rootId":null,"fromId":2613,"content":"什么面试官这么会装逼呢","createdAt":"2023-03-07T13:35:06"},{"id":"01963dd3-bee2-70f6-9cd9-d44eec25aefa","parentId":null,"rootId":null,"fromId":2849,"content":"五一只放三天假期哟","createdAt":"2023-04-21T14:14:29"},{"id":"01963dd3-bf2b-722e-a62b-b6fd397f33dc","parentId":null,"rootId":null,"fromId":3382,"content":"四季为农真的是整个济南最垃圾的公司了，如此变态！！！尤其是人事部的那个神人，真的6！不愧是必普干了6年的人，就会精神洗脑，把公司离职率搞成了70％以上，厉害啊！！","createdAt":"2023-04-25T12:11:14"},{"id":"01963dd3-bf74-70ca-a464-a956e967b475","parentId":null,"rootId":null,"fromId":3382,"content":"想做新媒体的同学，是千万不能来这里！！！太可怕了，我呆了两天立马辞职走人了。听之前的员工说，新媒体的离职率是整个公司最高的！！经常加班到8点以后，累死了。想方设法的给你扣钱，周六周日还得来加个班，晚上被部门领导疯狂的洗脑。咱就说不至于吧？？拿个6k的工资，要奉献自己的全部时间。","createdAt":"2023-04-25T12:14:53"},{"id":"01963dd3-bfc1-72cc-80fe-179179113cee","parentId":null,"rootId":null,"fromId":3382,"content":"我真的笑了！新媒体部门的领导就是一群变态，有张  王  陈  三个人一手遮天 狼狈为奸，比春节晚会都热闹。这三位主管把之前的经理搞走了，现在来了一位姓石的经理，三位人专门建立了小群，不停的骂人家，属实666！！！尤其那个张 和 王   两个人纯纯的恶心人，什么玩意？？？千万别去！！！真的！！！不然你会后悔的，现在人都快走光了，都在跑路！！！没有人能超过两个月！","createdAt":"2023-04-25T12:21:00"},{"id":"01963dd3-bf27-706d-aae1-097d848fffbd","parentId":null,"rootId":null,"fromId":3382,"content":"哈哈哈哈，纯恶心人吧！","createdAt":"2023-04-25T12:21:35"},{"id":"01963dd3-c009-71d2-b3c1-a15df69627f3","parentId":null,"rootId":null,"fromId":3618,"content":"技术不行心机来凑，愚蠢。小垃圾就爱使绊子 企业文化如此吧 虚的一批","createdAt":"2023-05-24T19:49:33"},{"id":"01963dd3-bdc1-732e-a67d-8b22dd95ebdd","parentId":null,"rootId":null,"fromId":3623,"content":"所以，走了吗\n","createdAt":"2023-05-26T15:56:26"},{"id":"01963dd3-bf6f-729b-9af6-2e8e454b4b9c","parentId":null,"rootId":null,"fromId":2267,"content":"确实挺神的，硬生生的搞走一批人 还是大过年","createdAt":"2023-06-06T16:04:30"},{"id":"01963dd3-bdc6-70b4-a55a-8f6f1806ce54","parentId":null,"rootId":null,"fromId":557,"content":"大佬啥时候单独开贴啊","createdAt":"2023-06-08T10:05:55"},{"id":"01963dd3-c04d-7313-9b1c-c0f01281e6d0","parentId":null,"rootId":null,"fromId":1027,"content":"内斗太厉害，小团体多，突出一个人情世故，实则一个个技术烂的要命","createdAt":"2023-06-10T14:41:59"},{"id":"01963dd3-c091-7161-9cd6-e953dfc02aaa","parentId":null,"rootId":null,"fromId":2267,"content":"老哥 刚进去吗 ","createdAt":"2023-06-20T14:55:22"},{"id":"01963dd3-c005-7257-8229-434dcf3329cd","parentId":null,"rootId":null,"fromId":1930,"content":"那个张屁本事没有就一个老板的舔狗，就会在下属面前装b搞内斗。","createdAt":"2023-08-18T10:51:44"},{"id":"01963dd3-bfbc-706a-a557-720e6754ede1","parentId":null,"rootId":null,"fromId":1930,"content":"新媒体部门多恶心啊？","createdAt":"2023-08-18T10:52:02"},{"id":"01963dd3-c095-704a-ba25-5a63ad03e384","parentId":null,"rootId":null,"fromId":1110,"content":"哈哈，一般人情世故突出的公司都是技术烂的不行","createdAt":"2023-08-22T11:25:06"},{"id":"01963dd3-c09a-730d-a287-e54cf8b295d3","parentId":null,"rootId":null,"fromId":5553,"content":"感觉就是各种罚钱，日报晚交罚钱，周末消息不及时读罚钱，开会迟到罚钱，手机响罚钱，以及各种理由罚钱，而且公司本着员工为本，但是实际上公司绩效整的公司员工唉声叹气，不知道是不是老板被瞒着搞的，感觉很多政策都不是以员工为本的角度考虑的","createdAt":"2023-09-03T12:28:22"},{"id":"01963dd3-c0e6-721b-94b0-a77b0d713b6b","parentId":null,"rootId":null,"fromId":1150,"content":"收集好证据  仲裁一把要回来","createdAt":"2023-09-04T08:15:44"},{"id":"01963dd3-c0eb-71bd-9e74-d532e7ba0e35","parentId":null,"rootId":null,"fromId":1930,"content":"哈哈哈，不要想着老板不知道底下人弄的，虽然这种事肯定是他们想出来的，但这些事老板不拍板他们哪敢？当然都是一群吸员工血讨好老板的臭虫，成天舔老板屁股，还说什么“因为相信，所以跟随”，笑死了，还不是自己能力太差只能通过舔老板和压榨员工来证明自己价值？这么高离职率然后编一个“优化员工”，说什么是员工不适应公司，人事干长了都觉得公司是自己的了，自己是一点儿错没有。老板才是最大吸血虫，成天开会鞭策员工赶紧给他赚钱，美其名曰努力、奋斗，百日会战赚了钱给业务团队仨瓜俩枣的就各种炒作发现金，就像是天大的恩情了，没这一百天不休假不回家的员工你能赚来这些钱吗？假装和员工打成一片，其实懂的都懂。公司罚款基本都是违法的，收集证据告无良公司就行。","createdAt":"2023-09-05T11:11:42"},{"id":"01963dd3-c0ef-7068-86c8-6482ffcb7a48","parentId":null,"rootId":null,"fromId":5571,"content":"望见多人挞伐曹操，实则视曹操之立场，言之无不当理。此企业中间层之势弱颓废，高层与底层员工离职率异常之高。新员工如能忍耐一载则属巨毅之士，两载则谓之“老白兔”，三载合约届满将强迫更换聘约于他家(众子企尤多，贤德者皆知之)，足以经受三载以上者，乃为企业之创始时期之正统派。福利待遇方面，五险一金仅按最低比例缴纳，所谓HR之绩效奖金诚信度堪虑，年终奖仅先发半额，余者须待半年之后才予以发放。","createdAt":"2023-11-10T10:25:43"},{"id":"01963dd3-c153-72e2-9c6a-4ee632f96757","parentId":null,"rootId":null,"fromId":6559,"content":"各种福利政策越变越差钱越来越少就不说了，就年会来讲，守着其他部门发业务年终奖，其他部门就了了几个子就很不爽了，再说几个所谓奖项，总经办人事行政人手一个哦，你品，你细品","createdAt":"2024-01-27T06:59:21"},{"id":"01963dd3-c198-709b-8f15-3c819e728f15","parentId":null,"rootId":null,"fromId":5571,"content":"奉劝大家别来，24年转正率要60%以下，想来的琢磨琢磨吧","createdAt":"2024-02-02T15:26:56"},{"id":"01963dd3-c1dc-729f-993a-046bab946059","parentId":null,"rootId":null,"fromId":2380,"content":"一个讲究狼性文化的公司。","createdAt":"2024-02-22T14:00:41"},{"id":"01963dd3-c225-7077-8d6a-200ca3af5d05","parentId":null,"rootId":null,"fromId":5553,"content":"最近怎么没评论的了","createdAt":"2024-05-12T10:51:00"},{"id":"01963dd3-c26d-71c1-927d-d24819f44b5b","parentId":null,"rootId":null,"fromId":5571,"content":"评论的人都被开了","createdAt":"2024-05-13T10:28:34"},{"id":"01963dd3-c272-719d-9c3e-6d6bdabc8581","parentId":null,"rootId":null,"fromId":7427,"content":"被开了不应该更可以评论了吗","createdAt":"2024-05-17T15:22:18"},{"id":"01963dd3-c276-731e-9fc8-5aa49a07eac5","parentId":null,"rootId":null,"fromId":7427,"content":"现在内部还这么乱吗？","createdAt":"2024-05-17T15:36:20"},{"id":"01963dd3-c2c1-7203-9293-722fd753ec68","parentId":null,"rootId":null,"fromId":5987,"content":"不都是忙着在非法集资吗，骗员工众筹","createdAt":"2024-05-17T17:32:51"},{"id":"01963dd3-c34a-7260-bdea-8b39b6464186","parentId":null,"rootId":null,"fromId":22129,"content":"这公司技术部门挺惨的，绩效一点问题不出才能不扣钱\n其他部门甚至直言技术部门可有可无，都开了得了，部门之间很不和谐","createdAt":"2024-10-26T09:41:02"},{"id":"01963dd3-c38e-71ab-bfa2-aab886558ce3","parentId":null,"rootId":null,"fromId":22148,"content":"技术内部比较混乱，脏活累活都是新人的，评优评奖一直是和他一块进来那几个老人去年老人A 今年老人B，背锅一直是新人，我就是这样挤兑走的，降薪逼你走","createdAt":"2024-10-29T11:05:38"},{"id":"01963dd3-c398-7220-86da-be029e918e12","parentId":null,"rootId":null,"fromId":22148,"content":"这个公司拿员工不当人 当机器用；迟到扣钱 开大会都是晚上这就是时间观念了","createdAt":"2024-10-29T11:16:46"},{"id":"01963dd3-c393-704b-b390-44997f320c49","parentId":null,"rootId":null,"fromId":22153,"content":"我是一名在职员工，可以证实 你说的一点都不假；在降薪","createdAt":"2024-10-29T16:07:13"},{"id":"01963dd3-c3dc-7127-bb0f-eb67d095b4bc","parentId":null,"rootId":null,"fromId":22829,"content":"刚跑路的人来说一句，帖子里说的还是太保守了。现在已经变成报销超过5天没提交流程就给你扣了，还美其名曰是给员工减负。其它的槽点，大家说的都差不多，只不过越来越过分了。\n1、说好的14薪，随随便便找个理由就给你砍光了。\n2、新媒体部门的张英豪是个大SB，对人很没有礼貌，欺上瞒下，整天骗别人干活，还各种甩锅。\n3、试岗期没有工资。\n4、CEO朝令夕改，在那上班比坐牢还痛苦，迟到1分钟扣光全勤200元，请假要提前24小时走完流程，遇上突发情况只能旷工。\n5、加班不给调休，好不容易给你调休天数了，但给你拖到清零也不会让你休哒。\n6、说是双休，一个月4周有3周的周六周天给你喊过来不是开会就是打扫卫生。\n7、机器没有人味儿，毕竟不把员工当人，大家在那加班不是装得，是真的干不完。\n8、考勤制度8页纸，财务报销15页，全是坑。\n9、人员流动性很大，动不动就会被离职，有能力的人都会自己早早跑了。\n10、出差标准：去大城市根本找不到住处，睡大马路吧，要么自己贴钱，付费上班了。\n11、不提供电脑，每个月给200块电脑补助，笑死，这种垃圾环境谁能干到电脑回本啊，真会算计。","createdAt":"2025-02-26T16:03:16"},{"id":"01963dd3-c420-70d7-b86f-e6ab679879be","parentId":null,"rootId":null,"fromId":5987,"content":"这个可太正常了，从那个ceo到那个hr，然后加上那个搞培训的nc东西，全都是扯淡个顶个牛逼，办事个顶个傻逼，最离谱的就是那个技术总监，纯纯的只会吹牛逼自嗨，这么个破公司东西，还吹牛逼ddd，搞啥中台，一共服务器都没三台，甩十几个服务，自己的运营下载Excel能打挂线上的核心交易，搜索个日志，能宕机一个数据库，纯粹的nc，一个二十年前的野路子外包仔还硬追潮流","createdAt":"2025-02-26T16:49:10"},{"id":"01963dd3-c425-701a-a399-18002392577c","parentId":null,"rootId":null,"fromId":22972,"content":"我看现在还挂着招聘信息呢，说是要基于DDD微服务架构重构","createdAt":"2025-03-18T18:54:43"},{"id":"01963dd3-c429-7234-9d58-b20ed93f3711","parentId":null,"rootId":null,"fromId":5987,"content":"基于ddd重构，也就是为农企业文化：贷款、打压、爹味","createdAt":"2025-03-19T09:01:39"},{"id":"0196c325-7244-7045-83fb-af378e7e659c","parentId":null,"rootId":null,"fromId":5571,"content":"朝令夕改这个词体现的淋漓尽致","createdAt":"2025-05-12T14:18:53"},{"id":"0196cf44-a022-737c-bb3b-27af994f3485","parentId":null,"rootId":null,"fromId":24118,"content":"最近又又又又朝令夕改了，要离职了","createdAt":"2025-05-14T22:48:23"},{"id":"0196e644-25ca-7309-977f-fb262d8a59e5","parentId":null,"rootId":null,"fromId":6559,"content":"快说说，我要吃瓜","createdAt":"2025-05-19T09:59:07"},{"id":"0196e72d-2721-71d6-bb41-ada08a955501","parentId":null,"rootId":null,"fromId":5571,"content":"又增加福利了，懂得都懂- -","createdAt":"2025-05-19T14:13:38"},{"id":"0196fac6-f903-7236-8bfd-47e13cd2afa3","parentId":null,"rootId":null,"fromId":22466,"content":"远离远离远离","createdAt":"2025-05-23T09:34:26"},{"id":"01970a41-fad3-73ce-b144-3c5e172aeb5e","parentId":null,"rootId":null,"fromId":414,"content":"赶紧出来个老哥说说现在的情况，约我下午面试呢，现在这公司啥情况啊，我都不想去面试了哈哈哈，来人说一下！！！","createdAt":"2025-05-26T09:43:05"},{"id":"01970a63-5223-7072-b916-dcc64aaa920b","parentId":null,"rootId":null,"fromId":414,"content":"不用了，已经拒绝面试了，还没去呢，给我发了个表格和性格测试，那表格内容简直逆天傻逼，有：是否独生子女、是否会开车、是否有车、高考成绩等等。我就面个试，还没入职呢，我凭啥告诉你这些私人信息啊，而且就算入职了，我也不能告诉你这些隐私信息啊，工作这么多年，还没遇到让告诉这些信息的公司，纯纯傻逼，从这个表格就能知道这公司多么的傻逼，草！！！都别去","createdAt":"2025-05-26T10:19:30"},{"id":"01973a12-f54b-71f5-91cd-90864222fb48","parentId":null,"rootId":null,"fromId":5571,"content":"裁人不给赔偿，直接报警，帽子叔叔都来了","createdAt":"2025-06-04T16:33:30"},{"id":"01991387-ddbe-709d-b761-8ff061e36929","parentId":null,"rootId":null,"fromId":5571,"content":"已经没几个人了，也不招人了，情况很不好","createdAt":"2025-09-04T15:01:35"}]