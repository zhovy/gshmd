[{"id":"01963de7-bf7a-70f8-ab36-8078d2915e37","parentId":null,"rootId":null,"fromId":3112,"content":"面试流程如何","createdAt":"2023-09-08T09:57:38"},{"id":"01963de7-bfc2-719a-ba87-fa118ed51cfd","parentId":null,"rootId":null,"fromId":4127,"content":"最初是收到面试通知，说是需要笔试，去了结果没有笔试，就填了一个个人信息表，然后面试，第一次面的是人事主管还是其他的什么领导不清楚，完事以后信息部的经理又面了一次，过程挺坎坷的，几乎把简历上的项目问了一个遍。","createdAt":"2023-09-08T10:47:55"},{"id":"01963de7-bfc7-724c-b766-99b23c35665f","parentId":null,"rootId":null,"fromId":4253,"content":"咋其他的帖子不够你参考吗？","createdAt":"2023-09-08T15:42:08"},{"id":"01963de7-c00c-7116-8d34-507b7deea292","parentId":null,"rootId":null,"fromId":4253,"content":"这么说吧，外包和自己的其实大差不差，外包更恶心一点。","createdAt":"2023-09-08T15:43:27"},{"id":"01963de7-c011-7338-a834-1e129097b366","parentId":null,"rootId":null,"fromId":4127,"content":"我是面的实施岗位，没感受到开发岗位的压力氛围，不过那个面试官是真的能问啊，面了我一个多小时，把我简历上的所有项目挨个问了一遍。","createdAt":"2023-09-08T17:16:35"},{"id":"01963de7-c018-72b5-bae3-1ee47cd65ef9","parentId":null,"rootId":null,"fromId":4253,"content":"你可以去试试","createdAt":"2023-09-11T09:20:18"},{"id":"01963de7-c01c-72d7-a11f-7abea875c8a5","parentId":null,"rootId":null,"fromId":3180,"content":"大哥去了没","createdAt":"2023-12-20T11:05:09"},{"id":"01964d57-ede5-7337-be5a-e9e8416533dc","parentId":null,"rootId":null,"fromId":22724,"content":"看其他帖子说领导骂人，真假？","createdAt":"2025-04-19T17:18:50"}]