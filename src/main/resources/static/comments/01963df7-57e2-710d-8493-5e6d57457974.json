[{"id":"01963df7-5848-7310-ad46-c0ca70938d3a","parentId":null,"rootId":null,"fromId":1955,"content":"佰烧？？还开着门吗？","createdAt":"2025-02-26T14:32:05"},{"id":"01963df7-588b-71df-9cc7-530e097e3b54","parentId":null,"rootId":null,"fromId":22827,"content":"佰烧关了，可能是生意不好挣不到钱了","createdAt":"2025-02-26T14:41:52"},{"id":"01963df7-588f-707e-a768-c913730fd6b1","parentId":null,"rootId":null,"fromId":1955,"content":"佰烧应该是坚挺到最后的了吧","createdAt":"2025-02-26T14:49:49"},{"id":"01963df7-5894-708a-91ca-db8f8cb497de","parentId":null,"rootId":null,"fromId":2545,"content":"去年去过一次那个佰烧，基本没啥值得吃得。倒闭是应该的。当时感觉整个丁豪就没多少人了","createdAt":"2025-02-26T15:02:48"},{"id":"01963df7-58dc-7212-b686-01212795bd36","parentId":null,"rootId":null,"fromId":1955,"content":"丁豪的其实真不咋地，他们万虹比丁豪好太多了","createdAt":"2025-02-26T15:09:39"},{"id":"01963df7-58e0-703f-87dc-99b5c7db9dee","parentId":null,"rootId":null,"fromId":1553,"content":"感觉万虹也快完了,没啥人","createdAt":"2025-02-26T15:43:24"},{"id":"01963df7-58e3-7241-869b-de47a954e802","parentId":null,"rootId":null,"fromId":875,"content":"都摆摊吃烧烤了，两块五一串","createdAt":"2025-02-26T19:28:22"},{"id":"01963df7-5928-704a-a1f4-385b1f7a697f","parentId":null,"rootId":null,"fromId":7568,"content":"万红还真倒不了，每天工作日人不多，但是周末人真多啊。王舍人，恒大城，和周围的农村人都来，人挤人","createdAt":"2025-02-27T10:27:07"},{"id":"01963df7-596d-70b1-bf88-0cd378a23a9a","parentId":null,"rootId":null,"fromId":267,"content":"丁豪好几个店服务态度不好 快完了","createdAt":"2025-03-02T22:10:45"},{"id":"01963df7-59b1-7397-95ad-8116a8a220b0","parentId":null,"rootId":null,"fromId":1933,"content":"高新万达建好以后，丁豪基本上就已经废了，现在靠着楼下卖衣服的撑着","createdAt":"2025-03-10T19:32:34"}]