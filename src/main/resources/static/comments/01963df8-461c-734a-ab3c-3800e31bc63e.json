[{"id":"01963df8-4684-72d8-b441-2baef713d6fa","parentId":null,"rootId":null,"fromId":21302,"content":"看项目组，我22年初干过几个月，朝九晚五，中午休息俩小时，隔断工位，贼爽。技术组不知道啥情况，后面五一让我加班没搭理，来了就让我走了。","createdAt":"2025-03-29T12:04:29"},{"id":"01963df8-46c8-707a-a9d3-0458a3a7586d","parentId":null,"rootId":null,"fromId":1372,"content":"别信。21年在那联通那干过一年多。21-24楼都是他们公司的，里面大部分是保时通这家公司的，也有很多外包。加班很多，官僚气息严重。996也很正常。","createdAt":"2025-03-29T14:36:42"},{"id":"01963df8-4754-715f-9357-9deeea34715c","parentId":null,"rootId":null,"fromId":455,"content":"是联通的项目，不过不在铭盛大厦了，不租了，目前搬到山大路联通省公司或者舜华路联通省公司","createdAt":"2025-03-29T21:54:17"},{"id":"01963df8-4798-7031-a7ea-caa9ec77d8b1","parentId":null,"rootId":null,"fromId":7491,"content":"加班情况咋样，996吗  还是正常按他们说的早9晚5   或者正常加加班 6点  7点都没事","createdAt":"2025-03-31T18:03:27"},{"id":"01963df8-479d-70ab-a846-1c84f808d272","parentId":null,"rootId":null,"fromId":22809,"content":"别去，邮电直签卵用没有。说不要你就不要你，就是外包公司罢了。","createdAt":"2025-04-01T14:13:46"},{"id":"01963df8-47e1-706c-9ef1-8aef5a8dae45","parentId":null,"rootId":null,"fromId":22923,"content":"慎重···","createdAt":"2025-04-02T09:30:43"},{"id":"01963df8-482b-71c9-a2a7-6edd0f3fefd7","parentId":null,"rootId":null,"fromId":22923,"content":"懂的都懂","createdAt":"2025-04-02T09:31:04"},{"id":"01963df8-470c-72a0-9da2-7d52fbac497b","parentId":null,"rootId":null,"fromId":22827,"content":"我也在联通那干过，活多人少，各种零散的工作需要花费很多时间处理，所以得加班干","createdAt":"2025-04-02T09:57:33"},{"id":"01973892-6514-71a1-9153-07884f128846","parentId":null,"rootId":null,"fromId":24445,"content":"5点下班是公司规定下班时间，实际情况是你干到7点会被认为工作量不饱和，开始轮番pua","createdAt":"2025-06-04T09:33:27"},{"id":"01987442-55bb-7208-8c61-77921f527d62","parentId":null,"rootId":null,"fromId":7116,"content":"兄弟有没有入职，这公司现在又开始招人了","createdAt":"2025-08-04T16:46:01"},{"id":"01987d9b-86fc-73fc-9d09-838f0b8bf5f5","parentId":null,"rootId":null,"fromId":26070,"content":"哈哈","createdAt":"2025-08-06T12:20:01"},{"id":"0198dd72-732f-72b4-a9e7-6c7865a95402","parentId":null,"rootId":null,"fromId":22983,"content":"兄弟们有入职的吗，里边啥情况。现在又招聘了","createdAt":"2025-08-25T02:58:42"},{"id":"0198de0c-b686-73cb-b203-aa6f6167d5d9","parentId":null,"rootId":null,"fromId":22120,"content":"已收到offer，有点远，在考虑去不去","createdAt":"2025-08-25T05:47:11"},{"id":"0198dea4-26a9-72de-bb78-30fc62d9cf3c","parentId":null,"rootId":null,"fromId":22699,"content":"我只说一个现实的情况，有项目你就老老实实干，年底没有奖金。没有项目，可以随时滚","createdAt":"2025-08-25T08:32:36"},{"id":"0198df55-1f0a-72b5-af95-6bd35f8c7632","parentId":null,"rootId":null,"fromId":22983,"content":"兄弟这个有考虑到.外包公司都一个德行。只不过里边的项目周期有多长啊，别干几个月就滚蛋了","createdAt":"2025-08-25T11:45:54"},{"id":"0198dfb6-978f-7256-9bc9-18dc7a378fc6","parentId":null,"rootId":null,"fromId":22983,"content":"有好的就别去了","createdAt":"2025-08-25T13:32:22"},{"id":"0198ebcd-ec22-737d-ab81-1b731b3d6ad8","parentId":null,"rootId":null,"fromId":22983,"content":"兄弟去了吗","createdAt":"2025-08-27T21:53:17"},{"id":"0198f0cf-4214-7230-a999-b5c61dd10d07","parentId":null,"rootId":null,"fromId":22120,"content":"没去","createdAt":"2025-08-28T21:12:51"}]