[{"id":"01963df6-fa46-7200-8245-8bd60ec66bbe","parentId":null,"rootId":null,"fromId":6380,"content":"面试官和人力的话信一半都嫌多，就没有不加班的私企公司。","createdAt":"2025-02-15T00:18:44"},{"id":"01963df6-fa8b-73da-b309-b7f0ebe52d60","parentId":null,"rootId":null,"fromId":22138,"content":"24年底面过一次，初面过了跟我约二面，我也答应了把我鸽了。江西的项目需要驻场，一去就是半年，半年轮一次，屎山代码，天天加班，有帖子说这个事的。跑了不少人了","createdAt":"2025-02-18T08:50:51"},{"id":"01963df6-fadb-70b3-b45c-0ce2c8d56ec9","parentId":null,"rootId":null,"fromId":22467,"content":"如果不想自虐的话就别去这个垃圾公司，可以搜一搜之前的帖子，就知道什么德性了","createdAt":"2025-02-20T17:37:58"},{"id":"01963df6-fb1f-71c1-b58d-003494911505","parentId":null,"rootId":null,"fromId":1398,"content":"人力的话不要信?","createdAt":"2025-04-13T18:43:23"},{"id":"01963df6-fb69-719b-b2c9-13aee463587e","parentId":null,"rootId":null,"fromId":21267,"content":"人力是放屁，别信。都别去这家公司，去了就是火坑。江西有个项目简直就是地狱，还不如黑砖窑呢","createdAt":"2025-04-15T09:12:33"},{"id":"01963df6-fad6-707d-8c77-85627a5bcac0","parentId":null,"rootId":null,"fromId":21267,"content":"被折磨跑的，再不跑得疯。公司中高层就是畜生垃圾王八蛋，把父母的的阳寿、子孙的阴德都败光了。","createdAt":"2025-04-15T09:15:04"},{"id":"01963df6-fbb3-7040-bfa4-b8f00e90ed2d","parentId":null,"rootId":null,"fromId":1398,"content":"人力就是?","createdAt":"2025-04-15T14:06:38"}]