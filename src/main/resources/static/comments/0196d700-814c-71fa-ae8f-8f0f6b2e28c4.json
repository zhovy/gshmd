[{"id":"0196d73c-3169-738a-9ca9-ed37648641a6","parentId":null,"rootId":null,"fromId":1372,"content":"有同事在里面，听他说，长期加班，一周至少三四天，技术一般，好处是能正常发工资。对于中级工程师有需求，高级的不要。","createdAt":"2025-05-16T11:56:08"},{"id":"0196e71d-9a30-7271-a07f-23f272005098","parentId":null,"rootId":null,"fromId":1401,"content":"你可以搜下，之前有个这个公司的帖子，说的基本都没有问题。","createdAt":"2025-05-19T13:56:39"},{"id":"0196e721-c037-7179-88c3-8c035257d401","parentId":null,"rootId":null,"fromId":1401,"content":"https://gshmd.vip/posts/01963de7-f9e6-7360-9cd6-033e79debd38","createdAt":"2025-05-19T14:01:10"},{"id":"01981641-7b5c-7105-82fe-8d98c88eeca4","parentId":null,"rootId":null,"fromId":1421,"content":"现在看还挂着，要简历然后没下文","createdAt":"2025-07-17T10:40:46"},{"id":"01981645-eefe-7305-b3fb-99d6e2df55ab","parentId":null,"rootId":null,"fromId":1421,"content":"最烦这种，说是僵尸吧看活跃度还天天聊10+，一聊就是要简历然后各种问（行业经验、离职原因、期望薪资），问完一个流程后没下文，也不知道哪个出现问题了","createdAt":"2025-07-17T10:45:38"},{"id":"01981669-6968-7152-9c0f-b96e2129aec2","parentId":null,"rootId":null,"fromId":1421,"content":"这种一般还是工资问题，如果你5年经验要6k，立刻让你来面试报道","createdAt":"2025-07-17T11:24:23"},{"id":"0198166d-529c-735d-8031-f6cf1f964e53","parentId":null,"rootId":null,"fromId":1421,"content":"老东家，怎么说呢，公司10多年了也就这样了，大的发展肯定无了，总体感觉还是boss眼界问题","createdAt":"2025-07-17T11:28:40"},{"id":"0198173e-f9d0-71cf-b83c-882433ff11bc","parentId":null,"rootId":null,"fromId":1401,"content":"山东的老板怎么说呢，喜欢搞服从性测试。薪资相关的方面会PUA你，让你觉得给你少是应该的。招聘一般是老板娘在回，她一天天闲的没啥事，回复可能是个人爱好。老板娘每天登招聘网站，主要还是为了监控有没有在职的员工在找工作。","createdAt":"2025-07-17T15:17:39"},{"id":"0198173f-c271-73f1-b025-2b1d5f76eec7","parentId":null,"rootId":null,"fromId":1401,"content":"所以各位在职的，不要用公司内登记的手机号刷招聘网站，能查到的","createdAt":"2025-07-17T15:18:31"},{"id":"01981766-a4be-739c-ae60-43392a7764b5","parentId":null,"rootId":null,"fromId":1421,"content":"boss有企业监控员工预警服务","createdAt":"2025-07-17T16:00:59"},{"id":"019817be-6692-7031-ac1a-3a8857e5c047","parentId":null,"rootId":null,"fromId":1401,"content":"是的，就是boss","createdAt":"2025-07-17T17:36:50"},{"id":"01981c9a-6636-7231-84a1-154934871893","parentId":null,"rootId":null,"fromId":7074,"content":"钱少事多加班多，","createdAt":"2025-07-18T16:15:37"},{"id":"01981ca0-6c24-71b2-a394-2fe582b676c6","parentId":null,"rootId":null,"fromId":1401,"content":"工作少的时候也让你正常加班，说是从简入奢易，从奢入简难，怕你以后工作多的时候再加班不适应。","createdAt":"2025-07-18T16:22:12"},{"id":"01982c09-58d4-7395-91bb-bc56a0052a4a","parentId":null,"rootId":null,"fromId":1421,"content":"五思=无思，完全没时间思考","createdAt":"2025-07-21T16:11:06"},{"id":"01982c0a-1373-70b0-a0e7-64a23b6a09cf","parentId":null,"rootId":null,"fromId":1421,"content":"去了吗，让去面试，不知道怎样","createdAt":"2025-07-21T16:11:54"},{"id":"01982fd0-0330-7215-aee9-9aaf594c244f","parentId":null,"rootId":null,"fromId":1401,"content":"去试试吧，反正也没什么的","createdAt":"2025-07-22T09:46:58"},{"id":"0198352c-edb0-72d5-9589-e1c990c18dab","parentId":null,"rootId":null,"fromId":5661,"content":"找工作这么重要的事情，应该找自己同学朋友里面混的NB的人帮忙分析一下，这个网站上能问到啥，问就是血汗工厂，破烂公司。","createdAt":"2025-07-23T10:46:33"},{"id":"01985fb3-a589-7358-9e71-98f1e46faa0e","parentId":null,"rootId":null,"fromId":1421,"content":"感觉现在就是属于套路，说技术缺人，也说需求产品岗感觉工作内容属于售前相关的工作也缺人，让自己选适合哪个，我就是来面技术的扯这个干啥，自己都不知道没想好岗位匹配度让人过去面试，这不是耍人吗","createdAt":"2025-07-31T16:57:45"},{"id":"01985fbf-b6c1-7304-b3cf-f2562370961c","parentId":null,"rootId":null,"fromId":1421,"content":"想找个救火队长式的复合型员工，现在济南这些作坊没多少分工明确的","createdAt":"2025-07-31T17:10:56"},{"id":"019868e0-b78e-707e-87a1-f4588cca6ef6","parentId":null,"rootId":null,"fromId":1421,"content":"垃圾公司，加班多，入职后和面试时候说的差距好大，特别是无效加班这块","createdAt":"2025-08-02T11:43:34"},{"id":"019872ab-9c7d-71fd-b59d-4ee33d057809","parentId":null,"rootId":null,"fromId":1401,"content":"你们不加班老板难受","createdAt":"2025-08-04T09:21:46"},{"id":"0198abab-bb4a-72cb-a027-611cba0eebdb","parentId":null,"rootId":null,"fromId":1421,"content":"这公司技术是不是很老啊","createdAt":"2025-08-15T11:00:15"},{"id":"019ab3c9-cacf-7073-8e25-645f8e01a07c","parentId":null,"rootId":null,"fromId":4088,"content":"五险一金给交多少","createdAt":"2025-11-24T10:55:37"},{"id":"019ab3ca-46a2-7271-99ad-3345bc22c2a9","parentId":null,"rootId":null,"fromId":4088,"content":"你好，请问，五险一金缴纳基数和比例是多少","createdAt":"2025-11-24T10:56:09"}]