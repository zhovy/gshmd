[{"id":"01963df3-3fae-7358-a3b2-37325b395276","parentId":null,"rootId":null,"fromId":2408,"content":"然后呢？","createdAt":"2024-09-19T15:18:58"},{"id":"01963df3-3ff3-72a8-8741-dc4939bf96e8","parentId":null,"rootId":null,"fromId":3801,"content":"水货多了，各行各业都开始要求学历了，以前一个岗位本科优先，现在可能已经要到研究生了，最近打交道的很多应届，感觉本科也就十年前的专科水平，甚至不如。","createdAt":"2024-09-19T15:23:46"},{"id":"01963df3-403f-72e8-9392-304c4f50f1bb","parentId":null,"rootId":null,"fromId":2408,"content":"自己拿到入场券就像关门，任何时代，普通人都喜欢这么像","createdAt":"2024-09-20T00:36:56"},{"id":"01963df3-4083-739d-9b81-ae64c753117e","parentId":null,"rootId":null,"fromId":21053,"content":"你算个jb在这叫唤","createdAt":"2024-09-20T08:35:24"},{"id":"01963df3-40c7-72ba-84a0-461235d1ba34","parentId":null,"rootId":null,"fromId":5705,"content":"扩招本质就是为刺激内需消费和延迟就业的，治标不治本的法子。后果就是造成内卷的，也只能让普通人去承担了。","createdAt":"2024-09-20T08:54:47"},{"id":"01963df3-410c-7178-8c8e-ccf7ec0ecc0f","parentId":null,"rootId":null,"fromId":21642,"content":"十几年前500多分走的专科，后悔不已，还不如去三本","createdAt":"2024-09-24T10:00:01"},{"id":"01963df3-414f-721c-a889-fe0d829c7bbc","parentId":null,"rootId":null,"fromId":5584,"content":"不是大学生多 是学IT的人太多了","createdAt":"2024-09-25T19:21:47"},{"id":"01963df3-4194-70b2-96c9-567a44779f0b","parentId":null,"rootId":null,"fromId":3705,"content":"不扩张没办法啊。\n\n换句话说，如果不扩张，考不上学的孩子们就得去社会上打工，还不一定能找到工作，这算什么？妥妥的失业率啊（狗头）","createdAt":"2024-09-26T10:36:21"},{"id":"01963df3-41d9-719a-88ef-fe05dc7321ae","parentId":null,"rootId":null,"fromId":59,"content":"找不到工作就容易扎堆，容易对社会不满，就容易滋生暴乱，让他们在学校多好，消费能力强能带动周边各种经济，外面父母还得当牛马挣钱给他们花，一举多得","createdAt":"2024-10-15T11:21:27"}]