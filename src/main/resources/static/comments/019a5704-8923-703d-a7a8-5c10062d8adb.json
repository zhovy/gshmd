[{"id":"019a5718-3561-714f-abef-0490f6e0a32b","parentId":null,"rootId":null,"fromId":22459,"content":"工作的紧俏度，以及归属感","createdAt":"2025-11-06T10:56:35"},{"id":"019a57c6-0b41-702c-b93f-06c0a8bbb73b","parentId":null,"rootId":null,"fromId":22702,"content":"没有什么标准，就像我现在，背着房贷，找不到工作，但是买房的时候就业还是很好的，现在成这样了，现在房子还不够贷款，又能怎么办","createdAt":"2025-11-06T14:06:28"},{"id":"019a57c6-c568-700e-b865-22602fcf5a33","parentId":null,"rootId":null,"fromId":22250,"content":"你现在戾气大不大，要不要去游行一波","createdAt":"2025-11-06T14:07:15"},{"id":"019a57d3-cd6d-730a-bfe9-d5325dfc52e9","parentId":null,"rootId":null,"fromId":2921,"content":"有没有第三个选项，去北京上海？","createdAt":"2025-11-06T14:21:29"},{"id":"019a5811-a33a-70d2-bebc-dbb75478a698","parentId":null,"rootId":null,"fromId":23888,"content":"哈人，晶哥打过来我第一个run","createdAt":"2025-11-06T15:29:02"},{"id":"019a5813-4dce-71d2-b3e5-2896e723c628","parentId":null,"rootId":null,"fromId":4140,"content":"我前端时间也失业了，在济南找了两个月，没找到合适的，家里到是找到了，现在已经回老家了，但是偶尔还是怀念济南的生活，超意兴啊，趵突泉啊，和一堆好吃的，主要济南生活确实比较惬意，而且物价很低，但是就业实在一言难尽，感觉在济南就必须得考公务员，事业编才能享受这些，不然都很不稳定","createdAt":"2025-11-06T15:30:51"},{"id":"019a585c-4b3d-73c3-8231-9268fcb455ef","parentId":null,"rootId":null,"fromId":22699,"content":"一看你就是一个前端开发工程师","createdAt":"2025-11-06T16:50:34"},{"id":"019a5896-9938-72e5-9b55-c266152b1d88","parentId":null,"rootId":null,"fromId":414,"content":"老家有IT?","createdAt":"2025-11-06T17:54:15"},{"id":"019a5b96-ea41-7195-bbd1-33a13784dc6f","parentId":null,"rootId":null,"fromId":4140,"content":"后端开发，济南的得加班，大小周，家里的不用加班，管吃管住，还有福利分房，济南比家里多给三四k吧，想了想还是没留济南，压力太大","createdAt":"2025-11-07T07:53:28"},{"id":"019a62cf-2645-71db-b0e7-a47f784ace07","parentId":null,"rootId":null,"fromId":267,"content":"泉啊啥的没啥好玩的，真的好处就是餐饮这块选择多，别的没什么","createdAt":"2025-11-08T17:32:14"},{"id":"019a6b00-aa88-728b-8582-63a9fabadb29","parentId":null,"rootId":null,"fromId":875,"content":"这个是真的吗，大家都去哪里了","createdAt":"2025-11-10T07:43:17"},{"id":"019a6b11-d721-7170-8cc8-99a63b1a24ff","parentId":null,"rootId":null,"fromId":2408,"content":"30年，日月山川都会发生变化，你们是怎么敢贷款30年的","createdAt":"2025-11-10T08:02:02"},{"id":"019a6b18-8068-71cc-9ffd-c15a3c58d4ec","parentId":null,"rootId":null,"fromId":5689,"content":"说的对，30年前贷款买房的人都笑醒了。","createdAt":"2025-11-10T08:09:19"}]