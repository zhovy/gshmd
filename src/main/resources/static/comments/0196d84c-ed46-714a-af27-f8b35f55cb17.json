[{"id":"0196d86c-adc8-70e4-98c9-8f45a963c654","parentId":null,"rootId":null,"fromId":7566,"content":"1、看浪潮这边的审批进度，我当时面过了浪潮外包后一个星期就入职了，但是有的人面过浪潮外包后需要两个星期甚至更长时间才能入职，这一切都取决于浪潮这边的审批流程进度；2、多想不开来浪潮当外包。","createdAt":"2025-05-16T17:28:43"},{"id":"0196d8e4-dffe-72d6-be84-6ec2077804c1","parentId":null,"rootId":null,"fromId":1110,"content":"想要你分分钟就审批通过了，不然就是备胎","createdAt":"2025-05-16T19:40:00"},{"id":"0196dbf2-79ac-7262-a222-3e0ed9267a89","parentId":null,"rootId":null,"fromId":7124,"content":"浪潮外包，请自带水","createdAt":"2025-05-17T09:53:43"},{"id":"0196dce3-03d4-70e0-9ded-a0765c692882","parentId":null,"rootId":null,"fromId":5910,"content":"劝你别来","createdAt":"2025-05-17T14:16:27"},{"id":"019a00f3-2fa8-72bf-8e1b-0578182a057b","parentId":null,"rootId":null,"fromId":2558,"content":"兄弟你在浪潮吗 加班多吗","createdAt":"2025-10-20T17:28:48"},{"id":"019a00f3-6170-7373-b899-c3788bc96ce6","parentId":null,"rootId":null,"fromId":2558,"content":"哥们 你在浪潮吗","createdAt":"2025-10-20T17:29:01"},{"id":"019a044f-cfa5-728d-99a0-3345325f4f5b","parentId":null,"rootId":null,"fromId":7566,"content":"之前还在浪潮，现在去北京工作了。我所在的部门虽然也是经常加班，但是加班也不算多。加班多少看部门的。","createdAt":"2025-10-21T09:08:50"}]