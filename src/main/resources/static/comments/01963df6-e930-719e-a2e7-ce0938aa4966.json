[{"id":"01963df6-e994-725e-91be-42c827dad336","parentId":null,"rootId":null,"fromId":22723,"content":"你去面试了吗？怎么样","createdAt":"2025-02-15T09:51:33"},{"id":"019757df-a3e8-71c0-aeb4-40b5388398c4","parentId":null,"rootId":null,"fromId":1421,"content":"这公司怎么样啊，各位大佬","createdAt":"2025-06-10T11:26:03"},{"id":"0197beac-572b-73e0-b784-7f9b4586bae5","parentId":null,"rootId":null,"fromId":3495,"content":"同问","createdAt":"2025-06-30T10:30:55"},{"id":"0197d9d7-9e65-7290-87b7-f95434777b18","parentId":null,"rootId":null,"fromId":1110,"content":"咋样？","createdAt":"2025-07-05T17:07:56"},{"id":"01981189-4378-7032-854c-c083f5f24acf","parentId":null,"rootId":null,"fromId":5911,"content":"面试了，他们的项目就一个标准的增删改查，但是面试需要你非常懂分布式事务 + redis锁  实际工作1~3年完全能写。面试的是个光头，特别喜欢问分布式事务  redis加锁算法，，，没啥用，不要去，加起来没10个人","createdAt":"2025-07-16T12:41:05"},{"id":"01993390-0d6e-738f-ad3f-a052974608b5","parentId":null,"rootId":null,"fromId":3495,"content":"加班加到死，只要加不死就往死里加！总部菏泽，济南是一个分公司，所以大部分都是从总部调过来的菏泽人，地域歧视很大，他们本地人都互相关照，关系户也不少，排挤其他地方的人，恶心的要死！领导恶心，同事也恶心，还经常加班，领导说话跟放屁似的，一天一个样！","createdAt":"2025-09-10T20:18:22"},{"id":"01993616-f60d-70b0-b2c8-274913e25f95","parentId":null,"rootId":null,"fromId":23605,"content":"是大小周吗 加班这么严重吗","createdAt":"2025-09-11T08:04:58"},{"id":"01993d45-6870-7134-8bed-15f7f99e177c","parentId":null,"rootId":null,"fromId":246,"content":"有这么差劲吗  面试的人都说说怎么样啊","createdAt":"2025-09-12T17:33:02"},{"id":"01995b6f-de3e-71db-95bb-5deeb2effa70","parentId":null,"rootId":null,"fromId":7491,"content":"情况基本属实，加班狠 办公楼烂 ，而且电梯经常发生坠梯事故，一困就是半小时起步， 大小周实属折磨  ，而且有可能休都不给休 直接加班淌过去，，总结 不想死得快 就别去找罪受","createdAt":"2025-09-18T14:08:02"},{"id":"0199705a-2f3a-73ba-9f4b-80116308c28e","parentId":null,"rootId":null,"fromId":246,"content":"幸好没去","createdAt":"2025-09-22T15:36:22"},{"id":"019990fb-bb26-70a1-a8fc-d5818e3bf897","parentId":null,"rootId":null,"fromId":3495,"content":"开发技术总监姓刘，手下有一个开发也姓刘，同学关系，不只他俩，还有老板姓崔，项目总监姓段，都是同学，他们都互相维护，欺负排挤外来人，看你不顺眼拿你当骡子使，随便给你派活就是故意整你。他们觉得根本不缺人，有人来干一点是一点，总会有人来干的，也总会有干完的那一天的，所以能抽打就抽打不管你的死活！！","createdAt":"2025-09-28T23:40:40"},{"id":"01999861-4898-72df-870c-af0346a51934","parentId":null,"rootId":null,"fromId":246,"content":"这公司是不是搞诈骗的？","createdAt":"2025-09-30T10:08:56"},{"id":"0199e611-1b59-737e-9d38-9ca298e150be","parentId":null,"rootId":null,"fromId":3495,"content":"确实差劲??，面试了，面试官牛逼哄哄的，看不起人的样子","createdAt":"2025-10-15T12:11:44"},{"id":"0199e747-43a6-72b0-a9c5-5bb119575425","parentId":null,"rootId":null,"fromId":3495,"content":"哈哈，这个b公司，当初少发给我的工资就当是献祭了，祝该公司各位领导用的开心","createdAt":"2025-10-15T17:50:31"},{"id":"019a72be-7371-71af-a6d2-7118b5a90fdb","parentId":null,"rootId":null,"fromId":3495,"content":"确实，同学朋友合伙的公司，身边都是他妈的奸细，难受的要死","createdAt":"2025-11-11T19:47:55"},{"id":"019a812e-af6c-703d-8e4b-af15da357e43","parentId":null,"rootId":null,"fromId":7491,"content":"小心点吧，他们内部的人 也知道这个地址了，没准暗地里调查 谁背后说他们坏话，然后给你们一锅端 开调了。。。。\n\n\n傻逼公司有傻逼的管理，一群傻逼草台班子，  \n\n\n看清楚现实  及时止损 赶紧跑路 省的呆在那 恶心自己，，，早走早解脱","createdAt":"2025-11-14T15:05:11"},{"id":"019a8141-88d2-7367-a929-6d22b48da78d","parentId":null,"rootId":null,"fromId":7491,"content":"放下个人素质， 享受美好生活，预期为难自己 比如恶心别人！！！","createdAt":"2025-11-14T15:25:47"}]