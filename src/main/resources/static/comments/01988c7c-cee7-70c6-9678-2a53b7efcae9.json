[{"id":"01988c89-0b43-72cd-aec7-4810885ff8f8","parentId":null,"rootId":null,"fromId":6747,"content":"你这个是啥岗位，公司坐班的还是项目上的","createdAt":"2025-08-09T09:54:08"},{"id":"01988ce5-53bb-71fc-929b-fbdb9d6fc611","parentId":null,"rootId":null,"fromId":7124,"content":"会说你就多说点","createdAt":"2025-08-09T11:34:56"},{"id":"01988db5-9128-702f-b2e5-f0ff0a4a5094","parentId":null,"rootId":null,"fromId":926,"content":"软件相关的还是啥？","createdAt":"2025-08-09T15:22:23"},{"id":"01988ffe-f524-7202-8ba6-1b1ac251c848","parentId":null,"rootId":null,"fromId":267,"content":"工业南路海信贤文，聚学云也是超级坑，挺有名的","createdAt":"2025-08-10T02:01:47"},{"id":"019893ed-a46d-72ce-8075-9733acff23c4","parentId":null,"rootId":null,"fromId":3450,"content":"我在济南一建上过一年班，前端岗位，我证明楼主说的都是真的，而且当时对我承诺第一年先签外包合同，一年后签正式合同，但是一年到了后压根没提，我去问也跟我说现在工资帽不够，没法签正式，这谁还跟你玩，直接辞职，真是垃圾公司","createdAt":"2025-08-10T20:21:21"},{"id":"0198968a-0028-701e-b6b9-1d5a536889d8","parentId":null,"rootId":null,"fromId":21511,"content":"建筑行业也敢去？","createdAt":"2025-08-11T08:31:23"},{"id":"0198969d-3bdd-7322-ba6e-32f9eaaae05a","parentId":null,"rootId":null,"fromId":25373,"content":"前端开发","createdAt":"2025-08-11T08:52:23"},{"id":"0198969d-b587-7357-916c-a0c6e3d2c9df","parentId":null,"rootId":null,"fromId":25373,"content":"软件开发相关人员","createdAt":"2025-08-11T08:52:54"},{"id":"0198969e-e48a-7049-8a39-f592d1423809","parentId":null,"rootId":null,"fromId":25373,"content":"朋友你还呆了一年啊，我这一个月就受不了。有个经理转正式申请，一直被卡着，也是不走。","createdAt":"2025-08-11T08:54:12"},{"id":"0198969f-7fd6-73f2-97af-47354315036d","parentId":null,"rootId":null,"fromId":25373,"content":"诶，这不是被国企的名头忽悠了。进来就祛魅了","createdAt":"2025-08-11T08:54:52"},{"id":"0198979e-93b3-7028-9738-4768c3fa0e85","parentId":null,"rootId":null,"fromId":5689,"content":"看来我挺明智的，大约是23年吧，他们打电话，约我上午十点面试。到了地方让我先填表找地方坐下，一看周围10多个人，全在那个屋里干巴巴的坐着，一问全是面试的。就这样等到12点，就进去面试一两个人，其他人还一直在那坐着。我直接甩手走了，就这种没有时间观念的企业，我估计管理者也不会把打工人当人看，也不知道剩下那十几个面试者中午咋吃饭的。。。","createdAt":"2025-08-11T13:33:28"},{"id":"0198a622-ed7c-7338-bb9e-574f4908f40b","parentId":null,"rootId":null,"fromId":4092,"content":"哥们你啥时候入职的，我去面试过，前两轮面试让我等了好久，说是签第三方小公司，周六上半天班平时也加班，3轮面试我就没去?，没想到你入坑了","createdAt":"2025-08-14T09:12:43"}]