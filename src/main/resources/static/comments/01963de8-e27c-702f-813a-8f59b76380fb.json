[{"id":"01963de8-e2e4-703b-a891-02e0ff4e87be","parentId":null,"rootId":null,"fromId":3828,"content":"我是青岛面的一面电话面，全程不问项目，像是拿着网上的八股文一个个问的，二面现场面，去的时候发现办公地点不大，门口都坐着人，也是全程不问项目，拿着你简历的技能挨个问，问spring, mvc, boot有什么区别，怎么启动一个项目，稍微回答慢点直接说过，你问啥都不理你，给我感觉不太尊重人，可能只是那个人是那样，对公司不做评价","createdAt":"2023-10-11T18:00:55"},{"id":"01963de8-e331-70f0-8bb0-03eba9e1fd1b","parentId":null,"rootId":null,"fromId":1553,"content":"培训机构，骗钱的吧","createdAt":"2023-10-11T19:54:22"},{"id":"01963de8-e3b9-706f-9ed3-43dba3620309","parentId":null,"rootId":null,"fromId":1398,"content":"恶意压价，要 8 压到 6","createdAt":"2023-10-13T10:09:43"},{"id":"01963de8-e3ff-71cb-9cfe-e17957852ffe","parentId":null,"rootId":null,"fromId":1398,"content":"已经屏蔽","createdAt":"2023-10-13T10:22:21"},{"id":"01963de8-e32c-72d4-83a0-13e5eef9c880","parentId":null,"rootId":null,"fromId":1398,"content":"态度确实有问题，感觉像是谁欠了他钱一样，没见过这样的人，感觉脑子不会转弯一样","createdAt":"2023-10-13T10:23:38"},{"id":"01963de8-e446-72e3-b503-7ebed9c69bfe","parentId":null,"rootId":null,"fromId":6173,"content":"收人只要能上得了出差项目的，项目少了，时间长点没上去的就得立马滚蛋，得自己签个人离职申请呢","createdAt":"2024-09-18T23:10:54"}]