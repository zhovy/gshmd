[{"id":"01989821-8be8-73f8-982c-d7293a50a244","parentId":null,"rootId":null,"fromId":24780,"content":"必须录用你才不是刷KPI么？能给说不通过这不就是面试结果么？","createdAt":"2025-08-11T15:56:32"},{"id":"01989855-44d0-7361-a153-b8f170825c02","parentId":null,"rootId":null,"fromId":7566,"content":"我两年前也面试过，只是收了简历，问了问当前薪资等基本情况，然后就让我回去，回去后告诉我面试不通过，也不知道是为什么，可能是在刷KPI吧","createdAt":"2025-08-11T16:53:01"},{"id":"0198ab72-3a29-7141-8cd9-d524b14109a3","parentId":null,"rootId":null,"fromId":4092,"content":"你没看人家的工资范围吗？ 之前3-6K后来3-8K 去面试干嘛","createdAt":"2025-08-15T09:57:26"},{"id":"0198ac50-779d-707c-b19c-2a05967c8bc5","parentId":null,"rootId":null,"fromId":7566,"content":"现在这找工作的现状，对于很多初级程序员来说3-8k的工资已经很好了","createdAt":"2025-08-15T14:00:11"},{"id":"0198bae1-8954-731d-bed1-d41ea2bc22ab","parentId":null,"rootId":null,"fromId":3355,"content":"初试只有hr了解基本情况，hr将情况反馈给老板再看老板有没有时间进行复试，大概率是有被刷kpi了","createdAt":"2025-08-18T09:53:19"},{"id":"0198bae7-dd08-7295-a6d4-a87ba069bb71","parentId":null,"rootId":null,"fromId":1421,"content":"同样情况，就是刷kpi","createdAt":"2025-08-18T10:00:14"},{"id":"0198bb3c-3310-717c-86d5-de2d5c77d82a","parentId":null,"rootId":null,"fromId":7566,"content":"阁下也被刷KPI了？","createdAt":"2025-08-18T11:32:21"},{"id":"0198bb5c-50c8-71b6-bcc7-f82d38c7d90e","parentId":null,"rootId":null,"fromId":1421,"content":"嗯，和楼主情况差不多，hr随便聊聊就让回去了，连等通知的客套话都没说","createdAt":"2025-08-18T12:07:26"},{"id":"019a24a0-c8a4-715b-8e21-f54ac2982551","parentId":null,"rootId":null,"fromId":24086,"content":"同样情况，还进了二面了，可能是薪资给不到，后来就没消息了","createdAt":"2025-10-27T15:45:08"},{"id":"019a2509-fd78-7080-88ba-94dc17cfa22a","parentId":null,"rootId":null,"fromId":7566,"content":"敢问您期望的薪资是多少呢？人家能给的薪资大约是多少呢？","createdAt":"2025-10-27T17:40:03"}]