[{"id":"0199d281-9332-719e-9bbd-b68db68957b1","parentId":null,"rootId":null,"fromId":7170,"content":"二房东吧\n\n当时刚来济南让二房东坑了不少，建议大家尽可能避开二房东","createdAt":"2025-10-11T17:02:11"},{"id":"0199d28e-4fee-7118-8565-fa5138b7bd69","parentId":null,"rootId":null,"fromId":27118,"content":"分人，房主也有不退押金的，退房的时候恨不得让你重新给装修一遍，我上一个房东，邓家花园的一个叫陈芳的，就是那种人","createdAt":"2025-10-11T17:16:05"},{"id":"0199d28f-5c2d-7121-b605-987445d9053e","parentId":null,"rootId":null,"fromId":27118,"content":"回迁的老房子，家里并没有新家具，墙上有个印都得扣50","createdAt":"2025-10-11T17:17:14"},{"id":"0199db40-f7f3-7033-9bd5-908e6571f66d","parentId":null,"rootId":null,"fromId":26153,"content":"这个人不退押金，合同到期不回消息，会消失","createdAt":"2025-10-13T09:48:12"},{"id":"0199dcb6-0eb6-73da-b40b-3fbee1fd7fc4","parentId":null,"rootId":null,"fromId":25423,"content":"你也从他这租的吗？?中介一个","createdAt":"2025-10-13T16:35:42"},{"id":"0199e70d-0438-70c1-ad68-e74aa77cf673","parentId":null,"rootId":null,"fromId":2483,"content":"这个叼毛我好像有印象，我以前也在他这租过房子，退租的时候坑了我一把，好歹最后押金是退了。不过已经好几年了，不知道现在啥情况","createdAt":"2025-10-15T16:46:54"},{"id":"0199ec0f-2eb5-71cb-b34e-10a3aa19a876","parentId":null,"rootId":null,"fromId":25423,"content":"现在依旧很坑，这才租了几个月就给我拉黑了，骗子一个","createdAt":"2025-10-16T16:07:22"},{"id":"019a0aa7-40de-7178-ad4e-100ebb408023","parentId":null,"rootId":null,"fromId":26153,"content":"是的，之前租的他的房子，最后不退押金，联系不到人","createdAt":"2025-10-22T14:42:04"}]