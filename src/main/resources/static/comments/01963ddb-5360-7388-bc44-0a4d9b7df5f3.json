[{"id":"01963ddb-53d8-7136-bc5b-c0ee916f7332","parentId":null,"rootId":null,"fromId":1225,"content":"我也想知道，楼主去了吗感觉咋样","createdAt":"2022-08-05T16:03:35"},{"id":"01963ddb-541c-71b5-adae-fa969c4a9ae0","parentId":null,"rootId":null,"fromId":1346,"content":"除了社保公积金少点，其他没什么问题。","createdAt":"2022-08-15T15:42:42"},{"id":"01963ddb-5460-7067-956b-7d13b8a68286","parentId":null,"rootId":null,"fromId":353,"content":"哈哈，我是这个公司好多年老员工，还不错的，来吧","createdAt":"2022-08-22T17:07:35"},{"id":"01963ddb-54a6-7213-b9ad-a38cedbc086f","parentId":null,"rootId":null,"fromId":1225,"content":"农行驻场加班挺严重的","createdAt":"2022-09-07T17:03:42"},{"id":"01963ddb-54ec-7150-9e58-e3c11b79ece0","parentId":null,"rootId":null,"fromId":353,"content":"加班？哪个公司不加班。。","createdAt":"2022-09-14T09:43:51"},{"id":"01963ddb-5531-7046-9709-706ac06d7ba5","parentId":null,"rootId":null,"fromId":3992,"content":"管理比较混乱，一个领导一个想法，干活的人也不知道听谁的。小团体不少，整天勾心斗角，尤其号称老员工的团体组织，只要惹到他们了，那就给你穿小鞋，没好日子过。所谓的老员工，能力一般，甩锅第一。","createdAt":"2023-07-05T16:53:34"},{"id":"01963ddb-5576-71aa-a7a6-2b14a5df9007","parentId":null,"rootId":null,"fromId":1225,"content":"确实是，而且基本上都是专科，今年才开始本科起招","createdAt":"2023-07-17T10:02:54"},{"id":"01963ddb-557a-72ba-8c77-d2c78f149021","parentId":null,"rootId":null,"fromId":4036,"content":"公司内部比较混乱，领导不会别的只会让你加班，进度不管，干完活也得加班靠时间，平时加班是义务加班啥都没有，周末加班给调休，但是你用调休休假公司会扣你绩效，不建议现在来，已经和之前不一样了","createdAt":"2023-09-12T15:40:39"},{"id":"01963ddb-55bf-73b7-8400-61718b97c7c6","parentId":null,"rootId":null,"fromId":1225,"content":"确实是，比之前差远了越来越扣了，也不涨工资了","createdAt":"2023-09-14T17:00:16"},{"id":"01963ddb-55c4-718b-a611-6983c0a5f1fa","parentId":null,"rootId":null,"fromId":5699,"content":"加班严重嘛？","createdAt":"2023-09-21T17:33:28"},{"id":"01963ddb-560b-7218-a3e9-db101b0b67bf","parentId":null,"rootId":null,"fromId":1225,"content":"办公环境很差劲","createdAt":"2023-09-28T10:52:05"},{"id":"01963ddb-5653-71db-a430-c967030e93b1","parentId":null,"rootId":null,"fromId":5647,"content":"请问是在总部，还是哪个银行，我刚面试了这个公司","createdAt":"2023-09-28T11:10:03"},{"id":"01963ddb-5657-71cd-b4d2-8f972e91d1ab","parentId":null,"rootId":null,"fromId":1225,"content":"银行驻场技术很老学不到东西，总公司很小很破","createdAt":"2023-09-28T14:56:53"},{"id":"01963ddb-565b-713e-924a-f4eb2577d551","parentId":null,"rootId":null,"fromId":5647,"content":"面试的时候，总部确实不大，这个岗位比较适合什么样的人啊？","createdAt":"2023-09-28T17:27:27"},{"id":"01963ddb-5660-71b9-9ea9-0328d33dd6c3","parentId":null,"rootId":null,"fromId":1225,"content":"你面的公司还是驻场呀","createdAt":"2023-09-28T17:39:04"},{"id":"01963ddb-5664-738a-9ed6-5e4575afac86","parentId":null,"rootId":null,"fromId":1225,"content":"工资很低，银行应该工资高一点，驻场没几个想去的","createdAt":"2023-09-28T17:40:36"},{"id":"01963ddb-5668-722c-b7fd-380cf74c987a","parentId":null,"rootId":null,"fromId":5647,"content":"驻场是不是加班很多，很累的啊？","createdAt":"2023-09-28T17:43:34"},{"id":"01963ddb-5606-703d-9945-ab3d9c37232c","parentId":null,"rootId":null,"fromId":1225,"content":"累不是主要的，主要是学不到东西，刚毕业去驻场就废了","createdAt":"2023-09-28T17:46:44"},{"id":"01963ddb-566d-7260-9ff9-06687073832e","parentId":null,"rootId":null,"fromId":1225,"content":"驻场跟客户面对面打交道，碰到脾气不好的客户直接被骂死，项目经理都经常被骂","createdAt":"2023-09-28T17:49:10"},{"id":"01963ddb-5671-7352-8c54-d127fae80303","parentId":null,"rootId":null,"fromId":5647,"content":"唉，应届生真的很难找工作啊，尤其是代码学的又不好。你是还呆在里面吗？","createdAt":"2023-09-28T17:57:30"},{"id":"01963ddb-5675-71b9-9ac2-2b2241da3947","parentId":null,"rootId":null,"fromId":403,"content":"很多年前在嘉友呆过，那时候还没上市，名字叫山东嘉友科技有限公司。当时的管理水平就不咋滴，我因家属重病请了2天假去医院陪床，周一回来就被人事通知降薪，理由是不服从加班。问题是那根本不算请假，是公司安排周末两天加班，我也跟公司提前打好招呼了。周一回公司时，领导对我的家人非但没有表现出一丁点言语上的关怀和问候，反而搞逆向操作直接找我谈话说要降薪，它的降薪理由也是非法的，咱就别说什么”人性化“这种高要求了，这公司连最起码的遵纪守法也达不到。","createdAt":"2023-10-06T18:40:06"},{"id":"01963ddb-56be-729f-9f46-1e9fb02b95c0","parentId":null,"rootId":null,"fromId":3992,"content":"现在公司怎么样了？什么情况了有知道的吗？","createdAt":"2024-05-14T16:07:07"},{"id":"01963ddb-5703-72c6-86ec-07276414da33","parentId":null,"rootId":null,"fromId":7081,"content":"还行，除了公积金少点，工作强度真不算大，基本上稳定双休没啥问题","createdAt":"2024-07-09T12:06:26"},{"id":"01963ddb-5707-70d9-a915-0ec4c64cf5a6","parentId":null,"rootId":null,"fromId":6035,"content":"那真是良心企业了。","createdAt":"2024-07-09T12:34:29"},{"id":"01963ddb-570c-7322-a6dd-c0d6c2469dc1","parentId":null,"rootId":null,"fromId":21701,"content":"周二·、周四固定加班","createdAt":"2024-08-20T13:59:11"}]