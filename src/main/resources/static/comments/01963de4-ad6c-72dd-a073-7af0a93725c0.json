[{"id":"01963de4-adcf-70fb-a102-ee61cd02e85f","parentId":null,"rootId":null,"fromId":3703,"content":"待遇非常好，也不是很累。但是近几年效益不好，研发任务少，容易裁员","createdAt":"2023-07-08T09:30:10"},{"id":"01963de4-ae2a-726b-8a07-cd4d3a5b09ec","parentId":null,"rootId":null,"fromId":3801,"content":"浪潮云算比较不错的了，就是没活的时候也容易加班内卷，算是浪潮的企业文化了，能接受的话可以去。","createdAt":"2023-07-08T10:58:05"},{"id":"01963de4-ae13-7149-a095-f52c5ff07a67","parentId":null,"rootId":null,"fromId":4014,"content":"今年行情，20k都要不到，真难","createdAt":"2023-07-08T17:55:02"},{"id":"01963de4-ae6f-72e3-abe4-8f9601988033","parentId":null,"rootId":null,"fromId":4014,"content":"没活也加班??","createdAt":"2023-07-08T17:55:24"},{"id":"01963de4-ae18-73f6-a679-94fec501f10c","parentId":null,"rootId":null,"fromId":4016,"content":"济南要2万，老板得盯死你","createdAt":"2023-07-08T22:53:59"},{"id":"01963de4-ae1b-7228-9ba6-a0aaefc4d4d3","parentId":null,"rootId":null,"fromId":875,"content":"那就要两万五","createdAt":"2023-07-08T22:56:36"},{"id":"01963de4-ae21-726f-a685-e01c4cc39e41","parentId":null,"rootId":null,"fromId":875,"content":"刚毕业的怎么能要到一万加","createdAt":"2023-07-08T23:24:35"},{"id":"01963de4-ae73-738d-a7d6-e29fd2e8d022","parentId":null,"rootId":null,"fromId":875,"content":"得算时薪，加班时间长，得算一个月平均一个小时多少钱，有100块可以去","createdAt":"2023-07-09T09:59:37"},{"id":"01963de4-ae77-7144-bbe9-25e5f67a3dd5","parentId":null,"rootId":null,"fromId":3801,"content":"浪潮有没有活基本下班都没走的，周六有没有事都来公司转一圈，尤其是正式员工，这是企业文化！","createdAt":"2023-07-10T08:16:09"},{"id":"01963de4-ae25-73e5-81f1-86fcd8764ab6","parentId":null,"rootId":null,"fromId":2082,"content":"不是985 211 够呛 \n","createdAt":"2023-07-10T14:13:58"},{"id":"01963de4-ae7b-73e4-b928-9026efd82878","parentId":null,"rootId":null,"fromId":3996,"content":"实力劝退 不要去","createdAt":"2023-07-12T13:57:45"},{"id":"01963de4-aec1-73cf-8413-c7566c28b556","parentId":null,"rootId":null,"fromId":4014,"content":"啊，能具体说下嘛","createdAt":"2023-07-12T14:40:19"},{"id":"01963de4-aec6-72b8-b05d-d1388a4e0879","parentId":null,"rootId":null,"fromId":3703,"content":"加班看在哪个组，一般是周二周四加班到8点，平常六点半左右走，有的组要求大小周。每年都会有前移计划，让研发转销售，去了要做好随时跑路的准备。","createdAt":"2023-07-12T18:23:23"},{"id":"01963de4-aeca-71c2-a2e2-f58f65fd791d","parentId":null,"rootId":null,"fromId":3741,"content":"浪潮云工资还是挺高的，我同事跳槽过去了，五年给15，主要全额社保香啊","createdAt":"2023-07-14T15:34:04"},{"id":"01963de4-af0f-70c2-a618-209bf58ec19b","parentId":null,"rootId":null,"fromId":4010,"content":"15不高吧，加班多吗","createdAt":"2023-07-14T15:37:02"},{"id":"01963de4-af1a-70a7-a96c-3d03b1ce2327","parentId":null,"rootId":null,"fromId":1398,"content":"浪潮国际属于那个啊？","createdAt":"2023-07-14T15:46:29"},{"id":"01963de4-af15-709e-a282-c825b2cf79b7","parentId":null,"rootId":null,"fromId":4014,"content":"几年经验呀","createdAt":"2023-07-18T21:26:36"}]