[{"id":"01963df0-e023-70ab-8b99-8196e42ec934","parentId":null,"rootId":null,"fromId":3892,"content":"刷KPI，别去","createdAt":"2024-06-19T09:09:16"},{"id":"01963df0-e06c-717e-8f78-c6cc30bc4b2b","parentId":null,"rootId":null,"fromId":2525,"content":"我搜过也都是说刷kpi的，好奇有面进去的么","createdAt":"2024-06-19T13:43:08"},{"id":"01963df0-e0b4-7271-bbbb-b31af5256f02","parentId":null,"rootId":null,"fromId":1164,"content":"除了刷kpi,还会骗方案","createdAt":"2024-06-19T14:05:21"},{"id":"01963df0-e0fc-73bc-a0a3-565336a98cb7","parentId":null,"rootId":null,"fromId":7510,"content":"线上面，还是群面，然后就没消息了","createdAt":"2024-06-19T14:20:23"},{"id":"01963df0-e140-7268-80e2-dc1d387c9745","parentId":null,"rootId":null,"fromId":2525,"content":"面试的什么岗位呀","createdAt":"2024-06-20T16:33:16"},{"id":"01963df0-e144-7081-bff2-c22f425655b0","parentId":null,"rootId":null,"fromId":5375,"content":"4月底面的前端，面完告知通过了是去外包，要求马上入职，五一也要求过去加班，感觉很急，不敢去怕是一时着急要人","createdAt":"2024-06-20T16:51:15"},{"id":"01963df0-e151-738a-8c29-bd3f449cfce0","parentId":null,"rootId":null,"fromId":21038,"content":"有外包（主要给联通供人），也有自研，看岗位了，刷KPI不存在，因为公司没有KPI","createdAt":"2024-06-25T22:06:04"},{"id":"01963df0-e0f7-71c1-ae0d-081a8c4bf4cc","parentId":null,"rootId":null,"fromId":21038,"content":"我怎么不记得骗过别人的方案啊","createdAt":"2024-06-25T22:06:58"},{"id":"01963df0-e148-7027-a519-851a84517856","parentId":null,"rootId":null,"fromId":21038,"content":"最近联通给我们要的人比较多，都是群面","createdAt":"2024-06-25T22:07:50"},{"id":"01963df0-e0af-7203-a019-d9f33883f485","parentId":null,"rootId":null,"fromId":21038,"content":"我司还在招人，想知道不如试试","createdAt":"2024-06-25T22:08:52"},{"id":"01963df0-e067-7130-8235-c3496db2c16d","parentId":null,"rootId":null,"fromId":21038,"content":"天地良心，我们真没kpi","createdAt":"2024-06-25T22:09:25"},{"id":"01963df0-e194-7042-9e5f-aece59dc04b8","parentId":null,"rootId":null,"fromId":2525,"content":"那联通项目结束后怎么办","createdAt":"2024-06-26T08:36:10"},{"id":"01963df0-e199-71c0-8c2b-0f7ae1ebeaba","parentId":null,"rootId":null,"fromId":21038,"content":"外包这块，我们供人之前会跟客户协商好，这个人就是在客户这里长期用（短期我们不做，不划算），并且统一接受客户方的领导，我们给客户招的人，最长的已经在客户那干了4年了，除了一个作了大妖（想起来就恨。。。。）被客户退回来让我们开了的个例，其余还没有让客户主动退回的其他例子","createdAt":"2024-06-26T09:11:34"},{"id":"01963df0-e19d-73a9-ae86-eeebc79e17c8","parentId":null,"rootId":null,"fromId":3892,"content":"怎么不是刷KPI呢？投了简历之后HR立马约面试，可能连简历都没仔细看。去了面试官随便问几个问题就打发了，后续问面试结果要么是没出来要么是告知负责人出差。一个人说刷KPI可能是偶然，这么多人说难道都是面试人的问题？","createdAt":"2024-06-26T09:15:11"},{"id":"01963df0-e1a2-72e6-b6e4-c769e94e8f9d","parentId":null,"rootId":null,"fromId":1018,"content":"现在不招人了吧 没看到有招聘","createdAt":"2024-06-26T10:08:39"},{"id":"01963df0-e1ea-704d-b4c4-190f3e0b989e","parentId":null,"rootId":null,"fromId":2494,"content":"哈哈哈,看来都面过","createdAt":"2024-06-27T09:38:50"},{"id":"01963df0-e1e5-70d3-a210-0c8420872909","parentId":null,"rootId":null,"fromId":21038,"content":"招，请注意智联招聘发布的信息","createdAt":"2024-06-28T08:23:10"},{"id":"01963df0-e22e-7286-8f9c-acaab4608654","parentId":null,"rootId":null,"fromId":21038,"content":"这么多人说刷KPI呢，统一回复，确实没有刷这一说，招人面试这活累的不得了，做过面试官的都知道，一天面10几个人什么感觉，那晚上回家脑子都嗡嗡的啊，上班整天累成狗哪tm有心情陪你玩这个。\n说我们刷KPI的，我也理解你们的想法，无非是觉得，我擦我这么个人才你们这小po公司怎敢三言两语打发我，而且竟然还敢不给我发OFFER。\n拜托，各位老板，我们也不可能给来面试的每个人都发offer吧，你也不可能去每个公司面试都能拿到OFFER吧。我们编制紧张的一笔，尤其针对自研岗位，我们进一个人要经过两轮面试三级审批，哪有这么容易就招到这么多级领导都满意的人？\n最后在说一下哈，没有通过面试的各位老板，我们没有觉得各位不优秀的意思，只是说我们觉得有更合适的选择适罢了，好不，先这样，有问题可以留言，干活去了","createdAt":"2024-06-28T08:39:26"},{"id":"01963df0-e272-7251-b820-b15f4fd8bb66","parentId":null,"rootId":null,"fromId":21038,"content":"再补充一点，一般来说面试完两天内没接到通知的，基本来说就GG了，除非第一候选人他不来，对于我们觉得合适的人，我们都是上赶着去当舔狗的","createdAt":"2024-06-28T08:52:28"},{"id":"01963df0-e14d-70ed-ba25-3d48ba840407","parentId":null,"rootId":null,"fromId":3446,"content":"五一加班，不会是我们部门吧，某社会服务??","createdAt":"2024-06-28T15:44:31"},{"id":"01963df0-e2b7-705d-a21e-71ec34466048","parentId":null,"rootId":null,"fromId":3446,"content":"你们是不是和邮电设计院是一家啊","createdAt":"2024-06-28T15:47:40"},{"id":"01963df0-e2bd-7231-9a29-e39c4f104fc6","parentId":null,"rootId":null,"fromId":21038,"content":"跟规划院木有关系","createdAt":"2024-06-28T21:25:56"},{"id":"01963df0-e2c1-7298-af1d-f2244bfd1753","parentId":null,"rootId":null,"fromId":21761,"content":"外包公司，劳务派遣","createdAt":"2024-12-25T09:37:46"},{"id":"0196e845-9ee3-71fb-9fa0-d1f9b63b85de","parentId":null,"rootId":null,"fromId":21761,"content":"劳务外派，快跑","createdAt":"2025-05-19T19:19:58"},{"id":"019a3840-94ab-72e0-814c-a48a7588e150","parentId":null,"rootId":null,"fromId":2846,"content":"垃圾公司别去","createdAt":"2025-10-31T11:12:27"},{"id":"019a3864-d94c-707c-a3a1-3a29b3ed646e","parentId":null,"rootId":null,"fromId":5491,"content":"去之前  问清楚是外包还是多少   不是外包 工资都是   这种大国企  好像薪资不高 但是稳定点      都是靠项目油水  不过退休金好点","createdAt":"2025-10-31T11:52:04"}]