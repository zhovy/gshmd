[{"id":"01963dd1-5f5f-721d-8a03-5f5b2d4f93a6","parentId":null,"rootId":null,"fromId":138,"content":"上面写的是真的，白眼狼 疫情一波骚操作将我们开了\n拖欠3月的工资\nU•ェ•*U","createdAt":"2022-03-14T18:08:29"},{"id":"01963dd1-5fa9-73a6-91f5-dc321d0bc9b1","parentId":null,"rootId":null,"fromId":851,"content":"听说了，坑了两三月的工资","createdAt":"2022-07-01T09:29:44"},{"id":"01963dd1-5fec-718d-ad4d-6b4e4b05a19d","parentId":null,"rootId":null,"fromId":2225,"content":"三年前去过这家公司，感觉特别的奇怪。\n1. 早会和传销似的，天天洗脑\n2. 工作氛围特别的压抑，同事之间感觉欠别人钱似的\n3. 销售人员特别的横，有种倚老卖老的感觉\n4. 每天都加班，虽然没有明文规定加班，但是你要是早走，第二天就找你事\n5. 三个月后找各种理由不转正","createdAt":"2022-11-21T18:34:45"},{"id":"01963dd1-6037-730c-b17b-d222eb41ff74","parentId":null,"rootId":null,"fromId":2225,"content":"要求员工周末值班，并且不算加班，不算调休，不知现在还这样么","createdAt":"2022-11-21T18:41:22"},{"id":"01963dd1-6081-70cc-871f-b0b8dcb38f2b","parentId":null,"rootId":null,"fromId":4143,"content":"好几年前去面试过，系统原来好像是.net想 自己弄团队重构成java的。 \n个人认为本身不是软件企业，想自己开发维护一套系统，肯定是开发的时候招人，完事了就裁人的这种。所以当时就没考虑。","createdAt":"2023-07-20T10:01:06"},{"id":"01963dd1-607b-73c7-ae52-f0d89275f25a","parentId":null,"rootId":null,"fromId":2225,"content":"四年前 在这家公司待过 和你描述的一样","createdAt":"2023-08-02T09:26:33"},{"id":"01963dd1-5fa4-726c-b306-6e906ba9cf46","parentId":null,"rootId":null,"fromId":2225,"content":"上面描述的全是真的，不仅如何，还工作气氛压抑，天天和传销似的","createdAt":"2023-08-02T09:27:27"},{"id":"01963dd1-6032-73de-9450-3a4ee0c6f9df","parentId":null,"rootId":null,"fromId":2225,"content":"哥们你说的太对了  我当初就是这样被坑的","createdAt":"2023-08-02T09:28:02"},{"id":"01963dd1-60c6-7211-b9de-2d69262c6829","parentId":null,"rootId":null,"fromId":2225,"content":"同事们一天天的没有任何交流，工作压抑，天天和传销似的","createdAt":"2023-08-02T09:31:12"},{"id":"01963dd1-6151-73b7-93e2-5825f15654c1","parentId":null,"rootId":null,"fromId":22976,"content":"我当时也去过，待了一上午我就跑了，签了一堆空白合同，周六还值班【捂脸笑】","createdAt":"2025-03-19T11:30:47"}]