[{"id":"0197cba1-26c9-70cc-aab6-2fcf6d789253","parentId":null,"rootId":null,"fromId":1049,"content":"不是，哥们，你不要太离谱","createdAt":"2025-07-02T22:53:45"},{"id":"0197cda5-df41-72fb-a887-783df7097677","parentId":null,"rootId":null,"fromId":5480,"content":"你从泰聘上属实有点离谱，这不是泰安招聘的软件吗，上面有啥好企业？还有你说的12小时也能干，这种的一般是类似黄岛海尔那种厂，12小时还上夜班，这玩意真不是一般人能忍受的，不建议你年纪轻轻就干这","createdAt":"2025-07-03T08:18:09"},{"id":"0197cdbb-9e75-716e-a966-41618f4968e1","parentId":null,"rootId":null,"fromId":21267,"content":"这种网站太小众了，建议换其它招聘网站试试","createdAt":"2025-07-03T08:41:54"},{"id":"0197cdbd-9ab8-731a-bd42-1c94fbab31ba","parentId":null,"rootId":null,"fromId":5624,"content":"12小时都能干，你当奴隶呢","createdAt":"2025-07-03T08:44:04"},{"id":"0197cdc6-7048-729d-a892-bc29f869b298","parentId":null,"rootId":null,"fromId":6740,"content":"不是哥们，市场都是你们把大专生搞得很廉价吧，企业不就蹬鼻子上脸了，学历是低，但是不是slave","createdAt":"2025-07-03T08:53:43"},{"id":"0197cdfc-d3b5-710f-bf03-d1cc9519580e","parentId":null,"rootId":null,"fromId":21267,"content":"没学历学历低的可不就得去工厂，都抵制不可能的，你低估了人性，有骨气也得吃饭，一分钱难倒英雄汉。错的不是人，是制度！！制度和思想不开化，有再牛的高楼大厦大国重器都是白搭。","createdAt":"2025-07-03T09:53:08"},{"id":"0197e94b-6bac-7294-8aa7-2e7e199252fa","parentId":null,"rootId":null,"fromId":25686,"content":"还是个人能力问题吧，去电子厂才能挣多少","createdAt":"2025-07-08T17:08:43"},{"id":"019909d3-ac19-7327-8d8a-2624da03dc54","parentId":null,"rootId":null,"fromId":1538,"content":"咱能不这么卷不,啥叫12小时也能干,太过分了吧","createdAt":"2025-09-02T17:48:11"}]