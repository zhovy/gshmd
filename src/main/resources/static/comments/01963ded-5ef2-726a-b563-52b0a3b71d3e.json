[{"id":"01963ded-5f5a-7152-a2f9-0b39b541471b","parentId":null,"rootId":null,"fromId":6829,"content":"先找找 看看能找到你期望的工资不，现在大部分公司往往都是工资给的不高，还把人当牛马","createdAt":"2024-04-07T10:43:43"},{"id":"01963ded-5fa3-7229-8345-9528c626b20e","parentId":null,"rootId":null,"fromId":3341,"content":"缺钱就跳 不缺钱无所谓就不跳，就是这么简单的道理呀\n富二代家里有钱 毫无压力 必然是选择养老单位\n不是富二代 需要自己挣钱就跳多挣点钱能让自己生活质量提升一下 \n单身 无车贷房贷 不想努力 就不跳 \n自己对号入座一下看看自己是哪一个类型  就有答案","createdAt":"2024-04-07T10:44:34"},{"id":"01963ded-5f9e-70e3-9438-b8ceeb9d0187","parentId":null,"rootId":null,"fromId":3341,"content":"。。。他不是说已经拿到offer了 且涨幅50%","createdAt":"2024-04-07T10:45:03"},{"id":"01963ded-602b-739a-9280-39bbc488ccc8","parentId":null,"rootId":null,"fromId":7107,"content":"这个风险完全没有。现在行情确实差，面试机会少到手offer也少而且还压工资，虽然比现在公司薪资高 但是996还有出差997 福利也没有待遇很一般.所以有些纠结。现在公司能给涨薪但幅度不大，就怕去了新公司干了一段时间接受不了高前度出差 还得出来继续面。","createdAt":"2024-04-07T11:05:29"},{"id":"01963ded-602f-7009-a5d4-43ffa672e099","parentId":null,"rootId":null,"fromId":1492,"content":"安逸点吧，996和出差，真的受不了。或者观望下","createdAt":"2024-04-07T11:18:14"},{"id":"01963ded-6073-73be-aa60-fc558acf3c71","parentId":null,"rootId":null,"fromId":7107,"content":"?","createdAt":"2024-04-07T11:22:29"},{"id":"01963ded-6078-731d-8829-315ca677e343","parentId":null,"rootId":null,"fromId":875,"content":"想安逸，考公去，从20岁考到40岁，怎么不得中一次\n河南、山东率先调整公务员招录年龄至 40 岁，释放出什么信号","createdAt":"2024-04-07T12:34:33"},{"id":"01963ded-60bf-71a7-a5a3-224a40162b93","parentId":null,"rootId":null,"fromId":7107,"content":"嗯嗯。正有此打算。也不是贪图安逸，就是出差997有点伤害家庭伤害身体。","createdAt":"2024-04-07T12:52:08"},{"id":"01963ded-60c3-71f7-b791-2925d9a328bc","parentId":null,"rootId":null,"fromId":629,"content":"现在几年多少钱啊楼主","createdAt":"2024-04-07T14:47:15"}]