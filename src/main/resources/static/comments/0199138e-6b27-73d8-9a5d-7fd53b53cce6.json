[{"id":"019913a0-f32e-73eb-8eee-4b6684d9b873","parentId":null,"rootId":null,"fromId":796,"content":"招人的和找工作的都沉默了   这文学功底也没谁了","createdAt":"2025-09-04T15:28:59"},{"id":"0199140c-673e-73c9-8a5b-86b300fe8498","parentId":null,"rootId":null,"fromId":3450,"content":"是，开社招的公司是垃圾公司，社招来的人也都是垃圾人","createdAt":"2025-09-04T17:26:21"},{"id":"0199141e-5b77-70a4-9796-50692916b631","parentId":null,"rootId":null,"fromId":1538,"content":"看这话的意思是: 人是垃圾","createdAt":"2025-09-04T17:45:57"},{"id":"01991423-29e6-73f9-b635-0c7d07c447c1","parentId":null,"rootId":null,"fromId":24615,"content":"根据我近半年的招人面试情况，3年的比较水，跟应届生差不多，但要的薪资却比应届生多几千，性价比低，目前都放弃了；五六年的水平可以，虽然薪资多但确实能来干活，只要不是太水都可以长期办公，最近招的3个人都是这些年限的；8年及以上的不同人差别很大，主要是在他们自己那一行干的太久了，有的常年干些简单或者小众的项目（尤其是外包），有的常年干非常规范的重点项目，简直一个天上一个地下，对各种认知完全不在水平上，如果公司有钱或者需要这种高技能人才的话，确实比较香","createdAt":"2025-09-04T17:51:12"},{"id":"01991428-6228-7198-904e-213b1b87c581","parentId":null,"rootId":null,"fromId":24615,"content":"性价比的话，我觉得是五六年》应届生》两三年，有钱的话选能力强的8年及以上的人，尤其是常年在大厂干重点业务的那种","createdAt":"2025-09-04T17:56:54"},{"id":"0199174c-24e9-7332-9c6c-63416a4fc181","parentId":null,"rootId":null,"fromId":5624,"content":"出院","createdAt":"2025-09-05T08:34:50"},{"id":"0199177e-25a9-7163-9baf-bfc7a416ff16","parentId":null,"rootId":null,"fromId":3263,"content":"其实8年的也不贵，有些甚至不到 13k","createdAt":"2025-09-05T09:29:27"}]