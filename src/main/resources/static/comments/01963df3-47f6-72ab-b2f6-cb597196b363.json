[{"id":"01963df3-485a-7368-a716-5068f4b26493","parentId":null,"rootId":null,"fromId":21907,"content":"你培训的什么，Java？","createdAt":"2024-09-21T16:50:25"},{"id":"01963df3-489e-72e1-b270-e05f6f256f32","parentId":null,"rootId":null,"fromId":4140,"content":"大学有四年时间在b站上免费学，是没有学的；毕业了啥也不会到处找工作，是找不到的；想培训一下包装一下简历再找工作，是被骗的，最后来一句济南IT工作真垃圾，这是很难评的。","createdAt":"2024-09-23T09:46:37"},{"id":"01963df3-48e8-7208-91b9-58b127bd1db9","parentId":null,"rootId":null,"fromId":4140,"content":"现在这样你就看看你的合同能退款吗，要是合同上没有退款项，就老老实实上好进社会的第一课吧，一般这种公司早都把法律条文都研究明白了，你就好好把技术学好，把项目经验学好，当你下一次找工作的跳板，要是因为这个事对工作也自暴自弃，那才是真的得不偿失","createdAt":"2024-09-23T09:48:56"},{"id":"01963df3-492b-7199-babd-2e4df3e46137","parentId":null,"rootId":null,"fromId":7124,"content":"中肯，80%的毕业生肯定都经历过这种公司，我印象最深的就是叫什么青鸟的15年 16年的时候吧","createdAt":"2024-09-25T17:33:02"},{"id":"01963df3-48e4-71ca-8dbd-91d91369c5f6","parentId":null,"rootId":null,"fromId":5624,"content":"秀","createdAt":"2024-12-13T15:55:08"}]