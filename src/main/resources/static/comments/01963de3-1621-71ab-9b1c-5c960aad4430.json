[{"id":"01963de3-1689-71e1-85bb-f2b9ed6508d3","parentId":null,"rootId":null,"fromId":3272,"content":"给的不低，我拒了，应该还行","createdAt":"2023-05-26T13:05:07"},{"id":"01963de3-16d2-7074-8f2f-386b18370c1b","parentId":null,"rootId":null,"fromId":2680,"content":"据说不加班比较稳定，最高好像17~18k","createdAt":"2023-05-26T13:48:00"},{"id":"01963de3-1717-707f-95fa-c59fcf5e2d54","parentId":null,"rootId":null,"fromId":875,"content":"外包不能干","createdAt":"2023-05-27T20:40:50"},{"id":"01963de3-16cd-716f-b238-1a6d73a7f978","parentId":null,"rootId":null,"fromId":2056,"content":"为啥","createdAt":"2023-05-27T21:47:28"},{"id":"01963de3-1761-724d-adb1-a00d4e2e35a4","parentId":null,"rootId":null,"fromId":2628,"content":"现在不是一个上海的，叫海啥的公司的外包，最高给15吗，哪里来的17 18","createdAt":"2023-05-29T10:12:07"},{"id":"01963de3-17a8-730e-8d41-329367640b47","parentId":null,"rootId":null,"fromId":3333,"content":"什么深复蓝吗","createdAt":"2023-05-29T10:16:56"},{"id":"01963de3-17ac-73f8-bc65-2c8097cacc4a","parentId":null,"rootId":null,"fromId":4144,"content":"本人现在就在中泰研发某部外包岗。上班时间8:30-17:00， 大多数情况18点多就下班走了。加班看你所属项目紧急程度，我们团队都是在已经上线的项目上加功能，所以节奏不快，工作日加班不多，周末双休，很少有加班情况。我们公司另一个团队的同事进的新项目组，加班就很多，基本996，没加班费、加班餐，不过可以调休，看他干得还挺开心。他这边做的都是自己的项目，自己做自己用，是所以基本没有甲乙方矛盾，也不会一直赶工期。外包都在二楼，中泰内部人员都在别的楼层，一天基本见不到领导，所以下班不用担心看领导走没走的问题。中午吃饭可以去内部食堂或者附近餐馆。这边对考勤要求比较高，迟到早退扣钱挺多。还有查纪律的，被逮到违纪可能会扣钱或者严重直接让你离场。\n总结就是还不错，在济南范围感觉算是比较好的了。","createdAt":"2023-07-19T18:29:20"},{"id":"01963de3-1806-72e8-a992-18d61aad03ea","parentId":null,"rootId":null,"fromId":333,"content":"你们年假能正常休吗","createdAt":"2023-07-20T09:08:35"},{"id":"01963de3-180b-7373-b791-523416e80763","parentId":null,"rootId":null,"fromId":6170,"content":"外包测试岗怎么样","createdAt":"2023-11-25T14:24:23"}]