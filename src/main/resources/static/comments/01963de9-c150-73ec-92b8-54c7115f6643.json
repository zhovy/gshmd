[{"id":"01963de9-c1b5-70cc-a3de-d93482541f23","parentId":null,"rootId":null,"fromId":875,"content":"个人感觉，去外包都是增删改查，没啥核心技术，面试的时候人家人力可能会问你为啥上家工资干的这么短，不稳定哦，为啥去外包？是技术不行嘛，除非外包给到远超非外包的薪资，否则不去","createdAt":"2023-11-19T20:33:37"},{"id":"01963de9-c1ff-7271-99c2-dbccf3a94cd7","parentId":null,"rootId":null,"fromId":3892,"content":"感谢老哥解答，一年半工作经验找了一个半月都没有合适的工作，我同学在浪潮外包，他说他那领导很好，想着能不能进浪潮外包踏踏实实干个两年，学点东西，两年后提跳出来，去个神思电子啥的。今年浪潮外包也不好进，面三个选一个，行情太差了，有些焦虑","createdAt":"2023-11-19T20:47:07"},{"id":"01963de9-c204-73e3-ae52-4e80d2fa1c6e","parentId":null,"rootId":null,"fromId":5966,"content":"浪潮外包每个部门的情况是不一样的，你朋友既然说他们那个部门不错，要是能进你朋友的那个部门还好，要是去其他部门可能跟你预料的有很大的出入，望慎重","createdAt":"2023-11-20T01:37:31"},{"id":"01963de9-c247-72a6-bf1d-a26771e8cea6","parentId":null,"rootId":null,"fromId":3892,"content":"嗯嗯，感谢老哥解答","createdAt":"2023-11-20T16:43:42"},{"id":"01963de9-c293-71c6-abe9-a22fb757ead8","parentId":null,"rootId":null,"fromId":3892,"content":"懂了，听说现在地纬很疯狂，活不多开始加班了。我去年在地纬电力中心的时候地纬还挺好，有些怀念","createdAt":"2023-11-20T16:44:33"},{"id":"01963de9-c29b-7225-8b0e-adb60637558a","parentId":null,"rootId":null,"fromId":2177,"content":"不建议去神思电子","createdAt":"2023-11-20T17:26:13"},{"id":"01963de9-c2e9-716d-bb1d-d9eeaa445412","parentId":null,"rootId":null,"fromId":3892,"content":"为啥这么说？我以为这是家好企业呢","createdAt":"2023-11-20T17:32:36"},{"id":"01963de9-c2f7-71a1-a1c5-412a8bb24fff","parentId":null,"rootId":null,"fromId":6159,"content":"济南没有好公司，很快中国都没有了","createdAt":"2023-11-22T18:05:07"},{"id":"01963de9-c349-7048-89ab-8b9792775f39","parentId":null,"rootId":null,"fromId":2919,"content":"楼主大哥去了吗？","createdAt":"2023-11-27T14:05:34"},{"id":"01963de9-c394-7253-a279-2b3c4a893793","parentId":null,"rootId":null,"fromId":2919,"content":"求楼主大哥回复QAQ","createdAt":"2023-11-27T14:09:49"},{"id":"01963de9-c390-723b-a660-7e82fce5c466","parentId":null,"rootId":null,"fromId":3892,"content":"打算去了，这几天就准备入职了。如果你打算去浪潮外包的话，面试的时候问好工作时间，技术栈啥的。现在浪潮外包也不好进，面试三个，五个进一个","createdAt":"2023-11-27T20:14:17"},{"id":"01963de9-c3db-7142-94ca-9e10030c6eb5","parentId":null,"rootId":null,"fromId":6186,"content":"你去哪里了，别来浪潮软件，浪潮电商","createdAt":"2023-11-28T14:50:27"},{"id":"01963de9-c41f-73b8-8ef6-8795b35369b1","parentId":null,"rootId":null,"fromId":3892,"content":"浪潮国际，现在在走入职流程了，我有同学在那，部门还算比较不错得了","createdAt":"2023-11-28T22:55:28"},{"id":"01963de9-c424-7384-a6f4-90a97202d0eb","parentId":null,"rootId":null,"fromId":3892,"content":"收到offer了，浪潮通用软件。即使差也得去啊，得有个工作","createdAt":"2023-11-29T10:51:51"},{"id":"01963de9-c428-70b7-a422-92c3c2c15a85","parentId":null,"rootId":null,"fromId":6186,"content":"找多久了","createdAt":"2023-11-30T14:20:07"},{"id":"01963de9-c2ed-73a8-aadb-39add937ea05","parentId":null,"rootId":null,"fromId":5990,"content":"老哥能细说一下吗","createdAt":"2023-12-01T15:32:34"},{"id":"01963de9-c42d-707f-b4a6-ee19af1e1ceb","parentId":null,"rootId":null,"fromId":6239,"content":"浪潮通软怎么样？加班厉害吗","createdAt":"2023-12-07T10:56:56"},{"id":"01963de9-c46f-7234-8cd7-76dd66c9eaf5","parentId":null,"rootId":null,"fromId":3892,"content":"不好说，分部门。我刚来两天，我这个部门还好，加班少，11点30多就去吃饭，有的部门12点还没走。浪潮总体来说加班都不少","createdAt":"2023-12-07T11:25:47"},{"id":"01963de9-c473-7382-9452-b8d1ab808104","parentId":null,"rootId":null,"fromId":2919,"content":"老哥，现在感觉咋样耶？","createdAt":"2023-12-14T10:55:31"},{"id":"01963de9-c4b8-7252-887f-066e7b9126f6","parentId":null,"rootId":null,"fromId":3892,"content":"我这还行，双休不加班，一般六点左右就走了。但是我有两个同学，一个正式，一个外包，都在996","createdAt":"2023-12-14T14:32:09"},{"id":"01963de9-c298-735a-b648-4ea22c6fd140","parentId":null,"rootId":null,"fromId":1164,"content":"楼主后悔从地玮跑路了？","createdAt":"2024-01-05T13:17:50"},{"id":"01963de9-c2f2-7075-af78-02b6558e12f8","parentId":null,"rootId":null,"fromId":5624,"content":"不建议","createdAt":"2024-07-31T21:25:10"},{"id":"019a0194-1b3e-7022-9002-e1c41b5063f1","parentId":null,"rootId":null,"fromId":26822,"content":"兄弟，工业互联网部门咋样","createdAt":"2025-10-20T20:24:34"}]