[{"id":"01963dd3-afa9-72b6-98fa-9b6c5d81898a","parentId":null,"rootId":null,"fromId":297,"content":"老板姓牛，整天就会吹牛逼，项目干完了就把你给辞退了，而且干一个项目必须得加班，且没有加班费，人员流失厉害，员工基本都是老板的亲戚，面试承诺的13薪没有，年终奖更别提了。","createdAt":"2022-04-24T16:13:13"},{"id":"01963dd3-afed-71b3-91a4-92e1baa78d5c","parentId":null,"rootId":null,"fromId":2456,"content":"老板牛zengqiang，一个大傻逼。天天PUA女同事，再老的都是来者不拒。女生千万别去。","createdAt":"2023-02-02T14:16:27"},{"id":"01963dd3-b032-7001-a1fd-372e642e0a44","parentId":null,"rootId":null,"fromId":5638,"content":"666","createdAt":"2023-09-12T09:03:37"},{"id":"01963dd3-b076-7187-84d9-d84aa6df3921","parentId":null,"rootId":null,"fromId":5638,"content":"公司做商河政府项目的,属于吹牛挣钱,公司不大 这总那总的挺多 老板需要等政府回款 最近遇到资金问题工资拖好几个月发不出来.","createdAt":"2023-09-12T09:09:29"}]