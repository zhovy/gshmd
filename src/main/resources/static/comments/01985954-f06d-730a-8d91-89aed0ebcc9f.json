null,"rootId":null,"fromId":25097,"content":"神思天天背什么企业文化，安全作业，还抽查","createdAt":"2025-08-11T10:49:24"},{"id":"01989709-f0f9-72b5-be0b-2f00b444e42a","parentId":null,"rootId":null,"fromId":21003,"content":"请问所有人公积金都是按照7%吗","createdAt":"2025-08-11T10:51:07"},{"id":"01989729-b8ee-72a6-a9fe-ef352210372c","parentId":null,"rootId":null,"fromId":25097,"content":"是的，7%","createdAt":"2025-08-11T11:25:50"},{"id":"0198972a-7469-72a0-a8f9-be71c3d61e3b","parentId":null,"rootId":null,"fromId":25097,"content":"神思每年2月份清空上一年的年假。","createdAt":"2025-08-11T11:26:38"},{"id":"019897c1-42e1-703c-a5df-0e286f4a4109","parentId":null,"rootId":null,"fromId":25097,"content":"去山大地纬，工作之后支出很大一部分是住宿，山大地纬包住已经超越很多公司了。","createdAt":"2025-08-11T14:11:21"},{"id":"019903e9-3da5-73fc-b066-05527f2aea87","parentId":null,"rootId":null,"fromId":25902,"content":"真的五年不涨薪吗","createdAt":"2025-09-01T14:14:01"}]