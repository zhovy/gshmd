[{"id":"01963deb-2145-73f5-8138-578ec1e9dd38","parentId":null,"rootId":null,"fromId":3663,"content":"不是山东的专升本，是外省的，省跟省之间分数线跟规则不一样","createdAt":"2024-02-02T16:29:59"},{"id":"01963deb-218a-71f8-b39f-40f12fb51d02","parentId":null,"rootId":null,"fromId":5849,"content":"去，然后再考研","createdAt":"2024-02-02T17:25:03"},{"id":"01963deb-21d0-7193-bdae-b43bf63bdb72","parentId":null,"rootId":null,"fromId":508,"content":"不要去，太贵了，投入与产出不成正比","createdAt":"2024-02-02T17:29:47"},{"id":"01963deb-2257-73c3-b08f-d09e259ef195","parentId":null,"rootId":null,"fromId":3663,"content":"肯定是想走程序员这条路啊","createdAt":"2024-02-02T18:01:25"},{"id":"01963deb-225c-726b-b5bd-a0d5c408e4fd","parentId":null,"rootId":null,"fromId":3663,"content":"我要是考上了我肯定好好学java，我还想考个红帽的证，但是企业不是不认民办吗","createdAt":"2024-02-02T18:12:32"},{"id":"01963deb-2260-7363-9642-04911eebcaea","parentId":null,"rootId":null,"fromId":5859,"content":"先查查这个大学能在学信网上查到毕业信息吧。","createdAt":"2024-02-02T18:16:48"},{"id":"01963deb-22a8-73d0-bf0d-00741671fe05","parentId":null,"rootId":null,"fromId":3663,"content":"？为啥要查呢，统招全日制专升本4月份统一考试，怎么就需要查了","createdAt":"2024-02-02T18:19:27"},{"id":"01963deb-22ad-72f5-9775-e90ecd67630f","parentId":null,"rootId":null,"fromId":2658,"content":"去的话建议一定要考研","createdAt":"2024-02-02T19:11:49"},{"id":"01963deb-22f3-71da-aa55-9268ffc4d25c","parentId":null,"rootId":null,"fromId":6603,"content":"这笔钱对家里压力不算特别大的话，换做我可能会考虑去，毕竟这应该是最后一次可以将第一学历改为本科的机会了。\n可以选择不去，但是理由不要是为了帮家里节省这一笔本来可以承担的费用。\n当然如果你有信心两年后以同等学力的身份考研就另说了。","createdAt":"2024-02-03T09:53:44"},{"id":"01963deb-233c-71b8-9639-469275412351","parentId":null,"rootId":null,"fromId":3663,"content":"不想考研，再考研啥时候是个头","createdAt":"2024-02-03T14:32:20"},{"id":"01963deb-2341-7177-b1c1-76078b26c1e9","parentId":null,"rootId":null,"fromId":880,"content":"如果是统招的，必须要去，在考研","createdAt":"2024-02-03T16:26:56"},{"id":"01963deb-238e-707f-871a-5c4075c58a85","parentId":null,"rootId":null,"fromId":3663,"content":"肯定是统招的，不是统招的都不用上学的，后修学历统一都没有任何含金量，是个人花点钱就能拿得到","createdAt":"2024-02-03T16:30:52"},{"id":"01963deb-2392-710d-94ca-41ac370e7f43","parentId":null,"rootId":null,"fromId":4038,"content":"听谁说的不认民办本科，只要学信网可查就行；招聘说的民本指的是非学信网可查","createdAt":"2024-02-03T19:14:50"},{"id":"01963deb-23d6-7176-b4e4-37bc5529b6a7","parentId":null,"rootId":null,"fromId":4038,"content":"本科的机会比大专高","createdAt":"2024-02-03T19:27:48"},{"id":"01963deb-23da-73f8-9637-a9b926b7ec3f","parentId":null,"rootId":null,"fromId":1730,"content":"去，比专科强多了。","createdAt":"2024-02-04T10:48:15"},{"id":"01963deb-2464-7356-bf5a-3fab28222bde","parentId":null,"rootId":null,"fromId":6613,"content":"能本科就本科，比专科好太多","createdAt":"2024-02-04T14:08:25"},{"id":"01963deb-24a8-706c-b602-a11828abef97","parentId":null,"rootId":null,"fromId":721,"content":"我还真上过民办的专升本 待了三个月跑路了回去继续当码农 手抄代码 一周一次上机课 学习委员不会运行老师发的java代码 不过我那时候专科还是能找到程序员的工作的（三年前）","createdAt":"2024-02-05T09:00:49"},{"id":"01963deb-24ed-71de-8865-584ec05ee646","parentId":null,"rootId":null,"fromId":6344,"content":"要去的，学信网能查到就好啊，但是大概率要考研的，不考研的话你2年后毕业手里的证也没用","createdAt":"2024-02-05T16:49:21"},{"id":"01963deb-2531-7244-9a4f-967f0032836b","parentId":null,"rootId":null,"fromId":5460,"content":"有用也没用，虽然是统招但好多公司不认","createdAt":"2024-02-05T17:53:41"},{"id":"01963deb-2576-730e-aa0b-c5b5f0b34a1c","parentId":null,"rootId":null,"fromId":2738,"content":"学信网可查很重要。现在一般你去投简历，HR 会问你，本科学历是学信网可查还是民教网可查，我不太清楚你这个是什么。但是如果是民教网可查，绝大多数企业会不要。还有一点就是，这里很多人建议你考研，我个人比较认同，因为一些优质企业在删选简历的时候，会看你的第一学历，如果是专科的话，哪怕你第二学历是学信网可查的本科，也会遭到拒绝。如果你想去一些好的企业（国企，互联网大厂），你就必须要考研，虽然第一学历是专科，但是你的硕士学历也会加分。好的企业会意味着很多，虽然不绝对，但是往往在一个好的企业比如互联网大厂，国企，你的眼界，你的经验，你的薪资待遇都不会差。而且哪怕你干了一段时间选择跳槽，由于你上家公司的工作经历，你前公司的知名度等级，结合你个人的学历，你的专业水平，会更方便你跳槽拿到更好的薪资待遇，如果没有特殊的情况，你的待遇往往也会水涨船高。学历首先是块敲门砖，先不提你个人水平多牛。如果你学历不够，你连应聘的机会都没有。","createdAt":"2024-02-05T17:53:59"},{"id":"01963deb-25b9-73b8-90ac-0740f9812de3","parentId":null,"rootId":null,"fromId":6672,"content":"统招专升本第一学历就是本科了，只不过应该会标注专科起点","createdAt":"2024-02-19T12:00:33"}]