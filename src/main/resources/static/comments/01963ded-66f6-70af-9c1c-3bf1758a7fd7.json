[{"id":"01963ded-6766-7327-81af-61beaa3c6d1a","parentId":null,"rootId":null,"fromId":7122,"content":"三个公司人数，体量 都差不多","createdAt":"2024-04-07T23:04:46"},{"id":"01963ded-67ab-7041-a7ae-44f50909a524","parentId":null,"rootId":null,"fromId":1398,"content":"几年经验","createdAt":"2024-04-07T23:28:51"},{"id":"01963ded-67f4-72cc-8221-bf5aac899ed8","parentId":null,"rootId":null,"fromId":6939,"content":"你这基本属于是降薪跳槽，你在纠结就说明你应该很想去第二家，又想多挣点，这两家工资没给你到心理价位。","createdAt":"2024-04-08T08:54:10"},{"id":"01963ded-683d-73fe-8da4-b94ea2325818","parentId":null,"rootId":null,"fromId":3341,"content":"建议去双休的","createdAt":"2024-04-08T09:14:27"},{"id":"01963ded-6883-717f-8b47-f67484fc0aa9","parentId":null,"rootId":null,"fromId":6517,"content":"双休，不是双休不会考虑","createdAt":"2024-04-08T09:27:34"},{"id":"01963ded-68c8-7303-8d41-b1bf9f87504e","parentId":null,"rootId":null,"fromId":3149,"content":"大小周，粗算一下，一年50周左右，一半就是25天，相当于多干一个月，而且年终奖承诺了不一定发；至于外包是出了名的不稳定，没活了有的是办法让整治你，让你主动离职。所以还是双休自研靠谱点","createdAt":"2024-04-08T09:28:17"},{"id":"01963ded-67f0-70c7-a90d-215106070e02","parentId":null,"rootId":null,"fromId":7122,"content":"4-5年","createdAt":"2024-04-08T09:53:58"},{"id":"01963ded-6839-7299-b413-6e1017f6c684","parentId":null,"rootId":null,"fromId":7122,"content":"是的很纠结","createdAt":"2024-04-08T09:54:08"},{"id":"01963ded-690c-71e9-832f-1b979db7112c","parentId":null,"rootId":null,"fromId":7122,"content":"还有一个点，大小周的是研发型公司，60-70%是研发，双休的是软件部门只有10%的研发人员","createdAt":"2024-04-08T09:55:59"},{"id":"01963ded-690f-7166-bf92-3422e34a8cb4","parentId":null,"rootId":null,"fromId":7107,"content":"你犹豫了，实际内心更倾向双休的。双休的工作量肯定比单休的少很多。一年半经验面了个9的但是出差997 ，当时想法和你一样 非常纠结 是多赚钱还是有点休息，最后还是让我给拒了。","createdAt":"2024-04-08T10:22:42"},{"id":"01963ded-6957-7277-ba9e-cd9bf4dc2a7f","parentId":null,"rootId":null,"fromId":6940,"content":"年终奖在我看来就是画饼","createdAt":"2024-04-08T11:36:10"}]