[{"id":"01963dd4-ee1c-7320-aeb5-e8bae104ea1d","parentId":null,"rootId":null,"fromId":272,"content":"同为该公司员工，裁员不事先通知，临时私下谈话要求主动离职.年后各种日会日报，在下班点开.管理混乱，项目经常延期，项目老产品不懂技术，需求改了又改，效率很低","createdAt":"2022-04-19T15:23:09"},{"id":"01963dd4-ee60-73cc-8a7a-a7be8e88b708","parentId":null,"rootId":null,"fromId":1139,"content":"是的，贼恶心，代码一塌糊涂，架构非常老，祖传屎山，天天有bug。天天的写日报，而且周五还要写周报。开发也就算了，人家销售部门还要写，不写照样罚，就是离谱","createdAt":"2022-07-28T17:32:09"},{"id":"01963dd4-eea6-7209-9828-ea3597e60b3e","parentId":null,"rootId":null,"fromId":2418,"content":"这家公司目前咋样啊","createdAt":"2023-02-17T20:52:00"},{"id":"01963dd4-eeea-7085-96d7-9a7859d62b7d","parentId":null,"rootId":null,"fromId":1712,"content":"目前不写日报了，哈哈哈哈","createdAt":"2023-05-24T15:32:00"}]