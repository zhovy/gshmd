[{"id":"0199db4f-50ec-72e0-bd8e-13e4021203d4","parentId":null,"rootId":null,"fromId":26671,"content":"1","createdAt":"2025-10-13T10:03:52"},{"id":"0199db69-f718-70e6-a080-9d1d2c5bea43","parentId":null,"rootId":null,"fromId":23701,"content":"之前从杭州回来的，感觉杭州还不错，挣钱也多，济南薪资只有杭州的一半多点，但是杭州比较卷，要有心理准备","createdAt":"2025-10-13T10:32:58"},{"id":"0199db91-2ec1-7388-9c52-76c452125def","parentId":null,"rootId":null,"fromId":27024,"content":"在南方几个月了，是在济南找不到工作来的南方。 先说缺点：（1）远，节假日回家的车票不好买。（2）潮湿，南方的潮湿是在北方不好想想的，可以周末先来适应几天。（3）人情味低，人与人之间的热情比北方低，有文化的原因，也有人员构成的原因，在南方打工的外地人很多。（4）有能力的人很多，关键岗位竞争也很激烈，领导岗位很多都有互联网大厂的履历。（5）蔬菜水果价格比济南高，15%以上。（6）美食荒地，很荒；","createdAt":"2025-10-13T11:15:49"},{"id":"0199db94-6e30-7259-96aa-814dc3cc43ef","parentId":null,"rootId":null,"fromId":27024,"content":"（7）租房价格很高，我感觉中介还挺靠谱的。 我在济南租房6年。被中介坑过太多次了。  优点：全额五险一金，周末双休。未来有保障，当下有生活。","createdAt":"2025-10-13T11:19:21"},{"id":"0199dbab-e57c-7065-af94-753174326f47","parentId":null,"rootId":null,"fromId":2381,"content":"方便说下是哪个城市吗老哥","createdAt":"2025-10-13T11:44:59"},{"id":"0199dbb0-bb2d-72a2-963c-e2760c876be6","parentId":null,"rootId":null,"fromId":5480,"content":"南方人情味低很正常，尤其是江浙沪。可能浙还好点，江沪是真不行。都是生意人讲究利益，谁管你人情味啊","createdAt":"2025-10-13T11:50:16"},{"id":"0199e1e2-2760-70c6-a19f-ff35fd560cd4","parentId":null,"rootId":null,"fromId":21945,"content":"年后打算南下","createdAt":"2025-10-14T16:41:58"},{"id":"0199e364-8f32-700d-8bc7-d78131420fed","parentId":null,"rootId":null,"fromId":3968,"content":"兄弟想挣钱是好事但是现在这行情跟城市或者是个人能力基本没有关系，而且如果头铁去一线我觉得是个高风险的操作很大几率会赔房租","createdAt":"2025-10-14T23:44:02"}]