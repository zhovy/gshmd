[{"id":"01978c1d-2590-7367-aab2-0de12b7a97f7","parentId":null,"rootId":null,"fromId":460,"content":"你第一句话就错了 技术行业相比较来说 是不算难的 有的行业 就算是经济好的情况下 法定节假日都保证不了","createdAt":"2025-06-20T14:53:29"},{"id":"01978c27-5cd6-73dc-8d10-f9dc679ff2db","parentId":null,"rootId":null,"fromId":1049,"content":"你说的很对，如果跟医生之类行业一样，学会的东西不要随意分享，是不是程序员处境会好一点","createdAt":"2025-06-20T15:04:39"},{"id":"01978c29-2e70-7291-80e7-d9d6f553132f","parentId":null,"rootId":null,"fromId":22023,"content":"应该会好一些，我就经常听：能者多劳，从来没人提过多劳多得。","createdAt":"2025-06-20T15:06:38"},{"id":"01978c2b-45dc-7380-9d06-51e798d0fd1f","parentId":null,"rootId":null,"fromId":7381,"content":"开源 使用成本降低 才会有更多人开公司 你才会有工作机会 开源就是共产主义","createdAt":"2025-06-20T15:08:55"},{"id":"01978c2f-9d0f-711e-9526-64bba605efcb","parentId":null,"rootId":null,"fromId":22023,"content":"太理想了，谁的成本降低？多少钱的工资？做多少的工作？开源是共同理想，现实是企业可以更好地降本增效，到打工人手里的真的不剩什么，而且开源的可都是打工人做的开源，技术人的心血。","createdAt":"2025-06-20T15:13:40"},{"id":"01978c31-9015-734e-ba65-23a3488892b7","parentId":null,"rootId":null,"fromId":7270,"content":"你这是提加薪失败了？","createdAt":"2025-06-20T15:15:47"},{"id":"01978c32-4fe9-72e0-a8f1-40be50dd3e0d","parentId":null,"rootId":null,"fromId":7270,"content":"像个愤青","createdAt":"2025-06-20T15:16:36"},{"id":"01978c34-655a-73cd-8fb1-d9b56f5bc23f","parentId":null,"rootId":null,"fromId":22023,"content":"等你们干十年，得到的还是斗米恩，升米仇，你们就能体会我的意思了","createdAt":"2025-06-20T15:18:53"},{"id":"01978c37-4962-72f3-bea8-6b4edccb261d","parentId":null,"rootId":null,"fromId":7270,"content":"如果你真的有能力，在开源的情况下，肯定也能获得很多东西。\n如果说开源体现不出你的价值，你怎么确定闭源就能体现出来？","createdAt":"2025-06-20T15:22:02"},{"id":"01978c3a-a387-730e-9ea0-defb4a85f201","parentId":null,"rootId":null,"fromId":7270,"content":"时代如此，老哥。什么时代都有渣人，祝好","createdAt":"2025-06-20T15:25:42"},{"id":"01978c5a-da84-715f-8ec9-e19bb7c67805","parentId":null,"rootId":null,"fromId":22023,"content":"闭源就是对等报复，以社会之道还之社会，这个时候价值已经不重要了，你想想你对于公司的价值","createdAt":"2025-06-20T16:00:53"},{"id":"01978c73-8564-7233-b04d-8fa4a6864003","parentId":null,"rootId":null,"fromId":7124,"content":"可是她叫我哥哥呀","createdAt":"2025-06-20T16:27:50"},{"id":"01978d0d-3365-7264-ae94-7cf9f27430d6","parentId":null,"rootId":null,"fromId":24615,"content":"站在人类发展上看，还是多分享比较好，大家都藏着，技术更新太慢了，你也享受不到技术快速迭代带来的舒适","createdAt":"2025-06-20T19:15:42"},{"id":"01979030-14a6-73b7-907d-4b2afe959eda","parentId":null,"rootId":null,"fromId":1049,"content":"你是典型的好牛马，好好了解一下社会规律再说吧","createdAt":"2025-06-21T09:52:39"},{"id":"01979a62-6e73-71ca-86ba-6cf06d4eecdc","parentId":null,"rootId":null,"fromId":1376,"content":"我也不建议开源了，现在开源的人没收入，用爱发电，使用开源的人降本增效，本质是趴着开源社区吸血，甚至开源的人都被自己的公司裁了","createdAt":"2025-06-23T09:23:51"},{"id":"01979aa7-a490-71dc-825b-98e4d170a787","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-06-23T10:39:27"},{"id":"01979ba2-869a-738c-8488-01f32941e80d","parentId":null,"rootId":null,"fromId":4002,"content":"....","createdAt":"2025-06-23T15:13:29"},{"id":"01979bbd-e2f9-7375-be55-c22ad6f7b32c","parentId":null,"rootId":null,"fromId":24162,"content":"我觉得不看能力的情况是 社会上这种能力的人不稀缺 而且成本低。如果是稀缺的，成本高的，还是有点分量的。要么就是确实公司干的东西没啥技术含量，不需要这样的人。我面试过几家还是非常看技术匹配和技术能力的，当然一般上升期的企业确实不缺钱去构建能力强的技术团队，但凡业务稳定了，或者方向不可行 ，人员也就溢出了，可以裁员了 哈哈哈哈 主要还是现在人才溢出了。想当年 crud  ajax 那就是硬通货","createdAt":"2025-06-23T15:43:22"},{"id":"0197a99b-f358-70bf-9c2f-15cf9de92c18","parentId":null,"rootId":null,"fromId":2246,"content":"工作的经验是你踩过的坑，怎么填这些坑，怎么解决问题，而不是我学了什么技术什么技术，没有实践过的技术，只停留在自己电脑里运行的代码，都是空中楼阁。","createdAt":"2025-06-26T08:20:59"},{"id":"019816a1-76d3-71dc-a698-af94819a2452","parentId":null,"rootId":null,"fromId":1421,"content":"你的观点是对的，现在美国AI公司都在搞闭源，感觉开源就是对技术人员心血的践踏","createdAt":"2025-07-17T12:25:37"},{"id":"019816a2-cd55-72e4-a601-46fa09882740","parentId":null,"rootId":null,"fromId":1421,"content":"Alexandr Wang上任第一把火，Meta大模型闭源","createdAt":"2025-07-17T12:27:04"}]