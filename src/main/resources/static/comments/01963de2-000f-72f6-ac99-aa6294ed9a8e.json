[{"id":"01963de2-008d-723e-8653-07e3e69ccd59","parentId":null,"rootId":null,"fromId":2598,"content":"感谢啊，差一点就去了","createdAt":"2023-05-04T19:16:27"},{"id":"01963de2-00d2-70f5-9423-f3e6522b5005","parentId":null,"rootId":null,"fromId":933,"content":"狠啊，这家公司工龄没有超过2年的，一定会被辞退","createdAt":"2023-05-05T10:44:12"},{"id":"01963de2-0116-7180-a5ad-b75b6ffe7886","parentId":null,"rootId":null,"fromId":1549,"content":"5.1前去面试过，好像是刷业绩的，我面试完岗位就关了，项目我听着也不咋地，做人力资源管理系统的","createdAt":"2023-05-05T13:11:25"},{"id":"01963de2-015b-700a-bd5b-9012e11c30f4","parentId":null,"rootId":null,"fromId":2450,"content":"傻逼公司，垃圾ceo滚蛋了，剩一个傻狗老板，千万别去","createdAt":"2023-05-05T16:10:06"},{"id":"01963de2-01a1-72b4-814a-1f218a9e6913","parentId":null,"rootId":null,"fromId":2450,"content":"亲身经历：去了1天，什么都没干，就说我工作不合格，我是产品","createdAt":"2023-05-05T16:11:15"},{"id":"01963de2-01f3-7180-a219-68ebc6597a10","parentId":null,"rootId":null,"fromId":1955,"content":"这么一说，我也去过\n当时面的是技术经理，面试的人有3个\n1女的2男的\n其中有个男的简直素质低下，对面其他人问我问题，我只要说一句话，比如我的经历，我做的项目，我如何管理团队的\n他都在那里笑，一副看不起人的样子\n当即反驳了一下他，做为面试的人总是嘲笑似的的面对面试的人岂不是很没素质\n然后拿着简历走了","createdAt":"2023-05-05T18:26:19"},{"id":"01963de2-01ee-735e-a8c6-d12b8951ce51","parentId":null,"rootId":null,"fromId":557,"content":"当然不合格啊，又没给老板拍马屁【手动狗头】","createdAt":"2023-06-08T10:02:12"},{"id":"01963de2-0238-7280-b20e-ab4d127be54d","parentId":null,"rootId":null,"fromId":126,"content":"去这个公司的一定小心点，这老板可是一个小人，用得着人的时候朝前用不到人的时候朝后","createdAt":"2023-07-19T15:47:33"}]