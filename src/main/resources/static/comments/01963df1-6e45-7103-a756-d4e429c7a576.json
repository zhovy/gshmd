[{"id":"01963df1-6ea9-7194-a4d9-f38e12e311ee","parentId":null,"rootId":null,"fromId":7515,"content":"你坐在高铁上，你问周围人都买票了吗","createdAt":"2024-07-02T08:07:17"},{"id":"01963df1-6ef6-7128-9817-9b10b9aaa43d","parentId":null,"rootId":null,"fromId":21053,"content":"欠骂的sd","createdAt":"2024-07-02T08:29:49"},{"id":"01963df1-6f3a-7376-a231-7a90fcbae1e8","parentId":null,"rootId":null,"fromId":3450,"content":"我们公司倒了,我现在要是问周围人你失业了吗,那肯定全是失业人员,身边统计学有个鸡儿用","createdAt":"2024-07-02T08:59:58"},{"id":"01963df1-6f91-71df-b278-2f63f5a12e62","parentId":null,"rootId":null,"fromId":2056,"content":"不高  也就20%","createdAt":"2024-07-02T09:30:33"},{"id":"01963df1-6f8d-73b1-a550-a45419a5f69b","parentId":null,"rootId":null,"fromId":584,"content":"是看的身边的朋友，同学，室友之类的。并非说的是同事，同事有什么好统计的，都是一个公司的","createdAt":"2024-07-02T09:36:06"},{"id":"01963df1-6eed-7352-a7f3-f9498c7f7434","parentId":null,"rootId":null,"fromId":3341,"content":"去厕所敲敲门 问：你带纸了吗？","createdAt":"2024-07-02T09:37:02"},{"id":"01963df1-6fd8-711f-a5f4-ddcdca6c3124","parentId":null,"rootId":null,"fromId":228,"content":"fule","createdAt":"2024-07-02T09:47:03"},{"id":"01963df1-701d-72c9-a56b-579c8c3e6064","parentId":null,"rootId":null,"fromId":2509,"content":"我也问了身边的同事，他们都没失业呀","createdAt":"2024-07-02T10:05:09"},{"id":"01963df1-7067-7180-9beb-8a6454005421","parentId":null,"rootId":null,"fromId":630,"content":"我问了问我身边的人有钱吗，他们都说没钱","createdAt":"2024-07-02T11:26:53"},{"id":"01963df1-70ae-7309-89c0-430effd779e1","parentId":null,"rootId":null,"fromId":6517,"content":"我本地的，我周围都是国企 烟草的，他们都挺滋润，吃皇粮的基本没事，仅限于历下区","createdAt":"2024-07-02T11:37:43"},{"id":"01963df1-70f5-719b-9b66-3c2db3129b92","parentId":null,"rootId":null,"fromId":5927,"content":"保底20%吧，如果放在国外早炸锅了 哈哈 也就中国人能忍的住， 苟住这一两年，拖死老美，大环境估计会好点吧","createdAt":"2024-07-02T12:20:41"},{"id":"01963df1-7140-72d6-81e0-11625a0d75d6","parentId":null,"rootId":null,"fromId":875,"content":"不高，你看济南房价还跟坚挺，新房都两万多，还一堆人买","createdAt":"2024-07-02T12:37:33"},{"id":"01963df1-6ef1-72c8-a4c2-8d49550c5f42","parentId":null,"rootId"