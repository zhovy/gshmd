[{"id":"01963de1-c5eb-7051-90e4-d2290cdaad5c","parentId":null,"rootId":null,"fromId":246,"content":"最近也准备去仲裁公司……","createdAt":"2023-04-25T14:42:03"},{"id":"01963de1-c634-7165-924a-73b7f5e2a24d","parentId":null,"rootId":null,"fromId":544,"content":"微信小程序搜索 劳动争议调解智慧服务平台 ","createdAt":"2023-04-25T15:38:27"},{"id":"01963de1-c67a-7025-b814-524505604751","parentId":null,"rootId":null,"fromId":3408,"content":"劳动仲裁会在个人档案中记录吗？去下家公司会显示我有劳动仲裁记录吗？\n会被hr圈拉黑吗？","createdAt":"2023-04-27T14:00:18"},{"id":"01963de1-c6c0-70a0-8738-016ee906a1fb","parentId":null,"rootId":null,"fromId":2436,"content":"仲裁一般不会，诉讼会。除非你到处炫耀，不然公司怎么知道呢。还有公司在意这个是不是说明内部有问题，或者就找好欺负的","createdAt":"2023-04-27T16:57:35"},{"id":"01963de1-c62f-73b4-9949-5dd8b9e719cb","parentId":null,"rootId":null,"fromId":2753,"content":"不是泰信（瞳见）的吧（doge","createdAt":"2023-04-28T13:51:52"},{"id":"01963de1-c6cf-73ef-8905-b3abac57c2b7","parentId":null,"rootId":null,"fromId":2958,"content":"据我所知，在济南打仲裁还是非常简单吧，欠薪问题直接劳动监察大队，保险，加班费只能走劳动仲裁，大不了上法院，50块钱诉讼费，稳赢，至于执行速度，山东都一个样","createdAt":"2023-04-28T20:48:38"},{"id":"01963de1-c6c5-711c-836b-7bcec9971e22","parentId":null,"rootId":null,"fromId":1216,"content":"劳动仲裁阶段不会，法院诉讼是全国联网的，一般公司不会查，但是涉及需要做背调了，法院诉讼记录是可以查询到的","createdAt":"2023-05-04T00:43:58"},{"id":"01963de1-c6c9-701c-b30f-402f9f734b60","parentId":null,"rootId":null,"fromId":2436,"content":"对，诉讼要开庭的，要网上公示的，是可以查询到的","createdAt":"2023-05-04T11:10:34"}]