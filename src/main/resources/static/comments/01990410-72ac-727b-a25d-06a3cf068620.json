[{"id":"01990416-3a2d-7387-9316-8f8f4d08deb8","parentId":null,"rootId":null,"fromId":22250,"content":"你不去我不去，骗子公司自然而然就倒闭了","createdAt":"2025-09-01T15:03:09"},{"id":"01990419-c972-70db-84f2-5af019eecdd7","parentId":null,"rootId":null,"fromId":22699,"content":"我觉得，就这种言而无信的情况，早晚会坑你。。","createdAt":"2025-09-01T15:07:02"},{"id":"01990446-2f41-72bd-8ce9-a03d1fff9a19","parentId":null,"rootId":null,"fromId":5910,"content":"你为啥觉得能正常上下班呢 哈哈哈","createdAt":"2025-09-01T15:55:32"},{"id":"0199044a-0b71-701c-9993-78b914a5a930","parentId":null,"rootId":null,"fromId":25332,"content":"前lc人回答下，外协就是外包，这几年大部分子公司效益不好，几年不涨工资是基操，至于忙不忙还是具体看项目。","createdAt":"2025-09-01T15:59:45"},{"id":"01990459-5246-7092-bb0d-e374c2f4bb47","parentId":null,"rootId":null,"fromId":22990,"content":"那还是算了，听过来人的劝。不折腾了， 现在公司   除了工资低点， 其他还好","createdAt":"2025-09-01T16:16:26"},{"id":"0199045a-8ca9-736e-84e4-a1fc859a597c","parentId":null,"rootId":null,"fromId":22990,"content":"正常上下班是我现在的公司但是工资低， 正常上下班。\n 真要去浪潮的话， 就没想过能正常上下班，就怕去了不到半年就干掉， 白折腾","createdAt":"2025-09-01T16:17:47"},{"id":"0199045b-c1e5-7237-82c5-5047352e33b7","parentId":null,"rootId":null,"fromId":22990,"content":"大佬说的有道理，不折腾了， 老老实实在现在的公司苟着吧","createdAt":"2025-09-01T16:19:06"},{"id":"0199045b-d3c7-7121-8620-00d161b9363f","parentId":null,"rootId":null,"fromId":22576,"content":"浪潮工业互联网，放鸽子不是一回两回了…… 我之前也是，人资都走审批流程了，说是审批到最后，董事长又不让入职了，让用外协先顶一顶。\n我去，一个研发岗位，都轮到董事长过问了？\n\n所以我觉得，你还是别动了，动了你肯定会后悔。","createdAt":"2025-09-01T16:19:10"},{"id":"0199045c-c83a-7184-b39b-f1ed9f20768b","parentId":null,"rootId":null,"fromId":22990,"content":"就怕坑， 去了半年在干掉， 到时候再找个和现在一样工资的公司， 而且正常上下班的， 直接就不可能了，  看着都不推荐去，我还是老老实实苟着吧， 不折腾了","createdAt":"2025-09-01T16:20:13"},{"id":"0199045f-11a1-7375-abc2-34fb67aec652","parentId":null,"rootId":null,"fromId":22990,"content":"和我的情况差不多， 听人劝吃饱饭，哈哈， 苟着","createdAt":"2025-09-01T16:22:43"},{"id":"01990473-9b11-70e6-b09f-646781a9ffcb","parentId":null,"rootId":null,"fromId":24615,"content":"这肯定不去啊，不能只看工资，工作时长也非常重要，浪潮加班多是有名的，而且去了也是外包，即使自己这家公司以后不想待了或者啥的，也可以随时再去浪潮外包","createdAt":"2025-09-01T16:45:09"},{"id":"019907c4-973c-737b-b56b-ad0eefa54ae1","parentId":null,"rootId":null,"fromId":2246,"content":"别去，你看看你现在就遇见这些乱七八糟的了，这么随意， 你去了辞了你也很随意。","createdAt":"2025-09-02T08:12:28"},{"id":"019907dc-678f-731c-a4b9-8e6fa0c76290","parentId":null,"rootId":null,"fromId":22250,"content":"建议和浪潮相关的都不要去~ 眼看它起高楼，眼看它楼倒下","createdAt":"2025-09-02T08:38:29"},{"id":"0199081b-1aa6-719d-af2e-fd56198f98aa","parentId":null,"rootId":null,"fromId":22724,"content":"最近几年部分子公司业绩下滑比较多，压力很大，能用外包就用外包，指不定啥时候裁了","createdAt":"2025-09-02T09:46:58"},{"id":"01990828-a7c6-7379-b520-da850ce9cfc2","parentId":null,"rootId":null,"fromId":377,"content":"老哥什么公司，我也想正常上下班","createdAt":"2025-09-02T10:01:46"},{"id":"01990830-fcb4-7315-ae72-775034a1da2e","parentId":null,"rootId":null,"fromId":22250,"content":"别去了，浪潮的牛马可不好当，在家躺着玩多好","createdAt":"2025-09-02T10:10:52"},{"id":"0199088b-7e9e-7231-b568-e23911f58a91","parentId":null,"rootId":null,"fromId":926,"content":"我是浪潮的，现在正式卡的很严格，只能外协/外包","createdAt":"2025-09-02T11:49:43"},{"id":"0199090d-4b91-7210-bec0-0caa70babfc8","parentId":null,"rootId":null,"fromId":22990,"content":"找个小公司就行， 例如原来18  现在要12 你也可以正常上下班， 哈哈","createdAt":"2025-09-02T14:11:30"},{"id":"019909ed-e205-71d1-b98e-d44b04ba3dda","parentId":null,"rootId":null,"fromId":3263,"content":"楼上都推荐不去，虽然我在浪潮其他子公司，但是也出现了你说的这个情况。面试的时候打算开新项目，最后确认人选，走流程了，又突然被美国制裁新项目不做了，最后也没让候选人入职。过了2个月其他项目启动，又询问候选人是否还同意入职，结果还真同意了，跟我一个开发组。","createdAt":"2025-09-02T18:16:48"},{"id":"01991792-1d8d-705b-a4a9-f6bc38f915de","parentId":null,"rootId":null,"fromId":26269,"content":"兄弟，你也是外包HR 找你说浪潮技术面试过了，但是还要提交工资流水、个人信息。说浪潮集团审批通过才能入职 是这个流程吗。这个信息给外包靠谱吗？","createdAt":"2025-09-05T09:51:15"},{"id":"01991792-88a6-7301-97da-a43900be0fcd","parentId":null,"rootId":null,"fromId":26269,"content":"兄弟，你也是外包HR 找你说浪潮技术面试过了，但是还要提交工资流水、个人信息。说浪潮集团审批通过才能入职 是这个流程吗。这个信息给外包靠谱吗？ 兄弟看来你这是这样啊。","createdAt":"2025-09-05T09:51:43"},{"id":"0199186c-98e9-70f2-86e5-7b7afb574a46","parentId":null,"rootId":null,"fromId":23484,"content":"是浪潮云洲工业互联网吗，面试了两轮，当时我走的纽斯达（万古恒信）的外包，去之前再三跟我说，周末双休，平时偶尔加班，进去之后浪潮的人说我们这里固定每周一二四六加班，没加班费，没调休。","createdAt":"2025-09-05T13:49:54"},{"id":"019918b8-6300-72b5-ab32-11312a626813","parentId":null,"rootId":null,"fromId":22576,"content":"我当时不是外包，是正式员工，说不让入职的理由是，公司业绩不好，岗位需求的话，先找外协顶一顶，尽量不招正式员工了。","createdAt":"2025-09-05T15:12:41"},{"id":"01992757-1ed9-7034-be21-b5a1238c6fae","parentId":null,"rootId":null,"fromId":22389,"content":"lj gongsi","createdAt":"2025-09-08T11:20:45"},{"id":"019927d0-9e7b-711b-aef3-7bfa27f4cacd","parentId":null,"rootId":null,"fromId":3293,"content":"耍人玩？","createdAt":"2025-09-08T13:33:27"},{"id":"0199337e-30b3-7333-acfd-8e7abcc1f3e0","parentId":null,"rootId":null,"fromId":269,"content":"怎么样加班严重吗 老哥入职了吗 能给多少","createdAt":"2025-09-10T19:58:52"},{"id":"01993435-a9bb-7016-8405-6c62b232c64d","parentId":null,"rootId":null,"fromId":23484,"content":"6年前端，当时定的薪资是11，当天听到浪潮的说1246固定加班并且啥福利都没有就走了，总共待了俩小时。","createdAt":"2025-09-10T23:19:16"},{"id":"0199f640-79ea-72b4-bfd3-6525b752235c","parentId":null,"rootId":null,"fromId":2558,"content":"哥们 工业互联网现在加班严重吗","createdAt":"2025-10-18T15:37:24"},{"id":"0199f641-d687-7301-a04c-b605beaa8d9d","parentId":null,"rootId":null,"fromId":2558,"content":"兄弟  我也是前端 要进的工业互联网 我不会进的就是你这个部门吧","createdAt":"2025-10-18T15:38:53"},{"id":"0199ff3c-c776-7195-8013-2e71bac3b43e","parentId":null,"rootId":null,"fromId":23484,"content":"那差不多是这个部门，我是今年2月份面过的，到现在这个岗位还在招人看来离职率不低，谨慎选择吧","createdAt":"2025-10-20T09:29:57"}]