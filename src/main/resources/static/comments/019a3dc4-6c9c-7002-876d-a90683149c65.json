[{"id":"019a3e02-f206-707e-a786-277587b5d6f4","parentId":null,"rootId":null,"fromId":1049,"content":"浪潮吧，小公司工资都发不下来","createdAt":"2025-11-01T14:02:51"},{"id":"019a3e0e-fefa-702a-970f-fc3a341f4ce7","parentId":null,"rootId":null,"fromId":926,"content":"什么烟酒系统，让你去酒企还是烟草，14没有，就12*12","createdAt":"2025-11-01T14:16:01"},{"id":"019a3e0f-8879-7074-bcc5-684c206276b9","parentId":null,"rootId":null,"fromId":926,"content":"积成电子可不是小公司，人家也是国企。","createdAt":"2025-11-01T14:16:36"},{"id":"019a3e19-cd10-7061-8323-729badba591c","parentId":null,"rootId":null,"fromId":926,"content":"要我选，我就选积成电子，浪潮是指定会出差的，加班更长","createdAt":"2025-11-01T14:27:49"},{"id":"019a3e36-a4e2-7269-a3ee-4e4747b7186e","parentId":null,"rootId":null,"fromId":24615,"content":"最近三年浪潮除了信息，别的单位基本没有年终奖，即使有也不会给新人，另外这10%绩效一般都拿不满，每月绩效能拿50%就算高的，所以实际是11*12或者11.5*12","createdAt":"2025-11-01T14:59:19"},{"id":"019a3e38-46cb-732f-bd0a-be45b8403670","parentId":null,"rootId":null,"fromId":926,"content":"浪潮信息与浪潮通信，去年我们通信年终奖B+往上是1.5w","createdAt":"2025-11-01T15:01:06"},{"id":"019a3e3f-fc0d-71c5-9a0a-276c7139bb8c","parentId":null,"rootId":null,"fromId":24615,"content":"去浪潮认准浪潮信息就可以了。通信这行在国内属于老年饱和性行业了，你们居然能拿到年终奖，看来没少裁人，而且大概率是没涨薪了","createdAt":"2025-11-01T15:09:32"},{"id":"019a3e4f-ccd4-7308-a3c4-833c4edb1693","parentId":null,"rootId":null,"fromId":926,"content":"也有部分人涨薪，现在通信海外是重点，一直在动员转海外。","createdAt":"2025-11-01T15:26:48"},{"id":"019a3e50-bff8-725d-aabf-06112ce2d5ac","parentId":null,"rootId":null,"fromId":926,"content":"就这么说吧，虽然国内业务饱和了，但是国外业务疯涨，去年我们通信给集团交了2亿。","createdAt":"2025-11-01T15:27:50"},{"id":"019a3e5f-51c2-7308-a43e-cf3115d1530e","parentId":null,"rootId":null,"fromId":7124,"content":"还是上市公司","createdAt":"2025-11-01T15:43:45"},{"id":"019a3e68-d84d-72c8-9054-90aa2d9b5b73","parentId":null,"rootId":null,"fromId":24615,"content":"楼主如果去浪潮的话，刚去试用期因没有绩效每月就是10.8k*80%=8.64k，转正后11k~11.5k,不满一年没有涨薪，所以即使楼主今天入职，至少要到2027年才有涨薪的机会，如果2026年入职，那至少要到2028年才有涨薪的机会。转正后关注一下月绩效能拿多少百分比，如果低那做好跑路（或者背裁员指标）的准备，如果绩效一般那当年大概率是没有年终奖+月薪不变，如果绩效高，部门完成的好，那就好好待着干","createdAt":"2025-11-01T15:54:09"},{"id":"019a3f5d-8ece-72a9-a43c-e5fd87b58cc6","parentId":null,"rootId":null,"fromId":22333,"content":"我建议再找找 还有很多机会","createdAt":"2025-11-01T20:21:27"},{"id":"019a3f7c-a7e7-7351-85cd-e279d446c674","parentId":null,"rootId":null,"fromId":26932,"content":"济南机会不多了，唉:-(","createdAt":"2025-11-01T20:55:25"},{"id":"019a451a-f598-72cf-b92c-0fa6088ef17a","parentId":null,"rootId":null,"fromId":26932,"content":"感谢","createdAt":"2025-11-02T23:06:26"},{"id":"019a4743-97c1-736e-9f3c-b887824df07a","parentId":null,"rootId":null,"fromId":25906,"content":"垃圾浪潮还有这么多人推荐我是没想到的","createdAt":"2025-11-03T09:10:03"},{"id":"019a48a8-fb50-70e4-9f00-c7afa5cc609e","parentId":null,"rootId":null,"fromId":2256,"content":"浪潮这个部门 放过我鸽子 让我等入职就行，最后没动静了，你这俩offer是已经到手了吗","createdAt":"2025-11-03T15:40:25"},{"id":"019a48e6-0edb-7144-90c2-a7a8e2358e3e","parentId":null,"rootId":null,"fromId":6186,"content":"没有14薪，只有12薪，我都出差半年了，都有最低加班时间的，都得干到9点半，出差报销很慢，现在回款困难，报销卡半年都下不来的","createdAt":"2025-11-03T16:47:07"},{"id":"019a48e6-8312-706d-9ba7-c3afdd4b4b4a","parentId":null,"rootId":null,"fromId":6186,"content":"行情不好，没年终奖了，所以只有12薪","createdAt":"2025-11-03T16:47:37"},{"id":"019a48e8-ec69-7160-8c53-85d1bce2c6e3","parentId":null,"rootId":null,"fromId":6186,"content":"行情不好，涨薪也是奢望","createdAt":"2025-11-03T16:50:15"},{"id":"019a5ebf-bf71-71d2-9709-48a13b94323d","parentId":null,"rootId":null,"fromId":22905,"content":"积成电子估计也是996","createdAt":"2025-11-07T22:36:56"},{"id":"019a6c8e-8984-73a0-b3cb-9ea49c4b43c8","parentId":null,"rootId":null,"fromId":21529,"content":"积成吗老哥","createdAt":"2025-11-10T14:57:52"},{"id":"019aed8b-7292-701a-8b57-92ba09c0a77f","parentId":null,"rootId":null,"fromId":7495,"content":"坏了，这是真在那待过","createdAt":"2025-12-05T16:05:30"},{"id":"019afedc-cda2-715a-85db-fc6c5781dc70","parentId":null,"rootId":null,"fromId":23617,"content":"积成这两年在搞变革，加班越来越多，发的钱越来越少了，HR给你说的14薪大概率拿不到，能13薪你就谢天谢地吧。每年至少5%的强制降薪名额，我之前去HR办公室看见的至少有几十份标着淘汰的员工离职资料。当然了在济南这个软件粪坑里算是中上的了","createdAt":"2025-12-09T00:47:54"},{"id":"019afee0-97de-728f-83ec-d8aececb2279","parentId":null,"rootId":null,"fromId":23617,"content":"加班常规就是124加班到8点，有部分不要脸的领导会要求996，比如电网部的某几个老卷王。如果安排你出差的话996就是日常，007属于加磅","createdAt":"2025-12-09T00:52:03"},{"id":"019afee2-f399-73f7-bbf6-cbbae30f7362","parentId":null,"rootId":null,"fromId":23617,"content":"部分国资吧，不是国企，是私企","createdAt":"2025-12-09T00:54:37"},{"id":"019afee9-b307-73fe-97d2-abb184f329c0","parentId":null,"rootId":null,"fromId":23617,"content":"变革学华为，你懂的","createdAt":"2025-12-09T01:01:59"}]