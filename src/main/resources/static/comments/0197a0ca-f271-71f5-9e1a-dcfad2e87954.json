2:18"},{"id":"0197a52d-5e65-7337-be25-05e797e0d704","parentId":null,"rootId":null,"fromId":25358,"content":"1","createdAt":"2025-06-25T11:41:43"},{"id":"0197a65b-8fe1-71d5-a10b-1ff3f2ab4411","parentId":null,"rootId":null,"fromId":22024,"content":"哪个二级单位？我这没这么多","createdAt":"2025-06-25T17:11:47"},{"id":"0197be72-0b84-7161-bb5f-5e649f4e8a13","parentId":null,"rootId":null,"fromId":22444,"content":"你是什么时候面试过的？","createdAt":"2025-06-30T09:27:14"},{"id":"0197c4fa-440c-7257-b253-4384e14bc805","parentId":null,"rootId":null,"fromId":22024,"content":"也不知道哪来的小道消息，都在传，可是这都七月了，我这还没有听说有谁被裁，弄得人心惶惶的","createdAt":"2025-07-01T15:53:45"},{"id":"0197c9ff-fcd2-7113-b6bc-200651a99df7","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-07-02T15:18:06"},{"id":"0197ca01-6946-70b6-8a95-3d13e931f941","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-07-02T15:19:39"},{"id":"01987e8b-93d7-7146-89c3-785884074aea","parentId":null,"rootId":null,"fromId":21986,"content":"就连效益最好的浪潮信息都裁了10%了，还踏马天真的以为浪潮多稳定。奥对，裁的都是正式员工","createdAt":"2025-08-06T16:42:13"}]