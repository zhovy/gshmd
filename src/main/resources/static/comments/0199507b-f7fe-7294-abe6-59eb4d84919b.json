[{"id":"0199507e-3c5d-71a6-a2b1-b5ec10866e97","parentId":null,"rootId":null,"fromId":22699,"content":"跑外卖吧....","createdAt":"2025-09-16T11:07:54"},{"id":"0199508e-1c73-718b-b1e4-b67e86e464dd","parentId":null,"rootId":null,"fromId":1955,"content":"校友，考研！","createdAt":"2025-09-16T11:25:14"},{"id":"01995098-6823-72c6-b307-ba54bf1a6a6e","parentId":null,"rootId":null,"fromId":26929,"content":"??","createdAt":"2025-09-16T11:36:29"},{"id":"01995098-efe4-73ea-8299-e96260f475b1","parentId":null,"rootId":null,"fromId":26929,"content":"只能考研了嘛","createdAt":"2025-09-16T11:37:04"},{"id":"0199509e-18c5-71fc-b5e8-c0e49856275f","parentId":null,"rootId":null,"fromId":1398,"content":"山大的不愁找工作","createdAt":"2025-09-16T11:42:42"},{"id":"019950ac-0f8c-73f5-88ea-55d2b72466b5","parentId":null,"rootId":null,"fromId":2921,"content":"去隔壁几个办公区溜一圈不就知道了？\n远一点骑个共享单车去汉峪\n建议晚上7点以后去，看楼里乌漆嘛黑的就知道了\n5年前可都是灯火通明","createdAt":"2025-09-16T11:57:57"},{"id":"019950ef-bb66-73eb-99a2-d894b3b91b1b","parentId":null,"rootId":null,"fromId":22250,"content":"跑滴滴吧","createdAt":"2025-09-16T13:11:52"},{"id":"019950fc-3f59-7209-8ebc-1dee08eba30f","parentId":null,"rootId":null,"fromId":7535,"content":"考研考博","createdAt":"2025-09-16T13:25:32"},{"id":"0199510b-8233-7396-85bb-cd976ba90dd1","parentId":null,"rootId":null,"fromId":25906,"content":"先找工作，实在找不到合适的再说","createdAt":"2025-09-16T13:42:12"},{"id":"01995116-600b-7028-b622-4a1bcbe761c2","parentId":null,"rootId":null,"fromId":22809,"content":"都山大了你还愁啥，还让双非活吗","createdAt":"2025-09-16T13:54:04"},{"id":"0199511e-209d-71f1-b003-9547fb827ea6","parentId":null,"rootId":null,"fromId":4367,"content":"需要考虑的因素太多了，粗暴一点的话建议读研，再给自己两三年的缓冲。","createdAt":"2025-09-16T14:02:32"},{"id":"01995131-0156-734a-8598-b51f404dc5d5","parentId":null,"rootId":null,"fromId":26929,"content":"话是这样说，主要是研究生也不知道能有多大提升??","createdAt":"2025-09-16T14:23:10"},{"id":"01995142-08c5-73b0-bf3e-c98ff648f5e3","parentId":null,"rootId":null,"fromId":4367,"content":"社会的认同不是纯技术的。1.你没有硕博抬头，人工智能的研发进不去的，济南相关的国企对你的认同也很低，所以学历也是关键因素；2.读研以后导师的资源，同门师兄弟的资源，学校抬头的资源，都是一个加成，找工作本身就有很多的运气成分，好企业和好领导你很难认清，前面的资源就是给你的捷径和容错；3.可以说高校做的东西骗经费、没意义，但是省市发展策略的参考建议还是以高校教授为主，甚至是国家的战略。你可能不会找到一个大牛，但是985高校的导师对行业大方向的把握肯定是准确的，至少能抓住新兴方向（技术+市场），夕阳产业；4.去了企业也不是纯技术的，逻辑思考、信息检索、写作功底、PPT，这些能力的差距比技术的差距大得多，读研完全可以锻炼到。\n上面的内容就是想到什么说什么，只是我个人的见解，只供参考。这只是剖开读研的价值，真正的需求还是要看你个人","createdAt":"2025-09-16T14:41:46"},{"id":"01995148-0ffb-709f-9a3f-520ca9b0ac4d","parentId":null,"rootId":null,"fromId":26929,"content":"好的谢谢哥","createdAt":"2025-09-16T14:48:21"},{"id":"019951a7-808e-73ca-aa80-5970a7b9ad84","parentId":null,"rootId":null,"fromId":26654,"content":"山大的还怕找不到活，想挣钱就花个三四个月网课跟个项目，再来半年时间刷个底层八股文(不止java其他常用中间件的底层也要会)，当然你嫌网课不好编，济南这里的实习随你挑，到时候实习跟几个项目，再把八股文往上一套，随便展示点自己的基础，够你往大厂里面挤了","createdAt":"2025-09-16T16:32:35"},{"id":"019951a9-44ac-70f3-8989-b86a526a306e","parentId":null,"rootId":null,"fromId":26654,"content":"当然如果你对挣钱没有那么迫切，考研也比较有把握还是考研优先的","createdAt":"2025-09-16T16:34:31"},{"id":"0199532f-e614-70cc-a042-e95095b773b0","parentId":null,"rootId":null,"fromId":26929,"content":"济南有哪些合适的实习公司呢哥哥","createdAt":"2025-09-16T23:41:12"},{"id":"0199564a-ea69-7211-8658-b2f0608ed0d5","parentId":null,"rootId":null,"fromId":21511,"content":"这里基本是带专   你觉得你能问出来什么","createdAt":"2025-09-17T14:09:34"},{"id":"0199568f-f79d-735f-af72-bd1c99bcb5dc","parentId":null,"rootId":null,"fromId":5480,"content":"没必要考研，浪费时间和精力。以你的学习能力直接全力考公， 毕业直接上岸，明面上一辈子无忧，暗地里就看你的个人造化了。","createdAt":"2025-09-17T15:24:59"},{"id":"019956b0-db97-71bc-8667-52a4506c1ca3","parentId":null,"rootId":null,"fromId":22804,"content":"赞同，建议直接考公","createdAt":"2025-09-17T16:00:55"},{"id":"019956ce-b5a2-7192-8a9a-6d1ad4f680b2","parentId":null,"rootId":null,"fromId":5480,"content":"考公可能不会大赚，但绝对不亏。尤其是当下的环境，山大本科生当个公务员，不亏的","createdAt":"2025-09-17T16:33:31"},{"id":"019956ed-0636-7025-86a9-ad0718db08a4","parentId":null,"rootId":null,"fromId":3572,"content":"IT行业都这么卷了没必要入了，都过了红利期了；应届直接各大银行、国企投就行， 在此之前建议考研或考公，两手准备着，硕士其实含金量还是可以的，最起码走人才引进能摸到门槛","createdAt":"2025-09-17T17:06:38"},{"id":"01995755-6906-72d7-a358-d8cf716c2d72","parentId":null,"rootId":null,"fromId":26929,"content":"就是我准备考研，投这些银行国企什么的是不是还得抽出时间准备一下笔试面试呢，就是怕两个都抓不住","createdAt":"2025-09-17T19:00:39"},{"id":"01996647-4c1d-7259-8007-36c857cb4975","parentId":null,"rootId":null,"fromId":1933,"content":"两条路走，进体制、进编制，进不去就升学历，尽量避开这几年","createdAt":"2025-09-20T16:39:32"}]