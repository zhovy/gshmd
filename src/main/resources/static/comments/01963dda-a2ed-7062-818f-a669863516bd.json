[{"id":"01963dda-a36a-711d-96e2-0e2bc09af6fc","parentId":null,"rootId":null,"fromId":732,"content":"高新万达3号楼","createdAt":"2022-07-05T11:18:11"},{"id":"01963dda-a3af-72c5-99f6-f3e2df972c93","parentId":null,"rootId":null,"fromId":897,"content":"对，有没有研发的，里面啥情况","createdAt":"2022-07-05T14:29:35"},{"id":"01963dda-a406-72e8-bc37-177adbd0548c","parentId":null,"rootId":null,"fromId":902,"content":"同问，有没有测试，工作强度大不大，领导作风严不严重","createdAt":"2022-07-05T14:34:11"},{"id":"01963dda-a459-7143-867e-54f6a5a03c35","parentId":null,"rootId":null,"fromId":800,"content":"听说完美","createdAt":"2022-07-05T14:43:31"},{"id":"01963dda-a49e-705d-815f-19f65f14baa4","parentId":null,"rootId":null,"fromId":623,"content":"完美的公司","createdAt":"2022-07-05T15:16:38"},{"id":"01963dda-a4e2-72a6-9f86-1fa4dd00275a","parentId":null,"rootId":null,"fromId":797,"content":"和浪潮相较而言哪个好？","createdAt":"2022-07-05T15:30:38"},{"id":"01963dda-a527-73ad-b049-1ad36881fb2f","parentId":null,"rootId":null,"fromId":797,"content":"有人没","createdAt":"2022-07-06T11:56:25"},{"id":"01963dda-a56a-7181-8fc1-32a19a3945e1","parentId":null,"rootId":null,"fromId":21,"content":"这么大个公司没人问题，里面的人这么忙","createdAt":"2022-07-06T16:15:38"},{"id":"01963dda-a5ae-7186-bd25-ec3ff64cbc91","parentId":null,"rootId":null,"fromId":897,"content":"3楼，你是要入职测试么。\n6楼，浪潮的产业单位太多了，你说的比较是哪方面，薪资福利，业务发展，还是整体体制","createdAt":"2022-07-06T21:24:11"},{"id":"01963dda-a5f3-70f0-8d82-84d5d3ed7329","parentId":null,"rootId":null,"fromId":831,"content":"有他子公司的，哈哈，很完美啊","createdAt":"2022-07-08T08:20:26"},{"id":"01963dda-a638-73d6-b22b-c6302d25ae77","parentId":null,"rootId":null,"fromId":897,"content":"10楼，你是说子公司很完美么。到底说的是正话，还是反话","createdAt":"2022-07-08T08:40:12"},{"id":"01963dda-a67e-7017-baee-8f55c30efd2e","parentId":null,"rootId":null,"fromId":732,"content":"去吧，云鼎真不错","createdAt":"2022-07-09T10:10:04"},{"id":"01963dda-a6c4-7120-b985-182ac5398de6","parentId":null,"rootId":null,"fromId":897,"content":"12楼，兄弟，你说的是真的么，还是反话，这.里面的公司都看了，正反话,我有点分不清了.....","createdAt":"2022-07-09T17:17:45"},{"id":"01963dda-a708-7280-8724-63b6f6d38b20","parentId":null,"rootId":null,"fromId":797,"content":"来泰山信息科技","createdAt":"2022-07-09T23:10:07"},{"id":"01963dda-a753-737e-a8a1-327882981546","parentId":null,"rootId":null,"fromId":897,"content":"14楼，兄弟，我的水平不配去泰山信息科技","createdAt":"2022-07-10T07:24:53"},{"id":"01963dda-a799-727c-a296-2a39b9341580","parentId":null,"rootId":null,"fromId":939,"content":"不清楚，马一下","createdAt":"2022-07-10T13:50:25"},{"id":"01963dda-a7dd-723b-9cfb-a68ae390bfb1","parentId":null,"rootId":null,"fromId":1030,"content":"同问 听说加班很多 是真的吗","createdAt":"2022-07-20T10:41:27"},{"id":"01963dda-a821-7045-90e0-dee92403ca8d","parentId":null,"rootId":null,"fromId":460,"content":"加班很多 技术实在是不太新 全公司管理很混乱 自己入职试一下 千万别和内勤人员有太多交流","createdAt":"2022-07-20T11:46:05"},{"id":"01963dda-a867-70e9-97f9-88c06ebc4452","parentId":null,"rootId":null,"fromId":273,"content":"如果是外包过去，放弃吧，如果你能拿正式工offer那你厉害，也请回来回复一下打我脸，因为我看到他们招聘信息好久没招到人，2021年到2022年现在都没有招聘到","createdAt":"2022-07-27T14:48:30"},{"id":"01963dda-a8ab-70f6-801f-34925e5c1e6c","parentId":null,"rootId":null,"fromId":1887,"content":"18楼，你说的太对了。的确是这样。","createdAt":"2022-10-04T15:20:59"},{"id":"01963dda-a8ef-7239-95a0-b3f5702fbaa8","parentId":null,"rootId":null,"fromId":1078,"content":"加班多  996","createdAt":"2022-10-19T08:57:47"},{"id":"01963dda-a932-7276-9003-f79746783579","parentId":null,"rootId":null,"fromId":2052,"content":"加班不能调休也没有加班费。专挑晚上和周六开会","createdAt":"2022-10-22T12:51:14"},{"id":"01963dda-a74f-7253-9e87-f1812ab67568","parentId":null,"rootId":null,"fromId":5990,"content":"现在是不是不太行了","createdAt":"2023-10-23T17:53:57"},{"id":"01963dda-a977-70d1-97cc-cbb93f875a95","parentId":null,"rootId":null,"fromId":403,"content":"楼主关心的风气问题，我作为云鼎已离职的正式员工，回答一下：\n当时在云鼎机关部门，加班不多，但奇葩规定层出不穷，让你回家也要提心吊胆，玩的是精神内耗。\n云互联网事业部（研发部门）我也很熟悉，加班超级多，996状态，外行领导内行。动辄七八百万的项目，但水分很大，只是集团内部报价，放到市场上估计只能值四五十万，主打的是身体摧残。\n整个公司的风气，可以说是我呆过的几家公司里最差的，否则也不会放弃那么香的六险二金了，毕竟相比钱，还是狗命要紧。\n以上只针对云鼎正式员工，外包不了解。","createdAt":"2023-10-27T10:50:42"},{"id":"01963dda-a9bd-716e-96dc-2f2633b581d0","parentId":null,"rootId":null,"fromId":5990,"content":"感谢分享。在浪潮干着还不错，最近有个互联网部门挺感兴趣的的面试，二面也过了，在交流过程中了解的比较详细，也不知道到HR哪这么大的傲气，说起来五险一金就骄傲的不得了，发消息回复拖拖拉拉，爱回不回的，被nie姓HR和人力副总嫌弃，没看上，现在看不去挺好的","createdAt":"2023-11-24T08:44:06"},{"id":"01963dda-a9c1-725a-baec-4422f7d96a18","parentId":null,"rootId":null,"fromId":3996,"content":"他们那个人力部门就有毛病，约面试的还正常，特别是面试中的hr和人力总各种瞧不起人","createdAt":"2024-01-10T14:27:28"},{"id":"01963dda-a9c6-71b8-9aeb-2c3dea7978e1","parentId":null,"rootId":null,"fromId":21137,"content":"这个公司分体制内和体制外。体制内的都是铁饭碗，没啥技术背景。体制外的都是招聘来做牛马的。外行领导内行，体制内领导体制外。分分钟能搞死你不商量。","createdAt":"2024-06-29T20:30:50"},{"id":"01963dda-aa50-7020-8ed7-4e1c10038bab","parentId":null,"rootId":null,"fromId":21618,"content":"绝了，完美的公司。","createdAt":"2024-09-17T14:50:42"},{"id":"019aa0ba-3f0b-715f-b616-8a8bf1056a73","parentId":null,"rootId":null,"fromId":27618,"content":"能不能展开说说哥","createdAt":"2025-11-20T18:05:51"}]