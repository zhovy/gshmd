[{"id":"01963dee-cf9e-709b-be6a-d7b23b216686","parentId":null,"rootId":null,"fromId":5768,"content":"科班出身都找不到，培训出来的你觉得现实吗？","createdAt":"2024-05-13T09:31:18"},{"id":"01963dee-cfed-7230-8cf5-4b318ca1593b","parentId":null,"rootId":null,"fromId":7465,"content":"主要是觉得如果离职后的话简历上一点东西都没有，程序员的话还能写一些项目经历和熟悉的工具","createdAt":"2024-05-13T09:38:41"},{"id":"01963dee-d030-70c0-896b-c565e3b24ac8","parentId":null,"rootId":null,"fromId":1039,"content":"28就别入行程序员了，出来了也不好找工作，实施过程中深挖客户经验，可以考虑转行做售前行业专家，或者项目经理，行业经验资深的项目经理也很吃香","createdAt":"2024-05-13T09:45:25"},{"id":"01963dee-d074-705e-b830-e96b922cd60e","parentId":null,"rootId":null,"fromId":7465,"content":"售前是不是要写标书呀，是不是需要对文科功底有一定的要求呀\n项目经理不懂点技术的话会不会容易被坑呀","createdAt":"2024-05-13T09:50:33"},{"id":"01963dee-d0b9-71e3-bb80-4685ffda22f0","parentId":null,"rootId":null,"fromId":1039,"content":"你都28了，实施进阶项目经理的东西是一点都不学么，项目经理不会技术很正常，但是业务一点要了解的深刻，甚至于对于项目来说，业务了解比产品经理还要深","createdAt":"2024-05-13T10:15:35"},{"id":"01963dee-cfe4-728d-bdc8-7d431289d254","parentId":null,"rootId":null,"fromId":5624,"content":"科班+培训班","createdAt":"2024-05-13T11:21:22"},{"id":"01963dee-cfe9-70e4-8e0f-8b03fc7555c8","parentId":null,"rootId":null,"fromId":1398,"content":"???","createdAt":"2024-05-13T11:48:25"},{"id":"01963dee-d104-73b0-9887-bfa5acdeeea3","parentId":null,"rootId":null,"fromId":2408,"content":"现在转行做程序员就是49年入国军","createdAt":"2024-05-13T17:06:33"},{"id":"01963dee-d147-73d0-85a8-4897cc066363","parentId":null,"rootId":null,"fromId":7427,"content":"老铁，还程序员培训班呢，都夕阳西下，古道西风瘦马了。    赶紧销售练起来啊","createdAt":"2024-05-14T14:03:22"}]