[{"id":"01963dd1-30ac-72ef-b8ec-953c32910cab","parentId":null,"rootId":null,"fromId":293,"content":"外包 五险没有一金 还要过了试用期才给交  大小周","createdAt":"2022-04-23T23:39:03"},{"id":"01963dd1-30f1-7073-a22d-b55eb6a041d1","parentId":null,"rootId":null,"fromId":938,"content":"拖欠工资吗？？那位同仁了解，刚谈好要去的，说的清楚点就避雷了。","createdAt":"2022-07-18T20:26:32"},{"id":"01963dd1-3140-7037-8381-b226257523b5","parentId":null,"rootId":null,"fromId":1289,"content":"这个傻逼公司真的应该被吐槽一下，整个一个外包公司，入职还有7天试岗，试岗不通过就没有任何工资。\n曾经刚毕业面试的第一家公司就是这个，办理入职之后在一个小屋里待了七天，七天没人问我一句话，就让我看资料，然后第七天下午和我说试岗不通过。\n呵呵，垃圾，浪费老子时间。现在想来，感谢不录用之恩。","createdAt":"2022-08-11T14:19:30"},{"id":"01963dd1-318a-735b-904b-0251d24be309","parentId":null,"rootId":null,"fromId":3608,"content":"还有在这个公司的嘛，讲讲现状如何，项目经理岗位值得去吗","createdAt":"2023-05-24T15:54:49"},{"id":"01963dd1-31ce-73f0-8946-4995a528a4cf","parentId":null,"rootId":null,"fromId":3935,"content":"在这个公司的时候还是在舜泰广场六号楼的，后来搬到的济南站明珠怡和大酒店里面，然后后来同事们陆陆续续都被清退了，怎么说呢，老板是个智障，一天娘们唧唧的翘个兰花指，同事们走的原因都是降工资逼你走，找我们每一个人谈话让我们走，然后疫情那时候工资直接折半一个月2000多块钱，你就说你走不走吧，反正这家公司没啥好印象，亲身经历！勿踩雷！各种各样的借口，极其恶心人","createdAt":"2023-06-29T11:13:55"},{"id":"01963dd1-3214-7043-b1b6-6499f2633c96","parentId":null,"rootId":null,"fromId":3936,"content":"兄弟   你啥时候去的这家公司？","createdAt":"2023-06-29T11:16:14"},{"id":"01963dd1-3219-7271-b683-dbee091d7868","parentId":null,"rootId":null,"fromId":3935,"content":"4年前了吧","createdAt":"2023-06-29T11:18:34"},{"id":"01963dd1-321d-73f6-87e1-cd80da1b5403","parentId":null,"rootId":null,"fromId":3936,"content":"我大概也是四年前，当时也是被逼着走，我做开发的，非得逼着我去东北出差做实施去","createdAt":"2023-06-29T11:22:51"},{"id":"01963dd1-3222-7024-aaf6-b2a96f5220cf","parentId":null,"rootId":null,"fromId":3936,"content":"之前年会还是聚餐来着，见了老板一面，确实和你说的一样","createdAt":"2023-06-29T11:24:00"},{"id":"01963dd1-3227-7365-8739-03d602ccb3b1","parentId":null,"rootId":null,"fromId":3935,"content":"咱都心知肚明的事儿了，同一批，甚至能猜出来你是谁，有一说一我是当时被恶心坏了","createdAt":"2023-06-29T11:29:01"},{"id":"01963dd1-322b-73b7-b0d2-ae38d619e638","parentId":null,"rootId":null,"fromId":3936,"content":"我大概知道你是谁了，你是CXJ吗？","createdAt":"2023-06-29T11:42:24"},{"id":"01963dd1-322f-7323-a277-4ac7b4247ef2","parentId":null,"rootId":null,"fromId":3935,"content":"不是哟","createdAt":"2023-06-29T11:49:54"},{"id":"01963dd1-3233-72e6-a117-1e6ebec0783b","parentId":null,"rootId":null,"fromId":3936,"content":"那就是LH","createdAt":"2023-06-29T13:40:26"},{"id":"01963dd1-3185-725e-bdbf-80683570793d","parentId":null,"rootId":null,"fromId":6458,"content":"跟我一样一样的，我是9年前面的第一家公司，我学成java后面的第一家啊。那个老板跟个傻逼一样，那个秘书估计是他的小蜜，当时我一听7天试岗，还不发工资，当时我就骂了一句，甩手走人，当时出生牛犊不怕虎，还不算缺钱，并且当时在泰安还有自己的打架小伙伴。当时就骂了直接走的人，弄的那个面试官尴尬的很，但我当时就那么牛逼了，现在想象真庆幸啊。。","createdAt":"2024-04-26T11:25:40"}]