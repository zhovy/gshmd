[{"id":"01963df8-08d4-73d7-b77f-69921d56bbe5","parentId":null,"rootId":null,"fromId":22452,"content":"去经历,保持健康身体，做好本职工作，剩下交给天意!","createdAt":"2025-03-24T16:22:17"},{"id":"01963df8-0918-70f5-b94c-ae87b85544b9","parentId":null,"rootId":null,"fromId":22539,"content":"谈出路的前提是你有个健康的体魄","createdAt":"2025-03-24T16:25:20"},{"id":"01963df8-095e-73b5-ae69-6d4ea974f43b","parentId":null,"rootId":null,"fromId":1398,"content":"种地","createdAt":"2025-03-24T16:37:17"},{"id":"01963df8-0beb-7032-9691-8873e48400af","parentId":null,"rootId":null,"fromId":2246,"content":"还有十年呢，没人能预测那时候啥样，锻炼好身体，做好本职工作就行了","createdAt":"2025-03-24T17:00:24"},{"id":"01963df8-0c36-73ed-9a81-94e2bffd6b09","parentId":null,"rootId":null,"fromId":875,"content":"济南多买几套房，收租","createdAt":"2025-03-24T17:21:32"},{"id":"01963df8-0c7a-733d-b149-faa19c9ab00c","parentId":null,"rootId":null,"fromId":796,"content":"如果没有成家，别在山东混，挣几年钱再回山东买房","createdAt":"2025-03-24T21:44:50"},{"id":"01963df8-0cbe-70b1-93af-ba051caec866","parentId":null,"rootId":null,"fromId":875,"content":"今天济南空气质量轻度污染","createdAt":"2025-03-25T07:41:15"},{"id":"01963df8-0d02-731a-bc97-4b9ecc78288f","parentId":null,"rootId":null,"fromId":3279,"content":"37岁程序员真诚回复。假如你热爱技术，那就少想多做，找个技术栈深耕十年，无论数据库、前端、后端、大模型、单片机，都可以。每一行的技术专家还是能碗饭吃。--------------------------------如果你不热爱技术，可以改行干产品、销售，积累自己的人脉，搭建自已的行业赛道。-----------如果你只想混日子，建议沪江学点日语，去外包到日本IT，那边混日子还能多赚点。","createdAt":"2025-03-25T08:35:09"},{"id":"01963df8-0d48-723f-82dc-18ee90775291","parentId":null,"rootId":null,"fromId":3801,"content":"中肯，各个公司都有大龄程序员，大浪淘沙。","createdAt":"2025-03-25T08:54:54"},{"id":"01963df8-0d4c-737b-97bf-1aa094b59783","parentId":null,"rootId":null,"fromId":6268,"content":"干好自己的，未来如何，只有天知道了","createdAt":"2025-03-25T15:40:55"},{"id":"01963df8-0d90-73b2-9777-910d50423345","parentId":null,"rootId":null,"fromId":6268,"content":"爱惜自己的身体，将来看看我们的社会主义祖国会变成什么样子（哽咽）","createdAt":"2025-03-25T15:41:52"},{"id":"01963df8-0dd5-718f-ac46-f01360212073","parentId":null,"rootId":null,"fromId":4087,"content":"对于信用良好、有大额消费需求的客户，个人消费贷款自主支付的金额上限可阶段性从30万元提高至50万元，个人互联网消费贷款金额上限可阶段性从20万元提高至30万元。 在选择给百姓放水还是发钱的选择上，选择了放高利贷。","createdAt":"2025-03-25T15:44:42"},{"id":"01963df8-0e1f-70ca-a011-5cb9cc4d7b92","parentId":null,"rootId":null,"fromId":22972,"content":"我今年34岁，在济南上学，跑到一线城市，手里有些积蓄，无房无车无对象，现在焦虑的很，不知道以后出路在哪。","createdAt":"2025-03-25T16:27:04"},{"id":"01963df8-0e62-7134-952d-78c92bc57d7c","parentId":null,"rootId":null,"fromId":875,"content":"毕业到35，去北京干10年，赚够200万现金和50万公积金，回老家买房置地，当农场主，雇人搭理，不要老想着找工作，给别人打工，出卖时间是最低价的","createdAt":"2025-03-25T19:14:48"},{"id":"01963df8-0e1a-723c-97ee-9977d547419d","parentId":null,"rootId":null,"fromId":875,"content":"你有钱才能借到钱，小米配股定价53块钱，这就是底气","createdAt":"2025-03-25T21:16:34"},{"id":"01963df8-0e66-7211-8b7b-f79653fa7a74","parentId":null,"rootId":null,"fromId":403,"content":"我在两年前一直做程序员，后来刚转行做管理两年，现已40+了。本来想提供一些愚见的，一看UP要求是35岁才能提建议，无奈放弃了-_-","createdAt":"2025-03-26T08:52:36"},{"id":"01963df8-0eab-7283-b594-035ac7aa0007","parentId":null,"rootId":null,"fromId":7381,"content":"35+ 给点建议呗","createdAt":"2025-03-26T10:49:09"},{"id":"01963df8-0eaf-70f2-894c-32a9c166435e","parentId":null,"rootId":null,"fromId":6091,"content":"你是不是在逗楼主","createdAt":"2025-03-26T11:04:10"},{"id":"01963df8-0eb4-724a-8e90-7f1419017ee0","parentId":null,"rootId":null,"fromId":3341,"content":"只看到一群傻比说屁话。","createdAt":"2025-04-01T09:23:41"}]