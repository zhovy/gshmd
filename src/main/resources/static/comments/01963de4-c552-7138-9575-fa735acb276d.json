[{"id":"01963de4-c5bb-73c2-9172-dfdfa31c9746","parentId":null,"rootId":null,"fromId":576,"content":"济南的公司，软件性质的，你就认为随便学一套boot+vue+mysql+低代码的就几乎可以去全济南的软件性质的公司了。硬件另说。游戏另说。","createdAt":"2023-07-11T08:56:27"},{"id":"01963de4-c601-708e-a782-79772eb8cf5b","parentId":null,"rootId":null,"fromId":4016,"content":"哥们你这需求理解力，别说你干开发的","createdAt":"2023-07-11T09:20:00"},{"id":"01963de4-c606-71bd-8f82-50fe6b046959","parentId":null,"rootId":null,"fromId":1150,"content":"现在的愤青 擅长管中窥豹","createdAt":"2023-07-11T09:29:17"},{"id":"01963de4-c60f-719b-87ef-80789b08c656","parentId":null,"rootId":null,"fromId":3446,"content":"大概率合同不是和银行签，忙不忙要看项目吧","createdAt":"2023-07-11T10:17:44"},{"id":"01963de4-c655-7325-8127-5c8c4e28c431","parentId":null,"rootId":null,"fromId":3219,"content":"具体位置在哪啊","createdAt":"2023-07-11T11:21:58"},{"id":"01963de4-c69f-72d1-9ca5-f8a1fa65a67b","parentId":null,"rootId":null,"fromId":3024,"content":"没看见有招聘信息哈~~·boss上没有\n","createdAt":"2023-07-11T11:29:14"},{"id":"01963de4-c6e4-723f-9b53-eb3853a3c506","parentId":null,"rootId":null,"fromId":3263,"content":"官网有招聘信息","createdAt":"2023-07-11T13:22:52"},{"id":"01963de4-c6e8-71e0-8736-498ecc962194","parentId":null,"rootId":null,"fromId":4016,"content":"直接去齐鲁银行问，真招人告诉我一下","createdAt":"2023-07-11T13:29:05"},{"id":"01963de4-c6ec-7362-8bf3-1c855063e8c6","parentId":null,"rootId":null,"fromId":2551,"content":"官网上招聘的是齐鲁银行正式员工的","createdAt":"2023-07-11T15:02:13"},{"id":"01963de4-c730-72e4-99cf-e83f47f7b223","parentId":null,"rootId":null,"fromId":2551,"content":"齐鲁银行科技部社招，入职是跟齐鲁银行签约的，不过要求比较高。","createdAt":"2023-07-11T15:04:08"},{"id":"01963de4-c777-718c-b2b4-35869911384d","parentId":null,"rootId":null,"fromId":3263,"content":"就怕进去以后, 还是996","createdAt":"2023-07-12T11:12:11"},{"id":"01963de4-c77d-7392-93da-ec8bad9ab691","parentId":null,"rootId":null,"fromId":4016,"content":"996是福报，银行应该不会差钱","createdAt":"2023-07-12T12:39:25"},{"id":"01963de4-c780-71b9-a878-519268aa79f3","parentId":null,"rootId":null,"fromId":2551,"content":"银行应该不会996吧，而且你见过哪个银行科技自己写代码啊","createdAt":"2023-07-12T14:09:33"},{"id":"01963de4-c78a-725c-a4c2-ee2c27814b7f","parentId":null,"rootId":null,"fromId":933,"content":"冷知识，官网招聘也有可能是招外包","createdAt":"2023-07-12T14:32:48"},{"id":"01963de4-c7ce-714a-9ef7-b95d7c4cd0c3","parentId":null,"rootId":null,"fromId":4144,"content":"本人有幸在汉峪金谷邮储银行总部干过几天外包。说下我对银行项目的感受。\n1.技术落后，基本落后主流技术十年以上\n2.网络闭塞，全内网环境，基本没法连外网查资料\n3.加班严重，996是常态。\n当然不同银行、不同项目可能会有不同。","createdAt":"2023-07-20T14:13:32"},{"id":"01963de4-c785-70f0-b63b-c22a0c0c2a0d","parentId":null,"rootId":null,"fromId":3706,"content":"看负责的业务域，很多需要晚上值班跑批的","createdAt":"2023-08-03T12:30:23"}]