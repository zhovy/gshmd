[{"id":"01963ddf-deca-723c-ad2c-26e79005a607","parentId":null,"rootId":null,"fromId":2709,"content":"听说是国企？","createdAt":"2023-03-03T09:53:55"},{"id":"01963ddf-df11-7088-8c8b-25a0c92b04bc","parentId":null,"rootId":null,"fromId":2241,"content":"不是国企，是类似浪潮这种假国企；加班多，总公司在杭州被称为滨江四大坑之一；但待遇在济南来说算高的，在杭州坑是因为待遇相较杭州其他公司差太多","createdAt":"2023-03-03T10:57:48"},{"id":"01963ddf-df5f-73ba-947f-e16ea557dec5","parentId":null,"rootId":null,"fromId":2341,"content":"之前在杭州想进没进去，应该是可以的，入职了探探虚实，月更此帖","createdAt":"2023-03-03T17:09:00"},{"id":"01963ddf-dfa9-706d-aef8-99ab5d155211","parentId":null,"rootId":null,"fromId":167,"content":"面试过，整体感觉还可以，不过在济南产品薪资最多给到15，太低了。如果要更高需要去总部，咱拖家带口不适合，如果有需要的可以试试","createdAt":"2023-03-09T10:24:37"},{"id":"01963ddf-dfef-73fe-a53b-6ddda06906d1","parentId":null,"rootId":null,"fromId":2890,"content":"好不好的也不招人了，你就是想去也去不了","createdAt":"2023-03-13T11:17:56"},{"id":"01963ddf-e034-7280-82f1-4e458d6e5642","parentId":null,"rootId":null,"fromId":1039,"content":"我看都写的14薪，15薪，想问一下   22年两三个月年终奖确实发了么？真的还是画饼","createdAt":"2023-03-13T15:29:55"},{"id":"01963ddf-e07a-70bf-8c21-f8d91f4e6e46","parentId":null,"rootId":null,"fromId":3395,"content":"杭州那边是给15薪，当然加班到9点10点也是日常操作了","createdAt":"2023-12-26T16:26:15"},{"id":"01963ddf-df5a-72fa-b354-ad7ac62a77fe","parentId":null,"rootId":null,"fromId":3395,"content":"杭州那边的大厂太多了，没办法","createdAt":"2023-12-26T16:26:42"},{"id":"01963ddf-e07e-7107-a49e-a500042e605b","parentId":null,"rootId":null,"fromId":7130,"content":"老哥了解的咋样了","createdAt":"2024-04-16T13:59:36"}]