[{"id":"01963ddb-0b89-7004-8021-22a22e332dda","parentId":null,"rootId":null,"fromId":206,"content":"面试过，没去","createdAt":"2022-07-20T11:02:33"},{"id":"01963ddb-0bce-7192-8e3e-fcbdd4f26033","parentId":null,"rootId":null,"fromId":1046,"content":"同问","createdAt":"2022-07-20T11:11:42"},{"id":"01963ddb-0c13-72c8-aabb-092116effa00","parentId":null,"rootId":null,"fromId":1148,"content":"之前投过实习 面试也过了没去 公司是新成立没几年的 人不多 貌似是老板再创业 因为没去所以也不知道具体工作怎么样 反正面试过程很友好","createdAt":"2022-09-12T16:23:45"},{"id":"01963ddb-0c58-72f0-afcb-1772b0877863","parentId":null,"rootId":null,"fromId":1642,"content":"想问问3楼的工作经验，技术多强，面的什么岗。我毕业一年多，专业对口，上个月跟他们的闵谈过，但是嫌我技术跟车不对口不收。","createdAt":"2022-10-18T16:47:18"},{"id":"01963ddb-0c9c-707b-b20e-0b6eb1554494","parentId":null,"rootId":null,"fromId":6519,"content":"垃圾公司 天天大饼发奖金  一分钱没收到过  待遇越来越差 公司越来越恶心人  老板 和 HR  两条狗","createdAt":"2024-01-23T14:44:12"},{"id":"01963ddb-0ce2-712c-8bad-377fbc7b4f68","parentId":null,"rootId":null,"fromId":2367,"content":"你好，请问你在这工作过么，能不能加个联系方式向你详细了解下。","createdAt":"2024-05-11T19:21:43"},{"id":"01963ddb-0d2d-723a-802d-5c285102ead5","parentId":null,"rootId":null,"fromId":6393,"content":"公司福利很完善，有入职缴纳五险一金、全勤奖、餐补、项目奖金、季度奖。\n周末双休，上班时间弹性工作制，非常人性化。","createdAt":"2025-04-15T09:55:31"}]