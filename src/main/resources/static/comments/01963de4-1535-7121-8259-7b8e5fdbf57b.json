[{"id":"01963de4-15a2-7058-8a02-3e53b466fcdd","parentId":null,"rootId":null,"fromId":1039,"content":"https://gshmd.vip/company/1468","createdAt":"2023-06-26T08:32:09"},{"id":"01963de4-15e7-7220-b063-917f5c87445d","parentId":null,"rootId":null,"fromId":1049,"content":"1、待遇不是很高\n2、活很难干，领导安排的任务杂乱无章\n3、加班不少\n总之，有更好的选择不要来。","createdAt":"2023-06-26T11:13:38"},{"id":"01963de4-1630-7113-9750-2c85d9c5b0c8","parentId":null,"rootId":null,"fromId":1039,"content":"有加班费，但是加班很多，节假日无三倍工资，200一天","createdAt":"2023-06-27T15:18:09"},{"id":"01963de4-162c-7087-a0f6-222d1c3fc9e8","parentId":null,"rootId":null,"fromId":4086,"content":"找不到工作的，可以去试试吗？","createdAt":"2023-10-11T11:09:13"},{"id":"01963de4-1675-7122-8caf-6eb1a76b8278","parentId":null,"rootId":null,"fromId":1049,"content":"现在一三五六加班[doge]","createdAt":"2024-01-18T17:05:10"},{"id":"01963de4-16ba-7023-95c5-e07d4f91f10c","parentId":null,"rootId":null,"fromId":6682,"content":"最新：\n1.加班无加班费（事实依据，问过财务去年10月份之后就没有了）\n2.私自变更工作时间（大小周变为，上六休一，劳动法最高时间44小时哦）\n3.管理混乱，经常开会（宣传公司核心思想，还有考核？！过不了还扣钱，真是笑死）\n4.业务混乱，经常就是一拍脑袋就要上功能\n5.主打一个不画饼直接加压（认清现实赶紧跑路吧）\n6.公司感觉没一个懂法的（劳动法和他家写的一样，直接无视规定啊，也就是规定的罚款力度轻否则早拉倒了）\n7.基础工资特别低（五险一金有倒是有，多少？最低档）\n总结：\n按照近况来说，除非你是要饿死的那种，否则还是别来了","createdAt":"2024-02-20T00:35:35"},{"id":"01963de4-1700-71b5-b3ca-cedd2e10ff90","parentId":null,"rootId":null,"fromId":6682,"content":"补充：\n公司困难，15号发工资，20号还没收到呢","createdAt":"2024-02-20T00:37:44"},{"id":"01963de4-1705-73f7-ba1a-02411fd3f576","parentId":null,"rootId":null,"fromId":6737,"content":"说的太对了，要不要一块跑路呀！","createdAt":"2024-02-23T14:04:49"},{"id":"01963de4-1709-7166-890d-a58612042d5a","parentId":null,"rootId":null,"fromId":1049,"content":"出差不能随便打车，必须符合条件才可以，需要扛着大包小包挤公交","createdAt":"2024-04-08T21:32:34"},{"id":"01963de4-1754-7366-a222-cab9348993ec","parentId":null,"rootId":null,"fromId":1039,"content":"欠薪欠薪欠薪","createdAt":"2024-06-05T10:45:30"},{"id":"01963de4-174f-7133-87b7-74a52fb7d802","parentId":null,"rootId":null,"fromId":21237,"content":"笑死了，本来打算投简历的。?","createdAt":"2024-07-01T15:55:14"},{"id":"01963de4-179f-7237-8108-a85376c5e0ce","parentId":null,"rootId":null,"fromId":1039,"content":"单休，而且周六保证不休息，周日休息不保证，平时晚上倒是不怎么加班","createdAt":"2024-07-20T13:54:14"},{"id":"01963de4-17e4-736d-badb-5952080360d6","parentId":null,"rootId":null,"fromId":21429,"content":"有那么忙吗","createdAt":"2024-07-21T15:58:16"},{"id":"01963de4-1799-7236-a846-9e07e9f2bb44","parentId":null,"rootId":null,"fromId":21429,"content":"楼上说的那么忙还欠薪啊","createdAt":"2024-07-21T15:59:47"},{"id":"01963de4-17e9-71c1-bed9-3e227255e034","parentId":null,"rootId":null,"fromId":1049,"content":"没有假期，不管事假年假什么假，只要是请了就要再加班补回来，要不然就会不够标准工时扣分(傻逼)扣钱","createdAt":"2024-12-18T15:14:49"},{"id":"019b6945-06ef-7208-9f7b-f7fc4d41bcac","parentId":null,"rootId":null,"fromId":658,"content":"这公司现在怎么样有无了解的老哥说一下感谢","createdAt":"2025-12-29T16:41:30"}]