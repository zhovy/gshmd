[{"id":"01963de6-7b93-71b5-9d58-dd4d8d276482","parentId":null,"rootId":null,"fromId":1164,"content":"人资比技术牛逼，是装逼的逼","createdAt":"2023-08-17T18:07:47"},{"id":"01963de6-7bdb-705f-96b8-a2257dcdc9df","parentId":null,"rootId":null,"fromId":1398,"content":"确实?，去了你看看出来后不后悔","createdAt":"2023-08-17T18:58:59"},{"id":"01963de6-7c27-7372-967d-e4a22c6adcbf","parentId":null,"rootId":null,"fromId":4174,"content":"待遇怎么样","createdAt":"2023-08-18T09:20:17"},{"id":"01963de6-7bd7-7153-aa7f-a8f272bb8b81","parentId":null,"rootId":null,"fromId":4174,"content":"人力不看技术？","createdAt":"2023-08-18T09:20:32"},{"id":"01963de6-7c2c-707f-afd2-4c34d4f7e363","parentId":null,"rootId":null,"fromId":3383,"content":"怎么才能进去，投简历一直不回","createdAt":"2023-08-18T09:21:34"},{"id":"01963de6-7c71-712b-9647-a939653ba2b0","parentId":null,"rootId":null,"fromId":4174,"content":"什么学历","createdAt":"2023-08-18T09:25:23"},{"id":"01963de6-7c76-7149-8a0a-bb955c2870ed","parentId":null,"rootId":null,"fromId":3671,"content":"一堆人联系我，都是外包城商联盟","createdAt":"2023-08-18T10:10:49"},{"id":"01963de6-7c7a-7066-bbd3-73816a7fa59b","parentId":null,"rootId":null,"fromId":3383,"content":"本科，想进本部","createdAt":"2023-08-18T13:34:16"},{"id":"01963de6-7c7e-731b-9caa-18bc834c4d20","parentId":null,"rootId":null,"fromId":3238,"content":"你什么学历啊","createdAt":"2023-08-18T17:00:28"},{"id":"01963de6-7c83-7164-aab8-ae9ef6584d38","parentId":null,"rootId":null,"fromId":4222,"content":"校招进去呆了3年走了\n\n先说优点，对于刚毕业的学生挺友好的，工资总包普本13左右，双一流17左右，有食堂，双休，加班有加班费，公积金按基本工资的12%交的，补充商业保险和企业年金，中秋和过年会发比较大的福利，工作岗位看部门吧，每个部门不一样，基本不是特别忙\n\n缺点就是想走技术路线的建议慎重考虑，技术栈老旧，走金融业主路线的倒是有不少跳到银行的，位置很偏僻，在高新东孙村，内部开发流程繁琐且混乱，还有不少关系户，公司投入了很多钱花在人力外包上，然而根本就不需要这么多人力，本部大概900人，外包得1k多，我都替公司心疼，很多外包或者本部的人闲的很，人力过剩！！","createdAt":"2023-08-20T22:23:47"},{"id":"01963de6-7cc9-70c5-badb-13cfa624735e","parentId":null,"rootId":null,"fromId":4174,"content":"刚毕业一月能拿多少","createdAt":"2023-08-21T11:04:09"},{"id":"01963de6-7cce-7204-a2f5-7316c17b1712","parentId":null,"rootId":null,"fromId":4222,"content":"普本第一年总包13吧，年终奖挺多的","createdAt":"2023-08-21T21:39:32"}]