[{"id":"01963ddb-2326-7286-b3ff-2bd6e956049e","parentId":null,"rootId":null,"fromId":335,"content":"不知道你是说的外包还是正式员工\n正式员工两年前还是齐鲁交通的的时候基本工资是很低的，全靠绩效年终奖活着，一年到头的全部算下来在济南就普普通通（包括所有的福利加起来）。\n外包的话就没啥好说的 可能是一个公司一个样","createdAt":"2022-07-29T14:05:52"},{"id":"01963ddb-2369-72e8-ad6c-30c254df83f9","parentId":null,"rootId":null,"fromId":414,"content":"工资很低，学不到东西，薪酬制度跟能力毫无关系","createdAt":"2022-08-29T17:16:55"},{"id":"01963ddb-23af-73bb-a985-57a72b3507c7","parentId":null,"rootId":null,"fromId":2389,"content":"工资很低，低于津南平均水平，公积金基本工资（60%）的12% ","createdAt":"2023-05-16T10:51:51"},{"id":"01963ddb-23ff-7275-af6c-900738627fa7","parentId":null,"rootId":null,"fromId":4087,"content":"确实  工资水平低的感觉有些离谱。","createdAt":"2023-08-02T12:30:25"},{"id":"01963ddb-23fa-7193-813c-4197bbdd8de3","parentId":null,"rootId":null,"fromId":1712,"content":"不错了，比我们一两百强的不知道哪里去了","createdAt":"2023-08-02T13:09:49"},{"id":"01963ddb-2443-73fc-beed-dd5a848d8139","parentId":null,"rootId":null,"fromId":2821,"content":"三年能多少","createdAt":"2023-08-02T13:16:00"}]