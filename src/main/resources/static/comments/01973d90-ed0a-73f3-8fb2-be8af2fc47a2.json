[{"id":"01973dbc-ece4-70e6-bf1a-57a1c83b725e","parentId":null,"rootId":null,"fromId":21267,"content":"大城市也不大行了，全国都是如此，不过比济南好歹强一些。济南素有外包之城的美誉，哪有几个正经的自研公司，全是草台班子","createdAt":"2025-06-05T09:38:01"},{"id":"01973def-bcaf-7080-a334-323a7a7cdc84","parentId":null,"rootId":null,"fromId":23701,"content":"仅以自己经历为例说明，不代表其他人\n目前我自己在济南工资一万五感觉已经封顶，在杭州之前两万五还有上升空间，努努力能到三万以上\n我老婆在杭州薪资一万，普通小公司采购岗位，在济南五千左右\n杭州有很多中小规模的it公司，起码我面试了很多都是自研的，各种行业都有，当然也很内卷，技术要求比济南高一些","createdAt":"2025-06-05T10:33:31"},{"id":"01973e2c-ab46-7191-8308-831af442652b","parentId":null,"rootId":null,"fromId":23684,"content":"比济南好多","createdAt":"2025-06-05T11:40:04"},{"id":"01973eb8-c72a-7201-8941-927257bfa82d","parentId":null,"rootId":null,"fromId":2815,"content":"银行、通信、电网的外包项目撑起了济南的IT","createdAt":"2025-06-05T14:13:06"},{"id":"01973f4d-65f9-70bb-8ec0-e26126dcf2e4","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-06-05T16:55:26"},{"id":"01973f4f-f8e8-733b-9175-3eb07dcefe3e","parentId":null,"rootId":null,"fromId":23959,"content":"2","createdAt":"2025-06-05T16:58:15"},{"id":"01974304-0ff5-70ab-863d-49eacb41dee0","parentId":null,"rootId":null,"fromId":23300,"content":"你知道的太多了。。。不过知道的不晚","createdAt":"2025-06-06T10:13:49"}]