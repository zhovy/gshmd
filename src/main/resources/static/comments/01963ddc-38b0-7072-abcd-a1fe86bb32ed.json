[{"id":"01963ddc-3913-7228-bee3-0a1f21340f10","parentId":null,"rootId":null,"fromId":1164,"content":"有出差，但不频繁。每周固定几天加班，单休，领导多，不干实事。相对差劲，想去混混工资过度过度的可以考虑，不适合长期发展","createdAt":"2022-09-08T12:17:37"},{"id":"01963ddc-3959-7225-97af-e3c74413a536","parentId":null,"rootId":null,"fromId":1039,"content":"单双休，出差基本上没有吧，偶尔，不过工资很高，14/15薪的都有，老员工也很多，十几年的，相比我觉得比中孚好太多","createdAt":"2022-09-09T16:30:49"},{"id":"01963ddc-399f-7173-9c3c-6274dd07e4c6","parentId":null,"rootId":null,"fromId":1039,"content":"不要听信人力说的14/15薪，今年年终奖发了，全部都没有兑现，最多的一个半月年终","createdAt":"2023-02-09T09:22:19"},{"id":"01963ddc-39e6-7309-bf4b-c584dda60dd6","parentId":null,"rootId":null,"fromId":7425,"content":"入职2年半了，半分钱年终没见过","createdAt":"2024-11-19T18:34:22"}]