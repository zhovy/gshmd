[{"id":"019b43f1-018d-715a-9a54-5de8698d68ac","parentId":null,"rootId":null,"fromId":27587,"content":"你想表达什么？","createdAt":"2025-12-22T10:43:46"},{"id":"019b4416-3648-72cb-b171-5f751f60a0bd","parentId":null,"rootId":null,"fromId":557,"content":"估计不少国人是股东。","createdAt":"2025-12-22T11:24:25"},{"id":"019b4483-bdee-729c-988c-53845b1da0d9","parentId":null,"rootId":null,"fromId":22250,"content":"论《信息茧房》的危害","createdAt":"2025-12-22T13:24:03"},{"id":"019b44c7-e9f0-734b-9c0f-a9808d5204e0","parentId":null,"rootId":null,"fromId":2246,"content":"最好是公布出来。洪森这种跳梁小丑什么水平，也敢学特朗普造牌？","createdAt":"2025-12-22T14:38:30"},{"id":"019b44c9-a7b2-736b-ae0d-3cbfcf073af3","parentId":null,"rootId":null,"fromId":22250,"content":"背后的大人们可不敢让他们公布","createdAt":"2025-12-22T14:40:25"},{"id":"019b44cc-e884-7311-b052-8804ebdd6eed","parentId":null,"rootId":null,"fromId":2246,"content":"行啦，你也信这个。他只要敢公布，他就坐实了参与电诈和人口买卖，大人们没啥事儿，他自己考虑考虑能不能活着下台吧。","createdAt":"2025-12-22T14:43:58"},{"id":"019b44d0-80ca-7138-8881-4bc9100892e8","parentId":null,"rootId":null,"fromId":21302,"content":"不可能的，本来还有块遮羞布，谁会傻掉自己把这块遮羞布扯掉，往自己脸上刻证据？","createdAt":"2025-12-22T14:47:53"},{"id":"019b44d4-bfc6-72be-b1d5-cf904dc7b636","parentId":null,"rootId":null,"fromId":22250,"content":"他可不管什么脸面，前世界还有谁不知道他参与电砸？流氓还要脸？","createdAt":"2025-12-22T14:52:32"},{"id":"019b459b-44a3-7201-aa51-3047342b81a8","parentId":null,"rootId":null,"fromId":2921,"content":"你怎么确定它不是川普的一张牌呢","createdAt":"2025-12-22T18:29:22"},{"id":"019b48c0-5c15-7226-967c-f606b5939745","parentId":null,"rootId":null,"fromId":21302,"content":"还是有点不懂zz，只要不发红头文件，那就是没有。管你们怎么说呢","createdAt":"2025-12-23T09:08:44"},{"id":"019b49b8-8a99-708b-9f17-e020166e626c","parentId":null,"rootId":null,"fromId":2246,"content":"川普的牌就更完犊子了。爱泼斯坦的事儿他一屁股屎都擦不干净","createdAt":"2025-12-23T13:39:49"},{"id":"019b4a40-a7a7-7303-8852-acd5f9c719ec","parentId":null,"rootId":null,"fromId":2783,"content":"三大运营商：别啊","createdAt":"2025-12-23T16:08:29"}]