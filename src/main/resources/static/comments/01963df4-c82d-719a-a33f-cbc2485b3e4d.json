[{"id":"01963df4-c895-71a1-b4cb-898c31bd4379","parentId":null,"rootId":null,"fromId":21302,"content":"dd","createdAt":"2024-11-17T22:56:31"},{"id":"01963df4-c8d9-7061-bd48-d59ef5213a72","parentId":null,"rootId":null,"fromId":21302,"content":"办公环境不错，但看股权结构感觉不太靠谱啊","createdAt":"2024-11-17T22:56:58"},{"id":"01963df4-c920-73bc-9818-6f6ce620ad20","parentId":null,"rootId":null,"fromId":1398,"content":"这么晚了咋还不睡","createdAt":"2024-11-18T02:05:07"},{"id":"01963df4-c964-736a-b5f9-4eb3c4771e4a","parentId":null,"rootId":null,"fromId":5790,"content":"张怀民？","createdAt":"2024-11-18T09:20:57"},{"id":"01963df4-c969-71fb-a9f7-38fde6f80ae3","parentId":null,"rootId":null,"fromId":7249,"content":"加班强度很大，工资压的很低，需求不明确，天天发版上线","createdAt":"2024-11-27T16:36:15"},{"id":"01963df4-c9b1-73da-8a4a-688b7aa8e47a","parentId":null,"rootId":null,"fromId":5886,"content":"老哥 干了多久","createdAt":"2024-12-04T17:03:03"},{"id":"01963df4-c9b6-70c9-bff0-77248e2e5541","parentId":null,"rootId":null,"fromId":7491,"content":"这种公司 真他么打着灯笼都找不到第二个","createdAt":"2025-02-19T23:56:50"},{"id":"01963df4-c9ba-730c-8407-53fe73e6704d","parentId":null,"rootId":null,"fromId":23109,"content":"加班强度大，用的java，芋道源码的框架","createdAt":"2025-04-09T17:40:06"},{"id":"01965cf4-5ac1-7320-81b4-81ce04c083bd","parentId":null,"rootId":null,"fromId":22927,"content":"五天，三天在发版，发版就意味着加班自己品吧，六点下班，六点开会，开会谁也不能走，开个会半个小时一个小时是常有的事，周末还会安排人值班，没有闲着的时候","createdAt":"2025-04-22T18:04:00"},{"id":"0196a856-7c60-70c6-903e-8f58b6fc098f","parentId":null,"rootId":null,"fromId":3345,"content":"楼主去了没用，感受如何？","createdAt":"2025-05-07T09:22:42"},{"id":"0196adaf-d2ae-72b8-9ff3-eb5438dd5f2b","parentId":null,"rootId":null,"fromId":21267,"content":"最好别去，股权变更很频繁，说不定哪天就跑路。而且天天改需求，需求很不明确，前期改完需求着急上线完事上线期间又变，跟闹着玩一样，加班更不用说，只要需求变动就得通宵加通宵改。屋子不大，能想到大晚上不睡觉一屋子嗷嗷乱叫的场景吗，跟守灵一样。","createdAt":"2025-05-08T10:18:23"},{"id":"0196d279-b0cf-7191-9375-fa5758905b4f","parentId":null,"rootId":null,"fromId":24161,"content":"如果不怕加班的可以去。现在是只有晚上10点以后可以上线。不相关的人 也必须得等着。主要是加班就加班了没有调休，如果加班晚了让你第二天晚来一会，如果通宵了就第二天不用来了。主要是上线也不是单纯的都开发完了上线，有时候一堆bug呢，测试没完成呢。得先等着测试测试完成才上线。所以基本上加班就要到很晚。大点的需求基本要通宵。说的是1，2，3上线，但是那领导没事就给你整个今天必上。技术的领导不知道 是有亲戚还是自己家买卖或者说 承诺了什么，反正这种的 如果有其他选择最好选择其他的。如果没什么选择了可以试试。主要就是加班，不加班的话就开会。6点下班 但是6点你甭想走。最早的话得7点","createdAt":"2025-05-15T13:45:12"},{"id":"0196d280-7a53-73a7-9770-7d115fd7103f","parentId":null,"rootId":null,"fromId":6091,"content":"钱多不","createdAt":"2025-05-15T13:52:37"},{"id":"0196d286-9b42-700b-bf55-7333288ae32c","parentId":null,"rootId":null,"fromId":24161,"content":"而且周末不可能闲着的，得有人值班，而且新人刚去1周，2周的业务还没熟悉呢，你就得开始值班了。如果仅仅是回答问题就罢了，他会让你看代码改代码，回头群里甩张图片就会让你查问题你甚至都不直达这张图片是干嘛的前因后果也不知道。当然这也有可能是我的问题，业务熟悉的太慢流程熟悉的太慢。但是 咱就是说 再厉害的大牛 你技术可能很厉害 但是业务熟悉也得需要时间啊。如果你觉得你去个个把月就能把一个公司的业务熟悉的很透彻的话 是可以去的。如果说查问题是上班时间的话 这可能是一个熟悉业务的过程。但要注意 这是周末。可能很简单的一个问题要浪费你半天时间。甚至还不知道。你又不能抓住个人就问，人家都休息呢，你问人家也不回啊。（举个例子，有一次查问题，因为是分为不同的组，先是找的他们组，然后回头他们说是我们组过去的数据有问题，然后我问是通过什么方式过去的数据，的对应的哪个字段。他就说就是你们组里过来的数据，我说我知道我们组，我说什么方式 消息还是接口还是什么，他说消息，我说你们接受的哪个消息什么字段他说反正你们组过来的。当时我刚去不久大概2周内。我当时就想骂他）","createdAt":"2025-05-15T13:59:19"},{"id":"0196d287-f456-71c1-81a6-2a3717cdd550","parentId":null,"rootId":null,"fromId":24161,"content":"还行 不多 但是我个人感觉正常水平吧 反正后面我又找了工作比这个多点 也没多哪去","createdAt":"2025-05-15T14:00:47"},{"id":"019710a7-dbdc-70b6-95e9-4bd1e26d93ca","parentId":null,"rootId":null,"fromId":7491,"content":"垃圾，别去","createdAt":"2025-05-27T15:32:05"},{"id":"0197532f-bc2a-73c3-8c77-b398fe9b5a69","parentId":null,"rootId":null,"fromId":24895,"content":"天天加班，一周发4次版，通宵发版很常见。周六周天值班，只要群里发问题，就得马上回复处理问题。领导管理混乱，3天的活让你1天干完，必须上线。\n人员变动大，留不住人。","createdAt":"2025-06-09T13:35:26"},{"id":"01976d9f-b3fa-70f6-9216-1bb7c2d05510","parentId":null,"rootId":null,"fromId":24161,"content":"太对了 我就只干了 几周，几天就溜了。真坑啊，能溜快溜吧。早走早解脱","createdAt":"2025-06-14T16:47:52"},{"id":"0197d4d0-7546-7134-af36-d8fb6c61ace3","parentId":null,"rootId":null,"fromId":25133,"content":"公司产研负责人 技术出身的一个胖儿,无管理经验,小作坊式管理,管理混乱,只要听话被甘愿压榨就行,下班就开会,所有人全不能走,不参会的人也要陪伴,中途会出来几趟专门看谁走了,全拿小本本记着你,每周得有3天上线,看心情随时加班上线,无规划计划,上线当晚12点前走不了,要求全员陪伴,能接受高压的可以去,几天的工作量会要求你一天干完,每天都是催催催,周末还要值班处理线上问题,加班无调休,无偿加班","createdAt":"2025-07-04T17:42:00"},{"id":"0197e7cf-4ce7-7369-aa8f-347220dd4bfa","parentId":null,"rootId":null,"fromId":7491,"content":"最恶心的是傻逼老板整天监控里面看你干啥，偷窥你的隐私，控制欲变态","createdAt":"2025-07-08T10:13:32"},{"id":"0197ecc6-0c1a-70b5-b7df-bdb6203b6405","parentId":null,"rootId":null,"fromId":25133,"content":"真的吗 你咋发现的?一群神经病啊","createdAt":"2025-07-09T09:21:31"},{"id":"0198318f-2457-7242-94ec-1157502ee76b","parentId":null,"rootId":null,"fromId":25964,"content":"胖子能力也不行，他就是不想回去  天天宿舍面对老板，家装在公司加班，其实都在刷视频，然后自己回不去 也不想让其他人回去，所以就耗着大家 让大家加班","createdAt":"2025-07-22T17:55:21"},{"id":"01983190-2f86-71ec-b7ec-4cfe6c662670","parentId":null,"rootId":null,"fromId":25964,"content":"这么多年来遇到的最没品的一家公司，上梁不正下梁歪，天天还在外面吹牛逼，说济南人工便宜，让加班就加班 听话   很垃圾","createdAt":"2025-07-22T17:56:29"},{"id":"019834bf-a54e-7370-8b31-680861b4ddcd","parentId":null,"rootId":null,"fromId":21302,"content":"难道你们入职的时候没被要征信吗？我看没有一个人提这件事","createdAt":"2025-07-23T08:47:11"},{"id":"019835e5-a9a0-72ba-ad29-e95a869bfbad","parentId":null,"rootId":null,"fromId":25133,"content":"入职还要征信??啥岗位啊","createdAt":"2025-07-23T14:08:20"},{"id":"019835e9-f2c3-70c5-aebd-9ac9b9aabca4","parentId":null,"rootId":null,"fromId":25133,"content":"通透,不听话就把你搞走","createdAt":"2025-07-23T14:13:01"},{"id":"01983634-7b15-7142-be57-61e4b1429daf","parentId":null,"rootId":null,"fromId":21302,"content":"java","createdAt":"2025-07-23T15:34:25"},{"id":"01983af4-6ca3-7021-89fe-ec1e9963a190","parentId":null,"rootId":null,"fromId":25133,"content":"离谱啊干java要啥征信啊","createdAt":"2025-07-24T13:42:33"},{"id":"0198ad7a-576f-70d2-8a77-9ab2778207cb","parentId":null,"rootId":null,"fromId":6802,"content":"在Java行业中，独领风骚，敢说第二，就没人敢说第一，天天开会、上线是基操，要命不要去，不要命的可以考虑","createdAt":"2025-08-15T19:25:32"},{"id":"0198c0cd-4551-72a3-a038-ed13585876e5","parentId":null,"rootId":null,"fromId":22250,"content":"是老丝儿，不是老师儿。不要去，就看着它，让它倒闭就行了。","createdAt":"2025-08-19T13:28:54"},{"id":"0198cb34-a2b8-7071-a2d9-bd8d07126083","parentId":null,"rootId":null,"fromId":21302,"content":"有没有可能你那个si本来该读shi","createdAt":"2025-08-21T13:58:01"},{"id":"0198cc08-7347-707f-851d-497df9c4984e","parentId":null,"rootId":null,"fromId":22250,"content":"你是对的。但口语上丝（si）一般都会读shi儿","createdAt":"2025-08-21T17:49:22"},{"id":"019928de-b066-73b5-8e84-8d30cc0755ba","parentId":null,"rootId":null,"fromId":22927,"content":"周一下班开会\n周二下班发版\n周三下班开会\n周四下班开会加发版\n周五下班看心情开会","createdAt":"2025-09-08T18:28:26"},{"id":"0199380a-bb5d-7255-8d20-59a7bd6de8ff","parentId":null,"rootId":null,"fromId":6802,"content":"技术纯纯的毫无规划，想一出是一出，出现问题立马甩锅，没有排期，没有设计，有问题就是开发人员不行，脑瓜子不知道咋想的，没事就给你喂饼吃，恨不得吃喝拉撒睡都工位","createdAt":"2025-09-11T17:10:51"},{"id":"01994ca6-cec1-724b-9125-e872499efd41","parentId":null,"rootId":null,"fromId":24161,"content":"快溜吧，","createdAt":"2025-09-15T17:13:44"},{"id":"01994ca7-b8ea-714d-9a88-f390fe537505","parentId":null,"rootId":null,"fromId":24161,"content":"主要是 有人真信 那领导花的饼啊 。我真服了","createdAt":"2025-09-15T17:14:44"},{"id":"01994cf8-0ccb-737b-a157-408e9755e86f","parentId":null,"rootId":null,"fromId":24161,"content":"就这样的 还需要被搞走吗 有好的机会 就抓紧走得了，没好机会 就摸摸鱼，躺平就好。这种公司不值得留恋","createdAt":"2025-09-15T18:42:28"},{"id":"0199515d-2f1e-7318-bbe5-798313c8c14f","parentId":null,"rootId":null,"fromId":6802,"content":"带馅的，好吃呗","createdAt":"2025-09-16T15:11:25"},{"id":"01995b6d-5898-73fb-b630-491766ec5297","parentId":null,"rootId":null,"fromId":7491,"content":"只能说一群sb 干不是人干的事呗","createdAt":"2025-09-18T14:05:16"},{"id":"0199988b-1cdc-735b-94a9-bc046b470264","parentId":null,"rootId":null,"fromId":24161,"content":"现在这公司怎么样了啊，还是一团乱麻吗","createdAt":"2025-09-30T10:54:37"},{"id":"019a6dc2-7da5-73d0-8552-b910c7d5646e","parentId":null,"rootId":null,"fromId":22927,"content":"面试记得问一下是面研发一组还是研发二组，一组不要去，二组放心去","createdAt":"2025-11-10T20:34:14"},{"id":"019a705f-f4f7-707a-bc36-e439040858a5","parentId":null,"rootId":null,"fromId":22250,"content":"哪个组都一个吊样，一丘之貉","createdAt":"2025-11-11T08:45:28"},{"id":"019a77d1-4d14-731c-91fc-5049345cae15","parentId":null,"rootId":null,"fromId":24161,"content":"哪个组都一样。1组上线 2组 还能下班不成，1组和2组领导长啥样啊。描述一下形态","createdAt":"2025-11-12T19:26:36"},{"id":"019a77d3-c9ef-7162-911e-32645f0c257e","parentId":null,"rootId":null,"fromId":24161,"content":"管理混乱。可以说是毫无管理 。自上而下的 不会管理。","createdAt":"2025-11-12T19:29:19"},{"id":"019a96b5-6197-708d-acfc-3836d3929dd7","parentId":null,"rootId":null,"fromId":22927,"content":"分开的，各管各的，一组那领导二比，没活也让你呆在公司呆着，二组领导看你没活让你早点走","createdAt":"2025-11-18T19:24:20"}]