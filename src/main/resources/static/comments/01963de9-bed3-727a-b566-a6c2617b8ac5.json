[{"id":"01963de9-bf36-732f-9722-dfe8f2347186","parentId":null,"rootId":null,"fromId":875,"content":"说真的，硕士211来济南真是浪费，还是fpga,c++，刚毕业也就一万二三样子","createdAt":"2023-11-18T23:19:17"},{"id":"01963de9-bf7a-720f-9fd8-89cd2c527b11","parentId":null,"rootId":null,"fromId":5913,"content":"唉，济南好多公司都进不去","createdAt":"2023-11-19T10:57:44"},{"id":"01963de9-bf7f-71f3-b1fd-4e8d4eb86d0f","parentId":null,"rootId":null,"fromId":5792,"content":"济南嵌入式不强，IT产值主要是服务外包撑起来的，你要是去青岛可能性大点，那边家电企业多，南方给的更多，济南说是布局电子信息，多少年能结果都不好说","createdAt":"2023-11-21T14:21:13"},{"id":"01963de9-bfc4-711d-bbee-66454e2b771c","parentId":null,"rootId":null,"fromId":5792,"content":"济南和青岛虽然IT产值一个第八，一个第九，但是领域是完全反着的，济南主要收入是服务外包，青岛主要是嵌入式，工资来说青岛稍微高点，但是青岛的房价确实贵不少，看你安排了","createdAt":"2023-11-21T14:26:23"},{"id":"01963de9-bfc9-73d9-9e71-aecb0b4c602b","parentId":null,"rootId":null,"fromId":5913,"content":"c++是软件图像那一块的嵌入式我不会?","createdAt":"2023-11-21T20:42:24"},{"id":"01963de9-bfce-7101-a132-9735bbed10a8","parentId":null,"rootId":null,"fromId":5913,"content":"去年就听说这事了，也没看着招电子信息的公司变多?","createdAt":"2023-11-21T20:43:06"},{"id":"01963de9-bfd2-720b-a053-317e355f5bdb","parentId":null,"rootId":null,"fromId":59,"content":"来济南真瞎了；去外面闯闯吧","createdAt":"2023-11-29T10:09:02"}]