[{"id":"01963ded-fa29-70af-b2fd-43a1d7d62172","parentId":null,"rootId":null,"fromId":3892,"content":"外包HR说是大学结尾的，学院结尾的不可以","createdAt":"2024-04-18T10:53:53"},{"id":"01963ded-fa72-7366-800f-09c1d9ae531b","parentId":null,"rootId":null,"fromId":6939,"content":"外包没这么高吧，前段时间是统本。","createdAt":"2024-04-18T10:59:34"},{"id":"01963ded-fab5-7068-8c07-2f690d5bad40","parentId":null,"rootId":null,"fromId":7083,"content":"我之前看群里说的是学校是XX大学结尾，计算机专业就行","createdAt":"2024-04-18T16:44:38"},{"id":"01963ded-fafa-73b8-b411-cb32f62499e7","parentId":null,"rootId":null,"fromId":6436,"content":"是的，必须大学结尾，外包也是这要求","createdAt":"2024-04-18T17:07:29"},{"id":"01963ded-faff-72de-a969-ea825a56d91d","parentId":null,"rootId":null,"fromId":7201,"content":"这么吓人？！还想毕业回济南工作呢，这不凉了","createdAt":"2024-04-18T20:01:41"},{"id":"01963ded-fb44-7117-9e5d-7bf7974751c2","parentId":null,"rootId":null,"fromId":403,"content":"据说麻省理工学院毕业生，看了城商行外包的招聘都瑟瑟发抖。","createdAt":"2024-04-22T10:07:35"},{"id":"01963ded-fb87-71b6-a613-571d2f9de779","parentId":null,"rootId":null,"fromId":7425,"content":"哈哈，麻省理工学院的来直接被HR拒了，臭学院的来济南要饭来了？看统招还说得过去，看名字真的离谱，不知道哪个大聪明想出来的，估计是一点见识没有","createdAt":"2024-07-11T20:28:05"},{"id":"01963ded-fb8b-7341-8e8d-d9eab6af6bc8","parentId":null,"rootId":null,"fromId":4174,"content":"说明不缺面试的人","createdAt":"2024-07-12T09:35:25"},{"id":"01963ded-fb90-71eb-ab0c-f89a36b4a2b9","parentId":null,"rootId":null,"fromId":6517,"content":"不会吧，年初我投外包简历 学院还行的。妈的，我都不敢不换工作了","createdAt":"2024-07-12T09:38:49"},{"id":"01963ded-fbd3-73fd-8c4c-a998802caf9d","parentId":null,"rootId":null,"fromId":3892,"content":"不是吧，我去年下半年投城商行外包，二本学院，外包公司HR都不搭理我，在我追问下说不要学院结尾的","createdAt":"2024-07-12T09:55:48"}]