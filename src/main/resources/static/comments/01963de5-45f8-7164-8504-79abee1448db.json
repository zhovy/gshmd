[{"id":"01963de5-4674-73df-be4e-853edfa91d4a","parentId":null,"rootId":null,"fromId":2935,"content":"好险。。差点入坑，面试的时候吹的老牛逼了，什么孵化模式，简单来说就是PPT造车的概念，做出来一个，有人投资就继续做，没人投资就继续做下一个，我当时就问，你们都不深入业务现场，就拍脑子琢磨着做，怎么能保证做出来的东西贴合业务场景呢，HR给我说确实是存在这种问题。。。。无语","createdAt":"2023-07-21T20:42:53"},{"id":"01963de5-46ba-737a-bcfc-0acdc6c47fe9","parentId":null,"rootId":null,"fromId":4149,"content":"我去面试的地点在万科中心五楼","createdAt":"2023-07-24T16:37:36"},{"id":"01963de5-4702-7337-827d-0d7dd722c199","parentId":null,"rootId":null,"fromId":3572,"content":"这家公司现在还拖欠工资？","createdAt":"2023-08-03T14:53:26"},{"id":"01963de5-474a-72e5-888c-d38510784684","parentId":null,"rootId":null,"fromId":4271,"content":"刚面试完，有没有在里边的同志说一下现在的情况，拖欠薪资吗，在网上了解了半天没搞懂这家是咋盈利的。","createdAt":"2023-08-03T16:21:00"},{"id":"01963de5-4793-73d6-8053-a882555e711a","parentId":null,"rootId":null,"fromId":2784,"content":"确实如此","createdAt":"2023-08-11T11:56:31"},{"id":"01963de5-47d9-73d5-9498-932986bff842","parentId":null,"rootId":null,"fromId":544,"content":"那俩人咋样了，有没有人讲讲？","createdAt":"2023-08-18T16:39:58"},{"id":"01963de5-481c-72f8-add2-680f915681d7","parentId":null,"rootId":null,"fromId":2784,"content":"哪两个","createdAt":"2023-08-18T20:37:03"},{"id":"01963de5-46fe-71dc-8977-7ec0370b7cbc","parentId":null,"rootId":null,"fromId":2784,"content":"搬了","createdAt":"2023-08-18T20:37:20"},{"id":"01963de5-4825-7190-ac49-4e439c4a463f","parentId":null,"rootId":null,"fromId":3905,"content":"承诺上周（八月14-18）给发五月份的工资，没动静，准备仲裁了","createdAt":"2023-08-21T09:38:17"},{"id":"01963de5-488e-7205-bbfe-93097d4304f1","parentId":null,"rootId":null,"fromId":3859,"content":"请问现在还拖欠工资吗？","createdAt":"2023-08-21T16:15:24"},{"id":"01963de5-4821-7247-85ac-cb6d09becc3e","parentId":null,"rootId":null,"fromId":922,"content":"细说","createdAt":"2023-08-22T09:47:45"},{"id":"01963de5-48ef-727d-aafe-ead265e12085","parentId":null,"rootId":null,"fromId":3905,"content":"《只拖不欠》","createdAt":"2023-08-24T14:45:50"},{"id":"01963de5-48f4-7182-8a2d-307c56373fc5","parentId":null,"rootId":null,