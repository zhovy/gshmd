[{"id":"01963ddc-e762-7292-889c-4b9afee4c8a9","parentId":null,"rootId":null,"fromId":1930,"content":"以我作为乙方多年的经验。\n奉劝大家，公司名字叫X氏公司（集团）的，或者叫XX伟业的，老板的名字和姓氏做公司名的，千万别去。","createdAt":"2022-10-12T10:11:15"},{"id":"01963ddc-e7a6-7354-9e2e-b1aaf77c04a5","parentId":null,"rootId":null,"fromId":1687,"content":"扁鹊中医药吧，哈哈哈哈，都是坑","createdAt":"2022-10-12T15:09:07"},{"id":"01963ddc-e7e9-7218-b754-ea685ad6dbde","parentId":null,"rootId":null,"fromId":1774,"content":"之前去聊过，绿地的那个办公地点。\n进去一看就是一群销售，还给自己美化，说什么战略、文化。实际工资很低，就是做销售，自己找客户，公司提点。\n据说这个公司还是菏泽-单县的重点企业，未来上市扶持企业，无语了","createdAt":"2022-10-13T16:29:48"},{"id":"01963ddc-e82c-732c-b1a4-615bb8292e4f","parentId":null,"rootId":null,"fromId":880,"content":"哈哈哈哈哈哈哈哈哈哈或   “猪福”哈哈哈哈哈笑死我了","createdAt":"2022-10-13T18:51:50"},{"id":"01963ddc-e870-719c-a017-4b5c42e4e31f","parentId":null,"rootId":null,"fromId":2134,"content":"这个公司，之前听人说每天会跳抓钱舞的，对就是保险公司每天跳的那种","createdAt":"2022-11-02T21:37:57"},{"id":"01963ddc-e8b3-73ba-9cda-ae9a4ad90703","parentId":null,"rootId":null,"fromId":1727,"content":"这个公司上市估计很难，账务上估计不过关","createdAt":"2023-02-26T13:57:17"},{"id":"01963ddc-e8fa-7254-823e-dfb88f833abd","parentId":null,"rootId":null,"fromId":3128,"content":"哈哈哈哈这个公司我是久闻大名","createdAt":"2023-03-29T15:29:06"},{"id":"01963ddc-e941-7275-81c8-c98fb980defe","parentId":null,"rootId":null,"fromId":6090,"content":"慎重啊","createdAt":"2023-11-09T15:38:25"}]