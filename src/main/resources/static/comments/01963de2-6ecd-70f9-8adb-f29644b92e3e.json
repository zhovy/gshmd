[{"id":"01963de2-6f38-7356-8a9b-7a7219dc946f","parentId":null,"rootId":null,"fromId":1391,"content":"问清楚是不是鲁软的外包公司","createdAt":"2023-05-15T15:18:34"},{"id":"01963de2-6f83-7375-bdbb-6410c6e67278","parentId":null,"rootId":null,"fromId":875,"content":"主要做电力行业的科技项目，以火电为主，好像有中碳能投的几个人和以前在华电干过的几个人，弄了个小公司，是不是外包不好判断，反正不是做产品的公司。济南嘛，就是国企有钱花不出去，然后扔给一堆小公司弄几个科技项目做做，顺便给国企体制内的主任评个职称","createdAt":"2023-05-15T19:05:28"},{"id":"01963de2-6f7e-730d-9d98-c72d7d6b28f8","parentId":null,"rootId":null,"fromId":2680,"content":"好像是鲁软外包","createdAt":"2023-05-28T17:20:40"},{"id":"01963de2-7033-71f4-91ae-115943051e74","parentId":null,"rootId":null,"fromId":22449,"content":"看最近又在招人了  问hr 说不是外包。。","createdAt":"2025-02-26T09:10:21"},{"id":"01979be2-23bc-70b7-8ba8-3bf7f92eb3b1","parentId":null,"rootId":null,"fromId":25318,"content":"你投什么岗","createdAt":"2025-06-23T16:22:58"}]