[{"id":"019aa974-d3f3-71ee-bf62-254fa5d1198e","parentId":null,"rootId":null,"fromId":2921,"content":"请辞职回家躺平。反正出去也找不到，为什么要付费打工？","createdAt":"2025-11-22T10:46:37"},{"id":"019aab03-a1bd-708f-8132-d8c78ccf8a2f","parentId":null,"rootId":null,"fromId":875,"content":"超意兴真强，分店开到老家了，准备回家租个门脸，干超意兴分店，当店长，4块钱一个菜，在老家很有市场","createdAt":"2025-11-22T18:02:13"},{"id":"019aab0a-416a-7215-8621-e03ea6279f84","parentId":null,"rootId":null,"fromId":1703,"content":"彼此彼此","createdAt":"2025-11-22T18:09:27"},{"id":"019aad9f-a012-7131-a101-2bbd78a24e85","parentId":null,"rootId":null,"fromId":23223,"content":"正常。大内卷环境下，秩序崩坏，弱肉强食，最后谁也赚不到钱。还是人太多，工贼太多","createdAt":"2025-11-23T06:11:50"},{"id":"019ab046-00c5-73fe-a0c2-68b050f9293d","parentId":null,"rootId":null,"fromId":2115,"content":"公司名字发下","createdAt":"2025-11-23T18:32:49"},{"id":"019ab3bf-6471-7309-a55e-d0f3df36f79a","parentId":null,"rootId":null,"fromId":27881,"content":"现在跑外卖都没多少单了，说明工作的人越来越少，点的外卖越来越少，再就是，外卖就业人员越来越多，匀到每个人的单子肯定越来越少。降薪就降薪吧，别裸辞，要不然两三个月都没收入，太难了。","createdAt":"2025-11-24T10:44:16"},{"id":"019ab3c0-7c37-7142-83cc-9d57d474bc11","parentId":null,"rootId":null,"fromId":27881,"content":"我前公司让员工众筹，一人三万块钱，然后坚持到现在，上个月还去爬齐长城团建了，说的盈利了。","createdAt":"2025-11-24T10:45:27"},{"id":"019ab3c0-ca3d-733f-8be4-ab2c0af8fd19","parentId":null,"rootId":null,"fromId":27881,"content":"不能返乡滞乡，哈哈，讽刺不？","createdAt":"2025-11-24T10:45:47"},{"id":"019ab46d-7c49-70ad-9d47-01adc15d795f","parentId":null,"rootId":null,"fromId":2330,"content":"新里程","createdAt":"2025-11-24T13:54:25"},{"id":"019ab4ab-81e2-72bf-be08-95a64c60fb60","parentId":null,"rootId":null,"fromId":267,"content":"是海信贤文那个吗","createdAt":"2025-11-24T15:02:10"},{"id":"019adced-a803-71b6-9e3e-8de9004f0b29","parentId":null,"rootId":null,"fromId":21742,"content":"同事问领导要工资，领导说你先办个信用卡顶顶","createdAt":"2025-12-02T10:39:13"}]