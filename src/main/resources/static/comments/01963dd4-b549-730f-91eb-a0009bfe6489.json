[{"id":"01963dd4-b5c7-72d3-8eb4-930b8d7f2af8","parentId":null,"rootId":null,"fromId":158,"content":"当时我去面试的时候这个公司急招人，面完之后刚到家就给我打电话 让我第二天过去，我说不去了，hr就各种嘲讽","createdAt":"2022-03-24T16:58:53"},{"id":"01963dd4-b60a-7063-a275-639c57b5b026","parentId":null,"rootId":null,"fromId":173,"content":"强制加班","createdAt":"2022-03-26T14:19:02"},{"id":"01963dd4-b64f-705f-8d10-b0baf0d56626","parentId":null,"rootId":null,"fromId":353,"content":"HR就像战斗民族，逮谁干谁","createdAt":"2022-05-13T15:34:28"},{"id":"01963dd4-b693-73ff-a113-8f29e5c774f6","parentId":null,"rootId":null,"fromId":789,"content":"就是闪创教育，很恶心的公司，用个人号拉群卖课，让学生贷款买课，6点下班，人事加班到7点甚至是8点，为了kpi人头，邀约面试还要有流程，也不知道所谓的人事总监脑子里是浆糊吗","createdAt":"2022-06-20T21:57:58"},{"id":"01963dd4-b6d8-7100-a45a-843e0a77a470","parentId":null,"rootId":null,"fromId":789,"content":"接上条，如果不去面试，面试不入职，背后就各种骂你，这个公司没门槛，是个人就要，人事小组长中专学历就能干，不是歧视学历，是特么没能力，靠入职时间长混上去的","createdAt":"2022-06-20T21:59:58"},{"id":"01963dd4-b71e-7017-9c1a-46ccb9306cf3","parentId":null,"rootId":null,"fromId":3749,"content":"加班严重，20多人的技术团队，搞得只剩5-6个，还美其名曰人才多功能使用","createdAt":"2024-02-29T13:46:28"},{"id":"01963dd4-b762-718c-be31-fc238a472850","parentId":null,"rootId":null,"fromId":3705,"content":"因为你不去影响到 HR 的 KPI 了，找你出出气 哈哈","createdAt":"2024-02-29T13:54:13"}]