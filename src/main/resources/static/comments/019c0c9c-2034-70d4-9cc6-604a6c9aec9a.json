[{"id":"019c0caa-6824-7269-a816-fd3a05d9fa82","parentId":null,"rootId":null,"fromId":27856,"content":"这种好多叫什么寓的 大部分都是二房东吧 都团伙  直接安居客筛选个人房东的","createdAt":"2026-01-30T10:10:20"},{"id":"019c0cae-5dfa-7045-97b6-934022065969","parentId":null,"rootId":null,"fromId":926,"content":"我知道，我已经合同到期退租了，我需要他们把租金给我","createdAt":"2026-01-30T10:14:39"},{"id":"019c0cc8-f75b-73a8-8a37-cac64d607c80","parentId":null,"rootId":null,"fromId":22809,"content":"没用","createdAt":"2026-01-30T10:43:43"},{"id":"019c0ccd-5a61-7073-a4b4-aa4b577dc64c","parentId":null,"rootId":null,"fromId":5725,"content":"消防举报","createdAt":"2026-01-30T10:48:30"},{"id":"019c0cd1-138f-71ae-b7d6-f43cf3733e9c","parentId":null,"rootId":null,"fromId":926,"content":"钱可以不要，但是气必须要撒出来，我气不顺，他们也别想好过","createdAt":"2026-01-30T10:52:34"},{"id":"019c0cda-8100-730b-87c2-d0c0d534e653","parentId":null,"rootId":null,"fromId":22452,"content":"济南很多房产中介都是这个套路,房子不到期退租押金不退，大部分租给刚毕业大学生,或刚参加工作的，一个房子三个月换三人都有(押一付三,工作变动，钱不退，继续租给其他人)，他们挣的就是那个钱，普通人打官司起诉，他们又有合同,除非找律师,律师又是吃完原告吃被告，所以在社会上立足尽量自己睁大眼睛(唯一能帮到你的话),到处是人生老师(法家锁喉，儒家攻心,唯有自立)","createdAt":"2026-01-30T11:02:52"},{"id":"019c0d09-32d0-72ab-8699-719d5599f9c3","parentId":null,"rootId":null,"fromId":22702,"content":"看看是不是隔断房，举报，然后找朋友故意去那边租房子，多看几个，记好房间号，最后一个一个举报就行，要是有人联系你，你就说是寓来寓美让你这么做的，记住不要泄露身份证等个人信息，可是提前办个手机号，用完这段时间就注销就行了，你打官司一点用没有，他们还求你打官司呢，没用的。主要是济南不管他们。你得想些有效果的办法。","createdAt":"2026-01-30T11:53:52"},{"id":"019c0d8e-2f95-737f-9940-f4d51882dd37","parentId":null,"rootId":null,"fromId":926,"content":"现在那边的网格员介入了，给网格员承诺一周内退还，如果还不退的话，我就这样搞他们","createdAt":"2026-01-30T14:19:08"},{"id":"019c14c4-aeaa-70db-b2d9-099691a5a727","parentId":null,"rootId":null,"fromId":25953,"content":"没啥好办法，因为你不管怎么投诉，流程最后都会由街道来处理，后面的我就不说了，，，，，自己意会吧","createdAt":"2026-01-31T23:56:00"},{"id":"019c1527-1292-7204-8e5e-4a3e420221a2","parentId":null,"rootId":null,"fromId":267,"content":"不会退","createdAt":"2026-02-01T01:43:28"}]