[{"id":"019898d9-c403-7022-adf1-71537e0f6c9b","parentId":null,"rootId":null,"fromId":22024,"content":"UY125","createdAt":"2025-08-11T19:17:45"},{"id":"01989bbe-b183-7094-9f6c-3d09770a060e","parentId":null,"rootId":null,"fromId":1003,"content":"AFR125","createdAt":"2025-08-12T08:47:02"},{"id":"01989bc6-5c20-7335-aa37-8c4a8a187e31","parentId":null,"rootId":null,"fromId":770,"content":"直接上150 现在125和150价格差不了多少了，豪爵uhr150, 五羊本田的150","createdAt":"2025-08-12T08:55:24"},{"id":"01989bc9-a93d-7279-8fb6-fce5894ccbc5","parentId":null,"rootId":null,"fromId":460,"content":"谢谢大家 都说豪爵的好呢？ 咋回事","createdAt":"2025-08-12T08:59:01"},{"id":"01989bcd-9334-7351-91e5-c725b52429bd","parentId":null,"rootId":null,"fromId":7707,"content":"有两辆踏板\nafr125还不错，骑了两年一点问题没出\n三阳飞度不大行，小毛病不断，半路撂挑子两次，但有前后abs稍安全点","createdAt":"2025-08-12T09:03:17"},{"id":"01989bd0-b0d8-73ee-bf31-c82344fd8c9d","parentId":null,"rootId":null,"fromId":460,"content":"好的 谢谢","createdAt":"2025-08-12T09:06:42"},{"id":"01989bd9-7647-73f2-a445-903eaaf38b8e","parentId":null,"rootId":null,"fromId":21512,"content":"gk1200","createdAt":"2025-08-12T09:16:16"},{"id":"01989be6-c68a-71c7-b105-652dd4054de1","parentId":null,"rootId":null,"fromId":5705,"content":"UY125便宜不容易坏配件也多，200以及以上排量的不要考虑，济南这破交通通勤速度很难起来，除非在偏僻地方","createdAt":"2025-08-12T09:30:49"},{"id":"01989c41-9aa5-70c3-9fae-848b1468ac2f","parentId":null,"rootId":null,"fromId":3968,"content":"买豪爵，你听我的","createdAt":"2025-08-12T11:10:01"},{"id":"01989c44-11b5-71f3-b6e2-82b375b5d022","parentId":null,"rootId":null,"fromId":460,"content":"身边大部分人 都这样说 看来豪爵有点东西","createdAt":"2025-08-12T11:12:43"},{"id":"01989c44-28e7-72be-a4bf-6dbe8737e26b","parentId":null,"rootId":null,"fromId":22702,"content":"相亲被嫌弃 骑踏板 直接买车吧","createdAt":"2025-08-12T11:12:49"},{"id":"01989c47-6645-7088-ad12-b3176fecd8b8","parentId":null,"rootId":null,"fromId":3968,"content":"我玩过好几辆车了，你当工具车用就买豪爵，其他车看都不用看，玩乐车另说","createdAt":"2025-08-12T11:16:21"},{"id":"01989c4e-86c6-706d-b471-215061d27898","parentId":null,"rootId":null,"fromId":460,"content":"好的 谢谢","createdAt":"2025-08-12T11:24:08"},{"id":"01989cd6-a34a-73a4-a05f-c82715940889","parentId":null,"rootId":null,"fromId":1039,"content":"楼上推荐的都可以买，但是我尤其推荐一点，选完车型买二手的，省很多钱，没啥差距，一般摩托店都卖二手，或者去工业北有专门的二手摩托","createdAt":"2025-08-12T13:52:48"},{"id":"01989cda-d6f2-73ad-9a43-4caa1523b352","parentId":null,"rootId":null,"fromId":21512,"content":"铃木的怎么样","createdAt":"2025-08-12T13:57:24"},{"id":"01989cdf-50f1-7120-ac6f-4a3ffd8ed05d","parentId":null,"rootId":null,"fromId":460,"content":"如果摩托车坏半路上，都是怎么拉到修理厂啊？","createdAt":"2025-08-12T14:02:17"},{"id":"01989d4d-6e1d-7094-bde2-bb7194177fdd","parentId":null,"rootId":null,"fromId":6747,"content":"踏板摩托车对比电动车有啥优势，除了续航","createdAt":"2025-08-12T16:02:34"},{"id":"01989d4e-40d0-7218-bfc9-9515c23d1d53","parentId":null,"rootId":null,"fromId":460,"content":"我认为这条就够了","createdAt":"2025-08-12T16:03:28"},{"id":"01989d87-c739-71cd-81e7-fa608a30e783","parentId":null,"rootId":null,"fromId":3968,"content":"铃木分两种，一种是合资一种是纯进口，济南铃木，也就是轻骑铃木前几年都快倒闭了，靠着铃木给的125超级芯盘活了，除了这款车也是扶不起的阿斗，豪爵铃木只有250跨骑也是一代神车了，都是返销日本的，从骑不坏的角度来看都没啥问题，进口就没啥必要买了，铃木进口都是跨骑太贵了不合适","createdAt":"2025-08-12T17:06:18"},{"id":"0198a0d5-1c3f-70bb-a63e-a1dc166cd2c5","parentId":null,"rootId":null,"fromId":25789,"content":"豪爵的adx hur ufr刚降价了","createdAt":"2025-08-13T08:29:37"},{"id":"0198a0d6-a524-7293-9664-25ec4dc4c595","parentId":null,"rootId":null,"fromId":460,"content":"你们都是全款买的吗？","createdAt":"2025-08-13T08:31:18"},{"id":"0198a0e1-35c0-711e-a442-c9123e765e94","parentId":null,"rootId":null,"fromId":5624,"content":"你也是人才，问出来这样的话？通勤摩托车有多贵，这些金额不全款，你为什么不做公交，骑电车呢？","createdAt":"2025-08-13T08:42:50"},{"id":"0198a0e4-2a7f-73ab-a849-f100ec22dcaf","parentId":null,"rootId":null,"fromId":460,"content":"哈哈哈哈哈哈  多贵啊  将近1万块钱呢","createdAt":"2025-08-13T08:46:04"},{"id":"0198a281-24f9-7101-9612-c046d08d3409","parentId":null,"rootId":null,"fromId":6517,"content":"刚买了个幼兽，骑着玩的，喜欢复古弯梁","createdAt":"2025-08-13T16:17:09"},{"id":"0198bc7d-4af0-7010-abbc-a169100761ab","parentId":null,"rootId":null,"fromId":22576,"content":"三阳飞度4，5，除了双通道ABS这一点优点以外，动力还不错，125的功率能媲美一些150的功率了。\n缺点的话，车重，骑起来车把不稳，油耗高，进气口低导致空气滤芯换得勤。","createdAt":"2025-08-18T17:23:04"}]