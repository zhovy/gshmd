[{"id":"01963dda-214a-71f1-8c36-4176a800e3e3","parentId":null,"rootId":null,"fromId":193,"content":"1","createdAt":"2022-06-20T19:44:33"},{"id":"01963dda-2190-727b-a3f1-775a83c7ca1d","parentId":null,"rootId":null,"fromId":771,"content":"系统集成？","createdAt":"2022-06-21T08:51:41"},{"id":"01963dda-21d5-7096-b152-3c57d6d9613f","parentId":null,"rootId":null,"fromId":195,"content":"你查清楚签合同是外包第三方协议,还是啥,电信基本只校招的,社招一般是领导关系户,","createdAt":"2022-06-21T08:56:09"},{"id":"01963dda-221b-7213-bba7-372e62a2f4a3","parentId":null,"rootId":null,"fromId":739,"content":"之前在中国电信做项目外包的时候，人家内部人员说过只要校招的研究生毕业的，自己掂量一下就知道了","createdAt":"2022-06-21T09:04:07"},{"id":"01963dda-2261-7121-8786-12b4c5371d24","parentId":null,"rootId":null,"fromId":273,"content":"搞笑呢，之前面试过，面试完了我问是和电信签合同吗，人家回答不是，是自己的子公司，待遇一样，我信你个鬼啊，就是他自己弄得一个外包子公司，忽悠说一样的，实际上自己想吧","createdAt":"2022-06-21T11:12:15"},{"id":"01963dda-22b0-708f-8f44-241d08d9e1b1","parentId":null,"rootId":null,"fromId":203,"content":"我也去面试过，说是跟第三方公司签合同，实际就是外包","createdAt":"2022-06-21T12:09:02"},{"id":"01963dda-231a-7310-b05d-16c3de80cb02","parentId":null,"rootId":null,"fromId":203,"content":"以前叫系统集成，后来改名叫中电信数智了，合同跟第三方公司签，就是外包","createdAt":"2022-06-21T12:13:22"},{"id":"01963dda-2362-72b9-bca8-f3d3c5d32e9f","parentId":null,"rootId":null,"fromId":783,"content":"在舜泰广场和逸家大厦都有办公地点，项目简单，技术要求不是太高，薪资也很低，签北京的一家三方合同","createdAt":"2022-06-22T09:05:13"},{"id":"01963dda-23a9-7393-bfd9-f751aff81188","parentId":null,"rootId":null,"fromId":2250,"content":"薪资很低，签的合同不是子公司，是三方的劳务公司。","createdAt":"2022-12-05T22:56:15"},{"id":"01963dda-23f4-73c9-9628-72813a8b30a5","parentId":null,"rootId":null,"fromId":3953,"content":"绩效全扣，变相裁员","createdAt":"2023-07-02T10:42:24"}]