[{"id":"0198f37b-5d44-7037-9c31-d8b169258ed2","parentId":null,"rootId":null,"fromId":460,"content":"至少得有个1千万吧  可别光考虑自己","createdAt":"2025-08-29T09:40:05"},{"id":"0198f37e-9584-7310-b138-27684d132f27","parentId":null,"rootId":null,"fromId":22702,"content":"其实现在就可以回老家 但是为啥都在城市苟着 不就是因为老家就业和薪资不行么 要不谁愿意出来 还背着房贷 就这样也得在公司苟着 因为苟着一个月一万多 但是在老家5000都不好找 更别说公司质量了","createdAt":"2025-08-29T09:43:36"},{"id":"0198f3aa-2b0b-72f5-add8-aa8d217e377b","parentId":null,"rootId":null,"fromId":2572,"content":"一个月一万多，不错了。很多都没有这个水平。","createdAt":"2025-08-29T10:31:12"},{"id":"0198f3b0-f129-7398-bae4-937a19afad29","parentId":null,"rootId":null,"fromId":1372,"content":"你若想时便是闲，\n回乡观阳也种田。\n问君浑身有多款？\n付那清茶二两钱。\n余年漫漫又多难，\n岂让我等闲又闲。\n少年勿灭凌云志，\n生死富贵全由天。","createdAt":"2025-08-29T10:38:36"},{"id":"0198f445-8ca0-7073-b829-43c6e8127148","parentId":null,"rootId":null,"fromId":22250,"content":"超过95%的人了，绝大部分人在五六千左右，甚至更低","createdAt":"2025-08-29T13:20:55"},{"id":"0198f4da-bea9-716e-91de-751efea4acf2","parentId":null,"rootId":null,"fromId":2246,"content":"现在种地的都还没饿死，你可以回去","createdAt":"2025-08-29T16:03:53"},{"id":"019907c5-818e-717c-b62a-85cd8f2e2885","parentId":null,"rootId":null,"fromId":2246,"content":"按你这说法，种地的都得身价千万","createdAt":"2025-09-02T08:13:28"},{"id":"019907d4-8862-737c-9911-b6f89158d06e","parentId":null,"rootId":null,"fromId":460,"content":"他说的是不工作 只种地。而且父母也不管了，结不结婚不清楚，如果有了孩子，还这样真是很不应该，很自私。","createdAt":"2025-09-02T08:29:53"},{"id":"01990d09-bbf3-7332-ad01-7f9205cb3b65","parentId":null,"rootId":null,"fromId":26104,"content":"现在只能在梦里实现","createdAt":"2025-09-03T08:46:05"}]