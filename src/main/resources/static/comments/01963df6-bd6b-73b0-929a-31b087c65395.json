[{"id":"01963df6-bddd-70b2-a46f-9720f406a786","parentId":null,"rootId":null,"fromId":1398,"content":"你浅谈一下那些公司要求全站?","createdAt":"2025-02-06T17:20:37"},{"id":"01963df6-be2f-725f-a509-19f2a22fff77","parentId":null,"rootId":null,"fromId":22539,"content":"合久必分，分久必合，很久之前没有前后端之分，这种形势下，全栈可能是趋势，后端不会点前端活不下去，。","createdAt":"2025-02-07T08:58:05"},{"id":"01963df6-be79-7350-89a9-9fadc4b5043c","parentId":null,"rootId":null,"fromId":6208,"content":"只能说叫全干吧 说是全栈对那个又能很熟悉呢 干后端前端没系统学过 简单写点页面还可以 再深一点都不太熟悉","createdAt":"2025-02-07T09:17:01"},{"id":"01963df6-be7d-7237-a161-5c8957613b29","parentId":null,"rootId":null,"fromId":21958,"content":"全栈就是个伪命题，中高层为什么不全沾，财务，人力，行政，销售，市场反正都是管理","createdAt":"2025-02-07T10:55:37"},{"id":"01963df6-bec1-72a4-b7cb-5c5b26eff482","parentId":null,"rootId":null,"fromId":875,"content":"全栈很难吗，大模型都会自己写","createdAt":"2025-02-07T19:28:42"},{"id":"01963df6-be26-73e8-849a-cfaf43e50c67","parentId":null,"rootId":null,"fromId":21742,"content":"挺多的 之前面试几家好像都要全站","createdAt":"2025-02-08T17:38:03"},{"id":"01963df6-be2b-7378-b954-2fae4c81c4dd","parentId":null,"rootId":null,"fromId":21742,"content":"名字记不住l","createdAt":"2025-02-08T17:38:09"},{"id":"01963df6-bf04-7160-8bea-52bb55ff7990","parentId":null,"rootId":null,"fromId":5755,"content":"真的很夸张，什么全栈侧重前端，全栈侧重后端的，想问他们的技术负责人都会嘛","createdAt":"2025-02-11T10:18:19"}]