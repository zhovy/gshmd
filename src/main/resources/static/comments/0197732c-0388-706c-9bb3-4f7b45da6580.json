[{"id":"019773b5-c800-7239-8b5c-5aa413e0d278","parentId":null,"rootId":null,"fromId":22186,"content":"刚毕业的时候都这样想，其实干几年才发现，单纯会技术没啥用，和人打交道才是真理，销售上限高，下限也低","createdAt":"2025-06-15T21:09:42"},{"id":"019773b8-2ae7-7373-9ba2-0c1d07fce1ea","parentId":null,"rootId":null,"fromId":6208,"content":"点了 在济南技术不是最重要了 大部分都是外包没有几个公司特别看重技术 能把软件卖出去 建立自己关系网才是最重要的","createdAt":"2025-06-15T21:12:18"},{"id":"0197762a-c294-7349-80b6-d2ef8be8eeaa","parentId":null,"rootId":null,"fromId":24615,"content":"销售才是王道，不要对它有什么误解","createdAt":"2025-06-16T08:36:43"},{"id":"01977634-cf58-71fc-928e-f9cddae3f602","parentId":null,"rootId":null,"fromId":22459,"content":"找工作又何尝不是在销售自己呢","createdAt":"2025-06-16T08:47:41"},{"id":"01977641-f183-7024-8c48-0280e25cd1f4","parentId":null,"rootId":null,"fromId":6091,"content":"真心觉得不要觉得销售低，就对销售这个工作有偏见，销售需要学习的东西不比程序员少","createdAt":"2025-06-16T09:02:02"},{"id":"01977642-30c2-720f-8256-4b93155756d4","parentId":null,"rootId":null,"fromId":6091,"content":"门槛低","createdAt":"2025-06-16T09:02:18"},{"id":"01977660-713e-7308-b4f0-a986ebf28161","parentId":null,"rootId":null,"fromId":228,"content":"精辟","createdAt":"2025-06-16T09:35:21"},{"id":"01977666-30d9-72c8-91a6-5c168ea16660","parentId":null,"rootId":null,"fromId":23684,"content":"还是干销售吧","createdAt":"2025-06-16T09:41:38"},{"id":"0197786d-929f-708a-aa44-a229533ddc05","parentId":null,"rootId":null,"fromId":59,"content":"能说会道，懂得人情世故，销售赚的不少","createdAt":"2025-06-16T19:08:56"},{"id":"019778d8-0aa6-73f5-8767-ab163e81d5eb","parentId":null,"rootId":null,"fromId":22186,"content":"补充一点，销售的主要能力，在于推销自己和维持客户关系的能力，而不是单纯的销售商品，能掌握这2种能力的销售才可以干，像电话销售什么的，无用还浪费时间","createdAt":"2025-06-16T21:05:13"},{"id":"01977d42-a0c4-72d9-a24f-1f12c778a615","parentId":null,"rootId":null,"fromId":25096,"content":"还是学个技术好，销售又累又卷，辞职了又没有别的可干的，还是有技术好找工作","createdAt":"2025-06-17T17:40:08"}]