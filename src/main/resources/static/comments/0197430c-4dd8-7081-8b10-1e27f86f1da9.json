[{"id":"0197430f-8e23-7085-a646-fa1b9578f027","parentId":null,"rootId":null,"fromId":3835,"content":"都3年经验了 还去培训啊","createdAt":"2025-06-06T10:26:22"},{"id":"01974313-73e1-70aa-8199-541e4f1588af","parentId":null,"rootId":null,"fromId":2256,"content":"环境一时半会好不了了，薪资放低要求先干着吧","createdAt":"2025-06-06T10:30:37"},{"id":"01974315-2939-72e4-90da-9cc12a3ff9af","parentId":null,"rootId":null,"fromId":1372,"content":"你都工作3年多了，培训机构的课程对你来说已经没用了。大环境不好，工作不好找不是个人问题，先平衡好心态。你可以边找工作边深入学习，包括前后端原理性的东西。","createdAt":"2025-06-06T10:32:29"},{"id":"01974315-3311-7224-9b7c-d3d14aff9c1b","parentId":null,"rootId":null,"fromId":2846,"content":"虽然三年经验，但是现在没工作天天躺着自律不起来，还是想看看报个班提高一下啥的。感觉会的也不多","createdAt":"2025-06-06T10:32:32"},{"id":"01974316-0097-7037-9c94-6677b0869e95","parentId":null,"rootId":null,"fromId":2846,"content":"我现在面试要薪资8-9是不是要高了？ 面试应该7-8的要嘛","createdAt":"2025-06-06T10:33:24"},{"id":"01974316-b7cd-72e2-9ba6-ca0f54a0e368","parentId":null,"rootId":null,"fromId":2846,"content":"有道理，原理性的东西现在确实不会。您觉得大数据hadoop一类的需要去学习一下吗","createdAt":"2025-06-06T10:34:11"},{"id":"01974319-021f-7062-9e25-87e42c2b0775","parentId":null,"rootId":null,"fromId":4016,"content":"网上任何资料都有，没有自学能力，不建议干这行","createdAt":"2025-06-06T10:36:41"},{"id":"0197431b-5f3e-70ab-80bf-4fecb65d41ab","parentId":null,"rootId":null,"fromId":2846,"content":"我没报过培训班，从毕业到现在所有东西都是自学的，只是现在有点焦虑学不进去了","createdAt":"2025-06-06T10:39:16"},{"id":"01974322-ba04-73aa-b88a-863e45020ad8","parentId":null,"rootId":null,"fromId":1372,"content":"有必要。你可以设置一个计划。常用的技术框架 spring 、mybatis 、spring cllou、jvm 等等的原理，一个一个学。无需特别精通，至少能知道个大概。学完后你的技术能更上一层楼。","createdAt":"2025-06-06T10:47:18"},{"id":"01974325-a178-709a-94dd-4abb77898527","parentId":null,"rootId":null,"fromId":2846,"content":"好的感谢","createdAt":"2025-06-06T10:50:29"},{"id":"01974328-b3b2-72bb-b5ae-3fec10345d2f","parentId":null,"rootId":null,"fromId":2256,"content":"我本来12k三月份离职的，一开始有10k的没去，现在6月份了我8k都找不着了，投简历没人回复","createdAt":"2025-06-06T10:53:50"},{"id":"0197432a-34eb-70be-81a4-a2bc5e5199aa","parentId":null,"rootId":null,"fromId":21796,"content":"不建议报培训班","createdAt":"2025-06-06T10:55:29"},{"id":"0197432b-af8f-737d-b53c-bc8a49f95439","parentId":null,"rootId":null,"fromId":2807,"content":"这两年的行情3年要9不会给你的，降低一点进个公司学习，自己在家学不下去在公司逼着就学了","createdAt":"2025-06-06T10:57:05"},{"id":"01974332-317b-7291-a35d-104c31898234","parentId":null,"rootId":null,"fromId":3835,"content":"咸鱼买个课程 自学就行了","createdAt":"2025-06-06T11:04:12"},{"id":"01974332-d277-7078-89f6-371e2de09907","parentId":null,"rootId":null,"fromId":1049,"content":"不要唯技术论，现在IT赚钱的时代已经过去了，技术再深年龄一大也完蛋","createdAt":"2025-06-06T11:04:53"},{"id":"01974339-22ac-717e-b974-174e19bd4d3d","parentId":null,"rootId":null,"fromId":2846,"content":"不唯技术论，出路又在哪里呢？和我一样的人估计不在少数，他们年龄大了又该咋办呢？难道年龄大了只能吉祥三保（保安 保姆 保洁）吗？ 发展副业也好、转型也好、换行业也好，不知道该咋办，难道这就是这个时代人的命吗？","createdAt":"2025-06-06T11:11:47"},{"id":"01974349-e155-7247-8af1-46b9beba2f9d","parentId":null,"rootId":null,"fromId":21796,"content":"每个人都是时代的洪流罢了","createdAt":"2025-06-06T11:30:04"},{"id":"01974405-5d86-7171-b5f1-a1277df349de","parentId":null,"rootId":null,"fromId":22186,"content":"你真以为你培训出来就能找着工作了啊","createdAt":"2025-06-06T14:54:51"},{"id":"0197440d-ab65-7397-acea-544d1377e506","parentId":null,"rootId":null,"fromId":23600,"content":"不要浪费时间 抓紧时间找工作 有机会就上车 至于提高水平 新环境就能学到新东西 平时注意自学 就行了","createdAt":"2025-06-06T15:03:56"},{"id":"01974411-c00f-7330-b19e-0bdd7fabd24f","parentId":null,"rootId":null,"fromId":2846,"content":"好的感谢","createdAt":"2025-06-06T15:08:23"},{"id":"01974414-8581-731f-b136-d6f6f78725fe","parentId":null,"rootId":null,"fromId":2846,"content":"theShy，你不打上单，改行干java了吗","createdAt":"2025-06-06T15:11:25"},{"id":"0197441a-76ff-72a1-a5f5-071a9d5f05fa","parentId":null,"rootId":null,"fromId":2846,"content":"离谱，大家都难","createdAt":"2025-06-06T15:17:54"},{"id":"0197441d-aaf3-729a-81d1-d83117b62838","parentId":null,"rootId":null,"fromId":24709,"content":"看下这个   ：https://gshmd.vip/posts/0197397e-7065-73f9-9025-21943bc072fa","createdAt":"2025-06-06T15:21:24"},{"id":"0197441e-6387-722a-bbc2-dfe15441cb02","parentId":null,"rootId":null,"fromId":24709,"content":"看下这个    https://gshmd.vip/posts/0197397e-7065-73f9-9025-21943bc072fa","createdAt":"2025-06-06T15:22:11"},{"id":"0197539e-7a49-7328-9404-373296c1cd82","parentId":null,"rootId":null,"fromId":7100,"content":"没了","createdAt":"2025-06-09T15:36:24"},{"id":"0197539e-7c82-72ca-b805-16bb55054a9b","parentId":null,"rootId":null,"fromId":7100,"content":"没了","createdAt":"2025-06-09T15:36:24"},{"id":"019758f2-1c6f-7182-9871-393dcf02f8d2","parentId":null,"rootId":null,"fromId":23974,"content":"哥们方便加个微信么","createdAt":"2025-06-10T16:25:51"},{"id":"019758fa-57d7-7363-8f49-cbd77ad42cb7","parentId":null,"rootId":null,"fromId":2846,"content":"ja2023423    有什么问题？ 可以加下我","createdAt":"2025-06-10T16:34:50"},{"id":"019758fb-2881-7227-9688-4a3087708446","parentId":null,"rootId":null,"fromId":23974,"content":"你是发帖子的博主么、","createdAt":"2025-06-10T16:35:44"},{"id":"01975901-54f4-7181-8030-46ef58350cff","parentId":null,"rootId":null,"fromId":2846,"content":"帖子是我发的，有什么问题。你也可以在这里说","createdAt":"2025-06-10T16:42:28"},{"id":"0197595b-0d16-72d9-bbc9-405134390efa","parentId":null,"rootId":null,"fromId":3346,"content":"三年经验去培训？培训老师都不一定有你经验丰富，那群人也就理论强点","createdAt":"2025-06-10T18:20:28"},{"id":"0197599a-4740-72d7-9a74-b560e5057af3","parentId":null,"rootId":null,"fromId":2846,"content":"主要还是想提高一下，不管是深度上还是广度，没工作在家很废","createdAt":"2025-06-10T19:29:32"},{"id":"019761f9-7874-72e5-933e-3b217d671801","parentId":null,"rootId":null,"fromId":23140,"content":"培训班出来也就crud熟练工水平，甚至还不如。没结婚没对象没负担的话济南找不到工作就往北上广深投，别吊死在济南这颗树上","createdAt":"2025-06-12T10:30:28"},{"id":"01976220-e01b-71c6-92fa-34a6664fbc5c","parentId":null,"rootId":null,"fromId":2846,"content":"确实没结婚没对象，有点车贷。我97年的，不管是去一线还是新一线，早晚得回来，去待3-5年又能攒多少钱呢。除非这辈子不结婚了，一直在外面漂着。家里给的压力也挺大的","createdAt":"2025-06-12T11:13:31"},{"id":"01976226-481e-71b1-a7e7-7e080b35884e","parentId":null,"rootId":null,"fromId":7074,"content":"正确认识认清自己，认清环境形式，拒绝眼高手低。","createdAt":"2025-06-12T11:19:25"},{"id":"01976229-592d-703a-ab3d-3f8ec7690dce","parentId":null,"rootId":null,"fromId":2846,"content":"是的，有道理","createdAt":"2025-06-12T11:22:46"},{"id":"0197b046-ebb1-73ad-8aa0-67d11e54c0ff","parentId":null,"rootId":null,"fromId":25433,"content":"0","createdAt":"2025-06-27T15:25:27"},{"id":"0197b06d-b79a-7048-b80d-d36efd9fb4b5","parentId":null,"rootId":null,"fromId":24615,"content":"我接触过N多开发人员，很多人干3年就跟没开窍一样，逻辑思维能力不行，代码没有规范性可言，喜欢copy代码但自己都不知道为啥要那样写。开窍的过程及其痛苦，基本三个过程：因工作原因被拉着加班学习&gt;对技术产生兴趣自我学习&gt;分享技术并在工作中应用。在第一个过程中容易产生自己被pua的感觉，然后受不了加班离职，实际是快速提升自己的过程，人一般都是懒惰的，不被催没有压力，很容易懈怠，如果年轻都不闯荡和奋斗，等年龄变大生活琐事多了，更力不从心","createdAt":"2025-06-27T16:07:49"},{"id":"0197b087-6e79-7032-a874-aa716533ab8c","parentId":null,"rootId":null,"fromId":1421,"content":"没形成体系化思维，原同事被经理吐槽过，说一个业务有n种做法，每次他给的都是最蹩脚的一种设计逻辑","createdAt":"2025-06-27T16:35:55"},{"id":"0197b113-85e2-71c8-90d1-82b9ae6e88f5","parentId":null,"rootId":null,"fromId":2846,"content":"感谢这位哥的评论，现在回想一下确实是这样，工作上提升确实是最快，我很幸运遇到解决不了的问题也都有高级开发帮我解决，但是也失去了自己独立解决问题的能力。因为工作中什么都接触过点，导致现在什么都会一点，系统化学习基本没有，现在技术水平就像是东一犁，西一耙的。您所说的问题我都有，现在我也基本处于第一过程。人是需要往前看的，有问题就要解决。看您后面所说的是建议其他城市发展吗？最起码是驱动自己学习，在学习上是有点迷了，总觉得自己啥都会点，眼高手低，工作也找不到，我也不知道下一步该怎么走了，所以才想问下要不要去花钱让自己去学习，自驱力差点，那么就需要其他方面的压力了","createdAt":"2025-06-27T19:08:56"},{"id":"0197b1c8-be82-72f6-89c6-92982faa102d","parentId":null,"rootId":null,"fromId":24615,"content":"我没有建议你去大城市闯荡，我觉得不管去哪，跟解决你现在面临的迷茫无关，我给你的建议是，尽量不要去小公司，而是去大公司（不是几百人那种，最好是上万），并且尽量坚持时间长一些，当然去北上广可能更容易实现这个目的。我甚至觉得大公司的外包都比小公司自研强，因为在大公司外包和正式干的活差不多。去大公司会见识到各种各样的情况，平台大接触到其他厂家也多，人脉拓展很快。在大厂你将快速提升代码编写规范性、功能高可用高拓展、系统安全、容灾自动切换、日常运维监控、与客户交流技巧、跨部门工作协调等等方面的能力，你在接触它们的时候往往是一个执行者参与进去，还会掺杂着被催促、被批评、被指导，过程不会舒服，随着时间的推移，你会逐渐变为你负责、你指导、你批评，你会为团队的进度焦虑，甚至发现还不如当参与者轻松。","createdAt":"2025-06-27T22:26:52"},{"id":"0197b21e-8c82-7304-9f1d-9b258861867b","parentId":null,"rootId":null,"fromId":2846,"content":"感谢指导，我会尽量去做的","createdAt":"2025-06-28T00:00:35"}]