[{"id":"01963df5-f0fb-7201-a4a9-3e8ed8d6009d","parentId":null,"rootId":null,"fromId":22173,"content":"国企有了面试机会，拿到了offer再考虑一下前景怎么样。现在硕士也不好进了，因为硕士近些年也都是百万的毕业生。国企很多萝卜岗（有些职位不是缺人了，才招人，而是有了某个人，才有了这个职位），希望你懂的。","createdAt":"2024-12-31T15:11:59"},{"id":"01963df5-f141-71e6-aee3-2ad33135f69e","parentId":null,"rootId":null,"fromId":6345,"content":"我们公司招数据分析，可以留下联系方式（福利很好，双休，全额交）","createdAt":"2025-01-02T14:06:14"},{"id":"01963df5-f193-724c-8e5a-739885f48bf3","parentId":null,"rootId":null,"fromId":875,"content":"面试你得说自己是单身，没对象，还是很好找工作的，济南企业里硕士还是很少的","createdAt":"2025-01-02T20:21:18"},{"id":"01963df5-f186-72fa-ab11-46bfeae1f538","parentId":null,"rootId":null,"fromId":22468,"content":"请问贵公司是？","createdAt":"2025-01-06T14:36:11"},{"id":"01963df5-f18a-7277-9fe2-076ae5a1b19e","parentId":null,"rootId":null,"fromId":6345,"content":"如果有意向，可以留个联系方式哈，公司在济南相对还不错，福利很好","createdAt":"2025-01-06T18:10:01"},{"id":"01963df5-f18e-736b-a221-b5cc73db2c56","parentId":null,"rootId":null,"fromId":21481,"content":"q：3759663618","createdAt":"2025-01-23T15:57:16"},{"id":"01963df5-f21d-7324-8885-1bc85d58603d","parentId":null,"rootId":null,"fromId":7427,"content":"这岗位要求一般就是，python计算库，excel处理，产品方向的可视化大屏数据计算，数据库查询统计，最后数学专业、统计学专业优先。","createdAt":"2025-01-24T12:25:17"}]