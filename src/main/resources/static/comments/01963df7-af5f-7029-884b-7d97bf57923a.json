[{"id":"01963df7-afc6-73e1-9f40-102f56f50792","parentId":null,"rootId":null,"fromId":6268,"content":"去让老头给你上上课吧，反正闲着也是闲着","createdAt":"2025-03-13T10:41:36"},{"id":"01963df7-b00a-7053-b221-d02edd96912c","parentId":null,"rootId":null,"fromId":6091,"content":"这个评价绝了，就是这样","createdAt":"2025-03-13T10:44:28"},{"id":"01963df7-b00e-7304-b4ef-3a1ad0a9c7d3","parentId":null,"rootId":null,"fromId":22806,"content":"不招人？纯上课？","createdAt":"2025-03-13T10:57:53"},{"id":"01963df7-b012-724d-bd36-f8f5f2eb2c4e","parentId":null,"rootId":null,"fromId":6091,"content":"我面过一次没过，三个人面了一个小时","createdAt":"2025-03-13T11:12:51"},{"id":"01963df7-b017-73de-aa0f-0e181d1dfbe1","parentId":null,"rootId":null,"fromId":6091,"content":"到了哪里老头先给你上上课，然后让研发领导来面试，最后告诉你没通过在给你上课，不过看着环境不错，就是人不太多","createdAt":"2025-03-13T11:14:16"},{"id":"01963df7-b01b-7212-b85d-00ad22cf3377","parentId":null,"rootId":null,"fromId":1368,"content":"人少事多，工资低。建议入职前一定把工资要到位，因为未来几年不会给你有薪资的调整。","createdAt":"2025-03-13T14:16:24"},{"id":"01963df7-b05f-72c8-b390-bd03eea626e8","parentId":null,"rootId":null,"fromId":22806,"content":"还让做笔试题，直接我就走了，真是浪费时间","createdAt":"2025-03-13T16:38:33"},{"id":"01963df7-b0a2-730d-9cab-440e06327504","parentId":null,"rootId":null,"fromId":5777,"content":"如果能接受，加班没有任何加班费或者调休，周末加班没有任何补助，也没有任何调休，工资除了每年涨一百外，三四年基本不会给你主动涨薪。能接受这些，就可以去试试","createdAt":"2025-03-17T18:55:28"},{"id":"01963df7-b0e8-73d9-86eb-887bd624279f","parentId":null,"rootId":null,"fromId":21948,"content":"加班那么频繁吗  周末还加班","createdAt":"2025-03-21T11:31:00"},{"id":"019740a8-e1e9-7038-8ccf-10b4297e8c77","parentId":null,"rootId":null,"fromId":21757,"content":"可不，画个大饼给你吃","createdAt":"2025-06-05T23:14:59"},{"id":"019a8fef-8faf-73d8-80e7-034f083df9f3","parentId":null,"rootId":null,"fromId":2725,"content":"不得不说，兄弟们说得对","createdAt":"2025-11-17T11:50:33"}]