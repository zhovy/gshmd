[{"id":"01963de2-be0a-715d-b2fa-b0c48082e56b","parentId":null,"rootId":null,"fromId":933,"content":"杰哥的公司么","createdAt":"2023-05-22T09:09:12"},{"id":"01963de2-be4f-73bf-9b5d-1da5c6465dd6","parentId":null,"rootId":null,"fromId":1003,"content":"可以去  找杰哥卷起来","createdAt":"2023-05-22T09:17:32"},{"id":"01963de2-be94-7395-be99-7abb55162caa","parentId":null,"rootId":null,"fromId":1074,"content":"杰哥是谁....","createdAt":"2023-05-22T13:07:17"},{"id":"01963de2-bedd-7094-9773-0b2caec647d6","parentId":null,"rootId":null,"fromId":2767,"content":"杰哥是谁……","createdAt":"2023-05-22T13:28:02"},{"id":"01963de2-bf22-7049-a1cd-3482e0291abe","parentId":null,"rootId":null,"fromId":1656,"content":"杰哥是？","createdAt":"2023-05-22T16:02:50"},{"id":"01963de2-bf68-730c-9d27-8751c98ad9fd","parentId":null,"rootId":null,"fromId":576,"content":"里面俩杰哥,大杰哥可帅啦,还有个闺女呢,以后你们的儿子可以找他家闺女聊聊人生啊.这颜值基因,靠谱.","createdAt":"2023-05-23T10:58:39"},{"id":"01963de2-bfae-7230-bd20-390c3b1936ba","parentId":null,"rootId":null,"fromId":3615,"content":"杰哥 ，勤成首席架构师，以前在天安门附近干开发，进去之后跟杰哥好好学","createdAt":"2023-05-24T16:16:41"},{"id":"01963de2-bff4-7150-acb8-ea370478eba1","parentId":null,"rootId":null,"fromId":4275,"content":"关于技术开发早上八点半上班下午七点左右下班，一周六天。公司很恶心，除非实在没地方去真不建议去。售后在外面，满足老板恶趣味，早上七点半之前起来晨读录音上传。重点：态度傲慢，公司找借口直接不协商调岗降薪，号称随便你去劳动仲裁，没有用。总之对于劳动者来说这种公司就是该死，去了就会发现是个坑。","createdAt":"2023-08-02T10:07:02"},{"id":"01963de2-c03e-7162-aa5e-729b4c5f7fb8","parentId":null,"rootId":null,"fromId":7254,"content":"吃相难看","createdAt":"2024-04-18T16:58:09"},{"id":"01963de2-c0c7-7313-b08e-11315263b7c1","parentId":null,"rootId":null,"fromId":22431,"content":"从23年下半年就开始拖欠工资，从拖一周到拖一月，到24年12月已经拖了近半年了，没啥希望，有梦想的人可以加入，跟公司一起度过难过","createdAt":"2024-12-20T10:10:50"},{"id":"01963de2-c10c-7086-b6cd-5d960be8646a","parentId":null,"rootId":null,"fromId":22494,"content":"不发工资，老板还跟没事人一样，MD。各部门开会也不提工资的事，就跟没有拖欠工资这回事一样，每次问每次都说发，每次都是实现不了，啪啪打脸，恶心的各种开会各种培训，都是晚上或者周末，还有一堆考核，早晨七点左右就得晨读，还录音，大坑比","createdAt":"2024-12-23T10:52:50"}]