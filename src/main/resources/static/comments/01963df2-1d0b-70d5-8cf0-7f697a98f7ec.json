[{"id":"01963df2-1d76-73e5-8a96-384d848ad1e4","parentId":null,"rootId":null,"fromId":7425,"content":"题主补充：编程能力尚可，可以自主搭建一整套微服务开发环境，独立完成开发平台，但是组织语言、表达能力一般，面试表现力不太行","createdAt":"2024-08-07T20:18:19"},{"id":"01963df2-1dcb-7062-a0f6-10885dffe118","parentId":null,"rootId":null,"fromId":7425,"content":"题主补充：学历统招二本计算机专业毕业","createdAt":"2024-08-07T20:21:40"},{"id":"01963df2-1dba-73be-9b41-57be3adbef59","parentId":null,"rootId":null,"fromId":2198,"content":"平台开发是指什么","createdAt":"2024-08-07T23:02:19"},{"id":"01963df2-1dbe-720e-b84c-5e1d9e042ec9","parentId":null,"rootId":null,"fromId":7425,"content":"就是可以提供快速二次开发能力的基座服务，包括不限于租户管理、用户管理、角色管理、组织管理、权限管理、菜单管理、文件服务、工作流管理、消息管理、导入导出配置等。跟目前市面上的低代码平台差不多，但是不包含代码生成器，没做过这个，代码生成暂时还是用的easyCode插件","createdAt":"2024-08-07T23:31:29"},{"id":"01963df2-1e0e-7247-be35-a16749aca466","parentId":null,"rootId":null,"fromId":21363,"content":"济南的话，13-15不是问题，可以的","createdAt":"2024-08-08T08:59:49"},{"id":"01963df2-1e52-72eb-bfdd-88f39424eaa6","parentId":null,"rootId":null,"fromId":21053,"content":"现在要不到了，除非去外包","createdAt":"2024-08-08T09:04:39"},{"id":"01963df2-1dc2-73a7-b3ed-d14dff7f7f21","parentId":null,"rootId":null,"fromId":6517,"content":"这些管理 不是人人都会吗","createdAt":"2024-08-08T09:20:41"},{"id":"01963df2-1e57-7206-834b-562239c9da10","parentId":null,"rootId":null,"fromId":21396,"content":"给楼主个参考，今年年初去找工作，经验学历差不多，外包给11k，大部分中小型公司只给10k，最后找了2个月，才找到个综合福利算下来12k的","createdAt":"2024-08-08T09:35:09"},{"id":"01963df2-1ead-726f-9ce3-35ea8f9bdbc2","parentId":null,"rootId":null,"fromId":21598,"content":"三年工作经验，其他的和你差不多。6月份跳槽，投了一个就面上了，给的12k。自研非外包，这个公司目前还有岗位","createdAt":"2024-08-08T09:50:36"},{"id":"01963df2-1f0a-700b-b174-8a8ca02ee81b","parentId":null,"rootId":null,"fromId":479,"content":"哪家呀","createdAt":"2024-08-08T10:41:30"},{"id":"01963df2-1f0f-7080-9c2c-43bbe2d69b5d","parentId":null,"rootId":null,"fromId":7425,"content":"兄弟，能否给个关键词，好人一生平安","createdAt":"2024-08-08T13:40:57"},{"id":"01963df2-1dc6-71ae-8e50-8cd4db9af1c2","parentId":null,"rootId":null,"fromId":7425