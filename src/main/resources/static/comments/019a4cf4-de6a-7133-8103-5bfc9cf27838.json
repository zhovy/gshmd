[{"id":"019a4d48-2821-7193-ac44-81a3079bfcab","parentId":null,"rootId":null,"fromId":4140,"content":"你自己其实啥都知道，没必要问别人","createdAt":"2025-11-04T13:12:45"},{"id":"019a4d5f-0697-7386-87c7-54c1331c153e","parentId":null,"rootId":null,"fromId":781,"content":"肯定没人当面歧视","createdAt":"2025-11-04T13:37:44"},{"id":"019a4d86-46af-7025-b9ae-756bb62e886e","parentId":null,"rootId":null,"fromId":21035,"content":"不是外包，zf的项目一般都需要驻场，基本都是甲方要求驻场的，方便随时沟通，而且有些是涉密的项目，所以需要驻场开发，也不会有歧视，除了jun的，有些单位还会给饭卡让去他们单位食堂吃饭","createdAt":"2025-11-04T14:20:36"},{"id":"019a4dd5-8129-73aa-b562-0f6565b30221","parentId":null,"rootId":null,"fromId":22316,"content":"初入社会，啥都不懂，都是听人说的，所以想问一下各位前辈们的切身经历","createdAt":"2025-11-04T15:47:09"},{"id":"019a4e32-98a3-708d-9322-a23d9ba90ccc","parentId":null,"rootId":null,"fromId":22806,"content":"不会有保障，项目结束运气好还有下一个项目能继续让你呆着，运气不好直接解除合同\n至于歧视。“肯定不会当面提示”","createdAt":"2025-11-04T17:28:50"},{"id":"019a4e83-a620-722c-a33a-c6a521566aa2","parentId":null,"rootId":null,"fromId":22316,"content":"解除合同的话，会有赔偿吗？","createdAt":"2025-11-04T18:57:21"},{"id":"019a4e88-67ed-7215-9a87-01dfb000f0c7","parentId":null,"rootId":null,"fromId":6222,"content":"分什么类型的ZF项目了，需要业务强类型的，直接转甲方合同工。身边好多同事这样干了  很爽 只负责一个大型项目就行","createdAt":"2025-11-04T19:02:33"},{"id":"019a519c-0add-73c3-a01e-b724a916ca1e","parentId":null,"rootId":null,"fromId":22806,"content":"看公司有没有良心吧","createdAt":"2025-11-05T09:22:52"},{"id":"019a53c4-8e39-727d-9e8e-64267eb943d6","parentId":null,"rootId":null,"fromId":926,"content":"ZF项目首先要看你入职的这个公司的业务领域，看他们做的是ZF什么口的系统，至于你所谓的外包，跟人ZF单位没有任何关系，你是不是外包，需要看你签订的公司跟你签的是什么合同。你在ZF单位身份就是乙方人员。ZF单位跟你司是甲乙方关系，你司与你才存在你所谓的是否为外包的关系。而且会不会完结后被裁掉，这要看你司有没有相关的其他ZF项目，如果只有这一个，那就要看你司的重视程度。还有，不存在甲方歧视行为，你不是人家ZF单位的外聘人员，谈不上所谓的歧视。","createdAt":"2025-11-05T19:26:21"},{"id":"019a56b1-a687-7081-96b7-2953f8e11b85","parentId":null,"rootId":null,"fromId":3450,"content":"外包就没有不歧视的","createdAt":"2025-11-06T09:04:34"}]