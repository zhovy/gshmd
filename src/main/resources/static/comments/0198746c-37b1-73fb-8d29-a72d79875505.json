[{"id":"01987483-5650-7265-b477-d6a2129b46c5","parentId":null,"rootId":null,"fromId":21818,"content":"背着房贷车贷老婆嫌弃没本事，出门干活也憋屈的像奴才。显什么神通啊？哪有神通啊？","createdAt":"2025-08-04T17:57:01"},{"id":"019874aa-d694-73b8-a3b7-7b0e80a987ae","parentId":null,"rootId":null,"fromId":3968,"content":"看似都是可怜人，本质上都是自己选的，对自己未来太过于乐观","createdAt":"2025-08-04T18:40:09"},{"id":"0198751c-4d40-7314-998e-626db2c907d7","parentId":null,"rootId":null,"fromId":6420,"content":"只要不结婚，后面这些都压迫不了你","createdAt":"2025-08-04T20:44:05"},{"id":"01987531-33bf-7225-b76a-7725dba171c4","parentId":null,"rootId":null,"fromId":1164,"content":"阅读理解零分，你可以含蓄的理解成好自为之、靠人不如靠自己、谁也帮不了你等等，还真以为有啥本事不成。。","createdAt":"2025-08-04T21:06:55"},{"id":"0198777f-4929-7259-8205-3bfd56e30239","parentId":null,"rootId":null,"fromId":2246,"content":"他卷他的，我摆我的","createdAt":"2025-08-05T07:51:27"},{"id":"019877b0-3c86-71de-b0a2-51dd54d9de6c","parentId":null,"rootId":null,"fromId":23971,"content":"别碰车贷、房贷、传宗接代，这些都不是事","createdAt":"2025-08-05T08:44:55"},{"id":"019877bb-d866-7164-a6de-f24e282d33ee","parentId":null,"rootId":null,"fromId":21267,"content":"靠个屁，你没钱没权啥也靠不住，等死吧","createdAt":"2025-08-05T08:57:36"},{"id":"019878e1-0d6c-700e-bccd-04c675b32553","parentId":null,"rootId":null,"fromId":5471,"content":"一直没有结婚，也不知道结婚有啥好处，有结婚的兄弟出来说说","createdAt":"2025-08-05T14:17:51"},{"id":"01987e6a-f42b-7139-bd58-722675ab3a7b","parentId":null,"rootId":null,"fromId":4016,"content":"你非要死在山东？就不行多出去走走？","createdAt":"2025-08-06T16:06:35"},{"id":"019883a4-0a25-7287-b3bb-6d7a395fe340","parentId":null,"rootId":null,"fromId":24324,"content":"既然扛不住世俗的压力选择了结婚，就别在这怨天尤人","createdAt":"2025-08-07T16:27:02"},{"id":"019883a4-8194-72e8-890f-3640890ae583","parentId":null,"rootId":null,"fromId":24324,"content":"都是自己选的","createdAt":"2025-08-07T16:27:33"}]