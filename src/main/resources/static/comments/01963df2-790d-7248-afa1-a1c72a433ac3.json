[{"id":"01963df2-7975-7356-841d-304482f58720","parentId":null,"rootId":null,"fromId":927,"content":"面试官是不是小陆啊，偏执狂+强迫症的结合体，哈哈哈哈！","createdAt":"2024-08-21T16:49:16"},{"id":"01963df2-79c7-709c-97fa-9cc5c8011f94","parentId":null,"rootId":null,"fromId":927,"content":"还有什么欣源根集团，都是一个公司。很垃圾！","createdAt":"2024-08-21T16:50:18"},{"id":"01963df2-7a11-7323-ae29-e85ca7fa45bb","parentId":null,"rootId":null,"fromId":1372,"content":"面过，给不起钱，面试官是一个五十来岁的男的，光问些有的没的。","createdAt":"2024-08-21T17:01:06"},{"id":"01963df2-7a5a-7234-a958-29d3b30c40bd","parentId":null,"rootId":null,"fromId":6446,"content":"其实他自己想问的和实际想表达的其实不一致，然后就很扯淡","createdAt":"2024-08-21T17:05:24"},{"id":"01963df2-79c2-7033-b776-4f7759db9c8b","parentId":null,"rootId":null,"fromId":6446,"content":"不，是老吴","createdAt":"2024-08-21T17:05:47"},{"id":"01963df2-7a0c-725a-9a6e-bb740c2202f5","parentId":null,"rootId":null,"fromId":6446,"content":"介绍手册啥都有，实际感觉没啥","createdAt":"2024-08-21T17:06:10"},{"id":"01963df2-7a5e-71b2-aa96-9a4effbca9de","parentId":null,"rootId":null,"fromId":1110,"content":"面试过，之前有个年轻的面试的，问的问题很不着边际，显得高大上实际上很low","createdAt":"2024-08-22T08:21:56"},{"id":"01963df2-7aa2-725d-9f78-d0a4ace6cdba","parentId":null,"rootId":null,"fromId":6446,"content":"看来大家感受都一样啊","createdAt":"2024-08-22T09:01:56"},{"id":"01963df2-7aa7-7185-b0a1-452f138fc4f0","parentId":null,"rootId":null,"fromId":403,"content":"面试八股文的，基本上都一个三高模子刻出来的神态---故作高深，高高在上，趾高气昂。\n能问八股文的，只能证明他是个程序员熟练工。","createdAt":"2024-08-22T09:52:29"},{"id":"01963df2-7aec-727f-8190-d31f0b9c3ecc","parentId":null,"rootId":null,"fromId":2408,"content":"完全没错，一点实际的东西都不问","createdAt":"2024-08-22T12:24:03"}]