[{"id":"01965cc3-df6a-7353-b589-a6dc3991355a","parentId":null,"rootId":null,"fromId":23140,"content":"这行情还有得挑？现在不是你瞧不上人家，而是人家瞧不瞧得上你。都投一遍，先看看有几家回复你。","createdAt":"2025-04-22T17:11:02"},{"id":"01965cda-416c-72cb-9a33-cab58163b45c","parentId":null,"rootId":null,"fromId":7125,"content":"Android还能找到工作吗？之前投过几个没一个回复的。。。。","createdAt":"2025-04-22T17:35:29"},{"id":"01965cdf-6734-709e-a3a7-4d693699aff6","parentId":null,"rootId":null,"fromId":5725,"content":"这行情还有得挑？现在不是你瞧不上人家，而是人家瞧不瞧得上你。都投一遍，先看看有几家回复你。","createdAt":"2025-04-22T17:41:06"},{"id":"01965cf1-834a-7033-a38b-e333d7abef03","parentId":null,"rootId":null,"fromId":926,"content":"山东鲁商科技集团有限公司（易通集团）肯定是最难的。","createdAt":"2025-04-22T18:00:53"},{"id":"01965cff-3b5a-70ff-9142-9472ab249072","parentId":null,"rootId":null,"fromId":4341,"content":"确实没得挑，看了这几家公司，不知道这些公司是啥待遇，特意上来问问的","createdAt":"2025-04-22T18:15:52"},{"id":"01965d00-d099-71e3-92cd-c1d216ba8488","parentId":null,"rootId":null,"fromId":4341,"content":"Android岗位确实越来越难找了，准备慢慢转行了","createdAt":"2025-04-22T18:17:36"},{"id":"01966064-e38b-735f-af42-7708f16bcc34","parentId":null,"rootId":null,"fromId":3500,"content":"山东鲁商科技集团有限公司（易通集团）有招聘吗 没搜到啊","createdAt":"2025-04-23T10:05:46"},{"id":"01966122-7e15-72ba-8b56-8bdcc492823e","parentId":null,"rootId":null,"fromId":3572,"content":"国资委网站或者官网，早就不在boss上了","createdAt":"2025-04-23T13:32:52"},{"id":"01966124-307c-71ea-b8dc-f3f3ec36df81","parentId":null,"rootId":null,"fromId":5951,"content":"其他的不了解，直接闭眼冲鲁商就行了，国资委控股，稳定靠谱","createdAt":"2025-04-23T13:34:43"},{"id":"01966126-4185-7109-8945-355dc3f1cf28","parentId":null,"rootId":null,"fromId":3572,"content":"科技今年上半年社招没有开发岗","createdAt":"2025-04-23T13:36:59"},{"id":"01966134-0631-7268-95aa-4776792a5aad","parentId":null,"rootId":null,"fromId":5951,"content":"确实，23年的时候有1个才聚齐鲁计划，在公众号上投简历，看着岗位和我很匹配，但是投了就没音了，不知道啥情况，现在有些国企是已经招聘完了，在把招聘信息发布出来，不知道是不是这种情况","createdAt":"2025-04-23T13:52:01"},{"id":"01966142-cc86-7224-8356-70d69b707460","parentId":null,"rootId":null,"fromId":3572,"content":"23年是科技新成立的，需要一些人，我就是那时候投的，现在人员基本满了，需求不大；现在制度是每半年公开招聘一次","createdAt":"2025-04-23T14:08:09"},{"id":"0196614c-5fcc-7291-8005-2c58694e536e","parentId":null,"rootId":null,"fromId":23548,"content":"不在易通，但是在那边驻场过，应该是这几个里面最好的了，国资背景，就是他们那边流行加班，之前有每周的加班排名","createdAt":"2025-04-23T14:18:37"},{"id":"0196619d-b1d2-71e8-9925-06985d06fa1d","parentId":null,"rootId":null,"fromId":21602,"content":"加毛线班，加班要申请，除非工期超级紧张的时候，别的时候别想加班","createdAt":"2025-04-23T15:47:26"},{"id":"0196d33f-1dbd-7383-a9bc-7c9515e88dea","parentId":null,"rootId":null,"fromId":24167,"content":"现在不加班了，也就工期特别紧的大项目需要加班，再就是功能上线当天需要加班到晚上10点以后。估计一年下来加班时长顶多也就160个小时左右。好处是可以随时调休。调休时长比例1:1。一年绝大多时间都是早9晚5.30，双休。唯一缺点：多年不涨工资。","createdAt":"2025-05-15T17:20:51"}]