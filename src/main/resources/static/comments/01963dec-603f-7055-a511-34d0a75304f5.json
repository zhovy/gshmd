[{"id":"01963dec-60aa-7343-9b7f-ab0c3dea2041","parentId":null,"rootId":null,"fromId":2815,"content":"4年还不到13k吗","createdAt":"2024-03-11T10:18:53"},{"id":"01963dec-60ef-70b1-b0c3-c8607caf61ea","parentId":null,"rootId":null,"fromId":6933,"content":"21年毕业的，现在都按毕业时间算，要不上去钱，这几天聊的最高给8，这不胡扯么","createdAt":"2024-03-11T10:32:51"},{"id":"01963dec-60f7-71be-bde5-a9a39166ebf7","parentId":null,"rootId":null,"fromId":3705,"content":"我和楼主一样，同21年毕业，也是前端。\n\n现在几乎都按照毕业时间开始算，谁管你实不实习呢，21年毕业 充其量就是 2.5 年经验。\n\n而且 9k 也不少了，先苟住吧，你出去了 9k 都不一定给能呢。\n\n我现在也是苟到了 1w.","createdAt":"2024-03-11T11:01:00"},{"id":"01963dec-613d-710c-a58b-3cc76e52f417","parentId":null,"rootId":null,"fromId":1398,"content":"按毕业时间开始算不到三年","createdAt":"2024-03-11T11:09:40"},{"id":"01963dec-6181-7063-a7a7-0a6e6080612f","parentId":null,"rootId":null,"fromId":3801,"content":"你这四年怎么算的，21年毕业到现在不是两年半么，招聘都是看毕业时间，两年半给8-10就不错了。","createdAt":"2024-03-11T11:17:24"},{"id":"01963dec-61d7-7146-88cf-d225d5b1243d","parentId":null,"rootId":null,"fromId":6517,"content":"我19年本科软件专业的， 5年前端才拿到11","createdAt":"2024-03-11T11:28:41"},{"id":"01963dec-6221-72bd-bf8b-557cef29f631","parentId":null,"rootId":null,"fromId":3341,"content":"四年本科9k  够苦的 我专科工作第二年就9k了 专科还是不是统招的。但是现在行情不行了 还是先gou住吧","createdAt":"2024-03-11T11:34:10"},{"id":"01963dec-60f3-727c-a0a7-272e5338c206","parentId":null,"rootId":null,"fromId":1398,"content":"给开八千是有道理的，21 年毕业到现在也就两年半，刚毕业的时候一般才 6 千，现在 8 千刚刚好","createdAt":"2024-03-11T12:41:10"},{"id":"01963dec-6264-70d6-beb0-bd141baa267c","parentId":null,"rootId":null,"fromId":5916,"content":"我们这个lj公司，22年毕业，到现在两年了，还是给我5，还没事找理由扣工资，现在找别的也不好找，太难了","createdAt":"2024-03-11T13:46:13"},{"id":"01963dec-61c4-71f0-8797-62bb05d29b3e","parentId":null,"rootId":null,"fromId":6933,"content":"20年三月份我就开始工作了，社保公积金都有证明，怎么不算四年。","createdAt":"2024-03-11T14:53:44"},{"id":"01963dec-61c9-7087-93b5-e521d72888d2","parentId":null,"rootId":null,"fromId":3892,"content":"你没毕业能给你交社保公积金？","createdAt":"2024-03-11T15:05:51"},{"id":"01963dec-61ce-72f3-aa53-21f0efea294c","parentId":null,"rootId":null,"fromId":929,"content":"实习也给交","createdAt":"2024-03-11T15:07:13"},{"id":"01963dec-62af-7235-acdd-b9c47745d6ad","parentId":null,"rootId":null,"fromId":6940,"content":"反正是需要跳槽的，我21年毕业，之前一直给我六千，后来六千五，我23年5月跳槽公司想留我说给我八千我没留，我直接跳槽了，新公司给我一万","createdAt":"2024-03-11T17:26:38"},{"id":"01963dec-621c-70d6-8ba1-23ba61bec6c9","parentId":null,"rootId":null,"fromId":6940,"content":"你跳槽太少了吧","createdAt":"2024-03-11T17:27:40"},{"id":"01963dec-61d3-71b1-9dc6-1c6a6126f31e","parentId":null,"rootId":null,"fromId":3801,"content":"我经历的几个公司都只看毕业时间，这块还真不知道有看社保、公积金的公司。","createdAt":"2024-03-11T17:36:31"}]