[{"id":"01963de5-5ed8-711e-b23a-bb4c9a42d4be","parentId":null,"rootId":null,"fromId":1492,"content":"银行、支付等行业的代码和系统都比较老，老而稳定，用ssh，ssm，用ssm多一点，一般不会用新的框架。除非启动新项目","createdAt":"2023-07-24T17:56:33"},{"id":"01963de5-5f22-7381-8a1a-4bf300c34669","parentId":null,"rootId":null,"fromId":4029,"content":"这个就得看银行里具体的项目了 有的项目技术架构还可以，有的项目技术就挺老的，而且银行开发8成概率是内网的  出了问题也不太好解决。","createdAt":"2023-07-24T18:05:34"},{"id":"01963de5-5f6b-72e1-947c-3b0faaa94309","parentId":null,"rootId":null,"fromId":3801,"content":"优点：\n1、除紧急项目和生产发版外，一般项目很少加班。\n2、金融业务算是比较复杂的，如果能多接触点，深入了解下业务，不管以后从事什么行业一通百通，能快速入门。\n缺点：\n1、技术框架都较老，稳定为主，java类开发大部分停留在ssh、ssm、jsp、bootstrap阶段，部分项目组还有C语言和C++，核心采用的cobol也是很老的技术。\n2、为保证数据安全，大部分的项目不允许办公电脑连接外网，对于纯百度型选手不是很友好。","createdAt":"2023-07-25T08:30:26"},{"id":"01963de5-5fb6-71f7-9bd4-8473d14edc2b","parentId":null,"rootId":null,"fromId":3973,"content":"现在技术更新迭代太快，如果你不是核心人员，离职以后找别的公司会比较困难","createdAt":"2023-07-25T11:07:40"},{"id":"01963de5-5f1e-7357-a450-6def04e7adfc","parentId":null,"rootId":null,"fromId":1398,"content":"好的","createdAt":"2023-07-25T14:09:31"},{"id":"01963de5-5f67-71e3-8e9b-7e9596696062","parentId":null,"rootId":null,"fromId":1398,"content":"收到","createdAt":"2023-07-25T14:09:41"},{"id":"01963de5-5fb1-7035-bd67-3ab64ec5b242","parentId":null,"rootId":null,"fromId":1398,"content":"嗯嗯","createdAt":"2023-07-25T14:09:57"},{"id":"01963de5-5ffa-7232-9806-05487e037351","parentId":null,"rootId":null,"fromId":1398,"content":"说的在理","createdAt":"2023-07-25T14:10:12"}]