[{"id":"01963df5-e0fe-727f-b3be-9ce013c99345","parentId":null,"rootId":null,"fromId":6344,"content":"泰***产业******","createdAt":"2024-12-30T10:02:17"},{"id":"01963df5-e147-70d8-a068-0b5d9714f085","parentId":null,"rootId":null,"fromId":22173,"content":"一个愿打一个愿挨，就这样而已。","createdAt":"2024-12-30T10:15:38"},{"id":"01963df5-e18c-71d8-bc6d-864823deb3d1","parentId":null,"rootId":null,"fromId":22395,"content":"腿长在你身上。不给工资违法，去劳动监察投诉，走劳动仲裁，或者可以走被迫离职。外面大环境不好就对了，就是你这种情况的人太多了，太好拿捏了","createdAt":"2024-12-30T10:19:18"},{"id":"01963df5-e1d1-7088-9de2-aa6ba6cfa14d","parentId":null,"rootId":null,"fromId":22395,"content":"不发工资，强制加班能把你逼离职，也省了一笔赔偿金了，奴隶主们学会了吗，这帮打工人不发工资还能自己走人哎","createdAt":"2024-12-30T10:21:00"},{"id":"01963df5-e1e3-712b-8e24-7edee7939190","parentId":null,"rootId":null,"fromId":22539,"content":"大家动起来，让职位流通起来，让薪资涨起来。","createdAt":"2024-12-30T10:22:29"},{"id":"01963df5-e1d6-73ba-873e-82b21293299f","parentId":null,"rootId":null,"fromId":6344,"content":"不是，是年底了不离职了，过完年回来走，加班费肯定是要声讨的","createdAt":"2024-12-30T10:22:38"},{"id":"01963df5-e1db-72d1-be51-2e5c88732919","parentId":null,"rootId":null,"fromId":6344,"content":"平常工作日1.5倍，周末2倍肯定不能少的，加班考勤记录和谈话录音我都有存着","createdAt":"2024-12-30T10:24:27"},{"id":"01963df5-e142-71d1-87f9-37f59fd6e69b","parentId":null,"rootId":null,"fromId":1999,"content":"是泰华吗，直接说全名就行","createdAt":"2024-12-30T10:27:10"},{"id":"01963df5-e226-722b-9597-1065d8704e9e","parentId":null,"rootId":null,"fromId":1372,"content":"他们怕的从来不是你拿起法律武器的时候，而是你放下法律，拿起武器的时候。","createdAt":"2024-12-30T10:50:30"},{"id":"01963df5-e1df-7181-9bd9-1be092fe4707","parentId":null,"rootId":null,"fromId":22395,"content":"嗯，祝你顺利","createdAt":"2024-12-30T12:10:57"},{"id":"01963df5-e273-7203-8266-b5227c04e4b3","parentId":null,"rootId":null,"fromId":5559,"content":"泰华又开始欠薪了吗","createdAt":"2024-12-30T12:12:40"},{"id":"01963df5-e2ba-7135-9043-862cf24e4276","parentId":null,"rootId":null,"fromId":3785,"content":"泰华不是让国企收购之后变好了吗？","createdAt":"2024-12-30T13:23:20"},{"id":"01963df5-e2b6-73a2-a136-0594ba17ba77","parentId":null,"rootId":null,"fromId":6344,"content":"是","createdAt":"2024-12-30T13:38:43"},{"id":"01963df5-e2fe-71b4-a278-a8df93445424","parentId":null,"rootId":null,"fromId":6344,"content":"好了一年，又不好了","createdAt":"2024-12-30T13:39:03"},{"id":"01963df5-e303-7116-8d3f-107818e2e701","parentId":null,"rootId":null,"fromId":22090,"content":"哈哈哈 哪个部门","createdAt":"2024-12-30T13:52:50"},{"id":"01963df5-e26a-7038-beb9-f5f24fef790b","parentId":null,"rootId":null,"fromId":297,"content":"在理儿?","createdAt":"2024-12-30T14:15:27"},{"id":"01963df5-e346-7078-a702-57f8bc9c5676","parentId":null,"rootId":null,"fromId":3572,"content":"走被迫离职一样赔偿N，学会了嘛，重要的是收集证据；正规流程还是要走仲裁，劳动监察，举报税务问题啥的其实都不管用，虽然仲裁很慢，但没有办法，谁让公司的违法成本几乎为零呢，劳动者就是天生弱势群体，没办法的事情。。。。。。","createdAt":"2024-12-30T15:52:51"},{"id":"01963df5-e38a-73a1-9a72-08728b033bac","parentId":null,"rootId":null,"fromId":6344,"content":"试试走被迫离职，先从人力资源那里下手","createdAt":"2024-12-30T16:09:36"},{"id":"01963df5-e393-709b-840f-b6fe441ee52a","parentId":null,"rootId":null,"fromId":22090,"content":"不说贷款下来了 今天就发 咋还没动静","createdAt":"2024-12-30T16:11:54"},{"id":"01963df5-e3dc-72b6-a988-3e6c21a0ce56","parentId":null,"rootId":null,"fromId":6344,"content":"银行也不傻啊，看你财务状况不好就不给你批贷款，财务状况好的求着你贷款","createdAt":"2024-12-30T16:23:35"},{"id":"01963df5-e26f-728d-8a22-938cc2ada484","parentId":null,"rootId":null,"fromId":7425,"content":"英雄所见略同，已经是做好一切准备了","createdAt":"2024-12-30T16:44:59"},{"id":"01963df5-e38e-706e-873f-618294f65dd0","parentId":null,"rootId":null,"fromId":22395,"content":"仲裁确实慢，但可以跳过（加一项不予受理），直接去法院起诉。举报税务和贿赂问题是很有效果的，只不过不是直接的，只是看着爽","createdAt":"2024-12-30T17:49:47"},{"id":"01963df5-e3e1-714f-8c40-f77add6e5e18","parentId":null,"rootId":null,"fromId":7013,"content":"是泰华智慧吗，我看boss上一直有招聘","createdAt":"2024-12-31T21:49:11"},{"id":"01963df5-e423-7129-b79d-7bb4338d1bef","parentId":null,"rootId":null,"fromId":6344,"content":"来了就被欠薪","createdAt":"2025-01-02T08:48:02"},{"id":"01963df5-e427-7235-85e6-f055a994fe2c","parentId":null,"rootId":null,"fromId":22431,"co