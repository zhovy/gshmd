[{"id":"01991224-f486-7012-aabc-463759a0c06b","parentId":null,"rootId":null,"fromId":21302,"content":"反正我跑了，其他人没人走","createdAt":"2025-09-04T08:33:55"},{"id":"01991227-2ed7-731a-9fae-da1a43045d9d","parentId":null,"rootId":null,"fromId":22250,"content":"1. 不敢，跑了也找不到工作\n2. 心存侥幸，总以为公司能补齐","createdAt":"2025-09-04T08:36:21"},{"id":"0199122f-a024-7302-833b-4a3ccdd1eff8","parentId":null,"rootId":null,"fromId":7074,"content":"怎么感觉跟当时的TJ这么像呢，最后大部分人被拖欠了将近一年的工资，最后只能仲裁起诉要回工资","createdAt":"2025-09-04T08:45:35"},{"id":"01991237-4ee8-70b4-a711-b99fa91a59f5","parentId":null,"rootId":null,"fromId":629,"content":"小TJ，情况一样的","createdAt":"2025-09-04T08:53:58"},{"id":"01991246-1aba-7192-8300-5eb90ff4112c","parentId":null,"rootId":null,"fromId":21302,"content":"我们小组长还说他跟公司大领导穿一条裤子，可是他工资也没发。","createdAt":"2025-09-04T09:10:08"},{"id":"0199124d-6bad-7350-85ea-961b1bf44375","parentId":null,"rootId":null,"fromId":21761,"content":"哪个公司？","createdAt":"2025-09-04T09:18:07"},{"id":"01991251-d0b6-735d-b37f-29b785f37f72","parentId":null,"rootId":null,"fromId":1049,"content":"因为没有卵蛋","createdAt":"2025-09-04T09:22:55"},{"id":"01991256-feab-7369-91db-694c1cad73d7","parentId":null,"rootId":null,"fromId":22809,"content":"因为中国人能吃苦，中国人不怕！","createdAt":"2025-09-04T09:28:35"},{"id":"0199126d-2272-7105-80a9-7f7a7630022b","parentId":null,"rootId":null,"fromId":7074,"content":"现在都删帖了，看不到消息了，也没几个人发消息了。俺顺利的话，明年才能把公积金拿回来","createdAt":"2025-09-04T09:52:46"},{"id":"01991294-6e22-70c1-84d0-b493756f4e8c","parentId":null,"rootId":null,"fromId":22702,"content":"我去 这种情况有没有大佬支招 第一时间拿回工资 要不越往后越没的拿","createdAt":"2025-09-04T10:35:41"},{"id":"019912a6-83db-730e-a1a8-47a4c1f4bac6","parentId":null,"rootId":null,"fromId":6747,"content":"建议花500找律师咨询，仲裁那边据说有免费的","createdAt":"2025-09-04T10:55:26"},{"id":"019912b1-9729-7268-b0e7-7636dc99b429","parentId":null,"rootId":null,"fromId":246,"content":"本人经历过仲裁  公司账户有钱就容易  不然到了强制执行那步  账户没钱也白搭 仲裁不需要花钱 开庭自己去就好了 没啥难的 就是多跑几趟法院","createdAt":"2025-09-04T11:07:32"},{"id":"0199132d-f821-7224-917a-17e478b542a3","parentId":null,"rootId":null,"fromId":22250,"content":"因为这些穷光蛋牛马最好欺负最没种了，扇左脸，右脸也凑上去。心里只恳求老板不要裁员，欠一年也能干，花家里老本就行了。","createdAt":"2025-09-04T13:23:23"},{"id":"019913dd-4ec8-71fc-a5cb-f2aa8b865387","parentId":null,"rootId":null,"fromId":3381,"content":"只能说还是没有房贷车贷的压力，你背上这账单一个月不发工资就得准备了，两个月不发就得开始面试了，三四个月？直接下家走人","createdAt":"2025-09-04T16:34:54"},{"id":"019913e3-71cb-7104-b15a-ed6fa4746107","parentId":null,"rootId":null,"fromId":21302,"content":"好多有房贷的也在拖着不走","createdAt":"2025-09-04T16:41:36"},{"id":"0199140d-ea42-71e1-9521-dc8c028cac60","parentId":null,"rootId":null,"fromId":3450,"content":"跑了就有工资了？反正都没钱，啥时候看公司不行了，直接把公司东西都搬回家","createdAt":"2025-09-04T17:28:00"},{"id":"01992363-f4a3-717e-a6f3-f0f99ddd89d7","parentId":null,"rootId":null,"fromId":23223,"content":"基本盘稳定，齐鲁更是最佳用人之地，老实憨厚，很多公司把主要人力放到济南开分公司。","createdAt":"2025-09-07T16:56:17"}]