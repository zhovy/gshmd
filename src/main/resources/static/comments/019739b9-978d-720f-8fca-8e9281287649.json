[{"id":"019739ba-615b-70da-b9ec-580b816b9ca6","parentId":null,"rootId":null,"fromId":21003,"content":"内卷","createdAt":"2025-06-04T14:56:45"},{"id":"019739ba-9094-72d4-835d-bf5988d22b7d","parentId":null,"rootId":null,"fromId":21003,"content":"好的互联网公司太少","createdAt":"2025-06-04T14:56:57"},{"id":"019739cf-0bda-708a-9812-277d3b40170e","parentId":null,"rootId":null,"fromId":21818,"content":"最大的原因还是大环境经济不行，其次是没有真正的互联网公司，电商时代没有跟上，直播时代也没有跟上。最后是行业内卷，内卷是通病，但是有些城市内卷实实在在挣到钱了，济南是也卷了也没挣到钱。","createdAt":"2025-06-04T15:19:19"},{"id":"019739d5-228b-7324-9272-2b1f397634a6","parentId":null,"rootId":null,"fromId":23910,"content":"僧多肉少,好单位一个萝卜一个坑,流通的就一些一般以下的公司,总而言之 还是人太多了  现在依然有人源源不断的进机构培训java","createdAt":"2025-06-04T15:25:58"},{"id":"019739d6-21cb-70e4-a85d-81cd7ff82ef4","parentId":null,"rootId":null,"fromId":23274,"content":"每年这么多毕业生进来；但是每年30多岁退出这行业的人没几个（今年35的人是2012年计算机毕业的，那时候才有几个学计算机的）","createdAt":"2025-06-04T15:27:04"},{"id":"019739e1-0d81-7398-ac6e-6410f5e8ad13","parentId":null,"rootId":null,"fromId":6186,"content":"有良心的老板少","createdAt":"2025-06-04T15:38:59"},{"id":"01973a22-65a5-72c0-beda-524527eab33d","parentId":null,"rootId":null,"fromId":1421,"content":"没头部互联网企业，都是交付型项目为主的，项目营收减少会各种想办法降本，进口袋的钱再让人掏出来怎么可能。","createdAt":"2025-06-04T16:50:22"},{"id":"01973aa3-3fa5-7071-aece-f15fca69af31","parentId":null,"rootId":null,"fromId":24615,"content":"大厂现在也在裁员降薪，而且是一个萝卜一个坑，裁掉正式员工，不招或者招一个外包。一个部门就十几个研发人员，多的可能几十个人，都是万年萝卜，根本进不来新萝卜。中小厂更是水深火热，别说五险一金和福利了，就是正常工资都很难发出来，只能想着法子扣绩效。这就造成现在的就业，完全是同一帮人在不同的中小厂来回跳，跳进去发现太坑接着又换一家，自己简历上今年在这家公司，明年又跑另一家了，干的全是外包的活，还自己编一些商城等造假的项目，最坑爹的是简历上好几个月甚至一年找不到工作的，毕业五六年，静下心干活的时间才三年，还好意思要五六年的工资","createdAt":"2025-06-04T19:11:06"},{"id":"01973bc7-a0bd-71ee-bafc-bd02931d2510","parentId":null,"rootId":null,"fromId":21806,"content":"不止互联网","createdAt":"2025-06-05T00:30:28"},{"id":"01973d8b-457a-7318-bc48-d4895e6b25e5","parentId":null,"rootId":null,"fromId":22514,"content":"我之前一个朋友从培训机构学的，学完出来面试简历写得5年经验，直接面试了项目经理，，真牛逼","createdAt":"2025-06-05T08:43:46"},{"id":"01973e30-fcc4-72d6-974a-53217ce97812","parentId":null,"rootId":null,"fromId":21364,"content":"没人管呗","createdAt":"2025-06-05T11:44:47"},{"id":"01973f36-2768-7200-a3c9-46a32c346db6","parentId":null,"rootId":null,"fromId":23223,"content":"劳动者人多给惯的。劳动者不争取合法权利惯老板，低成本内卷，精致利己，违法无成本，好企业撑不住淘汰，负反馈，恶性循环","createdAt":"2025-06-05T16:30:03"},{"id":"01973f40-8db0-70a6-a8dd-f2f52ea39b04","parentId":null,"rootId":null,"fromId":5661,"content":"济南环境互联网差吗？高新区上下班堵车和19年之前差不多吧，没见人少啊","createdAt":"2025-06-05T16:41:24"},{"id":"01973f52-a548-70b0-bb90-8c22b9502942","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-06-05T17:01:10"},{"id":"01975e4c-e9f8-723d-9203-3de219b67b26","parentId":null,"rootId":null,"fromId":24350,"content":"没有真正的互联网公司  更确切点 没有真正的互联网头部公司","createdAt":"2025-06-11T17:23:08"}]