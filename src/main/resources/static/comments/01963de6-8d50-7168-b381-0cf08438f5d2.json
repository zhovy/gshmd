[{"id":"01963de6-8dbf-73bf-a3af-30d0df4f1ca5","parentId":null,"rootId":null,"fromId":1492,"content":"日企，总体来说挺不错，之前在那工作了4年。6险一金，公积金很高，双休，9点到5点半，加班可选加班费或调休，节假日福利和购物卡，中秋500，过年1000，每年体检，旅游。日企就是薪资比国内少点","createdAt":"2023-08-18T16:31:46"},{"id":"01963de6-8e06-715d-a8f5-6de1706d111d","parentId":null,"rootId":null,"fromId":4019,"content":"人力外包过去的？是不是没有这些待遇","createdAt":"2023-08-18T16:36:07"},{"id":"01963de6-8e0a-73b3-af57-e97eff63eb83","parentId":null,"rootId":null,"fromId":3892,"content":"对日开发技术含量怎么样？再找国内其他开发好转吗？\n","createdAt":"2023-08-18T16:49:43"},{"id":"01963de6-8e0f-7333-8cf2-b19df214df4c","parentId":null,"rootId":null,"fromId":1492,"content":"不是，本社的。外包待遇看你自己公司啊","createdAt":"2023-08-18T16:58:31"},{"id":"01963de6-8e13-718e-b258-166fecc5ad2b","parentId":null,"rootId":null,"fromId":1492,"content":"技术的话，好几年了，之前是ssh，ssm那套，现在不知道了。有对日也有对国内开发，也接国内的项目","createdAt":"2023-08-18T17:00:16"},{"id":"01963de6-8e17-71fc-9ed9-9903232ed765","parentId":null,"rootId":null,"fromId":3892,"content":"老哥，那你现在去哪家公司了？","createdAt":"2023-08-18T17:02:54"},{"id":"01963de6-8e1c-70aa-88ea-86cbcf21ac0d","parentId":null,"rootId":null,"fromId":1492,"content":"老实一点在日企挺好的，出来两年就后悔。裁员，降薪，发不出工资，国内公司各种sb行为。","createdAt":"2023-08-18T17:07:31"},{"id":"01963de6-8e24-71ea-b832-814211e90c9f","parentId":null,"rootId":null,"fromId":1110,"content":"感觉很一般吧，工作量给你安排的满满当当的","createdAt":"2023-08-18T17:31:57"},{"id":"01963de6-8e69-732f-b335-920eed9a9b65","parentId":null,"rootId":null,"fromId":5394,"content":"加班严重嘛","createdAt":"2023-08-21T11:38:27"},{"id":"01963de6-8e6e-70ce-9d7a-0fdf792d7493","parentId":null,"rootId":null,"fromId":1110,"content":"每天固定九点周六加班是否看进度","createdAt":"2023-08-21T11:54:21"},{"id":"01963de6-8e20-72eb-9511-5f4e1920252c","parentId":null,"rootId":null,"fromId":4163,"content":"外协没有福利，团建，体检。其他的和正社员一样","createdAt":"2023-08-21T15:00:19"},{"id":"01963de6-8e73-728a-976f-d12a5d659ef2","parentId":null,"rootId":null,"fromId":4163,"content":"你是第三事业部的吗","createdAt":"2023-08-21T15:01:06"},{"id":"01963de6-8e77-70b