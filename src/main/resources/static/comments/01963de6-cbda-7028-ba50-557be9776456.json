[{"id":"01963de6-cc42-7352-b72e-ecaf15115c5d","parentId":null,"rootId":null,"fromId":1398,"content":"那家公司","createdAt":"2023-08-23T15:12:36"},{"id":"01963de6-cc8f-7368-a829-81a1ace29990","parentId":null,"rootId":null,"fromId":21,"content":"工资高吗？是你想要的吗","createdAt":"2023-08-23T15:13:36"},{"id":"01963de6-cc86-7132-975f-3dbd4daf35f4","parentId":null,"rootId":null,"fromId":5448,"content":"现在还没离职不方便透露，一个20来个人的小公司","createdAt":"2023-08-23T15:28:42"},{"id":"01963de6-ccd3-72ca-a8b8-e207b746a261","parentId":null,"rootId":null,"fromId":5448,"content":"工资不算高，来了三年就涨了一次","createdAt":"2023-08-23T15:29:02"},{"id":"01963de6-ccd7-71d3-b331-9e1beafa7320","parentId":null,"rootId":null,"fromId":3892,"content":"想办法跑吧，工作累还不涨薪水，垃圾公司","createdAt":"2023-08-23T15:35:32"},{"id":"01963de6-cd1b-72cd-856a-567d158a4237","parentId":null,"rootId":null,"fromId":4301,"content":"正常啊 存在即正常","createdAt":"2023-08-23T15:37:42"},{"id":"01963de6-cd61-71ac-8b59-031bde836eb6","parentId":null,"rootId":null,"fromId":2572,"content":"看工资多少了。若是工资不高，就这个加班法，太累了。","createdAt":"2023-08-23T15:48:15"},{"id":"01963de6-cda6-726b-81d1-0f8dea12403e","parentId":null,"rootId":null,"fromId":1492,"content":"固定加班就不正常！何况小公司，工作时间完不成任务嘛。","createdAt":"2023-08-23T15:52:03"},{"id":"01963de6-cdea-72fc-a21c-151c9b6f57e6","parentId":null,"rootId":null,"fromId":1969,"content":"准备换吧  不太行","createdAt":"2023-08-23T16:23:14"},{"id":"01963de6-ce34-71a3-b89d-297af396e501","parentId":null,"rootId":null,"fromId":258,"content":"这是在学浪潮吧\n","createdAt":"2023-08-23T16:45:16"},{"id":"01963de6-ce78-72d9-8539-fbf03c962ec8","parentId":null,"rootId":null,"fromId":654,"content":"跟我公司一模一样","createdAt":"2023-08-23T16:48:33"},{"id":"01963de6-cebc-73bd-87b4-8a5d7ddde2da","parentId":null,"rootId":null,"fromId":3705,"content":"正常啊","createdAt":"2023-08-23T16:59:15"},{"id":"01963de6-cf00-705f-8f97-a6f979ce75a9","parentId":null,"rootId":null,"fromId":922,"content":"刚毕业可以体验一下，因为工作几年后你会越来越不想加班，除非你是一个工作狂","createdAt":"2023-08-23T17:18:44"},{"id":"01963de6-cf44-7078-9dad-472597cff8c4","parentId":null,"rootId":null,"fromId":5448,"content":"好多人觉得正常呢。。。是不是就因为我们平静的都接受了，所以公司才肆无忌惮的让我们加班。干程序我觉得加班正常比如说项目快上线了熬夜通宵几天我都可以接受，但是长期固定加班真的让人觉得没有啥盼头","createdAt":"2023-08-23T19:22:29"},{"id":"01963de6-cf8d-7118-898d-5ee3e0de9b2d","parentId":null,"rootId":null,"fromId":875,"content":"没人反抗吗","createdAt":"2023-08-24T07:30:18"},{"id":"01963de6-cfd2-73ab-bc3d-201be6009c1a","parentId":null,"rootId":null,"fromId":1493,"content":"南京大屠杀的时候也反抗了，结果呢","createdAt":"2023-08-24T08:37:53"},{"id":"01963de6-cf88-71e3-aa2a-9cdce9d3c20b","parentId":null,"rootId":null,"fromId":3897,"content":"是的，公司习惯你加班，然后加班就成了习惯，我现在就觉得很无力，每天都在加班，辞职现在这环境又不敢","createdAt":"2023-08-24T08:41:19"},{"id":"01963de6-cfd7-73fb-8c3c-bf3aac01660a","parentId":null,"rootId":null,"fromId":4165,"content":"所以要有组织的反抗，收集证据见一个告一个，之前有个大公司公积金不按规定交，员工离职一个告一个","createdAt":"2023-08-24T09:19:06"},{"id":"01963de6-cc8b-73ec-b4d5-eb49f8cf7ef3","parentId":null,"rootId":null,"fromId":1581,"content":"跟莱易有得一拼啊","createdAt":"2023-08-30T13:51:45"},{"id":"01963de6-cfdb-73da-8d5a-9e140ed93749","parentId":null,"rootId":null,"fromId":2935,"content":"正不正常，请参考《劳动法》","createdAt":"2023-09-02T00:09:42"}]