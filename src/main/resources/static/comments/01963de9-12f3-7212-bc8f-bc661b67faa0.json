[{"id":"01963de9-135c-73a1-9f58-3d0ada731159","parentId":null,"rootId":null,"fromId":837,"content":"现在行情，，能有个工作挣点钱学点技术很棒了，，可是7500在上海能生存吗，哥们","createdAt":"2023-10-18T08:30:22"},{"id":"01963de9-13a5-7016-b032-a7c48e04ecec","parentId":null,"rootId":null,"fromId":837,"content":"是外包，，浪潮内部自己的外包，，五险一金最低，但是不会拖欠工资","createdAt":"2023-10-18T08:43:15"},{"id":"01963de9-13f2-7352-be36-2f51b21743b1","parentId":null,"rootId":null,"fromId":1372,"content":"听同学说是浪潮里面最垃圾的子公司。","createdAt":"2023-10-18T09:17:09"},{"id":"01963de9-1436-7273-8944-5722b3f3668e","parentId":null,"rootId":null,"fromId":4384,"content":"外包公司 ，比较垃圾 ，把你派到浪潮其他公司工作，就相当于其他公司的外协人员，受到双层管理，还不受待见，待遇五险一金最低，其他福利啦  年终奖啊 就别想了 ，出差报销还得借其他人的账号报销  建议不要去了，哥哥早已从这个垃圾公司润了。","createdAt":"2023-10-18T09:57:55"},{"id":"01963de9-147a-70b7-b72e-56c789f7a888","parentId":null,"rootId":null,"fromId":3892,"content":"老哥，我没有特别好的去处，我技术不好，想磨练磨练，能去吗？工作时间是双休八小时吗？","createdAt":"2023-10-18T10:09:19"},{"id":"01963de9-1487-7113-af8b-8b66ecebc5a2","parentId":null,"rootId":null,"fromId":1398,"content":"浪潮不加班的很少，加班的很多很多?","createdAt":"2023-10-18T10:12:47"},{"id":"01963de9-14cb-70d5-9af5-0f743d29e1bc","parentId":null,"rootId":null,"fromId":1398,"content":"自己投上海的估计薪资都很高","createdAt":"2023-10-18T10:13:32"},{"id":"01963de9-150f-70f7-b292-9e9006fe2447","parentId":null,"rootId":null,"fromId":4140,"content":"去干吧，工作就得跳槽跳出来，但是前提你得确定方向，掌握一门技术，看你现在这样啥都不会，去锻炼锻炼也行，我毕业两年跳槽两次，第一次从国企双休6400调到私企9433大小周，选定从业mes、wms、erp开发方向，工作快两年，这次跳槽还是mes方向，给开了12k，反正不管去哪你不静下心学习到哪都一样，你得有职业规划，多学业务上的东西，技术上的在我看来现在倒不是什么问题","createdAt":"2023-10-18T10:13:50"},{"id":"01963de9-13a0-7273-8db5-2fd50ebc8215","parentId":null,"rootId":null,"fromId":3892,"content":"去上海应该会有住宿和补贴吧","createdAt":"2023-10-18T10:17:06"},{"id":"01963de9-147f-7202-8adb-cf5493fb43e1","parentId":null,"rootId":null,"fromId":3892,"content":"老哥，您在里面待过，我想多问您一下。其实我的意思是去的。我现在没有稳定的工作，简历也是包装过得，技术也不好。之前因为考研耽误了。边工作边考研，也在吃抗抑郁症的药物，现在状态不是很好。我的想法是苦点没事，但是能不能学到东西。提升自己，而且工作时间怎么样？离考研还有两个月我想再试一试","createdAt":"2023-10-18T10:20:52"},{"id":"01963de9-1553-7161-9c75-912e1f4d84c4","parentId":null,"rootId":null,"fromId":3892,"content":"感谢老哥给出的指导，我会听从您的建议，继续努力","createdAt":"2023-10-18T10:21:44"},{"id":"01963de9-1558-72d4-a14b-b9d8bebe9233","parentId":null,"rootId":null,"fromId":3892,"content":"同为21年毕业生，混到现在这个状况一言难尽","createdAt":"2023-10-18T10:37:22"},{"id":"01963de9-155c-7010-b925-c514eeed17b2","parentId":null,"rootId":null,"fromId":3892,"content":"昨天技术和HR给打的电话，现在就给发offer了，是不是待遇不太好了，跑的人太多了","createdAt":"2023-10-18T10:43:02"},{"id":"01963de9-13ea-7006-a03c-92226858e25e","parentId":null,"rootId":null,"fromId":2407,"content":"浪潮世科呢？","createdAt":"2023-10-18T13:53:00"},{"id":"01963de9-13ee-713b-9cfa-14c7a0322284","parentId":null,"rootId":null,"fromId":5859,"content":"浪潮世科改名字了","createdAt":"2023-10-18T14:02:08"},{"id":"01963de9-1483-7271-967c-3293e61d73f8","parentId":null,"rootId":null,"fromId":3892,"content":"老哥，可以交流交流吗？我qq号2414929097。谢谢您","createdAt":"2023-10-18T15:49:11"},{"id":"01963de9-159f-72c6-aa5d-f8a1f81e6e83","parentId":null,"rootId":null,"fromId":1398,"content":"刚从浪潮数字跑路","createdAt":"2023-10-18T18:04:21"},{"id":"01963de9-15a4-72c7-be61-60fda35154e4","parentId":null,"rootId":null,"fromId":3892,"content":"为啥跑路啊兄弟？工资不高还累？","createdAt":"2023-10-18T18:20:09"},{"id":"01963de9-15a8-701b-80e7-f9b28859ca80","parentId":null,"rootId":null,"fromId":1398,"content":"晚上八点半走，你以为是下班？不是下班，是出去吃个晚饭，之后回来继续上班","createdAt":"2023-10-18T21:49:19"},{"id":"01963de9-15ac-7342-9688-dd735b20c84d","parentId":null,"rootId":null,"fromId":1037,"content":"主打一个中间商，赚差价。以前叫世科，后来叫数字服务，\n现更名浪潮成诚。\n这个分部门吧，碰上好点的部门加班不多，但是涨薪还有调整社保挺难的，入职了把你外包出去基本上就不管了。并且项目上开发用的框架啥的基本就是固定的，都是搬砖。以后出去感觉不太好找工作。要是没就业经验，还不如找个小公司先历练一番，除了发工资稳定，其他也就那样。","createdAt":"2023-10-19T09:26:47"},{"id":"01963de9-15f1-72df-a402-a0dbebdd033a","parentId":null,"rootId":null,"fromId":3892,"content":"老哥，你之前在哪工作过吗？方便加我qq2414929097细说一下吗？感谢！","createdAt":"2023-10-19T10:33:01"},{"id":"01963de9-15f6-7304-868a-3cefc0756e09","parentId":null,"rootId":null,"fromId":1037,"content":"https://gshmd.vip/company/2101\nhttps://gshmd.vip/company/2067\nhttps://gshmd.vip/company/445\nhttps://gshmd.vip/company/2045\nhttps://gshmd.vip/company/1969","createdAt":"2023-10-19T13:53:22"},{"id":"01963de9-163e-72f2-9713-b1944ccfc5e2","parentId":null,"rootId":null,"fromId":2341,"content":"外包，相当于捡来的孩子给二儿子打工，不拖欠工资，但没年终不涨薪。项目基本都还行，可以学到技术，但没有晋升的希望，想学技术可以，但是记住别待太久","createdAt":"2023-10-19T14:21:23"},{"id":"01963de9-1687-70e9-9189-a5838abbaf16","parentId":null,"rootId":null,"fromId":4384,"content":"学技术？根本不存在的 ，都是他妈的闭门造车  ，好多项目都是外包出去的 ，大多东西都是没人教你 ，靠你各种百度。","createdAt":"2023-10-19T14:59:52"},{"id":"01963de9-163a-711e-9da6-987f6bd86527","parentId":null,"rootId":null,"fromId":3892,"content":"感谢","createdAt":"2023-10-19T15:02:04"},{"id":"01963de9-1682-70b5-8785-8e64683331e5","parentId":null,"rootId":null,"fromId":3892,"content":"感谢","createdAt":"2023-10-19T15:02:14"},{"id":"01963de9-16cb-72f0-980d-d18c4f05b279","parentId":null,"rootId":null,"fromId":3892,"content":"感谢","createdAt":"2023-10-19T15:02:21"}]