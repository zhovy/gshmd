[{"id":"01963de0-aad2-73d7-bf38-47b4adaaacbb","parentId":null,"rootId":null,"fromId":1959,"content":"离职率是超级高了吧 一个岗位能换好几个人","createdAt":"2023-03-24T16:28:13"},{"id":"01963de0-ab17-70b1-adfb-b5bcd1521fe5","parentId":null,"rootId":null,"fromId":1959,"content":"加班费=没有 调休一天跟对不起公司一样 不想给你假 领导阴阳怪气的说你 工作效率低 领导不会安排工作 导致必须通宵做给领导看","createdAt":"2023-03-24T16:32:02"},{"id":"01963de0-ab5d-7386-948e-9df301f27bd3","parentId":null,"rootId":null,"fromId":2125,"content":"周末加班费60(无论岗位)，其余加班没有,而且需要等到年底才给。项目上线之前经常各种改动，项目上线前一晚上经常通宵加班，一般第二天中午才能走。","createdAt":"2023-03-24T16:52:03"},{"id":"01963de0-aba2-71a8-8c75-a1acd22a476a","parentId":null,"rootId":null,"fromId":2125,"content":"汇景别的部门还可以，开发部门真的一言难尽。想想离职率，不是开发人员有问题就是管理者有问题。","createdAt":"2023-03-24T17:04:19"},{"id":"01963de0-abeb-7199-ba6b-68557624c0a2","parentId":null,"rootId":null,"fromId":3020,"content":"管理者嘴上说大家都意见都可以提，但是提了几乎是不采纳，而且阴阳怪气的去指责人，都是打工，何必这样呢？就是不管再努力，都不会被看到，就是垃圾中的战斗机","createdAt":"2023-03-24T17:41:34"},{"id":"01963de0-ac2f-712c-aa5c-eaa93ba9fec6","parentId":null,"rootId":null,"fromId":933,"content":"离职率有链上企客高吗","createdAt":"2023-03-27T08:50:29"},{"id":"01963de0-ac75-705e-8946-51bab680f08a","parentId":null,"rootId":null,"fromId":2589,"content":"离职率有链上企客高吗","createdAt":"2023-03-28T16:39:20"},{"id":"01963de0-acba-71c9-919b-23e65e9e340b","parentId":null,"rootId":null,"fromId":1959,"content":"离职率99.99999%","createdAt":"2023-04-07T15:39:24"},{"id":"01963de0-ad01-7191-936d-f4cdd08bc133","parentId":null,"rootId":null,"fromId":1959,"content":"基本上入职一段时间都受不了离职了，当天就走的也不少，一个月 两个月都有 之前工资很低 估计招不到人了 加了点薪","createdAt":"2023-04-07T15:41:39"},{"id":"01963de0-ad46-72cb-a290-3549d16d708c","parentId":null,"rootId":null,"fromId":5609,"content":"五险一金最低基数吗？楼主你好","createdAt":"2023-09-07T19:21:58"}]