[{"id":"01963dee-430c-7379-96c9-b274be5ee8ed","parentId":null,"rootId":null,"fromId":576,"content":"找到就不错了，济南看你背书。高薪都是背书好，没有看技术的。","createdAt":"2024-04-25T10:51:18"},{"id":"01963dee-4353-709a-86ca-932fce9bd8e5","parentId":null,"rootId":null,"fromId":7083,"content":"不要拿北上广深和济南比，在这样的环境下，能在济南找到工作已经不错了。自己反思下在一线城市那么久了，自己获得了什么了吧，别说浪费青春后，就什么没有","createdAt":"2024-04-25T10:51:25"},{"id":"01963dee-43b3-73ba-a9fa-1c3f9e4b6e40","parentId":null,"rootId":null,"fromId":3341,"content":"济南工作有峰值 最高到什么地方 但是没下限   \n15以上不论能力只谈机会 少很多。\n13以内全凭忽悠 大差不差。","createdAt":"2024-04-25T10:55:25"},{"id":"01963dee-43f8-723b-8045-cf45896641d7","parentId":null,"rootId":null,"fromId":4367,"content":"985硕，回来的时候一年半工作经历，北京39w，济南19w。接受就好，没得挑","createdAt":"2024-04-25T11:15:57"},{"id":"01963dee-443e-72c3-8e95-fa2af0f26a1e","parentId":null,"rootId":null,"fromId":3892,"content":"老哥，去哪个公司了？","createdAt":"2024-04-25T11:19:39"},{"id":"01963dee-4442-711d-b5c8-5634c3b18e3f","parentId":null,"rootId":null,"fromId":4367,"content":"当时在一个研究院，已经走了。我这个行业太窄了，济南没几家，现在转做偏嵌入式的工作了","createdAt":"2024-04-25T11:25:11"},{"id":"01963dee-43a2-736a-aaa0-9ac7554b87c5","parentId":null,"rootId":null,"fromId":3040,"content":"我也知道济南行情差，也没想到能差这么多","createdAt":"2024-04-25T11:50:27"},{"id":"01963dee-444b-7216-8d90-9cd8b353b9e1","parentId":null,"rootId":null,"fromId":875,"content":"降薪一般比较正常，济南社保公积金交的底，基本没有年终奖，周六大小周比较正常","createdAt":"2024-04-25T12:50:37"},{"id":"01963dee-448f-7338-9740-64babde8a578","parentId":null,"rootId":null,"fromId":333,"content":"很正常 这边工资标准就这样了 跟你从哪回来没关系","createdAt":"2024-04-25T14:45:23"},{"id":"01963dee-44d3-721d-b182-0e75a55f32a9","parentId":null,"rootId":null,"fromId":3684,"content":"统本，前端19年毕业，去年夏季从南方新一线回济南，薪资降幅差不多35%左右","createdAt":"2024-04-25T15:32:20"},{"id":"01963dee-43a6-7198-b0b9-9dede3fb5a8d","parentId":null,"rootId":null,"fromId":3663,"content":"又看到一个教别人做人的，大师你好","createdAt":"2024-04-25T20:22:09"},{"id":"01963dee-4447-722b-9912-b64616a1436b","parentId":null,"rootId":null,"fromId":576,"content":"去年火热的嵌入式开发培训，培训完即失业。。。","createdAt":"2024-04-26T09:22:04"},{"id":"01963dee-43ab-7127-8d01-8448a2dbcaa7","parentId":null,"rootId":null,"fromId":2407,"content":"只获得了一点存款，别的什么都没有","createdAt":"2024-04-28T09:47:27"},{"id":"01963dee-4517-7299-ad4d-4a6a4b1c0c36","parentId":null,"rootId":null,"fromId":6631,"content":"年龄大了刚回济南，拦腰截断的降幅，还是个外包。天天暴躁的很，薪水我可以勉强接受，但是工作真的很让人暴躁，屎一样的项目代码","createdAt":"2024-04-30T08:44:10"},{"id":"01963dee-455b-7200-a8f4-757a0a1ff309","parentId":null,"rootId":null,"fromId":3183,"content":"我降50%都找不到，所以干脆没回，再混混看看","createdAt":"2024-04-30T09:01:47"},{"id":"01963dee-43af-7031-b26e-cffb21923028","parentId":null,"rootId":null,"fromId":3183,"content":"一线6年从0混到了车房老婆存款，够本了嘻嘻","createdAt":"2024-04-30T09:04:01"}]