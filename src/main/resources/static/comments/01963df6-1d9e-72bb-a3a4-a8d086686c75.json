[{"id":"01963df6-1e01-713d-a50f-46286ac85730","parentId":null,"rootId":null,"fromId":1391,"content":"鲁软外包。火车站东泰","createdAt":"2025-01-07T20:33:41"},{"id":"01963df6-1e49-73fa-9ee8-112353c34a7b","parentId":null,"rootId":null,"fromId":875,"content":"外包","createdAt":"2025-01-07T20:42:54"},{"id":"01963df6-1e44-736c-ab57-a2e5c22b6b1f","parentId":null,"rootId":null,"fromId":21821,"content":"里面待遇应该不怎么样吧，而且裁员风险很大？","createdAt":"2025-01-08T10:08:52"},{"id":"01963df6-1e8d-7142-b313-b25045fd175d","parentId":null,"rootId":null,"fromId":22600,"content":"凡是外包到鲁软的真心建议别去，我就是从里面被恶心出来的，迟到一分钟扣半天工资，天天东泰8.30打卡 8点人排队的都快到大楼外面了，不加班就pua你各种毛病，想办法裁你，只要你每天框框加班那不会裁你，咱就是说命不是命了","createdAt":"2025-01-10T09:09:07"},{"id":"01963df6-1ed1-733d-9ee8-810972b7d684","parentId":null,"rootId":null,"fromId":2246,"content":"现在的外包，有多远躲多远。先不说待遇，现在不比以前，以前外包，项目完了，人留着干下一个，现在是，项目完了，人都裁了","createdAt":"2025-01-10T16:46:10"},{"id":"01963df6-1f15-7278-ac0c-eb9e944d0d25","parentId":null,"rootId":null,"fromId":1591,"content":"这个公司21年的时候待过，社保医保公积金260元，最大榨取个人价值。","createdAt":"2025-01-13T16:22:04"},{"id":"01963df6-1f5b-738a-8dca-c87ee77baf58","parentId":null,"rootId":null,"fromId":21481,"content":"怎么样？去了吗","createdAt":"2025-01-23T15:52:11"},{"id":"01963df6-1fa7-701c-a295-c8c1188aba72","parentId":null,"rootId":null,"fromId":21821,"content":"应该没过，没后续了","createdAt":"2025-01-24T10:07:53"}]