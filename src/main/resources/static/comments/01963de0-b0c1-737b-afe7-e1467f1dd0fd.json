[{"id":"01963de0-b129-72bb-8996-b00231da4041","parentId":null,"rootId":null,"fromId":875,"content":"咋呼什么，去北京薪资直接翻倍，就问你敢不敢","createdAt":"2023-03-27T12:02:37"},{"id":"01963de0-b16e-722c-9675-a420763651de","parentId":null,"rootId":null,"fromId":2897,"content":"你厉害赶紧去","createdAt":"2023-03-27T14:04:44"},{"id":"01963de0-b1b5-72f4-9770-93000522f295","parentId":null,"rootId":null,"fromId":2241,"content":"一楼这弱智玩意 北京公司都是慈善家是吧","createdAt":"2023-03-27T14:49:08"},{"id":"01963de0-b1fc-720d-b208-333e600c21bb","parentId":null,"rootId":null,"fromId":333,"content":"三年四年也不好找   招聘软件上我翻了一圈就没一个我心动的 说到底 还是企业招人少了+前端人太多","createdAt":"2023-03-27T14:53:12"},{"id":"01963de0-b247-70ff-b8b6-047f0c0bd733","parentId":null,"rootId":null,"fromId":576,"content":"小小前端，也敢猖狂","createdAt":"2023-03-27T15:22:10"},{"id":"01963de0-b28b-739a-9af0-1504c7cdaf7a","parentId":null,"rootId":null,"fromId":1656,"content":"前端后端一个样，人多","createdAt":"2023-03-27T15:50:27"},{"id":"01963de0-b2cf-71c3-95d9-4217317728a3","parentId":null,"rootId":null,"fromId":185,"content":"不只是前端，都一样","createdAt":"2023-03-27T17:56:22"},{"id":"01963de0-b317-73cf-9f1c-07c288134766","parentId":null,"rootId":null,"fromId":2125,"content":"两三年前在济南满满的招前端的，现在招人的不多，好公司更少，一般都是外包。","createdAt":"2023-03-28T13:49:06"},{"id":"01963de0-b35c-73ab-8984-5fd6e10a1dcb","parentId":null,"rootId":null,"fromId":2958,"content":"都一样，说点有格局的，互联网泡沫太多，全球都在去泡沫，疫情后小微企业倒闭的太多，中大型企业以及国企都依靠政府项目存活。上层处于新旧交替阶段，相应的扶持政策还不明朗，就说这么多，没事的提升自己，刚入行、刚培训出来的觉得卷不动就趁早转行，互联网之前野蛮生长，随便都能拿个高薪的时代已经结束了","createdAt":"2023-03-28T18:10:51"},{"id":"01963de0-b39f-73cf-b768-c8dea275dfc2","parentId":null,"rootId":null,"fromId":2958,"content":"补充9楼，但是全国的就业环境不容乐观，我问了问几个伙计，深圳 成都 北京都很难找工作，不限于高级别的架构师，就算是技术过关，薪资给的一定比跳槽前低，政策方面，目前房地产、互联网全面熄火，大会刚开完，人员调整都很大，很多部门的负责人暂时留任，就是为了平稳的交接，避免卸任后一地鸡毛\n千言万语一句话：目前大环境差，只能苟着，至于苟到什么时候能好转，没人说得准，央媒天天批判”孔乙己“文化，鼓吹摆地摊，可见就业恶化到什么程度了","createdAt":"2023-03-28T18:20:58"},{"id":"01963de0-b3e5-7080-bd2f-621017c02ec9","parentId":null,"rootId":null,"fromId":557,"content":"9,10楼说的很中肯。点个赞。","createdAt":"2023-03-29T09:10:08"},{"id":"01963de0-b42a-7106-8010-a89ba95912ba","parentId":null,"rootId":null,"fromId":2582,"content":"白搭了，现在根本不招人，我后端三年，现在面试都是面一个后面都有排队面试的，根本白搭了，可以说是非常残酷","createdAt":"2023-03-29T10:04:13"}]