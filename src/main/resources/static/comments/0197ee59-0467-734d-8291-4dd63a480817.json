[{"id":"0197ee90-76a7-705a-a085-a2541e07997d","parentId":null,"rootId":null,"fromId":25694,"content":"4年前在里面工作过，你面的什么岗位？","createdAt":"2025-07-09T17:42:14"},{"id":"0197ee99-128b-71f4-8d46-e9ec1489f0d1","parentId":null,"rootId":null,"fromId":246,"content":"能详细说说吗  还没面 先了解一下","createdAt":"2025-07-09T17:51:38"},{"id":"0197eef5-c26d-7340-a69a-f617c2093e6e","parentId":null,"rootId":null,"fromId":24989,"content":"别去","createdAt":"2025-07-09T19:32:52"},{"id":"0197ef05-61bc-7253-b05f-cd78052b59b0","parentId":null,"rootId":null,"fromId":246,"content":"能说说为啥吗","createdAt":"2025-07-09T19:49:56"},{"id":"0197ef23-5a33-7151-ad65-7d8b3d9ec1ca","parentId":null,"rootId":null,"fromId":25694,"content":"4年前是不行的，现在真不了解","createdAt":"2025-07-09T20:22:40"},{"id":"0197efb6-602e-7221-9389-76549f22eb2d","parentId":null,"rootId":null,"fromId":108,"content":"https://gshmd.vip/register","createdAt":"2025-07-09T23:03:16"},{"id":"0197f1c2-e1ed-702e-a9b2-70579d65a3d6","parentId":null,"rootId":null,"fromId":561,"content":"https://gshmd.vip/posts/0197db59-238d-70cc-83ed-abde35078bab  这不是一个公司吗","createdAt":"2025-07-10T08:36:10"},{"id":"0197f21e-b183-7099-b4a8-71d4d905bcdb","parentId":null,"rootId":null,"fromId":25649,"content":"去面试过，面试体验感很不好，老板一点专业问题不懂，只会问你人生大道理（问我如果马云来他这个公司会如何如何）典型的说教人士，抓住我嘟噜了一个多小时，东问一下，西问一下，可恶心死了，问点基本的福利待遇就说我在舒适圈里出不来！我请问呢，我都出来打工了，肯定看重这些，我真服了","createdAt":"2025-07-10T10:16:27"},{"id":"0197f354-b469-73a2-94ab-b592abd0813a","parentId":null,"rootId":null,"fromId":246,"content":"确实有毛病","createdAt":"2025-07-10T15:55:04"},{"id":"01981233-ee1c-737f-a49a-9b6c106b3417","parentId":null,"rootId":null,"fromId":7706,"content":"蓝桥控股、中科都是一家子，老板徐新，流氓的一批，两口子企业，发工资看老板心情，发多少看老板心情，工资给你拆成两份两个公司发。冬天夏天不开空调，冻死热死，单休。经常招人试用期结束就开走，离职要逼你待够天数，试用期3天，转正后1个月，离职未发工资会给你扣1/3，大家都闭坑吧~","createdAt":"2025-07-16T15:47:29"},{"id":"01981619-c764-7146-8f08-6a4aebc95bdd","parentId":null,"rootId":null,"fromId":25749,"content":"想面测试岗，大家有了解的吗？","createdAt":"2025-07-17T09:57:24"}]