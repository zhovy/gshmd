[{"id":"01963ddc-a9f5-733e-9b9c-761d85858ca5","parentId":null,"rootId":null,"fromId":228,"content":"从六月份到九月份,找个三个多月.太难了","createdAt":"2022-09-26T10:54:13"},{"id":"01963ddc-aa45-7379-8d48-53bf7adb2faa","parentId":null,"rootId":null,"fromId":353,"content":"找工作不难，找好的难","createdAt":"2022-09-26T13:31:50"},{"id":"01963ddc-aa8a-71f0-80c9-d6a448de69f4","parentId":null,"rootId":null,"fromId":1656,"content":"2楼兄弟，我也是找了三个月了，太难了，外包招人都少了","createdAt":"2022-09-26T16:50:34"},{"id":"01963ddc-aace-735b-9bad-d6751f44821b","parentId":null,"rootId":null,"fromId":1811,"content":"真的太难了，现在找工作全是外包","createdAt":"2022-09-26T20:24:04"},{"id":"01963ddc-ab13-7375-9bfa-53d8e04f3a69","parentId":null,"rootId":null,"fromId":1532,"content":"还真是，我从7月份开始找工作，福利待遇好的公司一直在排队面试，待遇差一点的也断断续续有人面，感觉现在竞争蛮大的了，无论怎样，先找个班上着吧，边上班边找工作，找到了再换，上有老下有小真的熬不起。","createdAt":"2022-09-27T11:19:08"},{"id":"01963ddc-ab59-70c8-a087-eeefe801809a","parentId":null,"rootId":null,"fromId":206,"content":"还好吧，毕竟现在入互联网行业的人在增多，但是大环境下互联网公司在减少，并且发不出薪资的公司又屡见不鲜，竞争压力肯定是有的，不过自己有能力到哪都没问题，各位友友加油。","createdAt":"2022-10-11T13:58:08"},{"id":"01963ddc-aa40-7328-902b-a8ca33341612","parentId":null,"rootId":null,"fromId":4020,"content":"我本来打算找好下家我就走，找了三个月每一个感觉满意的，反而是坑比公司都让我去面试","createdAt":"2023-07-10T14:40:18"}]