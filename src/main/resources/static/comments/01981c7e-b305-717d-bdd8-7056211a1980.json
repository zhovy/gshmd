[{"id":"01981c9d-0c11-71bc-831f-5230df6f4b21","parentId":null,"rootId":null,"fromId":1164,"content":"伙计，现在过的有点艰难吗，别灰心，咋过不是过","createdAt":"2025-07-18T16:18:31"},{"id":"01981ca1-8cbb-73d2-817b-79d7c8eb4834","parentId":null,"rootId":null,"fromId":25906,"content":"你说的这种情况，个人感觉最低标准家庭月收入30k吧。","createdAt":"2025-07-18T16:23:26"},{"id":"01981ca3-a058-725a-8c8f-4cc0f53ced76","parentId":null,"rootId":null,"fromId":460,"content":"好的","createdAt":"2025-07-18T16:25:42"},{"id":"01981cba-7582-72cb-91a0-85a1d33d325a","parentId":null,"rootId":null,"fromId":22972,"content":"首先要全款买房，然后再谈衣食无忧","createdAt":"2025-07-18T16:50:38"},{"id":"01981cbf-5f5a-724f-bf51-6e8cc1e5d1c6","parentId":null,"rootId":null,"fromId":460,"content":"我说的无贷款 就是没有房贷啊 你看没看全啊","createdAt":"2025-07-18T16:56:00"},{"id":"01981cc0-9412-7333-aeda-c86583e48676","parentId":null,"rootId":null,"fromId":25908,"content":"一个月至少1.5w","createdAt":"2025-07-18T16:57:19"},{"id":"01981cdb-16b9-727d-9124-00190f924847","parentId":null,"rootId":null,"fromId":23684,"content":"也就创业的能达到，安稳上班的不多","createdAt":"2025-07-18T17:26:17"},{"id":"01981d0c-8677-7327-a712-2c9d4b3a21ef","parentId":null,"rootId":null,"fromId":24615,"content":"这种一般是国企高管或者小老板，开个超市或者xx店铺，某些行业的销售，或者经常出国出差的人","createdAt":"2025-07-18T18:20:16"},{"id":"01982a73-43c8-71e8-8423-471a61ef74d8","parentId":null,"rootId":null,"fromId":22024,"content":"为啥要二胎，一胎不行吗","createdAt":"2025-07-21T08:47:33"},{"id":"01982a74-340e-711f-9dfc-b643f3e80385","parentId":null,"rootId":null,"fromId":460,"content":"人家有条件 为什么不要","createdAt":"2025-07-21T08:48:35"},{"id":"01982a74-a1ef-7276-b432-0a549104e84c","parentId":null,"rootId":null,"fromId":22024,"content":"没有贷款是和月薪无关的前提吗？","createdAt":"2025-07-21T08:49:03"},{"id":"01982a75-3c9c-72ad-8bbd-4cd37dddc3d6","parentId":null,"rootId":null,"fromId":22024,"content":"都问出问题来了，不一定有条件啊","createdAt":"2025-07-21T08:49:43"},{"id":"01982a78-a6d2-7245-b541-7a29087267b7","parentId":null,"rootId":null,"fromId":22024,"content":"这个和存款多少也有关系，有500w存款就不用考虑月薪多少了。如果不考虑存款，并且已经买房买车无贷，家庭月薪2w就够了，得保证稳定。如果不考虑存款，但是还没买房买车，得看家庭条件咋样，家里不出钱就不好说了，每个人攒钱的速度不一样，即使是一样的工资前提","createdAt":"2025-07-21T08:53:26"},{"id":"01982a85-9d54-72b4-b072-6192b9216818","parentId":null,"rootId":null,"fromId":24162,"content":"买房100w左右（按低的来的）  买车咱们算15个w（普通人挺不错的车了）        无贷款相当于 首先掏出100+w 存款 （这个基本很少能直接掏那么多把！，很多的话就是我穷）起码小生意做的还挺好的。  再来谈孩子， 2个孩子    这个等上学 起码月薪得1.5w把（应该不够，看教育投入了）。 个人见解，如有错误可能是个人认知问题。希望大家多科普。。。","createdAt":"2025-07-21T09:07:36"},{"id":"01982a87-3aa7-720a-92f0-4d19445f7627","parentId":null,"rootId":null,"fromId":24162,"content":"我觉得房子大家目前还是贷款的多。","createdAt":"2025-07-21T09:09:22"},{"id":"01982ff0-e4e1-70ea-91f4-d1dd46c4790a","parentId":null,"rootId":null,"fromId":23701,"content":"看区域吧，如果在城西城北，房价低一点，100w以内能有很多选择（三室），无贷款+2胎，家里如果能给50w，感觉2w差不多吧，就算有贷款几年也就还的差不多了，家里不能帮衬的话感觉要月入3w\n城东感觉100w买不到，三室至少150w起，月薪要多5k以上","createdAt":"2025-07-22T10:22:53"},{"id":"0198301e-23c9-7301-bfe9-069464c478a9","parentId":null,"rootId":null,"fromId":25953,"content":"富有富的过法，穷有穷的过法","createdAt":"2025-07-22T11:12:18"}]