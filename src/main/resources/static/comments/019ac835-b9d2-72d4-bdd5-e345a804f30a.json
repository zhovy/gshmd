[{"id":"019ac842-5724-70af-9e1e-1ace2eec3959","parentId":null,"rootId":null,"fromId":23888,"content":"何意味","createdAt":"2025-11-28T10:19:42"},{"id":"019ac84d-1f5a-718d-8563-f733cd3737e2","parentId":null,"rootId":null,"fromId":27800,"content":"让我入职浪潮的时候心里好受一点","createdAt":"2025-11-28T10:31:28"},{"id":"019ac84d-74ef-73f4-b4e1-b9cadaf6d79f","parentId":null,"rootId":null,"fromId":557,"content":"1. 有面子（能装逼吹牛）\n2. 不拖欠工资","createdAt":"2025-11-28T10:31:50"},{"id":"019ac852-8370-7147-a899-103d17c3a84d","parentId":null,"rootId":null,"fromId":22250,"content":"点把火把园区烧了","createdAt":"2025-11-28T10:37:22"},{"id":"019ac860-2c27-7387-b04d-ef42e372c30c","parentId":null,"rootId":null,"fromId":22250,"content":"浪潮浪潮，业界最强。\n工位常亮，键盘声狂。\n扣分无妨，命都硬扛。\n浪潮儿郎，生来就刚。\n\n经十路上，尽是潮郎。\n省立在旁，冷光透墙。\n加班太猛，心跳失常。\n抬脚三步，病房在旁。\n\n自嘲牛马，也敢逆浪？\n卷到天亮，使命不降！\n老板豪强，数钞手忙。\n利润飞涨，不见分账。\n\n可怜牛马，每日忙忙。\n一旦失业，全家凉凉。","createdAt":"2025-11-28T10:52:17"},{"id":"019ac861-b60a-73c5-a335-a94c1ee5affc","parentId":null,"rootId":null,"fromId":26964,"content":"好诗","createdAt":"2025-11-28T10:53:58"},{"id":"019ac879-242e-70ef-b73a-de21d886d9c3","parentId":null,"rootId":null,"fromId":24615,"content":"有啥好夸的？在那工作10来年，各种往医院跑，不是这疼，就是那难受","createdAt":"2025-11-28T11:19:33"},{"id":"019acd84-cf9a-722d-996a-d89cf1256c19","parentId":null,"rootId":null,"fromId":926,"content":"还有一点，不是出差，就是在出差的路上","createdAt":"2025-11-29T10:50:24"},{"id":"019acd98-5fb0-7253-a8e7-84b92a0c9c3a","parentId":null,"rootId":null,"fromId":27800,"content":"开发人员吗","createdAt":"2025-11-29T11:11:46"},{"id":"019ad7d3-ea80-7297-8fcb-0dcbabd75e97","parentId":null,"rootId":null,"fromId":22024,"content":"公积金双边 12% （现在一年接近5w）\n发工资稳定，我是 8号\n薪资可以，一年20w+（不算年终）\n办公环境还可以\n有饭补 每天20\n虽然平时加班，但都是熬时间而已，不算很冷，也就到晚8，吃饱饭遛弯到七点，再熬一小时就可以了，比晚9好熬\n但是不稳定，准备再干5年攒够钱就躺平了","createdAt":"2025-12-01T10:53:00"},{"id":"019ad7d4-7016-70fa-a21a-cc056f57d6c5","parentId":null,"rootId":null,"fromId":22024,"content":"另外请假不用走流程，跟领导说一声就行~","createdAt":"2025-12-01T10:53:35"},{"id":"019ad7e7-b905-73e8-8a4b-35901aa114ad","parentId":null,"rootId":null,"fromId":1049,"content":"浪潮信息吧？","createdAt":"2025-12-01T11:14:38"},{"id":"019ad7ef-23d4-72d3-94a9-a2196c2c1c3c","parentId":null,"rootId":null,"fromId":25783,"content":"哪个子公司呀老师","createdAt":"2025-12-01T11:22:45"},{"id":"019ad881-c5f2-7097-83a9-5f507d9c2640","parentId":null,"rootId":null,"fromId":22250,"content":"浪潮之特斯拉分公司","createdAt":"2025-12-01T14:02:54"},{"id":"019ad98d-ef70-728b-827d-779358b13920","parentId":null,"rootId":null,"fromId":22024,"content":"云，信息要比我们强不少~","createdAt":"2025-12-01T18:55:49"},{"id":"019ada83-9c43-70d7-8d26-1e756523ac77","parentId":null,"rootId":null,"fromId":25358,"content":"3","createdAt":"2025-12-01T23:24:09"},{"id":"019adc95-0c0b-719c-88f4-37c55f6d85f2","parentId":null,"rootId":null,"fromId":25332,"content":"子公司之间待遇差距太大了，去到类似软件股份的子公司，就没有这么好的待遇了","createdAt":"2025-12-02T09:02:26"},{"id":"019b1ad4-2151-71e6-8603-4f82d8c2526c","parentId":null,"rootId":null,"fromId":1467,"content":"比上不足比下有余","createdAt":"2025-12-14T11:07:48"}]