[{"id":"01963de1-ab3b-738c-946b-fac43393cd02","parentId":null,"rootId":null,"fromId":3209,"content":"捡些知道的说：可以理解为是联通的外包，联通产互内部编制有限，然后找他们外包，五险一金最低标准吧，公积金一共600好像。加班需要看部门，有的部门轻松。有的会出差，面试有个联通那边的，直接就问接不接受出差。","createdAt":"2023-04-23T08:57:51"},{"id":"01963de1-ab89-72c7-bf23-0c0a76b17e0a","parentId":null,"rootId":null,"fromId":2495,"content":"加。","createdAt":"2023-04-23T12:43:40"},{"id":"01963de1-abd3-7357-83c9-4bcf43862a97","parentId":null,"rootId":null,"fromId":2783,"content":"这家公司还压好几个月的工资","createdAt":"2023-04-24T14:29:30"},{"id":"01963de1-ac17-73fd-96b7-55f3001386c5","parentId":null,"rootId":null,"fromId":3352,"content":"啊、这么狠吗?","createdAt":"2023-04-25T13:57:49"},{"id":"01963de1-ac1b-71cf-a470-d44d3d3c8ed7","parentId":null,"rootId":null,"fromId":3352,"content":"好的好的，谢谢各位大佬","createdAt":"2023-04-25T13:58:05"},{"id":"01963de1-ab85-7209-b784-efff7862ad29","parentId":null,"rootId":null,"fromId":3352,"content":"谢谢","createdAt":"2023-04-25T13:59:45"},{"id":"01963de1-abcf-72aa-9c25-0f1e8cdce7d4","parentId":null,"rootId":null,"fromId":3352,"content":"谢谢谢谢","createdAt":"2023-04-25T13:59:50"},{"id":"01963de1-ac20-7127-9ea1-5ccec1bdfb1f","parentId":null,"rootId":null,"fromId":2968,"content":"1、紧密型外包关系，联通用保时通的名义在招聘\n2、目前top3比较卷的部门，你如果自认为牛逼的话适合长期发展，年终也会比较多（待够一年+以上）\n3、看个人水平和成绩，可以提同不同意另说，时间比较长是真的，78年不至于\n4、保时通发工资\n5、看部门，名义上有一部分没有的\n6、五险基本是全额工资，公积金一共不到600\n7、多少有点","createdAt":"2023-05-05T13:47:08"},{"id":"01963de1-ac63-733f-8e15-0e0c5af1679d","parentId":null,"rootId":null,"fromId":3446,"content":"在招聘，部门确实很卷，加班问题进部门之后看项目组吧，有好有坏","createdAt":"2023-05-06T14:16:21"},{"id":"01963de1-aca7-7094-ac1b-01141b9845c9","parentId":null,"rootId":null,"fromId":21418,"content":"谁知道保时通智家工程师咋样啊？加班严重不。我看还有产品推广销售任务完不成扣钱吗？工资多少不拖欠吗？","createdAt":"2024-07-18T16:42:56"}]