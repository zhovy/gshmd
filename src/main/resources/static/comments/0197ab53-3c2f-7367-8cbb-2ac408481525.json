[{"id":"0197ab56-ef15-709b-aed1-ddcd35c7e8e3","parentId":null,"rootId":null,"fromId":24767,"content":"看哪个项目","createdAt":"2025-06-26T16:24:50"},{"id":"0197ab5f-284b-73fa-9863-51a58750c024","parentId":null,"rootId":null,"fromId":25409,"content":"老兄加个微信啊","createdAt":"2025-06-26T16:33:49"},{"id":"0197ab72-a62a-7117-a376-992fd36d3b09","parentId":null,"rootId":null,"fromId":23205,"content":"看哪个事业部","createdAt":"2025-06-26T16:55:07"},{"id":"0197ab74-9c4a-7088-a2d3-50e953bcc395","parentId":null,"rootId":null,"fromId":24767,"content":"电网信息事业部2","createdAt":"2025-06-26T16:57:15"},{"id":"0197abd1-fb14-72e9-8746-63e5ac9f6aa9","parentId":null,"rootId":null,"fromId":23205,"content":"那最好不去","createdAt":"2025-06-26T18:39:14"},{"id":"0197aed7-7889-7290-be65-ae0a7d05b6da","parentId":null,"rootId":null,"fromId":25417,"content":"不是一直在裁人吗，就算进去了也是周一到周五疯狂加班","createdAt":"2025-06-27T08:44:06"},{"id":"0197af04-d45b-73bc-822b-f530418221f6","parentId":null,"rootId":null,"fromId":7083,"content":"之前是出了名的加班多了，据说九点之前没有走的；另外现在也人员进不来吧，除非按项目外包进，三个月后转人员外包。","createdAt":"2025-06-27T09:33:38"},{"id":"0197af08-74f6-714f-82ab-dda2e662ed4e","parentId":null,"rootId":null,"fromId":24767,"content":"我之前在的那个项目组挺好，鲁软的项目经理人也不错，加班挺多，休息的时间也多；但是疫情之后就变了，换了项目组，去变电那边，天天和鲁软的项目经理干架，干了半年跑路了（PS：我是项目外包，驻场项目经理，公司规定管理人员不能转人员外包，哈哈哈\n）","createdAt":"2025-06-27T09:37:36"},{"id":"0197af80-e6b6-7218-82f2-3fc69a39a7d3","parentId":null,"rootId":null,"fromId":25426,"content":"人员外包有啥好的，限制这么多，感觉还不如项目外包","createdAt":"2025-06-27T11:49:09"},{"id":"0197b179-c4e8-73f7-8f2e-4a549e8011d3","parentId":null,"rootId":null,"fromId":1391,"content":"会毁你简历，项目结束或者不会讨好项目经理，会让你滚蛋的，里面的一些人坏的很","createdAt":"2025-06-27T21:00:36"},{"id":"0197b249-2485-73ba-ac24-7cdb3d439b94","parentId":null,"rootId":null,"fromId":22893,"content":"适合会站队会玩心眼子的人去，老实巴交的尽量别去","createdAt":"2025-06-28T00:47:07"},{"id":"0197ee52-4417-723a-a568-2973ab34a382","parentId":null,"rootId":null,"fromId":22578,"content":"钱到位、受的住就行。如果还想有其他追求，一开始就要远离外包这种身份，年龄大了会很被动。人与人之间的偏见就是从身份不通开始的。","createdAt":"2025-07-09T16:34:18"},{"id":"019c22d0-4fd9-71b1-9d10-62eb7735d3e5","parentId":null,"rootId":null,"fromId":5684,"content":"同感","createdAt":"2026-02-03T17:23:23"},{"id":"019c22d2-94e4-7387-906e-005197325e9d","parentId":null,"rootId":null,"fromId":5684,"content":"避雷人工智能事业部，部门经理是个老女人，一天事情特别多，而且里面要学会讨好项目经理，站好对","createdAt":"2026-02-03T17:25:51"}]