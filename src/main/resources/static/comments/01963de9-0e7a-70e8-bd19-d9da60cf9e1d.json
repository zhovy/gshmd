[{"id":"01963de9-0ee7-7062-bb4c-aa002eeab449","parentId":null,"rootId":null,"fromId":5945,"content":"老哥周六笔试过了？","createdAt":"2023-10-17T15:20:29"},{"id":"01963de9-0f35-71f5-b61c-498e77321080","parentId":null,"rootId":null,"fromId":875,"content":"有编吗","createdAt":"2023-10-17T19:47:13"},{"id":"01963de9-0f88-71ac-8b13-156574cfa5e0","parentId":null,"rootId":null,"fromId":3149,"content":"面过java, 然后他们问我会不会写移动端样式..........","createdAt":"2023-10-19T10:35:46"},{"id":"01963de9-0f7b-70f0-89e1-5cb942a70d26","parentId":null,"rootId":null,"fromId":6523,"content":"什么编啊？内部招聘？","createdAt":"2024-03-08T17:47:53"},{"id":"01963de9-0fdc-71ee-b472-b1259e979915","parentId":null,"rootId":null,"fromId":6039,"content":"国核信息和中国电投是一家吗","createdAt":"2024-03-09T15:05:52"},{"id":"01963de9-1021-7302-8095-687be9c33e0c","parentId":null,"rootId":null,"fromId":5851,"content":"国电电投的子公司","createdAt":"2024-03-12T16:29:44"},{"id":"01963de9-0f7f-72d7-966c-e7af00234fb3","parentId":null,"rootId":null,"fromId":5851,"content":"校招，不清楚","createdAt":"2024-03-12T16:30:07"},{"id":"01963de9-0f2c-724b-8bc5-244627db9088","parentId":null,"rootId":null,"fromId":5851,"content":"催一催hr,问的他","createdAt":"2024-03-12T16:30:49"},{"id":"01963de9-0fd1-7251-aa4c-b4a4a50a628d","parentId":null,"rootId":null,"fromId":5851,"content":"校招问是八股+项目+校园班干部经历","createdAt":"2024-03-12T16:31:47"},{"id":"01963de9-1025-73a8-84e9-b118ec9c9b5f","parentId":null,"rootId":null,"fromId":5851,"content":"国家电投的子公司，上面的回复打错字了","createdAt":"2024-03-12T16:32:44"},{"id":"01963de9-1029-7012-b3a7-26345966dd38","parentId":null,"rootId":null,"fromId":6039,"content":"之前21年面过国家电投的架构师，不巧的是1面技术的领导好像要走，2面时候又换了一个京东过来的的技术面试官针对简历上写的问了几个问题，最好是把写在简历上的自己都理清楚；2面hr，几个领导，技术面试官大概五六个人坐对面，当时有点紧张，在出差问题我回的很硬，不接受长期出差，最终是没通过","createdAt":"2024-03-12T16:56:55"},{"id":"01963de9-0f31-7183-b1aa-b971b123f6bc","parentId":null,"rootId":null,"fromId":7559,"content":"入职了吗，朋友","createdAt":"2024-10-11T17:20:55"},{"id":"01963de9-0f83-7321-b07d-2c12c2e83d20","parentId":null,"rootId":null,"fromId":7559,"content":"入职了吗，朋友","createdAt":"2024-10-11T17:21:09"},{"id":"01963de9-0fd8-72ae-84d9-f107971c99fd","parentId":null,"rootId":null,"fromId":7559,"content":"入职了吗，朋友，我也通过了面试在等offer","createdAt":"2024-10-11T17:21:41"},{"id":"01963de9-102e-7203-83ff-5d8f84044df2","parentId":null,"rootId":null,"fromId":7559,"content":"入职了吗，朋友，我也通过了面试在等offer","createdAt":"2024-10-11T17:21:52"},{"id":"01963de9-1036-71cd-b2ff-d62a65b83783","parentId":null,"rootId":null,"fromId":6035,"content":"说实话，也不能说是国电投的子公司，这个公司性质，怎么说呢，略有复杂。但是，之前我在的时候，除了工资不高，其他算不错。","createdAt":"2024-10-12T16:21:56"},{"id":"01963de9-107c-72c0-bf7d-6e318c2ee66f","parentId":null,"rootId":null,"fromId":7559,"content":"说是国电投三级子公司，另外年终奖几薪啊","createdAt":"2024-10-14T14:27:05"},{"id":"01963de9-1032-7069-b5cc-a4d6e3c4a841","parentId":null,"rootId":null,"fromId":6035,"content":"国电投下面的国家核电下属的山东院下属的三产公司，我觉得这样定义比较准确一些。如果准备入职，就当它是个私企即可。","createdAt":"2024-10-16T10:26:20"},{"id":"01963de9-1080-7245-afaf-8ede5fe90de1","parentId":null,"rootId":null,"fromId":6035,"content":"国电投下面的国家核电下属的山东院下属的三产公司，我觉得这样定义比较准确一些。如果准备入职，就当它是个私企即可。","createdAt":"2024-10-16T10:26:28"},{"id":"01963de9-1085-723b-91b5-f33aa0034e47","parentId":null,"rootId":null,"fromId":21010,"content":"工资不得算年薪？ 详细说说怎么好法呗  为啥离开呢","createdAt":"2024-10-29T09:48:22"},{"id":"01963de9-1089-73df-b5e3-fd5cb2a40ac9","parentId":null,"rootId":null,"fromId":6035,"content":"你想多了，兄弟。我估计，现在，工资也不会多高，但是，也没那么多膈应的事。当初离开，是很多年前的事情了，那时候，国核貌似都不需要你们这批IT精英，做SIS，做MIS，做系统集成，做控制。个人对国核没有什么可吐槽的，中规中矩，放到济南，肯定不算差公司。要说拿年薪，我不信。能拿到大院身份的话，有希望拿年薪。但是，大院身份，对于社会招聘的人员来说，应该是痴人说梦。","createdAt":"2024-10-29T13:54:32"},{"id":"01963de9-108d-7233-a1e8-40e8c0bc4704","parentId":null,"rootId":null,"fromId":22324,"content":"请问您说的大院身份指的是什么呀？应届生在面这个公司 不太了解?","createdAt":"2024-11-25T20:37:26"}]