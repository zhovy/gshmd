[{"id":"01963dd2-86f2-7302-a622-e748733faecc","parentId":null,"rootId":null,"fromId":141,"content":"公司就几个人，天天画饼，聚餐都是找最便宜的地方，老板和他的狗腿子连菜都不舍得点。出门全是公交卡，再急的事情也不会打车...","createdAt":"2022-03-15T14:30:51"},{"id":"01963dd2-8737-7286-84a5-faddda445592","parentId":null,"rootId":null,"fromId":1207,"content":"整个公司员工加上管理层和老板 不超过十个人","createdAt":"2022-08-05T19:16:53"},{"id":"01963dd2-8780-70cb-8a74-5448f8e728e6","parentId":null,"rootId":null,"fromId":1591,"content":"济南英网是李辉的，山东互信发展集团也是李辉，公司都是靠做网站的，画大饼，股权，公司挣的钱都让老板带回家了，买了好几套房子，工资是能拖就拖，根本也不想给。","createdAt":"2022-09-07T18:19:13"},{"id":"01963dd2-87c6-7105-a5b7-66cae6780af4","parentId":null,"rootId":null,"fromId":2334,"content":"新人，观察中，这个公司存在15年还是有它的道理吧，听说是因为疫情影响有出现过欠发的情况后来都发了。互信集团产业和子公司还是挺多的，不像楼主说的那样吧，具体不了解。","createdAt":"2023-01-02T21:29:50"},{"id":"01963dd2-880b-7297-8d67-a15e8d5a8dda","parentId":null,"rootId":null,"fromId":5369,"content":"怎么样了?","createdAt":"2023-08-16T09:36:38"},{"id":"01963dd2-880f-7321-89bc-462330e8342a","parentId":null,"rootId":null,"fromId":3183,"content":"啊对对对，农场主奴役黑奴也是有他的道理的吧，听说还给黑奴饭吃呢，不像历史书上写的那样吧，具体不了解。","createdAt":"2023-08-16T09:53:34"},{"id":"01963dd2-8813-7166-b200-afcee6a372ee","parentId":null,"rootId":null,"fromId":274,"content":"13年给他做了一次ui兼职，600多块钱要了得有半年，还要提供发票，这辈子记住这个公司了","createdAt":"2023-08-16T21:44:50"}]