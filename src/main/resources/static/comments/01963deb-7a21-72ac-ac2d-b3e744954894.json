[{"id":"01963deb-7a8f-72f2-ae74-31a4e5c7f75c","parentId":null,"rootId":null,"fromId":6434,"content":"5、从新任一把手上任以后，联盟的考核越来越严格，一些正式员工听说很不习惯，但对外包来说都差不多，之前对外包考核也挺严格的。","createdAt":"2024-02-23T09:42:19"},{"id":"01963deb-7ad5-7266-aec0-f5c8fc5eea00","parentId":null,"rootId":null,"fromId":3383,"content":"怎么考核？那些外包稍微好点，我想进城商行，但现在只能通过外包进","createdAt":"2024-02-23T09:54:29"},{"id":"01963deb-7add-7329-bd6d-f223df3154de","parentId":null,"rootId":null,"fromId":6377,"content":"联盟早就不行了，温水煮青蛙","createdAt":"2024-02-23T09:55:30"},{"id":"01963deb-7b22-7151-a2a7-3005e9bbe19b","parentId":null,"rootId":null,"fromId":3333,"content":"城商正式有什么好处吗，记得五六年前随便进","createdAt":"2024-02-23T09:58:46"},{"id":"01963deb-7b6f-72f1-b434-b9aef358b4fd","parentId":null,"rootId":null,"fromId":6434,"content":"正式稳定呗，薪资高一点，其它看着也没啥了。","createdAt":"2024-02-23T10:00:07"},{"id":"01963deb-7b7c-71cb-bd7e-7fda45822316","parentId":null,"rootId":null,"fromId":2551,"content":"楼主哪个部门的呀，前些年的确好转一点，最近今年人太多了","createdAt":"2024-02-23T10:01:52"},{"id":"01963deb-7ad9-72cb-b748-c794694ae2b3","parentId":null,"rootId":null,"fromId":6434,"content":"这个得看你到时候去哪个部门了，部门领导风格怎么样，只能说现在整体考勤、工时的考核严格，一些部门领导就加码，根本不把底下员工当人看，搞什么工时排名。","createdAt":"2024-02-23T10:01:54"},{"id":"01963deb-7bdd-710d-b948-80b62e783db2","parentId":null,"rootId":null,"fromId":4174,"content":"楼主几年经验，外包费多少","createdAt":"2024-02-23T10:04:44"},{"id":"01963deb-7b73-7140-9b60-83a7d911bee6","parentId":null,"rootId":null,"fromId":2551,"content":"正式的有年终奖吧，还有各种补贴，普通员工每个月交通补贴1K，年终3个月工资加其他奖金","createdAt":"2024-02-23T10:05:05"},{"id":"01963deb-7c37-71ff-81f0-aca16c8ec290","parentId":null,"rootId":null,"fromId":6434,"content":"三年，发到手不到一万。","createdAt":"2024-02-23T10:12:20"},{"id":"01963deb-7bd4-7169-8e51-e7e2777875c5","parentId":null,"rootId":null,"fromId":6434,"content":"现在想法也变了，能转也不转了，感觉正式员工在这种环境下也挺憋屈的。","createdAt":"2024-02-23T10:12:57"},{"id":"01963deb-7c3c-71c6-b7da-c865af730f3f","parentId":null,"rootId":null,"fromId":4174,"content":"进去后是不是涨薪不太好涨","createdAt":"2024-02-23T10:14:03"},{"id":"01963deb-7c40-714b-aac6-c892215791d5","parentId":null,"rootId":null,"fromId":6434,"content":"看领导吧，跟个傻逼领导，就基本不用考虑涨薪了……","createdAt":"2024-02-23T10:14:54"},{"id":"01963deb-7c45-7113-916a-0999abb0a0f4","parentId":null,"rootId":null,"fromId":6434,"content":"反正跟一些外包也好，正式员工也好，沟通下来，普遍对联盟现在加班强度的问题意见很大，其它倒还OK，有些领导在加班这事上确实不当人，很惹众怒","createdAt":"2024-02-23T10:17:39"},{"id":"01963deb-7b77-7024-8aa5-627b6ec7bec7","parentId":null,"rootId":null,"fromId":4174,"content":"这待遇可以啊","createdAt":"2024-02-23T10:25:02"},{"id":"01963deb-7bd9-7105-ab09-8c4d08cd0bcf","parentId":null,"rootId":null,"fromId":2551,"content":"能转的话，最好还是转下，工资基本是平移的，但是多了补贴还有年终奖","createdAt":"2024-02-23T10:31:20"},{"id":"01963deb-7c89-7183-9f43-fcfe20afdea3","parentId":null,"rootId":null,"fromId":6731,"content":"客观的，公正的，一语中的。","createdAt":"2024-02-23T10:36:40"},{"id":"01963deb-7cd0-7239-ad0c-53d84e6f8fb2","parentId":null,"rootId":null,"fromId":6731,"content":"贴主说的这个郑姓领导的部门，我也有所耳闻，大搞特搞工时排名属实666。","createdAt":"2024-02-23T10:37:33"},{"id":"01963deb-7d1e-70c4-8b43-abed284ff75d","parentId":null,"rootId":null,"fromId":6066,"content":"联盟正式工，如果不想干技术，能转到别的岗位吗","createdAt":"2024-02-23T16:55:05"},{"id":"01963deb-7d68-7115-bab0-c5454a6b3040","parentId":null,"rootId":null,"fromId":6731,"content":"那就看你关系硬不硬了","createdAt":"2024-02-23T16:57:00"},{"id":"01963deb-7d6c-731b-9027-f7b8e49d586e","parentId":null,"rootId":null,"fromId":6731,"content":"关系到位，能去联盟的行政部门，我觉得就是济南天花板的工作了","createdAt":"2024-02-23T16:58:31"},{"id":"01963deb-7d71-7231-b281-51990731d8b8","parentId":null,"rootId":null,"fromId":4174,"content":"有缺口的时候可以申请","createdAt":"2024-02-23T17:08:16"},{"id":"01963deb-7d77-73e4-aa11-b23821f8c42b","parentId":null,"rootId":null,"fromId":6066,"content":"卧槽可以","createdAt":"2024-02-23T17:50:31"},{"id":"01963deb-7d15-737f-b9b4-75b1aae4d7c1","parentId":null,"rootId":null,"fromId":6066,"content":"那么怎么造关系呀，娶个高管闺女？可以给我介绍吗","createdAt":"2024-02-23T17:51:51"},{"id":"01963deb-7d1a-7296-8531-a6860c224dee","parentId":null,"rootId":null,"fromId":6066,"content":"评论错楼了","createdAt":"2024-02-23T17:52:30"},{"id":"01963deb-7d7b-70e3-ac6a-abcdff90d933","parentId":null,"rootId":null,"fromId":6066,"content":"那么问题来了，怎么创造关系呢","createdAt":"2024-02-23T18:00:26"},{"id":"01963deb-7d7f-737d-b548-bef7ce878a8e","parentId":null,"rootId":null,"fromId":3665,"content":"外包测试岗怎么样","createdAt":"2024-02-24T14:57:27"},{"id":"01963deb-7dc8-70ea-9a4f-e6ccdc2301f7","parentId":null,"rootId":null,"fromId":1516,"content":"楼主联盟外包有学历要求吗，非全日制本科能进不？","createdAt":"2024-02-25T15:57:10"},{"id":"01963deb-7e0e-732e-bb6f-7b762efa0dc0","parentId":null,"rootId":null,"fromId":6731,"content":"HR声称是只要全日制本科且计算机相关专业。","createdAt":"2024-02-26T08:46:42"},{"id":"01963deb-7dc4-72bc-8c5d-be0ee08f9b8b","parentId":null,"rootId":null,"fromId":6731,"content":"去联盟的外包都差不多，稳定是稳定，其它全看分到什么部门，什么领导手底下去","createdAt":"2024-02-26T08:47:13"},{"id":"01963deb-7e12-7014-aa51-2426b34e6449","parentId":null,"rootId":null,"fromId":5431,"content":"今年卡211了，我刚面完","createdAt":"2024-10-16T22:10:40"}]