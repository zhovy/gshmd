[{"id":"01963df5-96e1-7183-8f53-2fff0d73f974","parentId":null,"rootId":null,"fromId":2572,"content":"这年头去java培训班，相当于49年入国军。有去java培训班的钱，还不如报个考公考编培训班","createdAt":"2024-12-19T14:54:09"},{"id":"01963df5-9726-72a0-b080-4413d665180c","parentId":null,"rootId":null,"fromId":1401,"content":"其实还可以，就是现在这行情就业形势不怎么好，如果能找到工作不建议去培训，可以自己在工作中和下班后学。\n\n再就是如果要去培训，培训完后不要参加易途内部的工作，都是外包，短的俩三月结束，然后又要继续面试，不想到处奔波记得自己找个正式工作","createdAt":"2024-12-19T15:03:47"},{"id":"01963df5-976f-7112-9ad4-7adfba810729","parentId":null,"rootId":null,"fromId":1372,"content":"本人13年前从易途培训出来的，易途还是可以的。不过你要想好，就算培训机构再好，现在的市场行情已经不是当年了。工作太难找以及做java的太多了。","createdAt":"2024-12-19T15:46:24"},{"id":"01963df5-97c0-7043-9d49-0f47a2f6afec","parentId":null,"rootId":null,"fromId":5987,"content":"完全没有用，现在学java完全没有用，要么考公考编，要么学点工科的技术还能好点儿，互联网已经死路一条了","createdAt":"2024-12-19T16:12:06"},{"id":"01963df5-9809-71e3-b4d8-e19fc2f97e7b","parentId":null,"rootId":null,"fromId":7780,"content":"还培训呢哥们，这行情你投投简历看看情况吧","createdAt":"2024-12-20T08:54:44"},{"id":"01963df5-984e-7146-af5b-aee30e725e5c","parentId":null,"rootId":null,"fromId":6371,"content":"没啥用，现在行情那么不好，12月份齐鲁软件园明显吃饭的都减少了一半。互联网已经不行了，还是拿这钱去考公更划算","createdAt":"2024-12-20T11:07:24"},{"id":"01963df5-97b3-733b-b71d-80347841f1ef","parentId":null,"rootId":null,"fromId":3319,"content":"还在工作吗 老哥","createdAt":"2024-12-20T13:42:00"},{"id":"01963df5-9898-7041-9962-7e5f7931e645","parentId":null,"rootId":null,"fromId":3572,"content":"现在用工作的都找不到工作更何况培训出来的，应届生应该多关注下各大国企招聘，比如银行、电网、烟草，还可以参加国考、省考，尤其国考面向应届生的岗位多而且计算机相关专业又是考公大类岗位多，这才是应届生该做的事","createdAt":"2024-12-20T14:45:15"},{"id":"01963df5-97b7-7142-9535-40d1833cc98f","parentId":null,"rootId":null,"fromId":258,"content":"我是15年的，易途确实还可以","createdAt":"2024-12-20T17:58:11"},{"id":"01963df5-98e1-7260-bdbc-37d1f3493e93","parentId":null,"rootId":null,"fromId":258,"content":"我是15年的，易途培训确实还可以，但是现在这环境 程序员也不好找工作","createdAt":"2024-12-20T17:59:06"},{"id":"01963df5-98dc-731f-8637-ec9b94463956","parentId":null,"rootId":null,"fromId":22481,"content":"现在都快元旦了基本都结束了吧。或者等明年？那中间这段时间做什么？","createdAt":"2024-12-20T19:28:47"},{"id":"01963df5-9928-7255-8fca-bf3ab201da0c","parentId":null,"rootId":null,"fromId":3671,"content":"49年入国军，别花这个钱了，实在想进这个行业，自己花点时间自学一下","createdAt":"2024-12-21T13:57:09"},{"id":"01963df5-9924-7180-b7af-6c2befbc76d9","parentId":null,"rootId":null,"fromId":6458,"content":"ET多少？现在去哪了？","createdAt":"2024-12-24T10:14:34"},{"id":"01963df5-97bc-709b-abac-618b96f2c924","parentId":null,"rootId":null,"fromId":21796,"content":"我18年的  易途还是挺良心的","createdAt":"2024-12-24T15:18:19"},{"id":"01963df5-996b-7202-b181-322ba9621ccf","parentId":null,"rootId":null,"fromId":3263,"content":"我达内培训的，推荐达内","createdAt":"2024-12-26T15:18:50"},{"id":"01971c44-d5ef-72e3-b42e-2fa17688f4c6","parentId":null,"rootId":null,"fromId":4366,"content":"很好啊，没人坑，进来吧。努力就行，不努力就别来了；进来后就是易家人了。有困难了把印章亮出来，就会有附近的师兄师弟帮你。","createdAt":"2025-05-29T21:39:22"},{"id":"01994799-3814-7327-b415-77a6ce2922a4","parentId":null,"rootId":null,"fromId":5624,"content":"易途出品必属精品","createdAt":"2025-09-14T17:40:47"}]