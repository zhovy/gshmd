[{"id":"01963ddd-f597-7363-b534-b7c0c8f2b89f","parentId":null,"rootId":null,"fromId":2276,"content":"薪资结算不是下个月中旬，是上旬，一周吧","createdAt":"2022-12-13T13:05:37"},{"id":"01963ddd-f5dc-7073-b2d3-4cc9f01de99a","parentId":null,"rootId":null,"fromId":1589,"content":"南蛮子就是陶虹，老色批；印象最深的一句话，怎么现在的年轻人不喜欢加班了呢；公司挺好，就是它垃圾。","createdAt":"2023-01-06T17:12:28"},{"id":"0197b44a-66e1-70f4-a525-04b8c576b080","parentId":null,"rootId":null,"fromId":25423,"content":"您好，还在爱福迪吗，销售岗位怎么样，人员流动大不大，刚成立的蝾螈电子商务怎么样","createdAt":"2025-06-28T10:07:44"},{"id":"0197bc09-d0d1-72b9-a36e-ff9ba1ba76bd","parentId":null,"rootId":null,"fromId":22893,"content":"都搞成这个样子了怎么可能还在","createdAt":"2025-06-29T22:14:09"}]