[{"id":"01963dec-6ea3-7059-8a80-df8a129e1c17","parentId":null,"rootId":null,"fromId":1398,"content":"20K，那一个月还能剩多少？?","createdAt":"2024-03-11T23:38:22"},{"id":"01963dec-6ee7-71f1-b6b6-2a3ee37cd5cb","parentId":null,"rootId":null,"fromId":6915,"content":"还完贷款剩10","createdAt":"2024-03-12T00:11:39"},{"id":"01963dec-6eeb-72f0-a332-f0587f48670f","parentId":null,"rootId":null,"fromId":1398,"content":"那就是一年存 12 ，一年就能买个车??","createdAt":"2024-03-12T00:20:57"},{"id":"01963dec-6eef-70a7-babe-cc2c2d7e04d2","parentId":null,"rootId":null,"fromId":6645,"content":"税前还是税后呢  税前20K，然后还完房贷还能剩10K？","createdAt":"2024-03-12T08:30:59"},{"id":"01963dec-6f33-7293-9497-f9ae9f9bd343","parentId":null,"rootId":null,"fromId":916,"content":"济南的公司很坑的，你做好心理准备","createdAt":"2024-03-12T08:33:06"},{"id":"01963dec-6f77-7204-9b0d-cc6b8fed52f2","parentId":null,"rootId":null,"fromId":3801,"content":"统招本科的话可以要12-15K试试，专科就别回来受气了。","createdAt":"2024-03-12T08:36:37"},{"id":"01963dec-6fbb-7299-a6a8-f8b642bec7f1","parentId":null,"rootId":null,"fromId":4321,"content":"我是深圳回来的，之前18k，回到济南国企给11k，私企12k，外包14k，去年年初面试的，最后去了国企，公积金交的高一些，我是5年经验的，给你参考一下","createdAt":"2024-03-12T08:40:04"},{"id":"01963dec-6ffe-73c8-9006-f825acf0a4ac","parentId":null,"rootId":null,"fromId":3892,"content":"老哥，啥样的国企啊？您是什么学历？","createdAt":"2024-03-12T08:42:05"},{"id":"01963dec-7007-71e1-912e-e8974109b8e0","parentId":null,"rootId":null,"fromId":1049,"content":"卤煮，北京情况如何？","createdAt":"2024-03-12T08:56:49"},{"id":"01963dec-704b-736a-b38c-6ba7a655041c","parentId":null,"rootId":null,"fromId":1049,"content":"补充一下，本科及以上应该差不多，专科的话挺难，现在到处卡学历","createdAt":"2024-03-12T08:57:46"},{"id":"01963dec-7050-7088-a81d-7533d2a4fb10","parentId":null,"rootId":null,"fromId":6915,"content":"我是专科，但是有个非全本，现在北京有个20k和18k的offer ，还是想回去","createdAt":"2024-03-12T09:25:45"},{"id":"01963dec-7096-7204-9cc9-8993ac892e92","parentId":null,"rootId":null,"fromId":6344,"content":"专科算了吧，别回来了，12k不可能的，10k都到不了","createdAt":"2024-03-12T09:27:43"},{"id":"01963dec-709b-735e-9aef-f8ee99a294c6","parentId":null,"rootId":null,"fromId":6344,"content":"再说现在济南不需要前端了","createdAt":"2024-03-12T09:28:08"},{"id":"01963dec-709f-7159-96a9-c4dd579578ce","parentId":null,"rootId":null,"fromId":6915,"content":"专科这么恐怖吗","createdAt":"2024-03-12T09:34:36"},{"id":"01963dec-70a3-71c5-a632-653dc69fa093","parentId":null,"rootId":null,"fromId":3341,"content":"12 3的找找 能有 但是很少 机会不多  得碰","createdAt":"2024-03-12T09:35:18"},{"id":"01963dec-70a7-73ed-838a-d7a53103f783","parentId":null,"rootId":null,"fromId":3801,"content":"回来你就回焦虑，海投不回，约面试的基本都是外包，这种状态持续上一个月你试试。","createdAt":"2024-03-12T09:38:13"},{"id":"01963dec-70ab-708b-89cb-98ea585a0343","parentId":null,"rootId":null,"fromId":6915,"content":"北京也好不哪去，全是在外包","createdAt":"2024-03-12T09:39:41"},{"id":"01963dec-70af-7158-a6a3-6ac145683d0f","parentId":null,"rootId":null,"fromId":3801,"content":"北京至少能找到工作，我周围几个专科被裁了之后直接是失业状态了。","createdAt":"2024-03-12T09:51:28"},{"id":"01963dec-70b4-738d-849b-96029c7ea256","parentId":null,"rootId":null,"fromId":6915,"content":"北京本科也找不到工作，这玩意就是看运气","createdAt":"2024-03-12T11:01:50"},{"id":"01963dec-70b8-714c-ab98-fcb911ce3877","parentId":null,"rootId":null,"fromId":6742,"content":"别回来，就说这么多","createdAt":"2024-03-12T11:09:09"},{"id":"01963dec-70fc-7213-82e4-f92ac41a1fd3","parentId":null,"rootId":null,"fromId":875,"content":"12k私企差不多，不过公积金济南私企一般每月就一百块，社保最低，过年没年假，周六一般要上班，不给钱，私企都没有餐补，晚上一般都加班到七八点，回济南图啥呢你","createdAt":"2024-03-12T11:14:39"},{"id":"01963dec-713f-736e-8ea3-0b037629610d","parentId":null,"rootId":null,"fromId":6915,"content":"北京留不下，在济南买了房，早晚要回去","createdAt":"2024-03-12T11:36:21"},{"id":"01963dec-7144-7289-a5c7-54fd01efc97f","parentId":null,"rootId":null,"fromId":875,"content":"在北京找个好工作，全额缴纳公积金的，然后月供济南的房子，房子下来租出去，每月再赚3500","createdAt":"2024-03-12T12:40:17"},{"id":"01963dec-7148-7309-b3e6-5bef08663619","parentId":null,"rootId":null,"fromId":1049,"content":"北京干不动了，再回济南，现在等你回来了，你真的会后悔，只能说这么多了，良言难劝","createdAt":"2024-03-12T13:11:20"},{"id":"01963dec-7178-71a8-b7d0-9812ac280434","parentId":null,"rootId":null,"fromId":333,"content":"还完贷款再回来吧","createdAt":"2024-03-12T13:24:28"},{"id":"01963dec-714c-7154-917b-ac6f7883f7cf","parentId":null,"rootId":null,"fromId":6915,"content":"都是选择，没啥好后悔的，漂着真的不爽的","createdAt":"2024-03-12T13:43:00"},{"id":"01963dec-7151-7189-899d-1425782361ec","parentId":null,"rootId":null,"fromId":6979,"content":"好言难劝该死的鬼，他乐意回就回，回来不爽自己受着下?","createdAt":"2024-03-12T15:00:47"},{"id":"01963dec-7155-71fc-b5e1-c81c17f276b7","parentId":null,"rootId":null,"fromId":6039,"content":"这个看个人选择，如果家庭在这边，以后发展也打算在这边，回来也可以；之前北京和济南来回跑了两年，确实难受","createdAt":"2024-03-12T15:27:52"},{"id":"01963dec-7159-70e4-b9ac-e1ef8592a854","parentId":null,"rootId":null,"fromId":1049,"content":"能挣到钱才是最优解，即使在济南陪着老婆孩子挣不到钱，也一样难受的要死","createdAt":"2024-03-12T16:26:21"},{"id":"01963dec-715d-7116-8d13-47162cd7aef2","parentId":null,"rootId":null,"fromId":6915,"content":"早晚都得回去，也不想两地跑","createdAt":"2024-03-12T16:34:55"},{"id":"01963dec-71be-7161-8d59-917edd0240bb","parentId":null,"rootId":null,"fromId":6915,"content":"济南这么恐怖的吗，说的我心慌，有没有客观评价的，感觉戾气好重","createdAt":"2024-03-12T16:39:45"},{"id":"01963dec-7002-739e-b415-368a2c67a78c","parentId":null,"rootId":null,"fromId":6915,"content":"应该是个不错的本科吧","createdAt":"2024-03-12T16:40:19"},{"id":"01963dec-7162-70a0-9962-ef32d633d9f0","parentId":null,"rootId":null,"fromId":6039,"content":"这个需要自己衡量，如果家里还有点家底，贷款没啥压力，那为啥不能回来；如果是压力很大，就多呆几年，攒点钱；个人感觉年龄越大越不好往后走，类似架构师，主管之类的很少有空缺，到了年龄没有对应岗位可以跳也很尴尬","createdAt":"2024-03-12T17:02:07"},{"id":"01963dec-7166-705c-b115-de1f5ca2049b","parentId":null,"rootId":null,"fromId":6915,"content":"楼上和我想的一样，我也是担心年纪大了 就更不好回去了","createdAt":"2024-03-12T17:04:38"},{"id":"01963dec-716a-71e6-95be-9df96b2d625c","parentId":null,"rootId":null,"fromId":6039,"content":"基本上你觉得差不多的企业招架构师或者高级都冲着双一流，大厂经验，硕士去的，有几家投了不给回，问了几次hr说其实是招硕士，因为很多硕士都在投，但是boss学历要求没改过来","createdAt":"2024-03-12T17:05:03"},{"id":"01963dec-716e-716a-abb9-78008d6b6d56","parentId":null,"rootId":null,"fromId":6039,"content":"自己站在面试官和企业的角度讲，6年和10年以上要的钱差不多的情况下，我更愿意选择年轻的；到了年龄之后，面临老人，小孩各种事情，就算应聘学习劲头和抗压能力说得再好，面试官也难免有疑虑","createdAt":"2024-03-12T17:08:59"},{"id":"01963dec-7173-72b3-8c54-8e0942968b85","parentId":null,"rootId":null,"fromId":6915,"content":"是啊，我已经六年了，现在感觉年纪越大越不好找工作了","createdAt":"2024-03-12T17:55:39"},{"id":"01963dec-7202-7157-9bb7-9ff04e481350","parentId":null,"rootId":null,"fromId":6987,"content":"客观评价，很差","createdAt":"2024-03-12T18:32:10"},{"id":"01963dec-7206-735e-a0db-3a5f7e414b23","parentId":null,"rootId":null,"fromId":6631,"content":"我是去年北京回济南的。说实话挺后悔的，真的是没有对比就没有伤害的，如果之前没待过北京可能也不会感觉到济南的就业环境差以及其他种种。我今年面的几家公司，全部要求会前端。我是后端。","createdAt":"2024-03-12T19:44:24"},{"id":"01963dec-724a-72ac-bb5e-5d1b531074f4","parentId":null,"rootId":null,"fromId":6915,"content":"那我纯前端不会Java 这不没戏了","createdAt":"2024-03-12T21:56:10"},{"id":"01963dec-724f-702d-a284-41207c89746c","parentId":null,"rootId":null,"fromId":2269,"content":"David","createdAt":"2024-03-13T11:45:31"},{"id":"01963dec-7293-71eb-8b13-0b5dfd8851c4","parentId":null,"rootId":null,"fromId":6186,"content":"回济南就是要全能，还得是本科，专科直接GG","createdAt":"2024-03-15T16:09:30"},{"id":"01963dec-72dd-718d-afa3-368c10f0927a","parentId":null,"rootId":null,"fromId":1049,"content":"老哥，回济南了吗，感觉怎么样？","createdAt":"2024-05-24T16:53:20"},{"id":"01963dec-7321-70de-8ada-2900393ab554","parentId":null,"rootId":null,"fromId":7418,"content":"老哥回济南了吗","createdAt":"2024-05-24T17:01:35"},{"id":"01963dec-7372-7053-8f89-e15760c9835a","parentId":null,"rootId":null,"fromId":7437,"content":"肯定能找到的，我去年回来的，目前年包25，我给你的建议就是走内推，市面上招人的感觉都不咋样","createdAt":"2024-05-24T17:47:20"}]