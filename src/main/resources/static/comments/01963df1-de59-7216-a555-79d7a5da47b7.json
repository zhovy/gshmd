[{"id":"01963df1-deca-7107-9d48-a9c7e38206ea","parentId":null,"rootId":null,"fromId":21549,"content":"哥们多大了？比我有魄力，我35+，刚被裁员","createdAt":"2024-08-01T17:21:57"},{"id":"01963df1-df10-7363-bb24-a5bf9bda3192","parentId":null,"rootId":null,"fromId":3450,"content":"33了,不想卷了,没结婚,只有房贷,而且因为提前还了一部分,所以压力不太大,混下这辈子来就行了","createdAt":"2024-08-01T17:25:01"},{"id":"01963df1-df14-7225-9574-805a4abe7dfe","parentId":null,"rootId":null,"fromId":2408,"content":"保安证怎么考的？","createdAt":"2024-08-01T18:05:45"},{"id":"01963df1-df5d-7111-9dd1-911cd1b5d837","parentId":null,"rootId":null,"fromId":2574,"content":"润吧","createdAt":"2024-08-01T19:12:46"},{"id":"01963df1-dfa7-7296-88c6-c58ced3b3cb0","parentId":null,"rootId":null,"fromId":3450,"content":"没钱,润不了","createdAt":"2024-08-01T19:30:43"},{"id":"01963df1-df59-7261-9214-55262f2c31da","parentId":null,"rootId":null,"fromId":3450,"content":"济南保安员证的办理流程主要包括网上办理和窗口办理两种方式。\n\n一、网上办理流程\n\n申请。申请人登录网上办事大厅提出申请，上传电子材料。\n受理。接收受理人员对材料进行预审，在2个工作日之内提出预审意见，作出受理决定。申请人符合申请资格，且材料齐全、格式规范、符合法定形式的，预受理，出具电子版《预受理回执》；申请人不符合申请资格或材料不齐全、不符合法定形式的，接件受理人员不予受理，出具《不予受理通知书》。预受理后，申请人按约定方式自行或邮寄向公安部门服务窗口或业务科室提交纸质材料，接件受理人员当场与网上电子材料审核无误后予以正式受理。\n审查。受理后，审查人员对材料进行审查，在1个工作日内提出审查意见，出具《特殊审查期限告知书》，组织考试特殊审查，作出审查结论；决定人员在所有审查环节完成后60个自然日内作出审查决定。符合审批条件的，予以通过，出具《保安员资格证》；不予通过的，出具《不予通过决定书》。审查过程，发现材料需补正的2个工作日内向申请人提出补正要求，出具《申请材料补正告知书》，申请人按要求补正后重新受理审查。\n领取结果。申请人按约定的方式通过公安部门服务窗口或业务科室或以邮寄的方式领取办理结果。\n二、窗口办理流程\n\n申请。申请人向公安部门服务窗口或辖区社区民警中队警长提出申请，提交申请材料并将申请人到辖区社区民警中录入生物指纹。\n受理。接件受理人员核验申请材料，当场作出受理决定。申请人符合申请资格，并材料齐全、格式规范、符合法定形式的，予以受理；申请人不符合申请资格或材料不齐全、不符合法定形式的，接件受理人员不予受理，出具《不予受理通知书》。申请人材料不符合要求但可以当场更正的，退回当场更正后予以受理。\n审查。受理后，审查人员对材料进行审查，流程与网上办理相同。\n领取结果。申请人按约定的方式到公安部门服务窗口或辖区社区民警中队警长领取办理结果。","createdAt":"2024-08-01T19:32:44"},{"id":"01963df1-dfac-7130-9526-2f51f4544786","parentId":null,"rootId":null,"fromId":875,"content":"开饭馆啊，很挣钱","createdAt":"2024-08-01T19:47:42"},{"id":"01963df1-dffc-715c-a272-2517cbda25f2","parentId":null,"rootId":null,"fromId":3306,"content":"真心的问下，保安现在能给到多少薪资啊，给缴纳五险一金吗，我也想转了，合适真转，有点干不动了","createdAt":"2024-08-01T19:54:32"},{"id":"01963df1-dff7-73ad-813a-61ad2bab69a1","parentId":null,"rootId":null,"fromId":3450,"content":"没本钱","createdAt":"2024-08-01T21:52:20"},{"id":"01963df1-e041-73ec-923a-1a31c921aabd","parentId":null,"rootId":null,"fromId":3450,"content":"我还在找,等上岗了就行了","createdAt":"2024-08-01T21:52:40"},{"id":"01963df1-e046-71ab-b1c9-01039bd85295","parentId":null,"rootId":null,"fromId":875,"content":"中介租房子卖房子，不需要动脑子，躺着数钱","createdAt":"2024-08-01T22:03:34"},{"id":"01963df1-e08f-73e4-852d-790d3594bbd8","parentId":null,"rootId":null,"fromId":2408,"content":"房子一卖，回老家躺平","createdAt":"2024-08-01T23:23:30"},{"id":"01963df1-e0db-71ab-892f-affb67607184","parentId":null,"rootId":null,"fromId":875,"content":"济南两套房，躺平收租子","createdAt":"2024-08-02T07:30:42"},{"id":"01963df1-e08a-7136-b581-d90dd5711986","parentId":null,"rootId":null,"fromId":3450,"content":"要不是我曾经的室友当过中介我就信了","createdAt":"2024-08-02T08:28:45"},{"id":"01963df1-e0e0-70ee-9060-6a0bf58323cb","parentId":null,"rootId":null,"fromId":3450,"content":"卖不上价,现在卖也就五六十万,根本躺不平","createdAt":"2024-08-02T08:29:22"},{"id":"01963df1-e0e4-7077-927e-a9a2a7a04f1a","parentId":null,"rootId":null,"fromId":403,"content":"在济南要想躺平，首先得有套无贷款的房子，手里有100W的存款，这应该是最低要求了吧？","createdAt":"2024-08-02T10:41:47"},{"id":"01963df1-e12c-7313-90dd-3a6b6eaea193","parentId":null,"rootId":null,"fromId":3450,"content":"100w不够,后面通货膨胀+低利率,你的100w购买力会快速缩水","createdAt":"2024-08-02T10:51:53"},{"id":"01963df1-e131-7227-8945-801dededa015","parentId":null,"rootId":null,"fromId":3450,"content":"找到保安工作了,干了一天,只能说,闲的一批,只要能按时发工资就好了,后续有变化会继续更新","createdAt":"2024-08-19T10:51:27"},{"id":"01963df1-e179-720d-a654-89f8938ca330","parentId":null,"rootId":null,"fromId":3892,"content":"一个月多少钱？","createdAt":"2024-08-19T11:20:21"},{"id":"01963df1-e17d-73c4-9724-3f2b6a2c0450","parentId":null,"rootId":null,"fromId":933,"content":"多钱一个月，我也想干","createdAt":"2024-08-19T11:32:57"},{"id":"01963df1-e182-7065-951d-dea92afd93d5","parentId":null,"rootId":null,"fromId":3450,"content":