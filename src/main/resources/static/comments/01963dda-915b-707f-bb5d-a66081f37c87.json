[{"id":"01963dda-91c2-73f2-9d21-a3340b69bf15","parentId":null,"rootId":null,"fromId":872,"content":"初来济南，看了一堆帖子属实有点意外……有没有朋友在银座或者鲁商的，说说情况","createdAt":"2022-07-02T08:12:51"},{"id":"01963dda-9208-735e-92f8-58212f9e2d69","parentId":null,"rootId":null,"fromId":909,"content":"同问鲁商。听说有理财任务和绩效挂钩呢","createdAt":"2022-07-05T17:44:01"},{"id":"01963dda-924d-71d5-b309-ea940924a47f","parentId":null,"rootId":null,"fromId":948,"content":"鲁商系统很多单位具体得分哪一家，在鲁商一卡通淦过，属于养老型公司。","createdAt":"2022-07-12T14:43:44"},{"id":"01963dda-9297-70d0-b77c-d809cc26e909","parentId":null,"rootId":null,"fromId":948,"content":"鲁商是以前的商业厅。\n保留了以前的岗位体系但是都事业编体系和公务员体系都不认。\n我当时就是外聘正科，被人使唤的跟狗一样，拿着勉强糊口的工资，当然公务员工资普涨没我事。\n捐钱的时候：“原来你是正科呀，你应该捐这个数”\n每年两次调薪调岗民主评议……呵呵","createdAt":"2022-07-12T14:48:41"},{"id":"01963dda-9293-702e-9098-13b359ad3330","parentId":null,"rootId":null,"fromId":6162,"content":"待遇咋样啊","createdAt":"2023-11-23T14:26:35"}]