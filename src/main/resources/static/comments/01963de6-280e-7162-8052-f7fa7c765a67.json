[{"id":"01963de6-2880-70d1-a2fe-3248797fa997","parentId":null,"rootId":null,"fromId":1181,"content":"大哥，说重点，说具体","createdAt":"2023-08-11T11:15:54"},{"id":"01963de6-28c4-70a7-9930-8ad3b4d61922","parentId":null,"rootId":null,"fromId":2079,"content":"具体说说","createdAt":"2023-08-11T15:49:08"},{"id":"01963de6-290c-73b6-a27a-8b5fbdb87621","parentId":null,"rootId":null,"fromId":4337,"content":"裁人 给的补偿只有21天的补偿","createdAt":"2023-08-23T22:27:58"},{"id":"01963de6-295a-7183-97f4-3d2d4ecbd9f0","parentId":null,"rootId":null,"fromId":4337,"content":"请假 领导觉得你的理由不合理，就不通过","createdAt":"2023-08-23T22:28:58"},{"id":"01963de6-299e-71e8-9a18-c8e8a4c1feb2","parentId":null,"rootId":null,"fromId":2079,"content":"最近公司怎么样了？","createdAt":"2023-08-31T10:05:41"},{"id":"01963de6-29e7-723d-b54e-04d5af74e9f5","parentId":null,"rootId":null,"fromId":2079,"content":"该公司五险一金比例是多少？","createdAt":"2023-09-05T15:18:09"},{"id":"01963de6-2a3e-7339-a09d-3b7b48f01173","parentId":null,"rootId":null,"fromId":5591,"content":"员工离职率不高，领导层是一周一换，政策一周一边，承诺盖不拖欠，就是从不兑现","createdAt":"2023-09-07T13:29:22"},{"id":"01963de6-2a8c-73c4-aded-a00b35e55254","parentId":null,"rootId":null,"fromId":5593,"content":"9月了，7月的工资还发。领导像是集上批发来的，一周一换，辞退压根没补偿，想仲裁直接威胁。","createdAt":"2023-09-07T13:40:19"},{"id":"01963de6-2ad9-7073-9099-c37da9549ccc","parentId":null,"rootId":null,"fromId":5595,"content":"在天际，很幸福、很快乐！领导对员工爱护有加，充分激发员工活力，马上就要上市了，你们不要尬黑了。(▽◕ ᴥ ◕▽)(▽◕ ᴥ ◕▽)(▽◕ ᴥ ◕▽)","createdAt":"2023-09-07T13:48:25"},{"id":"01963de6-2b3d-704d-8ed6-167dd84fab6a","parentId":null,"rootId":null,"fromId":5596,"content":"只有无能的人才会抱怨社会不公平,上天不给你机会;有能力的人则在旁人抱怨时不断丰富自己,擅于寻找机会。天际一定会成功，一定会上市，一定会市值101个亿的","createdAt":"2023-09-07T14:08:08"},{"id":"01963de6-2b81-7190-b952-f0e9749e3ac8","parentId":null,"rootId":null,"fromId":5595,"content":"101亿只是起点，不是终点。TJ Never Die。","createdAt":"2023-09-07T15:13:41"},{"id":"01963de6-2b85-7091-8006-2b81e3e85ea7","parentId":null,"rootId":null,"fromId":5591,"content":"你怕不是 外甥行里的吧","createdAt":"2023-09-07T15:31:16"},{"id":"01963de6-2b21-73d8-9af3-a320f44b39bb","parentId":null,"rootId":null,"fromId":5591,"content":"原来你老板的外甥啊","createdAt":"2023-09-07T15:31:39"},{"id":"01963de6-2b8a-70de-824b-2f6513a0ff7f","parentId":null,"rootId":null,"fromId":5591,"content":"舔狗舔狗舔到最后一无所有","createdAt":"2023-09-07T15:34:31"},{"id":"01963de6-2b26-727d-8c7a-ec3cc26a3d01","parentId":null,"rootId":null,"fromId":5591,"content":"我草，原来真是外甥","createdAt":"2023-09-07T15:34:51"},{"id":"01963de6-2b8f-7191-baf7-71754ed23aa0","parentId":null,"rootId":null,"fromId":5591,"content":"果然这有亲戚不会被扣工资，扣绩效，整天找麻烦","createdAt":"2023-09-07T15:36:05"},{"id":"01963de6-2a84-7010-8100-c94371f884a2","parentId":null,"rootId":null,"fromId":5607,"content":"真押韵啊","createdAt":"2023-09-07T18:01:51"},{"id":"01963de6-2b97-7144-9cb4-798a09210fb8","parentId":null,"rootId":null,"fromId":5668,"content":"瑞康、天际，让你签的任何东西都要慎重，坚决不能签，签了就不认了","createdAt":"2023-09-14T16:47:12"},{"id":"01963de6-2bdc-71df-b0b5-30263832b8da","parentId":null,"rootId":null,"fromId":5668,"content":"李文，宋怀岳；这帮人资一定要小心，做狗 没底线","createdAt":"2023-09-14T16:59:38"},{"id":"01963de6-2951-71f8-8726-3858d63ae874","parentId":null,"rootId":null,"fromId":6090,"content":"不给，说给但是不执行","createdAt":"2023-11-09T15:30:45"},{"id":"01963de6-2c20-70da-b964-24a93d96bdbe","parentId":null,"rootId":null,"fromId":6090,"content":"这是一个无底线、无诚信的公司；诱导签协议、回头就不认了。发布虚拟招聘职位，实际没有，去了也是当枪使得；大家一定慎重。\n人资是杨B 的狗，毫无底线与廉耻可言。23年5月到9月总经理换了五个，人资无数（懂事的进本去了就走，大展身手的人资也没有超过2个月的）。\n大家一定慎重","createdAt":"2023-11-09T15:31:27"},{"id":"01963de6-2c64-734c-9ebf-64c4adc68326","parentId":null,"rootId":null,"fromId":6090,"content":"欺软怕硬的公司。别给他脸","createdAt":"2023-11-16T09:02:12"},{"id":"01963de6-2b2a-73b1-9ea9-f5c007145183","parentId":null,"rootId":null,"fromId":6090,"content":"外甥的狗","createdAt":"2023-11-16T09:04:56"},{"id":"01963de6-2b93-728f-a327-d6fdfcdb55fd","parentId":null,"rootId":null,"fromId":6090,"content":"101 次舔狗","createdAt":"2023-11-16T09:06:01"},{"id":"01963de6-2cac-7058-8ad8-2b47443d015e","parentId":null,"rootId":null,"fromId":6090,"content":"马上到武汉了，在武汉建分公司了；济南可能最后的挣扎了，杨博就是sb天天 更换人资，妻儿不认，很幼稚的一个人","createdAt":"2023-12-14T15:38:05"},{"id":"01963de6-2b2f-71c5-a01f-d8b2bb8a58aa","parentId":null,"rootId":null,"fromId":6090,"content":"这就是天际跟瑞康的狗；看见打死","createdAt":"2023-12-16T14:38:14"},{"id":"01963de6-2a88-71cd-8fdf-edbe3da66cbc","parentId":null,"rootId":null,"fromId":6090,"content":"sb杨博，就是个富二代啃老无赖，公司快搞死了；几个狗腿子  李文、宋怀岳，现在来个刘静；基本也快扛不住了要离职了","createdAt":"2023-12-16T14:40:20"},{"id":"01963de6-2a31-7120-9735-ebdf593dcb03","parentId":null,"rootId":null,"fromId":6304,"content":"按照公司实缴","createdAt":"2023-12-18T20:13:00"},{"id":"01963de6-2b34-71e4-bd76-6187890ac8cc","parentId":null,"rootId":null,"fromId":6090,"content":"狗比给你爹打电话，别在这啰啰","createdAt":"2023-12-24T09:33:23"},{"id":"01963de6-2a35-70b2-be98-19e9aad8fa62","parentId":null,"rootId":null,"fromId":6090,"content":"不给你钱，这谁能受得了","createdAt":"2024-01-20T15:28:53"},{"id":"01963de6-2cf5-7100-a30c-163813dba80a","parentId":null,"rootId":null,"fromId":6090,"content":"已经实施了，业务全被武汉接手了，现在是济南的骨干扶着武汉的干活，然后干掉济南这边的人；为了稳定军心还开会辟谣但是阻止不了济南全员裁员的事实，真恶心，已经没救了","createdAt":"2024-01-28T15:37:40"},{"id":"01963de6-2cfa-71a3-980f-22d76be431ea","parentId":null,"rootId":null,"fromId":6716,"content":"众所周知，老板开公司有两个重要目标：1.赚钱。2.折磨员工。\n二者不分主次。\n现在第一条没做到，以第二条为主要目标。","createdAt":"2024-02-22T11:21:59"},{"id":"01963de6-2d44-724a-8a36-b0ee0d7528bd","parentId":null,"rootId":null,"fromId":6716,"content":"就这几个人的公司   弄了三个不干人事儿的人资   制定各种利己的政策   新修订的员工手册三个人资开会轮流念给员工听   念了三个多小时   念到中午吃饭时间都没人听了   根本记不住都制定了什么内容   员工要把文件发给个人看看   人资狗还不给  还说员工提防着公司呢   公司防员工才防的方方面面呢","createdAt":"2024-02-22T11:40:18"},{"id":"01963de6-2d87-7012-9994-5761b2842f75","parentId":null,"rootId":null,"fromId":6090,"content":"想把济南全部干完，然后到武汉了。狗外甥，找狗来咬人，然后杀狗吃肉","createdAt":"2024-02-25T16:03:31"},{"id":"01963de6-2d3f-7162-a9fc-3b598df78d53","parentId":null,"rootId":null,"fromId":6090,"content":"现在就是在做第一条，杨博认为做it  盯着电脑就是不干活，赔钱是开发的原因，不是公司方向错误与无底线的原因（his公司外采都不给人家结账，别的公司都起诉了）","createdAt":"2024-02-25T16:06:11"},{"id":"01963de6-2d8d-701f-87db-fc07d40b613a","parentId":null,"rootId":null,"fromId":6716,"content":"这个叫刘jing的所谓人资总监可搞笑了，大早晨在会议室里开会，突然就嗷嗷哭，大声喊叫，大家在外面都听见了，把大家都吓一跳，现在看到她就想笑，缺德事儿不少干，人还挺脆弱","createdAt":"2024-02-26T15:11:41"},{"id":"01963de6-2956-707c-a7d8-181dc82eeff7","parentId":null,"rootId":null,"fromId":6090,"content":"不给的，只会骗，现在公司还在继续折腾人，要到全部把人都赶走，迁都武汉","createdAt":"2024-02-27T10:40:28"},{"id":"01963de6-2dd1-72d1-a565-4b99ec98c0e9","parentId":null,"rootId":null,"fromId":6716,"content":"现在的绩效评定基本上都是扯淡，老实人永远吃亏。不扣分的和加分的的永远的是领导和善搞关系的、胡编乱造工时的，对提高工作积极性毫无意义，评审内容和指标极具幕后操作性，没有公平公正，反而挫伤踏实干活的员工的积极性，垃圾制度，垃圾人资。","createdAt":"2024-03-06T14:11:05"},{"id":"01963de6-2e17-70fb-9100-911ca6109f3e","parentId":null,"rootId":null,"fromId":6090,"content":"现在可以这么形容：地主老财家的傻儿子买了三只狗看着一群牛","createdAt":"2024-03-19T16:08:08"},{"id":"01963de6-2e5c-7027-9d7c-6fd6f80cf6b1","parentId":null,"rootId":null,"fromId":6716,"content":"只要是属于武汉那边的人，什么烂货都能当上管理层，上班打呼噜睡觉，写代码代码不行，管理管理不行，就给自己和自己手底下属于武汉的员工编造工时和任务有一套，沟通也沟通不顺畅，脑子里一团浆糊，手下干活的人还要哄着这么个糊涂蛋领导，一颗老鼠屎坏了一锅粥，这样的人早晚把想好好干活的人逼走，劣币驱逐良币了属于是。","createdAt":"2024-05-16T16:05:27"},{"id":"01963de6-2ea3-7116-a9a4-f3c76851b9ba","parentId":null,"rootId":null,"fromId":6419,"content":"我大天际必定欣欣向荣，研发主管都换成济南的老人了，这还不行么！","createdAt":"2024-07-01T14:49:08"},{"id":"01963de6-2ea8-7370-bca5-d92e5feb04c9","parentId":null,"rootId":null,"fromId":7040,"content":"可不能说领导是糊涂蛋，不然狗子们不愿意；杨b 就是一个sb","createdAt":"2024-09-03T19:36:01"},{"id":"01963de6-2ead-7395-83b1-688ac9c78ca0","parentId":null,"rootId":null,"fromId":7040,"content":"听说搬到 福瑞达大厦了","createdAt":"2024-09-03T19:37:15"},{"id":"01963de6-2a3a-70b7-9646-3197e0c5c74c","parentId":null,"rootId":null,"fromId":21972,"content":"目前社保是全额，公积金从10降低到了百分之五\n最好是不要去，一天天不能安心工作就是各种汇报工作","createdAt":"2024-09-29T16:42:04"},{"id":"01963de6-2b38-7374-ba24-ad3ea877c3cc","parentId":null,"rootId":null,"fromId":21972,"content":"21年谈上市也是李福亮总在的时候，杨博来了就把李福亮搞走了，就因为创业初期俩人不对付","createdAt":"2024-09-29T16:43:21"},{"id":"01963de6-2ef3-72a2-80cc-3a2b135e77a3","parentId":null,"rootId":null,"fromId":22086,"content":"我很多时候纳闷，Yb是不是没有一个正的气场，没有一个正的方向。L和y和y作为二把手内心对于他的所作所为是不是并不认可，有没有听说y私底下跟前销售有联系。另起炉灶的事比比皆是，正主的致命点，是不是二把手最清楚。","createdAt":"2024-10-23T12:55:02"},{"id":"01963de6-2f39-71c6-93ed-bf00d45e1369","parentId":null,"rootId":null,"fromId":7040,"content":"一群猪根本理解不了博总的商业战略；全公司靠博总带着往前走，你们就像是一圈好吃懒做的猪，公司养着你们，你们就应该感谢公司；还在公司搞对立，年后马上干掉你","createdAt":"2024-12-13T17:32:45"},{"id":"01963de6-2f86-7023-ad6e-1b544598616a","parentId":null,"rootId":null,"fromId":6090,"content":"公司已经搬到 福瑞达大厦9楼（东），找了个角落，做黑心事别的公司看不到。员工剩下的不多了。","createdAt":"2025-01-14T11:30:34"},{"id":"0198c683-a3b7-7017-b820-1f85c0cbdaa0","parentId":null,"rootId":null,"fromId":7040,"content":"搬家到福瑞达后怎么样了，有没有出来说说的；新闻报道瑞康总裁被留置调查了；不知道外甥与狗的故事是否还在继续？","createdAt":"2025-08-20T16:06:12"}]