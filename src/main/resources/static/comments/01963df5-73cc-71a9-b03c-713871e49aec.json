[{"id":"01963df5-743b-72fa-b4d2-e5c917ba4b0d","parentId":null,"rootId":null,"fromId":875,"content":"想跳出外包，只能跳出济南","createdAt":"2024-12-15T12:13:31"},{"id":"01963df5-7484-712b-a607-2784568c4224","parentId":null,"rootId":null,"fromId":2408,"content":"要不然呢","createdAt":"2024-12-15T13:08:32"},{"id":"01963df5-74c7-70b1-ae01-775a64a0a625","parentId":null,"rootId":null,"fromId":3333,"content":"能干电网外包不错了，济南大部分都是电网项目，被裁了起码有业务背景以后找相关业务背景的工作好找，那些自研产品冷门业务线一旦被裁员了才是真的完蛋，出来后一点业务背景没有纯靠技术找工作更难","createdAt":"2024-12-16T08:54:37"},{"id":"01963df5-7515-71f8-8101-3f11949e753b","parentId":null,"rootId":null,"fromId":6380,"content":"这地方大部分开发需求都是来自国央企，自然大部分公司都是做这行的了，本土互联网没有排得上号的；不过讲真的，能有这些需求养得起来这些公司已经算是老爷们赏饭吃了，你怎么还挑上了？","createdAt":"2024-12-16T09:15:18"},{"id":"01963df5-7560-7343-bd2f-4a8378b16359","parentId":null,"rootId":null,"fromId":3263,"content":"济南的自研跟外包有区别？有的甚至没外包好","createdAt":"2024-12-16T11:42:11"},{"id":"01963df5-750d-7077-8739-730d20051804","parentId":null,"rootId":null,"fromId":3263,"content":"我现在找工作就是纯技术，由于经常跳槽，业务都不是很了解。","createdAt":"2024-12-16T11:44:17"},{"id":"01963df5-7511-718f-a862-ec86112c6969","parentId":null,"rootId":null,"fromId":3341,"content":"看出来你是混东泰那一片了兄弟","createdAt":"2024-12-17T17:00:02"},{"id":"01963df5-747f-7014-a73d-eb2d95e5624e","parentId":null,"rootId":null,"fromId":22510,"content":"哥，又说到点子上了","createdAt":"2024-12-24T22:13:04"},{"id":"01963df5-755c-72c2-a3ed-e452357a95ab","parentId":null,"rootId":null,"fromId":22510,"content":"哥说的挺实在的，其实还得是北上广大一线，跳出济南才能跳出外包，要么就国企开始混吧","createdAt":"2024-12-24T22:14:41"},{"id":"01963df5-75a2-70aa-b5ce-a71632dd0f57","parentId":null,"rootId":null,"fromId":2122,"content":"山东企业是政府主导的，大企业都是国有控股，其他省份就没有这个问题，所以经济发展慢","createdAt":"2024-12-26T17:20:46"}]