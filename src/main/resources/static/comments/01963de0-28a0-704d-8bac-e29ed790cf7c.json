[{"id":"01963de0-2910-73b5-98ff-176e518cb27c","parentId":null,"rootId":null,"fromId":2598,"content":"嗯~~ 咋说呢，周六反正无效加班半天","createdAt":"2023-03-08T16:37:36"},{"id":"01963de0-2954-7192-8a78-2746d96f32ad","parentId":null,"rootId":null,"fromId":2573,"content":"据说是休一天半 有加班 社保交最低的 试用期不容易过","createdAt":"2023-03-08T16:40:25"},{"id":"01963de0-2999-7390-b7f9-974aebc470e0","parentId":null,"rootId":null,"fromId":1474,"content":"想问下2楼，加班是常态吗？还是忙的时候加班？一般加班到几点？试用期不容易过是怎么不容易过的？","createdAt":"2023-03-08T19:43:36"},{"id":"01963de0-29dd-72ca-87fb-ece230b01e8a","parentId":null,"rootId":null,"fromId":2573,"content":"额，待过几天，领导不走你不能走，卡人会增加试用期，不推荐","createdAt":"2023-03-09T08:12:09"},{"id":"01963de0-2a21-719a-abeb-ce74b5e15295","parentId":null,"rootId":null,"fromId":2598,"content":"在职跑路中，劝告一句，慎入。工资进来多少就是多少永远不会涨（抠鼻），下班晚走个一小时那叫加班吗。。。\n效益好了有个几百的年终奖还是分四个季度给你就是怕你领完钱就跑了，疫情这两年连这都木有","createdAt":"2023-03-09T08:44:27"},{"id":"01963de0-2a67-7224-a597-657084aa4e15","parentId":null,"rootId":null,"fromId":1474,"content":"楼上的朋友可以加我v聊一下吗？","createdAt":"2023-03-09T09:56:14"},{"id":"01963de0-2aac-732c-b7e3-0630019657cc","parentId":null,"rootId":null,"fromId":2573,"content":"你直接去公司面试 不就行了","createdAt":"2023-03-09T10:34:32"},{"id":"01963de0-2af0-718c-aba6-491fc4f29275","parentId":null,"rootId":null,"fromId":2598,"content":"我是5楼的，微信就不加了哈，说多了也不大好，主要看你自己怎么考虑了","createdAt":"2023-03-09T13:27:41"},{"id":"01963de0-2b35-71cb-beaa-480762a8ec8f","parentId":null,"rootId":null,"fromId":1474,"content":"楼上的朋友，我再问一点，五一，十一，端午，春节这种假期公司按国家规定的放假时间放假吗？","createdAt":"2023-03-09T19:52:12"},{"id":"01963de0-2b78-73b6-b716-24e904d887b5","parentId":null,"rootId":null,"fromId":2598,"content":"那得看你项目了，赶上项目上线，大家辛苦辛苦啦，加加班，都小意思。还十分巧妙的躲开节假日当天，因为它三倍工资呀，哈哈哈，和我同一批的同事基本走完了，总之三思就好了?","createdAt":"2023-03-10T08:35:45"},{"id":"01963de0-2bc5-718c-a60c-f1f1a67fca0a","parentId":null,"rootId":null,"fromId":2573,"content":"开会占假期一半 没工资","createdAt":"2023-03-10T08:42:26"},{"id":"01963de0-2c0b-7350-8c19-37cdd22c92fa","parentId":null,"rootId":null,"fromId":2598,"content":"收到面试邀请还想去呢，感谢，避坑了","createdAt":"2023-03-10T13:59:59"},{"id":"01963de0-2c50-729f-8b09-5bcd2f2b35e0","parentId":null,"rootId":null,"fromId":1474,"content":"想问下 周一到周五晚上平时晚上几点下班啊   5点半下班  6点之前能走吗？","createdAt":"2023-03-10T18:11:54"},{"id":"01963de0-2c95-706f-8fb9-992b42776018","parentId":null,"rootId":null,"fromId":2598,"content":"不是五点半下班，是六点下班，能不能走，那你得看领导的了，领导不走你先溜了，不得pua你","createdAt":"2023-03-11T12:40:06"},{"id":"01963de0-2cda-7035-adff-a7745d1df575","parentId":null,"rootId":null,"fromId":1474,"content":"不然8点半到5点半吗？规定是6点下班吗？领导一般几点走，实际上6点半能走吗？","createdAt":"2023-03-11T21:13:39"},{"id":"01963de0-2d1e-71c7-9178-effb8461a4e7","parentId":null,"rootId":null,"fromId":3333,"content":"楼主去了吗，初试和复试都是说的双休呢，但是开发人员不多，就两三个","createdAt":"2023-05-29T10:04:50"},{"id":"01963de0-2d24-7070-8c3d-8ee513df7458","parentId":null,"rootId":null,"fromId":3749,"content":"我去面时说休1.5天，先让看半小时纪录片，岗位说是有php","createdAt":"2023-07-01T16:06:00"},{"id":"01963de0-2bbc-717b-afde-23a1f4448193","parentId":null,"rootId":null,"fromId":3749,"content":"有很多项目吗？不是说开发不多吗？","createdAt":"2023-07-01T16:09:36"},{"id":"01963de0-2d29-71aa-bac2-55df96d1ba42","parentId":null,"rootId":null,"fromId":1712,"content":"我去面试的时候怎么说双休呢，我没有看纪录片","createdAt":"2023-07-04T10:56:47"},{"id":"01963de0-2bc1-704b-8d9d-1a5bb70edbd3","parentId":null,"rootId":null,"fromId":1474,"content":"看这意思应该是几个月前开发多，现在开发少了。我猜有可能是离职了不少。","createdAt":"2023-07-06T09:53:11"}]