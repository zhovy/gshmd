[{"id":"01963ded-f24a-706c-a72d-d6b0061f1f86","parentId":null,"rootId":null,"fromId":6939,"content":"因为公司老板都是资本家，在中国这种环境下多多少少都有点问题，自己去甄别吧，就我个人来说，只要工资给到位，能及时发放，其他的都是小事。","createdAt":"2024-04-17T14:04:53"},{"id":"01963ded-f293-73f2-bf34-bd81adf311f3","parentId":null,"rootId":null,"fromId":7237,"content":"你说的两条基本满足把也算，但是持续性的每天加班到两点三点，第二天正点来，是真的顶不住了，感觉在透支身体","createdAt":"2024-04-17T14:36:43"},{"id":"01963ded-f297-710a-bd5a-a389fc673b13","parentId":null,"rootId":null,"fromId":1492,"content":"这太过分了，两三点了，还正点来！","createdAt":"2024-04-17T14:55:45"},{"id":"01963ded-f29b-720c-a7d4-17a3fb9e29b1","parentId":null,"rootId":null,"fromId":6939,"content":"加班的公司遇到过，持续性加班的公司也遇到过，基本最晚9点差不多了，赶上上线得凌晨，不过第二天上午可以休息，你说的这种情况还真没遇到过。","createdAt":"2024-04-17T16:19:49"},{"id":"01963ded-f2a0-7049-bc68-bd23b6e73cec","parentId":null,"rootId":null,"fromId":1261,"content":"上线那天做到凌晨两点，第二天还不能迟到，换来领导一句辛苦。","createdAt":"2024-04-18T07:17:50"},{"id":"01963ded-f2a3-7358-aac7-fe7d471d18ed","parentId":null,"rootId":null,"fromId":4010,"content":"济南的互联网环境就这样","createdAt":"2024-04-24T09:11:59"}]