[{"id":"01963df6-61ff-73f9-8a1f-4fa58698cfc1","parentId":null,"rootId":null,"fromId":5960,"content":"这不是积成电子吗？","createdAt":"2025-01-15T10:25:24"},{"id":"01963df6-6249-7305-9c84-03b9d9330588","parentId":null,"rootId":null,"fromId":5491,"content":"试用期6K，有项目奖金吗，还是固定工资，后期涨薪怎么定，去了一个地方长期呆着还是随着项目走，工作地需要会开车吗，车补怎么样，因为比较偏，住宿估计也偏，住宿和工作地的往返打车给报销吗？这些都是问题哈","createdAt":"2025-01-15T10:48:14"},{"id":"01963df6-6295-72e7-a41f-cbddfb40963d","parentId":null,"rootId":null,"fromId":22176,"content":"大概是在一个固定省内跟着项目走，交通能报销，其他的不清楚","createdAt":"2025-01-15T14:12:31"},{"id":"01963df6-628d-7316-91b0-b8c96c9f1efe","parentId":null,"rootId":null,"fromId":4171,"content":"根据具体情况 可能会租车，租车钱跟油钱都能报销。不租车打车的话 打车钱也能报。超出部分报备即可。没有项目奖金，出差的话180住宿+90吃饭，张薪是每年会调薪，调薪幅度不定。不是固定一个地方，全国游走，但是每个地方的工作地点都会很偏，因为那个东西建在市内的很少很少。。。","createdAt":"2025-01-15T15:02:30"},{"id":"01963df6-6291-707e-8e01-7458f675933f","parentId":null,"rootId":null,"fromId":4171,"content":"14薪，每年三次过姐夫，五险一金全额交，公积金是7%，有餐补，园区有超市，长期出差的餐补没地方花，可以年终去超市买东西 有米面粮油礼盒啥的。","createdAt":"2025-01-15T15:20:25"},{"id":"01963df6-62d9-732e-b0cd-e02484dd555a","parentId":null,"rootId":null,"fromId":1589,"content":"咋联系","createdAt":"2025-01-16T09:20:43"},{"id":"01963df6-631d-7273-b48f-c2f98292bb1e","parentId":null,"rootId":null,"fromId":22176,"content":"wxid_8z003n2gpkpq22\n微信小号，发我简历给你内推","createdAt":"2025-01-16T15:52:25"},{"id":"01963df6-6321-7307-9b13-c852ec15e990","parentId":null,"rootId":null,"fromId":22176,"content":"工作地点有：山东，内蒙古，陕西，宁夏，甘肃，新疆，湖南，湖北，川渝","createdAt":"2025-01-16T16:45:14"}]