[{"id":"0198e96f-8ef6-7181-8522-ce91fe91a115","parentId":null,"rootId":null,"fromId":460,"content":"我认识的一个 某三甲医院的主任 人家刚从欧洲公费旅游回来 。你要是问他，是不是医疗行业完蛋了，你猜他会咋说？","createdAt":"2025-08-27T10:50:59"},{"id":"0198e970-1025-738b-909d-f04e8dbaac18","parentId":null,"rootId":null,"fromId":24615,"content":"开什么玩笑，医疗相比其他行业爽的一批","createdAt":"2025-08-27T10:51:32"},{"id":"0198e971-f60b-7252-9d88-4ce820901b13","parentId":null,"rootId":null,"fromId":460,"content":"记住是公费哦 用国家的钱出去旅游 正大光明的，国家给他掏钱。","createdAt":"2025-08-27T10:53:36"},{"id":"0198e972-3dec-70dc-8540-e291c9e3aca0","parentId":null,"rootId":null,"fromId":6747,"content":"你说的是之前严查卖医疗设备的那些么，听说好多人跑路了","createdAt":"2025-08-27T10:53:55"},{"id":"0198e972-f76d-7188-a2dc-353c14d412c5","parentId":null,"rootId":null,"fromId":460,"content":"其实公费不公费的吧 对于欧洲旅游 人家也不缺这点钱  公费旅游也是对他能力的一种荣誉吧","createdAt":"2025-08-27T10:54:42"},{"id":"0198e976-b7ea-7308-bc0e-d7b20e4db03f","parentId":null,"rootId":null,"fromId":21511,"content":"小丑一个","createdAt":"2025-08-27T10:58:48"},{"id":"0198e982-2d72-7362-903e-472fc4ed4461","parentId":null,"rootId":null,"fromId":22695,"content":"看你是哪个层次哪个分支的了。不是卫生厅直接拨款的医院目前确实不好过，做医疗器械的小公司也不好过，但是大医院，除了更忙，待遇可是好的不行。","createdAt":"2025-08-27T11:11:19"},{"id":"0198ea79-265e-7134-bb8e-bd0169354115","parentId":null,"rootId":null,"fromId":22970,"content":"我说的是软件方面，医疗软件?","createdAt":"2025-08-27T15:41:04"},{"id":"0198ec20-2b8f-71c9-95b0-50f41de977b0","parentId":null,"rootId":null,"fromId":22695,"content":"医疗软件的话，大医院早就已经有合作的公司了，小医院没钱整，就算是有钱，现在卫生厅又要求数据传到省厅，肯定会对合作公司有限制，所以现在小公司整医疗软件，挺难的","createdAt":"2025-08-27T23:23:08"},{"id":"0198ef59-ae59-7053-a77f-0254d1f9c990","parentId":null,"rootId":null,"fromId":23484,"content":"医院可没有双休、节假日，每天都得回消息、处理问题，五一、端午这种节假日还得排班值班，当然源头是公司的项目做的太垃圾了，问题太多","createdAt":"2025-08-28T14:24:48"}]