[{"id":"01963ddc-8d6e-72f5-b607-e69fa10fe9fd","parentId":null,"rootId":null,"fromId":1160,"content":"突如其来的降薪，建议别来","createdAt":"2022-09-19T16:34:55"},{"id":"01963ddc-8db2-7233-9197-f0671ce42aa4","parentId":null,"rootId":null,"fromId":729,"content":"微品现在做啥项目，移动项目撤场了之后就不太好了吧","createdAt":"2022-09-20T09:52:54"},{"id":"01963ddc-8df8-7300-a151-2ed34f898dcd","parentId":null,"rootId":null,"fromId":1710,"content":"全体降薪，干的漂亮","createdAt":"2022-09-20T09:59:39"},{"id":"01963ddc-8e3e-71cd-b148-c789d79e25b1","parentId":null,"rootId":null,"fromId":1709,"content":"很不地道，疫情初期跟风扣工资（在家办公一点没耽误项目进度，项目也是按年签的没耽误入账赚钱）。现在又说资金周转不开，高新区临时通知不续租了让去市中，另外裁员+降薪20%+逼着自己走。想要补偿门都没有，工资都开不出。以前天天喊着让大家奉献，现在工资给不全还要求一起共度难关","createdAt":"2022-09-20T09:59:58"},{"id":"01963ddc-8e80-724c-9db2-e34cc3fb0bdc","parentId":null,"rootId":null,"fromId":1712,"content":"    前两月面试过了，幸好没去，当时就因为看到有在黑名单上就没去的。做得是移动业务的项目外包，没劲，那也是外包啊（狗头）","createdAt":"2022-09-20T11:51:46"},{"id":"01963ddc-8ec5-7354-8fca-856594045e85","parentId":null,"rootId":null,"fromId":1714,"content":"为什么不集体仲裁呢","createdAt":"2022-09-20T14:34:31"},{"id":"01963ddc-8f0e-7283-8f83-d17428717805","parentId":null,"rootId":null,"fromId":204,"content":"突如其来的骚，闪了你们的老腰，哈哈","createdAt":"2022-09-20T15:45:02"},{"id":"01963ddc-8f58-71f5-8ad3-9c49b011ec79","parentId":null,"rootId":null,"fromId":1726,"content":"从来不给同甘，凭什么要我们共苦？","createdAt":"2022-09-21T10:27:57"},{"id":"01963ddc-8fb0-70e8-be27-12a17cded21d","parentId":null,"rootId":null,"fromId":1729,"content":"岗位绩效占比超过30%，还好意思说什么80%，有胆子降，没胆子认，济南高新直接办公室都没有，还强制搬到市中，有没有想过，都她妈降薪了。哪里还有金钱和时间来逼逼在哪上班的问题","createdAt":"2022-09-21T14:23:53"},{"id":"01963ddc-8ff7-71d6-a11c-c8f1b6bf6976","parentId":null,"rootId":null,"fromId":2345,"content":"12月31日发送通知，全公司停工1个月，发送50%的薪资，山东业务部因为不能停工，领导给山东画饼说上班最低发80%工资，正在跟总部申请发全薪工资，最后上班5天了得了消息说年前上班的按照80%发工资，不允许请假调休，请假调休得视为居家办公发50%的工资，恶心死了，还不如直接休假呢","createdAt":"2023-01-05T14:18:39"}]