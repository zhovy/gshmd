fromId":6517,"content":"双休，按时发，5点半下班不加班","createdAt":"2025-09-30T10:10:30"},{"id":"01999888-6b4d-71a1-8a31-f66aa792a3cc","parentId":null,"rootId":null,"fromId":22459,"content":"哈哈哈哈哈哈哈哈哈哈哈哈哈哈","createdAt":"2025-09-30T10:51:41"},{"id":"01999888-9734-702e-8be6-5484bc5f1482","parentId":null,"rootId":null,"fromId":22459,"content":"新北洋啊","createdAt":"2025-09-30T10:51:52"},{"id":"019998b7-e9c0-71bb-81d8-c85eb3d74e3a","parentId":null,"rootId":null,"fromId":24443,"content":"兄弟能否细嗦  我不会认识吧","createdAt":"2025-09-30T11:43:33"},{"id":"0199b568-8ad5-72d0-96ee-aa817b45ffa5","parentId":null,"rootId":null,"fromId":3968,"content":"工资太低，20年那会到手只有不到五千","createdAt":"2025-10-06T01:25:51"},{"id":"0199c650-c59d-729a-9b5f-4027aff4e1a7","parentId":null,"rootId":null,"fromId":2246,"content":"看什么岗位，既要这个又要那个的工作不存在。","createdAt":"2025-10-09T08:13:26"},{"id":"0199c72d-7edc-702e-abe3-14795201da21","parentId":null,"rootId":null,"fromId":3968,"content":"所以留不住人","createdAt":"2025-10-09T12:14:31"},{"id":"0199c82c-5cfe-72d7-9b2e-38411f1fb255","parentId":null,"rootId":null,"fromId":26964,"content":"还是有的，8点半上班，5点下班，基本不加班，双休，正常节假日放假福利","createdAt":"2025-10-09T16:52:54"},{"id":"0199cb7c-27fa-710e-87d2-05bfb6d502cc","parentId":null,"rootId":null,"fromId":2246,"content":"近三年没有人员流动，不知道你这个留不住人从哪里来的。","createdAt":"2025-10-10T08:18:55"},{"id":"019a0155-828f-70c3-9414-2fea60e7a7ca","parentId":null,"rootId":null,"fromId":6428,"content":"请问还招前端吗?","createdAt":"2025-10-20T19:16:12"},{"id":"019b1add-d982-73fb-9072-98728b3291ea","parentId":null,"rootId":null,"fromId":1467,"content":"没有，","createdAt":"2025-12-14T11:18:25"}]