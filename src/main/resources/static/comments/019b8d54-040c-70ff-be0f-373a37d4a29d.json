[{"id":"019b8de7-ef19-7261-827b-4a2c7aa7f52a","parentId":null,"rootId":null,"fromId":933,"content":"卡学历就待遇好，不卡学历就垃圾，明白了吧","createdAt":"2026-01-05T19:25:46"},{"id":"019b9096-e565-736a-bd8d-7bc3d8884b7b","parentId":null,"rootId":null,"fromId":2572,"content":"香蕉岗，不是给你留的。先有这个人，才有这个岗位","createdAt":"2026-01-06T07:56:06"},{"id":"019b90ae-3fbf-7394-81de-5950c122e8a3","parentId":null,"rootId":null,"fromId":3450,"content":"应聘的时候说的多好，进去干的时候就有多垃圾，学历歧视相当严重，我个本科生进去就跟奴隶没区别，而且没有休息日，随时有活随时给你打电话，干了1个月我就跑了，不是人干的","createdAt":"2026-01-06T08:21:37"},{"id":"019b90d9-5a03-7365-aa95-ddd79ef96324","parentId":null,"rootId":null,"fromId":26671,"content":"感觉像是在管理学生一样","createdAt":"2026-01-06T09:08:42"},{"id":"019b910c-f221-7185-8d0e-a8b32d190e8c","parentId":null,"rootId":null,"fromId":21302,"content":"高校肯定学历歧视很严重，内部文化如此。","createdAt":"2026-01-06T10:05:03"},{"id":"019b9338-83da-714b-a1ec-44adc4067e5b","parentId":null,"rootId":null,"fromId":28064,"content":"去了吗？怎么样","createdAt":"2026-01-06T20:11:53"},{"id":"019bb1aa-9404-7043-9f31-ff04b6acc1ea","parentId":null,"rootId":null,"fromId":22724,"content":"有免费的学生不用，为嘛要花钱用社会招聘的呢？只能说这个活很多学生都不愿意干","createdAt":"2026-01-12T18:05:04"}]