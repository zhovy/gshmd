[{"id":"01963de3-5819-73ad-a088-9b3748fc7cc8","parentId":null,"rootId":null,"fromId":246,"content":"曹操送哪个部门？曹操送技术部门王领导擅长PUA 傻逼一个","createdAt":"2023-06-03T00:42:44"},{"id":"01963de3-5879-723e-94a3-cd56bb92bc39","parentId":null,"rootId":null,"fromId":3663,"content":"开创云本身也挺垃的","createdAt":"2023-06-04T13:35:41"},{"id":"01963de3-58c1-7033-9baa-2977989ab780","parentId":null,"rootId":null,"fromId":190,"content":"曹操送技术总监吗 ","createdAt":"2023-06-05T10:50:03"},{"id":"01963de3-5908-7122-91fd-73c4e6a307e7","parentId":null,"rootId":null,"fromId":190,"content":"据说曹操送的离职率超级高 ","createdAt":"2023-06-05T11:02:44"},{"id":"01963de3-585d-7352-a0e0-e3d8f5e26957","parentId":null,"rootId":null,"fromId":190,"content":"听朋友说王**擅长PUA 人送外号不粘锅，没事的时候我们是一个团队，有锅的时候你们是一个团队。整个开发团队天天政治加班给上级领导看，隔壁其他部门都正常下班。你要是敢早走第二天开会就点你PUA你。没事就站你背后看你在干啥，又不是给他干活，互联网公司工作干完就行了呗。恶心走了一批又一批人，自己还感觉不到。听说开创不会涨工资来多少走就多少还得扣你点，不知道曹操送是这样不。好像技术团队总共没几个人老员工基本都走了，后端歇班也得值班，带着电脑处理问题，一但群里回复不及时或者没看见第二天开会就怼你。天天开晨会不是怼这个就怼那个说这个不行那个不行，在这干的没有不骂他的不知道是不是真的，要是真的就太SB了。","createdAt":"2023-06-06T17:06:54"},{"id":"01963de3-5862-73df-b71b-d90d123db2cc","parentId":null,"rootId":null,"fromId":246,"content":"他就是这样 你全说到点上了","createdAt":"2023-06-06T19:36:59"},{"id":"01963de3-5866-72f6-91df-90e4a92f4c43","parentId":null,"rootId":null,"fromId":246,"content":"不粘锅哈哈哈哈越想越觉得生动形象","createdAt":"2023-06-06T22:52:03"},{"id":"01963de3-586c-738f-89cc-0824dec5a3d1","parentId":null,"rootId":null,"fromId":190,"content":"对上唯唯诺诺 对下重拳出击","createdAt":"2023-06-08T09:29:43"},{"id":"01963de3-5870-730f-a83a-9728538adcc6","parentId":null,"rootId":null,"fromId":346,"content":"WZH?","createdAt":"2023-06-09T11:56:27"},{"id":"01963de3-5875-7071-86f2-69c9c6ff14ef","parentId":null,"rootId":null,"fromId":190,"content":"WWS","createdAt":"2023-06-12T10:58:56"},{"id":"0196d754-5fa0-7094-b55b-f87c5c78f185","parentId":null,"rootId":null,"fromId":2527,"content":"KCY 为数不多的能收支平衡的部门 , 现在唯一的问题是领导不太行 , 给他换了就挺好的","createdAt":"2025-05-16T12:22:33"}]