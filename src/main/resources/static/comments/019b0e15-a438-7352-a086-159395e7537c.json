[{"id":"019b0fad-42e1-70bd-b5dd-abc304f77000","parentId":null,"rootId":null,"fromId":4333,"content":"年年如此，没有HC就招人，有HC领导都不一定给批过，刷KPI而已。","createdAt":"2025-12-12T07:09:31"},{"id":"019b1014-4707-7201-8c95-d557e6eaf277","parentId":null,"rootId":null,"fromId":2846,"content":"确实","createdAt":"2025-12-12T09:02:03"},{"id":"019b101b-d0af-7271-a212-e65f8889c463","parentId":null,"rootId":null,"fromId":26160,"content":"现在没有hc是肯定进不去了 想问下年初都会申请hc吗 那还能有点希望","createdAt":"2025-12-12T09:10:17"},{"id":"019b1033-61c0-736a-ab0b-85cf2c0169d3","parentId":null,"rootId":null,"fromId":629,"content":"hc是啥玩意","createdAt":"2025-12-12T09:36:01"},{"id":"019b103f-c30c-70a2-8273-4cf3e05e7584","parentId":null,"rootId":null,"fromId":1932,"content":"都在说你妈呢？hc是啥，都特么一群狗罕见么，不会说中文么","createdAt":"2025-12-12T09:49:32"},{"id":"019b104c-4963-70a0-8464-fc39ff19f979","parentId":null,"rootId":null,"fromId":3219,"content":"hc是什么","createdAt":"2025-12-12T10:03:13"},{"id":"019b104d-aa1c-714c-a261-a18ad97c6e88","parentId":null,"rootId":null,"fromId":1955,"content":"想入浪潮？浪潮内部的人给你解惑。几个条件，1你是不是研究生学历？2你是不是985,211院校？3你是不是校招的？4你的专业得起码对口，等等吧，至少满足1个条件，你再琢磨到底能不能过面试的问题。那么如果1个不满足，那就一准外包，外包另说了","createdAt":"2025-12-12T10:04:43"},{"id":"019b104f-e663-7249-a2e8-6aa1de069a60","parentId":null,"rootId":null,"fromId":1955,"content":"啥HC不HC的，你要知道如果真的需要人，浪潮正式还有一种合同叫协办，就是和浪潮正式一样一样的，就因为HC没有，但是需要人就直接外部人力资源公司待签合同，待遇一摸一样的。如果你说的HC有了，先优先将协办转成正式，轮不到招聘的人","createdAt":"2025-12-12T10:07:10"},{"id":"019b1057-24b7-7015-b782-0564f20f78f6","parentId":null,"rootId":null,"fromId":21818,"content":"哈哈哈哈，该啊，你求着他给你工作，他塞你这种不常用的内部术语，按着你头学，你一点辙没有！你拿这种术语和你毫无关系的人沟通，强行增加别人的沟通成本，活该被骂","createdAt":"2025-12-12T10:15:05"},{"id":"019b105d-a1a5-70bb-a2af-11d5da0c8413","parentId":null,"rootId":null,"fromId":22250,"content":"人丑B话还多","createdAt":"2025-12-12T10:22:10"},{"id":"019b109a-9c02-734c-b9a2-0fda92e2271c","parentId":null,"rootId":null,"fromId":926,"content":"难","createdAt":"2025-12-12T11:28:46"},{"id":"019b109a-c89d-73eb-a76d-09dd8d93f1f9","parentId":null,"rootId"