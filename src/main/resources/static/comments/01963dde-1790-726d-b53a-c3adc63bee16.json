[{"id":"01963dde-180e-72b4-98c2-92bcfe4412b8","parentId":null,"rootId":null,"fromId":2238,"content":"公司随便克扣工资，且一群人事，裁人的时候一群人围着劳动者逼劳动者离开，就给半个月赔偿，不同意的就派保洁、人事、同事从各个方面搜集证据非法辞退劳动者，法人李朋选了一批没有正义感李朋让干什么干什么，只图钱的人","createdAt":"2023-01-01T11:45:15"},{"id":"01963dde-1853-7151-8f4f-a46ef145bee3","parentId":null,"rootId":null,"fromId":2238,"content":"用到人靠前，用不到人靠后，一不忙了想方设法让你离职，不管是年底还是你刚忙完大工程2天","createdAt":"2023-01-01T11:48:04"},{"id":"01963dde-189c-7282-952d-b376b1c0b9d3","parentId":null,"rootId":null,"fromId":2348,"content":"你这起码辞退还给工资呢 不错了","createdAt":"2023-01-06T16:20:49"},{"id":"01963dde-18e0-7287-baa8-2237a2cbe325","parentId":null,"rootId":null,"fromId":2238,"content":"签的保密协议和竞业协议让你稍微有点不注意的地方赔一年的收入","createdAt":"2023-01-06T18:55:25"},{"id":"01963dde-1924-71d2-999b-b8afebb71c6c","parentId":null,"rootId":null,"fromId":2238,"content":"那半个月的赔偿和之前克扣的工资和将来稍有不注意竞业违约金相比真是少的可怜了","createdAt":"2023-01-06T18:56:25"},{"id":"01963dde-1968-70f0-b838-665f09d96220","parentId":null,"rootId":null,"fromId":2351,"content":"通过pua来逼人走的公司，一年逼走2/3，用完即逼走，榨干利用价值就逼走，公司故意制造矛盾，让同事出手","createdAt":"2023-01-06T21:35:53"},{"id":"01963dde-19ae-70e4-bc01-1826d9dd9028","parentId":null,"rootId":null,"fromId":2351,"content":"都不敢在智联注册公司招聘，怕差评","createdAt":"2023-01-06T21:37:31"}]