[{"id":"01963ded-7fbd-7265-b46c-e3369311b45b","parentId":null,"rootId":null,"fromId":6829,"content":"济南结婚刚需就买吧，非刚需没必要，济南房价在省会城市里算低的了，估计一套每年也就跌个两三万，经济形势好起来可能不跌了","createdAt":"2024-04-09T09:03:35"},{"id":"01963ded-8002-731e-823d-50b9d76ad658","parentId":null,"rootId":null,"fromId":5790,"content":"有没有好片区推挤推挤","createdAt":"2024-04-09T09:11:26"},{"id":"01963ded-8006-7312-9eb7-a9729027a880","parentId":null,"rootId":null,"fromId":6939,"content":"我关注的唐冶，但是没多少新盘了，看上的价格又太贵了。","createdAt":"2024-04-09T09:13:29"},{"id":"01963ded-800e-71e8-a8f6-da4fed62e7ea","parentId":null,"rootId":null,"fromId":4140,"content":"买房子看周边产业，第一第二产业多的附近的房子会慢慢回暖，对应的就cbd那块，像西客站、唐冶、孙村、郭店这边的等着吧，除非有二手房东打骨折出手，否则你完全可以先租房，把钱放银行吃利息，等租售比到1:200-300的时候再买，如果非要买（结婚、孩子上学）买个小平房的过渡，主打的就是少赔点，不建议一步到位远郊改善，远郊到时候出手越大越不好出手，因为价格太高，人家完全可以买cbd那块的小房子","createdAt":"2024-04-09T09:14:35"},{"id":"01963ded-8053-72c4-8db7-6f677c73dacc","parentId":null,"rootId":null,"fromId":6939,"content":"现在就是住的小户型，想买二套，不想走远，不考虑cbd。","createdAt":"2024-04-09T09:21:47"},{"id":"01963ded-8061-730e-b512-903564f9daa6","parentId":null,"rootId":null,"fromId":6129,"content":"放眼全国房价下降是大趋势，如非结婚生育需求不建议买","createdAt":"2024-04-09T09:23:24"},{"id":"01963ded-8058-72dc-a92e-2463ed06cb1c","parentId":null,"rootId":null,"fromId":4140,"content":"先忍忍，买错房3年白玩，你想想你三年干活多累，别急，等租售比下来，起码等像青岛取消贷款利率下限，青岛现在商贷利率3.45%快跟公积金贷款一样了，而且人家的政策现在买房是永久比正常利率低50个bp，咋就慢慢耗着吧","createdAt":"2024-04-09T09:27:59"},{"id":"01963ded-80a4-7089-9b7a-39515f903d1f","parentId":null,"rootId":null,"fromId":3500,"content":"我也因为要结婚 在关注 张马屯那一片可以入手吗今年 会不会跌还","createdAt":"2024-04-09T09:36:52"},{"id":"01963ded-805c-731b-80a0-168c17e6078f","parentId":null,"rootId":null,"fromId":6939,"content":"据了解，济南马上也3.45了。","createdAt":"2024-04-09T10:08:31"},{"id":"01963ded-80e9-70ae-9d66-6635d65ad434","parentId":null,"rootId":null,"fromId":6939,"content":"不少同事在那买的，应该还可以。","createdAt":"2024-04-09T10:20:42"},{"id":"01963ded-80ee-728c-b876-db783b0cf2fd","parentId":null,"rootId":null,"fromId":258,"content":"把你的预算写出来","createdAt":"2024-04-09T10:55:51"},{"id":"01963ded-8132-7295-8a16-4d0094c84f1b","parentId":null,"rootId":null,"fromId":7034,"content":"一堆中介回复闹麻了","createdAt":"2024-04-09T11:29:26"},{"id":"01963ded-8177-7306-b8dd-a7163b3271f7","parentId":null,"rootId":null,"fromId":7034,"content":"经济下行期大多数资产跑不了降价，更何况是本来就有泡沫的房子，还买呢，着急接盘是吗？就这么想自己一辈子被套牢？CN什么人均收入，对应什么房产价格，自己想一想，房价高完全是蓄水池，都是炒起来的，和虚拟币没本质上的区别，金融属性早就大于居住属性了。现在经济下行期，房价要不是有GM限跌早就步Jp后尘了，生育率在逼，双轨制是未来大势所趋。但是好言难劝该死鬼，有些人就是拿刚需说事，想当冤大头就缴税呗，整的这个房子不买就要睡大街一样，有时候好好想想人活着为了什么挺好的。","createdAt":"2024-04-09T11:38:10"},{"id":"01963ded-81c4-7318-85aa-20e090aeaf61","parentId":null,"rootId":null,"fromId":875,"content":"买什么房子，还是在济南，租房不行不，钱投黄金里，一年收益20%","createdAt":"2024-04-09T12:40:16"},{"id":"01963ded-8209-713f-ab61-531006e775a8","parentId":null,"rootId":null,"fromId":576,"content":"最近聊的比较多的是金价暴涨，明白了吗？对抗通货膨胀货币贬值的方案就是：同等价值品替换。","createdAt":"2024-04-09T13:07:45"},{"id":"01963ded-824e-73dc-bab5-9ded000efb2e","parentId":null,"rootId":null,"fromId":7132,"content":"地段，地段，地段。\n学校，医院，配套设施，周边环境。\n不要盲目。不要只看价格。","createdAt":"2024-04-09T16:37:16"},{"id":"01963ded-8295-727c-8645-5e0fb3086e99","parentId":null,"rootId":null,"fromId":5471,"content":"买的未来壹号，大落地窗，挺香","createdAt":"2024-04-09T17:06:14"},{"id":"01963ded-82d8-704a-8834-76584d5fbeaf","parentId":null,"rootId":null,"fromId":6091,"content":"单价多少","createdAt":"2024-04-09T17:17:31"},{"id":"01963ded-82dc-7024-9bcb-dbe635a64562","parentId":null,"rootId":null,"fromId":875,"content":"黄金555.5了，一年涨了20%房子涨了多少钱","createdAt":"2024-04-09T19:56:09"},{"id":"01963ded-81bf-707f-9ac7-034a8ae7b894","parentId":null,"rootId":null,"fromId":6368,"content":"你以为花钱的是来问的人吗，花钱的是来问的人的父母，刚需的意思就是丈母娘给死命令了，不买房就分手，哈哈哈。","createdAt":"2024-04-12T10:47:47"}]