[{"id":"01963dee-9e9c-738f-b2d3-c6b086fcfc89","parentId":null,"rootId":null,"fromId":6435,"content":"加班加到神志不清，浪潮加班这么狠吗","createdAt":"2024-05-09T09:21:21"},{"id":"01963dee-9ee5-72c7-80ef-3844e7ae0520","parentId":null,"rootId":null,"fromId":5954,"content":"浪潮我一个哥们在里边，一个人负责4-5个项目，当天提的需求或者BUG当天解决（不是一个两个的），而且还把很紧急的线上问题（从来没接触过的项目）要赶紧解决，如果这些都不符合，就等着辞退吧。","createdAt":"2024-05-09T10:15:36"},{"id":"01963dee-9f30-73c2-8993-4a95268bf178","parentId":null,"rootId":null,"fromId":5954,"content":"可想而知，浪潮加班是必须的","createdAt":"2024-05-09T10:24:46"},{"id":"01963dee-9ee1-717b-8b35-e3c6252c983b","parentId":null,"rootId":null,"fromId":7374,"content":"一个月工时统计300多，感觉还是狗命重要先跑了","createdAt":"2024-05-09T13:27:48"},{"id":"01963dee-9f34-71a9-a8df-e07e0686565c","parentId":null,"rootId":null,"fromId":6517,"content":"我4月考勤 总工时才176小时，外面加班这么严重了吗","createdAt":"2024-05-09T13:39:04"},{"id":"01963dee-a23c-72ac-aae3-84d84e5ae982","parentId":null,"rootId":null,"fromId":5913,"content":"浪潮哪个子公司","createdAt":"2024-05-09T13:54:47"},{"id":"01963dee-a284-73bd-b66c-ee55723ddfd2","parentId":null,"rootId":null,"fromId":1261,"content":"待几年了啊，一直这样吗","createdAt":"2024-05-09T20:20:06"},{"id":"01963dee-a2c8-73fa-92b9-ef56a6d216e4","parentId":null,"rootId":null,"fromId":2513,"content":"积成啊，不过这两年也在加班，但是比起浪潮来说，好很多了，还有北谷，中维，宇视，都比浪潮加班少","createdAt":"2024-05-22T11:24:33"}]