[{"id":"01963dd1-8574-70e3-b494-b0b64cc995a0","parentId":null,"rootId":null,"fromId":42,"content":"拖欠一两个月工资很正常，报销的钱也是迟迟下不来，基本上每天下了班都会开会扯淡。","createdAt":"2022-04-19T15:24:39"},{"id":"01963dd1-85ba-7276-b0e5-656dc12617cc","parentId":null,"rootId":null,"fromId":1096,"content":"是做信号及监控的中安公司么","createdAt":"2022-07-25T15:08:17"},{"id":"01963dd1-8605-7042-9972-38d11565aa47","parentId":null,"rootId":null,"fromId":1591,"content":"我在过，当时是三四月的工资，10月才发，公司有个习XX，什么业务都不懂，乱指挥。","createdAt":"2022-09-07T18:20:44"},{"id":"01963dd1-8601-708d-ab96-978bd3e22c03","parentId":null,"rootId":null,"fromId":3986,"content":"是做监管 监狱的 政府项目","createdAt":"2023-07-05T11:18:57"},{"id":"01963dd1-864c-714f-9adb-a1c9f90d7987","parentId":null,"rootId":null,"fromId":3986,"content":"拖欠7-8个工资很正常，领导层能力不行，瞎指挥，如果是监狱项目，恭喜你 自己垫钱出差把，出差多久12个月也就在公司代个15天左右吧。","createdAt":"2023-08-11T13:08:08"},{"id":"01963dd1-869c-7006-8da2-617658854551","parentId":null,"rootId":null,"fromId":3986,"content":"不发工资也就算了，而且理直气壮","createdAt":"2023-08-11T13:08:34"},{"id":"01963dd1-86a0-7132-a225-0cd5c4e4d196","parentId":null,"rootId":null,"fromId":3986,"content":"1.公司做公安监管的，属于传统行业，涉及板块很窄，行业也不景气\n2.项目回款特别的困难，工资一拖再拖，一年12个月拖欠7-8个月很正常，还理直气壮，实在不行让提自己的公积金先花着，就是不给工资 也没个说法\n3.管理特别混乱，几个pmo瞎指挥瞎扯淡，项目谈不上管理就是一边碰一边在做，杂乱无章没有章程\n4.有能力的员工都离职了，留下的基本上都是拆迁户，想学东西呢，别来这个公司，太安逸，养老公司\n","createdAt":"2023-08-22T09:12:34"},{"id":"01963dd1-86a6-72a3-a24c-636a4e6346a0","parentId":null,"rootId":null,"fromId":3893,"content":"1. 拖欠工资4-8个月，出差报销款5-7个月\n2. 管理层混乱  乱指挥\n3. 现在人员离职多，入职的基本没有。流动性很大。","createdAt":"2024-02-04T01:04:23"},{"id":"01963dd1-8700-73ac-a04f-f674590ebafe","parentId":null,"rootId":null,"fromId":3986,"content":"java开发已经全部离职了 已经发不起工资了  大家别入坑了","createdAt":"2024-06-06T15:43:20"}]