[{"id":"01963df3-6c56-7123-b171-93101e7c0cd8","parentId":null,"rootId":null,"fromId":875,"content":"你才知道，都大涨了三天了，白酒指数昨天八个酒涨停板，干指数基金，可防止基金经理偷吃","createdAt":"2024-09-27T12:20:51"},{"id":"01963df3-6c9a-73c1-be60-59c4ccc8e626","parentId":null,"rootId":null,"fromId":875,"content":"原来是上证系统上午被买崩了，所以资金疯狂涌入创业板下单扫货导致的","createdAt":"2024-09-27T12:52:06"},{"id":"01963df3-6ce2-72bb-a2c6-af2211666e59","parentId":null,"rootId":null,"fromId":3705,"content":"听没听说过一个词？叫做回光返照，买房？你有钱？谁有钱？","createdAt":"2024-09-27T14:01:42"},{"id":"01963df3-6d2b-7130-a8d8-d33ee9b01c89","parentId":null,"rootId":null,"fromId":875,"content":"创业板涨停了，刺激，100万就是10万块","createdAt":"2024-09-27T15:03:00"},{"id":"01963df3-6d27-70eb-968c-6943e78d7a57","parentId":null,"rootId":null,"fromId":4140,"content":"哥们我说的是卖房，眼镜近视就配眼镜","createdAt":"2024-09-27T15:56:39"},{"id":"01963df3-6d6f-70b4-ba05-676b920b482d","parentId":null,"rootId":null,"fromId":4140,"content":"下午最高11.95%太爽了，我满仓10万块钱，三天赚了20个点爽死了","createdAt":"2024-09-27T15:57:42"},{"id":"01963df3-6cde-7342-b1bc-650192734099","parentId":null,"rootId":null,"fromId":21464,"content":"创业板在深圳。","createdAt":"2024-09-27T17:02:40"},{"id":"01963df3-6d74-716a-9b10-07d22dcf837f","parentId":null,"rootId":null,"fromId":875,"content":"两万块到手","createdAt":"2024-09-27T20:42:51"},{"id":"01963df3-6d78-73a4-92b0-7a3c2d58c88c","parentId":null,"rootId":null,"fromId":875,"content":"加上今天的30个点了，我才知道下周一又是大涨的一天，毕竟特殊节日","createdAt":"2024-09-27T20:58:49"},{"id":"01963df3-6d7c-7087-98e5-6d68e65c5451","parentId":null,"rootId":null,"fromId":2408,"content":"快要割韭菜了，快跑啊","createdAt":"2024-09-28T00:18:19"},{"id":"01963df3-6dc0-73c7-b100-a07bf33ced29","parentId":null,"rootId":null,"fromId":875,"content":"财联社9月27日讯（记者 林坚 陈俊兰 赵昕睿）“各个新成立的互联网分支已经上刺刀了，有人昨天到凌晨3点，都在忙开户和新客转化。有的友商增量有三倍的。”9月27日凌晨，有券商业务负责人与财联社记者的交流还带着白天“战斗的硝烟味”。\n\nA股接连大涨数天，27日交易量甚至“干”到系统瘫痪，券商紧急采取应对措施。这也让券商忙于应对的事项更多。","createdAt":"2024-09-28T08:19:43"},{"id":"01963df3-6dc4-7359-97ea-c8dd14cc5310","parentId":null,"rootId":null,"fromId":875,"content":"没事多看看新闻，多看看招聘，别老抱怨，市场火热，就业机会就会多，至少券商那应该开始扩张招人了，实在不行去应聘客服，你看开个户都能排到凌晨3点了，让我想起了15年的大牛市，跑步入市开个户，这次不到6000点不减仓","createdAt":"2024-09-28T08:23:19"},{"id":"01963df3-6dc9-7175-88b4-47fa8f086abe","parentId":null,"rootId":null,"fromId":3450,"content":"那你等着被套吧,这回反弹顶多到国庆节后全都要吐出来","createdAt":"2024-09-29T13:47:40"},{"id":"01963df3-6dcd-70ab-ba05-5789457e7b9e","parentId":null,"rootId":null,"fromId":875,"content":"拭目以待","createdAt":"2024-09-29T14:03:38"},{"id":"01963df3-6dd2-727b-bab7-184d47751e1d","parentId":null,"rootId":null,"fromId":875,"content":"哈哈，又涨停了，十万块，上周五搞一万，今天又是一万","createdAt":"2024-09-30T11:24:24"},{"id":"01963df3-6dda-710a-bbb1-720ff150ae98","parentId":null,"rootId":null,"fromId":875,"content":"牛市第五天，白酒加上今天的涨了37%了，真舒服，还是不如创业板，不到6000点不下车","createdAt":"2024-09-30T12:55:50"},{"id":"01963df3-6e1e-7211-8f03-f12a11cfb7ab","parentId":null,"rootId":null,"fromId":875,"content":"牛市第八天，加仓啊","createdAt":"2024-10-04T20:10:25"},{"id":"01963df3-6e62-72aa-be39-6fcd6be6d522","parentId":null,"rootId":null,"fromId":875,"content":"明天喜迎A股牛市第六天，港股牛市第十一天，加仓不要倒金字塔加仓，不要梭哈，不要满仓，到了牛市第二阶段了，不要最后满仓抄在山顶上","createdAt":"2024-10-07T22:55:16"},{"id":"01963df3-6dd6-7153-a240-4176c2e01ec9","parentId":null,"rootId":null,"fromId":2262,"content":"第二楼那个傻逼，今天还笑的出来吗？","createdAt":"2024-10-09T15:58:44"},{"id":"01963df3-6ea7-73ff-85bc-98fe6008459f","parentId":null,"rootId":null,"fromId":7684,"content":"暴跌了  在山顶还好么","createdAt":"2024-10-09T16:23:13"}]