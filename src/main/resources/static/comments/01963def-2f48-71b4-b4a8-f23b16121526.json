[{"id":"01963def-2fab-729b-9ad9-45bb98d963af","parentId":null,"rootId":null,"fromId":875,"content":"硕士毕业买房补贴10万，购房15%.利率下调到2.85哈哈哈，好机会都让刚毕业的赶上了。济南一百万的房子首付15万，研究生补贴10万，相当于首付5万就能上车啊，济南太幸福了","createdAt":"2024-05-17T19:41:40"},{"id":"01963def-2ff5-71ae-b6ca-0ae94f2c8ee4","parentId":null,"rootId":null,"fromId":875,"content":"赶紧转行卖房去了，利率下降，买房子的人多，提成白拿","createdAt":"2024-05-18T08:18:02"},{"id":"01963def-3038-7335-85af-bffcab7b59f3","parentId":null,"rootId":null,"fromId":4052,"content":"买毛线。年轻人还是少加杠杆，现在经济形势不乐观。。","createdAt":"2024-05-23T22:11:56"},{"id":"01963def-2ff0-7293-a4ab-51d97bdb46a8","parentId":null,"rootId":null,"fromId":7617,"content":"这里的打工人都没钱，有本事卖给黑心老板去啊，房子好卖的话还用你跑到这里来张罗？","createdAt":"2024-05-24T07:16:17"},{"id":"01963def-3081-7374-9475-127ca55d289e","parentId":null,"rootId":null,"fromId":21429,"content":"驾校有推荐吗","createdAt":"2024-07-21T16:51:48"}]