[{"id":"01963dee-589b-712a-8163-bf08d595839e","parentId":null,"rootId":null,"fromId":1553,"content":"要不然能怎么样呐?都去死吗?","createdAt":"2024-04-28T09:46:04"},{"id":"01963dee-58e0-7304-bc9e-c7832a41390c","parentId":null,"rootId":null,"fromId":3227,"content":"我觉得这时能苟住是最好的了，","createdAt":"2024-04-28T09:51:40"},{"id":"01963dee-5923-70f2-8aac-0c84c745c362","parentId":null,"rootId":null,"fromId":3801,"content":"这个阶段能苟住的千万别跳。","createdAt":"2024-04-28T11:02:43"},{"id":"01963dee-5968-7064-bbcb-8f8ae39b5102","parentId":null,"rootId":null,"fromId":7083,"content":"已经被打击了，但是还是庆幸能过得下去，虽然辛苦点","createdAt":"2024-04-28T11:13:49"},{"id":"01963dee-59ae-712e-a5b5-bcea6eb85ec6","parentId":null,"rootId":null,"fromId":875,"content":"北京成本真心不高。一顿饭15块吃饱，租房子一月1500足够了","createdAt":"2024-04-28T12:44:51"},{"id":"01963dee-59f1-70ef-beb9-afe27fd7c105","parentId":null,"rootId":null,"fromId":3801,"content":"你这1500的通勤成本是多少，我不说钱啊，主要是时间，另外还有这1500能租到什么房子?","createdAt":"2024-04-28T13:48:37"},{"id":"01963dee-59f6-71c1-beb7-b3797bf07028","parentId":null,"rootId":null,"fromId":1553,"content":"就算租房3000+吃饭3000,北京还能剩10000.济南一共10000","createdAt":"2024-04-28T14:02:30"},{"id":"01963dee-59fa-70a1-81a9-e4f9c9df31ed","parentId":null,"rootId":null,"fromId":3801,"content":"早晚要回来的，你在北京混6年和在济南混6年的圈子能一样么，为什么现在好多工作时间长的都是走内推，无非就这几年混成的圈子，你工作十来年再拿着简历回济南海投？","createdAt":"2024-04-28T14:39:26"},{"id":"01963dee-59ff-728a-bda3-f2de0cfb4295","parentId":null,"rootId":null,"fromId":6939,"content":"短期去赚钱还可以，长期待就算了吧，去廊坊出差，那个早上5点排队等8XX公交车的景象我一点都没忘。","createdAt":"2024-04-28T14:44:59"},{"id":"01963dee-5a03-73c3-8758-9efcb4f21d47","parentId":null,"rootId":null,"fromId":6039,"content":"我们公司现阶段不社招了，让内部转岗或者内推面试，做产品，时间卡的不紧","createdAt":"2024-04-28T15:02:27"},{"id":"01963dee-5a07-703f-9824-3eba57679a07","parentId":null,"rootId":null,"fromId":1553,"content":"不买房,在哪都是赚钱,买了房,在哪都是牛马","createdAt":"2024-04-28T15:12:40"},{"id":"01963dee-5a0b-70f4-88cd-78883451a5a1","parentId":null,"rootId":null,"fromId":6939,"content":"你在北京连想买房当牛马的念头都别想有。","createdAt":"2024-04-28T15:29:00"},{"id":"01963dee-5a1d-7356-892b-d77c8e89aadc","parentId":null,"rootId":null,"fromId":3663,"content":"你也就会这两句话了，怎么还喜欢给别人当老师呢，自己是那个吗？","createdAt":"2024-04-29T17:42:41"},{"id":"01963dee-5a65-7047-80ef-370fdd0b9483","parentId":null,"rootId":null,"fromId":6939,"content":"实话伤人？这是急眼了？","createdAt":"2024-04-30T07:35:46"},{"id":"01963dee-5a6a-700c-a58c-e1ac45351e25","parentId":null,"rootId":null,"fromId":875,"content":"我无房无车，长的丑，没钱，工资低，工作不行，没有房，家庭条件不好，没有退休金，想找一个高富美","createdAt":"2024-05-01T18:12:12"},{"id":"01963dee-5a10-70f9-8835-68642350c4da","parentId":null,"rootId":null,"fromId":21117,"content":"说圈子的纯属搞笑了兄弟，济南呆了5年没有一个朋友呢，同事都不认识几个了，而且同事回老家的回老家，去一线的去一线","createdAt":"2024-07-02T20:42:26"},{"id":"01963dee-5ab1-738b-ab14-f71f6faf73f7","parentId":null,"rootId":null,"fromId":7318,"content":"别说时间成本，对于穷人来讲，最不值钱的就是时间","createdAt":"2024-07-03T08:09:46"},{"id":"01963dee-5a14-7079-a096-b84dcfc90fa6","parentId":null,"rootId":null,"fromId":1049,"content":"不要觉得在济南就有圈子了，圈子的本质就是利益互换，穷在闹市无人问，富在深山有远亲","createdAt":"2024-07-03T09:55:56"},{"id":"01963dee-5a18-7123-ac3b-4ea81be7c504","parentId":null,"rootId":null,"fromId":21280,"content":"济南程序员有个屁圈子，都是老实打工人，","createdAt":"2024-07-04T08:39:28"}]