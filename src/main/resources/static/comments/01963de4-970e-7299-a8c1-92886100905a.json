[{"id":"01963de4-9772-7239-a36a-1d6d1576405a","parentId":null,"rootId":null,"fromId":7620,"content":"公司二三十人左右，主要岗位是技术岗和销售岗\n上下班弹性工作制，但早上不管来的多早，下班都得按最晚时间走。\n特喜欢下班后开会，每次结束都得十一二点\n发工资不准时，喜欢拖延","createdAt":"2024-05-24T13:23:17"},{"id":"01963de4-97bd-7327-ae3e-bc32b1489329","parentId":null,"rootId":null,"fromId":2367,"content":"看来弹性上下班就是早弹晚退，哈哈！","createdAt":"2024-05-24T13:58:00"},{"id":"01963de4-9801-73b1-9b69-934c8855c737","parentId":null,"rootId":null,"fromId":7083,"content":"公司做智慧城市，智慧社区的，其实之前总体来说挺好，工资除了节假日顺延没拖过。就是老总微操指导开发，能为了某个业务和员工争论sql怎么写。","createdAt":"2024-05-26T00:38:24"},{"id":"01963de4-97b8-72a1-9601-89a91c54100b","parentId":null,"rootId":null,"fromId":7083,"content":"到半夜开会，是版本发布评审吧，很多开发下班加班，是为了一小时40的加班费?","createdAt":"2024-05-26T00:40:31"}]