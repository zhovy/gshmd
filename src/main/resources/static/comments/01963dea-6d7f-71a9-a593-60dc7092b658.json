[{"id":"01963dea-6dec-70d5-9641-52e7a6eb33c6","parentId":null,"rootId":null,"fromId":3500,"content":"国企加班这么狠吗","createdAt":"2023-12-29T14:41:03"},{"id":"01963dea-6e34-70bb-819b-5dcb44127d3f","parentId":null,"rootId":null,"fromId":3446,"content":"我们项目组最近有个卷b，一个月打卡工时四百多小时","createdAt":"2023-12-29T14:42:05"},{"id":"01963dea-6e3d-731b-9118-bc293945f60e","parentId":null,"rootId":null,"fromId":3892,"content":"老哥，请问您是什么类型的国企啊？省公司？","createdAt":"2023-12-29T15:11:47"},{"id":"01963dea-6e83-71a8-98f6-8b9ff92573ef","parentId":null,"rootId":null,"fromId":3446,"content":"不同的国企差别也很大，不同部门也有差别，只要还干开发，加班应该都是普遍的","createdAt":"2023-12-29T15:54:18"},{"id":"01963dea-6e88-705d-9ba6-d9a195a5edf9","parentId":null,"rootId":null,"fromId":3892,"content":"不是银行科技岗不怎么加班吗？","createdAt":"2023-12-29T16:25:25"},{"id":"01963dea-6e8d-7210-8500-6ead13d387a1","parentId":null,"rootId":null,"fromId":875,"content":"济南的假国企，一大堆，请注意分辨， 15号之后发工资的。周六上班的，社保公积金不全额缴纳的，签订外包合同的，绩效考核严格占比高的，没有年假的，没有餐补的，每天上班喊口号的，以加班为荣的，假的不能在假的，对面还是一个个国企","createdAt":"2023-12-29T21:29:45"},{"id":"01963dea-6edc-7320-86f3-ef608690c9e8","parentId":null,"rootId":null,"fromId":875,"content":"没有年终奖的国企也能算国企嘛，","createdAt":"2023-12-30T12:09:06"},{"id":"01963dea-6f21-7179-8b58-aa64a49b1b04","parentId":null,"rootId":null,"fromId":875,"content":"算啊，没有年终奖也是国企，虽然是一个子公司","createdAt":"2024-01-01T09:43:28"},{"id":"01963dea-6f2a-7018-8707-32b5b885f2f9","parentId":null,"rootId":null,"fromId":875,"content":"江湖不只是打打杀杀，江湖还是人情世故。没关系，进了国企也白搭，这是济南，不是北京，没人管你技术牛逼的，再牛逼也成不了股东，当不了领导，你看看当领导的都是些啥货，你会拍马屁嘛，会奉承嘛，不会，你就是底层码农，工资在济南一万五～两万就是顶了，人家会拍的都是领导了，都是拿年薪百万的","createdAt":"2024-01-01T20:41:31"},{"id":"01963dea-6f6e-7043-b3cb-f493462564fd","parentId":null,"rootId":null,"fromId":5954,"content":"特别赞同 技术再牛逼 不如人家拍马屁的几句话 实地去国企经历过 领导也暗示过我 但是 哎 我好像不太属于那种拍马屁的人","createdAt":"2024-01-01T21:40:33"},{"id":"01963dea-6ed4-71aa-bd3f-6c73fe267396","parentId":null,"rootId":null,"fromId":3446,"content":"真大型央企，全额，但是太卷了，感觉要加一辈子班，没什么希望","createdAt":"2024-01-02T09:04:45"},{"id":"01963dea-6f25-71c0-9790-57fa6481e265","parentId":null,"rootId":null,"fromId":3446,"content":"有年终，待遇还行，但是太卷了，卷的毫无生气","createdAt":"2024-01-02T09:05:24"},{"id":"01963dea-6f76-7321-849d-798df6a147f8","parentId":null,"rootId":null,"fromId":3500,"content":"哪个国企啊 楼主透漏一下呗 避坑一下","createdAt":"2024-01-02T13:44:17"},{"id":"01963dea-6e38-70fd-b009-20c8535ab9ff","parentId":null,"rootId":null,"fromId":576,"content":"什么神仙选手啊？","createdAt":"2024-01-02T14:25:05"},{"id":"01963dea-6ed8-71a9-b03c-32330f01cb10","parentId":null,"rootId":null,"fromId":576,"content":"我这里是全额，但是不是国企也不是央企捏","createdAt":"2024-01-02T14:26:14"},{"id":"01963dea-6fbc-7044-9d97-229541d22791","parentId":null,"rootId":null,"fromId":3446,"content":"运营商","createdAt":"2024-01-02T16:39:09"},{"id":"01963dea-6f72-719c-9593-56b845bc1991","parentId":null,"rootId":null,"fromId":4010,"content":"济南大环境就这样，确实和北上广差距巨大，作为一个北漂多年回来的人深有感触","createdAt":"2024-01-04T17:19:59"}]