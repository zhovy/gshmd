[{"id":"019b5351-60ca-717d-a4f9-0a8e0faeb373","parentId":null,"rootId":null,"fromId":6517,"content":"领N+1","createdAt":"2025-12-25T10:23:20"},{"id":"019b5354-73f2-7036-854a-ccfc37bd4f83","parentId":null,"rootId":null,"fromId":926,"content":"啥工作","createdAt":"2025-12-25T10:26:42"},{"id":"019b535a-b086-732a-8eab-864f528aa061","parentId":null,"rootId":null,"fromId":2572,"content":"哪个公司，哪个领导？说出来让大家避雷。被边缘化这种情况下，你做什么都是错的，不要想着讨好领导或者情况好转，等领N+1就行了","createdAt":"2025-12-25T10:33:31"},{"id":"019b535d-8f6b-7111-82ea-9da92b0098c7","parentId":null,"rootId":null,"fromId":330,"content":"收集好打卡、加班、工作日志等记录 领导人事找你谈话记得录音","createdAt":"2025-12-25T10:36:39"},{"id":"019b536b-383a-7374-9860-64912095bc23","parentId":null,"rootId":null,"fromId":5480,"content":"首先，公司如果没明确通知你转岗更换工作内容，那么你就可以直接在和领导聊天记录中询问是否计入绩效考核，如何计入捏可以说出来，这不是你本岗位的工作，你不可能在规定的时间内完成非岗位职责的工作。这样记录可能会让你在被裁了之后争取n+1多了一点几率。 但是，你要明白，公司如果想辞退你，他是有各种理由的。","createdAt":"2025-12-25T10:51:34"},{"id":"019b5386-ebd9-7199-8137-64fc136204f9","parentId":null,"rootId":null,"fromId":24419,"content":"什么公司啊","createdAt":"2025-12-25T11:21:49"}]