[{"id":"01963df7-a601-70b9-bbd4-6cd3e727a10f","parentId":null,"rootId":null,"fromId":403,"content":"2009年在这公司呆过，在章丘一个小宾馆做封闭开发，当时整个项目组是早9晚11，一周七天。有一次我发烧晚上10点去睡了，第二天一大早被项目负责人叫房间谈话，说他在宾馆房间看到我的飞秋10点就下线了，质问我为什么下班那么早，吓得我第二天直接打辞职跑路。。。一晃10多年过去了， 不知道他们把员工当牲畜的加班文化是否收敛了些。","createdAt":"2025-03-10T15:11:13"},{"id":"01963df7-a647-73c7-8382-b04ff63b3b76","parentId":null,"rootId":null,"fromId":1049,"content":"真畜生啊","createdAt":"2025-03-10T16:01:50"},{"id":"01963df7-a64b-7068-89e9-cd14002bed45","parentId":null,"rootId":null,"fromId":3319,"content":"老哥09年就参加工作了，也算最早一批大哥。现在混的怎么样了，还在职吗，还是码农吗","createdAt":"2025-03-10T17:12:46"},{"id":"01963df7-a65c-73bd-a431-42b3ea8cba40","parentId":null,"rootId":null,"fromId":1517,"content":"傻逼公司","createdAt":"2025-03-11T08:44:04"},{"id":"01963df7-a6a0-734a-96e6-a991152b6615","parentId":null,"rootId":null,"fromId":6268,"content":"很混乱","createdAt":"2025-03-11T09:01:20"},{"id":"01963df7-a650-7277-8948-de919b427298","parentId":null,"rootId":null,"fromId":2246,"content":"我记得欧玛是做高考那个读卡器的吧","createdAt":"2025-03-12T11:22:55"},{"id":"01963df7-a654-73b5-a3a6-9ee89c0f042c","parentId":null,"rootId":null,"fromId":875,"content":"宾馆里上飞秋，人才","createdAt":"2025-03-12T18:40:58"},{"id":"01963df7-a658-7194-acfe-21745fd0ff76","parentId":null,"rootId":null,"fromId":5725,"content":"飞秋不是局域网里的吗","createdAt":"2025-03-14T15:41:30"},{"id":"0196c3ba-d19e-7005-84f4-d8d365527604","parentId":null,"rootId":null,"fromId":24073,"content":"三年不涨工资喽","createdAt":"2025-05-12T17:02:02"},{"id":"0196c757-0a1c-713e-a94d-5a404a1b81e7","parentId":null,"rootId":null,"fromId":1517,"content":"巧了，我也是","createdAt":"2025-05-13T09:51:32"},{"id":"01973a4a-a913-73c1-98f0-d5e12720bc5b","parentId":null,"rootId":null,"fromId":3160,"content":"你要是能熬得住不涨工资，就来","createdAt":"2025-06-04T17:34:20"}]