[{"id":"01963dd4-21c8-73c0-9a26-6c799c601476","parentId":null,"rootId":null,"fromId":129,"content":"我作为一个之前在山东通维信息工程有限公司待过的人，有发言权，我离职的原因是因为太闲了，混下去学不到东西，但是这个公司在里面混，是真的舒服，我当时是停车组，停车组的项目经理和技术经理，真的特别好，大家都明着混，刘LL是物业组，雀食那个刘LL挺烦的，整天装B，但是你只要不招惹他，在他手下默默干活，也是挺好的，现在这个公司免费吃饭，免费停车，晚上加班到八点半算半天加班，其实很不错了，如果有一直混下去的想法，进这个公司还不错，不过最近听说要每天写日报啥的，因为没活，大家都挺烦哈哈","createdAt":"2022-03-11T07:35:24"},{"id":"01963dd4-2210-73b0-b660-a0d707f2effe","parentId":null,"rootId":null,"fromId":153,"content":"面试了一下 ， 态度也不是很好。 让面试者开摄像头 ， 两个面试官都不开 ，我提了意见。两个人就开始提牛角尖的问题 ， 而且面试他们迟到了30分钟， 一点歉意都没有。","createdAt":"2022-03-24T02:09:10"},{"id":"01963dd4-2255-70f4-9473-70a8960a45c9","parentId":null,"rootId":null,"fromId":1110,"content":"里面的个正式员工勾心斗角，心累","createdAt":"2023-02-08T09:41:51"},{"id":"01963dd4-229b-71f1-abe1-22b57dcea8ef","parentId":null,"rootId":null,"fromId":3835,"content":"现在入职都要走外包了吗","createdAt":"2024-01-16T11:12:11"},{"id":"01963dd4-2324-7290-bb3b-99af7d9a5073","parentId":null,"rootId":null,"fromId":3450,"content":"裁员结束,留下来的人压力山大啊","createdAt":"2024-08-21T09:37:18"},{"id":"01963dd4-236c-729b-9689-4b10b8671c27","parentId":null,"rootId":null,"fromId":3835,"content":"哪个部门裁员了？研发？","createdAt":"2024-08-22T17:05:03"},{"id":"01963dd4-2370-7151-9070-b652049ff6a1","parentId":null,"rootId":null,"fromId":3450,"content":"裁了一个前端一个运营","createdAt":"2024-08-22T17:42:22"},{"id":"01963dd4-237a-7287-a85b-5317f092dc5e","parentId":null,"rootId":null,"fromId":3884,"content":"同志们，新一波裁员来了，期不期待，开不开心","createdAt":"2024-09-30T18:25:03"},{"id":"01963dd4-23c4-72b8-b6da-5ea2009b21f3","parentId":null,"rootId":null,"fromId":3835,"content":"哪个部门裁员","createdAt":"2024-10-09T14:20:55"},{"id":"01963dd4-2375-703e-92b2-6ad05a6f5c8f","parentId":null,"rootId":null,"fromId":1110,"content":"哪个项目的？停车场的？","createdAt":"2024-10-15T08:28:16"},{"id":"01963dd4-23c9-73ac-bfbd-69774a34ebc7","parentId":null,"rootId":null,"fromId":1110,"content":"裁也都是外包","createdAt":"2024-10-15T08:28:36"},{"id":"01963dd4-23ce-711b-b064-f3c789c77de6","parentId":null,"rootI