[{"id":"01963de7-348d-739e-af61-b44f65f20e42","parentId":null,"rootId":null,"fromId":2572,"content":"之前面试过这家，面试过了，但是公司说试岗期7天，若是试岗过了，这7天有工资。若是不过，这7天没有工资。个人感觉不是好公司，不建议去","createdAt":"2023-08-30T14:29:51"},{"id":"01963de7-34da-71ad-9854-49e520420e80","parentId":null,"rootId":null,"fromId":1372,"content":"搜一下，我记得有这家公司的评价。确实不咋的。试岗期就是扯淡并且犯法的。这种公司最好别去。","createdAt":"2023-08-30T15:03:07"},{"id":"01963de7-34d2-7393-972c-19cde8b5bdd3","parentId":null,"rootId":null,"fromId":5511,"content":"兄弟面试什么岗位","createdAt":"2023-08-30T15:04:48"},{"id":"01963de7-34d6-7318-b6cb-ce21097373c7","parentId":null,"rootId":null,"fromId":2572,"content":"面试的java开发","createdAt":"2023-08-30T15:18:55"},{"id":"01963de7-3520-725d-92a9-355e532bc5da","parentId":null,"rootId":null,"fromId":83,"content":"去年去他家面试过，一位赵姓经理面试的，当时公司一共20来人。因为当时想让我先出方案再谈工资和职位，我觉得是想白嫖方案，就没继续跟进","createdAt":"2023-08-30T15:56:36"},{"id":"01963de7-3565-71d7-ab44-2b48ba3af063","parentId":null,"rootId":null,"fromId":5511,"content":"解决方案岗位吗","createdAt":"2023-08-30T16:12:09"},{"id":"01963de7-356a-709f-94f9-168d8907a592","parentId":null,"rootId":null,"fromId":2382,"content":"人力资源岗位","createdAt":"2023-08-31T09:19:24"},{"id":"01963de7-356e-70b5-8c95-38c9093c08cc","parentId":null,"rootId":null,"fromId":1955,"content":"别去了，这公司\n面试过，面试的领导高高在上的样子\n还没怎么弄呢，就这个那个了\n要是入职了，不得死里面","createdAt":"2023-08-31T10:01:14"},{"id":"01963de7-35b1-71de-bd4a-220f298653ff","parentId":null,"rootId":null,"fromId":1935,"content":"千万别去，老板不拿员工当人，认为员工都是来挣他的钱不是帮他挣钱的，亲身经历，制定各种条规针对员工克扣工资，少则五六十，多则上千。非常恶心的一个公司，人生阴影。","createdAt":"2023-09-21T17:21:19"},{"id":"01963de7-35f8-73b5-a0fa-29ffcaf61235","parentId":null,"rootId":null,"fromId":1935,"content":"千万别去，老板不拿员工当人，认为员工都是来挣他的钱不是帮他挣钱的，亲身经历，制定各种条规针对员工克扣工资，少则五六十，多则上千。非常恶心的一个公司，人生阴影。","createdAt":"2023-09-21T17:21:41"},{"id":"01963de7-363d-71f4-a6da-4026da394eb5","parentId":null,"rootId":null,"fromId":6659,"content":"哈哈，这公司现在还有五个人","createdAt":"2024-04-02T22:12:31"},{"id":"01963de7-3681-70bd-b2e9-18d0a552ae95","parentId":null,"rootId":null,"fromId":2367,"content":"业务还能运转么","createdAt":"2024-05-29T10:14:19"}]