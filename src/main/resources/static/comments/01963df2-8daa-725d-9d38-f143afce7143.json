[{"id":"01963df2-8e13-7042-9b96-a749cf9e5f3f","parentId":null,"rootId":null,"fromId":1591,"content":"别去，我刚去了面试，公司不到10个人，办公室只有20平，四个研发，其它都项目经理，面试要求，年龄小长的帅会开车会喝酒（至少1斤的白酒量）能伺候客户。","createdAt":"2024-09-06T11:29:49"},{"id":"01963df2-8e5b-7385-815c-a82fe5d8e681","parentId":null,"rootId":null,"fromId":1372,"content":"草台班子，别去。垃圾。","createdAt":"2025-01-20T17:23:06"},{"id":"01971ad7-6fdc-735f-aeb0-0234ae97284c","parentId":null,"rootId":null,"fromId":3495,"content":"工资补给你了吗？","createdAt":"2025-05-29T15:00:15"},{"id":"01977c25-b3ce-70d8-b4bd-b0406aaf42d3","parentId":null,"rootId":null,"fromId":3219,"content":"真的假的","createdAt":"2025-06-17T12:28:55"},{"id":"0197a061-d6f5-7075-a166-daa141b3a71f","parentId":null,"rootId":null,"fromId":25341,"content":"我昨天面试过了，这样我还是不去了","createdAt":"2025-06-24T13:20:56"},{"id":"0197a52f-0329-73a1-aad6-684487252dd1","parentId":null,"rootId":null,"fromId":3495,"content":"草台班子，别去，垃圾","createdAt":"2025-06-25T11:43:31"},{"id":"0197a52f-fc1e-7132-a89e-7a37bbe44cd0","parentId":null,"rootId":null,"fromId":3495,"content":"今天过去面试的，鸟窝大点的地方，人挤人，看着都难受","createdAt":"2025-06-25T11:44:34"},{"id":"0197a530-6a9b-72a1-a9aa-8b946cc17e75","parentId":null,"rootId":null,"fromId":3495,"content":"工资补给你了吗","createdAt":"2025-06-25T11:45:03"},{"id":"0197a65a-002f-73bc-af4b-97afb0a3ebd4","parentId":null,"rootId":null,"fromId":3495,"content":"前两天去面试过，感觉面试官对问题的都不太清楚，还感觉挺牛的样子，我真的醉了","createdAt":"2025-06-25T17:10:05"},{"id":"0197a744-7c71-7287-aed9-aabe213fe41f","parentId":null,"rootId":null,"fromId":3495,"content":"留不住人，人员换了一波又一波，领导至上，说话都得小心翼翼的","createdAt":"2025-06-25T21:26:12"},{"id":"0197a74b-d058-7128-abca-070b39617deb","parentId":null,"rootId":null,"fromId":3495,"content":"都怪我不听劝，深受其害，找不到工作也不能去啊，不是人待的地方啊，呜呜呜呜呜呜呜呜呜~~~","createdAt":"2025-06-25T21:34:13"},{"id":"0197b557-e9c5-7159-96b0-a66ef25e00b5","parentId":null,"rootId":null,"fromId":25446,"content":"刚聊了  说话冲的很  牛鼻哄哄的","createdAt":"2025-06-28T15:02:07"},{"id":"0197bcb0-63fb-7043-b934-54f4ff458507","parentId":null,"rootId":null,"fromId":22012,"content":"别去了，这垃圾公司，我去年干了三个月，10底到25年1月底。现在这都快7月份了，去年12月和今年1月份的工资还没发。每次问他，他都不理人。而且单休，加班特别多，普遍到凌晨3点。就算是单休也有可能让你周天去加班。而且节假日加班算白给他干活。没有什么两倍三倍工资。现在这公司已经欠了7个人的工资没发了。也就是说只要你提离职，那么离职后你就拿不到工资了。4月底问了一嘴，现在6月底又问了一嘴，根本不回你，现在我还没拿到。当然你们要去这个公司做慈善的话就去吧。","createdAt":"2025-06-30T01:16:06"},{"id":"0197beb4-ed38-73e8-8e1e-68ed7343f1b4","parentId":null,"rootId":null,"fromId":3495,"content":"就是个傻吊玩意，觉得现在找工作的多，看不起这个看不起那个的，在这装B","createdAt":"2025-06-30T10:40:17"},{"id":"0197beb8-144d-7116-989b-8e8d0f79f934","parentId":null,"rootId":null,"fromId":3495,"content":"我草，原来这么多受害者，还有兄弟吗？约一下到时候一起仲裁！","createdAt":"2025-06-30T10:43:44"},{"id":"0197beb9-e54d-700d-ae9c-9e21788212be","parentId":null,"rootId":null,"fromId":3495,"content":"他这摆明了就是拖着不给发工资，不能一直拖着，该搞就得搞起来，现在这钱就那么好骗吗？本来挣钱就不容易，还能让他白嫖了？","createdAt":"2025-06-30T10:45:43"},{"id":"0197e96d-a33b-7221-9365-ea1e636fa3e9","parentId":null,"rootId":null,"fromId":23450,"content":"骗试用期，各种理由不给转正，单休还不让请假，总是搞急活给你找理由加班，试用期还没有公积金","createdAt":"2025-07-08T17:46:06"},{"id":"0197f992-0f54-73b0-8989-407713ef54f8","parentId":null,"rootId":null,"fromId":3495,"content":"这样的公司能活到现在，真是恶心?","createdAt":"2025-07-11T20:59:48"},{"id":"01982321-229f-7398-967a-8620cf61ae55","parentId":null,"rootId":null,"fromId":3495,"content":"俩月没发还等着呢？一天不发就得行动起来了，兄弟","createdAt":"2025-07-19T22:40:30"},{"id":"01985b49-6080-72cc-a92a-893801876d92","parentId":null,"rootId":null,"fromId":3495,"content":"可别说了，就这个公司的那个技术总监叫什么李帅吧，纯纯的煞笔，吹牛逼一来一来的，说的自己可牛逼了，说自己捅过人，跟个黑社会似的，可能有前科吧，只要看你不顺眼了就开始各种找你事，时不时的阴阳你，在老板跟前打小报告，和小人没啥区别，这种人迟早遭报应！","createdAt":"2025-07-30T20:23:12"},{"id":"0198f5ee-3b9a-7032-a979-da74ff0e6eae","parentId":null,"rootId":null,"fromId":3495,"content":"那个姓李的是真的艹，就一个煞笔玩意","createdAt":"2025-08-29T21:04:47"},{"id":"0199589e-b1ae-73b3-8b62-474d526eeea1","parentId":null,"rootId":null,"fromId":6822,"content":"哈哈","createdAt":"2025-09-18T01:00:19"},{"id":"0199daa8-f859-73db-935d-a295c80113b4","parentId":null,"rootId":null,"fromId":22012,"content":"这个叫姓李的是后来的，我今年1月份离的职。公司原本9个人，1月份就跑了6个，这是又重新招的，哈哈，反正公司特别垃圾，加班10点起步","createdAt":"2025-10-13T07:02:10"},{"id":"019a72bc-6f33-70b0-8301-7f91a2579d33","parentId":null,"rootId":null,"fromId":3495,"content":"鸡窝大点的地方，领导架子倒是不小，不伺候了，傻逼","createdAt":"2025-11-11T19:45:43"},{"id":"019b023a-b2d3-7288-833f-a4d23040cae1","parentId":null,"rootId":null,"fromId":3242,"content":"23年干了一周，当官的啥也不懂上去就让你干，面试吹牛逼说在软件园有二十多个人的团队，其实我去的时候就剩一个开发了，听话里的意思也要跑路，我立马收拾铺盖跑路，一周的工资要不是我坚决要他都不发。","createdAt":"2025-12-09T16:29:19"}]