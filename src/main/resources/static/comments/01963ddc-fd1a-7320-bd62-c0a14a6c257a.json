[{"id":"01963ddc-fd9c-7076-8e3f-8ae3f7d12a63","parentId":null,"rootId":null,"fromId":1240,"content":"德佑供应链？ 办公地点在汉峪金谷，不是刚组建的研发团队吗","createdAt":"2022-10-18T10:37:13"},{"id":"01963ddc-fddf-70ec-a086-73ba28464ab9","parentId":null,"rootId":null,"fromId":654,"content":"重新组建的开发团队吧，行不行的图里都是他们的规定～","createdAt":"2022-10-18T11:53:35"},{"id":"01963ddc-fe25-7152-8503-3109f7a0b1a8","parentId":null,"rootId":null,"fromId":1955,"content":"去面试过，进去说组建团队，整个楼层都是他们的，正在装修\n然后聊的挺好，当即决定让我入职\n后来没去\n1 感觉太唐突，面试那么多都石沉大海了，到他这里就直接入职了\n2 口头允许的，不靠谱\n3 个人认为，是组建团队，所以肯定会很多事事在里面\n各位谨慎","createdAt":"2022-10-18T16:38:03"},{"id":"01963ddc-fe6e-72cd-9b87-5c1adf5f27c1","parentId":null,"rootId":null,"fromId":2005,"content":"也忒恶心了吧","createdAt":"2022-10-19T17:36:56"},{"id":"01963ddc-feb3-7029-84b8-fe432c57ce17","parentId":null,"rootId":null,"fromId":2006,"content":"义务加班绝了就是","createdAt":"2022-10-19T17:41:15"},{"id":"01963ddc-fef9-717f-9de7-88b758d1ec93","parentId":null,"rootId":null,"fromId":2004,"content":"面过，进去聊了20多分钟就决定让就说要发offer让入职，当时觉得不靠谱就没去，幸亏没去，恶心。","createdAt":"2022-10-19T17:55:08"},{"id":"01963ddc-ff3f-705d-88a4-bd6746ae5bf8","parentId":null,"rootId":null,"fromId":2025,"content":"经理是那位华为出来的“大牛”吗？怎么搜不到这个公司了？","createdAt":"2022-10-20T12:20:44"},{"id":"01963ddc-ff85-73d1-8655-3b99887d4050","parentId":null,"rootId":null,"fromId":2025,"content":"公司地址发出来，防止公司换壳继续坑人！","createdAt":"2022-10-20T12:22:33"},{"id":"01963ddc-ffcb-7113-bb17-7f7d299dcb90","parentId":null,"rootId":null,"fromId":654,"content":"牛逼了","createdAt":"2022-10-20T13:04:58"},{"id":"01963ddd-0011-7397-9069-f2ae3b1e4012","parentId":null,"rootId":null,"fromId":747,"content":"有谁在那工作过的吗？楼主在那工作过吗？感觉怎么样？压抑吗","createdAt":"2022-10-22T13:10:45"},{"id":"01963ddd-0056-71b0-a645-1b89370445ac","parentId":null,"rootId":null,"fromId":654,"content":"非常之压抑～\n如果图薪资，那么他们公司在目前的就业环境可以满足，前提是不迟到不请假接受加班（五险最低标准缴纳，公积金一个月几百）；\n如果图身心健康，那么他们不适合；\n如果图技术的发展，也不适合；\n如果图成就感，基本没有。。。\n建议能去大公司就去大公司，中型企业也可以去。。","createdAt":"2022-10-25T13:18:38"},{"id":"01963ddd-00a1-7040-a21c-72df249cb578","parentId":null,"rootId":null,"fromId":1078,"content":"有幸参加过线上面试，面试官迟到。面试时间总长10分钟。 自我介绍 对面说信号不好 要重新进，我没介绍完就退出了。第二次进来就不让我自我介绍了。 技术 业务 项目经历一概不问  就问现在的薪资  为啥换工作。 然后就结束了。总觉得是来套路市场行情的。","createdAt":"2022-11-07T19:44:57"},{"id":"01963ddd-0135-738b-9a66-eab85158be39","parentId":null,"rootId":null,"fromId":747,"content":"询聘公司已注销，现叫勇往职前","createdAt":"2024-10-11T17:16:33"}]