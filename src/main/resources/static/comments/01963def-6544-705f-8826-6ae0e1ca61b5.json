[{"id":"01963def-65ab-73ec-a965-fad85e18f6b5","parentId":null,"rootId":null,"fromId":3879,"content":"是软通吧，工资应该还可以，加班应该是常态","createdAt":"2024-05-22T09:17:58"},{"id":"01963def-65f1-71da-9062-806e5dce634c","parentId":null,"rootId":null,"fromId":5954,"content":"老哥 有联系方式吗？我有点事问问","createdAt":"2024-05-22T09:25:36"},{"id":"01963def-65f5-7127-8019-f7b8b1fe424d","parentId":null,"rootId":null,"fromId":5790,"content":"华子的移动外包不是在玉兰广场吗","createdAt":"2024-05-23T10:55:25"},{"id":"01963def-663e-7188-ac6f-fd38a1a4a411","parentId":null,"rootId":null,"fromId":7658,"content":"我就在那里工作，不是中国移动，是中移在线(可以看作是中国移动的子公司)，这里的华为员工分两部分，一部分是华为外包的，另一部分是软通外派到华为，华为再外派到中移在线的。工资很低，双休，员工基本17:30卡点下班。系统发版会夜间加班，第二天调休。在这工作5年了，加班次数单只手可数。","createdAt":"2024-05-28T15:49:01"},{"id":"01963def-6683-73ab-a9f8-d5818286e21e","parentId":null,"rootId":null,"fromId":7395,"content":"老哥你说的是玉兰广场那个项目吗","createdAt":"2024-05-29T18:47:32"},{"id":"01963def-6688-70dc-9b6c-31973765813e","parentId":null,"rootId":null,"fromId":5954,"content":"给你说了是腊山的 还问玉兰广场","createdAt":"2024-05-29T22:43:43"},{"id":"01963def-668c-715a-8fec-f67b992f78b0","parentId":null,"rootId":null,"fromId":6047,"content":"您好 我想问一下薪资组成包含绩效么","createdAt":"2024-05-31T08:17:46"},{"id":"01963def-6690-72ee-8e48-b24bc1439ded","parentId":null,"rootId":null,"fromId":7658,"content":"腊山北路18号","createdAt":"2024-06-05T08:55:25"},{"id":"01963def-6695-7065-8170-ae0e1ee8b746","parentId":null,"rootId":null,"fromId":7658,"content":"我是入职和HR谈的，每月固定工资，没有绩效考核，没有年终奖。","createdAt":"2024-06-05T08:57:21"},{"id":"01963def-6699-7343-bd2f-56a61ee71d0e","parentId":null,"rootId":null,"fromId":7658,"content":"两年前开会提过几次，东边还有一个办公地点，在银荷大厦。住东边的同事可以申请过去，工作内容不变。最近不怎么提了，不知道地方还在不在，有没有变。","createdAt":"2024-06-05T09:04:01"},{"id":"01963def-6639-7258-a861-537fb5caa8a3","parentId":null,"rootId":null,"fromId":7658,"content":"和玉兰广场的应该不是一个，这里是中移在线的项目。和泉舜(经二纬六路口那个中移在线楼里面的)还有所关联。这里好多人都是从那过来的","createdAt":"2024-06-05T09:14:16"},{"id":"01963def-669d-7335-83f1-f0994ec8a32d","parentId":null,"rootId":null,"fromId":21429,"content":"驾校有推荐吗","createdAt":"2024-07-21T16:51:49"},{"id":"01963def-66e0-7093-a62c-6906104dc9b9","parentId":null,"rootId":null,"fromId":5954,"content":"难得的好公司哦 谁去谁知道 适合养老","createdAt":"2024-09-24T15:28:20"}]