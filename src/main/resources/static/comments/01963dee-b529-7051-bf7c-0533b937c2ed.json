[{"id":"01963dee-b58d-72c1-a903-34109a5b4ccb","parentId":null,"rootId":null,"fromId":4030,"content":"3天能看出来一个人的真实水平？可以决定一个人的去留？？？？？？？？？？？？？？？？？","createdAt":"2024-05-10T16:04:55"},{"id":"01963dee-b5da-7031-a93b-819bbc1b77da","parentId":null,"rootId":null,"fromId":1924,"content":"他们给你多少，我当初6k他们都嫌多，全栈越来越不值钱了","createdAt":"2024-05-10T16:08:38"},{"id":"01963dee-b61e-71aa-832f-cb4d74c6ddaf","parentId":null,"rootId":null,"fromId":7179,"content":"7","createdAt":"2024-05-10T16:16:52"},{"id":"01963dee-b5d2-7084-b1d2-4e043968cc17","parentId":null,"rootId":null,"fromId":7179,"content":"不好说啊他们说主要看性格还有交流能力类似于半销售的程序员吧","createdAt":"2024-05-10T16:18:55"},{"id":"01963dee-b623-71c1-bb2b-89e7046f75cf","parentId":null,"rootId":null,"fromId":5408,"content":"我当时也是要6k，嫌我要的多","createdAt":"2024-05-10T17:04:39"},{"id":"01963dee-b627-737f-b7d8-ec16d68e628a","parentId":null,"rootId":null,"fromId":5485,"content":"不管什么岗位都要干销售，但是分业绩不如销售分的多，不建议技术岗来，会耍嘴皮子的可以考虑","createdAt":"2024-05-11T08:55:48"},{"id":"01963dee-b66f-700c-92b7-052b0d6dfb2a","parentId":null,"rootId":null,"fromId":7179,"content":"感谢老哥，可以详谈吗","createdAt":"2024-05-11T09:34:41"},{"id":"01963dee-b673-7312-b193-b548de5dce96","parentId":null,"rootId":null,"fromId":5485,"content":"优点\n每月15号按时发工资(周末节假日可能提前或延后)\n最低的五险(一金看人)\n业绩好的每半年发一点业绩(怕离职留下烂摊子没人管)\n现在中午管饭\n\n缺点\n单双轮休，单休遇到节假日的调休可能就不休了两周连上，也可能休一天管理层还觉得自己很仁慈\n迟到、不写日报、下班或周末不回复客户消息、其他某些情况需要\"乐捐\"\n每周一下班强制开会定目标\n平时不强制但鼓励加班，部分卷王会卷到凌晨一点\n别得罪产品经理(销售)，不然事少钱多的项目可能提前安排掉，事多钱少的项目会被动(强制)给你\n\n总结\n不管你是什么岗位，能从客户那要来钱，伺候好客户不被客户投诉，内卷的就是好员工，躺平会被优化\n\n提示\n前两年的时候，技术岗业绩前五的老员工的业绩总和，干不过销售第一","createdAt":"2024-05-11T12:00:34"},{"id":"01963dee-b678-7066-832b-98d521504cc7","parentId":null,"rootId":null,"fromId":7179,"content":"感谢老哥的长文讲解","createdAt":"2024-05-11T14:50:45"},{"id":"01963dee-b67c-700e-ac7e-54ca40ca5ed9","parentId":null,"rootId":null,"fromId":7483,"content":"啊","createdAt":"2024-05-14T11:06:49"},{"id":"01963dee-b5d6-734e-b829-700b88a8fbc9","parentId":null,"rootId":null,"fromId":7483,"content":"楼主表达不准确  我昨天去面试过  我也是个大专崽  首先面试根本没问技术  公司提的要求是 试岗1~3天定薪资  试岗没工资 通不通过都不确定呢 楼主估计经验不多 没明白啥意思吧","createdAt":"2024-05-14T11:08:15"},{"id":"019addd9-4bae-71e9-9ae9-2f93e8bfe4ee","parentId":null,"rootId":null,"fromId":801,"content":"做开发也得找客户拉业绩吗","createdAt":"2025-12-02T14:56:36"}]