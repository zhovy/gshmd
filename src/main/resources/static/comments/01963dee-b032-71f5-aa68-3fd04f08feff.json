[{"id":"01963dee-b098-724d-90f9-64b6a211f083","parentId":null,"rootId":null,"fromId":6743,"content":"你这不给这公司埋点雷，对得起他们吗","createdAt":"2024-05-09T21:25:07"},{"id":"01963dee-b0dd-739a-8d0e-26aada804cb0","parentId":null,"rootId":null,"fromId":7107,"content":"永远不要把老板往好了想，hr也是一丘之貉，吃一堑长一智了","createdAt":"2024-05-10T08:30:24"},{"id":"01963dee-b0e2-73f4-866e-898a25a3c29a","parentId":null,"rootId":null,"fromId":1889,"content":"怎么不说是什么公司名字呢？","createdAt":"2024-05-10T08:39:23"},{"id":"01963dee-b132-73c8-ace0-45d0207c0251","parentId":null,"rootId":null,"fromId":5954,"content":"既然提了离职你就忠诚度有问题了，没有忠诚度就不要有幻想他们能做出有信用的行为来。你傻吗？提了离职，已经触碰红线了，赶紧走啊？都多大了？还吃饼？","createdAt":"2024-05-10T08:40:09"},{"id":"01963dee-b179-72ab-af79-a461a77d9203","parentId":null,"rootId":null,"fromId":333,"content":"开弓没有回头箭 提了离职就不该心软 这下难受了吧","createdAt":"2024-05-10T09:15:02"},{"id":"01963dee-b1bc-72d1-9114-ec2a8bd7283c","parentId":null,"rootId":null,"fromId":5624,"content":"奇奇怪怪，提了离职还等什么呢？不懂","createdAt":"2024-05-10T10:17:09"},{"id":"01963dee-b200-7092-b428-51e6318f5985","parentId":null,"rootId":null,"fromId":7427,"content":"开弓没有回头箭","createdAt":"2024-05-10T10:44:30"},{"id":"01963dee-b244-7384-99fa-eb5bdade073a","parentId":null,"rootId":null,"fromId":4261,"content":"你这智商配得上你的经历，真的不是嘲讽你。是你确实...","createdAt":"2024-05-10T11:19:34"},{"id":"01963dee-b287-7211-a323-9eadaeba800c","parentId":null,"rootId":null,"fromId":4140,"content":"你提了离职，HR就开始招人顶替你，结果你不走了，人家招聘的人招到了，offer也发了，说不定人家薪资比你还低，技术比你好，人家为啥留你，最主要你自己主动提的离职，人家解雇你一毛钱不用赔，是你自己一步步把自己至到这种全是风险，没有收益的地步，建议吃一堑长一智，以后干任何事都想想你干的事风险和收益再做决定","createdAt":"2024-05-10T11:36:33"},{"id":"01963dee-b2d1-7277-9fba-4e0e8b7e47ed","parentId":null,"rootId":null,"fromId":5954,"content":"真的不赖别人","createdAt":"2024-05-10T12:16:50"},{"id":"01963dee-b316-723a-9dce-49dd79378929","parentId":null,"rootId":null,"fromId":7107,"content":"看了网友说的我也不辩解我一点问题都没有。也干了好几年了 为什么离职呢？刚进公司第一年工资发的即时，之后老板就开始骚操作，频繁欠薪，去年底欠了四个月工资，过年前几天才发了一个月的，当时给所有人承诺过完年不会了，过完年到现在又欠三个多月了，你得多忠诚啊 能继续给他干。再一个为什么提了没走，他不给开离职证明怎么走？没点能力敢辞职？很抱歉已经拿了几个offer，都比上家好，涨幅40%，感谢老板让我睁眼看世界","createdAt":"2024-05-10T12:22:25"},{"id":"01963dee-b2cc-7010-8135-163fd8114fa5","parentId":null,"rootId":null,"fromId":7107,"content":"谢烽火哥指点，确实我考虑的也欠妥。事以密成","createdAt":"2024-05-10T12:30:06"},{"id":"01963dee-b35e-7012-8445-5810f3419b86","parentId":null,"rootId":null,"fromId":875,"content":"济南都跟谁学的？没有年终奖，工资绩效占比越来越高","createdAt":"2024-05-11T09:25:25"},{"id":"01963dee-b35a-7334-9957-720feb33b95f","parentId":null,"rootId":null,"fromId":7453,"content":"某林？","createdAt":"2024-05-11T11:30:09"}]