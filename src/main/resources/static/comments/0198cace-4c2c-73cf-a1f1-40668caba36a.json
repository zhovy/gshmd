[{"id":"0198cb0e-30fd-7351-98a9-5e1aece4ddd4","parentId":null,"rootId":null,"fromId":6018,"content":"去面试了 问的非常简单 不知道为啥挂了","createdAt":"2025-08-21T13:16:01"},{"id":"0198cb36-9b65-73ec-8a33-13086b6fa3a7","parentId":null,"rootId":null,"fromId":21302,"content":"最近一年第三次还是第四次搬家吧，办公环境倒是越换越好，优点除了极个别特殊人员其他同事都不错，缺点公积金双边还没我现在公司单边交的多。","createdAt":"2025-08-21T14:00:10"},{"id":"0198cb3e-65fa-7242-b6eb-492a6832f29c","parentId":null,"rootId":null,"fromId":3378,"content":"我朋友刚从那里离职，让他给你说说","createdAt":"2025-08-21T14:08:40"},{"id":"0198cb43-d758-7238-85c6-12e3b4e9dbcd","parentId":null,"rootId":null,"fromId":2783,"content":"1.五险一金，济南最低基数，最低比例。\n2.周六上午上班\n3.说是有年终奖，据悉老员工说 最多一半。\n4.多年不涨薪。提涨薪就PUA你\n5.工作没技术含量，全是调取第三方数据接口。\n6.工作日加班多，基本是强制性的那种。\n7.项目管理混乱。","createdAt":"2025-08-21T14:14:37"},{"id":"0198cb44-8eda-72d3-953b-8f41d703d7f1","parentId":null,"rootId":null,"fromId":2783,"content":"迪亚这破地方 这叫环境好？","createdAt":"2025-08-21T14:15:24"},{"id":"0198cb46-dfcb-72d5-8484-366e34671888","parentId":null,"rootId":null,"fromId":2783,"content":"小心试用期卡转正 听劝兄弟","createdAt":"2025-08-21T14:17:56"},{"id":"0198cb47-c5db-7036-9184-25df2ddd0fea","parentId":null,"rootId":null,"fromId":3378,"content":"太全面了","createdAt":"2025-08-21T14:18:55"},{"id":"0198cb4d-5f77-703e-9832-7290cf98ea28","parentId":null,"rootId":null,"fromId":21302,"content":"总比之前银荷和银荷之前那个地方好吧","createdAt":"2025-08-21T14:25:02"},{"id":"0198cb4f-05fc-72d8-8208-9ab45ca85421","parentId":null,"rootId":null,"fromId":21302,"content":"项目管理混乱是因为研发组长（性别未知）太垃圾","createdAt":"2025-08-21T14:26:50"},{"id":"0198cb57-a983-73c8-8994-faf45115166d","parentId":null,"rootId":null,"fromId":1955,"content":"我觉得没银荷好吧","createdAt":"2025-08-21T14:36:16"},{"id":"0198d231-74d6-73a6-8f0c-e51dfd328d4f","parentId":null,"rootId":null,"fromId":26583,"content":"1、大概率会卡试用期不给过\n2、每周六强制上半天班，后期可能会彻底变单休\n3、加班强度大，没有加班费。只给调休，年底调休有几十上百小时直接无偿清零。\n4、领导要求责任到人，同事之间互相甩锅\n5、多年不给涨工资，新出绩效各种扣工资\n6、日常PUA，公司挂满了各种PUA标语，不知道以为进了传销窝点","createdAt":"2025-08-22T22:31:53"},{"id":"0198df2a-0dd0-71bc-b1fd-cbe3dc127fb1","parentId":null,"rootId":null,"fromId":414,"content":"为啥都说卡试用期，是有很多先例吗?","createdAt":"2025-08-25T10:58:51"},{"id":"0198e122-d084-73d8-9ad5-8c399b0afafa","parentId":null,"rootId":null,"fromId":26583,"content":"卡了得四五个人了","createdAt":"2025-08-25T20:10:11"},{"id":"0198e124-8903-718a-9147-7b6b848eaa00","parentId":null,"rootId":null,"fromId":26583,"content":"说不符合预期，然后逼着你签协议同意延长试用期。直到受不了走人为止","createdAt":"2025-08-25T20:12:04"},{"id":"0198e1a6-dc81-7002-b53d-747a09532679","parentId":null,"rootId":null,"fromId":2783,"content":"完全同意","createdAt":"2025-08-25T22:34:25"},{"id":"0198eaf2-3e9a-71dc-91a8-5935d0ebd318","parentId":null,"rootId":null,"fromId":2783,"content":"不止四五个人","createdAt":"2025-08-27T17:53:21"},{"id":"0198f390-42eb-7157-8875-93654f8fddd8","parentId":null,"rootId":null,"fromId":22105,"content":"公司不知道，那个地方真的一言难尽，电梯又小又破，早晚就猛猛挤就行，食堂的饭难吃的很，又贵分量又少，15的面扒拉几筷子就没了，盒饭也是给的少。中间小公园一下去全是抽烟的全是烟蒂","createdAt":"2025-08-29T10:02:54"},{"id":"0198fb47-1d69-727f-b68a-1e2530a16d0a","parentId":null,"rootId":null,"fromId":2783,"content":"办公地点不行的公司 待遇好不到哪去","createdAt":"2025-08-30T21:59:58"},{"id":"01991e09-c221-7037-921c-6a59a9007ba1","parentId":null,"rootId":null,"fromId":22772,"content":"能劝一个是一个，能不去就别去，从领导到基层就是一群草台班子，各种甩锅，听以前不少同事说还有卡试用期的。。。","createdAt":"2025-09-06T15:59:40"},{"id":"019a7dbd-82d8-714f-9094-fb9dbffdd624","parentId":null,"rootId":null,"fromId":721,"content":"1.公司已实行大小周，且日常加班成为常态。\n2.绩效规定极为严苛，对细微错误的容忍度低，绩效当月会扣减工资\n3.同事间协同效率低，存在明确的问责文化，员工为防止甩锅，不得不反复在公开群聊中确认工作细节，内耗严重。\n4.近月来多位老员工离职，出现人员断层","createdAt":"2025-11-13T23:02:43"},{"id":"019b67d0-1acb-733c-bac6-a45d51770b4e","parentId":null,"rootId":null,"fromId":557,"content":"某蕾丝边吗","createdAt":"2025-12-29T09:54:10"},{"id":"019b67d2-43f1-70fb-b63e-60f5091746e2","parentId":null,"rootId":null,"fromId":2783,"content":"？？？？？","createdAt":"2025-12-29T09:56:31"},{"id":"019ba142-6a12-730a-a011-4770bf1d81b5","parentId":null,"rootId":null,"fromId":28332,"content":"关于 2，3 这2个事能不能举个例子。","createdAt":"2026-01-09T13:37:22"}]