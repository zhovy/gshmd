[{"id":"01963de4-ea0e-7005-9a36-3a40db50472b","parentId":null,"rootId":null,"fromId":2408,"content":"没有建议，现在都难的一批，今时不同往日了? ","createdAt":"2023-07-15T10:19:02"},{"id":"01963de4-ea53-7319-8a70-aafed98bcb0f","parentId":null,"rootId":null,"fromId":875,"content":"实在找不到工作的，刚毕业的瞎写几个项目，背熟面试题，糊弄糊弄面试官，要个一万来块钱不是问题","createdAt":"2023-07-15T10:47:55"},{"id":"01963de4-eaac-72cd-9d03-9ad537b665a6","parentId":null,"rootId":null,"fromId":3172,"content":"啥逻辑这是？？？","createdAt":"2023-07-15T10:51:57"},{"id":"01963de4-eab0-72a5-bd55-4135e2f52cb9","parentId":null,"rootId":null,"fromId":1492,"content":"他这意思，你包装下简历，但你刚毕业也没啥项目，写两个项目包装下自己开发经验。再背背1-3年经验的面试题。面试应该也不会多难为应届生，毕竟干刚毕业也没啥经验","createdAt":"2023-07-15T11:09:55"},{"id":"01963de4-eab8-70d9-a3bf-2e6cd7b687f2","parentId":null,"rootId":null,"fromId":1376,"content":"刚毕业包装啥简历，难道说高中就开始工作了吗","createdAt":"2023-07-17T20:59:41"},{"id":"01963de4-eab4-7159-9154-d6ac6760b87c","parentId":null,"rootId":null,"fromId":2890,"content":"别尼玛忽悠人了，当面试官都傻啊，包装的简历只是不愿戳破你而已。就算你进去了，啥都不会干你就等着挨裁吧","createdAt":"2023-08-06T12:40:19"}]