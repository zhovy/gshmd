[{"id":"01963df1-8e9e-709b-a056-5ad6f7e6baed","parentId":null,"rootId":null,"fromId":3341,"content":"青岛左岸不清楚 但是如果你要是说滨河左岸 咱们就可以深入的聊一聊了。","createdAt":"2024-07-04T16:30:02"},{"id":"01963df1-8ee9-708f-a3ad-5f1edea2d7db","parentId":null,"rootId":null,"fromId":5768,"content":"青岛左岸不清楚 但是如果你要是说滨河左岸 咱们就可以深入的聊一聊了。","createdAt":"2024-07-04T16:33:00"},{"id":"01963df1-8f2e-7386-828b-e08e8d45a059","parentId":null,"rootId":null,"fromId":6941,"content":"青岛左岸不清楚 但是如果你要是说滨河左岸 咱们就可以深入的聊一聊了。","createdAt":"2024-07-04T16:41:50"},{"id":"01963df1-8ee4-72fc-9c2a-e10b4f08c5ac","parentId":null,"rootId":null,"fromId":880,"content":"哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈  是不是很了解那边姑娘的价格","createdAt":"2024-07-04T16:42:40"},{"id":"01963df1-8fba-7182-b53f-29ad49e382bb","parentId":null,"rootId":null,"fromId":21293,"content":"兄弟细嗦，工资不是按月给的吗，放假还扣工资？","createdAt":"2024-07-04T20:19:51"},{"id":"01963df1-8fbe-70c4-8019-93cf19987563","parentId":null,"rootId":null,"fromId":267,"content":"是的，放假扣，工资会拖欠一部分","createdAt":"2024-07-07T12:35:06"},{"id":"01963df1-8fc2-736a-a060-19b06fe5a7aa","parentId":null,"rootId":null,"fromId":7124,"content":"左岸应该是在积成电子里面吧，属于一个积成电子的外包吧","createdAt":"2024-07-17T16:49:33"},{"id":"01963df1-9011-70f1-bd5f-c24526af15d0","parentId":null,"rootId":null,"fromId":1372,"content":"外包到临工重机这边，做WMS是仓库管理系统。这个系统之前有个公司在做了，那个公司工资不发，各种破事，现在想替换掉他。这个项目别去，乱的很。要上线了，需求还定不下来。天天加班到深更半夜，傻逼项目经理还觉得你没活干。","createdAt":"2024-07-18T15:45:43"},{"id":"01963df1-9054-7288-a432-a8e26ab2dae0","parentId":null,"rootId":null,"fromId":267,"content":"纯粹是最难缠的项目，给1.5倍加班工资都不好弄的那种吧","createdAt":"2024-08-23T02:57:04"},{"id":"01963df1-905a-7355-8c64-e55a65808762","parentId":null,"rootId":null,"fromId":1625,"content":"纯人力外包 死坑 待遇低，还被鄙视","createdAt":"2024-09-12T17:24:15"},{"id":"01963df1-90a3-704f-bbdd-d2e1a5facb2e","parentId":null,"rootId":null,"fromId":1039,"content":"为啥不直接面蓝剑智能，兰剑今年业务扩张，我今年就来的蓝剑，缺点就是最低五险一金、加班严重和没有节假日福利，好处就是工资还可以，双休一般不加班（项目现场除外）","createdAt":"2024-09-12T17:36:08"},{"id":"01963df1-90e7-713c-8c9a-57afe800dd3c","parentId":null,"rootId":null,"fromId":3219,"content":"工作到手能用多少，方便说下范围吗","createdAt":"2024-09-18T17:13:09"},{"id":"01963df1-90eb-728c-86b0-0bc612551a5f","parentId":null,"rootId":null,"fromId":6517,"content":"这几个缺点麻了，劝退了","createdAt":"2024-10-15T15:06:33"},{"id":"01963df1-909e-70d0-bc22-98e63715c003","parentId":null,"rootId":null,"fromId":267,"content":"是的","createdAt":"2025-03-07T08:31:54"},{"id":"019886e7-abd7-7144-b9d2-ddebbe5cfe8a","parentId":null,"rootId":null,"fromId":267,"content":"青岛左岸这家公司拖欠社保，拖欠工资","createdAt":"2025-08-08T07:39:46"},{"id":"01988831-14d4-71c9-bf63-50dfd2cbc5f5","parentId":null,"rootId":null,"fromId":1039,"content":"兰剑没拖欠工资啊，你说的是左岸吧","createdAt":"2025-08-08T13:39:34"},{"id":"01991491-d9b3-732b-a81c-1c31b9f04b6f","parentId":null,"rootId":null,"fromId":1039,"content":"范围因人而异，可以对标浪潮，我当时对比浪潮的offer，兰剑多15%","createdAt":"2025-09-04T19:52:06"},{"id":"019a7b23-4c96-7315-b1de-83ddfd71ad86","parentId":null,"rootId":null,"fromId":267,"content":"说的太对了，支持","createdAt":"2025-11-13T10:55:02"}]