[{"id":"01963de7-59a5-7014-b210-2fc0195451d7","parentId":null,"rootId":null,"fromId":2821,"content":"zy","createdAt":"2023-09-01T11:15:48"},{"id":"01963de7-59ee-7006-85c1-d9ffd4feb462","parentId":null,"rootId":null,"fromId":1398,"content":"楼主失业了吗？","createdAt":"2023-09-01T11:38:30"},{"id":"01963de7-5a32-70ce-a2cf-810219b669ff","parentId":null,"rootId":null,"fromId":3892,"content":"没有，想趁着年轻找个靠谱公司","createdAt":"2023-09-01T11:40:59"},{"id":"01963de7-5a36-71b6-8b35-82abe6a5492e","parentId":null,"rootId":null,"fromId":2921,"content":"自己开","createdAt":"2023-09-01T12:11:03"},{"id":"01963de7-59ea-7335-bdf7-8a047b81eacf","parentId":null,"rootId":null,"fromId":875,"content":"众阳？","createdAt":"2023-09-01T12:54:44"},{"id":"01963de7-5a7b-72de-8c49-b6c1c23caf02","parentId":null,"rootId":null,"fromId":1398,"content":"我想开个公司，各位大佬融资，未来绝对是济南最好的公司。","createdAt":"2023-09-01T14:33:54"},{"id":"01963de7-5ac6-7338-b773-a2248a35e000","parentId":null,"rootId":null,"fromId":3219,"content":"国子软件","createdAt":"2023-09-01T14:36:52"},{"id":"01963de7-5b10-71b4-90b0-30a5267f23ff","parentId":null,"rootId":null,"fromId":3705,"content":"好啊，但好公司没坑位啊","createdAt":"2023-09-04T09:57:27"},{"id":"01963de7-5b58-73c0-a349-a9094af72230","parentId":null,"rootId":null,"fromId":576,"content":"好公司要求也高啊，像华为，百度，字节，美团，高德，阿里，这不都是互联网公司么。还是说你喜欢在非互联网公司里面，然后人家老板成立一个技术部，说这个部门只是打助攻的，赚钱不靠你，你待的就是一直耗资的那个部门。这算是济南工业、商业性质的非互联网公司里比较典型的例子了。如果真的是要找互联网公司，真的建议你开始学习大数据、人工智能，提升英语水平，提升学历等等，这样你才能去月入3w+的大厂里面去。或者合伙创业，你要么出资，要么出技术。反正时间成本你得好好研究研究，因为市场是越快进越好，可是你的架构才刚刚开始，好好研究吧，要是创业的话，你该做些什么，你能做些什么。外包公司可别再建了，九死一生，凤毛麟角的外包企业或者合作价格极低的外包才能在济南站得住脚。现在的济南企业转型，大部分都只把技术部门当成辅助部门，没什么话语权，即使你100年经验，老板不给你配人控制成本，你又能兴起什么风浪呢？在济南打工是没法赚到200w的，创业又得想这个时间成本该怎么解决，转行还得从头再来，兼职要么没有时间要么没人理，做10年外包到最后人家一套大数据技术跟AI技术不直接完爆你么。","createdAt":"2023-09-05T08:28:08"},{"id":"01963de7-5b0a-7213-af55-d49a97957b4f","parentId":null,"rootId":null,"fromId":1751,"content":"笑死","createdAt":"2023-09-05T11:00:33"}]