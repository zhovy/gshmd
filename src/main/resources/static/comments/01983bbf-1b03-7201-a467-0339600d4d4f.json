[{"id":"01983f5c-541b-7279-831b-12a0837027a5","parentId":null,"rootId":null,"fromId":3608,"content":"很简单，开个户就行，不过现在可能得肉身去香港才行，提前预约一下，换成美元存定期，利息在4%左右，个别银行有门槛或者管理费，不过换回人民币的时候有汇率变动的风险。","createdAt":"2025-07-25T10:14:32"},{"id":"01983fa0-b538-7048-a0ca-ac9599642005","parentId":null,"rootId":null,"fromId":3450,"content":"好不容易把钱换出去了，干嘛还换回人民币，狡兔三窟","createdAt":"2025-07-25T11:29:13"},{"id":"0198405b-13d7-7340-bebe-0bfab786b06a","parentId":null,"rootId":null,"fromId":3608,"content":"你在国内花不了美元啊","createdAt":"2025-07-25T14:52:47"},{"id":"01984100-689a-71d5-898e-d7440debf89d","parentId":null,"rootId":null,"fromId":25953,"content":"听说俄罗斯那边更高，普遍年化18%","createdAt":"2025-07-25T17:53:22"},{"id":"01984ef4-254b-7174-8209-e01c5439e167","parentId":null,"rootId":null,"fromId":3608,"content":"那边风险太高了，存好存，取可就不好说了","createdAt":"2025-07-28T10:54:39"}]