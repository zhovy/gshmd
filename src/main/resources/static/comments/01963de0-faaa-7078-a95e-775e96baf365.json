[{"id":"01963de0-fb0e-732b-a4fc-b807411d6769","parentId":null,"rootId":null,"fromId":2241,"content":"待遇一般是根据工作经验与学历两方面来评估","createdAt":"2023-04-03T10:46:21"},{"id":"01963de0-fb54-72cb-9729-d1fb11403e53","parentId":null,"rootId":null,"fromId":629,"content":"两年多不到三年给的9.5","createdAt":"2023-04-03T11:05:04"},{"id":"01963de0-fb99-710f-a2d7-31b749733928","parentId":null,"rootId":null,"fromId":2495,"content":"不到三年能给9.5?啥公司啊，哥哥","createdAt":"2023-04-03T11:12:22"},{"id":"01963de0-fbe2-7028-a207-9bdb1cfd9656","parentId":null,"rootId":null,"fromId":1656,"content":"本科2年的话，现在估计能给8？算多的了吧","createdAt":"2023-04-03T11:13:25"},{"id":"01963de0-fc29-72da-8ae2-df2c031785ca","parentId":null,"rootId":null,"fromId":2495,"content":"我是本科，2年多不到3年，最多的现在给了8，唉，真不多","createdAt":"2023-04-03T11:14:41"},{"id":"01963de0-fc74-738b-aaee-e499dd929ab3","parentId":null,"rootId":null,"fromId":352,"content":"21年6月毕业，税前12，2月莫名其妙工资税前14（好像有去年第四季度的加班补贴），今天发现3月工资竟然是到手14.5，现在还不知道为什么","createdAt":"2023-04-03T13:12:09"},{"id":"01963de0-fcb9-7122-ab78-ab4920644c5c","parentId":null,"rootId":null,"fromId":352,"content":"楼上本科","createdAt":"2023-04-03T13:12:27"},{"id":"01963de0-fd26-7285-8887-7cb1a4591d05","parentId":null,"rootId":null,"fromId":629,"content":"//我是二楼，我这不推荐来，没有任何福利待遇，年终奖啥的，连过节礼品都没有，五险一金最低，我主要是图离家近没办法，面的也不好，没敢多要，顺便问问六楼是啥公司哈哈","createdAt":"2023-04-03T13:37:01"},{"id":"01963de0-fd6e-73c1-ada6-bf70afa12e7d","parentId":null,"rootId":null,"fromId":2241,"content":"六楼是985 211吗  我双非硕1年 只有10 so sad","createdAt":"2023-04-03T13:42:45"},{"id":"01963de0-fdb7-71f9-a3bf-cc75014e2e04","parentId":null,"rootId":null,"fromId":3131,"content":"6楼兄弟哪家公司啊，感觉挺香的","createdAt":"2023-04-03T13:52:19"},{"id":"01963de0-fdfc-7343-be43-0855d63a4078","parentId":null,"rootId":null,"fromId":1656,"content":"6楼这什么公司","createdAt":"2023-04-03T15:26:55"},{"id":"01963de0-fe41-7246-ab38-32468dbdc79b","parentId":null,"rootId":null,"fromId":352,"content":"诚邀各位加入我们天健联创控股（山东）集团有限公司，地址：济南市高新区鲁商福瑞达广场。公司福利齐全：薪资高于济南平均水平，缴纳五险一金，享受带薪年假、法定假日、年终奖，员工生育、生病慰问；员工子女保教费报销等，各种节日福利拿到手软\n1、集团公司实行弹性化工作制，让您成为自己的时间管理者。\n2、基本权益保障一应俱全。公司会与您签订正式的劳动合同，为您缴纳五险一金，并享受带薪的法定假期。\n3、薪酬体系完备完善。集团公司实施结构性工资制度，持续推动薪酬制度改革，让全体员工得到务实的安全感。\n4、以人为本，福利最大化。集团公司实现“基本保障+生活关爱+个性化关怀”福利全覆盖，为全体员工提供季度福利、节日福利、生育福利、生日福利等。\n5、重视培训投入，助力员工成才。集团公司定期组织各类培训学习活动，无限量发掘和培育创新人才，助您在职场实现华丽蜕变。","createdAt":"2023-04-03T16:23:33"},{"id":"01963de0-fe84-71ab-bc96-e5ad4bcc838c","parentId":null,"rootId":null,"fromId":3183,"content":"12楼有联系方式吗","createdAt":"2023-04-03T16:40:33"},{"id":"01963de0-fec8-738b-902d-469acd4396a5","parentId":null,"rootId":null,"fromId":2436,"content":"哈哈哈，我倒是觉得12楼是那种上班摸鱼的反串小黑子，不然哪里都能看到你呢；13楼看清楚了再打听吧","createdAt":"2023-04-03T17:06:12"},{"id":"01963de0-ff0d-7290-9242-acdb037f70d4","parentId":null,"rootId":null,"fromId":875,"content":"你们怎么回事，一年八千，三年一万，五年一万六，跳槽我都要两万+，你得要的多人家才敢给","createdAt":"2023-04-03T18:10:54"},{"id":"01963de0-ff52-718a-adea-f538cf6a3315","parentId":null,"rootId":null,"fromId":2407,"content":"是专科吗？","createdAt":"2023-04-03T19:42:25"},{"id":"01963de0-ff95-7061-9dc6-31a705cf6169","parentId":null,"rootId":null,"fromId":1656,"content":"15楼给offer了吗？还是就在这扯淡","createdAt":"2023-04-03T19:45:28"},{"id":"01963de0-ffda-7149-a5f0-09de685ab07e","parentId":null,"rootId":null,"fromId":352,"content":"我是6楼，大家不用问我什么公司，你找工作得敢要价，意向10要12、13，公司和打工人是双向选择，你敢要公司才会把你当回事，找工作跟要饭似的不会看不起自己？要是大家都这样还会拉低市场价格。面试的时候自信就完了，别管对不对敢说，就认定你说得对，公司爱要不要。打工人也得有尊严","createdAt":"2023-04-03T19:53:40"},{"id":"01963de1-001f-73fb-8d65-bdfb4944d1c2","parentId":null,"rootId":null,"fromId":352,"content":"13楼大哥火眼金睛啊，我是12楼小黑子，想让天健联创控股集团董事长姚萌携全家带上大壮给我嗦牛子","createdAt":"2023-04-03T20:03:33"},{"id":"01963de1-0063-702f-8c74-acadf58bdea3","parentId":null,"rootId":null,"fromId":1150,"content":"还行吧 面试都是要3w+，不给？那就不去了，反正我现在赋闲在家好几年了","createdAt":"2023-04-04T11:24:52"},{"id":"01963de1-00a8-71f6-ad06-900f77973e0a","parentId":null,"rootId":null,"fromId":1261,"content":"报价比心里预期价位高2k","createdAt":"2023-04-04T12:15:01"},{"id":"01963de1-00ed-712a-b9f0-7e16f621f0d6","parentId":null,"rootId":null,"fromId":1656,"content":"一个比一个说的牛逼，给offer了吗，我就不信济南两三万薪资这么多","createdAt":"2023-04-04T16:59:44"},{"id":"01963de1-0134-731c-b78e-6f63109befd6","parentId":null,"rootId":null,"fromId":2776,"content":"3年我绝对要12k往上，3年还7k干脆去送外卖，干这行干啥？专科且水平一般的话可以理解。","createdAt":"2023-04-05T12:35:01"},{"id":"01963de1-0179-710f-8ce6-e7eab76aba7b","parentId":null,"rootId":null,"fromId":875,"content":"就是五年我都要两万，然后人家要是还价一万五，最后成交价往往是一万七八，你要是要个一万五，最后也就能拿个一万","createdAt":"2023-04-05T15:15:50"},{"id":"01963de1-01bd-70bd-890d-248ec0d1d314","parentId":null,"rootId":null,"fromId":1656,"content":"一看你们这帮人就是最近没面试，还以为行情多好呢","createdAt":"2023-04-09T09:12:22"},{"id":"01963de1-0201-730a-8ffd-099d442f064e","parentId":null,"rootId":null,"fromId":2958,"content":"同意25楼，面试过的都懒得讨论工资","createdAt":"2023-04-12T10:30:30"},{"id":"01963de1-0246-7287-8f20-bef31c7ac207","parentId":null,"rootId":null,"fromId":3263,"content":"明天我面一个试试，我要30K","createdAt":"2023-04-12T21:31:28"},{"id":"01963de0-fbde-7397-9241-8383f19f7208","parentId":null,"rootId":null,"fromId":3341,"content":"也是看能力 实际上干1-2两年如果接触的技术比较核心  就出来了  包装五六年都没问题   能力不行十年也是白搭 ","createdAt":"2023-04-21T14:18:48"}]