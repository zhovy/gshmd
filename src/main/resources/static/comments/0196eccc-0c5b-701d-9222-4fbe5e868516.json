[{"id":"0196ecfb-4578-7091-aed8-299e5d74ded7","parentId":null,"rootId":null,"fromId":4140,"content":"换城市问题迎刃而解，你把你BOSS求职地址换了，再投简历，你会有不一样的感觉，济南投100个，80个不搭理你15个外包找你，5个销售、老师岗找你，投几百个可能遇到一个像人的公司，然后发现一堆人报名，工作十几年的，学历比你高的比比皆是，还干个dam~！","createdAt":"2025-05-20T17:16:52"},{"id":"0196ed03-e56f-7297-8989-16247813fb19","parentId":null,"rootId":null,"fromId":5661,"content":"30 35不重要，重要的是你会干啥，只会写接口，还是能带团队做项目","createdAt":"2025-05-20T17:26:17"},{"id":"0196ed20-f7ec-7354-96d5-9aa3238e658f","parentId":null,"rootId":null,"fromId":7650,"content":"换到北上广吗","createdAt":"2025-05-20T17:58:02"},{"id":"0196ed24-214f-7100-9d28-13d7b6e8a579","parentId":null,"rootId":null,"fromId":4140,"content":"北上广、青岛、苏州、杭州、武汉、宁波、南京等等都行，反正济南差的很，主要是投简历不回复","createdAt":"2025-05-20T18:01:30"},{"id":"0196ed24-b105-730b-b645-7cf817717b77","parentId":null,"rootId":null,"fromId":5661,"content":"北上广的人才密度远远高于济南吧，在济南都竞争不到个好岗位，去北上广能有机会？","createdAt":"2025-05-20T18:02:06"},{"id":"0196ed2e-a0a7-7176-8de8-93cb96247e1b","parentId":null,"rootId":null,"fromId":24145,"content":"我前两年从上海回来 体感确实上海环境比济南好很多 这次开了智联好多上海的打招呼邀请 济南的根本没有 关键问题就是上海没法买房结婚 老人也都在附近","createdAt":"2025-05-20T18:12:58"},{"id":"0196f03f-b3b9-7399-bee7-34583bd6aad1","parentId":null,"rootId":null,"fromId":2815,"content":"在济南你就是能上天，也得好好趴着","createdAt":"2025-05-21T08:30:28"},{"id":"0196f077-0c48-7295-bfa5-960d349fa5e2","parentId":null,"rootId":null,"fromId":23300,"content":"济南大龄程序员，要么自己干，要么干老师忽悠别人入行，大龄程序员在济南没走上管理岗，基本宣告职业生涯结束了，没办法，高校云集，狼多肉少。。","createdAt":"2025-05-21T09:30:55"},{"id":"0196f0ed-b534-712c-a01b-2aa849736a07","parentId":null,"rootId":null,"fromId":23027,"content":"去众阳。","createdAt":"2025-05-21T11:40:32"},{"id":"0196f20e-a7c1-733c-9324-ab2f285bf068","parentId":null,"rootId":null,"fromId":23531,"content":"北上广人才缺口更大，填不满的。退一万步说，你去北上广干外包也比在济南干好","createdAt":"2025-05-21T16:56:08"}]