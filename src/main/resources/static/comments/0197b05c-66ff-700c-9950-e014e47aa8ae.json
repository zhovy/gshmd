[{"id":"0197b067-0850-7041-8581-71cc1a1ea7e7","parentId":null,"rootId":null,"fromId":24326,"content":"几乎不太可能，投完简历基本上没人看","createdAt":"2025-06-27T16:00:31"},{"id":"0197b079-16ee-7165-970b-4f5a5499bb54","parentId":null,"rootId":null,"fromId":25434,"content":"投产品助理岗也没人理吗","createdAt":"2025-06-27T16:20:15"},{"id":"0197b0ae-1b4c-7159-8dea-34b639112752","parentId":null,"rootId":null,"fromId":7270,"content":"现在济南还有产品助理的岗位吗？","createdAt":"2025-06-27T17:18:09"},{"id":"0197b0bc-77b0-714b-879a-ff077885ff48","parentId":null,"rootId":null,"fromId":25434,"content":"有但非常少","createdAt":"2025-06-27T17:33:50"},{"id":"0197be95-f479-7352-af57-04f0ecde1624","parentId":null,"rootId":null,"fromId":1039,"content":"只能投投产品助理，或者自己上网学一下产品相关内容，然后把运营的经验包装成产品的经验，找个薪资要求不高的进去先磨练磨练，把能力和经验提升上来在换","createdAt":"2025-06-30T10:06:27"},{"id":"0197bed2-9532-73b4-b42f-ede67a464632","parentId":null,"rootId":null,"fromId":25463,"content":"还是要看个人，工作和生活分的很开的朋友，不建议做产品和项目经理岗位，因为周末接电话是真烦","createdAt":"2025-06-30T11:12:41"},{"id":"0197bf12-0d1d-72dc-ae55-d4138e442f0c","parentId":null,"rootId":null,"fromId":24615,"content":"我们公司的产品经理是靠年限慢慢晋升上去的，没见过直接招进来的。。。。毕竟外面人进来，系统功能、业务都不懂，这咋跟客户和团队成员沟通","createdAt":"2025-06-30T12:22:00"},{"id":"0197bf15-8e10-7021-8f92-139d6d07889d","parentId":null,"rootId":null,"fromId":24615,"content":"我们这产品经理很累，都是老油条而且情商不能低、有强大的抗压能力才能干的下去，周末开会写材料都是很正常的事情，别想着放松去某个景点玩啥的","createdAt":"2025-06-30T12:25:50"},{"id":"0197c49d-446a-73fe-843a-6fd7719331a4","parentId":null,"rootId":null,"fromId":24183,"content":"那项目经理呢，也是这个样子吗","createdAt":"2025-07-01T14:12:10"},{"id":"0197c58b-8743-7018-accf-61703124b769","parentId":null,"rootId":null,"fromId":24615,"content":"我们这项目经理有不少是社招进来的，对系统不熟悉也没事，主要是能把进度管控好，带着团队加班，做好合同签单和验收","createdAt":"2025-07-01T18:32:25"},{"id":"01987413-b10b-70d9-ad1d-e1193fd27318","parentId":null,"rootId":null,"fromId":25434,"content":"明白了，感谢??","createdAt":"2025-08-04T15:55:04"}]