[{"id":"01963de4-7039-7267-af61-54ffc13f79b7","parentId":null,"rootId":null,"fromId":4038,"content":"拖欠工资，老板不露面，让人事当档箭牌；现在是七月中，我五月份的工资还没发","createdAt":"2023-07-11T17:08:12"},{"id":"01963de4-7081-73f7-b06b-294db7e7e7e0","parentId":null,"rootId":null,"fromId":4038,"content":"你入职了没，发工资了没","createdAt":"2023-09-15T16:36:22"},{"id":"01963de4-707d-7003-9ad3-5431a85dd282","parentId":null,"rootId":null,"fromId":5691,"content":"我也是,咱俩说不准还认识呢","createdAt":"2023-09-18T09:50:15"},{"id":"01963de4-70c5-73f8-b7fc-12703a30eded","parentId":null,"rootId":null,"fromId":2598,"content":"现在还在欠薪嘛","createdAt":"2025-03-04T08:46:49"},{"id":"0196a97d-56e5-7088-a551-517a68cd7477","parentId":null,"rootId":null,"fromId":23949,"content":"欠的","createdAt":"2025-05-07T14:44:45"}]