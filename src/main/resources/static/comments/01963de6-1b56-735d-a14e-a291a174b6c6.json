[{"id":"01963de6-1bbd-7197-b6f9-533b9ebb3c36","parentId":null,"rootId":null,"fromId":3892,"content":"我问了问，是电信外包","createdAt":"2023-08-09T15:59:23"},{"id":"01963de6-1c01-704e-906d-83ec70af15bd","parentId":null,"rootId":null,"fromId":4020,"content":"但是他三个HR都来找我聊，我就有点怕，像是非我不可似的","createdAt":"2023-08-09T16:00:14"},{"id":"01963de6-1c06-730f-9ffc-e45d82a9624f","parentId":null,"rootId":null,"fromId":2821,"content":"那就加钱","createdAt":"2023-08-09T16:03:51"},{"id":"01963de6-1c0b-7069-8927-d929feec7978","parentId":null,"rootId":null,"fromId":3892,"content":"那就别去，估计不咋地","createdAt":"2023-08-09T16:20:33"},{"id":"01963de6-1c13-73ef-b01a-800dedbea14f","parentId":null,"rootId":null,"fromId":3117,"content":"只要你到中软那边去报道参与面试了，HR就有钱赚，所以HR不管你什么情况，都邀请去面试   ；能不去就不去，这家外包公司存在很多年了；多个HR找很正常，可能不是给同一家公司招人；一般来说薪资范围、技术标准都不一样；一旦去了某一个，假设没有过，还会一直让你去其他地方试试；","createdAt":"2023-08-11T11:44:48"}]