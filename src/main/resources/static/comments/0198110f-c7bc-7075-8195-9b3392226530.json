[{"id":"019811e6-a835-7194-a337-a6a2cbb2df83","parentId":null,"rootId":null,"fromId":22699,"content":"我就是偏头痛，但是没有去查过。你的严重吗","createdAt":"2025-07-16T14:23:05"},{"id":"019811ee-bc1e-7352-81d0-5cff8fe5f0c0","parentId":null,"rootId":null,"fromId":5635,"content":"严重的很，毫无原因的就疼，最近几次持续2 3 天，第一天吃布洛芬都不管用，和炸了似的","createdAt":"2025-07-16T14:31:55"},{"id":"01981262-6c17-73af-9a69-70b0bed26653","parentId":null,"rootId":null,"fromId":22699,"content":"那你和我不一样，我一般睡一觉就好了，有20多年了。看样子你这个更严重，最好听大夫的吧。","createdAt":"2025-07-16T16:38:16"},{"id":"01981268-b46f-72d2-b24a-a33f172b7005","parentId":null,"rootId":null,"fromId":2246,"content":"多看两家医院，多找几个医生，看看他们意见是否一致","createdAt":"2025-07-16T16:45:08"},{"id":"01981700-6ba8-72d4-8f0a-0832d8c5afa4","parentId":null,"rootId":null,"fromId":598,"content":"咱俩的症状是一样的 头疼的时候睡一觉就好了","createdAt":"2025-07-17T14:09:20"},{"id":"01982ff2-45c8-733c-8038-c9b76852536f","parentId":null,"rootId":null,"fromId":23701,"content":"多去几家医院，不要说之前检查过，参考多数医生的建议","createdAt":"2025-07-22T10:24:23"}]