[{"id":"019abe1b-1914-71c2-b7d1-eb00deef6467","parentId":null,"rootId":null,"fromId":24428,"content":"深度好文，对职场菜鸟很有帮助","createdAt":"2025-11-26T11:00:38"},{"id":"019abe20-58dc-738a-aec1-3c80fb8f6efd","parentId":null,"rootId":null,"fromId":7566,"content":"确实，我这几年面试的时候问的越详细的公司越不会给offer，问的问题很简单的公司给offer的概率就大很多","createdAt":"2025-11-26T11:06:22"},{"id":"019abe29-f800-70b2-98b7-eabe79354069","parentId":null,"rootId":null,"fromId":2846,"content":"过来人，有道理","createdAt":"2025-11-26T11:16:52"},{"id":"019abe3c-99bd-70cb-bfbc-cb80bf730ca2","parentId":null,"rootId":null,"fromId":4137,"content":"深度好文，顶起来，让更多的人看到","createdAt":"2025-11-26T11:37:13"},{"id":"019abe3d-ed5e-72df-974b-35c713c713cd","parentId":null,"rootId":null,"fromId":4137,"content":"这真是个好文章，让我不禁联想到了，恒宇，这个公司hr不是经常刷kpi","createdAt":"2025-11-26T11:38:40"},{"id":"019abe81-1212-71cd-849e-bae6b473c554","parentId":null,"rootId":null,"fromId":4140,"content":"是这样的，去清河电子面试，来回面试两轮，每次都是快两个小时，系统架构、业务流程，容灾备份机制、调度任务等等问了个边，最后告诉我不合适，过去一年了，发现这个岗位还在招人哈哈哈","createdAt":"2025-11-26T12:52:01"},{"id":"019abfcc-4c5b-72d5-89a7-4a3cafcb8d5c","parentId":null,"rootId":null,"fromId":27809,"content":"从来没有见过刷kpi的公司，短短一两个小时候选人的回答，还不如chatgpt回答的更全面，如果面试套取商业机密还有点可信度，套方案我是真没见过","createdAt":"2025-11-26T18:53:48"},{"id":"019ac2d0-ffd6-71d1-bdda-e8dee757fa4f","parentId":null,"rootId":null,"fromId":6091,"content":"可能面试问的多又细是那种不着急招人得公司，肯定需要挑好的","createdAt":"2025-11-27T08:57:48"},{"id":"019ac2fb-9ef5-7073-939a-efb88d23c31f","parentId":null,"rootId":null,"fromId":27118,"content":"这个得顶一下，免得找不到工作的人怀疑自己","createdAt":"2025-11-27T09:44:21"},{"id":"019ac33c-eac7-7112-b113-dbc00ae7731d","parentId":null,"rootId":null,"fromId":6091,"content":"扎心了老铁，就是菜哈哈","createdAt":"2025-11-27T10:55:40"},{"id":"019adc81-c920-72cf-971e-5a863a406570","parentId":null,"rootId":null,"fromId":3333,"content":"说的难听点，90%的人都是搬砖的，套你们方案，还不如去问ai，别把自己太当回事了哥们","createdAt":"2025-12-02T08:41:24"},{"id":"019adc91-d74b-728d-bc9a-5957de547fe5","parentId":null,"rootId":null,"fromId":26406,"content":"好文，结合自己之前的面试经历，深有同感","createdAt":"2025-12-02T08:58:56"},{"id":"019b0647-bf75-7016-96d9-d066367354f9","parentId":null,"rootId":null,"fromId":1933,"content":"说句实话，套你的方案，还不如找本书看看，或者网上搜搜效率高，你要是真的相关领域的资深工作者，你也不会去靠俩小时套方案就能解决技术难题的这种公司面试，面试细的要求一般都高，面试不上很正常","createdAt":"2025-12-10T11:22:04"},{"id":"019b0655-216c-7310-9cbd-0c92a86afc9b","parentId":null,"rootId":null,"fromId":6091,"content":"确实，现在要求都很高","createdAt":"2025-12-10T11:36:41"},{"id":"019b0705-ca47-70af-ac7c-f23d03d58410","parentId":null,"rootId":null,"fromId":21302,"content":"除了要求高的问的很细的，其他就是套方案的，这里的方案不是那种可行的方案，而是那种一开始的思路，如果他们会思考会去网上找方案，那么还会套方案吗？","createdAt":"2025-12-10T14:49:38"},{"id":"019b3535-1a49-729c-8421-4a5b13542255","parentId":null,"rootId":null,"fromId":1933,"content":"为啥要去一个连百度都不会的公司去面试呢，但凡能凑够十个人的公司都不止于这么拉胯","createdAt":"2025-12-19T14:03:51"}]