[{"id":"01995fe4-3bfa-701e-b703-434509605d45","parentId":null,"rootId":null,"fromId":6747,"content":"当着所有人的面叼他，让他颜面尽失，尤其是再他的领导面前挑战他侮辱他","createdAt":"2025-09-19T10:53:37"},{"id":"01995fe4-a532-713d-958d-8ee85543b759","parentId":null,"rootId":null,"fromId":22250,"content":"他会骂人你不会骂人？直接问候他母亲不行吗","createdAt":"2025-09-19T10:54:04"},{"id":"01995fe9-308e-739f-a5c2-7d1c5a05bf96","parentId":null,"rootId":null,"fromId":24202,"content":"公司没有任何一个人反驳他，都乖得很，副总都很听话的那种","createdAt":"2025-09-19T10:59:01"},{"id":"01995fe9-7caa-73a4-b63c-400b85303c4c","parentId":null,"rootId":null,"fromId":24202,"content":"他就是最大的领导了，没有任何一个人去忤逆他","createdAt":"2025-09-19T10:59:21"},{"id":"01995ff6-7574-7174-9554-4031874217a3","parentId":null,"rootId":null,"fromId":22250,"content":"无解","createdAt":"2025-09-19T11:13:31"},{"id":"01995ff8-33fb-7334-b39b-8ff397d557a9","parentId":null,"rootId":null,"fromId":5624,"content":"玩白，喜欢生气就多气","createdAt":"2025-09-19T11:15:25"},{"id":"01995fff-23a6-71c6-91b6-21b34a8e3669","parentId":null,"rootId":null,"fromId":7344,"content":"公司多少人？","createdAt":"2025-09-19T11:23:00"},{"id":"01996001-5897-72d9-84b6-95c70cdfac42","parentId":null,"rootId":null,"fromId":24202,"content":"几百人吧","createdAt":"2025-09-19T11:25:25"},{"id":"01996001-d687-71f1-a827-dc3a8341166c","parentId":null,"rootId":null,"fromId":7344,"content":"录音发抖音，让他火一把","createdAt":"2025-09-19T11:25:57"},{"id":"01996017-408c-72b7-a9ed-97ccd769f5fb","parentId":null,"rootId":null,"fromId":22250,"content":"还有个办法，知道它家地址么，知道就给他邮寄一些奇怪的东西","createdAt":"2025-09-19T11:49:20"},{"id":"01996017-ed62-7057-8edd-23003f0f7b70","parentId":null,"rootId":null,"fromId":6747,"content":"这更好办了，让他在员工面前颜面尽失，越是大领导越怕这个。不要有太多的光环他也是人","createdAt":"2025-09-19T11:50:04"},{"id":"0199601e-fc79-7119-9354-fe05902b0447","parentId":null,"rootId":null,"fromId":23027,"content":"是众阳的孙钊吗？","createdAt":"2025-09-19T11:57:47"},{"id":"019960a0-8114-7062-990a-919a0b6f7a4a","parentId":null,"rootId":null,"fromId":4073,"content":"孙钊也这样么，他刚当上研发中心领导的时候就离职了，不太了解这个人","createdAt":"2025-09-19T14:19:15"},{"id":"019960f1-4917-707c-9655-d8fc9e665fab","parentId":null,"rootId":null,"fromId":21821,"content":"该留个聊天记录，然后把图片晒出来、话说山东的自媒体也没这样发达，没一个热点博主能宣传的","createdAt":"2025-09-19T15:47:29"},{"id":"019960f9-4fbd-72c8-83b3-252c9e7cb0af","parentId":null,"rootId":null,"fromId":22809,"content":"济南普华春天","createdAt":"2025-09-19T15:56:15"},{"id":"01996131-72c4-7289-b347-e6b41c43e62e","parentId":null,"rootId":null,"fromId":2246,"content":"他卷他的，你躺你的","createdAt":"2025-09-19T16:57:34"},{"id":"01996161-304d-716d-b278-9861670de78a","parentId":null,"rootId":null,"fromId":26886,"content":"驸马啊","createdAt":"2025-09-19T17:49:43"},{"id":"0199663c-633f-7249-8764-35a3b3233e10","parentId":null,"rootId":null,"fromId":1933,"content":"一切向钱看，你觉得你的工资够你的精神损失的就忍着，要是工资很一般，那就可以拿道理怼他（不是对骂）。都21世纪了，不要觉得谁比谁高人一等","createdAt":"2025-09-20T16:27:37"},{"id":"01997cbb-7bb5-7365-aaf3-370b8181ccc9","parentId":null,"rootId":null,"fromId":25733,"content":"想干就忍着, 不想干就骂他, 开了你他得给钱, 难为你恶心你你就别管他, 正常工作上下班就行, 反正你都转正了怕啥, 他用&quot;不能胜任这个岗位&quot;这个理由已经不成立了","createdAt":"2025-09-25T01:18:05"}]