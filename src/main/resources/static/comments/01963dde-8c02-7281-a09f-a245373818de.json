[{"id":"01963dde-8c7c-709d-807e-76149c4f88c8","parentId":null,"rootId":null,"fromId":1955,"content":"单休，单休，单休\n号称成立什么水利专业部门\n要求会GIS，还得是全栈，前端后端一起撸","createdAt":"2023-02-09T18:04:36"},{"id":"01963dde-8cc6-734a-a2f6-b089a822d8cb","parentId":null,"rootId":null,"fromId":2079,"content":"单休确实太可怕了\n成立新部门和新方向，相当于一次新的创业啊","createdAt":"2023-02-09T19:54:20"},{"id":"01963dde-8d0f-7254-86d1-bd8d87d333cb","parentId":null,"rootId":null,"fromId":108,"content":"去年邀请过去面试，因为是单休没有去，听hr说世方是老板以及老板娘的名字中各取一个字组成的。老板崇拜狼性文化","createdAt":"2023-02-10T17:21:21"},{"id":"01963dde-8d53-7046-8e0d-4fca868bd67c","parentId":null,"rootId":null,"fromId":4087,"content":"人员流动大  一线部门老总都要招聘的公司 你说人都去哪里了","createdAt":"2023-07-16T01:12:36"},{"id":"01963dde-8d9c-731d-8c4e-97e709c1d86e","parentId":null,"rootId":null,"fromId":1110,"content":"面试过有个研发部门经理很有意思，估计很会PUA，感觉不像是个好人","createdAt":"2023-07-24T12:47:12"},{"id":"01963dde-8da0-729f-a1ab-f2f622374d8e","parentId":null,"rootId":null,"fromId":2613,"content":"垃圾公司有个研发部门的经理，那傻逼实在无语，说话那个吊样，并且很会PUA","createdAt":"2023-08-08T20:47:39"},{"id":"01963dde-8de4-70ec-a4b6-429c58b6dfa5","parentId":null,"rootId":null,"fromId":7706,"content":"避坑:\n1、单休，试用期没有五险，公积金满一年才给\n2、线上面试了两轮，分别是产品经理。研发老总，分管副总，均通过。关键的来了，人资告知了待遇以及去公司带的证件，去了后又增加了董事长面试，然后就回来等结果了！这是刷业绩啊！","createdAt":"2024-06-11T11:13:02"},{"id":"01963dde-8e29-726c-bde1-f5e3620bd23e","parentId":null,"rootId":null,"fromId":20996,"content":"你面试的是什么岗位？","createdAt":"2024-06-13T09:08:19"},{"id":"01963dde-8e71-72a0-b269-89f1036f1a31","parentId":null,"rootId":null,"fromId":21046,"content":"傻*公司 加班让自愿 不加班扣钱 单休 假期放三天加一天 放五天加三天 没有加班费","createdAt":"2024-12-31T09:07:42"},{"id":"01975e46-fc90-705f-ae2b-67f2fe82ceb9","parentId":null,"rootId":null,"fromId":24999,"content":"那人叫刘鑫，很不要脸的人，经常羞辱员工","createdAt":"2025-06-11T17:16:39"}]