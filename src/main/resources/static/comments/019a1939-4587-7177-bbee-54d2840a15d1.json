[{"id":"019a193b-9f83-717d-80ed-a0719be7ac07","parentId":null,"rootId":null,"fromId":1720,"content":"去长光卫星的话我看以往学长学姐好像搞得是卫星图像识别之类的，请问后续回济南有类似的工作吗","createdAt":"2025-10-25T10:38:49"},{"id":"019a1981-f5ce-73c2-9f27-944f2c7f48da","parentId":null,"rootId":null,"fromId":2921,"content":"当然是去长春","createdAt":"2025-10-25T11:55:38"},{"id":"019a2092-87c4-73e5-b82b-9edb171b87ee","parentId":null,"rootId":null,"fromId":2783,"content":"东三省没啥好公司 不建议。","createdAt":"2025-10-26T20:51:05"},{"id":"019a2330-a3a9-720c-8df9-3ec95ab2630e","parentId":null,"rootId":null,"fromId":24428,"content":"半年50%都能接受，说明你是新人，这里的老哥们肯定都不会接受的。其次虽然承诺了，但是也是承诺了，所以这个工资肯定不是去喝茶的，累半死是大概率的","createdAt":"2025-10-27T09:03:01"},{"id":"019a2331-af5b-7397-b275-a8a2c998d9ee","parentId":null,"rootId":null,"fromId":6435,"content":"50%的薪资？这还需要考虑啥吗？明显是糊弄人啊，干半年让你走，你啥话都说不出来","createdAt":"2025-10-27T09:04:10"},{"id":"019a2337-67dd-7200-bd95-e52c21a369fb","parentId":null,"rootId":null,"fromId":770,"content":"去南方吧","createdAt":"2025-10-27T09:10:24"},{"id":"019a2371-b3bd-721e-8ec7-f5674f94ab29","parentId":null,"rootId":null,"fromId":6517,"content":"济南这么多国企，你别光盯着这俩","createdAt":"2025-10-27T10:14:05"},{"id":"019a2373-776a-73cd-9012-8cb833ae6c07","parentId":null,"rootId":null,"fromId":5500,"content":"啥学历呀？","createdAt":"2025-10-27T10:16:01"},{"id":"019a2374-1e47-70a6-a5ee-f80bc22e9f32","parentId":null,"rootId":null,"fromId":5500,"content":"济南这个你是知道做那个方面的呀","createdAt":"2025-10-27T10:16:43"},{"id":"019a238e-cce0-724d-b0b5-8927bf518b50","parentId":null,"rootId":null,"fromId":1225,"content":"什么学历呀，研究生吗，是92吗","createdAt":"2025-10-27T10:45:52"},{"id":"019a23d4-d314-706f-8098-d5b4dcd56750","parentId":null,"rootId":null,"fromId":1225,"content":"华云别去了最近绩效扣的很严重","createdAt":"2025-10-27T12:02:21"},{"id":"019a2459-421b-71f5-9d3a-fd73a068229e","parentId":null,"rootId":null,"fromId":21676,"content":"济钢下面的子公司、齐鲁空天研究院","createdAt":"2025-10-27T14:27:00"},{"id":"019a2518-b8df-730a-9427-1101eb16f0d6","parentId":null,"rootId":null,"fromId":1720,"content":"硕士","createdAt":"2025-10-27T17:56:08"},{"id":"019a2519-4d35-7151-8b60-0fd257264c89","parentId":null,"rootId":null,"fromId":1720,"content":"是92研究生","createdAt":"2025-10-27T17:56:46"},{"id":"019a251a-14eb-7365-b34a-1e5616a56925","parentId":null,"rootId":null,"fromId":1720,"content":"应该就是搞算法开发的吧，有师兄师姐在里面工作","createdAt":"2025-10-27T17:57:37"},{"id":"019a251d-cb58-7247-86e5-2e3b96e05c78","parentId":null,"rootId":null,"fromId":1720,"content":"运营商和各类银行倒是都投了，但是做完笔试都没信了，前几天倒是面了联通济南软件研究院，感觉面得不怎么样，而且听说里面也挺坑的....","createdAt":"2025-10-27T18:01:40"},{"id":"019a251f-161b-7248-b87b-7dbc4f197926","parentId":null,"rootId":null,"fromId":1720,"content":"听说山大华天近几年要上市控制成本增加利润，感觉准备“降本增效”了","createdAt":"2025-10-27T18:03:05"},{"id":"019a2521-ea4c-73cd-9570-58efb66cb048","parentId":null,"rootId":null,"fromId":1720,"content":"我也是觉得这里面有坑，听今年入职的师兄说转正没太大问题，但是年初开除了一批人（据说是不愿意加班并且绩效不行的，但真相如何谁知道呢），而且进去主要是搞研究，读研后真的看到“研究”就难受，而且离家有点远，不太想去","createdAt":"2025-10-27T18:06:11"},{"id":"019a2532-c4d2-7134-ac68-49d65f012cd8","parentId":null,"rootId":null,"fromId":1720,"content":"听里面的师兄师姐说转正一般没问题，但是现在是政策型企业，要看政府拉投资，担心以后降薪","createdAt":"2025-10-27T18:24:35"},{"id":"019a2552-2cff-7270-963e-dd80a1c00cbe","parentId":null,"rootId":null,"fromId":1720,"content":"房价高，而且也去不了大厂qaq","createdAt":"2025-10-27T18:58:53"},{"id":"019a25fd-4cf7-7146-bc3f-069400a320f8","parentId":null,"rootId":null,"fromId":22485,"content":"同校招人，能去长光卫星说明你应该是双9或者强2+9吧，山东省内国企二级子公司或者总部都能有希望进吧。即使不选长光卫星，也不应该选华云三维，我本科毕业时同学很多去华云三维的（本科双非）","createdAt":"2025-10-27T22:05:48"},{"id":"019a3394-181a-724d-8150-e92376d06936","parentId":null,"rootId":null,"fromId":26819,"content":"感觉山高山能这几个二级子公司也都是只招财务，投融资等，计算机很少..","createdAt":"2025-10-30T13:25:34"},{"id":"019a33b1-17aa-70ea-97dd-f914fa12df92","parentId":null,"rootId":null,"fromId":21676,"content":"运营商出消息晚，11月中旬估计才有消息，哥们千万别急着签，后面机会还很多呢，催你签合同拖着就是，去这两个你这学历太不值了","createdAt":"2025-10-30T13:57:15"},{"id":"019a33f6-8b30-7025-b1f7-19ba3b00003d","parentId":null,"rootId":null,"fromId":22333,"content":"真心建议 你再找找 我猜不错你至少得2硕以上，多去小红书上搜搜济南国企，在找找，现在才10月份","createdAt":"2025-10-30T15:13:06"}]