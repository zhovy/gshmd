[{"id":"01963dde-2af4-7107-8b94-3e9bf9679013","parentId":null,"rootId":null,"fromId":2079,"content":"哈哈，终于看到这个公司啦。做早操老传统了。公司发展了那么多年还是这么大规模，问题在哪呢？","createdAt":"2023-01-17T10:17:22"},{"id":"01963dde-2b3a-70a9-869a-a6d56b37101d","parentId":null,"rootId":null,"fromId":1581,"content":"二逼公司 赶紧倒闭","createdAt":"2023-01-17T15:18:52"},{"id":"01963dde-2b82-7356-9c1e-83a6aca5fc59","parentId":null,"rootId":null,"fromId":692,"content":"去面试过，拿年龄和学历说事，说没结婚以后要结婚影响工作","createdAt":"2023-01-17T16:26:00"},{"id":"01963dde-2c0f-72ad-9f9b-23ed33bb3925","parentId":null,"rootId":null,"fromId":2706,"content":"大领导最应该反思，为啥留不住人，为啥公司20多岁了还是这个规模","createdAt":"2023-02-28T09:29:17"},{"id":"01963dde-2c52-723f-a4c9-e4a587e50536","parentId":null,"rootId":null,"fromId":5511,"content":"兄弟们，这公司加班严重吗，搞不搞固定加班那一套","createdAt":"2023-09-01T14:46:39"},{"id":"01963dde-2cdb-71b5-93dd-2efcce790fef","parentId":null,"rootId":null,"fromId":2122,"content":"两年后再来看，公司还是那个样","createdAt":"2025-02-13T16:44:57"},{"id":"019a291c-bd95-7020-bdd7-8c362be2b6e0","parentId":null,"rootId":null,"fromId":3962,"content":"目前看来这公司也是不尽人意，有人身攻击","createdAt":"2025-10-28T12:39:00"},{"id":"019a35ce-ca76-700b-b2fe-98a5a536e78c","parentId":null,"rootId":null,"fromId":27579,"content":"怎么说？","createdAt":"2025-10-30T23:48:56"},{"id":"019a5707-b926-720b-a2ca-ef608b6fcf20","parentId":null,"rootId":null,"fromId":27583,"content":"HR很亲切，讲的挺坦诚的，说早操不是强制的，也有不做的；看了一下开发办公室，有俩人在讨论，看着挺热闹的，看到这条信息多少还诧异了，噢，这是2年前的评价，不知道这两年情况咋样。不过小公司能活到现在也不赖了","createdAt":"2025-11-06T10:38:35"},{"id":"019a570a-dc18-7090-9e14-b4396e3ef4e6","parentId":null,"rootId":null,"fromId":27583,"content":"/偷笑","createdAt":"2025-11-06T10:42:00"},{"id":"019a571c-d53a-70f3-89de-551b74201c35","parentId":null,"rootId":null,"fromId":27583,"content":"她们说能正常发工资，不拖欠薪资。这倒是比我上两家强，妈的入职第二个月就不发工资了。","createdAt":"2025-11-06T11:01:38"}]