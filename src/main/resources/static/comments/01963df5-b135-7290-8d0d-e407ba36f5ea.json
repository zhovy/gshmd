[{"id":"01963df5-b1a3-7342-bea1-2485cae7ebf2","parentId":null,"rootId":null,"fromId":4140,"content":"如果下面情况你都无所谓，可以回去\n1、收入腰斩（10k->5-6k）\n2、生活配套降级（教育、医疗、商业、交通，滑雪没地方去，演唱会更是没有，脱口秀什么娱乐更别想）\n3、没有同龄人，身边都是大一轮的人（老家一个银行女，已轻度抑郁）\n4、没有夜生活，老家的作息基本上到晚上6点之后商店都关门了\n5、生活成本可能比济南更高\n6、小地方官僚气氛浓厚，办事没关系寸步难行（办个什么什么证卡你半天）\n7、找对象年轻、貌美、学历高的对象基本上不存在（有本事好看的女生谁会回老家）","createdAt":"2024-12-24T17:21:15"},{"id":"01963df5-b1e8-7285-9117-29dd3c3aadbc","parentId":null,"rootId":null,"fromId":875,"content":"投资纳斯达克指数吃利息","createdAt":"2024-12-24T18:13:51"},{"id":"01963df5-b22e-7106-a954-b911332f2ae7","parentId":null,"rootId":null,"fromId":22510,"content":"这周纳指和标普都雪崩了一小下子..... 要不要加仓....   还有个事：就是外币汇率，除了美元强势上升，澳元、日元、欧元、英镑都下降..... 有点慌啊","createdAt":"2024-12-24T21:48:23"},{"id":"01963df5-b23b-7221-bd21-687e377b6b3f","parentId":null,"rootId":null,"fromId":22510,"content":"200w在明年年底的实际价值会折扣掉10%的购买力","createdAt":"2024-12-24T21:49:22"},{"id":"01963df5-b232-70bf-a4e6-a7b9e6337272","parentId":null,"rootId":null,"fromId":875,"content":"纳斯达克两万点了，怕个锤子","createdAt":"2024-12-25T08:02:28"},{"id":"01963df5-b27f-710b-a0ee-a163ef3e420b","parentId":null,"rootId":null,"fromId":21053,"content":"都通缩了还折扣？你脑子呢","createdAt":"2024-12-25T08:37:26"},{"id":"01963df5-b2c0-73ce-8064-94ca064b7a38","parentId":null,"rootId":null,"fromId":7078,"content":"借给我吧，买个教训","createdAt":"2024-12-25T09:17:28"},{"id":"01963df5-b304-7313-9af4-a4c628113d8b","parentId":null,"rootId":null,"fromId":6435,"content":"哈哈，有点贵啊这教训","createdAt":"2024-12-25T09:40:03"},{"id":"01963df5-b237-71f6-9b1b-cb49fdba6dbe","parentId":null,"rootId":null,"fromId":5741,"content":"纳斯达克直接定投，哪里都比缅A强","createdAt":"2024-12-25T11:38:50"},{"id":"01963df5-b288-701c-a9a4-a24870ec76bb","parentId":null,"rootId":null,"fromId":21053,"content":"我看你mgb啊？哪来的小粉红","createdAt":"2024-12-25T13:41:25"},{"id":"01963df5-b290-72bd-9c06-fa624f74022d","parentId":null,"rootId":null,"fromId":1567,"content":"说通胀的连基本经济学原理都不懂","createdAt":"2024-12-25T14:08:20"},{"id":"01963df5-b295-70d5-9666-b0ba27a44d4e","parentId":null,"rootId":null,"fromId":1567,"content":"之后不仅仅国内通缩会更加严重，全球都会进入通缩当中","createdAt":"2024-12-25T14:09:19"},{"id":"01963df5-b29d-734a-8548-d02c9a309899","parentId":null,"rootId":null,"fromId":1567,"content":"哈哈哈笑了，他们说的那屁话你真信啊，但凡你懂点经济学原理你都知道他们说的那话都是在安慰民众","createdAt":"2024-12-25T14:13:28"},{"id":"01963df5-b2a2-7226-9ac0-b3aeaea4a8e7","parentId":null,"rootId":null,"fromId":1567,"content":"目前的通缩螺旋不是 国家出什么政策能摆脱的。","createdAt":"2024-12-25T14:13:59"},{"id":"01963df5-b309-7364-abd2-96c48c09f956","parentId":null,"rootId":null,"fromId":1567,"content":"守好自己的钱，不要负债。目前通缩在政策层面无解。现在出的政策类比来讲相当于对癌症晚期病人下猛药。看着很猛其实核心不在于药，而在于癌症本身。\n目前经济的核心问题在于停滞发展的基础科技无法刺激有效需求的问题。从18年贸易战开始 全球政治风向集体右翼化的核心都在于这里。\n各个国家争端的核心其实就在于有效需求的争夺。国内本来就是制造业大国，而国民应有的消费能力又由于某些原因得不到释放，所以这也就是为什么国际上各个国家不约而同地对中国进行贸易制裁的原因。","createdAt":"2024-12-25T14:23:04"},{"id":"01963df5-b2ab-7384-9406-31cde1c07394","parentId":null,"rootId":null,"fromId":1567,"content":"笑料了，自己去细细研究研究目前 m1 m2的组成部分 就不会说这话了。如果实在看不懂可以了解下GPD平减指数","createdAt":"2024-12-25T14:31:10"},{"id":"01963df5-b2af-701a-b45b-b533d5123a57","parentId":null,"rootId":null,"fromId":1567,"content":"实际国内外的经济学家结论都给出来了。稍微难听点的你就装看不见 那我也是没辙","createdAt":"2024-12-25T14:32:29"},{"id":"01963df5-b2b3-735b-925a-b856198ed9c8","parentId":null,"rootId":null,"fromId":1567,"content":"目前无论股市还是债市 已经用脚投票了。多说无益","createdAt":"2024-12-25T14:35:26"},{"id":"01963df5-b2bc-7114-9246-ea272cb04cbd","parentId":null,"rootId":null,"fromId":5741,"content":"债市还能长期拿嘛？","createdAt":"2024-12-26T09:55:54"},{"id":"01963df5-b34c-7022-b3e6-67c6137cb941","parentId":null,"rootId":null,"fromId":21845,"content":"回家躺平","createdAt":"2024-12-26T11:08:12"}]