[{"id":"019afc33-32b1-7214-bd5b-6ca22a2fc51c","parentId":null,"rootId":null,"fromId":1049,"content":"比起北京好多了","createdAt":"2025-12-08T12:23:25"},{"id":"019afc5d-7cf7-7386-90a0-ddf01e6ca921","parentId":null,"rootId":null,"fromId":875,"content":"多少钱","createdAt":"2025-12-08T13:09:36"},{"id":"019afc6e-f52e-73f0-bb74-8be12ea3f069","parentId":null,"rootId":null,"fromId":1003,"content":"汉峪金谷","createdAt":"2025-12-08T13:28:41"},{"id":"019afc74-353b-7062-8461-183d3bff0fbe","parentId":null,"rootId":null,"fromId":22779,"content":"你在汉峪金谷，你看看东站和唐冶的房子","createdAt":"2025-12-08T13:34:25"},{"id":"019afc7b-84d1-708e-addf-0af03d963423","parentId":null,"rootId":null,"fromId":26498,"content":"建议不要这么搞，我工作在高新，住在天桥，天天公交地铁通勤时间一个半小时，很压抑，后来换到了历城住。同一份工作，通勤半小时以内与40分钟以外心理落差很大的","createdAt":"2025-12-08T13:42:24"},{"id":"019afc8b-d94a-73b9-a2f9-c90d3c5ab6f5","parentId":null,"rootId":null,"fromId":6091,"content":"文旅城不行啊？？","createdAt":"2025-12-08T14:00:14"},{"id":"019afc8f-622d-7289-8d9a-ef206b5a676f","parentId":null,"rootId":null,"fromId":4190,"content":"西边才是生活，东边都是牛马","createdAt":"2025-12-08T14:04:06"},{"id":"019afc99-8a90-7286-a3b2-cd59512b50c5","parentId":null,"rootId":null,"fromId":7709,"content":"35公里单程1小时","createdAt":"2025-12-08T14:15:12"},{"id":"019afca7-c149-73e4-b424-34bb504db96f","parentId":null,"rootId":null,"fromId":2783,"content":"没毛病","createdAt":"2025-12-08T14:30:43"},{"id":"019afcad-7819-72fe-8998-0cb87cb04af8","parentId":null,"rootId":null,"fromId":6517,"content":"历下 龙洞，cbd才叫生活。。西边是兜里没几个子，被迫的选择","createdAt":"2025-12-08T14:36:58"},{"id":"019afcb8-a597-7157-babe-188d8b8a2e2f","parentId":null,"rootId":null,"fromId":1932,"content":"现在通勤二十多公里，生不如死，建议就住在东边","createdAt":"2025-12-08T14:49:10"},{"id":"019afcbd-3af0-7167-996b-f929661cb3c4","parentId":null,"rootId":null,"fromId":25906,"content":"住哪不重要，现在还贷款买房那可真是冤大头了","createdAt":"2025-12-08T14:54:11"},{"id":"019afcc9-e177-7282-a654-508e61d9220b","parentId":null,"rootId":null,"fromId":4273,"content":"未来4号线通车可以试试，海信时代城是地铁上盖 要注意一下 里地铁站挺远的，我也是在那里买的房 现在在西边工作，最好还是在王府庄不超过12公里范围内工作，来西边就是想躺平才来的","createdAt":"2025-12-08T15:08:00"},{"id":"019afcc9-e5e8-7110-a0c0-8e0199c5849b","parentId":null,"rootId":null,"fromId":21511,"content":"不如租房","createdAt":"2025-12-08T15:08:01"},{"id":"019afce1-6506-716b-a39b-23a11a6ad0e5","parentId":null,"rootId":null,"fromId":24615,"content":"十几公里内找不到工作吗，为啥非要跨城上下班~如果工资和福利很好的话，建议附近租房，4号线通车后可以坐坐试试。现在通勤痛苦，要是上班工作压力还大，那纯纯没罪找罪受","createdAt":"2025-12-08T15:33:41"},{"id":"019afce6-ed6d-7300-b275-355ae440f2aa","parentId":null,"rootId":null,"fromId":22024,"content":"唐冶不香吗","createdAt":"2025-12-08T15:39:43"},{"id":"019afceb-a793-72f2-bba8-69f914755e59","parentId":null,"rootId":null,"fromId":1003,"content":"天天五点下班 然后骑车一个半小时到家  早上一个小时","createdAt":"2025-12-08T15:44:53"},{"id":"019afcf9-f52b-7184-b173-1c9151ecfd07","parentId":null,"rootId":null,"fromId":6941,"content":"海信观悦距离地铁口还算可以，都是小高层单价多少？？？六七k？？？具体不清楚，可以转4号线直达奥体","createdAt":"2025-12-08T16:00:31"},{"id":"019afd0b-4209-70d1-9db8-dfe8d089b97e","parentId":null,"rootId":null,"fromId":875,"content":"4号线通了，住章丘都不算是个事","createdAt":"2025-12-08T16:19:24"},{"id":"019afd0e-5f51-71da-a5c6-45adf156d655","parentId":null,"rootId":null,"fromId":24154,"content":"王府庄附近到美联广场","createdAt":"2025-12-08T16:22:48"},{"id":"019afd57-4d94-7311-b5ea-fc7d1834941d","parentId":null,"rootId":null,"fromId":4190,"content":"能省则省","createdAt":"2025-12-08T17:42:28"},{"id":"019afd57-8a93-7312-baff-2a75b84923dc","parentId":null,"rootId":null,"fromId":5635,"content":"现在102平90万带3万装修","createdAt":"2025-12-08T17:42:44"},{"id":"019afd58-818b-7254-9ac0-971ea3c63aa9","parentId":null,"rootId":null,"fromId":5635,"content":"我听说4号线一站要3分钟，从王府庄到美莲广场那边得一个半小时吧","createdAt":"2025-12-08T17:43:47"},{"id":"019afd59-a03c-73fc-8b03-812ec2257581","parentId":null,"rootId":null,"fromId":5635,"content":"西边去软件园那边，地铁也得一个半小时吧","createdAt":"2025-12-08T17:45:00"},{"id":"019b00a8-6fbf-70cb-874f-e5a4fcbbbc33","parentId":null,"rootId":null,"fromId":4273,"content":"便宜的也9k左右","createdAt":"2025-12-09T09:09:57"},{"id":"019b00e0-33da-728f-955b-d562ca950a94","parentId":null,"rootId":null,"fromId":781,"content":"人教人教不会，事教人一教就会，支持买王府庄附近","createdAt":"2025-12-09T10:10:51"},{"id":"019b0100-65b7-72b3-ab39-9b312c1ecef3","parentId":null,"rootId":null,"fromId":5635,"content":"那意思是不推荐买呗，现在纠结的很，3-40首付，月供不想超3000，不知道买哪里都","createdAt":"2025-12-09T10:46:01"},{"id":"019b0100-b945-7340-8ce1-5dd58f27a3ac","parentId":null,"rootId":null,"fromId":22250,"content":"住东边的，比如唐冶或者再往东的都是穷光蛋，兜里没几个子的，毕业之后靠着在东边企业上班维持，程序员居多吧，说不定哪天就失业，每天骑个电驴上下班。","createdAt":"2025-12-09T10:46:23"},{"id":"019b0112-62b0-7245-9470-d4ad30550ad3","parentId":null,"rootId":null,"fromId":4190,"content":"买龙湖御湖镜二期，家门口就是北园高架，10分钟上高速，人少不堵车，交通相当方便。","createdAt":"2025-12-09T11:05:40"},{"id":"019b0115-0f64-7340-8851-1dcd8c39aa5d","parentId":null,"rootId":null,"fromId":4190,"content":"去东边上班就开车走高速，二环东下，这段高速不收费。","createdAt":"2025-12-09T11:08:36"},{"id":"019b0118-803b-71cc-8d08-d635e1b08d23","parentId":null,"rootId":null,"fromId":7650,"content":"住西站，去软件园附近摩托车通勤的路过","createdAt":"2025-12-09T11:12:21"},{"id":"019b011c-c6f0-709e-83ce-4b79795ad941","parentId":null,"rootId":null,"fromId":6091,"content":"这个小区100来万能买到么","createdAt":"2025-12-09T11:17:01"},{"id":"019b017e-9131-718e-be52-9d59a09484ff","parentId":null,"rootId":null,"fromId":6941,"content":"性价比不高","createdAt":"2025-12-09T13:03:50"},{"id":"019b01b4-9ad8-71e3-94ad-fa7b42c1ec30","parentId":null,"rootId":null,"fromId":5635,"content":"哥，通勤大概多长时间，一小时够吗","createdAt":"2025-12-09T14:02:51"},{"id":"019b01cb-766d-70c5-87a3-4bf82e1dd048","parentId":null,"rootId":null,"fromId":6939,"content":"不考虑房子贬值，只为了住的话，围绕汉峪片区可选择余地比较多，说什么风凉话的都有，但是实际上济南还是一直在往东发展，我14年在唐冶买的，当时唐冶周围还是玉米地，现在成什么样了，大家都能看到。预算100+，二手房：离的近的小区万科金域华府、璟仕府、旭辉金域蓝山、再老点的小区如：凤西地、奥东花园这些挑挑看差不多都能买到，这些都是经十路北面的小区，南面的现在价格都还比较高，100+还真够不到，如果只考虑新房的话，1.4万左右一平的只能去飞跃大道北、张马屯、孙村、西客站去找了，我建议买个次新的就行，至少不能等配套，我在唐冶等了10年配套才差不多。","createdAt":"2025-12-09T14:27:49"},{"id":"019b01cb-e60a-7254-b2b2-2ef4cf313525","parentId":null,"rootId":null,"fromId":6449,"content":"齐鲁软件园住，经四万达上班，早上定制公交40分钟，下班80分钟","createdAt":"2025-12-09T14:28:18"},{"id":"019b01e3-0213-720b-b3f7-d56b2611284d","parentId":null,"rootId":null,"fromId":4273,"content":"在12公里内工作的话可以 买王府庄 超出了 不是很建议","createdAt":"2025-12-09T14:53:33"},{"id":"019b01e3-757b-72b7-9c85-7ef4759b4afe","parentId":null,"rootId":null,"fromId":4273,"content":"没有小户型吧","createdAt":"2025-12-09T14:54:02"},{"id":"019b0206-f742-7031-8120-b5116b93c74d","parentId":null,"rootId":null,"fromId":22702,"content":"我在头几年也考虑过类似问题，通勤是绝对要考虑的，我买房子的时候都说买东面，工作机会多，但是我的工作在经四万达附近，也算属于西边，当然没西客站那么远，然后就出现一个问题，买东面虽然工作机会多，但眼下没作用，再者是我喜欢西边老城区的生活气息，对东面的高楼林立并无好感，所以我最终选择的是：老城区的和谐广场北边，原因是 那个位置坐 二号线、四号线和六号线 都方便 ，再者上班也方便，三公里就到了，交通也便利，火车站、医院这些配套没得说， 属于进可攻退可守的地方，不过后悔的是买早了、但从目前来看选择是没问题的。","createdAt":"2025-12-09T15:32:49"},{"id":"019b0223-6bad-72da-90ac-3f8419050cd8","parentId":null,"rootId":null,"fromId":24154,"content":"住王府庄，工作在美联广场，骑摩托骑了一年，目前坐2号线到姜家庄，再骑车到美联广场","createdAt":"2025-12-09T16:03:54"},{"id":"019b0225-49d6-7196-93c2-11d5191e886a","parentId":null,"rootId":null,"fromId":24154,"content":"目前坐2号线，再骑车，差不多七八十分钟吧","createdAt":"2025-12-09T16:05:56"},{"id":"019b0225-b7bc-71a4-b715-19a7387c9db7","parentId":null,"rootId":null,"fromId":5635,"content":"和谐附近我预算不太能买到，我就7 80的预算，不敢贷款太多","createdAt":"2025-12-09T16:06:24"},{"id":"019b0253-2356-712a-b97d-eb57f617bd1c","parentId":null,"rootId":null,"fromId":22779,"content":"阳光100的二手房也不贵","createdAt":"2025-12-09T16:56:01"},{"id":"019b0256-326b-72e3-8421-e368f5f5166b","parentId":null,"rootId":null,"fromId":5635,"content":"那边这价位的，都是筒子楼","createdAt":"2025-12-09T16:59:22"},{"id":"019b05f7-b583-70cc-90e6-4c458a0663c3","parentId":null,"rootId":null,"fromId":6939,"content":"所以说买不买房，在哪买房看自己的实际需求，我去年买的，除了今年价格下降了别的没什么不满意的，降价、涨价谁都左右不了，毕竟就算现在大涨，我也不会再卖掉，考虑的是长期居住，租房真的租够了，看人家脸色。","createdAt":"2025-12-10T09:54:38"},{"id":"019b069a-40b0-7286-a067-48a899702437","parentId":null,"rootId":null,"fromId":246,"content":"你是不是对西边有误解 西边才是老城区 拆迁户太多了 有钱的很多 你是外地人吧","createdAt":"2025-12-10T12:52:11"},{"id":"019b06e7-ad19-706c-8a90-0b32ec41be53","parentId":null,"rootId":null,"fromId":7650,"content":"一般是70分钟","createdAt":"2025-12-10T14:16:45"},{"id":"019b1f7f-d3f8-7224-b080-ce0bde982714","parentId":null,"rootId":null,"fromId":22702,"content":"对 尽量不要高杠杆 不过我这边房价我买的时候是一万二 现在八千多了 我就不说我的位置了 但是你的价格在这附近是可以的 建议不是很着急就再等","createdAt":"2025-12-15T08:53:49"},{"id":"019b1f80-c6bd-7338-b6aa-be50e142cdc9","parentId":null,"rootId":null,"fromId":22702,"content":"对 那边也听说降的挺厉害 还能靠着4号线 但我感觉往北点好 6号线到时候也挺重要","createdAt":"2025-12-15T08:54:51"},{"id":"019b1f86-576e-703d-a364-ef7f73d67841","parentId":null,"rootId":null,"fromId":22702,"content":"对，租房一个人可以凑合，但是想要住的质量和后面两个人了，租个两室以上的，环境可以，有电梯的，通勤方便的，最起码2000+，我贷的90万，利息也是两千多，但是住的质量绝对比租的强的多，想买什么电器买什么，卧室按自己的想法想什么改就怎么改，但是前提是自己的收入要稳定，并且能存钱应对危机，再者是不要高杠杆，每月还款能占4分之一是最好的。","createdAt":"2025-12-15T09:00:56"},{"id":"019b1f88-5de3-720d-a1e0-76728bd13472","parentId":null,"rootId":null,"fromId":22702,"content":"现在租个心仪的房子 也不便宜","createdAt":"2025-12-15T09:03:09"},{"id":"019b2094-e4b8-7169-9ce9-b47b8396f1fe","parentId":null,"rootId":null,"fromId":3000,"content":"推荐保利花园小区，交通特别方便，经十路北，南面是融创茂、夜市，2室的总价不到90万，找个精装修的","createdAt":"2025-12-15T13:56:27"}]