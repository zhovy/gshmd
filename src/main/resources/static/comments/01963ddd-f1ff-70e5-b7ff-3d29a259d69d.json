[{"id":"01963ddd-f266-734b-beae-370b101cba76","parentId":null,"rootId":null,"fromId":1401,"content":"行情不是很好，能按时发工资就不错了，可以下班后先为面试准备着，等后面实在干不下去了再考虑走吧","createdAt":"2022-12-10T14:24:58"},{"id":"01963ddd-f2a9-7125-b764-6860479da580","parentId":null,"rootId":null,"fromId":1336,"content":"公司一听目前在职，一个月才能入职，直接pass了。\n你要是适合公司，1个月对方也等得了。对方要是不把你看眼里，1个月都给不了你，那你也别去，换这种工作也没劲。","createdAt":"2022-12-10T18:19:44"},{"id":"01963ddd-f2ec-70b8-bbd4-b707531cd95d","parentId":null,"rootId":null,"fromId":1955,"content":"我时间赞同楼主\n很多公司一听在职，入职需要1个月啥的\n很多公司等不及，或者直接给你pass\n按照公司想法，人的是，我慢慢的找，不在乎这一个人\n除非一些财大气粗的公司，就想扩大团队，有那么几个名额，觉得你合适了，可以等你入职，他们也不急\n但是往往大部分公司都是因为出缺了，严重影响到公司的一些经度或者什么，他们招人，肯定不会等1个月后入职的，要的就是尽快入职","createdAt":"2022-12-10T21:06:50"},{"id":"01963ddd-f334-70e5-b417-97c0ac8b488b","parentId":null,"rootId":null,"fromId":1003,"content":"其实也看个人的经济实力吧，看看自己最多可以接受几个月没有工资再做决定，如果钱不是问题完全可以现在离职","createdAt":"2022-12-11T14:49:26"},{"id":"01963ddd-f379-7298-8f7b-06cfefff02ca","parentId":null,"rootId":null,"fromId":1656,"content":"想辞就辞职，干的憋屈确实难受，回家过完年放松放松，接着开始","createdAt":"2022-12-11T17:01:20"},{"id":"01963ddd-f3be-718d-b7f4-e61328229ea7","parentId":null,"rootId":null,"fromId":2124,"content":"存款够可以，没有存款还是忍忍","createdAt":"2022-12-12T13:38:14"},{"id":"01963ddd-f405-71b3-a002-2983f12bc692","parentId":null,"rootId":null,"fromId":2184,"content":"别人被裁或者离职，你还能留下，说明公司认可你，你的能力也不是那种不好找工作的。别管疫情，就当成正常想跳槽处理呗","createdAt":"2022-12-14T14:30:29"},{"id":"01963ddd-f44a-72de-9646-f0a3bca68ff0","parentId":null,"rootId":null,"fromId":2294,"content":"今年出差了半年，明年估计也要出差，出差期间真的不太好骑驴找马","createdAt":"2022-12-20T11:43:48"},{"id":"01963ddd-f493-704b-ac6b-23341703e88d","parentId":null,"rootId":null,"fromId":658,"content":"想离开浪浪山了吗","createdAt":"2023-02-02T10:40:36"},{"id":"01963ddd-f48f-706b-b429-b48cc861f9e4","parentId":null,"rootId":null,"fromId":2598,"content":"我就是  今年直接裸了 然后找工作找了一个半月了。。。\n","createdAt":"2023-04-24T15:29:48"}]