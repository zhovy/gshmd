[{"id":"01963de2-7ad0-70d0-8274-b1455a94aaa4","parentId":null,"rootId":null,"fromId":3450,"content":"找工作10天了，只有2个面试","createdAt":"2023-05-15T17:06:04"},{"id":"01963de2-7b1c-70eb-a937-fb506507bc5c","parentId":null,"rootId":null,"fromId":3306,"content":"看BOSS上给的薪资低的让人不敢看 而且今年学历卡的特别严","createdAt":"2023-05-15T17:11:56"},{"id":"01963de2-7b21-7048-9706-a706775d80f1","parentId":null,"rootId":null,"fromId":3516,"content":"同专科，3年多后端，前端也会。四月初到五月初面了6个，拿了3个offer（一个当场拒绝了，一个给不了那么高直接pass了，另一个没结果）8k,9k,11k  。但是从五月初到现在基本上约不到面试了。做个参考吧 今年行情确实不咋滴。跳槽需谨慎，最好还是内推","createdAt":"2023-05-15T17:22:06"},{"id":"01963de2-7b69-7066-a79d-6349c3c21456","parentId":null,"rootId":null,"fromId":875,"content":"五年工作经验，年薪正常在20~25万（加上餐补公积金过节费年终奖），比较正常，跳槽要两万，","createdAt":"2023-05-15T19:13:31"},{"id":"01963de2-7bc8-7075-a4ce-a2aca878c771","parentId":null,"rootId":null,"fromId":875,"content":"找什么工作？全是给济南体制内的大爷大妈送钱\n你们知道体制内退休金多少吗？\n\n有的人是2万多，你可能不信，\n\n事实就是如此。\n\n一个人一个月2万多退休金，\n\n你想想退休金账户的钱能够吗？\n\n那群老人天天广场舞，打乒乓球、旅游，摄影，买房，帮子女还房贷，\n\n你猜猜他们退休金多少。\n\n我是想不懂，都是老人，为什么有人2万多，有人200多。\n\n而2万多退休金的，还有各种医疗支持。\n\n关键是涨退休金是按比例。2万4个点就是800，2百4个点就是8块。\n\n你说幸不幸福？","createdAt":"2023-05-16T08:20:25"},{"id":"01963de2-7c0e-73b8-b15e-be87c0f4dd94","parentId":null,"rootId":null,"fromId":965,"content":"玛德\n","createdAt":"2023-05-16T08:33:23"},{"id":"01963de2-7bae-7025-a13f-5b59a913f0ba","parentId":null,"rootId":null,"fromId":2082,"content":"不到2w你给我补啊 /捂脸\n","createdAt":"2023-05-16T09:23:27"},{"id":"01963de2-7c12-7067-ab5e-b74fff4d59e2","parentId":null,"rootId":null,"fromId":3183,"content":"甜晕了","createdAt":"2023-05-16T09:27:40"},{"id":"01963de2-7bb3-71a1-abd4-ecaf5022a178","parentId":null,"rootId":null,"fromId":3306,"content":"大哥 这是在济南 能到15真的就谢天谢地了 但是还是不敢动 现在低的可怜 涨薪也不给涨","createdAt":"2023-05-16T11:02:37"},{"id":"01963de2-7c16-702c-a669-b00804ccd6d4","parentId":null,"rootId":null,"fromId":3306,"content":"大环境确实不是我们能改变的，我们只是生活在底层的小老百姓，现在就想工资高点改变一下自己的生活状态和生活水平，昨天刚发了工资，到手就没了，房贷车位贷房租，能留下的生活费都只剩一点点，生活真的很拮据，但是只能自己努力啊，大环境我们是改变不了的","createdAt":"2023-05-16T11:05:02"},{"id":"01963de2-7b64-72e7-a8f2-02753f3ec9aa","parentId":null,"rootId":null,"fromId":3306,"content":"谢谢，我只能说我五年和你三年的工资相当，所以想跳槽，感谢","createdAt":"2023-05-16T11:07:23"},{"id":"01963de2-7bb7-7242-beb4-8c1f3d595298","parentId":null,"rootId":null,"fromId":576,"content":"6年没到15的路过,  我实在是太可怜了","createdAt":"2023-05-16T11:18:50"},{"id":"01963de2-7bbb-7344-8c26-fcf55104d0a8","parentId":null,"rootId":null,"fromId":3306,"content":"5年11 你说纠结吗","createdAt":"2023-05-16T13:55:22"},{"id":"01963de2-7bc0-716f-9996-ea3caea83827","parentId":null,"rootId":null,"fromId":576,"content":"这有啥  我也是 到手11而已，最低缴纳","createdAt":"2023-05-16T18:10:21"},{"id":"01963de2-7c1b-7331-8d91-e0a4dc8e0ee7","parentId":null,"rootId":null,"fromId":875,"content":"买了房子了，就没办法了","createdAt":"2023-05-16T21:22:30"},{"id":"01963de2-7c20-72f9-84c3-1208a7b83c6a","parentId":null,"rootId":null,"fromId":875,"content":"哈哈哈，我boss上看有些公司把招聘年龄限制到33周岁以下，人力真的厉害的嘛，济南工资真的低，还要出差，还是个外包，招聘方哪来的优越感，这是年龄大的不好骗了，准备骗点年轻的使劲压榨嘛","createdAt":"2023-05-16T21:32:22"},{"id":"01963de2-7bc4-704f-ac46-0af15d36d862","parentId":null,"rootId":null,"fromId":3306,"content":"你是到手11 我是税前11 哎","createdAt":"2023-05-17T08:40:02"},{"id":"01963de2-7c65-713c-9247-fddc3eeffa61","parentId":null,"rootId":null,"fromId":3544,"content":"进入5月份，情况确实很艰难了，外包严重卡学历，要么必须有相关项目经验，薪资也很低，都约不到面试了。大专学历就等于有前科","createdAt":"2023-05-17T15:01:30"},{"id":"01963de2-7ca9-71e6-a149-241bb834e863","parentId":null,"rootId":null,"fromId":2613,"content":"感觉今年一直就很难","createdAt":"2023-05-17T15:30:31"},{"id":"01963de2-7cae-71fc-a64c-1b6ce85f294a","parentId":null,"rootId":null,"fromId":875,"content":"人力说，招聘专科的不要，没结婚的不要","createdAt":"2023-05-18T12:11:07"},{"id":"01963de2-7cb2-7140-abcf-e67d0fcd9d62","parentId":null,"rootId":null,"fromId":576,"content":"为什么还要跟没结婚的扯上关系？？？都不要算了","createdAt":"2023-05-18T15:44:29"},{"id":"01963de2-7cb6-7200-891a-9069206c3d0d","parentId":null,"rootId":null,"fromId":3516,"content":"楼上说的不全，应该是外地的没结婚，还没在济南买房的不要","createdAt":"2023-05-18T16:37:27"}]