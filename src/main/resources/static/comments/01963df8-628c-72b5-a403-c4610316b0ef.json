[{"id":"01963df8-62f1-710b-baca-33f07c1da6ff","parentId":null,"rootId":null,"fromId":22932,"content":"草，点到保存了","createdAt":"2025-04-02T16:52:36"},{"id":"01963df8-633e-7118-9d1e-1d8b5ec856ff","parentId":null,"rootId":null,"fromId":22932,"content":"懒得写了，总结就是一个月也就面了 八九家公司（外包我没去面），第一家公司挺好的，做建模的，我要12给我拒绝了（现在想想11也行啊），然后后面都是牛马公司，有给我8的有9的，面了三周我都麻木了，最后好歹有一家待遇还行，单双休，给我11，我就去入职了。大专现在不好找，打了一千多个招呼才约到这几个。","createdAt":"2025-04-02T16:58:03"},{"id":"01963df8-638b-70bb-8dc5-960e60070aa8","parentId":null,"rootId":null,"fromId":2598,"content":"纯前端吗","createdAt":"2025-04-02T17:11:49"},{"id":"01963df8-63d0-7099-9618-f6383503f998","parentId":null,"rootId":null,"fromId":22932,"content":"然后关于面试问的，基本上不问纯八股文，会围绕你的项目来问一些功能的实现，当然不问八股文并不代表不背，基本上常问的问题就是，性能优化，ES6新特性，兼容性问题, vue必问的就是2和3的区别，所以现在还想换工作的建议多在简历上面下功夫，也要看八股文，不然问到了说不出来很丢分。我的简历写了足足三页多，就是会的都往上写，反正也不一定会问。","createdAt":"2025-04-02T17:18:36"},{"id":"01963df8-6418-7387-a52c-92736699d69d","parentId":null,"rootId":null,"fromId":1398,"content":"四年Java后端能要到多少","createdAt":"2025-04-02T17:46:43"},{"id":"01963df8-6386-7052-8bb6-8b722bb58bdf","parentId":null,"rootId":null,"fromId":22610,"content":"真难啊现在","createdAt":"2025-04-02T18:13:54"},{"id":"01963df8-6414-738c-b934-fd2628f8d3de","parentId":null,"rootId":null,"fromId":21302,"content":"第一家新睿吧","createdAt":"2025-04-02T19:42:58"},{"id":"01963df8-645e-71f7-9d0c-8122db0c16ca","parentId":null,"rootId":null,"fromId":3341,"content":"3年9k","createdAt":"2025-04-03T08:58:56"},{"id":"01975443-3a00-72d2-bc32-04b6b1e0eee8","parentId":null,"rootId":null,"fromId":4384,"content":"建模的啥公司吗，可以推给我吗？老哥","createdAt":"2025-06-09T18:36:21"}]