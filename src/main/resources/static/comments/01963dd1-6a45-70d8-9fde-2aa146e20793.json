[{"id":"01963dd1-6ac4-7326-9c8b-3a0cf4eafee5","parentId":null,"rootId":null,"fromId":14,"content":"试用期的薪资只有（(原工资-500)* 80%）。\n原工资比如当时要的薪资是7k，那么实际只有6.5k，\n其中的0.5k是作为你的补贴：上班的时候每天15的伙食费，100是全勤奖，100是话费补（必须是济南卡)。\n没有加班补贴，只有搞不完的活。\n入职的时候说是一堆福利，实际入职之后试用期是没有任何福利以及补贴,\n转正后也只有从你原工资扣下的500当补贴，所发的offer上的福利都没有。","createdAt":"2021-12-31T17:47:28"},{"id":"01963dd1-6b08-70eb-bbb6-9e964a280d1f","parentId":null,"rootId":null,"fromId":199,"content":"我去 刚投了简历想去试试的。。。。。","createdAt":"2022-04-06T18:15:57"},{"id":"01963dd1-6b4c-7099-9d34-d2e44ec60aaf","parentId":null,"rootId":null,"fromId":365,"content":"去看过，感觉工作环境也好差","createdAt":"2022-05-23T12:57:25"},{"id":"01963dd1-6b92-734a-99bf-228e4adcdb53","parentId":null,"rootId":null,"fromId":634,"content":"环境一般，工资5号准时发，福利一般，五险一金分2个档，想全额的自己多拿钱。周末加班调休，平时加班只有餐补，打车报销。","createdAt":"2022-06-01T23:51:56"},{"id":"01963dd1-6c1f-7304-a6b2-1e5ae62e86e4","parentId":null,"rootId":null,"fromId":704,"content":"老板心胸狭隘，没有奖金。每周日报周报 、周目标、目标完成度 周会来看你的工作量，按每天提交的日志来评估绩效发多少钱 ，真坑壁","createdAt":"2022-12-02T14:21:54"},{"id":"01963dd1-6ca9-70f7-a8c6-61e3282cafab","parentId":null,"rootId":null,"fromId":1772,"content":"6楼补充一下，\n现在日报改成日记了\n干了什么活 几点干的 精确到时分秒，\n中间还要写 有无走神 走神时长，\n说了八百年的项目奖也没落地\n\n瞎几把定规则，公司制度几个月就变一次。\n还总是说裁人裁人。真应该把那个傻逼无能的管事的开了\n\n总之一句话 真傻逼","createdAt":"2023-03-14T15:08:38"},{"id":"01963dd1-6d50-703b-b077-70d2e63af428","parentId":null,"rootId":null,"fromId":168,"content":"面试情况怎么样？我也在面试","createdAt":"2023-04-27T09:41:42"},{"id":"01963dd1-6d5d-7336-90f7-3525f5099778","parentId":null,"rootId":null,"fromId":168,"content":"公司内部管理较混乱","createdAt":"2023-07-17T14:52:48"},{"id":"01963dd1-6d59-71f7-96c6-fbf5eeccd2c9","parentId":null,"rootId":null,"fromId":4103,"content":"速速远离","createdAt":"2023-07-20T15:20:30"},{"id":"01963dd1-6e2c-7100-bb42-d26928fc7c8d","parentId":null,"rootId":null,"fromId":21589,"content":"变相降薪+全员降薪","createdAt":"2024-08-07T16:40:06"}]