[{"id":"01963df3-3205-7213-a81b-50bfd9f202fe","parentId":null,"rootId":null,"fromId":7550,"content":"mlgb 我们都降薪35%了，这种工资构成分为基本工资和绩效的最恶心了，工资说不发就不发。","createdAt":"2024-09-18T18:52:36"},{"id":"01963df3-324d-70eb-91c8-ef73f922fc45","parentId":null,"rootId":null,"fromId":875,"content":"公司都不赚钱，降你一点工资怎么了","createdAt":"2024-09-18T20:11:21"},{"id":"01963df3-3298-7037-a6bb-88c689a1a97f","parentId":null,"rootId":null,"fromId":7066,"content":"当前公司发展面临的经营形势十分严峻，衷心感谢全体员工的支持理解与信任，请大家转变发展思维，立足本职岗位履职尽责、全力创效，让我们勠力同心、携手并肩，为公司的发展而努力奋斗、团结奋斗、接续奋斗。","createdAt":"2024-09-18T20:47:34"},{"id":"01963df3-32df-7091-9ca7-8a85c6e99155","parentId":null,"rootId":null,"fromId":7066,"content":"感谢全体员工的支持与理解，请大家立足本岗履职尽责、全力创效、共克时艰，为全年任务指标达成贡献力量，谢谢。","createdAt":"2024-09-18T20:55:08"},{"id":"01963df3-3200-73fe-8714-e3ac8a426738","parentId":null,"rootId":null,"fromId":4174,"content":"降岗位工资，绩效工资","createdAt":"2024-09-19T08:58:02"},{"id":"01963df3-3249-72cf-b8ef-61014833e30b","parentId":null,"rootId":null,"fromId":4174,"content":"真mlgb","createdAt":"2024-09-19T08:58:17"},{"id":"01963df3-3290-734c-ba20-e357208de975","parentId":null,"rootId":null,"fromId":4174,"content":"说得好 替老板谢谢你","createdAt":"2024-09-19T08:58:42"},{"id":"01963df3-3324-7274-bf7c-cac3cccfca44","parentId":null,"rootId":null,"fromId":21487,"content":"哪家公司？","createdAt":"2024-09-19T09:05:00"},{"id":"01963df3-3295-71a2-bd74-d1693118047a","parentId":null,"rootId":null,"fromId":4010,"content":"让领导先带个头","createdAt":"2024-09-20T10:00:02"},{"id":"01963df3-336b-7170-9898-447a22dec33d","parentId":null,"rootId":null,"fromId":1110,"content":"别是倒在了黎明的前夕","createdAt":"2024-09-27T08:12:59"},{"id":"01963df3-33ae-720a-b76d-6b09f587e5b5","parentId":null,"rootId":null,"fromId":875,"content":"前段时间公司开放了一个hc，岗位预算是20k，正好面到了一个背景还不错的候选人，期望薪资是12k。\n\n看起来这就是一个双赢的局面：岗位预算充足并且候选人的薪资远远低于预算，公司和候选人双方应该是可以谈的比较顺利。\n\n但是这位HR说他没想到领导这个时候竟然发神经了：想先给候选人把薪资压到10K然后再加到11K，这样会让候选人觉得惊喜，认为公司非常看重他。","createdAt":"2024-09-29T20:19:54"},{"id":"01963df3-33f5-71ee-b562-bb14e91ae7c3","parentId":null,"rootId":null,"fromId":629,"content":"司马老板","createdAt":"2024-09-30T09:41:23"}]