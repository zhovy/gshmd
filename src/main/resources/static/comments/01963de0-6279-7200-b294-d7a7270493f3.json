[{"id":"01963de0-62dc-72e5-8423-d6676d8d7310","parentId":null,"rootId":null,"fromId":2914,"content":"抱歉大家，第一次用想发咨询贴的，但是不知道怎么改","createdAt":"2023-03-14T17:06:41"},{"id":"01963de0-6323-71a9-a091-dd71bd421313","parentId":null,"rootId":null,"fromId":1656,"content":"面试完了？","createdAt":"2023-03-14T17:07:49"},{"id":"01963de0-636c-70b6-be48-9e5538e15c9c","parentId":null,"rootId":null,"fromId":2914,"content":"还没有去面试","createdAt":"2023-03-14T17:09:28"},{"id":"01963de0-63b1-70c3-b540-3d66433753fc","parentId":null,"rootId":null,"fromId":2408,"content":"加班好像很严重","createdAt":"2023-03-14T21:25:44"},{"id":"01963de0-63f6-73da-beee-7ab73fce7bfc","parentId":null,"rootId":null,"fromId":455,"content":"炎黄新星是东方国信的子公司吧，福利待遇，五险一金，五险应该是最低标准，一金是4000多的百分之8我记得，好像每年都会长基数。每个月都有个生日会，就是月底，大家一起吃个蛋糕，吃点水果什么的。年终奖分两次发，一次年底，一次第二年6月份吧，还是7月份忘记了，刚入职的那一年少，往后两次加起来得大于1个月工资。加班是肯定的，但是有时候想调休一下，直接跟领导说一声，基本上不会为难。济南这边主要是做万达的项目和移动的吧，大概就这样","createdAt":"2023-03-15T14:21:58"},{"id":"01963de0-643b-72e3-af1f-118ad647cc69","parentId":null,"rootId":null,"fromId":2495,"content":"面试过了吗","createdAt":"2023-03-16T09:39:11"},{"id":"01963de0-6481-7249-8239-a26f6b77ec11","parentId":null,"rootId":null,"fromId":1857,"content":"5L总结的差不多，但有个问题需要注意，出差是经常的，加班也是经常滴","createdAt":"2023-03-24T10:17:22"},{"id":"01963de0-64c5-70d1-9d67-3eaab5003627","parentId":null,"rootId":null,"fromId":3670,"content":"你好，请问出差有补贴吗，有的话补贴政策是啥","createdAt":"2024-02-22T10:20:42"},{"id":"01963de0-64c9-7342-b3b4-108bc0ef0dee","parentId":null,"rootId":null,"fromId":1039,"content":"问补贴可以直接问HR或者面试官","createdAt":"2024-02-22T10:27:29"}]