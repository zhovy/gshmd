[{"id":"01986452-822e-702d-ae19-f972dfb2d1e9","parentId":null,"rootId":null,"fromId":1421,"content":"最近面试了一家公司，聊完后说还是希望要大厂经验，主导过上千万QPS的核心架构师，boss工资范围8-13，关键是自己业务都说不明白","createdAt":"2025-08-01T14:29:45"},{"id":"0198645c-80d1-730a-aca4-60ae10155c7a","parentId":null,"rootId":null,"fromId":1401,"content":"这工资还招千万QPS的架构呢，心里没点B数","createdAt":"2025-08-01T14:40:40"},{"id":"0198645d-012a-7129-8149-3f3cae08792f","parentId":null,"rootId":null,"fromId":1401,"content":"我怀疑它们甚至不知道千万QPS是什么概念","createdAt":"2025-08-01T14:41:13"},{"id":"01986471-6e36-7355-a936-a1ce3fe46278","parentId":null,"rootId":null,"fromId":6091,"content":"8w到13w么","createdAt":"2025-08-01T15:03:32"},{"id":"01986479-e14b-731e-b561-82d4b6693cee","parentId":null,"rootId":null,"fromId":23605,"content":"想啥呢哥们","createdAt":"2025-08-01T15:12:45"},{"id":"0198647a-3636-732f-8dde-7674af7f7a75","parentId":null,"rootId":null,"fromId":23605,"content":"济南有这个工资我吃屎","createdAt":"2025-08-01T15:13:07"},{"id":"019864a1-3982-73ae-aa9d-e54bbb3c7b4e","parentId":null,"rootId":null,"fromId":6039,"content":"不管是8~13w还是8~13k，感觉你都不用去面，前面济南没有这种薪资的，后者高级研发也不止这个数了，还想招架构","createdAt":"2025-08-01T15:55:44"},{"id":"019864a4-7fa4-713f-923e-acbd48878b14","parentId":null,"rootId":null,"fromId":5889,"content":"汉峪金谷有个融邦集团就是这样，，，，面试官啥也不懂，，，还研发经理呢","createdAt":"2025-08-01T15:59:18"},{"id":"019864b6-90d7-72d4-9bc9-1bc593dc7d07","parentId":null,"rootId":null,"fromId":1421,"content":"这个公司的职位挂好几年了","createdAt":"2025-08-01T16:19:02"},{"id":"019864b8-f2a9-7199-8555-c648bb795b58","parentId":null,"rootId":null,"fromId":5889,"content":"很多上来就是问上万并发量，我就纳闷，你搞个企业内部用的管理系统，用户还没有几万呢，系统就做到了并发几万？","createdAt":"2025-08-01T16:21:39"},{"id":"019864bc-15ce-7157-b3dc-b9d24cacc99d","parentId":null,"rootId":null,"fromId":5889,"content":"我去面过，专门请假去的，问加解密，然后我说了我们现在生产环境的方案，他就在那懵","createdAt":"2025-08-01T16:25:04"},{"id":"019864bc-fea1-727d-9a67-505b9e8842bb","parentId":null,"rootId":null,"fromId":5889,"content":"笑死，千万QPS","createdAt":"2025-08-01T16:26:04"},{"id":"019864cb-23f6-7196-9497-2c890772b57e","parentId":null,"rootId":null,"fromId":1421,"content":"是这样，先普通三高架构聊一遍，聊完后再聊AI,AI如果你回答的还行，那就继续云原生，区块链等，当然这些你的知识储备量可能远远高于对面，然后会说你开源项目的start怎么才几百没影响力之类的，一句话：非的找到一个点打击下面试者然后秀下优越感","createdAt":"2025-08-01T16:41:31"},{"id":"019864cf-e8ab-716a-bf5a-2438c78f52b9","parentId":null,"rootId":null,"fromId":3835,"content":"怎么听着像山东高速工程检测 去年面过也是上千万QPS","createdAt":"2025-08-01T16:46:43"},{"id":"019864d3-7b95-7372-ac5a-e8ab6a831fe0","parentId":null,"rootId":null,"fromId":5889,"content":"汉汇科技~~~ 面试官最后来一句：你的面很广，深度不够，就因为问了一个volitate没答上来","createdAt":"2025-08-01T16:50:38"},{"id":"019864d8-1d4d-71c2-8be9-22d92b6fb1db","parentId":null,"rootId":null,"fromId":1421,"content":"那厮每次都是这句结尾","createdAt":"2025-08-01T16:55:41"},{"id":"019864d9-f13b-7045-b76f-d06b611ec53c","parentId":null,"rootId":null,"fromId":5889,"content":"看来不只是我一个","createdAt":"2025-08-01T16:57:41"},{"id":"01986510-37c0-70f9-b284-fe59a7abe4f1","parentId":null,"rootId":null,"fromId":1421,"content":"4月份面试最后还是这个话术，现在职位还在挂着","createdAt":"2025-08-01T17:56:58"},{"id":"01986512-f35f-73dc-a30c-e3a40949d432","parentId":null,"rootId":null,"fromId":1421,"content":"这是上班无聊找人唠嗑","createdAt":"2025-08-01T17:59:57"},{"id":"0199092a-c783-70c3-9543-427a5df3f2dd","parentId":null,"rootId":null,"fromId":1538,"content":"破公司业务量没几个,要求的不少, 看着上市公司的运营情况眼红的不行,照搬过来就是作死,多么愚蠢的要求,上千万的QPS,离了个大谱","createdAt":"2025-09-02T14:43:42"}]