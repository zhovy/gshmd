[{"id":"01963de9-02e4-717a-b208-87e6e76c18cb","parentId":null,"rootId":null,"fromId":1398,"content":"工作几年了","createdAt":"2023-10-15T20:41:19"},{"id":"01963de9-0329-71f5-b1ec-c6df6557e049","parentId":null,"rootId":null,"fromId":5927,"content":"20年毕业的","createdAt":"2023-10-15T20:56:22"},{"id":"01963de9-032e-70a7-8531-39b57631fa7d","parentId":null,"rootId":null,"fromId":5927,"content":"现在的IT的形式也不大好，前端已死，后端饱和 感觉转的的可能浪费大半年时间，云计算运维感觉还靠谱点","createdAt":"2023-10-15T21:06:47"},{"id":"01963de9-0332-70a7-bac1-44a271c8ce34","parentId":null,"rootId":null,"fromId":1398,"content":"确实是有很大的难度","createdAt":"2023-10-15T22:56:29"},{"id":"01963de9-033d-7220-8eed-7d567c332a1f","parentId":null,"rootId":null,"fromId":1398,"content":"兄弟，现在实施工资多少啊？?","createdAt":"2023-10-15T22:57:01"},{"id":"01963de9-038a-724a-9aec-8bba6bb0f745","parentId":null,"rootId":null,"fromId":2408,"content":"实施岗位薪资一般在多少？一个月大约出差多少天？","createdAt":"2023-10-16T11:12:21"},{"id":"01963de9-0385-714e-9519-d1c6eacd6f4d","parentId":null,"rootId":null,"fromId":5927,"content":"济南8k","createdAt":"2023-10-16T17:18:38"},{"id":"01963de9-03d8-7062-83b8-7e6ccb6a6fa1","parentId":null,"rootId":null,"fromId":5927,"content":"比研发低，出差挺频繁的大部分时间都出差","createdAt":"2023-10-16T17:19:22"},{"id":"01963de9-03dc-71d0-88c3-f0b2348f4486","parentId":null,"rootId":null,"fromId":1398,"content":"兄弟，你做实施的工作主要是什么呀？出差期间有什么工作内容，我也考虑转行了","createdAt":"2023-10-16T17:28:28"},{"id":"01963de9-0422-7035-9a99-ad26bef53424","parentId":null,"rootId":null,"fromId":5927,"content":"你想转实施吗","createdAt":"2023-10-16T20:39:58"},{"id":"01963de9-0427-703d-a245-36efd6834736","parentId":null,"rootId":null,"fromId":1398,"content":"有点想法了","createdAt":"2023-10-16T23:23:57"},{"id":"01963de9-042c-73d6-9fee-5dcc3d3cda06","parentId":null,"rootId":null,"fromId":5927,"content":"你现在干啥的","createdAt":"2023-10-17T09:25:39"},{"id":"01963de9-0430-72fb-90b3-44ea81e42e10","parentId":null,"rootId":null,"fromId":1398,"content":"开发","createdAt":"2023-10-17T11:05:28"},{"id":"01963de9-0434-729f-b123-8bae9c7140ee","parentId":null,"rootId":null,"fromId":5927,"content":"不抗拒出差就可以转，工作内容主要就是 软件的落地，上线那几天很忙，其他时间还好，主要就是负责软件的维护升级，使用过程出现问题及时处理。上下班时间一般是和甲方的上下班时间一致，你能接受基本就可以转。不过你开发干的好好地为啥要转呢，我都想做研发了，不出差多好，不过出差每天是有补助的，看每个公司的具体给多少。","createdAt":"2023-10-18T09:57:58"},{"id":"01963de9-0438-71bf-8f16-bb9b98093665","parentId":null,"rootId":null,"fromId":5429,"content":"老哥还在干么，我现在也是实施，兼顾vue模块开发，但是老板借口我实习工资低，已经涨了很多，给我压工资","createdAt":"2024-02-28T17:19:39"},{"id":"01963de9-0337-706a-aae2-a86dc3d46f57","parentId":null,"rootId":null,"fromId":929,"content":"济南的运维岗不多，请考虑好；做运维还得是大城市","createdAt":"2024-02-28T17:45:04"}]