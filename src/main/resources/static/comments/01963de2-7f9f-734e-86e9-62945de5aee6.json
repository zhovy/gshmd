[{"id":"01963de2-800e-711f-8750-eb858a3f2ad3","parentId":null,"rootId":null,"fromId":2144,"content":"公司各项福利都还行，就是公积金最低比例交的。基本不加班，每天5点半准时打卡走人。公司空间太小，不知道啥时候搬地方","createdAt":"2023-05-26T18:54:33"},{"id":"01963de2-805f-70ce-bd25-78a551085636","parentId":null,"rootId":null,"fromId":4006,"content":"工资延迟发放、承诺的福利有的没有、社保延迟缴纳","createdAt":"2023-07-06T18:57:27"},{"id":"01963de2-80ab-73ca-82a5-1b86a1f17f73","parentId":null,"rootId":null,"fromId":3126,"content":"不建议去，入职两周看了两周代码，没怎么给安排工作，直接劝退，不信的可以去试试","createdAt":"2023-08-15T18:32:27"},{"id":"01963de2-80f2-73e4-a4ef-1d9c96199305","parentId":null,"rootId":null,"fromId":3126,"content":"天天加班","createdAt":"2023-08-15T18:50:47"},{"id":"01963de2-805a-73cf-b3e9-d54828f0a673","parentId":null,"rootId":null,"fromId":7284,"content":"你跟楼下谁的对啊","createdAt":"2024-04-23T14:00:10"},{"id":"01963de2-80f7-72cd-8cce-1a78d0fbef4e","parentId":null,"rootId":null,"fromId":7433,"content":"已经被违法辞退，N+1没有。公司给补偿一个月工资，我们不同意。现在都开始拿不给5月份工资做威胁了，谁去谁知道哈哈。工资延迟发放，给你签个协议。其实就是降薪，入职承诺的13薪，年终奖，半年调薪制度。结果到年底迎来的确实降薪，其余啥也没有。","createdAt":"2024-06-13T12:08:59"},{"id":"01963de2-8143-715c-b3ad-31965f857403","parentId":null,"rootId":null,"fromId":7433,"content":"这公司也能算是自研吗哈哈，难道不是从\"中fu”反编译过来就拿来用了吗","createdAt":"2024-06-13T12:12:24"}]