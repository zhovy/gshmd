[{"id":"01963de7-e8ee-73e4-b71e-87461ecd068f","parentId":null,"rootId":null,"fromId":2408,"content":"老铁什么岗位","createdAt":"2023-09-12T08:47:56"},{"id":"01963de7-e933-73bb-8734-fc3a84a1d3d7","parentId":null,"rootId":null,"fromId":3892,"content":"裸辞吗？普联好像招人，先有个工作干着吧","createdAt":"2023-09-12T08:48:51"},{"id":"01963de7-e977-704f-ac6b-8139eb3c2b1d","parentId":null,"rootId":null,"fromId":4253,"content":"找了三个星期，很多公司没有投（因为看了黑名单，筛选条件：正常发工资，双休，不加班，不是外派），投了感觉得200 家，实际上邀请面试的不到10家，绝大多数连看都没有看，面试的有几家就是刷kpi，有得给了offer 工资给的太低了（还不如现在高）。唉，现在感觉投了之后就是石沉大海，难找。","createdAt":"2023-09-12T09:19:38"},{"id":"01963de7-e9bd-70c8-b1ae-3575dffcc6ce","parentId":null,"rootId":null,"fromId":1150,"content":"这年头还有人能找不到工作？","createdAt":"2023-09-12T10:05:04"},{"id":"01963de7-ea00-7199-9c38-8b914e77a879","parentId":null,"rootId":null,"fromId":3671,"content":"虽然我找到了，实属运气好，投了上百份，只要几个联系我的，面了两家，找个工作太难了","createdAt":"2023-09-12T10:09:15"}]