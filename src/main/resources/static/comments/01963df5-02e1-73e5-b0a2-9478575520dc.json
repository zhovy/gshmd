"},{"id":"01963df5-0549-7391-89a3-f33a9009f18d","parentId":null,"rootId":null,"fromId":6344,"content":"万科繁荣里","createdAt":"2024-12-02T09:22:34"},{"id":"01963df5-0500-7183-93b4-56f0075da9c7","parentId":null,"rootId":null,"fromId":297,"content":"其实“刚需”这个词就是背后资本家炒作出来的，逼着老百姓进入城市必须买了房子，孩子才能就近上学","createdAt":"2024-12-09T15:19:12"}]