[{"id":"01963ddb-a061-736b-8d54-d46656668796","parentId":null,"rootId":null,"fromId":1292,"content":"兄弟你这是怎么了，我是20年底离职走的，当时就是因为这个公司太黑了，老板是政府单位的，小手段给你玩的66的，各种加班克扣，到手工资打5折差不多","createdAt":"2022-08-11T17:18:22"},{"id":"01963ddb-a0a9-7287-a188-c989040c050d","parentId":null,"rootId":null,"fromId":1292,"content":"要是有合适的抓紧走吧，这公司不是人呆的","createdAt":"2022-08-11T17:19:12"},{"id":"01963ddb-a0f1-73bd-bbc9-915ddb6a65ba","parentId":null,"rootId":null,"fromId":1293,"content":"你也是怂逼，这还能干这么久","createdAt":"2022-08-11T17:22:14"},{"id":"01963ddb-a142-71e1-b000-a6c57c06ddfa","parentId":null,"rootId":null,"fromId":1275,"content":"请问你是怎么坚持下来的","createdAt":"2022-08-11T17:25:51"},{"id":"01963ddb-a187-722f-a89d-fc53577997b2","parentId":null,"rootId":null,"fromId":1300,"content":"我就是当时21年走的，当时公司实习期不给发绩效，过了3个月实习期，各种理由卡不让转正，最后说能力不行给辞退了。","createdAt":"2022-08-11T22:30:12"},{"id":"01963ddb-a1cb-7325-8da5-6379f8bb9565","parentId":null,"rootId":null,"fromId":460,"content":"青岛的就别在这出现了","createdAt":"2022-08-12T08:46:56"},{"id":"01963ddb-a20f-70bb-83d6-3bdd396e0639","parentId":null,"rootId":null,"fromId":1326,"content":"而立啊熊弟。描述很真实很可靠，顶一个！","createdAt":"2022-08-12T12:52:49"},{"id":"01963ddb-a252-733f-8141-fc517b061132","parentId":null,"rootId":null,"fromId":1159,"content":"顶一个，句句属实","createdAt":"2022-08-13T23:07:33"},{"id":"01963ddb-a296-71b4-8639-52481e3e4caf","parentId":null,"rootId":null,"fromId":557,"content":"济南分公司的帖子：https://gshmd.vip/#/company/585","createdAt":"2022-09-02T17:30:16"}]