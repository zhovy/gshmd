[{"id":"01963de4-8f7e-7002-b611-4706a0f5ebd4","parentId":null,"rootId":null,"fromId":2613,"content":"坑爹的公司别去","createdAt":"2023-07-06T08:55:49"},{"id":"01963de4-8fc4-719b-8864-4aa3c181f669","parentId":null,"rootId":null,"fromId":195,"content":"大佬能细说说吗","createdAt":"2023-07-06T08:58:32"},{"id":"01963de4-8fc8-7363-ab40-a62af62e0649","parentId":null,"rootId":null,"fromId":1039,"content":"知道结果就行了呗    知道太多对你不好","createdAt":"2023-07-06T09:07:03"},{"id":"01963de4-8fcc-732d-98bd-13a7e5aed73b","parentId":null,"rootId":null,"fromId":3957,"content":"站在旁观者的角度，你不说细节只说结果，可信度有吗，我不是在针对你兄弟。","createdAt":"2023-07-06T09:09:10"},{"id":"01963de4-8fd1-72f5-9851-d1c33ed4be43","parentId":null,"rootId":null,"fromId":2613,"content":"去看看，之前好像有评论","createdAt":"2023-07-06T09:40:58"},{"id":"01963de4-8fd4-728b-9ca6-20a931cf46e2","parentId":null,"rootId":null,"fromId":1474,"content":"之前去面过，感觉不靠谱，没去。","createdAt":"2023-07-06T10:06:30"},{"id":"01963de4-9017-7067-bca2-b5afdd77aea1","parentId":null,"rootId":null,"fromId":557,"content":"今年2月份的时候，我也去面过。当时的二面面试官，我感觉他谎话连篇，一会说自己在北京待了十几年，一会说自己以前在易搜干，一会说自己工作十来年，自己的工作履历和年限，自己说的就前言不搭后语，太能吹了。所以我就没去入职。做的项目有两个，一个是幼儿园的设备，内嵌的安卓。还一个就是他们母公司接的外包。就面试官的谈吐和吹牛，让我感觉这人和这公司不靠谱。所以没去。","createdAt":"2023-07-06T10:24:11"},{"id":"01963de4-9060-7198-9860-863306c74b86","parentId":null,"rootId":null,"fromId":4016,"content":"控股股东岛朗艺文化艺术发展有限公司看着还行\n","createdAt":"2023-07-20T16:57:24"},{"id":"01963de4-9064-7059-bca3-7deb3eb707c5","parentId":null,"rootId":null,"fromId":6637,"content":"是不是姓王啊","createdAt":"2024-02-06T15:14:35"},{"id":"01963de4-9069-7368-891c-b16b891ce285","parentId":null,"rootId":null,"fromId":7460,"content":"有内部斗争。谁去就做好鸡飞蛋打的准备，永远渣男的作风","createdAt":"2024-05-23T12:17:17"}]