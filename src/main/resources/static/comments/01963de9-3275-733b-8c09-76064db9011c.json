[{"id":"01963de9-32f2-7097-a4d8-cfadef12e741","parentId":null,"rootId":null,"fromId":875,"content":"现在注册制，上市公司那么多，外面拿高工资不好吗，济南一年上市几个？上不了市，就越来越拉跨","createdAt":"2023-10-21T09:44:09"},{"id":"01963de9-3337-7005-9098-f9a2b913364e","parentId":null,"rootId":null,"fromId":875,"content":"中午济南吃个面，面馆老板之前都是济南500强的高管，所以就说，在济南呆着有啥用，等到35开饭店嘛，在外面人家都一个个手握期权股权发大财，济南也就只能开面馆了","createdAt":"2023-10-21T12:16:45"},{"id":"01963de9-337d-71e0-a46e-6699723b7896","parentId":null,"rootId":null,"fromId":2407,"content":"哪有那么多产品或者技术驱动型的公司，基本都是业务驱动的。你说的这种公司在北上广也是少数","createdAt":"2023-10-21T22:01:19"},{"id":"01963de9-33c2-7150-9f4b-af20f085d6d3","parentId":null,"rootId":null,"fromId":875,"content":"选择比努力更重要，济南房价高，交通堵，水质差，环境卷，没关系没人脉5年即失业，谁会要一个大龄的开发","createdAt":"2023-10-22T19:53:19"},{"id":"01963de9-3409-738b-9f62-c6a39f10f15e","parentId":null,"rootId":null,"fromId":3219,"content":"济南为什么水质差啊","createdAt":"2023-10-23T10:39:23"},{"id":"01963de9-340d-71a5-b773-1d8f41c2f477","parentId":null,"rootId":null,"fromId":875,"content":"私企上班你有股权吗，去私企上班没股权干的没意思","createdAt":"2023-10-24T18:03:26"},{"id":"01963de9-3452-73ab-b795-0352e79339c4","parentId":null,"rootId":null,"fromId":7008,"content":"山东矩阵软件工程，刚融了a轮，不缺钱","createdAt":"2024-03-14T07:58:00"},{"id":"01963de9-3497-704b-8d1d-dd89c861a4a8","parentId":null,"rootId":null,"fromId":2433,"content":"矩阵软件就是好，不强制加班（五毛一条，括号里内容记得删掉）","createdAt":"2024-03-14T08:33:13"},{"id":"01963de9-349b-73df-a108-7d777073bc4e","parentId":null,"rootId":null,"fromId":6435,"content":"这公司996","createdAt":"2024-03-19T12:29:14"}]