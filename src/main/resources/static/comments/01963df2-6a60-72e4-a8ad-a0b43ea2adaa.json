[{"id":"01963df2-6ac5-7182-86ee-78334b6c66ae","parentId":null,"rootId":null,"fromId":7437,"content":"回老家进厂","createdAt":"2024-08-20T16:56:06"},{"id":"01963df2-6b0a-73db-9964-4b1eee52179d","parentId":null,"rootId":null,"fromId":5408,"content":"进厂或去大城市碰碰运气","createdAt":"2024-08-20T17:11:32"},{"id":"01963df2-6b4e-70e0-9946-61fe1dad892b","parentId":null,"rootId":null,"fromId":875,"content":"在济南就是卖房子，开滴滴，送外卖，开面馆，开理发店，开药店，高二房东租房子，股市豆跌成什么会变成样子了","createdAt":"2024-08-20T19:13:13"},{"id":"01963df2-6b97-7171-9767-1ccd1e1b0b5c","parentId":null,"rootId":null,"fromId":875,"content":"还是卖房子赚钱，小区门口五六个门头房都是卖房子的，中住，德祐，一大堆","createdAt":"2024-08-20T19:19:24"},{"id":"01963df2-6be0-7226-a1c0-53350d48005c","parentId":null,"rootId":null,"fromId":21706,"content":"努力学习，让自己变强","createdAt":"2024-08-20T21:31:18"},{"id":"01963df2-6b93-7067-8282-92b0901d3c74","parentId":null,"rootId":null,"fromId":1492,"content":"早点，面馆竞争也很激烈。小区不大，4个早点铺，4个面馆","createdAt":"2024-08-21T09:33:12"},{"id":"01963df2-6c27-72e9-9418-c95ef1de1a5d","parentId":null,"rootId":null,"fromId":21685,"content":"回去呗 树挪死 人挪活","createdAt":"2024-08-21T09:37:49"},{"id":"01963df2-6c6c-726d-b90a-b5da5aedaccd","parentId":null,"rootId":null,"fromId":403,"content":"我也觉得济南越来越不适合年轻人呆了，公司福利和社会福利都不行，996，大小周遍地开花。","createdAt":"2024-08-21T10:13:50"},{"id":"01963df2-6cb0-722d-a6d9-1a8e700210c6","parentId":null,"rootId":null,"fromId":4140,"content":"讲道理，济南虽然社保、公积金恶心人，大小周很常见，但是工资确实是山东省内给的最多的了，最主要，搞IT软件开发的，在山东省内不在济南能去哪呢？就算是青岛IT的需求岗位跟济南也不在一个数量级上。","createdAt":"2024-08-21T10:22:09"},{"id":"01963df2-6cb4-7079-a1c2-6f2879074f6b","parentId":null,"rootId":null,"fromId":2890,"content":"垃圾去哪里都是垃圾","createdAt":"2024-08-21T11:04:26"},{"id":"01963df2-6cfb-737f-8830-78fe88f93098","parentId":null,"rootId":null,"fromId":7249,"content":"你不是垃圾  你去开银行去","createdAt":"2024-08-21T11:05:57"},{"id":"01963df2-6d08-707e-9119-2c94013edc14","parentId":null,"rootId":null,"fromId":21711,"content":"也是迷茫中，还是想自己干点事儿。","createdAt":"2024-08-21T11:33:18"},{"id":"01963df2-6cff-7173-acf6-4bf2a03c6970","parentId":null,"rootId":null,"fromId":2783,"content":"话糙理不糙","createdAt":"2024-08-21T12:47:49"},{"id":"01963df2-6d4d-720d-9c57-935f9712d455","parentId":null,"rootId":null,"fromId":6939,"content":"IT行业济南给的薪资算是不错的了，但是济南整体的氛围不大行，不管是工作氛围还是生活氛围。","createdAt":"2024-08-21T15:39:36"},{"id":"01963df2-6d95-7212-b56c-3514357dfd66","parentId":null,"rootId":null,"fromId":3341,"content":"工作氛围多数不太好 但是生活氛围 济南的生活也还算不错吧？没一线和旅游城市那样人挤人 但是各个方面也很方便","createdAt":"2024-08-22T09:49:07"},{"id":"01963df2-6bda-7345-a75a-b0515ddae202","parentId":null,"rootId":null,"fromId":3341,"content":"所以你是买房子的吗？","createdAt":"2024-08-22T09:49:52"},{"id":"01963df2-6d99-706b-8ad2-3c4419578ccb","parentId":null,"rootId":null,"fromId":875,"content":"现在就混不下去了？65岁才退休呢，房贷30年","createdAt":"2024-08-22T14:38:20"},{"id":"01963df2-6de1-71d0-bf52-3963eaf23903","parentId":null,"rootId":null,"fromId":21722,"content":"这里怎么发帖啊","createdAt":"2024-08-22T15:46:55"},{"id":"01963df2-6e25-7056-b34f-9791a1f073c5","parentId":null,"rootId":null,"fromId":6091,"content":"控制台哪里","createdAt":"2024-08-22T16:17:18"},{"id":"01963df2-6d04-73e2-ac98-1b3607c771e6","parentId":null,"rootId":null,"fromId":21363,"content":"你是个垃圾","createdAt":"2024-08-23T14:31:35"},{"id":"01963df2-6e29-73eb-831c-78bbfe453d8f","parentId":null,"rootId":null,"fromId":875,"content":"但凡早几年买几套房","createdAt":"2024-08-24T10:06:39"}]