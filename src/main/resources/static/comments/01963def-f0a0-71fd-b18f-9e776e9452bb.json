[{"id":"01963def-f10d-72e2-8bf4-c6b18d67ded6","parentId":null,"rootId":null,"fromId":896,"content":"我就问济南有比这炸裂的吗？？？","createdAt":"2024-05-31T09:40:20"},{"id":"01963def-f159-7091-844d-eac5a1814e09","parentId":null,"rootId":null,"fromId":7702,"content":"1","createdAt":"2024-05-31T09:47:09"},{"id":"01963def-f19e-7013-9ae9-2b1f179ba4a5","parentId":null,"rootId":null,"fromId":2572,"content":"鲁软外包，狗JB，上一年不是还有个在东泰中心跳楼死了的么，中国人专门欺负中国人。","createdAt":"2024-05-31T09:48:25"},{"id":"01963def-f1e3-7332-8ac4-97aad6e84f8a","parentId":null,"rootId":null,"fromId":896,"content":"因为啥知道吗，看新闻说不是东泰上班的","createdAt":"2024-05-31T10:04:02"},{"id":"01963def-f1ec-7196-83e4-d8d0e6809ed2","parentId":null,"rootId":null,"fromId":7116,"content":"报工  补卡   请假这几条我觉得不算过分啊，不不卡扣钱也正常吧。报工都是应付领导的，写一下就可以了，没啥问题啊。按时打卡也正常啊，要不怎么知道你有没有迟到早退。这不是一个职场人应该做的么...","createdAt":"2024-05-31T10:04:47"},{"id":"01963def-f230-708d-a3ff-f127116ffff5","parentId":null,"rootId":null,"fromId":896,"content":"你觉得正常吗，你从哪听说迟到几分钟就直接扣一天工资正常的，又从哪听说不写日报就直接扣一天工资正常的，你看清楚这都是扣一天工资不是扣十几二十","createdAt":"2024-05-31T10:16:41"},{"id":"01963def-f234-71b8-a4bc-2e13edebdd0e","parentId":null,"rootId":null,"fromId":896,"content":"我给你举个例子吧，我一个同事迟到了两分钟没打上卡，那段时间正好实行没有机会的考勤，他就直接请了一上午假，扣了半天工资，更恶心的是因为打卡时间和考勤时间没对上，下午工资也没了。然后下午项目经理走那开会说，没事别请假！！我就想说就因为两分钟迟到扣完工资，还得无偿上班是吧","createdAt":"2024-05-31T10:19:55"},{"id":"01963def-f23d-73cc-99f1-fd3ea797938d","parentId":null,"rootId":null,"fromId":576,"content":"外包外协的日子，你们还在参与体验？这反人类的工作日常。","createdAt":"2024-05-31T10:40:59"},{"id":"01963def-f284-72b6-9a1a-cb044ff2ea99","parentId":null,"rootId":null,"fromId":1398,"content":"这样的话是不是迟到就可以直接请一天假了","createdAt":"2024-05-31T11:02:36"},{"id":"01963def-f2ce-716f-982e-35c4db25e7db","parentId":null,"rootId":null,"fromId":576,"content":"人家项目经理说了，没事别请假。。。。闭环了","createdAt":"2024-05-31T11:20:05"},{"id":"01963def-f2d3-70c7-9eb2-38d7f5387758","parentId":null,"rootId":null,"fromId":6334,"content":"鲁软外包 看公司吗还是全部公司都这样","createdAt":"2024-05-31T13:54:24"},{"id":"01963def-f317-723b-878c-2b8e37061a96","parentId":null,"rootId":null,"fromId":896,"content":"全部","createdAt":"2024-05-31T14:08:11"},{"id":"01963def-f320-73e1-9ecd-ca0232e960f1","parentId":null,"rootId":null,"fromId":6374,"content":"刷新了我的眼界， 这外包最近疯狂招人啊，遇见好多就直接拒绝了。","createdAt":"2024-05-31T19:39:05"},{"id":"01963def-f364-70f1-bc81-7188d8508e2d","parentId":null,"rootId":null,"fromId":875,"content":"过了打卡时间，不让打卡，也就济南的HR们敢这么的弄，直接扣钱，还是觉得开发人太多","createdAt":"2024-06-01T11:29:47"},{"id":"01963def-f3a8-725f-ac45-22423049f4a2","parentId":null,"rootId":null,"fromId":7735,"content":"我在鲁软上班的时候，两周休一天，晚上上班到11点","createdAt":"2024-06-03T08:40:52"},{"id":"01963def-f3f3-7090-b8cd-64b7800d340a","parentId":null,"rootId":null,"fromId":6631,"content":"见识到了，真的见识到了。为何如此霸道，是不是因为找工作的人太多，所以无所畏惧，走了一个，反正还是会很快招到下一个。","createdAt":"2024-06-03T09:27:07"},{"id":"01963def-f31c-7012-abd1-98b918d8684b","parentId":null,"rootId":null,"fromId":7743,"content":"别听他们吹牛逼，整个济南都是","createdAt":"2024-06-03T10:42:50"},{"id":"01963def-f3ef-71fa-a015-971ff652aeb8","parentId":null,"rootId":null,"fromId":7743,"content":"那你加班费可没少挣啊","createdAt":"2024-06-03T10:43:31"},{"id":"01963def-f154-73b1-8cb5-23ba430bbd1a","parentId":null,"rootId":null,"fromId":7743,"content":"鲁软外包几十家，是不是就你公司这样？","createdAt":"2024-06-03T10:54:20"},{"id":"01963def-f1e7-7052-a9a0-d1dcc3c4d9eb","parentId":null,"rootId":null,"fromId":7783,"content":"别造谣哈，这人就是专门到东泰跳楼的，跟鲁软没关系","createdAt":"2024-06-06T17:05:32"},{"id":"01963def-f446-70e9-abad-c9f514398d54","parentId":null,"rootId":null,"fromId":7783,"content":"第二条没听说过，第三条里的补卡是一直都能补卡啊，没遇到过几个月不能补的情况。\n其他的属实","createdAt":"2024-06-06T17:16:29"},{"id":"01963def-f48a-72f6-a159-4adf260b1ab2","parentId":null,"rootId":null,"fromId":896,"content":"第二条没听说过，等你出现这个问题，工资被扣就听说了。第三条不知道的话只能说明你在鲁软没多久，当时所有外包公司都发通知了","createdAt":"2024-06-07T09:53:44"},{"id":"01963def-f48f-7220-bb96-1c5e8b905f25","parentId":null,"rootId":null,"fromId":7783,"content":"周边所有同事都没听说过第二条，也没出现过因为这种事扣工资的情况。\n补卡那个只有过一次，说是必须有上级的工作佐证才可以补卡，也不是禁止补卡啊。","createdAt":"2024-06-07T14:29:02"},{"id":"01963def-f493-70c0-88af-8b6e47bafc66","parentId":null,"rootId":null,"fromId":7783,"content":"不行你问问周边同事，有这种情况不，你别是被外包公司坑了","createdAt":"2024-06-07T14:39:46"},{"id":"01963def-f238-7188-9b0e-00374d4944ae","parentId":null,"rootId":null,"fromId":7433,"content":"卷呗就是，这不就反人类吗，一点人情味没有。你竟然也觉着正常哈哈哈","createdAt":"2024-06-13T12:30:07"},{"id":"01963def-f441-728a-8a5b-67aadc20cd25","parentId":null,"rootId":null,"fromId":896,"content":"2023年4月21日17-30\nzxn\n@所有人 各位同事，所有在济南办公的项目组大家以后上下班需要使用考勤机打卡，企业微信手机端打卡就不要再用了，以后考勤数据以考勤机器打卡为准。另外，公司也取消了每月两次补卡的机会，烦请各位同事遭守考勤纪律和工作制度，按时上下班。谢谢!\n\n这是当时通知","createdAt":"2024-08-16T16:31:03"},{"id":"01963def-f497-72c4-a2e3-26797edfa470","parentId":null,"rootId":null,"fromId":896,"content":"2023年4月21日17-30 zxn @所有人 各位同事，所有在济南办公的项目组大家以后上下班需要使用考勤机打卡，企业微信手机端打卡就不要再用了，以后考勤数据以考勤机器打卡为准。另外，公司也取消了每月两次补卡的机会，烦请各位同事遭守考勤纪律和工作制度，按时上下班。谢谢! 这是当时通知","createdAt":"2024-08-16T16:31:18"}]