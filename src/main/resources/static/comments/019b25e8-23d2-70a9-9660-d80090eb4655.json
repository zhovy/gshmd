[{"id":"019b25f7-0d1e-721e-a20a-e758783d030e","parentId":null,"rootId":null,"fromId":781,"content":"正统研究生都翻不了盘，指望在职研究生翻盘吗","createdAt":"2025-12-16T15:01:46"},{"id":"019b2605-d5e3-7003-ae2f-eeddffc4f162","parentId":null,"rootId":null,"fromId":1039,"content":"一点意义都没有，只看第一学历","createdAt":"2025-12-16T15:17:55"},{"id":"019b2620-c1de-73a8-a541-c018e81b92aa","parentId":null,"rootId":null,"fromId":2783,"content":"你考这么多非全日制的意义是什么呢？","createdAt":"2025-12-16T15:47:19"},{"id":"019b2622-a70f-70f6-8a4e-0cbbead04662","parentId":null,"rootId":null,"fromId":4366,"content":"没时间再去上一个统招的学历了，搞个研究生，是不是竞争力能上去一点，现在函授自考，hr一听就摇头","createdAt":"2025-12-16T15:49:23"},{"id":"019b2626-866a-70f3-abfc-974d1bae1f1a","parentId":null,"rootId":null,"fromId":926,"content":"在职研究生认可度也不高","createdAt":"2025-12-16T15:53:37"},{"id":"019b2658-acca-711b-abc5-dc6c430fdc42","parentId":null,"rootId":null,"fromId":2783,"content":"有自考的时间 还不如考编去呢","createdAt":"2025-12-16T16:48:24"},{"id":"019b266f-3968-7092-99ff-57c6b84878c5","parentId":null,"rootId":null,"fromId":1955,"content":"给一个中肯的回答吧。我身边有很多大龄的人40的，37、38的，45岁的都有，好些个准备或者已经考上在职研，有人工智能方向的，有管理型比如MPA类似的等等，首先我只是IT行业的，这些人大部分也是IT行业的，他们普遍的共有的一个想法总结起来就是”年龄大了，IT在济南就这样了，不考在职研也还是这个样了，但是考上了会不会有另外的机会和圈子“，这个有身边人也有实际转折，是有那么几个朋友考上在职研圈子变了，职位变了，薪资也变了，比如刚才说的那个人工智能的老友，没考之前只是一个私企的项目经理，考上之后现在就通过圈子进入了一个专门从事人工智能研发的公司，薪资也涨了不少，仅此而已，仅供您参考","createdAt":"2025-12-16T17:13:02"},{"id":"019b2673-0c71-716e-98ec-5b4473ec8642","parentId":null,"rootId":null,"fromId":1955,"content":"一切准备好，机会来了可以把握住，就怕机会来了没能力把握，岂不是很后悔","createdAt":"2025-12-16T17:17:12"},{"id":"019b267f-d9a5-72f3-bc87-7aeb1893967c","parentId":null,"rootId":null,"fromId":4366,"content":"很全面，谢谢大佬","createdAt":"2025-12-16T17:31:11"},{"id":"019b29c4-14d3-705b-ba50-897a8cb612d7","parentId":null,"rootId":null,"fromId":22978,"content":"可以考个统招非全硕","createdAt":"2025-12-17T08:44:34"},{"id":"019b2a5e-21bc-72f9-b605-e13c0cfbd5bd","parentId":null,"rootId":null,"fromId":24782,"content":"老哥，说点扎心的实话，你以为研究生是说考就考的么，在职研究生你得准备至少一年时间，每天复习，你要是正规统招本科的话还有点戏，专科都是函授，英语单词，数学函数都不认识几个吧，咋考？非全的硕士也是要考试，写论文，上课的。","createdAt":"2025-12-17T11:32:50"},{"id":"019b2ae3-7184-701c-8a69-ce3672a4306a","parentId":null,"rootId":null,"fromId":1376,"content":"大家都知道，非统招都很水，难道水货研究所，企业就会要了吗，现在大部分分两种，一种有学历有实力去好公司没问题，有学历没实力和有实力没学历，找个一般的公司上着班，如果既没学历又没实力，就随便找个工作混混日子得了，到时候转行了","createdAt":"2025-12-17T13:58:27"},{"id":"019b2ae5-3ac8-7240-9db0-c579a018a73e","parentId":null,"rootId":null,"fromId":1376,"content":"我想知道知道这个进入人工智能研发的公司的这个人的，第一学历是啥","createdAt":"2025-12-17T14:00:24"},{"id":"019b4e79-8e32-7164-b33c-b651b64ba83d","parentId":null,"rootId":null,"fromId":1955,"content":"明确告诉你，他高中毕业，没有上过大学，然后自考的大学专科。","createdAt":"2025-12-24T11:49:07"}]