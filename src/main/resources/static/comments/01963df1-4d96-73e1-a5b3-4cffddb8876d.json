[{"id":"01963df1-4e0b-7045-9d2d-eac27727e824","parentId":null,"rootId":null,"fromId":875,"content":"有吗功夫投诉，不如赶紧找下家","createdAt":"2024-06-28T12:37:29"},{"id":"01963df1-4e50-7366-8d02-0efa09a5f79e","parentId":null,"rootId":null,"fromId":267,"content":"找到下家，不忙了再投诉，劳逸结合","createdAt":"2024-06-28T12:54:19"},{"id":"01963df1-4e55-715b-8e9b-8bbae6108df0","parentId":null,"rootId":null,"fromId":6276,"content":"投诉一个比一个慢，打蛇打七寸，找到弱点一击致命","createdAt":"2024-06-28T13:16:14"},{"id":"01963df1-4e98-710a-94c8-89e0faafd12c","parentId":null,"rootId":null,"fromId":4261,"content":"有一定规模的话，真想要就天天去公司躺着，不然你就别想了","createdAt":"2024-06-28T13:45:58"},{"id":"01963df1-4edc-73b5-8f07-480749b0cffe","parentId":null,"rootId":null,"fromId":1372,"content":"尝试投诉偷税漏税和欠社保。","createdAt":"2024-06-28T13:59:51"},{"id":"01963df1-4f25-73b1-9fcd-a1cbacbbcc23","parentId":null,"rootId":null,"fromId":3572,"content":"劳动监察什么的都没有用，并没有行政约束力，甚至社保投诉有的公司也不怕，正常讨薪还是要走劳动仲裁流程，拿到仲裁调解书，如果公司依然不履行就可以去法院申请强制执行，过几天就可以查询到公司被执行人信息了，如公司账户有钱法院会直接划入你的银行账户；到这个阶段基本都能要回钱了","createdAt":"2024-06-28T16:17:48"},{"id":"01963df1-4f6e-7272-8076-8d975a35747c","parentId":null,"rootId":null,"fromId":7294,"content":"就是去劳动大队投诉就行了。如果老板还想给的话，如果公司都不运营了，那就完犊子了","createdAt":"2024-07-01T11:33:38"},{"id":"01963df1-4f21-7344-877b-6fc768f16a10","parentId":null,"rootId":null,"fromId":880,"content":"nice","createdAt":"2024-07-01T11:42:33"}]