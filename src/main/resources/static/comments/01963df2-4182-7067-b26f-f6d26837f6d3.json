[{"id":"01963df2-41f1-71e9-9343-b5205e1f6a13","parentId":null,"rootId":null,"fromId":21511,"content":"待遇咋样","createdAt":"2024-08-13T16:03:21"},{"id":"01963df2-4234-704b-be30-2d78919ba950","parentId":null,"rootId":null,"fromId":4174,"content":"既然还在社招，那降薪干啥，要降薪就不社招了","createdAt":"2024-08-13T16:45:32"},{"id":"01963df2-4279-70c8-b872-0fac6eaedeae","parentId":null,"rootId":null,"fromId":4174,"content":"承诺的什么福利，我看看有没有要砍掉的","createdAt":"2024-08-13T16:52:25"},{"id":"01963df2-42be-7317-b8be-f9c31fc7413d","parentId":null,"rootId":null,"fromId":21487,"content":"面试的是外包还是本部？据说本部明年要砍东迁补助（油补），绩效延发，也有可能是烟雾弹","createdAt":"2024-08-13T17:00:11"},{"id":"01963df2-4315-7341-ad41-811bf4dbe120","parentId":null,"rootId":null,"fromId":875,"content":"在济南养生是第一位的，挣钱是第二位的","createdAt":"2024-08-13T22:08:08"},{"id":"01963df2-435c-7085-843d-61fd5eac6bc5","parentId":null,"rootId":null,"fromId":6434,"content":"是这样，降薪是大概率的事情，而且自23年以来，联盟整体不再像以前那么宽松，现在各项制度已经非常的严格。","createdAt":"2024-08-16T08:59:11"},{"id":"01963df2-4308-72a3-93c0-2dfb820968bb","parentId":null,"rootId":null,"fromId":1413,"content":"是的，承诺的福利里面有东迁补助，说是1000。绩效延发说延发一个月。","createdAt":"2024-08-16T16:05:07"},{"id":"01963df2-430c-7139-bcaf-6880b998f9bf","parentId":null,"rootId":null,"fromId":1413,"content":"你说的延发是指延长多久。","createdAt":"2024-08-16T16:05:45"},{"id":"01963df2-4311-737c-a27e-054b39aa5ba6","parentId":null,"rootId":null,"fromId":21487,"content":"有传言说明年停发东迁补助，绩效延发三年。","createdAt":"2024-08-16T16:30:03"}]