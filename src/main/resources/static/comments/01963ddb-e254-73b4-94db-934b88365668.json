[{"id":"01963ddb-e2c1-7128-9658-533e93124e6f","parentId":null,"rootId":null,"fromId":557,"content":"好好奇啊。","createdAt":"2022-08-25T15:06:02"},{"id":"01963ddb-e30c-706d-95bb-b24d1439dad1","parentId":null,"rootId":null,"fromId":1476,"content":"不是应届生呢？建不建议去","createdAt":"2022-08-25T16:21:33"},{"id":"01963ddb-e352-70a3-97f5-190b5e079754","parentId":null,"rootId":null,"fromId":1391,"content":"不是吧，双一流毕业的研究生就没进车间啊","createdAt":"2022-08-25T16:58:01"},{"id":"01963ddb-e396-7337-b854-a6f3545cdae2","parentId":null,"rootId":null,"fromId":1336,"content":"老帮菜过来说一句，第一年下车间是非常务实的单位的做法。\n干一年车间，你其他业务都熟悉了。比一上来坐机关强很多倍。\n如果你想在行业内长远发展，车间经验很有用！不要盲目排斥下车间，上工地这种一线工作。","createdAt":"2022-08-25T17:48:10"},{"id":"01963ddb-e3df-7143-a4f0-f00a58d5c05e","parentId":null,"rootId":null,"fromId":1493,"content":"我先回答个问题，亲身经历，我一个计算机专业和一个山大的英语硕士进车间生产，你觉得对我们工作有任何意义吗，前面几楼","createdAt":"2022-08-25T17:59:44"},{"id":"01963ddb-e428-730f-9eac-0d77f49dc2c3","parentId":null,"rootId":null,"fromId":1493,"content":"而且最初招聘承诺，计算机专业去IT组负责信息流程化以及相关运维，山大英语硕士是承诺去负责进出口贸易那边，最后呢，呵呵，天天就会说，有国有厂才有我们幸福的家，想想都恶心，一个私企天天觉得自己跟国企一样，搞笑呢搁这","createdAt":"2022-08-25T18:09:28"},{"id":"01963ddb-e46c-72a7-8fc3-d7fb9f80bbc8","parentId":null,"rootId":null,"fromId":1493,"content":"4楼怎么不敢对线了","createdAt":"2022-09-06T09:51:44"},{"id":"01963ddb-e4b2-7031-8737-deab942a4f74","parentId":null,"rootId":null,"fromId":1646,"content":"计算机专业你去应聘一个制药企业为什么不能下车间呢？制药业本身就是以生产为核心的，机关统称为后勤单位，说白了就是为了保生产的，再者你作为信息技术人员肯定需要接受公司的信息系统吧？需要开发或者运维吧？假如你做开发，你不了解公司业务，不懂流程，你做个锤子的开发？就会增删改查搞技术？一辈子也就这样了。","createdAt":"2022-09-16T19:38:29"},{"id":"01963ddb-e4fc-73e9-bf85-400ecd59f279","parentId":null,"rootId":null,"fromId":1493,"content":"开他马的研发，了解麻痹的流程，系统都买的浪潮的，你隔着搞笑呢，哪个开发技术好来药企，搞笑呢","createdAt":"2022-09-23T09:09:23"},{"id":"01963ddb-e547-73a7-9455-20b6a18a6d67","parentId":null,"rootId":null,"fromId":1493,"content":"我想问这个8楼，清洗药斗和信息系统有个jb关系啊，我操你妈的，这么喜欢当齐鲁的狗，请问给你发年终奖吗，你妈还好吗，坟头草多高了","createdAt":"2022-09-23T09:12:17"},{"id":"01963ddb-e593-7083-8b5a-a6fccd4b33e5","parentId":null,"rootId":null,"fromId":1843,"content":"回复9楼，系统不是全买的浪潮，部分是自研的，也有部分是借助三方平台维护开发的。比如业务流程，表单等等。另外开发技术好坏和去哪入职，入职什么类型的企业没什么直接关系，你愿意去IT公司就去IT，愿意入职实业公司就入职实业，基本都有信息化部门，看你选择了。","createdAt":"2022-09-28T09:49:43"},{"id":"01963ddb-e5dd-72be-9a55-ee6fdf397445","parentId":null,"rootId":null,"fromId":1843,"content":"回复10楼，就冲您这素质，上来就问候国骂，各位看官估计也能看出点端倪。你还是继续适合清洗药斗，不要来信息化部门了。","createdAt":"2022-09-28T09:52:12"},{"id":"01963ddb-e625-7058-96c3-6a528b147c1a","parentId":null,"rootId":null,"fromId":1493,"content":"麻烦看看你们车间的同事在干嘛吧，真搞笑，另外，早考编上岸了，傻逼才呆这","createdAt":"2022-10-08T08:43:16"},{"id":"01963ddb-e66b-7371-b0ff-6dbdd70c7a69","parentId":null,"rootId":null,"fromId":476,"content":"这一看这8楼就是信息部那个性孙的sb","createdAt":"2022-10-18T17:38:09"},{"id":"01963ddb-e6ba-7328-8fde-6ed77001a650","parentId":null,"rootId":null,"fromId":1493,"content":"还是有明事理的曾经的同事，只能这么说，公道自在人心","createdAt":"2022-10-23T15:29:21"},{"id":"01963ddb-e6fe-72b4-908d-b8ab095ed06e","parentId":null,"rootId":null,"fromId":2231,"content":"麻烦前辈们进群帮我们萌新解答一下问题，不胜感激！605587900","createdAt":"2022-11-24T14:38:48"},{"id":"01963ddb-e748-7317-a73e-214b4fa80fbf","parentId":null,"rootId":null,"fromId":2541,"content":"21年有幸面试过，初试通过，接待的小姑娘及人事经理都还不错，沟通很顺利，约第二天下午线上复试，好家伙，全程不开摄像头，也不知道是哪位大爷，问的全是针对未婚女性的问题（本人20年毕业女生）我回答完问题对方沉默，还是别人提醒面试结束，总共不到5分钟，仅仅几分钟感受到满满的恶意！！！","createdAt":"2023-02-14T10:11:19"},{"id":"01963ddb-e542-7080-8921-8f3a65fd49ff","parentId":null,"rootId":null,"fromId":3219,"content":"哈哈哈哈哈哈","createdAt":"2023-07-12T15:24:41"},{"id":"01963ddb-e78d-7307-890a-1d27beabc851","parentId":null,"rootId":null,"fromId":5867,"content":"五险一金实缴吗？比例多少？","createdAt":"2024-05-29T16:42:46"},{"id":"01963ddb-e58f-71d5-897d-09bfc0018e03","parentId":null,"rootId":null,"fromId":7746,"content":"素质堪忧不可信","createdAt":"2024-06-03T15:18:41"},{"id":"01963ddb-e81a-7009-a24b-50f1ebdae9a7","parentId":null,"rootId":null,"fromId":1493,"content":"卧槽烂你麻麻的b","createdAt":"2024-07-23T16:38:14"},{"id":"01963ddb-e7d1-7339-b98e-a541fb64e252","parentId":null,"rootId":null,"fromId":7746,"content