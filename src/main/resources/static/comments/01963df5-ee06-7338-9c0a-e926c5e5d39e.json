[{"id":"01963df5-eeac-7031-85de-37633d0c63e0","parentId":null,"rootId":null,"fromId":113,"content":"不建议买","createdAt":"2024-12-31T09:24:57"},{"id":"01963df5-eef0-7281-858b-beda04b24c55","parentId":null,"rootId":null,"fromId":2572,"content":"保险和社保都是骗人的","createdAt":"2024-12-31T09:25:15"},{"id":"01963df5-ef3a-7006-a13a-f4ad6c8c7307","parentId":null,"rootId":null,"fromId":875,"content":"欺负我数学不好是吧，医保报销完，自费花2万的话，起码也得是10万以上的大手术了，花个几万块钱，根本用不上它","createdAt":"2024-12-31T10:00:35"},{"id":"01963df5-ef7e-71d2-9a07-800a98acba6d","parentId":null,"rootId":null,"fromId":1372,"content":"我提供给你一个点。支付宝多次推消息给我参与齐鲁保。而记住一句话，只要是号召的就是有坑让你填的，只要是禁止的，就是有利益不想分给你的。","createdAt":"2024-12-31T10:21:12"},{"id":"01963df5-ef35-7203-827b-8f4b16b1a282","parentId":null,"rootId":null,"fromId":875,"content":"医保还是有用的","createdAt":"2024-12-31T12:20:30"},{"id":"01963df5-f009-7192-a303-76935565061b","parentId":null,"rootId":null,"fromId":1401,"content":"想想从小到大有多少好事主动找你的","createdAt":"2025-01-02T08:38:36"},{"id":"01963df5-f04d-731d-b3c7-b848718a6e8d","parentId":null,"rootId":null,"fromId":21585,"content":"补充一句吧，前面我母亲脑出血住院，医保报销比例大概是50%左右，剩下的就是自费部分，别管报销的起付线是多少，还是各种自费药不给报等等，最后怎么着也能报销一部分，反正齐鲁保百十块钱，我是一直买着。年轻人的话，百万医疗就可以了，但老人上了年纪，百万医疗是买不上的。只能退而求其次","createdAt":"2025-01-02T15:53:42"},{"id":"01963df5-f092-70d2-8807-69e358e5cc16","parentId":null,"rootId":null,"fromId":6091,"content":"老年人确实得买","createdAt":"2025-01-02T16:04:28"}]