[{"id":"01963ddd-0d6c-7296-b89e-d55fa18c5739","parentId":null,"rootId":null,"fromId":1039,"content":"华天或者华云三维看看有没有岗位，公司里有这个职位，但是不知道还需要招人么，不过降薪差不多，济南开不了这么高，大概降20%-40%之间吧","createdAt":"2022-10-18T17:04:36"},{"id":"01963ddd-0db5-72ac-b157-501770831eb4","parentId":null,"rootId":null,"fromId":1955,"content":"劝你，挂着985的研究生是吧，还有什么奖学金\n离开济南去北上广深啥的\n是多想不开，在济南憋屈自己","createdAt":"2022-10-18T17:11:57"},{"id":"01963ddd-0dfb-7062-b109-81badbcab381","parentId":null,"rootId":null,"fromId":1925,"content":"建议大厂干到三十多再回来，非要现在来济南 就公司而言，华为 浪潮 还有听说中泰证券也行，岗位不太了解","createdAt":"2022-10-18T17:16:22"},{"id":"01963ddd-0e40-7088-a3db-16b55ef03ab9","parentId":null,"rootId":null,"fromId":1780,"content":"为了个女朋友 回济南 我真是服了 女朋友不能跟你去一线城市？  要不换个女朋友","createdAt":"2022-10-18T17:17:02"},{"id":"01963ddd-0e86-72cc-9c49-25ff5fd6d7b9","parentId":null,"rootId":null,"fromId":1656,"content":"有一说一，大伙替他惋惜是真的，倒也不必如此激进","createdAt":"2022-10-18T17:32:27"},{"id":"01963ddd-0eca-7294-b279-4bd25f4fea2e","parentId":null,"rootId":null,"fromId":1995,"content":"之前秋招拿到了智洋的17×14?，话说济南算法那么低吗","createdAt":"2022-10-18T17:41:32"},{"id":"01963ddd-0f15-71ca-a107-46ba7840eef9","parentId":null,"rootId":null,"fromId":880,"content":"抓紧走吧，一线城市也有一线技术，为了女人你会后悔的","createdAt":"2022-10-18T20:29:39"},{"id":"01963ddd-0f9f-7149-914d-cd0ccf605db2","parentId":null,"rootId":null,"fromId":533,"content":"确实不建议","createdAt":"2022-10-19T08:37:42"},{"id":"01963ddd-0fe4-737f-97d0-65ae8cd81bca","parentId":null,"rootId":null,"fromId":1261,"content":"智洋挺好的","createdAt":"2022-10-19T11:41:21"},{"id":"01963ddd-1038-704f-bf43-1aeb3e917e34","parentId":null,"rootId":null,"fromId":1486,"content":"济南没有土壤，在济南你啥也学不到，你的技术能力会止步不前，让你越来越不值钱，建议去一线。否则自己越来越不值钱，也挣不到钱，血亏！","createdAt":"2022-10-19T20:15:21"},{"id":"01963ddd-1088-7193-9922-30b79e56c6b6","parentId":null,"rootId":null,"fromId":1656,"content":"看看 积成电子","createdAt":"2022-10-20T10:52:17"},{"id":"01963ddd-10ce-701b-86b8-b0da7bad417d","parentId":null,"rootId":null,"fromId":557,"content":"你这工资完全可以在杭州买房。何必回来呢。","createdAt":"2022-10-20T11:31:23"},{"id":"01963ddd-1115-73bf-88be-9872516e3c6b","parentId":null,"rootId":null,"fromId":1703,"content":"不要回来","createdAt":"2022-10-20T11:35:41"},{"id":"01963ddd-1157-7380-829d-974134f77e02","parentId":null,"rootId":null,"fromId":1924,"content":"注定被女朋友牵着走","createdAt":"2022-10-20T23:13:15"},{"id":"01963ddd-119a-71a0-ab55-b1e62b46c854","parentId":null,"rootId":null,"fromId":2034,"content":"想清楚自己到底想要什么，别被大家的言论带偏，济南的工资水平确实不高，但是可以想想以后定居的事情，毕竟生活是你们自己的","createdAt":"2022-10-21T11:15:16"},{"id":"01963ddd-11e1-70cc-a2e1-a3ae9bb3662f","parentId":null,"rootId":null,"fromId":1039,"content":"楼主觉得济南工资低的，最好还综合考虑，北上广深工资高很正常，但是消费水平也高，租房一个月四五千，济南一千左右住大主卧错错有余，一室一厅一卫也不过一千五","createdAt":"2022-10-24T17:36:16"},{"id":"01963ddd-1227-72a2-a06b-41ce5d1618fd","parentId":null,"rootId":null,"fromId":1524,"content":"可以看看空天院济南所, 不过价钱应该上不来, CV 算法岗的话印象中 潍柴 还是 重汽 招过无人驾驶相关","createdAt":"2022-10-24T18:02:10"},{"id":"01963ddd-1279-73dc-886d-a1e9423a8679","parentId":null,"rootId":null,"fromId":801,"content":"17楼那个,济南一千住大主卧那得是合租,而且也看地段的,我高新软件园这边三公里内的一居室都两千了,二居三居也两千多,只有合租的那种才一千左右","createdAt":"2022-11-03T13:51:38"},{"id":"01963ddd-12d7-7288-a8e1-6442f86bb676","parentId":null,"rootId":null,"fromId":2462,"content":"留个信息","createdAt":"2023-02-03T16:05:05"},{"id":"01963ddd-0daf-73c5-b9c7-23bc85b1554d","parentId":null,"rootId":null,"fromId":6197,"content":"请问你在华云工作吗，想了解一下这公司","createdAt":"2023-11-29T10:29:00"},{"id":"01963ddd-0f10-71f4-b880-32bd5e0b0cd6","parentId":null,"rootId":null,"fromId":5952,"content":"17 14还嫌少那你确实没必要回来了","createdAt":"2024-03-19T08:50:24"}]