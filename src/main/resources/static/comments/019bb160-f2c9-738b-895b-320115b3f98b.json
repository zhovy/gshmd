[{"id":"019bb168-1fca-7278-95a8-00e19ce40cdc","parentId":null,"rootId":null,"fromId":24615,"content":"你的工资远超很多人，但你是不是老济南人，老济南人好几套房，你的收入虽高如果给房贷了哪有钱消费，人家不仅没有房贷还每个月有租金，随便攒攒就可以买辆bba，你可能还在还车贷房贷，担心车子房屋贬值","createdAt":"2026-01-12T16:52:29"},{"id":"019bb168-4397-72c4-a174-49d8823f2466","parentId":null,"rootId":null,"fromId":793,"content":"我也感觉在邻居直接我是最低的","createdAt":"2026-01-12T16:52:38"},{"id":"019bb195-510b-73b2-af5b-2026f1d0c8bc","parentId":null,"rootId":null,"fromId":22024,"content":"你可能买的房子或者学校对于你的收入来说偏高","createdAt":"2026-01-12T17:41:51"},{"id":"019bb22b-ce36-7060-bbf7-1140dfa01135","parentId":null,"rootId":null,"fromId":2783,"content":"15K在济南也就是垫底的水平，你看看外面那些豪车，CBD的房子，这点工资远远不够啊","createdAt":"2026-01-12T20:26:13"},{"id":"019bb4a8-0326-7333-ade8-3c0e61ec07b5","parentId":null,"rootId":null,"fromId":4140,"content":"因为你看的不是人家的收入，是人家家庭的收入，人家父母就是济南本地，拆迁拿个四五百万，加上人家一个月一万多点，开个50w的车住个300w的房一点压力没有，反而你就你自己1.5w工资，贷了100w买个150w的房子每个月月供还个几千，家里支出几千，基本上没剩多少钱，靠你的工资，这辈子也换不起人家现在住的房子，更扎心的，人家房子算半个豪宅，房价下跌的时候你房子也跌了一大半，人家反而可能不跌，还涨，你更翻不了身，所以，不要比，自己过好自己的就行，比也别跟人家比，跟你老家的同学比","createdAt":"2026-01-13T08:01:08"},{"id":"019bb4af-cf34-728f-9c2a-6b467db442b8","parentId":null,"rootId":null,"fromId":23279,"content":"这位老师说的是非常在理的，贴主以为打王者呢还超越了百分之多少","createdAt":"2026-01-13T08:09:39"},{"id":"019bb4e6-fc5a-7228-b0b7-aa5bb69bfbdb","parentId":null,"rootId":null,"fromId":5584,"content":"没被裁员吗","createdAt":"2026-01-13T09:09:55"},{"id":"019bb568-bb3a-7159-953e-56c6a64993d6","parentId":null,"rootId":null,"fromId":28081,"content":"不是，就很普通的房子，买的时候180w左右吧，现在行情价也跌到了140左右，在济南只能说中规中矩的房子吧","createdAt":"2026-01-13T11:31:38"},{"id":"019bb569-140f-723e-aba1-01b2767f74a7","parentId":null,"rootId":null,"fromId":28081,"content":"你这个回复和我发的有啥关系？","createdAt":"2026-01-13T11:32:01"},{"id":"019bb56a-8bb7-739b-a68c-99b8928cce96","parentId":null,"rootId":null,"fromId":28081,"content":"并不是，我知道的同学家长大部分都是老家农村的，从带娃的爷爷奶奶姥姥姥爷也能看得出来，都是普通的农村人，有城里人但不多，我们小区里济南人很少，感觉十分之一都没有","createdAt":"2026-01-13T11:33:37"},{"id":"019bb56b-666c-7159-bd7b-00433a5eea58","parentId":null,"rootId":null,"fromId":28081,"content":"现在越来越感觉15k并不高，也就算中游水平","createdAt":"2026-01-13T11:34:33"},{"id":"019bb56c-76cf-73f9-83ed-9312d587cf47","parentId":null,"rootId":null,"fromId":781,"content":"他的意思是，如果被裁员，连1万5都赚不到了","createdAt":"2026-01-13T11:35:43"},{"id":"019bb5ff-5799-7103-999b-7699ba6cd7c8","parentId":null,"rootId":null,"fromId":2783,"content":"15K现在烂大街了 这个薪资水平很一般。","createdAt":"2026-01-13T14:16:08"},{"id":"019bb639-6baa-73e2-8699-859fd288a336","parentId":null,"rootId":null,"fromId":24428,"content":"你也说了是商人，双公，销售，不是吃死工资的岗位，吃死工资的，15k不低了","createdAt":"2026-01-13T15:19:35"},{"id":"019bb64a-72cf-7357-b7d6-43ac6ebc4914","parentId":null,"rootId":null,"fromId":452,"content":"你感觉的对","createdAt":"2026-01-13T15:38:11"},{"id":"019bb67f-7f31-7152-b21f-b52bd8c4ec0b","parentId":null,"rootId":null,"fromId":22024,"content":"我买的80w的房子，工资 1.6w","createdAt":"2026-01-13T16:36:07"},{"id":"019bb68d-737e-727c-b0a1-b9e16ff43cd8","parentId":null,"rootId":null,"fromId":5471,"content":"因为人只看到比自己优秀的人","createdAt":"2026-01-13T16:51:22"},{"id":"019bc603-b385-7322-9f1c-678583a51a2c","parentId":null,"rootId":null,"fromId":481,"content":"现实中你属于不低，但是这是网上，所以垃圾","createdAt":"2026-01-16T16:54:49"},{"id":"019c1d4d-4fe5-73ac-a30c-2b57f7dc7901","parentId":null,"rootId":null,"fromId":21821,"content":"我8年工作经验12k","createdAt":"2026-02-02T15:42:11"},{"id":"019c20de-d3bd-7295-9452-a740ecebbc76","parentId":null,"rootId":null,"fromId":41,"content":"我就纳闷了我这boss直聘啥的推荐给我的都是什么8000的工作  纳闷了","createdAt":"2026-02-03T08:20:00"}]