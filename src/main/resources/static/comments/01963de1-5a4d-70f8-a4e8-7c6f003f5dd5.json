[{"id":"01963de1-5ab5-7166-9870-85524e5ef40c","parentId":null,"rootId":null,"fromId":333,"content":"啥学历啊","createdAt":"2023-04-15T14:10:48"},{"id":"01963de1-5b00-7351-91bc-470fdf04f9d7","parentId":null,"rootId":null,"fromId":3172,"content":"本科啊","createdAt":"2023-04-15T14:19:51"},{"id":"01963de1-5b45-716d-8996-5ef7f0d96f20","parentId":null,"rootId":null,"fromId":875,"content":"不要闭关学习，直接boss投简历，不要怕","createdAt":"2023-04-15T18:15:32"},{"id":"01963de1-5b92-7006-97c4-2a2419de1138","parentId":null,"rootId":null,"fromId":3209,"content":"可以考虑先找个实习，边学习边积累经验。","createdAt":"2023-04-17T09:09:50"},{"id":"01963de1-5bea-7241-bf16-9db5aaf5d1b6","parentId":null,"rootId":null,"fromId":333,"content":"本科之间亦有差距 国企开发岗肯定没这么好进","createdAt":"2023-04-17T09:43:04"},{"id":"01963de1-5c51-71a3-be94-e0bf9bd26562","parentId":null,"rootId":null,"fromId":576,"content":"没有经验可以找gitee作者问下有没有新手大礼包，然后把博客整理的漂亮些，内容质量稍微好点就行。项目经验的话，一般都是跟着网上老师做1-3个项目放简历上，比如：商城购物车，银行项目，学生管理系统等。论竞争优势，除了学历，就剩下技术这块了，因为项目是建立在技术基础上的。再一个就是自学的态度了，这点也是很重要，以后不学习是不可能的，这个行业就代表着以后也会持续不断学习，不达标就转行吧。","createdAt":"2023-04-17T13:34:07"},{"id":"01963de1-5c98-7087-9eee-4842d4370baf","parentId":null,"rootId":null,"fromId":3395,"content":"建议闭关，应届生的身份还是很重要的","createdAt":"2023-04-26T16:41:45"}]