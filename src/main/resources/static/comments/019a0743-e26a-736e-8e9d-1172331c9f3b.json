[{"id":"019a0772-5eb9-72d1-99da-1164e16e28bc","parentId":null,"rootId":null,"fromId":24618,"content":"目前整个人社中心，都在忙一个一体化项目，一直是大小周，平时是周124，到晚上8点。不管你忙还是闲，都得加班。五险基本都是济南最低标准，像养老，医疗。公积金目前是实际工资的7%","createdAt":"2025-10-21T23:45:27"},{"id":"019a0978-c04a-71dd-8f29-a474bc3bfcc8","parentId":null,"rootId":null,"fromId":2381,"content":"开发岗吗？  公司固定周一周四加班到8点，大小周，忙的时候再加码","createdAt":"2025-10-22T09:11:39"},{"id":"019a0982-2886-725a-9e83-f07b6a0a5359","parentId":null,"rootId":null,"fromId":22250,"content":"累死你，进去就整你","createdAt":"2025-10-22T09:21:56"},{"id":"019a0989-680a-70a2-867e-4101452c9718","parentId":null,"rootId":null,"fromId":22303,"content":"从来没有双休过，都是一直大小周吗？还是因为这个一体化项目才这样子的？","createdAt":"2025-10-22T09:29:51"},{"id":"019a0989-db83-70a7-a3d3-c86c89f34c4c","parentId":null,"rootId":null,"fromId":22303,"content":"对，开发岗，一直都是大小周吗？从来没双休过吗？","createdAt":"2025-10-22T09:30:20"},{"id":"019a098b-6d91-72b6-9b2f-e46479c648ed","parentId":null,"rootId":null,"fromId":2381,"content":"一直大小周","createdAt":"2025-10-22T09:32:03"},{"id":"019a0997-d0b8-7018-95bf-2964a9281c5d","parentId":null,"rootId":null,"fromId":2381,"content":"公司在章丘，加完班回家，要考虑通勤时长","createdAt":"2025-10-22T09:45:35"},{"id":"019a09bd-d033-717f-b7a4-347ed5511906","parentId":null,"rootId":null,"fromId":22303,"content":"怕了怕了，不去面了","createdAt":"2025-10-22T10:27:05"},{"id":"019a0a81-8481-706c-bdfd-cd4474546958","parentId":null,"rootId":null,"fromId":23866,"content":"政务那边不清楚。大小周（固定），社保中心124到8点，其他中心目前目前1、4到8点，五险最低标准，公积金全额7%.，提供三餐住宿班车（三餐住宿自己需要扣一部分钱。不多），后面转到高速的话，有没有变动就不清楚了","createdAt":"2025-10-22T14:00:51"},{"id":"019a0a9a-1980-7386-ad92-2e92469c70b5","parentId":null,"rootId":null,"fromId":2381,"content":"老哥，大概什么时候转高速能转完？","createdAt":"2025-10-22T14:27:42"},{"id":"019a0ab8-0452-7116-8019-63809a66b1f3","parentId":null,"rootId":null,"fromId":23866,"content":"没消息，不过应该是在推进，等公告吧","createdAt":"2025-10-22T15:00:23"},{"id":"019a0b9f-1381-72bc-b85c-29dde918d8b6","parentId":null,"rootId":null,"fromId":24618,"content":"好几年前连着双休过几次，持续了没几个月，后来一直都是大小周","createdAt":"2025-10-22T19:12:45"},{"id":"019a2dc3-b0ea-7074-872e-e7268986b3f6","parentId":null,"rootId":null,"fromId":3450,"content":"今天发公告了，转完了","createdAt":"2025-10-29T10:19:50"},{"id":"019a3cf0-d4ba-72f4-a20f-2b31779c8c06","parentId":null,"rootId":null,"fromId":2381,"content":"有没有可能取消大小周啊老哥","createdAt":"2025-11-01T09:03:27"},{"id":"019aab87-1b44-73f1-8d49-8b7dab26e77a","parentId":null,"rootId":null,"fromId":27107,"content":"老哥，开发出差多吗","createdAt":"2025-11-22T20:25:49"},{"id":"019ab4e7-e092-7293-aa4d-7488fc490c15","parentId":null,"rootId":null,"fromId":23866,"content":"出差看部门和项目吧，不好说，有时候赶上项目一次出去半年都有可能（基本两周能回来一次，差旅报销），有时候大半年都在部门待着，部分项目可能会需要短期驻场","createdAt":"2025-11-24T16:08:06"}]