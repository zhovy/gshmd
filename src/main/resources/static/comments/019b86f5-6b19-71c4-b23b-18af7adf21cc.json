[{"id":"019b87d7-7e6a-70ae-9da9-0b9bef6aefd3","parentId":null,"rootId":null,"fromId":3925,"content":"ai进行测试吗还是啥","createdAt":"2026-01-04T15:10:05"},{"id":"019b87dc-1c4e-7015-8097-aea27da715a4","parentId":null,"rootId":null,"fromId":26079,"content":"针对大模型开发的测试","createdAt":"2026-01-04T15:15:07"},{"id":"019b87dd-7e58-7003-a7c0-fcb0355be830","parentId":null,"rootId":null,"fromId":3925,"content":"是对于大模型 微调/训练的测试还是智能体的","createdAt":"2026-01-04T15:16:38"},{"id":"019b87e4-3ffa-709b-a5a2-ba5c60f088a9","parentId":null,"rootId":null,"fromId":26079,"content":"都有，都想问问","createdAt":"2026-01-04T15:24:01"},{"id":"019b87e7-ca4c-72ff-906d-35ef66112735","parentId":null,"rootId":null,"fromId":3925,"content":"模型微调的话方法论比较多，一般训练的时候会有训练集，然后让ai对训练后的模型进行回答然后把答案和模型的回复结果交给另一个ai进行打分，如果训练集跑不过就是欠拟合，如果是通过了可以让ai对于问题和答案生成测试集。我微调只是玩过一点点懂得不是很多。","createdAt":"2026-01-04T15:27:53"},{"id":"019b87e9-cdc5-73dd-a84c-42019bcafa12","parentId":null,"rootId":null,"fromId":3925,"content":"Agent的测试要麻烦一些。我自己总结的以下几点\n1.针对Agent工具调用的测试\n一方面是agent能否调用正确的工具，另一方面是agent调用工具时的参数是否传递的正确。这一块可以对agent的调用进行跟踪，然后也是要搞测试集的\n2.针对agent总结的测试\n对于问题以及回复的正确生成测试集然后打分啥的","createdAt":"2026-01-04T15:30:05"},{"id":"019b8801-5a7b-703c-8116-1063ba90169e","parentId":null,"rootId":null,"fromId":2056,"content":"ai本身测试还是ai做单元测试，对项目代码测试","createdAt":"2026-01-04T15:55:48"},{"id":"019b883b-9fa6-7060-a9ef-6c211bf7a604","parentId":null,"rootId":null,"fromId":26079,"content":"ai本身的测试，功能性能这块","createdAt":"2026-01-04T16:59:27"},{"id":"019b8b90-2ac4-7209-8a38-a3a969ee7b4d","parentId":null,"rootId":null,"fromId":2056,"content":"模型训练过程中一般就是loss和准确率，f1分数等。大模型的话有rouge 困惑度等指标。性能就是跟传统开发差不多，并发，响应时间t99，再就是每秒生成的token数","createdAt":"2026-01-05T08:30:39"}]