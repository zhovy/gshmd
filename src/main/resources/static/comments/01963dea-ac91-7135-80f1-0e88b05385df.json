[{"id":"01963dea-acf8-71a7-a390-66bb1d1c5e9c","parentId":null,"rootId":null,"fromId":1164,"content":"你有什么优势提涨薪？你有核心技术？你有广大人脉？你有丰富资源？公司离了你不行？你除了又老了一岁你还有什么变化？那么，你还要求涨薪吗？","createdAt":"2024-01-09T14:03:52"},{"id":"01963dea-ad6b-7194-9840-c679b019653b","parentId":null,"rootId":null,"fromId":3592,"content":"不敢苟同1楼，不惯着这帮丑资本家，提他娘的，要是不同意，干两年一分不涨的公司，也没必要待了。","createdAt":"2024-01-09T14:07:16"},{"id":"01963dea-adaf-72d2-8630-da605bb4cf5b","parentId":null,"rootId":null,"fromId":3801,"content":"提就是了，很多公司就是装傻，不管规定是一年一涨还是一年两涨，你不提涨薪的事，不会主动给你涨的，一般给领导说了多多少少都会涨一些，除非你非常的废，我这就有个高薪低能的，别说涨工资了，直接工资宁可N+1也都给辞退了。","createdAt":"2024-01-09T14:15:03"},{"id":"01963dea-ad3f-7143-ae4a-7a92e33768e1","parentId":null,"rootId":null,"fromId":3663,"content":"sb","createdAt":"2024-01-09T14:19:05"},{"id":"01963dea-ad44-736d-9253-e288f68fbb5f","parentId":null,"rootId":null,"fromId":2859,"content":"sd","createdAt":"2024-01-09T14:23:05"},{"id":"01963dea-ad49-71be-a67a-338d807956bf","parentId":null,"rootId":null,"fromId":2859,"content":"什么都有 还给你打工？cnm的 脑瘫","createdAt":"2024-01-09T14:23:35"},{"id":"01963dea-ad4d-70b0-862a-0d7d4149cfe6","parentId":null,"rootId":null,"fromId":6091,"content":"sb","createdAt":"2024-01-09T14:29:24"},{"id":"01963dea-adf6-7165-aafc-bf8c237e20cf","parentId":null,"rootId":null,"fromId":6404,"content":"先找好下家，然后提，不给涨薪辞职就是了，离了这个公司又不是活不下去","createdAt":"2024-01-09T14:36:08"},{"id":"01963dea-ad51-7096-a1f6-80893cf44736","parentId":null,"rootId":null,"fromId":1101,"content":"sb","createdAt":"2024-01-09T14:37:03"},{"id":"01963dea-ad56-70c6-93d2-8cefd4b13a1b","parentId":null,"rootId":null,"fromId":6091,"content":"sb","createdAt":"2024-01-09T14:39:26"},{"id":"01963dea-ad5a-70ec-802b-39c79e53c82b","parentId":null,"rootId":null,"fromId":1164,"content":"老少爷们看不出来开玩笑呢，要求涨薪提就是了，两年不涨他以为他是国企啊，给个三瓜俩枣的还没保障真让打工人做牛做马啊","createdAt":"2024-01-09T15:39:13"},{"id":"01963dea-ae3c-7164-90e5-e7360f63906a","parentId":null,"rootId":null,"fromId":875,"content":"提涨工资，不给涨马上休年假，敢扣钱，分分钟炒了老板","createdAt":"2024-01-09T21:55:30"},{"id":"01963dea-ad5f-70d2-aaad-5eefba477120","parentId":null,"rootId":null,"fromId":1581,"content":"sb","createdAt":"2024-01-10T17:09:25"},{"id":"01963dea-aec7-7065-a794-33db01e59b54","parentId":null,"rootId":null,"fromId":5859,"content":"市场不好只是对于一般人的，你这么优秀担心这个干什么！有能力还怕找不到好工作？！","createdAt":"2024-01-10T17:34:41"},{"id":"01963dea-ad63-73ca-92c2-5281942ffdcd","parentId":null,"rootId":null,"fromId":5471,"content":"sb","createdAt":"2024-01-11T09:46:59"},{"id":"01963dea-ad67-7181-b9e7-5fbd7f8276e9","parentId":null,"rootId":null,"fromId":1989,"content":"sb","createdAt":"2024-01-18T14:34:30"}]