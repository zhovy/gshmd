[{"id":"0198ca6a-b0ab-7231-9854-5541fc6936e0","parentId":null,"rootId":null,"fromId":1003,"content":"年底一起发不行吗？","createdAt":"2025-08-21T10:17:26"},{"id":"0198ca76-762a-73c4-baa2-42fcf6ee88fe","parentId":null,"rootId":null,"fromId":1372,"content":"没呸他一口然后扭头走人吗？","createdAt":"2025-08-21T10:30:17"},{"id":"0198ca83-0733-702c-b788-1d97f3736ec2","parentId":null,"rootId":null,"fromId":6898,"content":"开始压工资了之后就会越压越多","createdAt":"2025-08-21T10:44:01"},{"id":"0198ca86-4aff-70c6-9a27-893b8e4b170c","parentId":null,"rootId":null,"fromId":26048,"content":"也是这么跟我说的","createdAt":"2025-08-21T10:47:35"},{"id":"0198ca8b-cd63-7253-a684-28ec3f2113ae","parentId":null,"rootId":null,"fromId":41,"content":"直接骂他","createdAt":"2025-08-21T10:53:36"},{"id":"0198ca8c-3c1a-71d6-8838-11504dbc1e36","parentId":null,"rootId":null,"fromId":5480,"content":"他都不装了，你还装什么啊，直接喷","createdAt":"2025-08-21T10:54:04"},{"id":"0198ca92-0b0b-70c9-bc4a-e2838c69366b","parentId":null,"rootId":null,"fromId":460,"content":"当资本家尝到剥削带来的甜头 他就停不住了","createdAt":"2025-08-21T11:00:25"},{"id":"0198ca97-6d7f-72e8-a13c-1f5b84c03914","parentId":null,"rootId":null,"fromId":1421,"content":"一样，我说都发不出工资还招人，这不是浪费时间，然后他就叭叭的说公司新制度之类的，后面我一句话没回，他感觉也没啥意思不说了我就走了","createdAt":"2025-08-21T11:06:18"},{"id":"0198ca98-f5dc-7041-9daf-61869eb96049","parentId":null,"rootId":null,"fromId":1421,"content":"你年底在吃饭不行吗","createdAt":"2025-08-21T11:07:58"},{"id":"0198cabf-9e79-7161-801b-2c84bb9c4078","parentId":null,"rootId":null,"fromId":22719,"content":"我也问了这个公司，还没咋地，上来先说：压2个月工资是否能接受","createdAt":"2025-08-21T11:50:12"},{"id":"0198cc16-3360-72b6-b6e7-249ef26d7b7c","parentId":null,"rootId":null,"fromId":22250,"content":"直接问候他（她）家十八代","createdAt":"2025-08-21T18:04:23"},{"id":"0198cf3d-d7fe-722b-8df2-d57a70c8fe6e","parentId":null,"rootId":null,"fromId":22702,"content":"哈哈哈","createdAt":"2025-08-22T08:46:33"},{"id":"0198e042-1456-7264-823f-83c1157e05a3","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-08-25T16:04:43"},{"id":"0198eba4-994a-72db-aaf9-0cf200ee9524","parentId":null,"rootId":null,"fromId":26637,"content":"1","createdAt":"2025-08-27T21:08:09"}]