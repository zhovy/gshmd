[{"id":"01963def-7f9f-7059-a098-1aab33403dd8","parentId":null,"rootId":null,"fromId":875,"content":"东方通信，10倍大牛股","createdAt":"2024-05-22T23:12:51"},{"id":"01963def-7fe8-7138-9e47-7477ca5dc60e","parentId":null,"rootId":null,"fromId":5790,"content":"怎么在济南问杭州的","createdAt":"2024-05-23T10:51:05"},{"id":"01963def-8031-720d-8640-2ff0dd4b7153","parentId":null,"rootId":null,"fromId":3892,"content":"我记得在济南也有工作岗位，我面试过，做移动的项目，驻场开发","createdAt":"2024-05-23T11:08:50"},{"id":"01963def-803a-72a3-aa96-8a6e85431990","parentId":null,"rootId":null,"fromId":6470,"content":"公司超小，就不到十个人，领导还有点毛病，平时倒是不算忙，不过忙的时候要带电脑回去接着干，他现在只招外包吧。薪资待遇还可以，不过五险一金低","createdAt":"2024-05-24T10:24:45"},{"id":"01963def-8036-7168-a46b-ab5d65673389","parentId":null,"rootId":null,"fromId":49,"content":"在济南还有邹平的项目呢 说让去邹平开发，一直在那，这应该也是驻场开发吧","createdAt":"2024-06-14T10:54:13"},{"id":"01963def-807f-72d6-83e3-36f4fb115539","parentId":null,"rootId":null,"fromId":49,"content":"是每个都这样么？","createdAt":"2024-06-14T10:54:33"},{"id":"01963def-8083-723a-bb5a-cbd685ab6a06","parentId":null,"rootId":null,"fromId":6654,"content":"面试完了，谈到最后一步了，大概说说：压工资三年经验工资8500 ，五险一金最低，公积金双边各100 ，可能没有年终奖，和我说的是0~1个月，我还确认了一下，确实会有0的情况。公司在济南可能一共就10个人左右吧，在移动大楼办公，不加班应该是真的。国企的三方合同，4个月试用90% 工资，待遇和心理预期差别太大，没去。","createdAt":"2024-06-19T10:16:27"},{"id":"01963def-80c7-717a-acc0-aabde9ab670b","parentId":null,"rootId":null,"fromId":6470,"content":"平时不忙是不加班的，年底比较忙加班就厉害了，弹性工作制，晚上九点十点找你是很正常的。就给你开那么点工资是挺离谱的，他节假日偶尔也给补助，不过我是不喜欢的","createdAt":"2024-06-27T18:37:12"},{"id":"01963def-80cc-70b7-b7c8-45d7964d24c3","parentId":null,"rootId":null,"fromId":21429,"content":"驾校有推荐吗","createdAt":"2024-07-21T16:51:49"},{"id":"01963def-8111-736e-bc68-e2bd696859d8","parentId":null,"rootId":null,"fromId":22176,"content":"实习过，在移动那，济南这边算上实习生十来个人，往前三年没招人了，不忙","createdAt":"2025-01-21T10:11:46"}]