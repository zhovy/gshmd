[{"id":"0199937b-6494-738b-89e2-31229948493d","parentId":null,"rootId":null,"fromId":2381,"content":"本来这是一个互帮互助的网站，大家互通一些公司的求职信息，这不分性别也不分职级，有些人非要发一些乌烟瘴气的挑起男女对立，我就不明白了，挑唆这个对你有什么好处？大家都在这里浏览的是求职信息、公司信息，谁愿意看你这些乱七八糟的东西啊","createdAt":"2025-09-29T11:19:21"},{"id":"0199937c-6f84-71b7-888c-40c1277acdfd","parentId":null,"rootId":null,"fromId":22250,"content":"可以，站长会考虑的，回家等消息","createdAt":"2025-09-29T11:20:29"},{"id":"0199937f-3351-73d9-87f8-3949cb2eecbb","parentId":null,"rootId":null,"fromId":21818,"content":"躲都躲不过，总有人如影随形追过来搞这些","createdAt":"2025-09-29T11:23:31"},{"id":"019993a0-3a94-7234-a4be-246c8d7ab077","parentId":null,"rootId":null,"fromId":22250,"content":"“他们人多” 是不是无形间就搞起了对立？","createdAt":"2025-09-29T11:59:35"},{"id":"0199940b-c57d-7097-bb04-8128e3e5c3c8","parentId":null,"rootId":null,"fromId":27118,"content":"就像传播邪教的教徒一样，加入邪教的人会联合起来维护邪教，而不信的那些却是各有各的不信，矛盾的两个极端是两类非正常人，而正常人站在中间说句公道话的时候，会迎来两个极端的攻击，正常人恰是由于本身正常，从而不会有任何组织阵营，被攻击的时候就会孤立无援，因为正常人都是独立的","createdAt":"2025-09-29T13:57:03"},{"id":"0199942b-fc95-7056-878f-75e7c9cc139c","parentId":null,"rootId":null,"fromId":22250,"content":"比喻完全是偷换概念，把网络上的群体争论硬套成邪教，没有任何逻辑。更重要的是，你把自己贴上“正常人”的标签，把别人都归为“非正常人”，这才是真正的制造对立。所谓“正常人孤立无援”的说法，本身就是把别人先极端化，然后再把自己拔高。要是真想解决问题，先别把不同意见的人当成病人或者邪教徒。","createdAt":"2025-09-29T14:32:14"},{"id":"0199943f-be09-72a9-91fd-c6a9174639e9","parentId":null,"rootId":null,"fromId":27118,"content":"你说的都对，我跟你这样的人在这里讨论这玩意本身就是有病","createdAt":"2025-09-29T14:53:49"},{"id":"0199944c-5624-7346-ae84-d58eec8f10b9","parentId":null,"rootId":null,"fromId":22250,"content":"典型的 转移矛盾 + 情绪化表达，你说自己是“正常人”，结果一转头就靠骂人收场，逻辑果然很正","createdAt":"2025-09-29T15:07:34"},{"id":"0199944e-827f-728f-badf-ed46d0ee81ea","parentId":null,"rootId":null,"fromId":23971,"content":"不理他们就好了，越争论他们越高朝","createdAt":"2025-09-29T15:09:57"},{"id":"0199c7e4-e058-7059-bb96-3388e1a1b3ce","parentId":null,"rootId":null,"fromId":2854,"content":"理性的人总归是少数","createdAt":"2025-10-09T15:34:49"},{"id":"0199cc8d-3a7a-7238-b1cd-3722abba145e","parentId":null,"rootId":null,"fromId":2246,"content":"和找工作无关的都得删掉","createdAt":"2025-10-10T13:17:11"}]