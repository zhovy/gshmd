[{"id":"01963de7-fa56-7078-96d4-6355b4c6a471","parentId":null,"rootId":null,"fromId":5656,"content":"什么岗位","createdAt":"2023-09-13T17:47:29"},{"id":"01963de7-fa9b-73e8-a3c0-4e4fe047ab59","parentId":null,"rootId":null,"fromId":629,"content":"Java，貌似也是全栈","createdAt":"2023-09-13T20:48:35"},{"id":"01963de7-fa9f-72f8-80fb-f646c886f5be","parentId":null,"rootId":null,"fromId":5656,"content":"技术不难，1246强制自愿加班，工资不拖欠","createdAt":"2023-09-13T23:30:32"},{"id":"01963de7-faa4-7367-b3fc-5fbd8e7524b2","parentId":null,"rootId":null,"fromId":4209,"content":"剥削压榨技术，最低级的开发，没任何前途。","createdAt":"2023-09-13T23:40:56"},{"id":"01963de7-faa8-7278-9130-0f2538fb1afd","parentId":null,"rootId":null,"fromId":5655,"content":"优点：1、当月25号发工资。2、年假半个月。3、有加班餐报销。\n缺点：1、对于加班，有的部门每周指定那几天加班大小周，有的部门不说那几天加班，不过你加班少会被谈话说态度问题，而且还有加班强度排名。2、加班没加班费。3、技术，确实是比较老了。有的部门是新开发产品，有的部门是维护老项目，屎山代码懂吗！\n总的来说，工资按时发，每年涨薪一次。过节该有的福利都有，就是有大多数公司存在的问题，加班没有加班费，领导pua。比上不足比下有余。","createdAt":"2023-09-14T07:49:24"},{"id":"01963de7-fafc-703b-9db7-ff6a8451fe74","parentId":null,"rootId":null,"fromId":629,"content":"综合起来还是不建议哦，钱多吗","createdAt":"2023-09-14T09:11:22"},{"id":"01963de7-fb46-7157-8fd8-d56ee7f46c08","parentId":null,"rootId":null,"fromId":3002,"content":"1. 说是双休，进去之后发现是单休。\n2. 技术栈陈旧，在公司自研框架里面开发，工具人。\n3. 领导pua","createdAt":"2023-09-14T09:55:50"},{"id":"01963de7-fb8b-72a2-9589-a7ae992fa167","parentId":null,"rootId":null,"fromId":1401,"content":"在济南来说算是比较正规的公司，该有的节假日和福利都有。五险一金按济南最低比例交，招聘上工资写的挺高，实际是只有你在公司呆满一整年拿到所谓的年终奖才能到那个水平。面试说双休，偶尔加班，实际上每周最少加三四天。如果不加班，领导会找你谈话。公司技术栈Spring、SpringMVC、Hibernate、JSP，有自研框架，除了进框架组，其他组纯干业务，学不到任务技术，业务你出了公司没有任何用处。公司基本只招应届和实习生，代码质量堪忧，有问题全靠运维顶着，其他的你再看看其他人说的吧，基本都是对的。","createdAt":"2023-09-14T10:26:51"},{"id":"01963de7-fbd1-7165-bf5b-e5a6f0f230df","parentId":null,"rootId":null,"fromId":5655,"content":"其实年终奖就相当于加班费了","createdAt":"2023-09-14T10:31:39"},{"id":"01963de7-fbd5-70ab-93a6-55df1a5032be","parentId":null,"rootId":null,"fromId":2821,"content":"尼玛五险一金按济南最低比例交就是比较正规的了？","createdAt":"2023-09-14T10:35:24"},{"id":"01963de7-fbda-734d-9f30-2abf33b2d2b3","parentId":null,"rootId":null,"fromId":1401,"content":"济南什么牛鬼蛇神公司都有，你多去几个公司就知道了","createdAt":"2023-09-14T10:37:59"},{"id":"01963de7-fbde-7254-b7cd-d566b1f092cf","parentId":null,"rootId":null,"fromId":5661,"content":"兄弟在那干了多久走的，有没有好地方内推一下？不想入坑啊","createdAt":"2023-09-14T11:02:50"},{"id":"01963de7-fbe3-7034-83b6-61a6fada6497","parentId":null,"rootId":null,"fromId":1401,"content":"现在经济形式不好，不建议去人数太少的公司，福利差是一方面，再就是倒闭风险太大。如果水平还可以，可以试试济南的哪些上市公司，或者至少上百人的公司。","createdAt":"2023-09-14T11:17:45"},{"id":"01963de7-fbe8-71e5-8955-a17d0c6673c1","parentId":null,"rootId":null,"fromId":629,"content":"上百人的基本全是外包了，boss上来回就是那几个公司，全是外包，如何破局？充会员？\n","createdAt":"2023-09-14T11:24:38"},{"id":"01963de7-fbec-701e-b2f7-4e9dfec87639","parentId":null,"rootId":null,"fromId":5661,"content":"说到底打铁还得自身硬啊，听说浪潮5年的Java，能给开到18K，还给全额交五险一金，但是要求太高了，学历+项目经验+技术各种要求，硬投不好进，如果有内推会好一些。","createdAt":"2023-09-14T12:15:35"},{"id":"01963de7-fbf0-730c-ad38-fb16a45634e9","parentId":null,"rootId":null,"fromId":5663,"content":"兄弟，是外包吗？平时出差多吗？","createdAt":"2023-09-14T12:41:38"},{"id":"01963de7-fbf4-71da-8075-fb9945b6346e","parentId":null,"rootId":null,"fromId":1401,"content":"非外包，开发极个别时候会出差，钱少事多","createdAt":"2023-09-14T15:26:52"},{"id":"01963de7-fc3b-7056-a09e-fbb4bd34c913","parentId":null,"rootId":null,"fromId":5680,"content":"经历过几分工作，感觉到哪都是一个鸟样，每个公司都有混的好的，也有混不下去愤然离开的，所以很难去客观评价好与坏。","createdAt":"2023-09-15T10:16:11"},{"id":"01963de7-fc80-70bc-b9fa-6553f5bb7358","parentId":null,"rootId":null,"fromId":5656,"content":"这里是评价公司如何的，你如果有客观的想法可以直接说出来，你这么说让我很难判断你是什么性质","createdAt":"2023-09-15T11:01:26"},{"id":"01963de7-faf7-72e5-b4e5-f4cf523d722c","parentId":null,"rootId":null,"fromId":22641,"content":"在百度搜不到差评，果然还是可以哈~","createdAt":"2025-01-20T15:18:27"},{"id":"019ab3ca-e473-7189-aa39-4de5277f3ae9","parentId":null,"rootId":null,"fromId":4088,"content":"你好，请问，五险一金缴纳基数和比例是多少","createdAt":"2025-11-24T10:56:49"},{"id":"019ab3ca-f84b-725d-ba7a-5be24b09b952","parentId":null,"rootId":null,"fromId":4088,"content":"你好，请问，五险一金缴纳基数和比例是多少","createdAt":"2025-11-24T10:56:54"}]