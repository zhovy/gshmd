[{"id":"01963ded-8387-702e-b2e5-34dab75483b3","parentId":null,"rootId":null,"fromId":1372,"content":"与其为难自己，不如为难别人。","createdAt":"2024-04-09T13:35:04"},{"id":"01963ded-83cd-725a-b4ee-b6685e052f43","parentId":null,"rootId":null,"fromId":2082,"content":"所以你是技术还是产品还是市场？","createdAt":"2024-04-09T13:58:20"},{"id":"01963ded-8412-715f-bc3a-e80095f94f0f","parentId":null,"rootId":null,"fromId":576,"content":"小公司的联合创始人会区分这些吗？很可惜我不是，我区分了，我是产品兼技术。","createdAt":"2024-04-09T14:08:22"},{"id":"01963ded-8417-72e6-b53c-736062bed77f","parentId":null,"rootId":null,"fromId":1150,"content":"他是杰哥","createdAt":"2024-04-09T14:08:46"},{"id":"01963ded-8423-700f-97a6-d3421b19d5a6","parentId":null,"rootId":null,"fromId":5790,"content":"为什么要内耗自己？","createdAt":"2024-04-09T14:16:08"},{"id":"01963ded-8468-7285-a5be-2258fcde3604","parentId":null,"rootId":null,"fromId":933,"content":"杰哥老老实实干活吧，你还不是当领导的料，老实沉淀几年吧","createdAt":"2024-04-09T14:51:05"},{"id":"01963ded-84ae-713c-abf1-a5f0818d10cf","parentId":null,"rootId":null,"fromId":576,"content":"投了几个联合创始人的岗，看看有没有有意向的。其实下一个个人成长提升阶段是我需要去市场走动走动了，而不是天天写代码。toG的客户也是需要去市场积累经验才能拿捏他们的性格特点啊，虽然说里面有各种各样的坑，但并不是每一个官二代都能拿到项目的。而且有意思的是我咨询的营销专家他也不会喝酒，还能拿几十亿的大客户订单，其实我也不会喝酒，本来还以为不喝酒就没法跑市场呢，结果他帮我解答了这个问题。","createdAt":"2024-04-09T15:08:35"},{"id":"01963ded-84b2-7058-8cfe-b4a075159c02","parentId":null,"rootId":null,"fromId":6743,"content":"ren人生如此艰难，能怪别人就不要怪自己了。","createdAt":"2024-04-09T15:15:49"},{"id":"01963ded-841b-73cd-a9a1-8808c38a0ab4","parentId":null,"rootId":null,"fromId":2082,"content":"这还是杰哥啊，咋跑这伤感来了","createdAt":"2024-04-09T15:32:55"},{"id":"01963ded-84fc-708c-a24d-c4868a3085e8","parentId":null,"rootId":null,"fromId":875,"content":"你得学会摸鱼","createdAt":"2024-04-10T07:21:32"},{"id":"01963ded-8541-717a-8668-de79e218f8d3","parentId":null,"rootId":null,"fromId":3663,"content":"感觉我们公司的这个产品就像死妈了一样 纯畜生 真把自己当回事了","createdAt":"2024-04-10T09:53:20"},{"id":"01963ded-841f-70ec-9427-8b494c78d61e","parentId":null,"rootId":null,"fromId":576,"content":"我只想知道老板欠我一个月工资以及5000块钱的报销没给我是什么个意思？我还得受他的气，不明白他的自信从哪里来的，公司前前后后走了11个人了，一共就26个人的公司，从我来了之后，我看过的就已经走了11个人了。   所以老板还不想放权吗？当个董事长不好吗，非得当CEO，当了CEO还得管着市场团队，我怎么跟市场打交道啊，我是直接跟老板聊市场的事情呗，老板跟我年龄差这么多，见识面程度又不一样沟通是不是有代沟啊，而且老板还不反思一下为什么没有利润入账的吗，太难了。","createdAt":"2024-04-10T10:10:42"},{"id":"01963ded-8586-72d6-b1e2-b751dda2d941","parentId":null,"rootId":null,"fromId":576,"content":"讲讲故事内容，我看看是不是说的我","createdAt":"2024-04-10T10:12:00"},{"id":"01963ded-858b-7319-8720-c889bcae0afc","parentId":null,"rootId":null,"fromId":875,"content":"领导不懂业务，瞎提需求，该怼还是要怼的，sb","createdAt":"2024-04-14T22:53:16"}]