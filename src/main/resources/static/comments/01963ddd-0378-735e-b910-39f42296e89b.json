[{"id":"01963ddd-03f3-73af-ac4f-5832cbffdf12","parentId":null,"rootId":null,"fromId":1656,"content":"面试几轮？有笔试吗？难不","createdAt":"2022-10-18T10:27:25"},{"id":"01963ddd-0437-70cb-b227-5dead58d79d8","parentId":null,"rootId":null,"fromId":782,"content":"好像是实习期不交五险一金的吧，而且是最低标准？","createdAt":"2022-10-18T10:46:36"},{"id":"01963ddd-047e-71bd-bd12-75151ebb0066","parentId":null,"rootId":null,"fromId":113,"content":"挺好的公司，该有的都有，工资正常发。","createdAt":"2022-10-18T13:50:38"},{"id":"01963ddd-04ca-7355-b9aa-a1e61eba251b","parentId":null,"rootId":null,"fromId":1989,"content":"我想换工作嘞，这个怎么样","createdAt":"2022-10-18T16:09:48"},{"id":"01963ddd-0511-72c7-b1fa-153ad0e041b9","parentId":null,"rootId":null,"fromId":481,"content":"三轮面试，小组长，部门总监，副总。他们有一套固定的面试流程，基本是固定的问题。薪资比市场行情低点，其他不清楚，没去","createdAt":"2022-11-01T09:30:28"},{"id":"01963ddd-0555-70b2-a7b1-0b307ee0aaf9","parentId":null,"rootId":null,"fromId":154,"content":"收到了这个公司的面试邀请，能请问下面试问题大概是哪些吗","createdAt":"2022-11-24T11:49:34"},{"id":"01963ddd-059a-7380-9f48-e57727e615fc","parentId":null,"rootId":null,"fromId":236,"content":"傻逼公司 工资每个月都晚 拖发工资还不给大家说原因 狗逼公司 都别来","createdAt":"2023-02-17T17:40:20"},{"id":"01963ddd-05e0-73b7-965d-d6da4f10aa27","parentId":null,"rootId":null,"fromId":2578,"content":"要求天天写日志 不写扣钱 入职的时候会让你签知道不写日志扣钱的违法协议  美名其曰是公司天条级的企业文化 还有专人查谁没写 乱调作息 缩短休息时间 公司级别会议都在周末开  没有加班费 不能调休 但是你完不成任务就扣你绩效 直接发通知延期发工资 最近更是乱成一锅粥 到时间不给转正 本人目前已脱坑","createdAt":"2023-02-18T13:08:56"},{"id":"01963ddd-0626-7005-8806-14a2e5949d47","parentId":null,"rootId":null,"fromId":236,"content":"接楼上、发通知延期发工资但是到了延期的时间还是没有发、公司说话就和放屁一样","createdAt":"2023-02-22T17:40:17"},{"id":"01963ddd-066c-7351-a9dd-adc1dc90f7d6","parentId":null,"rootId":null,"fromId":2774,"content":"顶联已经不是原来的顶联了，逐渐开始变态，由于某个大部门做出来的东西没有收益，某个大部门开始了全新的考核体系，不，应该说是整个公司开始了全新的考核体系，公司的现金流应该也是出了一点问题，导致发工资开始拖时间，十三薪纯纯画饼，公司年会选在周末开，还他妈不管饭，申请团建还不申批，领导还乐呵呵的去吃大餐。","createdAt":"2023-03-03T23:02:57"},{"id":"01963ddd-06b5-70ce-a370-b3102a90cdfd","parentId":null,"rootId":null,"fromId":2848,"content":"基于10L说的，补充一下，之所以垃圾，就是因为M们沉浸在自己的思想里不能自拔，能力不咋的，逼事还很多，不去接触市场，天天闷着头自己搞，天天想着给别人使绊子，能长久的了才怪","createdAt":"2023-03-08T10:04:36"},{"id":"01963ddd-06fa-726f-af08-b45e16bce880","parentId":null,"rootId":null,"fromId":113,"content":"我是三楼，我收回我说的话","createdAt":"2023-03-08T10:42:07"},{"id":"01963ddd-073e-70ba-9bee-0d4a58fd1f47","parentId":null,"rootId":null,"fromId":2578,"content":"最近开始裁员了，电视剧里面的下三滥招数居然在现实中上演了，也不知道是觉得员工傻还是自身不懂法，补偿不给够还威胁员工说耗着工资也发到六月底，HR忽悠员工“不用来上班了”让你旷工，千方百计的让你自己离职，说实话大环境如此谁都有心理准备，好聚好散不行吗？非得恶心人，DL到今天这个境况，完全是某位副总的和其嫡系的无能，项目拉不来，产品逻辑乱，除了甩锅挣功小心眼就没别的事了","createdAt":"2023-05-31T09:38:11"},{"id":"01963ddd-0781-73bb-9c92-a123f8bd711a","parentId":null,"rootId":null,"fromId":1755,"content":"现在已经开始裁员了吗，当时拿了offer没去，还有点后悔","createdAt":"2023-07-05T13:39:25"},{"id":"01963ddd-078b-725a-ba52-906af2ea08d7","parentId":null,"rootId":null,"fromId":966,"content":"开始了，毫无征兆的双休改成单休，每天工作时间不含午休8个小时，每周工作6天，周天以部门为单位值班","createdAt":"2023-07-17T11:43:57"},{"id":"01963ddd-07d1-71e5-b8c5-6c8f937a7103","parentId":null,"rootId":null,"fromId":4094,"content":"一堆人在这儿搞管理  就是搞员工心态，内部极其混乱，已经是第二次改作息时间了，想方设法恶心人","createdAt":"2023-07-17T14:59:21"},{"id":"01963ddd-0786-736f-ae7b-30126c0b6cc1","parentId":null,"rootId":null,"fromId":113,"content":"DL的HR就是纯nt，特别是那个总监，sb一个","createdAt":"2023-07-28T15:39:18"}]