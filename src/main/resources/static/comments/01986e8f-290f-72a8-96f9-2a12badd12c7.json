[{"id":"01986ef6-2fbd-705e-bac2-31303b5e82e7","parentId":null,"rootId":null,"fromId":21294,"content":"社保公积金可能缴的比较少。","createdAt":"2025-08-03T16:04:44"},{"id":"01986f13-1f56-7001-80ad-ef19a78c56cb","parentId":null,"rootId":null,"fromId":25460,"content":"请问工资及时吗？加班严重吗","createdAt":"2025-08-03T16:36:20"},{"id":"019b3013-a9a5-72af-a874-d7a0290c4376","parentId":null,"rootId":null,"fromId":24043,"content":"大小周，入职前会多次问你能不能出差，既然问了肯定是经常出差，出差是没有任何补助的。","createdAt":"2025-12-18T14:09:13"},{"id":"019b3035-41a4-700b-b675-71ba8336e4a4","parentId":null,"rootId":null,"fromId":24043,"content":"言而无信，谈了好了工资也会反悔，拖着你，就说领导还没决定，然后最后给你一句不招人了，工资压得很低。","createdAt":"2025-12-18T14:45:55"},{"id":"019b3bcf-cefb-7281-a3d0-fd1b0e3ab439","parentId":null,"rootId":null,"fromId":25460,"content":"pua严重","createdAt":"2025-12-20T20:50:33"}]