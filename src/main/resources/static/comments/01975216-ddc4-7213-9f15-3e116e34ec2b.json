[{"id":"01975224-22cb-72c8-a161-c651a20d2b4a","parentId":null,"rootId":null,"fromId":21267,"content":"方案一：拿着证据，去高新管委会仲裁等结果\n方案二：搬公司电脑或打印机做抵扣\n方案三：去公司门口拉横幅声讨\n方案四：让车库里老板的劳斯莱斯大修一次\n方案五：给boss邮寄一包刀片，也许可以刮胡子用","createdAt":"2025-06-09T08:43:09"},{"id":"01975237-50dd-7029-8dbe-0a2bbcf409ed","parentId":null,"rootId":null,"fromId":178,"content":"除了方案一，剩下的都可以进去，哈哈","createdAt":"2025-06-09T09:04:06"},{"id":"0197527d-4828-713e-bb3a-f2d8d88595b6","parentId":null,"rootId":null,"fromId":2846,"content":"哈哈哈哈哈哈","createdAt":"2025-06-09T10:20:31"},{"id":"0197571a-2703-72a4-bb8d-9375cc4f98d9","parentId":null,"rootId":null,"fromId":6267,"content":"1","createdAt":"2025-06-10T07:50:21"},{"id":"0197579a-3c74-7132-a31f-aace3a228449","parentId":null,"rootId":null,"fromId":2082,"content":"邮寄刀片也进去？？","createdAt":"2025-06-10T10:10:15"},{"id":"01975cf1-e1d3-72b0-94c5-b64afe2941b5","parentId":null,"rootId":null,"fromId":24091,"content":"仲裁不管报销只管薪资","createdAt":"2025-06-11T11:04:05"},{"id":"01975d19-1fd0-7347-b752-e08bf07c6f41","parentId":null,"rootId":null,"fromId":21818,"content":"方案3不会，只是人数多了需要打110报备。寄刀片有点不太行，但是单人去管事的那个领导的家里堵他，只说工作的事情也没事，大部分管事的出了公司也是平头老百姓，就算有帽子管也是和稀泥。帽子来了你一把鼻涕一把泪，说你自己劳动人民被资本压迫，说不定还能帮你要一下","createdAt":"2025-06-11T11:46:57"},{"id":"01976748-34b7-70c4-a389-eb638f647048","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-06-13T11:14:34"},{"id":"01976d22-6e06-7352-a07c-d6d60b409e15","parentId":null,"rootId":null,"fromId":6267,"content":"丁","createdAt":"2025-06-14T14:31:02"},{"id":"01978715-20eb-714e-87a3-1aed64621de0","parentId":null,"rootId":null,"fromId":25238,"content":"0","createdAt":"2025-06-19T15:26:38"}]