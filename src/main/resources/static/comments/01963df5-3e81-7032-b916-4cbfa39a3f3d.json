[{"id":"01963df5-3ee4-71b7-a9a6-89f6b530afad","parentId":null,"rootId":null,"fromId":3263,"content":"哪家公司","createdAt":"2024-12-06T10:39:09"},{"id":"01963df5-3f28-7208-aac2-3e48cb28273e","parentId":null,"rootId":null,"fromId":793,"content":"哪家公司？","createdAt":"2024-12-06T10:39:59"},{"id":"01963df5-3f6b-722e-befd-fd37411ac34f","parentId":null,"rootId":null,"fromId":6344,"content":"浪潮吧，目前正在谈话","createdAt":"2024-12-06T10:51:59"},{"id":"01963df5-3fbe-7036-a441-1a5ee3224f18","parentId":null,"rootId":null,"fromId":6276,"content":"哪个公司来？","createdAt":"2024-12-06T11:18:12"},{"id":"01963df5-4003-701e-85b0-c3bead8addae","parentId":null,"rootId":null,"fromId":875,"content":"年底不是该发年终奖了吗","createdAt":"2024-12-06T11:22:14"},{"id":"01963df5-404b-71b9-981d-b61fd0d30570","parentId":null,"rootId":null,"fromId":506,"content":"裁员就给补偿 直接裁，现在都想0成本裁员","createdAt":"2024-12-06T11:26:12"},{"id":"01963df5-3fb0-732d-96b0-9ee5e590d11b","parentId":null,"rootId":null,"fromId":6124,"content":"真假","createdAt":"2024-12-06T14:22:42"},{"id":"01963df5-3fb5-7086-aa05-f1bd568ed9dd","parentId":null,"rootId":null,"fromId":6124,"content":"哪个子公司？","createdAt":"2024-12-06T14:22:54"},{"id":"01963df5-4090-7353-ad02-796c7e9bb206","parentId":null,"rootId":null,"fromId":22313,"content":"被裁后找工作找的麻木了，看来竞争又大了，痛苦的打工人","createdAt":"2024-12-06T15:12:00"},{"id":"01963df5-3fb9-70ae-9d3c-d983e33246a6","parentId":null,"rootId":null,"fromId":1553,"content":"哪家子公司?","createdAt":"2024-12-06T15:22:10"},{"id":"01963df5-40d8-714c-bf03-41c8e9b420ac","parentId":null,"rootId":null,"fromId":21811,"content":"到厕所了你拉裤子里了，哪个公司说啊","createdAt":"2024-12-06T15:45:30"},{"id":"01963df5-411c-7162-a135-157e66648054","parentId":null,"rootId":null,"fromId":21808,"content":"统一回复,我是山东高速的劳务派遣,我们这一层大概50多人,只有6个领导是正式工,其余全是劳务派遣,话谈完了,我没被裁,但是我看群里他们讨论的情况应该是裁了一半劳务派遣,也就是20多人","createdAt":"2024-12-06T17:04:48"},{"id":"01963df5-4160-7045-a3ea-9be4b7f19b57","parentId":null,"rootId":null,"fromId":228,"content":"不裁的也谈话吗?还是只找要被裁的谈话?","createdAt":"2024-12-06T17:06:47"},{"id":"01963df5-4164-7009-8caa-864a5f322353","parentId":null,"rootId":null,"fromId":21808,"content":"只找被裁的谈话","createdAt":"2024-12-06T17:11:25"},{"id":"01963df5-4169-7355-a0bc-8a8f406f9438","parentId":null,"rootId":null,"fromId":21808,"content":"这20多人里,产品,运营,运维,开发,测试都有,基本是每个项目组都裁了四五个人","createdAt":"2024-12-06T17:12:38"},{"id":"01963df5-416e-72dc-af06-1b1a73bebcda","parentId":null,"rootId":null,"fromId":22024,"content":"高速还没裁完，上个月信联刚裁了十几个外包","createdAt":"2024-12-06T17:17:19"},{"id":"01963df5-4172-7376-b788-7c845bfc117b","parentId":null,"rootId":null,"fromId":7078,"content":"兄弟哪个公司，信息集团吗","createdAt":"2024-12-06T17:45:51"},{"id":"01963df5-4180-706b-a4a0-827be07def85","parentId":null,"rootId":null,"fromId":875,"content":"再坚持一下，多年以后，你会感谢多年以前在一线城市的坚守，一线城市的教育，医疗，环境，交通，未来发展机会不是一般城市可以比拟的","createdAt":"2024-12-06T19:29:00"},{"id":"01963df5-4177-71e2-9013-7ca0e82f7cf2","parentId":null,"rootId":null,"fromId":880,"content":"劳务派遣的有啥好谈的，直接推给服务商不就得了","createdAt":"2024-12-07T15:00:51"},{"id":"01963df5-40d3-7362-9449-d04d253120d7","parentId":null,"rootId":null,"fromId":2890,"content":"被裁的本来就是不行的，让不行的出去找工作当然痛苦了，你看厉害的人现在怕被裁吗","createdAt":"2024-12-09T16:47:56"},{"id":"01963df5-41c3-73a9-836f-fcdaba348891","parentId":null,"rootId":null,"fromId":7000,"content":"某些公司5年、7年老员工都裁，其他人都是事不关己高高挂起，等到刀挥到自己头上，也只能跟前人一样被公司消耗","createdAt":"2024-12-09T21:59:12"},{"id":"01963df5-417b-70bb-ac4a-8ac228e5ed8b","parentId":null,"rootId":null,"fromId":3835,"content":"山东高速的哪个公司啊","createdAt":"2024-12-16T14:34:56"}]