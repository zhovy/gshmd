[{"id":"01963dd5-2095-721b-8865-c3c9d9493f27","parentId":null,"rootId":null,"fromId":697,"content":"这个可不光济南有，估计全国都有，以找工作的名义，把你骗去，然后给你面试一下，接着说你技术水平不行，然后让你参加他们的培训，说培训完之后推荐工作，很多年前刚找工作那会在北京遇到的真事！","createdAt":"2022-06-08T09:18:58"},{"id":"01963dd5-20d9-7051-b124-4938a0335626","parentId":null,"rootId":null,"fromId":1049,"content":"销售孙某可是孙某琪？","createdAt":"2022-07-20T14:44:15"},{"id":"01963dd5-211d-716b-8882-82718a8a3ded","parentId":null,"rootId":null,"fromId":414,"content":"我非常后悔当初在学校的时候单纯不懂，进了这个培训，学的都是一些基础，根本学不到啥比较有用的，销售是孙某琪，嘴比较能忽悠，我还有她的微信呢","createdAt":"2022-11-17T15:57:36"}]