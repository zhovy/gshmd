[{"id":"01963dd3-fa99-7083-b77e-d29972798fc6","parentId":null,"rootId":null,"fromId":222,"content":"幸好没去，天元拖欠公司很严重，1月份的工资3月份能发就不错了","createdAt":"2022-04-11T15:41:29"},{"id":"01963dd3-fadc-72b9-a827-84ea463f79a4","parentId":null,"rootId":null,"fromId":1373,"content":"看介绍感觉公司不小，去了发现就几个人，说什么总部在外地，这个不清楚，但济南这边就是个小作坊","createdAt":"2022-08-18T12:28:44"},{"id":"01963dd3-fb25-7035-9536-3d750b63dc17","parentId":null,"rootId":null,"fromId":2935,"content":"他们总部在东营，基本上的套路就是在济南招人，然后找个借口忽悠你去东营，去了之后给你安排一个宿舍，然后就成了在东营就业的人员了，一个宿舍十几个人，那味道啊。。。而且他们的主营业务是测绘，所以软件部的地位非常低","createdAt":"2023-04-08T13:13:51"},{"id":"01963dd3-fb7f-71ca-96be-e10400c714ca","parentId":null,"rootId":null,"fromId":2857,"content":"拖欠工资厉害，五六月的工资，一次发一两千，陆陆续续发了六七次，到10月才发完五六月的，很坑","createdAt":"2023-05-10T10:27:25"},{"id":"01963dd3-fc0a-71f3-93dd-989506780c86","parentId":null,"rootId":null,"fromId":21467,"content":"我去！是C语言大佬开盒大手子！拿拿我的?","createdAt":"2024-07-24T15:53:58"}]