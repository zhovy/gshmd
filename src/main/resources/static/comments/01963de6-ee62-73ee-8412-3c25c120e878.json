[{"id":"01963de6-ef15-7279-bc47-f0e8811ede56","parentId":null,"rootId":null,"fromId":5497,"content":"我的评价是不如自己当老板","createdAt":"2023-08-27T18:30:25"},{"id":"01963de6-ef10-7115-87ea-be9f56dca886","parentId":null,"rootId":null,"fromId":5497,"content":"我觉得就是我觉得","createdAt":"2023-08-27T18:30:40"},{"id":"01963de6-ef58-71ce-9afc-8fbdd2ce4c33","parentId":null,"rootId":null,"fromId":4366,"content":"老城区一个办事处就够你忙活好几年的。那是因为没有高楼大厦，只能在老破小楼里面。","createdAt":"2023-08-28T13:20:45"},{"id":"01963de6-efa2-72e3-984c-0fa28f979702","parentId":null,"rootId":null,"fromId":274,"content":"也是分公司，我们公司之前在市中区经纬那一块，被绿色包围，附近美食还多，员工状态很悠闲，搬到高新区后挤电梯就受不了，人，路上也是人挤人，上班中间也不可能下楼遛弯，毫无幸福感可言，但是公司搬回去是不可能了","createdAt":"2023-08-28T15:02:48"},{"id":"01963de6-efe5-7170-b04a-ffd3f420a859","parentId":null,"rootId":null,"fromId":2935,"content":"你觉得没错，我用了好几年验证这件事，去了这种公司，他们为啥去那么偏的地方？还不是为了省成本？但是真的省了么？不见得。。。至少招人难，换人难，但是你别觉得你去了就有了粘性，领导让你走，是跟你能力无关的","createdAt":"2023-09-02T00:04:07"},{"id":"01963de6-f032-7264-a015-13e8b37d3a0e","parentId":null,"rootId":null,"fromId":2710,"content":"这个上世纪的大楼是世纪金榜吗？，他们那别程序员待遇怎么样啊","createdAt":"2024-07-14T12:16:24"}]