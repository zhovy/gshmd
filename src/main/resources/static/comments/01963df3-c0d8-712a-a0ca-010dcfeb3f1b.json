[{"id":"01963df3-c187-70ac-a376-ac095e220f2e","parentId":null,"rootId":null,"fromId":880,"content":"绝大部分","createdAt":"2024-10-16T13:54:47"},{"id":"01963df3-c18c-73c4-b452-f52ab962fbc5","parentId":null,"rootId":null,"fromId":5654,"content":"别迷恋什么国企背景，正儿八经的国企都是逢进必考有门槛的。济南好多国资参股的企业没有国企的命，却有国企的病，毛病一大堆。","createdAt":"2024-10-16T14:18:11"},{"id":"01963df3-c1cf-7038-9a58-fa580fd48bcc","parentId":null,"rootId":null,"fromId":933,"content":"国企背景=民企外包","createdAt":"2024-10-16T14:56:07"},{"id":"01963df3-c213-728c-845e-f9913025f85d","parentId":null,"rootId":null,"fromId":5814,"content":"兄弟去面试了吗? 怎么样","createdAt":"2024-10-18T09:59:19"},{"id":"01963df3-c259-739f-b2c9-ae2d1f00dc13","parentId":null,"rootId":null,"fromId":6523,"content":"好兄弟，进去感觉怎么样","createdAt":"2024-10-21T14:46:01"},{"id":"01963df3-c29f-70e9-ac17-ced5a8dc54d0","parentId":null,"rootId":null,"fromId":3450,"content":"投简历了,没理我","createdAt":"2024-10-21T16:47:42"},{"id":"01963df3-c2e4-727d-ab23-0c432e876d50","parentId":null,"rootId":null,"fromId":22151,"content":"根本不是国企背景，纯纯骗人，只是一个国企项目而已，而且业务做不起来；\nHR不干人事，福利待遇啥啥没有，整天就只想着扣你仨瓜俩枣的绩效；\n拖欠工资！拖欠工资！拖欠工资！大家避雷！","createdAt":"2024-10-29T15:22:30"},{"id":"01963df3-c328-71bd-aea7-5358ca7944bb","parentId":null,"rootId":null,"fromId":7593,"content":"哥们，还欠着呢吗","createdAt":"2024-11-13T11:05:47"},{"id":"01963df3-c32c-7221-b1b7-14e2d45f46e0","parentId":null,"rootId":null,"fromId":7593,"content":"盼回","createdAt":"2024-11-13T11:06:15"},{"id":"01963df3-c331-7007-a0d6-a3b4a45d262b","parentId":null,"rootId":null,"fromId":22326,"content":"拖欠已成定局，\n单休，面试的时候告诉你双休。\n社保最低标准，说是入职交五险一金，到现在也没给交。\n我来了不久准备溜了。\n我的工资很可能要不回来了。","createdAt":"2024-11-26T08:37:44"},{"id":"01963df3-c374-70e7-b89e-66e67f8e2626","parentId":null,"rootId":null,"fromId":22829,"content":"根本不是国企，就是接了政府的项目，但政府款一直不到位，导致项目运行不起来，拖欠工资，改单休、降薪，一言不合就裁员，姓刘的老板和姓李的人事都不是什么好东西，别去了。他们连工位都是借用的，也不提供办公电脑。","createdAt":"2025-02-26T17:04:48"}]