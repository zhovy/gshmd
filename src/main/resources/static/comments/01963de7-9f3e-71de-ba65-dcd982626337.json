[{"id":"01963de7-9fb2-73c4-bf44-d3c65fe87a0c","parentId":null,"rootId":null,"fromId":5581,"content":"最近走了一波人了","createdAt":"2023-09-06T16:49:08"},{"id":"01963de7-a002-7258-bccd-2ae70455a7f0","parentId":null,"rootId":null,"fromId":4152,"content":"干过一段时间，每年有四次200京东卡，过年年终奖看你一年的表现，没有很具体的考核，周报写写就行。外包看你是项目外包还是人力外包，项目外包最起码是自己公司的团队，好说话。工资不高，一直出差，就连开发都会出差","createdAt":"2023-09-06T16:56:05"},{"id":"01963de7-a046-7259-8e95-e828d0343d58","parentId":null,"rootId":null,"fromId":4152,"content":"入职人多离职也多，铁打的领导流水的兵。但我建议别做外包","createdAt":"2023-09-06T16:56:53"},{"id":"01963de7-a04b-7215-ad4c-3f28a84f6182","parentId":null,"rootId":null,"fromId":3892,"content":"金现代一年能涨多少工资？","createdAt":"2023-09-06T17:02:58"},{"id":"01963de7-9ffd-7001-9a9a-6b53ad6aa335","parentId":null,"rootId":null,"fromId":4043,"content":"为啥","createdAt":"2023-09-06T17:20:03"},{"id":"01963de7-a096-7302-864a-77db079ea3b9","parentId":null,"rootId":null,"fromId":1039,"content":"五月份裁了一批人，自己想想","createdAt":"2023-09-06T19:03:20"},{"id":"01963de7-a0da-727d-8a5e-a870ac9a3cb1","parentId":null,"rootId":null,"fromId":3199,"content":"不咋样，有经验的别去，要是刚毕业可以去学一下","createdAt":"2023-09-07T09:40:05"},{"id":"01963de7-a11d-7248-adc0-72b30b6194ce","parentId":null,"rootId":null,"fromId":1398,"content":"要是找不到工作就去金现代吧","createdAt":"2023-09-07T13:15:15"},{"id":"01963de7-a162-7282-901b-44205317d3c3","parentId":null,"rootId":null,"fromId":3892,"content":"金现代也没那么好进，也要求工作经验的\n","createdAt":"2023-09-07T13:21:28"},{"id":"01963de7-a167-71d0-97bc-807d64b0afc0","parentId":null,"rootId":null,"fromId":3112,"content":"？？？","createdAt":"2023-09-12T11:28:28"},{"id":"01963de7-a1ac-708a-ad0e-eb22ca0eb52c","parentId":null,"rootId":null,"fromId":4317,"content":"我感觉金现代也还算可以，我们这个部门目前是没有裁人，但是你要提离职会让你直接走，以前会加钱留你，我部门大概不到一年涨一次工资，具体涨多少是由上面说了算的，最低500，高点1000，出差问题，我部门一直都有，要是项目不紧急，可以说不愿意去，要是紧急，那就没办法了，餐补很低，除了一线城市，好像是45一天，一般来说出差的活都是跑那天天加班，所以都不愿意加班","createdAt":"2023-09-12T11:41:17"},{"id":"01963de7-a1fd-7120-8042-d08b78cbbd17","parentId":null,"rootId":null,"fromId":3199,"content":"要是设计人员的话，就别去了，进了交互设计部，不患上心理疾病都是好的","createdAt":"2023-09-12T14:27:38"},{"id":"01963de7-a247-713a-82a0-9145bc49bd1c","parentId":null,"rootId":null,"fromId":1161,"content":"公司是个好公司，看你入职的部门和部门领导怎么样。咱也不一杆子打死，真的很看你入职的部门领导怎么样。","createdAt":"2023-09-12T14:34:50"},{"id":"01963de7-a28b-70c1-aa68-9ee6fd7c6905","parentId":null,"rootId":null,"fromId":4225,"content":"在那工作过，还没毕业就去了，在济南总部待了一年，后来被以人员外包的形式派遣到南京，遇到了一个不错的甲方大哥，后来一直跟着甲方的老大哥干，用了三年时间，做到了甲方的保留人员，在甲方担任技术经理角色，后来在甲方大哥的操作下，通过了甲方的社招面试，只差一步就成了国家电网的正式员工，结果被公司领导得知，强行搅黄了。","createdAt":"2023-09-15T16:48:47"},{"id":"01963de7-a2d0-7305-8a65-5d3d42c1973a","parentId":null,"rootId":null,"fromId":4043,"content":"沃日，这么恶心人么","createdAt":"2023-09-15T17:27:53"},{"id":"01963de7-a2d5-73da-818f-c9b55007cf37","parentId":null,"rootId":null,"fromId":1712,"content":"怎么可能胡搅蛮缠，直接离职，在面试进电网，傻逼公司又能拿你如何，","createdAt":"2023-09-15T21:01:56"},{"id":"01963de7-a2d9-7357-a27d-163a41310457","parentId":null,"rootId":null,"fromId":2815,"content":"只差一步就成了国家电网的正式员工  这个应该是不太可能，大概率是进入到了电网下面的劳务派遣单位","createdAt":"2023-10-09T10:19:51"},{"id":"01963de7-a2dd-7263-940f-fd9cc589cd22","parentId":null,"rootId":null,"fromId":403,"content":"差点成国网的正式员工？要不是我在省电力局工作了三年（合同工），我差点就相信你说的了。","createdAt":"2024-05-15T10:10:47"},{"id":"01963de7-a091-732a-b48c-6726815d0f30","parentId":null,"rootId":null,"fromId":3024,"content":"一次涨200现在","createdAt":"2024-05-16T08:48:12"},{"id":"01963de7-a2e1-7297-8619-7ad36fb629a7","parentId":null,"rootId":null,"fromId":21762,"content":"新面试通过的，大哥大姐给说一下，项目经理入职 数字军工分公司，怎么样","createdAt":"2024-08-27T17:19:45"},{"id":"01963de7-a1f8-7377-9627-f58ca38ab7d0","parentId":null,"rootId":null,"fromId":21762,"content":"大哥，你这是什么部门，现在还在吗，能给说说具体情况吗","createdAt":"2024-08-27T17:38:43"},{"id":"019c17f5-61e1-72ad-b52f-f872a79b18a9","parentId":null,"rootId":null,"fromId":25732,"content":"金现代主动裁人?怎么裁的，因为不加吗","createdAt":"2026-02-01T14:48:03"},{"id":"019c17f5-83c3-73f0-9e0b-3e5330b4d70e","parentId":null,"rootId":null,"fromId":25732,"content":"不加班吗","createdAt":"2026-02-01T14:48:11"},{"id":"019c17f6-fdb3-7136-9307-7445f3f2a187","parentId":null,"rootId":null,"fromId":25732,"content":"去之前说去可以，拒绝加班会咋样","createdAt":"2026-02-01T14:49:48"}]