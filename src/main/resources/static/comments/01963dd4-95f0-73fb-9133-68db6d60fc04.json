[{"id":"01963dd4-96d5-700f-a1e2-8ce3ceb9264c","parentId":null,"rootId":null,"fromId":195,"content":"人员流失大是真的","createdAt":"2022-03-31T20:46:40"},{"id":"01963dd4-971b-730c-a400-722c6104bff3","parentId":null,"rootId":null,"fromId":281,"content":"不知道现在还有没有每月400的合同奖励，不满3年离职还要退还每月的400","createdAt":"2022-04-20T16:45:45"},{"id":"01963dd4-9760-7259-9e8a-55e08c5d7e26","parentId":null,"rootId":null,"fromId":276,"content":"入职合同说的一个季度调薪一次300，后来是两年涨了700","createdAt":"2022-04-22T20:08:04"},{"id":"01963dd4-97a8-7110-ab7e-4a277c6f3d67","parentId":null,"rootId":null,"fromId":304,"content":"年终奖可不是13薪啊，按入职时间定的，n/12*月工资","createdAt":"2022-05-10T10:52:01"},{"id":"01963dd4-9803-7258-9335-fb0407a56bb1","parentId":null,"rootId":null,"fromId":352,"content":"实习生应届被招进去后不签薪资确认单，转正的时候4500-5000，实习三千，领导装知心大哥大姐，人事人身攻击，没错就是赵he玉，负责入职的是李玉jiao，李负责入职画饼，赵负责人身攻击，各个领导就是装死的","createdAt":"2022-05-12T16:07:33"},{"id":"01963dd4-9847-726d-b14d-912c1df254bf","parentId":null,"rootId":null,"fromId":352,"content":"实习转正的时候不承认入职的时候约定的工资，约定转正6k，转正的时候给4500左右，入职还不给签薪资确认单","createdAt":"2022-05-12T16:10:09"},{"id":"01963dd4-988f-7113-a16a-437ec0f4952f","parentId":null,"rootId":null,"fromId":404,"content":"头一次遇到如此垃圾的公司\n面试的时候。HR和技术聊的特别好，还各种画饼，什么带团队啥的，乱七八糟一通吹，然后一直在催入职时间，提完离职之后，告诉我是外包，要去其他公司，然后还要面试，结果要去的公司面试的技术栈并不一致，没通过。\n现在想想，多亏没通过，没去成。\n垃圾，千万不要去","createdAt":"2022-05-18T14:29:43"},{"id":"01963dd4-98d6-7121-8a4d-7164b3d819b6","parentId":null,"rootId":null,"fromId":456,"content":"金现代的四个眼秦昊平就是一傻X，啥都不懂，还在那装，表面一套背面一套的狗","createdAt":"2022-06-08T16:14:03"},{"id":"01963dd4-9927-73b7-bbba-b96c8271a267","parentId":null,"rootId":null,"fromId":851,"content":"大哥们 金现代有开发低代码平台吗？\n还说研发团队120人左右\n啊啊啊啊啊啊啊啊啊啊啊啊？","createdAt":"2022-07-05T17:12:57"},{"id":"01963dd4-997c-7061-bdef-d882de2edd5d","parentId":null,"rootId":null,"fromId":959,"content":"社招面试，有什么要注意的嘛？谢谢","createdAt":"2022-07-13T13:23:43"},{"id":"01963dd4-99c7-737d-8b30-a6f91dfd9585","parentId":null,"rootId":null,"fromId":1083,"content":"特么的面试骗我去两次，就因为问了一个益智题没答出来，就说我思维不行不适合，妮玛两次喊我去啥意思呢","createdAt":"2022-07-25T09:55:10"},{"id":"01963dd4-9a0d-7037-9a5b-739d53189241","parentId":null,"rootId":null,"fromId":1121,"content":"记得入职的时候，赵河玉说过公积金社保都没用，都是国家白让员工掏钱，公司为了员工拿到很多钱，所以交最低的，印象深刻，特此记录，还有合同奖励，离职要退回，这是真的!!!","createdAt":"2022-07-27T09:25:56"},{"id":"01963dd4-9a50-7140-ac96-fd507823c62d","parentId":null,"rootId":null,"fromId":1344,"content":"金现代是我觉得最垃圾的公司了，就一外包公司，装的不行，赚人头费的而已，坑应届生太厉害。","createdAt":"2022-08-15T13:48:51"},{"id":"01963dd4-9a96-7304-b576-81dc88038093","parentId":null,"rootId":null,"fromId":1555,"content":"别去，尤其是应届生，别去，笑死去了不挣钱还往里面搭钱","createdAt":"2022-08-31T16:29:46"},{"id":"01963dd4-9adb-7280-82cc-708b77ae2486","parentId":null,"rootId":null,"fromId":1947,"content":"他妈傻逼金现代，我都工作将近三年了，今天面试，很痛快，然后下午告诉我通过了，当时我要的是11K，下午问我7500来不，我说你他妈玩我呢在这，他告诉我他们平台好，操他妈了真的是","createdAt":"2022-10-12T16:20:41"},{"id":"01963dd4-9b23-7165-b644-38fe6e842451","parentId":null,"rootId":null,"fromId":1948,"content":"千万不要去，除非哪里都没人要你，天天不加班就咬PUA你，天天pua，事多的要死，工资低的要死，很疑惑这样的公司为什么存在，吸员工血","createdAt":"2022-10-12T16:54:29"},{"id":"01963dd4-9b83-72f7-9d4d-fb46ea1126ad","parentId":null,"rootId":null,"fromId":2057,"content":"纯纯吸血公司","createdAt":"2022-10-24T16:05:27"},{"id":"01963dd4-9bd4-7088-9946-5cb5c66125fd","parentId":null,"rootId":null,"fromId":1948,"content":"谁去谁sb","createdAt":"2022-10-26T11:26:50"},{"id":"01963dd4-9c19-737e-bf48-0fe56e40f2d1","parentId":null,"rootId":null,"fromId":2061,"content":"完全的坑，不建议有工作经验的和有理想的去那，各种克扣，各种坑","createdAt":"2022-11-08T15:28:34"},{"id":"01963dd4-9c5f-715f-8f25-c47f4c2b6bc9","parentId":null,"rootId":null,"fromId":2268,"content":"日你妈一年半涨了300工资，还是自己提的，领导还不情不愿，本来基础工资就不高。除了月底发当月工资之外没啥别的值得称赞的","createdAt":"2023-01-03T10:11:10"},{"id":"01963dd4-9ca2-73fe-a5aa-48ea317fe0e7","parentId":null,"rootId":null,"fromId":2233,"content":"这过年连个屁也没有 真服了 明天就最后一天班了 连个鸟屁也不放","createdAt":"2023-01-16T21:41:09"},{"id":"01963dd4-9ce6-7329-8257-9b3838b975b2","parentId":null,"rootId":null,"fromId":2229,"content":"狗篮子公司第一天入职就让加班到凌晨十二点，全年三百六十五天无间断招人，什么水平不用多说了吧","createdAt":"2023-02-08T10:34:47"},{"id":"01963dd4-9d2b-7153-a606-ab952d2a7ea0","parentId":null,"rootId":null,"fromId":2495,"content":"楼上这是刚入坑啊","createdAt":"2023-02-10T17:22:51"},{"id":"01963dd4-9d6f-71c4-982c-b43b02b3e474","parentId":null,"rootId":null,"fromId":2587,"content":"从人事就能看出这家公司的水平，某个人事不专业，不尊重求职人员，没有素质","createdAt":"2023-02-20T15:46:08"},{"id":"01963dd4-9db3-707d-8bc4-8bb57e6c58d3","parentId":null,"rootId":null,"fromId":2640,"content":"群二交付产品部，陈磊更傻逼、哈哈哈，笑死了，pua员工，说什么有本事谁会来金现代啊，在座的大家都不是富二代，家里也不是什么副部级之类的，所以好好上班，各种贬低员工，贬低公司，二逼一个，啥话都往外喷，不让员工上班看手机，自己却看的要命","createdAt":"2023-02-26T20:54:19"},{"id":"01963dd4-9df8-73af-8275-f00ac4a4de93","parentId":null,"rootId":null,"fromId":2782,"content":"工伤不给员工上报，还不给员工足够的治疗时间，直接裁员了给","createdAt":"2023-03-06T09:59:14"},{"id":"01963dd4-9e3b-70bf-ba4d-c87db99b5716","parentId":null,"rootId":null,"fromId":2788,"content":"婆婆妈妈的一个公司，前面说给发入职通知 发了傻逼3天 都没发  薪资谈好的又变卦，特别是他们公司的人事部门的人，说话不经过脑子 光浪费时间，画大饼 画的很大说进去有人带 有两个大姐 没进去就知道里面画大饼 特别是里面面试的两个负责人  净说些屁话，到最后 啥也给不了","createdAt":"2023-03-06T15:37:23"},{"id":"01963dd4-9e7f-705f-8c46-8e16536530d8","parentId":null,"rootId":null,"fromId":2233,"content":"妇女节没看见女生有啥福利 挺尬的","createdAt":"2023-03-08T14:29:14"},{"id":"01963dd4-9ec3-70a2-ba70-ab2af6ab13b4","parentId":null,"rootId":null,"fromId":1776,"content":"不是发了抽纸吗？","createdAt":"2023-03-15T11:26:15"},{"id":"01963dd4-9f06-7362-aee8-a01302c78c8b","parentId":null,"rootId":null,"fromId":2640,"content":"等着五一给你发京东卡吧……就这点福利了","createdAt":"2023-03-15T12:37:07"},{"id":"01963dd4-9f4f-72c0-b265-f2056580b43c","parentId":null,"rootId":null,"fromId":2047,"content":"发的京东卡居然也要交税","createdAt":"2023-03-22T16:51:32"},{"id":"01963dd4-9f98-70de-9ebe-688d97233c73","parentId":null,"rootId":null,"fromId":3121,"content":"入职说半年涨薪一次，一年1000到1500，干了两年半一共涨500，各种部门调动，调过去就不管你之前的业绩了，想涨薪别想了","createdAt":"2023-03-29T11:00:20"},{"id":"01963dd4-9fe7-726d-af7c-2d9824cb85f2","parentId":null,"rootId":null,"fromId":3121,"content":"某某群四领导除了会阴阳怪气，PUA啥也不会，部门不景气谁都看得出来，大领导都离职了，想辞退员工保成本就说，拐弯抹角恶心人是好手","createdAt":"2023-03-29T11:06:47"},{"id":"01963dd4-a02d-732b-bb62-712def45a3ec","parentId":null,"rootId":null,"fromId":2233,"content":"要黄了 拖欠工资恶心人了开始","createdAt":"2023-03-31T11:45:47"},{"id":"01963dd4-a078-7006-b9e1-7c5186f55ff1","parentId":null,"rootId":null,"fromId":2640,"content":"真的拖欠工资了？","createdAt":"2023-03-31T12:33:05"},{"id":"01963dd4-a0c0-7057-8a3b-8ad8aedc0940","parentId":null,"rootId":null,"fromId":3165,"content":"没拖工资吧，，我刚收到这个月的工资","createdAt":"2023-03-31T16:25:00"},{"id":"01963dd4-a104-7335-bf84-22567e9b776e","parentId":null,"rootId":null,"fromId":3165,"content":"可能有些部门效益不行，都是单独核算的","createdAt":"2023-03-31T16:26:08"},{"id":"01963dd4-a149-721d-bb09-9253acdd9ab5","parentId":null,"rootId":null,"fromId":3199,"content":"某部门基本全是女的，无能领导pua，搞“一言堂”，打击员工自尊心，就会大吼大叫，否定比自己能力强的员工，搞自己的小团体，部舔王、表面温柔背地里打报告的心机女比比皆是","createdAt":"2023-04-04T17:47:54"},{"id":"01963dd4-a18e-7102-afcc-ffed67c46c2b","parentId":null,"rootId":null,"fromId":2640,"content":"下班了到点不走，等着给你上坟？工作不饱和怪我了？项目经理是吃屎的吗？为啥不安排工作？难道把自己负责的模块做好不就行了吗？为啥我要主动去找活干！你安排多少活我就做多少，做的多了还是给我那些钱！我何必去当那个冤种！臭傻逼","createdAt":"2023-04-07T17:17:11"},{"id":"01963dd4-a1d4-72ce-8a46-9e4255fdb8e3","parentId":null,"rootId":null,"fromId":352,"content":"金现代啊，，，我毕业第一家公司，先骂一句群四交付中心姓王的傻逼经理，还有群四需求组傻逼王伟","createdAt":"2023-04-10T20:35:09"},{"id":"01963dd4-a25d-710e-a860-c2191790bc4d","parentId":null,"rootId":null,"fromId":2233,"content":"哈哈 看了看照片 李玉娇和赵荷玉长得好像啊","createdAt":"2023-04-11T09:05:00"},{"id":"01963dd4-a2a3-7026-850d-240ca6e82b16","parentId":null,"rootId":null,"fromId":3199,"content":"建议所有设计人员，都不要去面试金现代的交互设计部，一群老娘们画大饼、吹牛逼","createdAt":"2023-04-12T16:06:45"},{"id":"01963dd4-a2ea-71be-89f5-d984f41548e3","parentId":null,"rootId":null,"fromId":2280,"content":"好想跑，但是还有违约金","createdAt":"2023-04-12T17:41:33"},{"id":"01963dd4-a334-7315-a189-e4228d7d3d55","parentId":null,"rootId":null,"fromId":2640,"content":"44楼是金桥的吧……该跑跑，去哪挣得不比在那挣得多","createdAt":"2023-04-13T08:51:27"},{"id":"01963dd4-a377-736a-abfb-d69f6330a9ca","parentId":null,"rootId":null,"fro