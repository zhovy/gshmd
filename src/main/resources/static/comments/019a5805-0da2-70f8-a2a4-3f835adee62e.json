[{"id":"019a5828-4c06-702e-b0e5-892e2200b49d","parentId":null,"rootId":null,"fromId":22250,"content":"任天堂（《超级马里奥》、《塞尔达传说》）\nR星（《侠盗猎车手》、 《荒野大镖客》）\n电子艺界（《FIFA》、《战地》）\n微软（光环》、《极限竞速》、《我的世界》）\n米哈游（《原神》、《崩坏》）\n索尼（《战神》、《最后生还者》）\n育碧（《刺客信条》、《孤岛惊魂》）\n暴雪（《魔兽世界》、《星际争霸》、《暗黑破坏神》）\nEpic（《堡垒之夜》）\n网易（《梦幻西游》、《阴阳师》）\n盛大（《传奇》）\n腾讯（代理公司，忽略不计）\n等世界知名游戏（代理）公司全部集中在济南各大写字楼，CBD，济南又被成为世界”游戏之都“，”电竞之城“，无数的游戏研发人员每日骑电驴从唐冶、雪山、济钢、工业北、神武、华山、奥体、槐荫等地区奔赴汉峪骗谷、软件园和CBD等地的写字楼上下班，为济南GDP贡献了超过35%的份额。同时也带动了游戏周边的很多产业的发展，文化影响力也空前强大。每当提起游戏，济南总是一个绕不开的城市，济南同时也被大家成为”东方小缅甸“，影响力可见一斑。","createdAt":"2025-11-06T15:53:47"},{"id":"019a5839-d662-7375-af41-b5e5ffcdb51f","parentId":null,"rootId":null,"fromId":25075,"content":"真的吗?","createdAt":"2025-11-06T16:12:56"},{"id":"019a5846-c62b-7150-b8de-0fd9a4fcde3e","parentId":null,"rootId":null,"fromId":26245,"content":"哈哈东方小缅甸，厉害厉害","createdAt":"2025-11-06T16:27:04"},{"id":"019a5c50-8ed5-7391-84cd-545df5dfe6ca","parentId":null,"rootId":null,"fromId":6517,"content":"有。我之前同事转行做游戏。启蒙公司在文化东路那边。现在跳槽到杭州了","createdAt":"2025-11-07T11:16:14"},{"id":"019a5d10-88e5-72e8-875e-8c9464404dd1","parentId":null,"rootId":null,"fromId":7124,"content":"青岛人这招厉害","createdAt":"2025-11-07T14:45:56"},{"id":"019a71f6-36b1-7324-bca9-ff1d232a10bc","parentId":null,"rootId":null,"fromId":41,"content":"有公司一大堆啊","createdAt":"2025-11-11T16:09:12"},{"id":"019ace6c-7921-73da-aefb-30ef7927df51","parentId":null,"rootId":null,"fromId":25256,"content":"笑了","createdAt":"2025-11-29T15:03:26"},{"id":"019ace6d-1fe2-7167-83b0-3e13ae39962f","parentId":null,"rootId":null,"fromId":25256,"content":"叫什么名字老哥?现在还在那吗","createdAt":"2025-11-29T15:04:09"},{"id":"019ace6d-57bd-7340-a151-92c186f7d555","parentId":null,"rootId":null,"fromId":25256,"content":"在哪??","createdAt":"2025-11-29T15:04:23"}]