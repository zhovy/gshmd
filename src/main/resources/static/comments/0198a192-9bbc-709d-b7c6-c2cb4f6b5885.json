[{"id":"0198a1fa-7fbf-7125-b11f-35fc55d7ba0e","parentId":null,"rootId":null,"fromId":6435,"content":"又一个想去我们镇上干活的？我可以给你推荐下哪里有好吃的羊杂汤","createdAt":"2025-08-13T13:50:05"},{"id":"0198a1ff-ae8d-7352-afb7-a592a3a0f7b5","parentId":null,"rootId":null,"fromId":3450,"content":"人员流动性太高了，你觉得自己能不能坚持住","createdAt":"2025-08-13T13:55:44"},{"id":"0198a3b5-e0b6-719a-83c7-be41240fbced","parentId":null,"rootId":null,"fromId":5383,"content":"乡镇家族式企业。管理比较混乱，靠关系，普通工人需要讨好领导，除部分岗位外（财务等），全年无休，所有法定节假日不放假。大部分都是附近乡镇的居民，年纪普通较大，年轻人少，离着近，肯下力的乡村人比较适合来这。\n正式工有五险，工资大概晚发一个半月；临时工没有五险，工资晚发半年。","createdAt":"2025-08-13T21:54:22"},{"id":"0198a7aa-55ce-708f-8516-516f773c9c4c","parentId":null,"rootId":null,"fromId":5559,"content":"九羊信息化的岗位人员流动性也很大吗   工资按时发不","createdAt":"2025-08-14T16:20:14"},{"id":"01992e47-bf33-72fd-8bb2-2aa8ebf23725","parentId":null,"rootId":null,"fromId":5944,"content":"在哪 我回家尝尝","createdAt":"2025-09-09T19:41:18"},{"id":"01994b03-410b-72ae-98f9-ee9b1d76944d","parentId":null,"rootId":null,"fromId":6435,"content":"金浩西边有两家，好像都卖，我一般吃东边那家，但缺点是太咸了","createdAt":"2025-09-15T09:35:28"}]