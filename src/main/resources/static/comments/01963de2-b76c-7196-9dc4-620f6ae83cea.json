[{"id":"01963de2-b7fd-70f6-b32d-17320b5f229a","parentId":null,"rootId":null,"fromId":3582,"content":"的确是 +1","createdAt":"2023-05-22T09:21:32"},{"id":"01963de2-b844-73ad-9c8c-c4350332792b","parentId":null,"rootId":null,"fromId":557,"content":"22年1月份吧，我还面过高级java。没想到这公司真实情况是这样。。","createdAt":"2023-05-22T09:41:40"},{"id":"01963de2-b889-7213-862b-7bdffdb85e74","parentId":null,"rootId":null,"fromId":557,"content":"说错了，是23年1月份，也就是今年年初的时候","createdAt":"2023-05-22T09:57:09"},{"id":"01963de2-b893-715d-9bf5-619153c5b46f","parentId":null,"rootId":null,"fromId":3588,"content":"产研不仅每天有早会，还要写周报月报，甚至还有季报","createdAt":"2023-05-22T15:01:26"},{"id":"01963de2-b8db-7317-914d-c32eb79f0362","parentId":null,"rootId":null,"fromId":3589,"content":"确实是事实","createdAt":"2023-05-22T15:08:23"},{"id":"01963de2-b966-739b-b3bb-fa9917a09ec2","parentId":null,"rootId":null,"fromId":3582,"content":"真的是这样   商业医疗险还要自己交钱买","createdAt":"2023-05-23T10:35:11"},{"id":"01963de2-b9ad-7001-99fd-7b8e43da185a","parentId":null,"rootId":null,"fromId":1581,"content":"21年还分别去面试过，技术面过了最终我也没去，还好没去","createdAt":"2023-05-23T13:58:05"},{"id":"01963de2-b9f1-713d-8e8a-e7c0dcd214c0","parentId":null,"rootId":null,"fromId":3611,"content":"喜欢钱少事多的快快来","createdAt":"2023-05-24T11:41:21"},{"id":"01963de2-ba37-71ee-8920-fad69772965d","parentId":null,"rootId":null,"fromId":2225,"content":"1. 创意产研部的刘某昊满嘴喷粪天天哭丧着脸，好像所有人都欠他钱似的，不适合共事。\n2. 经常迭代上线（基本上一周一次），一般都折腾到晚上12点多。\n3. 这个公司有6个月的试用期，转正述职不通过没有任何赔偿。\n4. 项目结束了，就开始戕害功臣。后来才得知，2022年公司就只想把项目做完，一开始就没打算留人，有种被欺骗被利用的感觉。\n5. 刘某昊各种PUA，1.工作经验和能力不匹配 2.不像一个10年老兵的员工 3. 不能光写代码，要向前一步，要反过来引导需求，让产品听你的话 4. 公司不忙就不招人了，加班是应该的\n具体细节：\n1. 进入公司后天天加班，基本上一个人完成了项目后端所有功能的开发\n2.做项目的时候，临时添加了计算交付时间需要跳过节假日的功能，奇葩的事来了：临时添加的功能，我还没说啥呢，刘某昊突然说了一句，就算添加了新功能，也不是你延期的理由，我当时都懵了，无语中。。。，至今明白为啥这么说。\n3.刘某昊说工作经验和能力不匹配，不像一个10年老兵的员工。我不解的是：项目基本上是我一个人开发上线交付的，竟然污蔑经验和能力不行，更奇怪的是，这个10年的数字从哪儿来的，嘴没有把门的，想说啥说啥满嘴喷粪，哎，还不脸红，人才啊！！！","createdAt":"2023-07-03T15:44:14"},{"id":"01963de2-b88e-7225-806f-b0fcc66de7c4","parentId":null,"rootId":null,"fromId":2225,"content":"没来是明智的，太坑了\n","createdAt":"2023-07-03T15:48:48"},{"id":"01963de2-b8d7-736b-9995-86b808bae1c8","parentId":null,"rootId":null,"fromId":2225,"content":"天天早会 太形式了","createdAt":"2023-07-03T15:50:12"},{"id":"01963de2-ba88-71c7-9ce4-cf9cd7e0fde0","parentId":null,"rootId":null,"fromId":2225,"content":"楼主说的都是真的","createdAt":"2023-08-02T09:33:20"},{"id":"01963de2-bacd-7268-97f4-6543e75327fc","parentId":null,"rootId":null,"fromId":2225,"content":"22年收到了几家offer，最重选择了他，至今还在后悔，假！！！","createdAt":"2023-08-02T09:34:55"},{"id":"01963de2-ba83-733b-8dfd-aa9136f8f626","parentId":null,"rootId":null,"fromId":2225,"content":"2年前去过这家公司，和你说的一样，不仅如何，试用期裁员各种套路，没有任何补偿。","createdAt":"2023-08-02T09:39:21"},{"id":"01963de2-bb11-72e3-b656-96c24a23445a","parentId":null,"rootId":null,"fromId":880,"content":"楼主说的很对啊，他们人力也很垃圾，各方面都不专业，很傻逼的那个人力总监","createdAt":"2023-10-20T16:23:19"},{"id":"01963de2-bb55-71c0-b297-5a9377440b26","parentId":null,"rootId":null,"fromId":7259,"content":"有没有还在里面上班的兄弟，\n1.创客贴济南产研部门加班严重吗？\n2.研发流程规范吗？\n3.薪资待遇怎么样(五险一金，薪资水平咋样)\n4.试用期会裁人？","createdAt":"2024-06-12T22:30:47"},{"id":"01963de2-bb99-73ee-8efa-c0ab6097eb60","parentId":null,"rootId":null,"fromId":7259,"content":"绩效占比高吗？打低分能少多少钱？","createdAt":"2024-06-19T10:38:25"},{"id":"01963de2-bbdf-710e-a577-5e1b5819c5fb","parentId":null,"rootId":null,"fromId":2367,"content":"看了楼主说的好心塞，另外感觉楼主挺幽默的，哈哈！","createdAt":"2024-06-19T11:33:33"},{"id":"01963de2-bc23-7188-b52d-6fdacfc4d2fb","parentId":null,"rootId":null,"fromId":21176,"content":"现在这个公司怎么样，有没有在里面的老铁说一下","createdAt":"2024-06-28T23:22:18"},{"id":"01963de2-bcb0-7032-8e45-f46b52089135","parentId":null,"rootId":null,"fromId":21719,"content":"试用期八折薪资，工资、五险一金、办公环境跟外包没啥区别，甚至还更差。招人就是为了刷kpi和用你的打折期劳动力的，3个月述职很多情况不过，试用期裁员没有补偿。一直在裁人，入职算本人附近走了5个人，包括顶头领导，当时就意识到情况不对。还有绩效，轮着给你扣薪资用的，医疗保险要自己买。下午6点半下班，但是产研经常加班，算上加班时间等，时薪比外包还低。","createdAt":"2024-08-22T10:21:33"},{"id":"01963de2-bcf6-71ac-bd1a-8dab865e8e4c","parentId":null,"rootId":null,"fromId":1750,"content":"面试的设计师，这的设计师待遇怎么样？","createdAt":"2024-12-12T20:36:45"},{"id":"01963de2-bd3d-70d4-b558-de4925df834b","parentId":null,"rootId":null,"fromId":1712,"content":"目前情况怎么样","createdAt":"2025-03-20T14:01:32"}]