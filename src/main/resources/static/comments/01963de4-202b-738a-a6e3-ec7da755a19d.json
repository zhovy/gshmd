[{"id":"01963de4-208f-7234-83f3-c54a1f256aad","parentId":null,"rootId":null,"fromId":2598,"content":"一般化，说是大小周，其实还是单休","createdAt":"2023-06-26T18:17:57"},{"id":"01963de4-20da-73c5-ba09-143ea4eae4fc","parentId":null,"rootId":null,"fromId":270,"content":"办公地点在孵化器的那个吗？每天爬楼上下班","createdAt":"2023-06-27T21:44:54"},{"id":"01963de4-2120-725a-aa59-38bd5d8c63bc","parentId":null,"rootId":null,"fromId":2478,"content":"20层吗","createdAt":"2023-06-28T16:34:40"},{"id":"01963de4-20d5-7163-a069-a05ea99c1929","parentId":null,"rootId":null,"fromId":3946,"content":"公司前景如何？","createdAt":"2023-06-30T14:59:10"},{"id":"01963de4-2129-70ff-84f3-3258869f4c0d","parentId":null,"rootId":null,"fromId":3929,"content":"有在这个公司认识的人嘛？公司怎么样","createdAt":"2023-07-07T05:56:55"},{"id":"01963de4-2125-721c-9033-4c16a490c23a","parentId":null,"rootId":null,"fromId":3929,"content":"刚搬家了不是\n","createdAt":"2023-07-07T06:45:29"},{"id":"01963de4-216e-73fe-9ea8-2b6bf8526940","parentId":null,"rootId":null,"fromId":1895,"content":"+1","createdAt":"2023-07-07T08:30:44"},{"id":"01963de4-2172-73ba-b29c-8101d8f72bd9","parentId":null,"rootId":null,"fromId":3238,"content":"这公司面试基本就属于骗方案的，技术负责人都讲不清规划","createdAt":"2023-08-10T10:49:41"},{"id":"01963de4-217c-7207-8a89-5ba5ef446641","parentId":null,"rootId":null,"fromId":5510,"content":"目前里面啥情况啊，能去吗","createdAt":"2023-10-13T17:17:05"},{"id":"01963de4-21c1-711f-abae-dae1bdb660fe","parentId":null,"rootId":null,"fromId":6284,"content":"垃圾公司！拖欠工资！加班加到没人性！老板动不动就张嘴骂人！闭坑！","createdAt":"2023-12-16T18:53:21"},{"id":"01963de4-220c-7233-9f79-a91b0eb21fc0","parentId":null,"rootId":null,"fromId":6468,"content":"同意楼上，垃圾公司，真的没遇到这么垃圾的公司，中国人不骗中国人，老板有地域歧视，性别歧视还有学历歧视，歧视东北，说不招女生，还说本科学历低，也不招，还说要是离职，工资减少20%，谁去谁懵逼","createdAt":"2024-01-15T18:40:37"},{"id":"01963de4-2250-714c-9b48-480d78625b4a","parentId":null,"rootId":null,"fromId":6515,"content":"小公司不正规，项目需求都是口头需求，做得稀烂。10号发工资，老板一人说了算，有空了就准时，没空就延期。\n加班严重，节假日周六周天强制加班，节假日会让你写个自愿加班之类，加班不能调休不能抵扣请假什么的。\n入职不给合同，要也找理由不给，试用期找理由延长或者辞退，10号之后入职的，转正日期会顺延一个月。离职扣钱，以有损公司利益为由扣个几千块。\n老板经常骂人是真的，脏话连篇，认为项目延期难以交付是下面人干的不行。\n其它，办公氛围一般，办公室有监控，老板经常关心员工的电脑屏幕内容，开会时老板自己说的。\n上班时间朝9晚6，下班时间开会，多数晚上8点。也有早上开会的，比较膈应的是那次暴雪预警下大雪的那天，是要求早上开会，全市倡导可以晚到，这里要求8点半之前到，到的没到的反正是记了一个名单，下午别的公司是鼓励早走，这里是要求你继续加班。\n入坑之前慎重。","createdAt":"2024-01-23T01:29:37"},{"id":"01963de4-2299-73d3-876c-a2af800f326a","parentId":null,"rootId":null,"fromId":2367,"content":"题主去这家公司了么？？","createdAt":"2024-07-04T09:20:40"},{"id":"01963de4-2177-72b1-82fc-dfc067dbc455","parentId":null,"rootId":null,"fromId":2367,"content":"您好，你去这家公司了么","createdAt":"2024-07-04T09:21:04"},{"id":"01963de4-2294-70e0-a5f4-f1ccc2d5ecec","parentId":null,"rootId":null,"fromId":2367,"content":"卧槽  这么坑么","createdAt":"2024-07-04T09:22:29"},{"id":"01963de4-22dc-7147-ae65-e9fae6308454","parentId":null,"rootId":null,"fromId":3888,"content":"没去","createdAt":"2024-07-04T10:22:02"},{"id":"01963de4-22e0-720a-b647-921959cde665","parentId":null,"rootId":null,"fromId":21287,"content":"这家公司规模怎么样，人多不多，工资福利待遇什么的稳定吗，老板人好吗？","createdAt":"2024-07-04T15:52:20"},{"id":"01963de4-2323-71a8-bf55-6862c526d425","parentId":null,"rootId":null,"fromId":7249,"content":"现在这家公司还这么垃圾吗   有在职的人么","createdAt":"2024-08-22T11:34:33"}]