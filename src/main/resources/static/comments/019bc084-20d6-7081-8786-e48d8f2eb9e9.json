[{"id":"019bc1d9-6505-7158-af05-fe63de73dd5f","parentId":null,"rootId":null,"fromId":27629,"content":"不扣都是好的还发，不是经常骂猪狗不如，混吃等死。","createdAt":"2026-01-15T21:30:08"},{"id":"019bc20a-0497-71e1-91ee-1747314c0306","parentId":null,"rootId":null,"fromId":27629,"content":"你是在职的还是离职的，\n多少年不发了，年年赔钱，\n还要绩效不得骂的你和孙子一样，\n听说前段时间都追出来骂人了，\n当着那么多人，被骂的连个屁也不敢放，\n总经办的好像也经常被骂，好像只有找事的那个部门不被骂。\n这个公司就是个传奇。\n不亏是法律出身，\n骂起人来居然没有敢反抗的。","createdAt":"2026-01-15T22:23:15"},{"id":"019bc44b-bfdd-70b9-9fc1-1e827b6f7cf6","parentId":null,"rootId":null,"fromId":22250,"content":"这些人在网上可是义愤填膺夸夸其谈，现实确实相反的，只能说中国人活该被奴役几千年","createdAt":"2026-01-16T08:54:17"},{"id":"019bc45d-aa3d-726a-979b-4ab24d005d6c","parentId":null,"rootId":null,"fromId":2783,"content":"是的 国人不团结","createdAt":"2026-01-16T09:13:51"},{"id":"019bc467-e290-7171-82d7-af11f091e22f","parentId":null,"rootId":null,"fromId":23279,"content":"一般谁好骂人啊，我离职多年了，想知道一下","createdAt":"2026-01-16T09:25:01"},{"id":"019bc479-cac9-70f1-8458-7f87afb9cc38","parentId":null,"rootId":null,"fromId":22098,"content":"骂你又能咋滴，打你也得受着，学法律的还拿捏不了你啊。xx勾结，能理解吧","createdAt":"2026-01-16T09:44:34"},{"id":"019bd3ae-b4e7-71f1-a53f-bf59f1bb9e85","parentId":null,"rootId":null,"fromId":2246,"content":"奴役几千年？你能找到一个农民起义比中国还多的国家民族吗？","createdAt":"2026-01-19T08:36:40"},{"id":"019c0435-afe4-71d8-be6e-c211a8e87057","parentId":null,"rootId":null,"fromId":23334,"content":"兄弟别考虑绩效了，考虑一下未足额缴纳的五险一金，一个举报，公司老老实实的补缴，我刚提交资料","createdAt":"2026-01-28T18:45:53"},{"id":"019c0823-6193-72ec-a07c-fb0bfc4e0592","parentId":null,"rootId":null,"fromId":21676,"content":"这啥意思，就是让你公司给你按双边12%缴纳嘛？那补缴了之后，自己还需要再交钱吗？","createdAt":"2026-01-29T13:04:22"},{"id":"019c0875-39cf-701f-8c2c-c0d4072fd915","parentId":null,"rootId":null,"fromId":22945,"content":"同问","createdAt":"2026-01-29T14:33:46"},{"id":"019c2d99-fd1e-7214-b73f-2bc24ab6ab91","parentId":null,"rootId":null,"fromId":23334,"content":"就是让公司按你的工资给缴纳五险一金，目前公司是按你济南最低工资给你缴纳的五险一金，如果工资1万的话，公司得再补6000地五险一金。自己需要交，公司补公司的，自己补自己的，自己的补五险进个人养老账户和医保账户，公积金补玩了，可以直接提出来。这个举报公司补的钱是你补钱的三倍左右。","createdAt":"2026-02-05T19:39:52"}]