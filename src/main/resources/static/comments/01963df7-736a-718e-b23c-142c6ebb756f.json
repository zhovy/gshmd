[{"id":"01963df7-73de-721f-9f0f-30f77f52b75b","parentId":null,"rootId":null,"fromId":1039,"content":"交社保和五险的公司都要","createdAt":"2025-02-28T16:12:52"},{"id":"01963df7-7428-711a-9cd8-0a3a5ef216f1","parentId":null,"rootId":null,"fromId":1398,"content":"你被裁员了？","createdAt":"2025-02-28T16:15:07"},{"id":"01963df7-746c-71a9-b63b-afd3d822a606","parentId":null,"rootId":null,"fromId":22740,"content":"被裁了，哎","createdAt":"2025-02-28T16:25:10"},{"id":"01963df7-7471-725c-ba30-48ed11c656fc","parentId":null,"rootId":null,"fromId":5725,"content":"搞个萝卜章就行，为啥被裁就没有离职证明吗","createdAt":"2025-02-28T16:32:10"},{"id":"01963df7-74ba-7016-ba9f-76fb1b510410","parentId":null,"rootId":null,"fromId":22539,"content":"那失业补助咋办。","createdAt":"2025-02-28T16:35:59"},{"id":"01963df7-74ff-70d3-a938-dfc7529fe986","parentId":null,"rootId":null,"fromId":22740,"content":"没领呢","createdAt":"2025-02-28T17:48:32"},{"id":"01963df7-7423-71ae-b440-1190f48a92c8","parentId":null,"rootId":null,"fromId":22740,"content":"那找不到公司了啊","createdAt":"2025-02-28T17:49:49"},{"id":"01963df7-74b5-73fc-ad62-699f29984cc6","parentId":null,"rootId":null,"fromId":22740,"content":"胆小，不敢搞。我在仲裁呢，公司不给开离职证明","createdAt":"2025-02-28T17:51:09"},{"id":"01963df7-754a-73c4-a954-ef7312966d7e","parentId":null,"rootId":null,"fromId":22157,"content":"劳动合同法实施条例规定了离职证明的内容，可以先找劳动监察投诉","createdAt":"2025-02-28T20:05:29"},{"id":"01963df7-7593-705a-bb80-3621f34c6a92","parentId":null,"rootId":null,"fromId":5755,"content":"公司不开离职证明导致你不能入职下家的话。你让下家开一份不录用的证明，然后去仲裁，公司要赔偿你的。","createdAt":"2025-02-28T22:06:24"},{"id":"01963df7-75d8-723d-aad1-57217f57791d","parentId":null,"rootId":null,"fromId":22399,"content":"这样得充分准备好证据，包括前公司不给的证据、跟新公司hr的聊天记录、因为没有上家离职证明的不予录用通知（最好是盖章的）、证明你新公司未入职损失的工资","createdAt":"2025-03-01T10:45:46"},{"id":"01963df7-758f-729f-8849-3ec941385ca0","parentId":null,"rootId":null,"fromId":22424,"content":"有用，不光能要离职证明，还能要没交的社保和劳动合同","createdAt":"2025-03-01T11:12:10"},{"id":"01963df7-75dd-7354-8a74-17e90ac26dd3","parentId":null,"rootId":null,"fromId":22082,"content":"他这是不合法的，辞退就要开辞退的离职证明才能领失业金，打劳动监察大队电话和劳动仲裁同时进行，处理前先百度济南市免费律师咨询电话根据个人情况问清楚处理流程","createdAt":"2025-03-01T11:29:21"},{"id":"01963df7-7622-73ed-8a31-68b4f0428d25","parentId":null,"rootId":null,"fromId":21912,"content":"要我说，直接去找劳动监察、社保、消防、税务举报，惯的他们了","createdAt":"2025-03-01T11:32:52"}]