[{"id":"01963de2-4ba5-7014-bb73-df361411b6ba","parentId":null,"rootId":null,"fromId":2558,"content":"奥维科技好像也没有了吧","createdAt":"2023-05-11T10:00:38"},{"id":"01963de2-4bf1-70c6-9a3d-90a662c5c448","parentId":null,"rootId":null,"fromId":3475,"content":"本来就没有这些公司的帖子。","createdAt":"2023-05-11T10:05:04"},{"id":"01963de2-4c37-7235-8f27-d25569e95b65","parentId":null,"rootId":null,"fromId":2558,"content":"我昨天还看见的啊，可能标题不一样","createdAt":"2023-05-11T10:20:57"},{"id":"01963de2-4c7b-707e-a69c-af67543f3768","parentId":null,"rootId":null,"fromId":2924,"content":"这个公司怎么样","createdAt":"2023-05-11T10:34:04"},{"id":"01963de2-4c80-707e-a33c-f5cee0770c99","parentId":null,"rootId":null,"fromId":2558,"content":"忘记了，所以才来找找看","createdAt":"2023-05-11T11:42:51"},{"id":"01963de2-4c87-713c-b5c4-36893ed914a8","parentId":null,"rootId":null,"fromId":2783,"content":"五险一金最低，年终奖说的是两个月，但是得满工作一年后才能拿到，至于到那时候能不能拿到就算你的本事了。出楼梯口一股尿骚味。","createdAt":"2023-05-11T13:17:41"},{"id":"01963de2-4ccd-703d-8afe-87042561ebba","parentId":null,"rootId":null,"fromId":2420,"content":"去年的年终奖到现在没法，说是没通知 就是卡你","createdAt":"2023-05-11T15:57:13"},{"id":"01963de2-4c83-707e-87ff-45eeff1fec69","parentId":null,"rootId":null,"fromId":2420,"content":"接鲁软的外包或在山东国网下面的小地市接项目","createdAt":"2023-05-11T15:58:40"},{"id":"01963de2-4cd1-73c4-906c-2bf330846ac9","parentId":null,"rootId":null,"fromId":2783,"content":"属于外包中的外包 ","createdAt":"2023-05-12T16:06:04"},{"id":"01963de2-4d14-7106-a978-7947ecdf5916","parentId":null,"rootId":null,"fromId":3523,"content":"呆过一段时间，薪资福利偏低，所谓的市场总监专科学历一言堂，决定都是瞬间就下没有任何考虑，实行三天又换方案；加班比较频繁，技术团队水平偏低，被坑数次，年终奖从转正后开始算一年，本年六月在岗才会拿到年终奖，另外不会给你全部，根据绩效评分，评分全由一人决定，其管理下的团队无一人不抱怨其领导能力。另外个别员工素质堪忧，另外无补助相关任何东西，入职请做考虑","createdAt":"2023-05-15T16:27:03"},{"id":"01963de2-4d60-71d6-960c-2e12e658d090","parentId":null,"rootId":null,"fromId":3527,"content":"总结很到位","createdAt":"2023-05-16T09:25:47"},{"id":"01963de2-4d64-736e-8ec6-3c0c10edc9c6","parentId":null,"rootId":null,"fromId":3547,"content":"工资是否按时发放啊？是双休不？有大佬知道嘛？","createdAt":"2023-06-20T19:45:31"},{"id":"01963de2-4da8-70a2-acb4-9eb85d2f802e","parentId":null,"rootId":null,"fromId":2420,"content":"18 、19 发 不出意外的话要出意外 说让你加班就加","createdAt":"2023-06-29T17:22:15"},{"id":"01963de2-4dad-7288-8e37-6ee12b2ab241","parentId":null,"rootId":null,"fromId":4158,"content":"周六周天不加班，除非有周一的汇报，大多是时间加班不加班看自己心情，20年底拿了不到15薪，21和22都是14薪+但是都不是年底发了，改3-6月之间了。我也呆了快5年了，要走的时候连老板楼出面留我了，也算没白了我的青春。提醒4楼半的兄弟，不知道你是几月发的奖金，没发也别等了，潜规则是评价越高发的越早（有年三十当天就发了的大哥），评价后10%还是20%的就~~~你懂的","createdAt":"2023-07-25T11:18:09"},{"id":"01963de2-4db1-71ef-81af-14e3adff0781","parentId":null,"rootId":null,"fromId":5732,"content":"根本就没有年终奖，如果你敢要年终奖就直接把你开除，而且招聘一个前端，面五六十个人，加班到12点是常有的事情，你敢相信9点下班，让你带电脑回家，10点继续开会开到12点的吗，你就等于是卖给公司了","createdAt":"2023-09-19T10:10:43"}]