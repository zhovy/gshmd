2023-06-19T18:22:30"},{"id":"01963de3-ec28-70ea-938e-3e969a8c9e9a","parentId":null,"rootId":null,"fromId":1656,"content":"想查你的，咋包也没用，不在乎的，多假都无所谓","createdAt":"2023-06-19T19:05:28"},{"id":"01963de3-ec71-7278-9ca7-855ece73bc75","parentId":null,"rootId":null,"fromId":875,"content":"遇见要工资流水，人力就开始狗了，工资流水是多少，工资就给多少，甚至还往下压价，说什么14薪16薪","createdAt":"2023-06-19T19:51:45"},{"id":"01963de3-ec19-707b-a42f-f036c93fcf35","parentId":null,"rootId":null,"fromId":557,"content":"啥公司能给2w","createdAt":"2023-06-20T08:40:41"},{"id":"01963de3-ec1f-72fb-845f-c3f7abdf8a63","parentId":null,"rootId":null,"fromId":2921,"content":"遇见装傻的面试官比如我，你就是寄","createdAt":"2023-06-20T08:52:07"},{"id":"01963de3-ec24-7037-81bd-6b9148fbbaa3","parentId":null,"rootId":null,"fromId":3705,"content":"济南这地方，你要多了，人家就不鸟你了，除非那种技术很垃圾的公司，面试官技术也菜然后被你吹的都高潮了，可以会给你高薪。\n但是如果你入职了，他们会对你有非常高的期望，这种期望是很大的压力，尤其是在你技术和水的东西不匹配的情况下。","createdAt":"2023-06-20T09:47:54"},{"id":"01963de3-ec75-72e5-8b02-77975c80155a","parentId":null,"rootId":null,"fromId":875,"content":"得包装，刚毕业的包装个bat的实习经历，进济南这些个私企要一万八不是问题，前提是学校的时候好985211起步","createdAt":"2023-06-20T19:43:12"},{"id":"01963de3-eb86-706d-8e40-1ddcb77ec4ad","parentId":null,"rootId":null,"fromId":2958,"content":"git代码都不会拉。。。可见面试答得再好实战不行也没用","createdAt":"2023-06-21T11:50:51"},{"id":"01963de3-ecba-7327-bda8-3a5951ad52e9","parentId":null,"rootId":null,"fromId":3960,"content":"不包装，干了啥，工资是多少，如实写","createdAt":"2023-07-08T00:37:25"}]