[{"id":"01989d75-e2e4-71cb-9168-62ca3c2a5ffd","parentId":null,"rootId":null,"fromId":21234,"content":"大学在无锡实习，我们部门的经理和一年轻小姑娘有一腿，我们部门没有总监，就调了济南的总监过来带我们我们，这个总监是个女的，也和这个经理有一腿，但这个经理是有家室的，半夜很晚女总监和男经理约着看电影，然后我们部门的这个小姑娘和无锡公司的老总也有一腿，现在过了那么多年，都各种成家结婚了","createdAt":"2025-08-12T16:46:45"},{"id":"01989d76-ca2f-70d9-aee3-c1e9a9d54e23","parentId":null,"rootId":null,"fromId":4190,"content":"周瑜打黄盖","createdAt":"2025-08-12T16:47:44"},{"id":"01989d77-9bb7-73d0-b79b-0e5d811bbf5a","parentId":null,"rootId":null,"fromId":21234,"content":"前公司的hr打小报告，如果看见你玩手机或者不干活啥的，就会和你的领导说你工作不饱和，找机会干掉","createdAt":"2025-08-12T16:48:38"},{"id":"01989d7a-250f-70c8-85db-dab3bd169aca","parentId":null,"rootId":null,"fromId":7124,"content":"第一份开发工作，在天桥区，老板姓于，整天pua我们，每天晚上11点在群里拍小视频，坐在路虎揽胜里面哭着自拍，说我们不关心他，不在乎公司业绩，什么的，从此以后被我们嘲讽为，坐在路虎里哭泣的男人","createdAt":"2025-08-12T16:51:24"},{"id":"01989d7a-bbb8-737a-ae65-7c5a530db5d2","parentId":null,"rootId":null,"fromId":21234,"content":"前公司的老板和CFO谁也看不上谁，但因为利益关系老板也不敢把他干掉，他们彼此都想扶持上自己的人，据说是吞了资方的money，做的账是J账","createdAt":"2025-08-12T16:52:03"},{"id":"01989d81-0587-7265-9743-3d4a15cc1224","parentId":null,"rootId":null,"fromId":21234,"content":"讲点同事的八卦，喜欢上一个有家庭的男的，那个男的应该是类似于杰瑞那种公司的车间或者厂子上班，有白班有夜班，这个男的的老婆白天上班，那么这男的白天休班的时候就会把我同事带回家，甚至在家里给她炖鸡汤喝，男的和他老婆没有孩子，也不可能离婚娶她，现在不知道那俩人还好着吗，她第一次跟我讲的时候我非常震惊，甚至这个男的身边的朋友哥们都知道，他们还一起出去玩，唯独他老婆不知道","createdAt":"2025-08-12T16:58:55"},{"id":"01989d82-1746-7287-8642-45716cfbb1f2","parentId":null,"rootId":null,"fromId":21234,"content":"刚入职一个月，公司组织架构调整了3次............","createdAt":"2025-08-12T17:00:05"},{"id":"01989d91-bdcb-72aa-8834-c3a7650d4aaf","parentId":null,"rootId":null,"fromId":1372,"content":"入职了2个月。劳动合同因为公司组织变动，签了4回。","createdAt":"2025-08-12T17:17:10"},{"id":"01989da5-cecb-72a7-a2a4-0cbec006fbbe","parentId":null,"rootId":null,"fromId":21512,"content":"某短工国企的某部门盯加班吃晚饭时长","createdAt":"2025-08-12T17:39:06"},{"id":"0198a15e-1756-703d-98d7-8b8ac328d1f0","parentId":null,"rootId":null,"fromId":7074,"content":"让我来让我来：有几个同事，基本没啥活，但是每天都能加班，愣是换出来很多的调休。（招投标，大半年了，一个标没投过，没写过标书，加班确实常态）","createdAt":"2025-08-13T10:59:14"},{"id":"0198a240-c272-708d-9c83-85de30210639","parentId":null,"rootId":null,"fromId":3925,"content":"以前公司有个项目经理啥也不懂，有一次在客户现场，当时大晚上的加班呢我就在旁边，他说打开做的地图大屏之后电脑的硬盘占用率直接到了99%，说这玩意是超级大bug必须得解决，这玩意懂的都懂，其实就是电脑用的机械硬盘不太行了，完事就问我这个大bug应该谁改，我看他挺认真的我就说这玩意不是我的问题，找chrome的开发吧，他咋写的我咋知道。","createdAt":"2025-08-13T15:06:49"},{"id":"0198a281-eaec-71a9-aa23-6df0a510bb00","parentId":null,"rootId":null,"fromId":3778,"content":"说","createdAt":"2025-08-13T16:18:00"},{"id":"0198a2cc-f77a-7146-9e58-49fd34c9c27c","parentId":null,"rootId":null,"fromId":21512,"content":"工位鲁管算吗","createdAt":"2025-08-13T17:39:58"},{"id":"0198a42c-b6b5-7119-a978-9176d7e9726f","parentId":null,"rootId":null,"fromId":23027,"content":"老板说挣不到钱应该找个角落抽自己嘴巴子，还要一遍抽一遍骂自己笨蛋。开不上五十万的车都不好意思出门。","createdAt":"2025-08-14T00:04:10"},{"id":"0198a610-523a-717b-a056-ceb63ce441b8","parentId":null,"rootId":null,"fromId":21234,"content":"这。。。。。。","createdAt":"2025-08-14T08:52:24"},{"id":"0198a610-c040-730e-9c6a-60a922d190a4","parentId":null,"rootId":null,"fromId":21234,"content":"这老板格局真不小","createdAt":"2025-08-14T08:52:52"},{"id":"0198a61c-bea0-711e-995a-8cf910750bfe","parentId":null,"rootId":null,"fromId":4092,"content":"公司业绩下滑，老板找了一个大师来公司看，大师走后就把公司正门给锁死了，员工上下班只能走侧面的小门，但是大师道行不够，公司还是黄了","createdAt":"2025-08-14T09:05:58"},{"id":"0198a62c-cba3-70d3-bc31-29b31d478523","parentId":null,"rootId":null,"fromId":21904,"content":"这不是人人阳老吴年会时的经典语录么","createdAt":"2025-08-14T09:23:30"},{"id":"0198a77e-3532-7311-a9f1-436b4046d7b7","parentId":null,"rootId":null,"fromId":3608,"content":"牛逼","createdAt":"2025-08-14T15:32:02"},{"id":"0199091b-6c7e-716d-bac2-c36d14861293","parentId":null,"rootId":null,"fromId":1538,"content":"我怎么感觉那个大师的意思是,早点关门(大门)吧倒闭留个后路(小门)撤,啊哈哈哈","createdAt":"2025-09-02T14:26:56"}]