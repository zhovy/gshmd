[{"id":"01963df7-28da-7204-a29c-88a202e25bc4","parentId":null,"rootId":null,"fromId":629,"content":"不行，生殖隔离","createdAt":"2025-02-21T10:50:15"},{"id":"01963df7-2922-71a1-9c5b-a43f2ada213b","parentId":null,"rootId":null,"fromId":6186,"content":"建议多看看书","createdAt":"2025-02-21T11:02:48"},{"id":"01963df7-2965-735f-bbd1-912b197d8c98","parentId":null,"rootId":null,"fromId":7566,"content":"请阁下明示","createdAt":"2025-02-21T11:08:58"},{"id":"01963df7-296a-7346-9369-c421b68d9ba8","parentId":null,"rootId":null,"fromId":1398,"content":"那个公司的外包，那个公司的正编？","createdAt":"2025-02-21T11:22:47"},{"id":"01963df7-29af-7377-a8de-181b4773f9e2","parentId":null,"rootId":null,"fromId":7566,"content":"不特指某个公司，就是问一下外包和正编能谈恋爱吗","createdAt":"2025-02-21T11:56:28"},{"id":"01963df7-29b4-72d9-803b-60a6061b2436","parentId":null,"rootId":null,"fromId":22539,"content":"女方是正编，男方是外包，而且还是上下级，太棒了。","createdAt":"2025-02-21T11:59:02"},{"id":"01963df7-29b8-71d3-a18d-c9841bef9a53","parentId":null,"rootId":null,"fromId":22702,"content":"外包是什么 自己不清楚吗","createdAt":"2025-02-21T15:34:53"},{"id":"01963df7-2a01-706e-a89d-3efb6334fd00","parentId":null,"rootId":null,"fromId":22173,"content":"王思聪如果是外包   我估计女的是正编也很主动吧。你爸如果是李刚，你是外包，女生也很主动吧。你在大厂（华为，阿里等）工作是政府单位的外包，他们也会主动吧。你要是济南某些外包公司的外包估计你主动戏份也少吧","createdAt":"2025-02-21T16:22:58"},{"id":"01963df7-2a44-7261-8639-f13e100574c0","parentId":null,"rootId":null,"fromId":3149,"content":"听说之前有家公司的外包给正编的一个不认识的女孩表白，被女孩举报了，然后就被清退了...","createdAt":"2025-02-24T09:50:12"},{"id":"01963df7-2a88-7263-bd24-4a442abbfdd0","parentId":null,"rootId":null,"fromId":7381,"content":"生殖隔离","createdAt":"2025-02-25T15:48:11"},{"id":"01963df7-291d-712f-be9b-9fcd80eba8f1","parentId":null,"rootId":null,"fromId":7566,"content":"生殖隔离的定义是指由于各方面的原因，使亲缘关系接近的类群之间在自然条件下不交配，或者即使能交配也不能产生后代或不能产生可育性后代的隔离机制。目前看外包和正编属于在自然条件下不交配这种情况，还真是生殖隔离。","createdAt":"2025-02-25T16:42:02"},{"id":"01963df7-2acc-7190-8948-d04a843c4ca7","parentId":null,"rootId":null,"fromId":7566,"content":"生殖隔离的定义是指由于各方面的原因，使亲缘关系接近的类群之间在自然条件下不交配，或者即使能交配也不能产生后代或不能产生可育性后代的隔离机制。目前看外包和正编属于在自然条件下不交配这种情况，还真是生殖隔离。","createdAt":"2025-02-25T16:43:01"}]