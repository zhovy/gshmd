[{"id":"0198bb2b-12fb-734e-bf2a-88e1bf8334f7","parentId":null,"rootId":null,"fromId":23279,"content":"不会是那种帮人解决法律问题，不良资产解决方案什么的吧","createdAt":"2025-08-18T11:13:39"},{"id":"0198bb2d-485b-7271-b60b-6489124925b2","parentId":null,"rootId":null,"fromId":460,"content":"你搜一下 这几个公司名字  挨个搜 在这个网站 你就了解了","createdAt":"2025-08-18T11:16:03"},{"id":"0198bb39-66c6-70f2-aa3f-b50544fb3f1c","parentId":null,"rootId":null,"fromId":2980,"content":"嗯，面试的时候搜互仲宝看不到负面评价，入职的时候才能看到博勤，真会隐藏","createdAt":"2025-08-18T11:29:18"},{"id":"0198bb43-2342-710b-9d11-2fdaabd1c5a3","parentId":null,"rootId":null,"fromId":1372,"content":"但凡是这种若干名字轮换着来的公司，一般都有坑。你可以考虑一点，如果要仲裁的话，仲裁谁？ 打卡记录等相关证据能指向一家公司吗？如果不能的话，就做好被坑的准备。证据链会不全，到时候仲裁也没办法。","createdAt":"2025-08-18T11:39:56"},{"id":"0198bb45-30db-739b-8831-8867a43bb4e0","parentId":null,"rootId":null,"fromId":2980,"content":"对，有这方面的业务","createdAt":"2025-08-18T11:42:10"},{"id":"0198bb4a-b3b5-730f-928b-9d4cbbcc4cd7","parentId":null,"rootId":null,"fromId":2598,"content":"别去啊，老板是老赖。。。","createdAt":"2025-08-18T11:48:11"},{"id":"0198bb56-ebd2-70f4-84a1-df58a194072c","parentId":null,"rootId":null,"fromId":2980,"content":"没签合同，赶紧溜了","createdAt":"2025-08-18T12:01:32"},{"id":"0198bb57-77dd-7053-ba63-f164a769a3eb","parentId":null,"rootId":null,"fromId":2980,"content":"是的，一看就不靠谱","createdAt":"2025-08-18T12:02:08"},{"id":"0198bb61-2ffd-729c-9a5f-c36fcd782390","parentId":null,"rootId":null,"fromId":1421,"content":"企查查看下就知道了，泽一实业下面的：博勤，互仲宝，学易付，致新，都是一伙人，马甲经常换着招聘，可能这个名字臭了又会有个新公司出来招，面试简单看你没啥城府就会让你去，老油条直接让回去等通知。","createdAt":"2025-08-18T12:12:45"},{"id":"0198bbb2-3f45-7295-b5fc-93653a7663b9","parentId":null,"rootId":null,"fromId":460,"content":"估计是刚毕业的小年轻，发帖人","createdAt":"2025-08-18T13:41:17"},{"id":"0198bbbb-e01d-7369-adb5-dcd38c371455","parentId":null,"rootId":null,"fromId":23279,"content":"幸亏你溜了，这中业务本身就是个疑似诈骗","createdAt":"2025-08-18T13:51:48"},{"id":"0198bc14-1679-726c-ab8e-2ef48ef26741","parentId":null,"rootId":null,"fromId":2980,"content":"是的，哥哥，还需要注意些什么吗","createdAt":"2025-08-18T