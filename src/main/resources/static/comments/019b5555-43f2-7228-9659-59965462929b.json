[{"id":"019b5579-edac-704d-8a48-5be4f233e63c","parentId":null,"rootId":null,"fromId":21302,"content":"其实你多了解了解建国后的历史，你会发现人群种类还是那些人群种类，早点看透早点清醒。","createdAt":"2025-12-25T20:26:52"},{"id":"019b57f4-d329-712e-ab44-c303b51a923c","parentId":null,"rootId":null,"fromId":875,"content":"去北京吧，去北京一样可以吃超意兴，生活成本一样\n除了口味之外，极致性价比正在成为超意兴竞争的硬币两面。据超意兴北京员工此前向媒体介绍，虽然性价比吸引了多数消费者，但北京门店的利润率相比济南非常低，门店租金和员工成本一般为济南的三倍以上，“即便如此，公司目前也是下定决心要继续扩张”。","createdAt":"2025-12-26T08:00:21"},{"id":"019b584b-7773-734f-9f6c-bf7f5b2cf0b6","parentId":null,"rootId":null,"fromId":21818,"content":"我就是想朝九晚五稳定生活这要求很高吗？这环境都不能保证我抱怨两句都不行？","createdAt":"2025-12-26T09:34:59"},{"id":"019b5851-7b1d-7319-9175-9b2395e65a86","parentId":null,"rootId":null,"fromId":27587,"content":"又是抱怨社会抱怨国家的，如果你觉得中国不好请花250块钱退出国籍","createdAt":"2025-12-26T09:41:33"},{"id":"019b5853-b32c-708b-9ab1-fcc2cebef5ed","parentId":null,"rootId":null,"fromId":21818,"content":"经典弱智言论觉得不好就退出","createdAt":"2025-12-26T09:43:59"},{"id":"019b5854-e19d-7304-ab4c-4f3d26cecd54","parentId":null,"rootId":null,"fromId":27587,"content":"有能力的抱怨都往外面跑，没能力的抱怨只能在网上抱怨","createdAt":"2025-12-26T09:45:16"},{"id":"019b5858-086d-7054-bbae-cf478eab6e45","parentId":null,"rootId":null,"fromId":1049,"content":"解决不了问题，解决提出问题的人是吧","createdAt":"2025-12-26T09:48:42"},{"id":"019b5859-ab5d-7385-ad75-af599748fc66","parentId":null,"rootId":null,"fromId":1049,"content":"照你这么说不应该有革命先驱，他们润出去就好了","createdAt":"2025-12-26T09:50:30"},{"id":"019b585f-543a-7250-b196-9a6122d9402a","parentId":null,"rootId":null,"fromId":27587,"content":"别怪社会太现实只怪自己没能力","createdAt":"2025-12-26T09:56:41"},{"id":"019b5861-6def-72b2-bfcb-d55f6aec8b4c","parentId":null,"rootId":null,"fromId":1049,"content":"经典，但凡你有点社会经验就不会这样说","createdAt":"2025-12-26T09:58:58"},{"id":"019b586d-ce4d-73c4-bef6-fc06564638e1","parentId":null,"rootId":null,"fromId":7336,"content":"首先社会不公，环境不好不是个人造成的，其次，躺平也不是个人不努力，而是努力的程度和换来的回报不对等才导致的大家躺平","createdAt":"2025-12-26T10:12:29"},{"id":"019b5885-ae6e-73fd-91b9-4bf28ddc6118","parentId":null,"rootId":null,"fromId":557,"content":"经济下行，某些人活的很惨，只能在网上发泄了。不发泄不就憋坏了？","createdAt":"2025-12-26T10:38:34"},{"id":"019b5889-e3a3-7287-887e-d3dab8957910","parentId":null,"rootId":null,"fromId":27118,"content":"网络环境就这样，别人不知道自己是谁，人性的恶可以有所释放，少加那种垃圾群，别跟垃圾堆里扒拉，多跟现实里的朋友玩一玩，人生路上遇人不知凡几，交心者几人","createdAt":"2025-12-26T10:43:10"},{"id":"019b5898-0f4e-738c-9a5d-4938fb0dd3bd","parentId":null,"rootId":null,"fromId":21818,"content":"现在过的惨的只是某些人？大部分人都是夹着尾巴过活","createdAt":"2025-12-26T10:58:39"},{"id":"019b58a0-e4d8-72bc-86c6-61d24d43d2fa","parentId":null,"rootId":null,"fromId":21818,"content":"尖锐的矫枉过正的言论你觉得是人性的恶，温和的理性讨论的声音置若罔闻。这个经济环境注定网络环境就会是这样，只在自己舒适的小圈子里确实最好，公众环境在社会经济变好之前只会一直是这样","createdAt":"2025-12-26T11:08:18"},{"id":"019b5914-862d-738a-9fd7-d6e655c066b1","parentId":null,"rootId":null,"fromId":21302,"content":"平时公司里连正常沟通情况下都不敢发表自己意见的人，总算可以在网上喷了。","createdAt":"2025-12-26T13:14:35"},{"id":"019b591a-686a-72dc-ac32-696661b7f5ca","parentId":null,"rootId":null,"fromId":22250,"content":"经典弱智言论，你觉得真要是人群可以自由迁移，有多少人会走，跟个白痴一样","createdAt":"2025-12-26T13:21:01"},{"id":"019b591c-1ea6-734b-a268-33f82c4832ca","parentId":null,"rootId":null,"fromId":22250,"content":"喷同胞，喷和自己有共同处境的人，一旦遇到特权就怂了，生怕惹上一丁点麻烦","createdAt":"2025-12-26T13:22:53"},{"id":"019b591f-0eb8-7372-970f-6a08816cf951","parentId":null,"rootId":null,"fromId":22250,"content":"人性从来都是如此，好人坏人也哪里都有，要顺应更要有尖锐的批评，如果大家都文明讨论，那岂不都是圣人了？","createdAt":"2025-12-26T13:26:06"},{"id":"019b592b-47f5-7052-85bc-064de9e631ce","parentId":null,"rootId":null,"fromId":7078,"content":"好热闹","createdAt":"2025-12-26T13:39:27"},{"id":"019b5957-ea48-704a-b10a-622062242990","parentId":null,"rootId":null,"fromId":28244,"content":"看热闹","createdAt":"2025-12-26T14:28:12"},{"id":"019b59d2-7dc4-7341-ba1a-c0e749964a26","parentId":null,"rootId":null,"fromId":27987,"content":"哪家少爷出来体验生活来了","createdAt":"2025-12-26T16:42:05"},{"id":"019b59ec-6263-72ac-970a-708bae5477a5","parentId":null,"rootId":null,"fromId":25906,"content":"到底谁坏都搞不明白","createdAt":"2025-12-26T17:10:22"},{"id":"019b67b8-d4