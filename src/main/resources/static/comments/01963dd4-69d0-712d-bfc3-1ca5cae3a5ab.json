[{"id":"01963dd4-6a6e-73c0-9a98-6471e05cc610","parentId":null,"rootId":null,"fromId":203,"content":"去面试高级开发，问了我一堆管理方面的问题，技术问题一个没问，我特么是来面试开发岗位的，又不是面试管理的。还有面试官各种装逼、画饼，说他们是上市公司，然后拿这个当理由压工资，你特么上不上市跟我又毛关系？","createdAt":"2022-06-30T15:56:33"},{"id":"01963dd4-6ab3-70ea-babb-26169743b421","parentId":null,"rootId":null,"fromId":203,"content":"傻逼公司","createdAt":"2022-06-30T16:03:19"},{"id":"01963dd4-6afd-71b0-90d1-78f52a551dd2","parentId":null,"rootId":null,"fromId":1581,"content":"我只想说 公司很多人我觉得挺好 但是公司实在是不行","createdAt":"2022-09-06T09:16:14"},{"id":"01963dd4-6b8d-70df-8978-efc6844caa38","parentId":null,"rootId":null,"fromId":770,"content":"刚面试了，不知道啥情况，笔试题直接拒绝做","createdAt":"2023-02-14T12:40:12"},{"id":"01963dd4-6bd1-732a-993d-9c9206901a4a","parentId":null,"rootId":null,"fromId":1915,"content":"hr一上来就会问你 为什么要从上家公司离职 ，离职原因和他有个啥关系","createdAt":"2023-02-15T16:36:43"},{"id":"01963dd4-6c1d-706d-bbcc-379e285f27ae","parentId":null,"rootId":null,"fromId":770,"content":"谈薪资只会比你预想的低，绝对不会高","createdAt":"2023-02-16T08:58:40"},{"id":"01963dd4-6cb0-7162-b2a5-ea48b2734c83","parentId":null,"rootId":null,"fromId":1553,"content":"我想知道有人入职这家公司了吗？这家好像常年在招聘","createdAt":"2023-02-16T18:42:14"},{"id":"01963dd4-6cf3-7132-9ceb-f980d0816246","parentId":null,"rootId":null,"fromId":2543,"content":"蹲一个真实情况，8楼的最后去了么","createdAt":"2023-03-06T08:57:07"},{"id":"01963dd4-6d7d-7282-b403-84630c403e74","parentId":null,"rootId":null,"fromId":2889,"content":"完全不当人的公司","createdAt":"2023-03-13T10:39:08"},{"id":"01963dd4-6dc3-7388-a4f2-5bcaf514c1f8","parentId":null,"rootId":null,"fromId":1364,"content":"呜呜面试过了不敢去","createdAt":"2023-03-14T16:03:46"},{"id":"01963dd4-6e0b-722e-b790-2bdf236a674b","parentId":null,"rootId":null,"fromId":1364,"content":"想问一下，这个公司每周要强制加班吗","createdAt":"2023-03-15T09:49:34"},{"id":"01963dd4-6e51-7063-a058-59bdfe7cd385","parentId":null,"rootId":null,"fromId":2889,"content":"作为从这家公司跑路的人来补充：公司很好，晚上加班到2点可以早晨9点到，去年加班快200小时每个月 说工作时间不饱和 绩效倒数，年终奖分批发你几百块过年 哈哈哈哈哈","createdAt":"2023-04-04T10:02:54"},{"id":"01963dd4-6e95-7027-9e12-b82755362daf","parentId":null,"rootId":null,"fromId":2318,"content":"回答14楼，之前是因为项目太紧，人手不够，所以领导推出了一个开发支持的制度，每个项目组每周抽两天晚上加班到八点，八点半的，每个月抽个周六或周天加班。现在这个制度已经变成常态化了。加班没有加班餐，一小时10块钱，30小时起步，200小时封顶。","createdAt":"2023-04-04T10:26:09"},{"id":"01963dd4-6edb-7264-b10c-46b86e7f1b60","parentId":null,"rootId":null,"fromId":2318,"content":"去年11月每天强制加班到晚上11点，周六一定不休息，周天休息不一定","createdAt":"2023-04-04T11:18:25"},{"id":"01963dd4-6f20-73fc-849e-36070023e4c6","parentId":null,"rootId":null,"fromId":2889,"content":"近期公告：因项目紧急造成加班过凌晨情况，在不耽误项目的前提下经过组长审批后允许加班人员第二天上班时间后移。具体规则如下：\n1    凌晨1点后    上午9点  必须经组长审批才可以\n2    凌晨3点后   上午10点  必须经组长审批才可以\n3    凌晨5点后   下午1点半   必须经组长审批才可以   \n回复楼上 项目太紧能紧一年？  讲个笑话  每周这公司都能认识新同事 但公司人数还是那些","createdAt":"2023-04-04T11:34:22"},{"id":"01963dd4-6f6b-71fc-8d16-61289b4fbd2f","parentId":null,"rootId":null,"fromId":3121,"content":"有没有在里面做PO的，任职要求项目职责都不高，不太信","createdAt":"2023-04-28T14:13:54"},{"id":"01963dd4-6fb0-7288-b209-9d564595319e","parentId":null,"rootId":null,"fromId":3455,"content":"收到offer去入职还要试岗七天","createdAt":"2023-05-12T18:27:19"},{"id":"01963dd4-6ff7-714d-843d-80d96a212ebd","parentId":null,"rootId":null,"fromId":3455,"content":"加班常态化，出差常态化，接受996福报的可以去","createdAt":"2023-05-12T18:27:47"},{"id":"01963dd4-7040-722a-af39-7aac0d3303d0","parentId":null,"rootId":null,"fromId":3554,"content":"关于修正B积分激励制度的通知\n       根据B积分激励制度的试运行情况，结合工作实际对激励制度进行修正如下：\n单次工期在60分钟（不含）内的不计入有效B积分。其他不变。修正后的制度2023 年 5 月起正式执行，如有疑问请咨询公司人事部，特此通知！\n                                 公司人事部 ","createdAt":"2023-05-18T12:24:03"},{"id":"01963dd4-7086-725a-ad63-fd8c018baeda","parentId":null,"rootId":null,"fromId":3565,"content":"试岗七天，妈的周六让加班，周一说我不合适，真是狗啊","createdAt":"2023-05-19T09:32:28"},{"id":"01963dd4-70d1-71c8-94ab-7de7eece3211","parentId":null,"rootId":null,"fromId":3455,"content":"试岗七天，所以面试很简单，进去之后也是不把你当人看，傻逼公司","createdAt":"2023-05-19T11:39:46"},{"id":"01963dd4-7118-71a8-a728-dd2df03a32d4","parentId":null,"rootId":null,"fromId":3455,"content":"测试岗的兄弟们注意了，目前他们都没有测试的领导","createdAt":"2023-05-19T11:42:02"},{"id":"01963dd4-7161-73a9-9546-e7806dec791e","parentId":null,"rootId":null,"fromId":3846,"content":"拒绝加班，如果给的钱多当我没说！每周两天固定加班到八点半。嗯，一小时十块钱的诱惑","createdAt":"2023-06-16T19:21:18"},{"id":"01963dd4-71a5-7153-8b6d-364e0a30e046","parentId":null,"rootId":null,"fromId":3244,"content":"面试过了，待了一天，果断跑路。太可怕了，极其压抑，中午没人那个塑料壳子排队打饭，怎么说呢！无语了，避雷吧。上班不许带耳机，开发的电脑卡的一批。","createdAt":"2023-06-27T15:32:10"},{"id":"01963dd4-6e07-7323-891a-e41e43066543","parentId":null,"rootId":null,"fromId":3960,"content":"问下面试都有什么流程啊，都面试啥啊","createdAt":"2023-07-07T15:06:45"},{"id":"01963dd4-6b44-710a-8e9c-07827c730bbe","parentId":null,"rootId":null,"fromId":4016,"content":"好是指弱智吗","createdAt":"2023-07-12T23:02:24"},{"id":"01963dd4-71e9-726e-9cb6-09ce34a66dec","parentId":null,"rootId":null,"fromId":1110,"content":"现在好些了吗","createdAt":"2023-08-18T13:54:14"},{"id":"01963dd4-70cd-732c-b457-4ad25da0ff87","parentId":null,"rootId":null,"fromId":1110,"content":"这个确实狗","createdAt":"2023-08-22T11:49:54"},{"id":"01963dd4-6f67-72fc-b03e-c49751b3e2e3","parentId":null,"rootId":null,"fromId":4253,"content":"我操，直接住公司得了","createdAt":"2023-09-06T15:55:04"},{"id":"01963dd4-6cac-70f8-aa34-fc70c9781e3d","parentId":null,"rootId":null,"fromId":4253,"content":"兄弟，相信自己，一点都不高，我三年经验的时候都已经12 了","createdAt":"2023-09-06T16:02:57"},{"id":"01963dd4-71ee-7007-b01c-89af189fbbc3","parentId":null,"rootId":null,"fromId":6634,"content":"。","createdAt":"2024-02-19T11:35:10"},{"id":"01963dd4-6af8-73c7-bb47-5b2d5b07ca81","parentId":null,"rootId":null,"fromId":21314,"content":"公司有个姓王的HR，她是我现单位的甲方客户，现在想挖我去做他们公司的市场，不知道靠不靠谱","createdAt":"2024-07-08T13:58:04"},{"id":"01963dd4-7278-710b-a973-bfbe35d20019","parentId":null,"rootId":null,"fromId":880,"content":"可显着你了","createdAt":"2024-07-23T14:54:53"},{"id":"01963dd4-727d-7316-b265-8ade74ff2979","parentId":null,"rootId":null,"fromId":1581,"content":"你算个什么逼玩意 在这叫叫叫 你看你能的  你有种处理一个试试","createdAt":"2024-07-24T15:29:30"},{"id":"0197347d-689e-710d-84b4-7b3927db45bc","parentId