Id":null,"fromId":22913,"content":"降薪加90%的工资是怎么回事，次数多吗","createdAt":"2025-05-21T08:48:55"},{"id":"0196f167-df6b-71bb-b29c-aa9d9d55e0c8","parentId":null,"rootId":null,"fromId":1225,"content":"是降到百分之九十吧，之前行情好的时候很多给的偏高了，降点正常","createdAt":"2025-05-21T13:53:58"},{"id":"0196f1c0-988e-70d1-97e6-c0360b8c4b71","parentId":null,"rootId":null,"fromId":22335,"content":"公司项目亏钱没回款就只发90%，绩效考核扣分到一个地步就按照工资乘以系数。年后4个月工资发了3个月90%。","createdAt":"2025-05-21T15:30:53"},{"id":"0196fac4-e1bd-7265-a072-8db4bb128d23","parentId":null,"rootId":null,"fromId":22466,"content":"屁","createdAt":"2025-05-23T09:32:09"},{"id":"01973f4c-7387-7023-bf20-b59744afb240","parentId":null,"rootId":null,"fromId":22826,"content":"降薪就降薪吧，扣钱就扣钱吧，就当给你们这些人添棺材本了。","createdAt":"2025-06-05T16:54:24"},{"id":"01976314-bb12-72bb-a920-d5bd2b9d084c","parentId":null,"rootId":null,"fromId":5916,"content":"还好润的早，越呆越恶心人。","createdAt":"2025-06-12T15:39:52"},{"id":"01976314-c06e-70e5-9a58-7cefccb40213","parentId":null,"rootId":null,"fromId":5916,"content":"还好润的早，越呆越恶心人。","createdAt":"2025-06-12T15:39:53"},{"id":"01976824-7134-725a-8397-851058b8c709","parentId":null,"rootId":null,"fromId":22465,"content":"这小一年也没看到有人离职啊","createdAt":"2025-06-13T15:15:08"},{"id":"0197d3ed-e12d-71d8-a295-417264e02f4e","parentId":null,"rootId":null,"fromId":22826,"content":"这个月又90%？","createdAt":"2025-07-04T13:34:31"},{"id":"0197d964-7c58-7062-b72a-5e4b51162aee","parentId":null,"rootId":null,"fromId":22913,"content":"我面试过了，也谈薪了，第二天告诉我岗位关闭了，offer没了，我服了","createdAt":"2025-07-05T15:02:10"},{"id":"0197e293-d4ef-708d-9341-4fdeb79ba079","parentId":null,"rootId":null,"fromId":21827,"content":"这么玩的吗","createdAt":"2025-07-07T09:50:28"},{"id":"0197e294-1db8-7335-b6be-34c2d9644f93","parentId":null,"rootId":null,"fromId":21827,"content":"是，又90","createdAt":"2025-07-07T09:50:47"},{"id":"0197e800-1eb9-7310-8879-a4c1dc71e6da","parentId":null,"rootId":null,"fromId":1978,"content":"是面的技术还是销售？","createdAt":"2025-07-08T11:06:51"},{"id":"0197ed98-fbd6-71dc-9a07-e48bd9a4a7eb","parentId":null,"rootId":null,"fromId":22826,"content":"都没钱发工资了，还有钱招新人吗","createdAt":"2025-07-09T13:11:55"},{"id":"019808bc-aabf-7012-be8a-e326cbaefe7d","parentId":null,"rootId":null,"fromId":1421,"content":"我也是这样，看样老板不想进人了","createdAt":"2025-07-14T19:40:38"},{"id":"01987913-1c98-721c-aee8-f50ac287ee7e","parentId":null,"rootId":null,"fromId":21827,"content":"嗯，公司运行稳定，依旧90%","createdAt":"2025-08-05T15:12:32"},{"id":"01987914-219c-7144-ade6-a04351fd3f5e","parentId":null,"rootId":null,"fromId":1978,"content":"亏没亏谁又能知道呢~","createdAt":"2025-08-05T15:13:39"},{"id":"01989894-648c-738a-bfce-72c01afe3c55","parentId":null,"rootId":null,"fromId":5916,"content":"早润了?","createdAt":"2025-08-11T18:01:58"},{"id":"01989896-f376-70d0-9662-d334e30ce9e4","parentId":null,"rootId":null,"fromId":5916,"content":"boss早就润了，现在就剩老本在吃，剩下的都在一层层筛的吃，他们吃不够的肉怎么可能给下级吃呢，只能这么说，大头吃肉，小头喝汤","createdAt":"2025-08-11T18:04:46"},{"id":"01989c0d-8415-70cf-b5f3-a484ef5a5d03","parentId":null,"rootId":null,"fromId":764,"content":"所以才骂他们，一个个的不是个东西，gou&#039;bi&#039;wan&#039;yi","createdAt":"2025-08-12T10:13:08"},{"id":"0198c043-7871-7101-bd0a-4fc3cf1f7f34","parentId":null,"rootId":null,"fromId":21844,"content":"在座的兄弟姐妹说一句：上面领导做事糊弄，和稀泥，勾心斗角，各种添腚，坐视不管，各种形式主义。被一群娘们弄得乌烟瘴气，看问题不看本质，那群娘们除了制定政策屌用没有。还有就是某些傻逼玩意，我行我素，只要是你参与到需求中，你就永远脱离不了关系，最后再给你穿小鞋戴帽子，最后狗屁不是。让你干活但是说不清楚让你干什么，客户要什么自己也不知道就让你干，需求是什么都不清楚就开始要结束时间，滚你妈拉个彼得的吧。老话就是领导都是光腚子泥鳅——浑水不沾泥儿。可怜之人必有可恨之处，切记不要多干一丝活，不然你会越干越累，最后惹一身骚。","createdAt":"2025-08-19T10:58:23"},{"id":"0198eaa1-551e-7370-9ba7-5fb56e10704f","parentId":null,"rootId":null,"fromId":22826,"content":"一个个的没啥脑子，但是心眼子真他妈的多。","createdAt":"2025-08-27T16:24:58"},{"id":"0198efa3-d1f1-71f2-a58b-f8899b7b05f9","parentId":null,"rootId":null,"fromId":764,"content":"细说心眼子","createdAt":"2025-08-28T15:45:47"},{"id":"019a4c4d-9f88-73a4-ac7c-c3399454b7c9","parentId":null,"rootId":null,"fromId":21827,"content":"MD","createdAt":"2025-11-04T08:39:06"},{"id":"019a5846-ec17-7066-b664-c8350cb00e6e","parentId":null,"rootId":null,"fromId":22826,"content":"这个月又90%？","createdAt":"2025-11-06T16:27:14"},{"id":"019b009c-904e-70a1-a272-96bc7d4c6443","parentId":null,"rootId":null,"fromId":764,"content":"好像是只要过节假日就发90%，给人恶心的死死的。一年12个月到现在发了11个月工资，中间有6个月都在克扣，丧心病狂到令人发指","createdAt":"2025-12-09T08:56:59"},{"id":"019c1d93-095f-7227-9437-174560e7057d","parentId":null,"rootId":null,"fromId":21827,"content":"能干干，不能干滚，就降薪了，你敢走？","createdAt":"2026-02-02T16:58:21"},{"id":"019c2b48-f200-73f3-a15f-10c7fb31ed2f","parentId":null,"rootId":null,"fromId":22826,"content":"各位最近相当冷静","createdAt":"2026-02-05T08:52:06"},{"id":"019c2b4e-df1c-72e3-9210-411382d6d06a","parentId":null,"rootId":null,"fromId":21827,"content":"今天发了工资，不知道还能不能这么冷静了，再冷静没声音，那估计都在等年后，看机会了","createdAt":"2026-02-05T08:58:35"},{"id":"019c2d14-97f9-70e9-831c-a4a13a7093ad","parentId":null,"rootId":null,"fromId":22826,"content":"工资今天竟然没发","createdAt":"2026-02-05T17:14:10"}]