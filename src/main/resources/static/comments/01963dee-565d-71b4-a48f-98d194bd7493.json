[{"id":"01963dee-56ca-7388-a11c-36c792efcee1","parentId":null,"rootId":null,"fromId":7344,"content":"同问，一起合作吗","createdAt":"2024-04-27T21:43:16"},{"id":"01963dee-5714-7091-92a8-582e7283f7d8","parentId":null,"rootId":null,"fromId":5396,"content":"1阿里巴巴不知道还行吗 2找源头厂家 3几年前加过一个二道贩子群，他们利用618、双11通过叠加优惠劵这种活动大量囤货，然后平时挂到得物去卖","createdAt":"2024-04-28T08:56:49"},{"id":"01963dee-5758-7355-82bf-3f6a18a1babc","parentId":null,"rootId":null,"fromId":3801,"content":"几年前我搞过，在泺口进的货，不过男装很难卖，女装还行，7块钱进的要价40,15块钱进的要价60，天天晚上和城管打游击，最后弄个不赔本就不搞了，剩一堆衣服，太累了。","createdAt":"2024-04-28T08:59:43"},{"id":"01963dee-57a2-7182-a9a7-2659dba61a02","parentId":null,"rootId":null,"fromId":7211,"content":"晋江那边多了去了，椰子鞋单买50一双。自有品牌的鞋子从15-35之间不等。","createdAt":"2024-04-28T10:49:29"}]