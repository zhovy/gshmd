[{"id":"0196c3ad-02be-7111-8424-4a7391f3ffe2","parentId":null,"rootId":null,"fromId":23971,"content":"话说真想知道是什么样的情况，自己去投投简历就能感觉到了。毕竟耳听为虚眼见为实","createdAt":"2025-05-12T16:46:57"},{"id":"0196c3b8-f80e-71d9-a25a-86614e754516","parentId":null,"rootId":null,"fromId":5471,"content":"是的，点开boss直聘全是跟我打招呼的，我要求也不高，期望薪资5万","createdAt":"2025-05-12T17:00:01"},{"id":"0196c412-fca5-728b-b4c6-d8b3c85a60ab","parentId":null,"rootId":null,"fromId":7425,"content":"\"不好找工作、工资要不上去\"的情况是客观存在的，不过在这个社区里有很多帖子有点夸张了，按照他们说的那样，估计济南明天就要宣布破产一样","createdAt":"2025-05-12T18:38:20"},{"id":"0196cc86-6a1d-70cc-b74e-c0ca4bb57867","parentId":null,"rootId":null,"fromId":414,"content":"不夸张，自己实打实的去找找工作，体验一下就知道了，经济形势不是一般的差","createdAt":"2025-05-14T10:01:23"},{"id":"0196d14a-0198-717d-af6c-61d2658849b3","parentId":null,"rootId":null,"fromId":2246,"content":"内鬼也有，工作也难，不冲突","createdAt":"2025-05-15T08:13:30"},{"id":"0196d32f-57c4-70ac-bd46-46c1215917fa","parentId":null,"rootId":null,"fromId":7425,"content":"经济形势确实不是一般的差啊，但是有些帖子描述的夸张也是真的夸张","createdAt":"2025-05-15T17:03:37"},{"id":"0196d6a0-def6-7213-b265-f54aabd2de52","parentId":null,"rootId":null,"fromId":22806,"content":"实际去投一投就知道了","createdAt":"2025-05-16T09:06:29"},{"id":"0196d6cc-18a5-701c-993f-5685df10c08e","parentId":null,"rootId":null,"fromId":21818,"content":"工资低休息少还拖欠工资的工作还是很好找的，但凡你想找个像点人的工作，就知道现状就是这么的差","createdAt":"2025-05-16T09:53:42"}]