[{"id":"01963ded-2843-70d3-bf6a-f9b8a570bcf6","parentId":null,"rootId":null,"fromId":4321,"content":"挺好的，我呆过一段时间，是一家小而的公司","createdAt":"2024-03-30T08:28:40"},{"id":"01963ded-2888-73ab-8975-9253aadb11a4","parentId":null,"rootId":null,"fromId":4321,"content":"小而美","createdAt":"2024-03-30T08:28:48"},{"id":"01963ded-28e7-736b-a28d-a3b585804cb6","parentId":null,"rootId":null,"fromId":2598,"content":"有在里面干过兼职的嘛，怎么样啊","createdAt":"2024-12-09T14:56:07"},{"id":"01963ded-2935-7380-baa0-9223f6f146b1","parentId":null,"rootId":null,"fromId":6631,"content":"有在里面干过兼职的吗，怎么样呀，好干吗，催活吗。","createdAt":"2025-03-14T10:43:34"},{"id":"01963ded-297d-72fe-8260-bde84a752d1b","parentId":null,"rootId":null,"fromId":2598,"content":"有没有人待过呀，这个兼职怎么样啊，能正常结工资嘛","createdAt":"2025-03-19T17:22:48"},{"id":"01963ded-2978-7026-a996-19e6e0b5eaee","parentId":null,"rootId":null,"fromId":658,"content":"去了吗老哥","createdAt":"2025-03-25T19:39:54"},{"id":"01963ded-29c1-72dc-9a14-b9ab4293d596","parentId":null,"rootId":null,"fromId":658,"content":"靠谱吗","createdAt":"2025-03-25T19:40:03"},{"id":"01963ded-29c5-7371-aa8d-189f8c33b02c","parentId":null,"rootId":null,"fromId":23090,"content":"里面很多兼职岗位，没有无线一金，领导长得就不是个好人样，心眼子很多，已经入职2个月了，天天催活，工期一再压榨，要不是坏境不好早走人了，前几天我看了一眼合同，工作还要以质量标准评审，真实想着法不给钱。频繁的来人走人，流动很高","createdAt":"2025-04-03T17:36:34"},{"id":"01963ded-2a0b-7222-a3a3-afb7e7addbc6","parentId":null,"rootId":null,"fromId":2598,"content":"对，那个领导一看就心眼子很多的样子，不是说每个月和他们员工一块发工资嘛，两个月了还没给你发过？","createdAt":"2025-04-03T17:59:41"}]