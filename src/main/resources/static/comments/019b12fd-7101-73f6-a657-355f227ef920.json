[{"id":"019b15d5-6f0c-725e-8007-f8450996e09e","parentId":null,"rootId":null,"fromId":5438,"content":"千万别去兄弟。就离谱的一家公司","createdAt":"2025-12-13T11:51:07"},{"id":"019b15db-d681-7207-939f-20ac403edaab","parentId":null,"rootId":null,"fromId":5438,"content":"这家公司卸磨杀驴是出名的，忙的时候就招人，忙完了就裁员，而且之前还双休呢，因为太没人性人走差不多了，要改成单休了","createdAt":"2025-12-13T11:58:07"},{"id":"019b1636-3070-7350-a0f6-5556cc22596b","parentId":null,"rootId":null,"fromId":27703,"content":"这么逆天吗？确实也给我说的单休……","createdAt":"2025-12-13T13:36:48"},{"id":"019b1637-93e4-7166-a3d7-ae72b51ead49","parentId":null,"rootId":null,"fromId":5438,"content":"你面的啥岗 哥们","createdAt":"2025-12-13T13:38:19"},{"id":"019b163d-cc9a-7083-b5dc-5756d47b1efa","parentId":null,"rootId":null,"fromId":27703,"content":"测试","createdAt":"2025-12-13T13:45:07"},{"id":"019b1644-7015-70e6-b542-c2ec775b7495","parentId":null,"rootId":null,"fromId":5438,"content":"那我给你说一下实际情况，里面现在分A,B俩业务，A业务原来忙的时候有4个人，忙完一个大项目后裁掉了俩，剩下俩女的，一个组长一个干活儿的，组长现在怀孕了，估计三四个月了，干活儿的听说刚跑路，你如果进去了，估计就是在A业务下面干，领导还怀孕，你就是顶梁柱，懂我意思吗，加班跑不了你的，还单休，我觉得单休都够呛。\n\nB业务俩测试，也很忙，跟竞品竞争干不完的需求，忙不过来的时候就互相帮忙，可能来帮你，也可能你去帮他\n\n不过加班可以换调休的，如果忙完了或者生完孩子你被裁了，加的班可以换成钱，自己考虑吧","createdAt":"2025-12-13T13:52:22"},{"id":"019b164b-923d-70b0-bfa5-a15d256ec082","parentId":null,"rootId":null,"fromId":27703,"content":"谢谢老哥了","createdAt":"2025-12-13T14:00:10"},{"id":"019b166c-7a4f-729b-853e-8207c0df900e","parentId":null,"rootId":null,"fromId":5438,"content":"别客气，别的不说，单休的就别考虑。","createdAt":"2025-12-13T14:36:06"},{"id":"019b2674-0595-70a3-a105-ed5aa614bc8c","parentId":null,"rootId":null,"fromId":59,"content":"啊？前几个月还面试了呢，看着是个不错的公司，业务挺稳定","createdAt":"2025-12-16T17:18:16"},{"id":"019b2f67-3b51-707b-acd0-6b4592b785ea","parentId":null,"rootId":null,"fromId":5438,"content":"今年来业务稳定下降，竞争不过人家","createdAt":"2025-12-18T11:00:53"},{"id":"019b3022-7f26-732d-b99a-5adffb3ae12b","parentId":null,"rootId":null,"fromId":21742,"content":"七月份去面试过  没要我 那时候一个男的面试的  说是双休 这才几个月就单休了。","createdAt":"2025-12-18T14:25:25"},{"id":"019b34fe-bdd2-73b0-a8a8-1b7316d4334e","parentId":null,"rootId":null,"fromId":26979,"content":"请问面的什么岗位啊","createdAt":"2025-12-19T13:04:28"},{"id":"019b3500-c63b-7013-ad97-53da9cb1d224","parentId":null,"rootId":null,"fromId":26979,"content":"给你发offer了吗？你去了吗？","createdAt":"2025-12-19T13:06:41"},{"id":"019b8868-60e0-73ad-a1ca-a55afa9c9ea9","parentId":null,"rootId":null,"fromId":27186,"content":"我是一共进行了2轮面试。第1轮是个领导面的，面完让回去等通知。本来以为没戏了。后又通知2面，所属部门负责人和另一个部门负责人，2个人一起面的。面完又没动静了，过了一周问人力啥原因也没给回。这2轮都至少半小时的面试时间，莫名其妙的折腾人啊","createdAt":"2026-01-04T17:48:20"}]