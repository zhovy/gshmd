[{"id":"01963de5-c946-738c-9b67-1df7fcc2acdd","parentId":null,"rootId":null,"fromId":1181,"content":"做激光的","createdAt":"2023-08-11T11:22:50"},{"id":"01963de5-c989-73a4-87fe-6b05a36c7f7f","parentId":null,"rootId":null,"fromId":3238,"content":"听君一席话如听一席话","createdAt":"2023-08-11T11:36:14"},{"id":"01963de5-c98d-7075-8df4-17fa14fdae8d","parentId":null,"rootId":null,"fromId":5726,"content":"兄弟你去了吗","createdAt":"2023-09-21T13:55:35"},{"id":"01963de5-c9d1-73b0-9068-3f8272e20c5f","parentId":null,"rootId":null,"fromId":535,"content":"我邦德的，你想问啥","createdAt":"2023-09-21T15:35:05"},{"id":"01963de5-ca15-712c-b023-84883aff4b1f","parentId":null,"rootId":null,"fromId":5726,"content":"我也想进去，不知道合不合适，可以加吗1582863271","createdAt":"2023-09-21T16:02:13"},{"id":"01963de5-ca1a-73f5-abbb-165fd24479cd","parentId":null,"rootId":null,"fromId":5381,"content":"加班情况怎么样？","createdAt":"2023-09-21T16:49:08"},{"id":"01963de5-ca23-718a-82a4-e3044beaa8cf","parentId":null,"rootId":null,"fromId":535,"content":"你看的是哪个岗位？海外还是国内？","createdAt":"2023-09-22T11:21:04"},{"id":"01963de5-ca68-72b1-82dc-02f3c7b17471","parentId":null,"rootId":null,"fromId":535,"content":"优缺点很明显，公司比较严格，上班必须穿工装，夏装和秋装，销售比较多，所以一般除了厂区的其他人的工装都是白衬衣，自己配西裤和黑鞋，五点半下班，但是分部门吧，有的比较卷就晚下班，下班就走也没人管，完成工作就行。每月15号发工资，只会提前不会延后，社保公积金济南最低，单双休，一周单休一周双休，公司人比较多有两千多人，所以肯定有事逼。公司因为各种制度都比较严格，所以有些高压线碰不得，碰到就开除，过节我是觉得比较抠，但是好的一点是公司不光给你一份过节礼也会你家里邮寄一份，还算有点温暖，其余的很多我也不知道你想问啥，就简单写几句，总的来说，还不错的公司，新厂区也在建，新闻上也可以搜到，实力还是有的，","createdAt":"2023-09-22T11:29:43"},{"id":"01963de5-caac-717e-a528-f6a70bc68204","parentId":null,"rootId":null,"fromId":6797,"content":"确实，我去年校招拿了软件开发的offer，由于个人毁约了，交完违约金立马就给解约了，办事效率非常高。就是心疼违约金5k，希望现在公司不会让我后悔","createdAt":"2024-02-28T09:12:32"},{"id":"01963de5-caf4-71d1-a454-0d1e3c57f7d3","parentId":null,"rootId":null,"fromId":5913,"content":"哥们啥学历啥技术栈","createdAt":"2024-02-28T09:25:23"},{"id":"01963de5-caf8-713a-ae39-545252e04950","parentId":null,"rootId":null,"fromId":535,"content":"这里重销售，销售为主，只能说这里除了按时发工资，有年终奖之外，其余一无是处，而且我的领导很sb，是我从业这些年来见过最恶心的一只舔狗，对外唯唯诺诺，对内重拳出击，无能力无本事。我待够了，精神内耗严重，能接受pua的人就来。","createdAt":"2024-02-28T09:39:52"},{"id":"01963de5-ca1f-702f-83c6-44d5c2762e10","parentId":null,"rootId":null,"fromId":6797,"content":"邦德开发加班严重不，里面的人卷不卷呀","createdAt":"2024-03-07T20:07:22"},{"id":"01963de5-cb40-71e2-afab-b80b98340177","parentId":null,"rootId":null,"fromId":23077,"content":"这公司软件开发岗位如何","createdAt":"2025-04-02T20:17:16"},{"id":"01963de5-cb86-72f3-af4c-5a9ca1a86d28","parentId":null,"rootId":null,"fromId":1722,"content":"看部门","createdAt":"2025-04-03T13:06:53"},{"id":"01975e57-661f-700f-88d3-4eaad75af65f","parentId":null,"rootId":null,"fromId":25001,"content":"哥们，哪个部门，我也出去了，加个QQ761416963","createdAt":"2025-06-11T17:34:35"}]