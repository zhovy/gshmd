[{"id":"01963df4-381c-738c-b1ee-8f2bba11cba6","parentId":null,"rootId":null,"fromId":880,"content":"如果这个银行的岗位类似编制，就回家。","createdAt":"2024-10-28T16:10:13"},{"id":"01963df4-3866-72b0-a15a-4670a8ad59d9","parentId":null,"rootId":null,"fromId":6334,"content":"这还用想啊，无脑银行","createdAt":"2024-10-28T16:12:25"},{"id":"01963df4-38ae-72d4-b223-8fec6c5185b7","parentId":null,"rootId":null,"fromId":21808,"content":"无脑银行啊,济南的运维有个鸡儿前途","createdAt":"2024-10-28T16:50:47"},{"id":"01963df4-38f7-71f2-8449-e0746c3db135","parentId":null,"rootId":null,"fromId":1401,"content":"要我的话肯定选回家","createdAt":"2024-10-28T16:51:15"},{"id":"01963df4-393c-73d0-9b57-3823cf293416","parentId":null,"rootId":null,"fromId":6517,"content":"不是，小县城里的银行 也有科技岗位吗？还真触及到知识盲区了","createdAt":"2024-10-28T17:00:50"},{"id":"01963df4-3981-717c-9d2a-d94b6d0799e9","parentId":null,"rootId":null,"fromId":6939,"content":"用脚指头选都是银行。","createdAt":"2024-10-28T17:02:49"},{"id":"01963df4-3a10-719a-aa52-a84a8a6ae2e1","parentId":null,"rootId":null,"fromId":3341,"content":"济南的运维也不是多强的东西啊。没有什么技术可言。 看你自己对钱的看法就行了","createdAt":"2024-10-28T17:37:59"},{"id":"01963df4-3a5e-718b-acde-1979f696724a","parentId":null,"rootId":null,"fromId":5954,"content":"如果你能力超强，想成就一番事业，恰好有个好领导带着你发展，那就选择济南运维吧。（但是确实应该换成北上广啊，济南这个选择太LOW了）岁数随着越来越大，在济南如果能力不强有没有人脉，还背井离乡的，要是那时候想回老家那可费劲了。离家近多好啊，工作有稳定，岁数越来越大，可以照顾照顾父母啊，走走亲戚，从小长起来的地方，多好啊。房子也不用太大压力。 这两个方向，你可以自己选择一下。我感觉大部分人都会选回老家的。","createdAt":"2024-10-28T18:13:49"},{"id":"01963df4-3aa5-737f-b8ea-e3ccfd50f69d","parentId":null,"rootId":null,"fromId":3785,"content":"给你20万还是你掏20万？","createdAt":"2024-10-28T18:54:37"},{"id":"01963df4-3aeb-7307-ad60-3cb0849a648b","parentId":null,"rootId":null,"fromId":21427,"content":"家里拿20多W 进银行科技岗（掏钱）","createdAt":"2024-10-29T09:24:03"},{"id":"01963df4-3af0-7061-959a-cb5b765615e2","parentId":null,"rootId":null,"fromId":22046,"content":"现在都20万了，我靠","createdAt":"2024-10-29T09:24:36"},{"id":"01963df4-3b35-717a-b0e5-ad54ce84e7a2","parentId":null,"rootId":null,"fromId":21427,"content":"县城里现在还是有很多 拿钱买岗位的","createdAt":"2024-10-29T09:26:14"},{"id":"01963df4-3b79-70d9-a2bf-636788e0aead","parentId":null,"rootId":null,"fromId":5913,"content":"小县城哪有什么科技岗，能接受当柜员就小县城","createdAt":"2024-10-29T11:09:53"},{"id":"01963df4-3bbd-704a-ab2d-2872b3fbb56a","parentId":null,"rootId":null,"fromId":5913,"content":"银行工资很少，自己要再考虑考虑，但是稳定，女生的话推荐银行，自己能力不咋样也推荐银行","createdAt":"2024-10-29T11:10:51"},{"id":"01963df4-3bc2-73b5-906c-19c8306bf569","parentId":null,"rootId":null,"fromId":1591,"content":"回家，济南运维好的只有去浪潮，但是浪潮运维是一天白班一天夜班","createdAt":"2024-10-30T22:34:23"},{"id":"01963df4-38f3-72ca-ab90-f0c9a3e51285","parentId":null,"rootId":null,"fromId":267,"content":"。。。好像真的没啥前途","createdAt":"2024-11-07T08:54:06"},{"id":"01963df4-3c07-71e9-8d8a-47c54e5f365c","parentId":null,"rootId":null,"fromId":2408,"content":"你是有熟人啊，还是什么所谓的付费安置就业？如果是后者，我建议你马上报警","createdAt":"2024-11-07T09:37:36"},{"id":"01963df4-3c50-7060-9082-3002894641f2","parentId":null,"rootId":null,"fromId":21511,"content":"都几把啥也不懂  小县城银行哪有什么科技岗位","createdAt":"2024-11-07T09:39:48"},{"id":"01963df4-3c9d-73f7-b9e5-4eda521718f7","parentId":null,"rootId":null,"fromId":352,"content":"我好像也面临这个问题，如果是地市银行那也许就回去了，但是是县城，现在在济南做产品经理，薪水还凑合，去银行肯定就没这薪水了","createdAt":"2024-11-07T12:08:12"}]