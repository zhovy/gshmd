[{"id":"01963df4-88f7-720c-aa0e-665d94e16a05","parentId":null,"rootId":null,"fromId":2408,"content":"这玩意8000我也不要","createdAt":"2024-11-09T22:43:48"},{"id":"01963df4-8944-71e3-b3a5-65dc0aa53d5b","parentId":null,"rootId":null,"fromId":267,"content":"问了同事们，没有要的","createdAt":"2024-11-10T07:29:07"},{"id":"01963df4-893b-712a-ad9a-4f7dd674eec5","parentId":null,"rootId":null,"fromId":21873,"content":"我看贝壳是一万一平米，不过不太好卖，半年没成交量","createdAt":"2024-11-10T11:35:07"},{"id":"01963df4-8987-711e-bfaf-8197ff5a81dd","parentId":null,"rootId":null,"fromId":4087,"content":"济南现在拆迁不给钱 给房票 你还得倒贴钱 说不准还要贷款才能买房  房地产行业完成历史使命了 坑完老百姓了。","createdAt":"2024-11-10T12:16:01"},{"id":"01963df4-89cb-70dd-a7ce-8e577294ec19","parentId":null,"rootId":null,"fromId":5987,"content":"能卖就卖，拆迁后面给啥都不好说，不过这种老破小未必能卖上钱了","createdAt":"2024-11-11T08:54:09"},{"id":"01963df4-8a0f-70b5-b94c-b8b69e647862","parentId":null,"rootId":null,"fromId":3341,"content":"不急用钱就挂着吧","createdAt":"2024-11-11T09:29:02"},{"id":"01963df4-8a54-7316-8317-9821e352b0dd","parentId":null,"rootId":null,"fromId":21563,"content":"现在二手房挂牌量很高了，济南得有小10万套了吧，成交周期也很长，基本都是以价换量，价格不够低，应该很难吸引到买家，你就算挂上了价格不合适也很难卖掉感觉，除非舍得割肉卖也得碰运气，还有拆迁的话，会不会只给房票不给钱了啊。","createdAt":"2024-11-11T09:54:51"},{"id":"01963df4-8a98-7090-9fc7-a12babebe574","parentId":null,"rootId":null,"fromId":6344,"content":"哪个小区，我就在那块住，我看有没有拆的可能","createdAt":"2024-11-11T10:00:42"},{"id":"01963df4-8aeb-7026-b6c6-fc3e648e5eec","parentId":null,"rootId":null,"fromId":3450,"content":"等拆迁吧,没人要,我房子挂2年了没成交","createdAt":"2024-11-11T10:49:55"},{"id":"01963df4-8b3e-7014-b962-fdfedb062889","parentId":null,"rootId":null,"fromId":4140,"content":"你看看林老师卖的老破小都多少钱成交的，单价五千左右基本上，装修好点的六千左右","createdAt":"2024-11-11T10:57:01"},{"id":"01963df4-8b8a-736c-b6f9-1d4a7a7005c9","parentId":null,"rootId":null,"fromId":1372,"content":"能卖就卖了。你也是年轻人，问下自己，你愿意住这种老破小吗？你不愿意，别人也不会愿意。","createdAt":"2024-11-11T14:25:37"},{"id":"01963df4-8b31-727f-9b5e-94165b5bf754","parentId":null,"rootId":null,"fromId":1376,"content":"那说明降的不到位","createdAt":"2024-11-11T15:40:59"},{"id":"01963df4-8c1d-7107-8297-974b94403af1","parentId":null,"rootId":null,"fromId":1376,"content":"我不听任何人说，我只看数据，房子属性是居住，长期来看人口负增长严重，人口老龄化严重，你觉得有多少人会按你的思路接手呢，要是你你买吗","createdAt":"2024-11-11T15:44:39"},{"id":"01963df4-8b35-734e-b71b-7ee7ce0d3997","parentId":null,"rootId":null,"fromId":1376,"content":"楼房很少有拆迁的，太不划算了，对于各方势力而已都不是很好的解决方案，明明可以继续卖地盖房，为什么要拆这种市区的，施工不好施工，赔偿不好协调，楼房和平房可不一样，同样的面积，赔给平房的可能是两三家，赔给楼房的那是几十家，拆迁比涨价我觉得还不靠谱","createdAt":"2024-11-11T16:59:31"},{"id":"01963df4-8b3a-715c-841e-bbc1a61e733c","parentId":null,"rootId":null,"fromId":1376,"content":"留在手里祖传吧","createdAt":"2024-11-11T17:00:11"},{"id":"01963df4-8c65-7351-bad4-3210c2262f56","parentId":null,"rootId":null,"fromId":2428,"content":"我有俩老破小。卖不上价了，不过我觉得这个价也没卖的必要了。问题是卖了干嘛呢，急用钱吗","createdAt":"2024-11-12T16:42:40"},{"id":"01963df4-8ae2-726d-a245-feb78b9be186","parentId":null,"rootId":null,"fromId":21873,"content":"小纬北路，铁道北街的职工宿舍","createdAt":"2024-11-12T22:41:51"},{"id":"01963df4-8cab-72fc-8bb6-9ab35ec6d820","parentId":null,"rootId":null,"fromId":21873,"content":"倒也不是急用钱吧，可能是想着换成钱存银行里比守着个老房子靠谱","createdAt":"2024-11-12T22:42:57"},{"id":"01963df4-8ae7-7005-b01b-958e0e5b2212","parentId":null,"rootId":null,"fromId":6344,"content":"留着吧，反正又卖不价，据说济泺路以东、北园大街以南要划给历下","createdAt":"2024-11-13T08:48:02"},{"id":"01963df4-8b82-7100-ba74-0b27a78a8bc7","parentId":null,"rootId":null,"fromId":267,"content":"刚看了牛旺庄老破小，报九千多点","createdAt":"2024-11-13T09:12:57"},{"id":"01963df4-8b86-7016-bd0b-5f0186fe4bea","parentId":null,"rootId":null,"fromId":267,"content":"有些中介报的挺高","createdAt":"2024-11-13T09:13:19"},{"id":"01963df4-8caf-7044-8af4-75bd819d90a3","parentId":null,"rootId":null,"fromId":22028,"content":"以后房价还会涨？？？","createdAt":"2024-11-13T10:53:34"},{"id":"01963df4-8940-70cc-b4ac-6555a50f1360","parentId":null,"rootId":null,"fromId":7467,"content":"贝壳的价格有水分啊，我现在住的老破小贝壳九千左右，这几天房东买房，我私下问中介楼层好点的六千，边户顶楼啥的五千","createdAt":"2024-11-26T13:41:48"}]