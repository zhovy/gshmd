[{"id":"01963dd9-e5eb-7392-88cd-249ecde41f38","parentId":null,"rootId":null,"fromId":584,"content":"同问","createdAt":"2022-06-15T16:29:07"},{"id":"01963dd9-e634-7057-b296-8c57a96666e3","parentId":null,"rootId":null,"fromId":522,"content":"之前在德亨大厦工作过，身边同事就是浩鲸的，都是华为的外包，加班没有加班费，发版本的时候需要通宵，我当时评平均一个月通宵两次，工作强度很大，如果有其他选择，不要选择外包，如果为了糊口进了外包，短时间内一定要跳出来","createdAt":"2022-06-16T07:27:09"},{"id":"01963dd9-e67b-70db-9c7c-c1b7605cd378","parentId":null,"rootId":null,"fromId":228,"content":"我也是德亨干过","createdAt":"2022-06-16T18:17:30"},{"id":"01963dd9-e6c4-70b3-a514-507183608d2d","parentId":null,"rootId":null,"fromId":2211,"content":"别来  我现在就在德亨","createdAt":"2022-11-16T22:02:24"},{"id":"01963dd9-e709-72da-af4f-4a486bf73b8c","parentId":null,"rootId":null,"fromId":4016,"content":"想去德亨，离家近","createdAt":"2023-07-12T23:10:30"}]