[{"id":"01989656-5c70-73f5-88df-74e745c52b27","parentId":null,"rootId":null,"fromId":6580,"content":"是在美莲广场那吗，之前面试过，觉得很不正规","createdAt":"2025-08-11T07:34:58"},{"id":"0198968f-e905-717b-a2de-896fb1802ba2","parentId":null,"rootId":null,"fromId":23910,"content":"不签合同就劳动仲裁","createdAt":"2025-08-11T08:37:50"},{"id":"01989693-5a11-71dc-a12c-e0496d499b1b","parentId":null,"rootId":null,"fromId":21267,"content":"假如刘姓总监和张玉叶他家人出车祸了，他俩还有心思祸害员工吗","createdAt":"2025-08-11T08:41:36"},{"id":"019896ef-1dce-72cd-878b-7883938e1045","parentId":null,"rootId":null,"fromId":6631,"content":"额，去过。当时和我说他们招兼职，去干了一周，感觉氛围有点压抑。就跑了，原来干完一个模块也会让人滚蛋儿呀。我还以为干完一个会接着又其他活呢。","createdAt":"2025-08-11T10:21:49"},{"id":"01989712-0986-727e-8c57-348de81f7a87","parentId":null,"rootId":null,"fromId":4321,"content":"现在这个公司多少人呀，很久以前干过一段时间，不知道现在公司挣钱吗","createdAt":"2025-08-11T10:59:58"},{"id":"01989715-01d5-70b8-873d-aa994f01f979","parentId":null,"rootId":null,"fromId":4321,"content":"你什么时候去的，当时公司多少人？","createdAt":"2025-08-11T11:03:13"},{"id":"01989ff0-9501-738a-9745-e2c06b874f2a","parentId":null,"rootId":null,"fromId":269,"content":"骗子公司 都别去 一点不正规","createdAt":"2025-08-13T04:20:00"},{"id":"0199142c-5f66-7146-9f71-671612a2130e","parentId":null,"rootId":null,"fromId":2287,"content":"解忠亮是哪位？","createdAt":"2025-09-04T18:01:16"},{"id":"0199db2f-ec6e-73b1-8b29-b282e9e71f47","parentId":null,"rootId":null,"fromId":24508,"content":"是公司的老板","createdAt":"2025-10-13T09:29:35"}]