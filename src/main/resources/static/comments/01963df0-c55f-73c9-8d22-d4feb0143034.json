[{"id":"01963df0-c5db-730e-9dbc-056e8bb7871b","parentId":null,"rootId":null,"fromId":4261,"content":"你但凡写个首字母缩写也比这个Tao某某强啊","createdAt":"2024-06-17T10:38:28"},{"id":"01963df0-c61e-7171-add8-5aa27d988361","parentId":null,"rootId":null,"fromId":7511,"content":"满足你\nTYM","createdAt":"2024-06-17T10:44:44"},{"id":"01963df0-c627-7121-adb1-510cee7bae54","parentId":null,"rootId":null,"fromId":2408,"content":"顶","createdAt":"2024-06-17T11:14:43"},{"id":"01963df0-c66b-739d-a058-eaa4f5cc587c","parentId":null,"rootId":null,"fromId":1889,"content":"名字都不打？不还是有受害者去应聘么。真的是为大家好，就打全名。","createdAt":"2024-06-17T11:25:23"},{"id":"01963df0-c6af-701a-b819-bd0ef2949a4b","parentId":null,"rootId":null,"fromId":7511,"content":"已经被开了，需要注意的是近期招人的公司","createdAt":"2024-06-17T11:31:39"},{"id":"01963df0-c6b3-72f6-ad6e-8f68473b48ea","parentId":null,"rootId":null,"fromId":1889,"content":"公司名字说出来也行，只要你评价的内容客观真实，就不用怕。","createdAt":"2024-06-17T11:32:46"},{"id":"01963df0-c6b7-7069-8bf8-bf3921a3f9d3","parentId":null,"rootId":null,"fromId":7511,"content":"你没看懂吗，这人已经被我司开了，我写出来只是给在济南工作的兄弟们提个醒，尤其是近期有招聘需求的","createdAt":"2024-06-17T11:44:01"},{"id":"01963df0-c622-73e4-ac47-e26f481a4786","parentId":null,"rootId":null,"fromId":330,"content":"陶渊明？？？","createdAt":"2024-06-17T12:11:53"},{"id":"01963df0-c6bc-729f-a8e7-ea0aae2759b9","parentId":null,"rootId":null,"fromId":3566,"content":"作为一个单纯吃瓜的人我想问一下就这种情况，都有实际证据了 报警举报了没，人被依法收到法律制裁了没？还有就是如果这个人这么玩，在公司瞎搞搞了多久？如果一搞搞了三四年，最后才被发现，那我只能说公司其他方面问题更大，给予了这部分人土壤，这个是客观事实。还有我要提醒一点，公司不可以泄露离职员工的信息，除非拿授权，比方说 入职新公司要背调；作为一个法律行业热心人士，提醒一下这位 HR，已经涉嫌违法了，如果造成员工损失员工有权利起诉，即便所说的全部为事实；","createdAt":"2024-06-17T15:46:50"},{"id":"01963df0-c700-71e9-9ab8-015828e2a984","parentId":null,"rootId":null,"fromId":7511,"content":"他能这么搞是因为济南公司他说了算，另外没有出现公司名称和人名，比脉脉的吐槽差得远","createdAt":"2024-06-17T17:58:31"},{"id":"01963df0-c706-7021-90da-5a59347b9987","parentId":null,"rootId":null,"fromId":1150,"content":"这1到7里面好几条但凡是真的也都让他吃牢饭了吧","createdAt":"2024-06-17T18:25:24"},{"id":"01963df0-c75b-73d0-a92c-ba9d2a8ac337","parentId":null,"rootId":null,"fromId":3566,"content":"我就是在疑惑这点啊，尤其是贪污公司奖金，这个要取证岂不是特别简单，人证--问一下该拿到奖金没拿到的员工 物证--银行汇款记录，这不妥妥的能进局子？包括吃回扣，直接报警啊，直接送去吃牢饭。孙宏斌不就被老柳送进去了？为啥这个人还又流到市场上以自由身份面试呢？奇怪，特别奇怪。","createdAt":"2024-06-17T18:42:49"},{"id":"01963df0-c764-7211-8303-e3052229d294","parentId":null,"rootId":null,"fromId":875,"content":"反向说，能忽悠也是一种能力的表现","createdAt":"2024-06-17T20:13:07"},{"id":"01963df0-c7b8-7225-8384-bf8cdb8bc35d","parentId":null,"rootId":null,"fromId":473,"content":"脉脉有链接嘛","createdAt":"2024-06-18T09:57:00"},{"id":"01963df0-c805-7314-be07-3938e2c0fae5","parentId":null,"rootId":null,"fromId":1238,"content":"这么多罪行怎么不把他送局子里 还在外面祸害别人","createdAt":"2024-06-18T10:01:54"},{"id":"01963df0-c75f-7059-85c1-c73b9b57a641","parentId":null,"rootId":null,"fromId":7511,"content":"你们投标是怎么投的，项目是怎么拿的，应该不是百分百的合规吧，他是济南公司老大，这些事都是经他手办的，他拿这个要挟公司，那就只能跟他和平分手了","createdAt":"2024-06-18T16:53:01"},{"id":"01963df0-c849-7298-804a-a5ce6435db4d","parentId":null,"rootId":null,"fromId":875,"content":"外行领导内行，还能这么明目张胆，可见公司体制有多么不堪","createdAt":"2024-06-18T20:25:09"},{"id":"01963df0-c88c-7073-a0ac-e7830159bd81","parentId":null,"rootId":null,"fromId":3566,"content":"说不定这个人就是发帖子的 HR 自己招的 哈哈哈","createdAt":"2024-06-19T08:56:44"},{"id":"01963df0-c890-72e0-ab31-3a5e4f71a07b","parentId":null,"rootId":null,"fromId":1164,"content":"晟邦知享的？？","createdAt":"2024-06-19T14:15:57"},{"id":"01963df0-c8d8-7063-8af5-0bfccd08aad5","parentId":null,"rootId":null,"fromId":21429,"content":"这个帖子发的好啊","createdAt":"2024-07-19T21:40:54"},{"id":"01963df0-c8d4-717f-8533-d827b99ea191","parentId":null,"rootId":null,"fromId":21429,"content":"啥意思","createdAt":"2024-07-19T21:50:43"},{"id":"01963df0-c800-73d3-9f9f-fa6b12cfb1d4","parentId":null,"rootId":null,"fromId":21429,"content":"没有","createdAt":"2024-07-19T21:55:12"}]