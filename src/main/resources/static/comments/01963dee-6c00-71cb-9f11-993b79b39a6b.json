[{"id":"01963dee-6c6f-71a1-9b7e-bc0b45b71206","parentId":null,"rootId":null,"fromId":875,"content":"他多报水电费了，被戳穿了","createdAt":"2024-04-29T08:11:52"},{"id":"01963dee-6cb8-711d-b91d-9bdeacc3730d","parentId":null,"rootId":null,"fromId":875,"content":"12345上反馈。微信小程序还是公众号上有","createdAt":"2024-04-29T08:26:01"},{"id":"01963dee-6cfd-70eb-85eb-67b21097e5c9","parentId":null,"rootId":null,"fromId":1049,"content":"不是行规，我租的几次都退了，可能会扣点钱，清洁费之类的","createdAt":"2024-04-29T08:35:03"},{"id":"01963dee-6d41-73d4-91c1-5b38a5e55bcd","parentId":null,"rootId":null,"fromId":5408,"content":"我租的房子押金都退了","createdAt":"2024-04-29T08:45:43"},{"id":"01963dee-6d86-714c-9e86-21870ad42db7","parentId":null,"rootId":null,"fromId":4140,"content":"提前一个月说会退，你突然就退，属于你违约，人家不退正常，签合同的时候你都写进合同？","createdAt":"2024-04-29T09:19:17"},{"id":"01963dee-6dcf-7334-96cd-a1d69de95ae7","parentId":null,"rootId":null,"fromId":7242,"content":"你就是这个房东，还是你的理解能力有问题？通篇没有提到突然退情况。要是突然退的，房东肯定会拿这个说事，还用得着扯水电费吗？济南就因为有你这样的房东才会上新闻，全国出名。","createdAt":"2024-04-29T09:35:22"},{"id":"01963dee-6dd3-7033-b99e-767becd2458b","parentId":null,"rootId":null,"fromId":1385,"content":"sb","createdAt":"2024-04-29T09:49:27"},{"id":"01963dee-6e2d-73b7-b343-beb573566e76","parentId":null,"rootId":null,"fromId":7358,"content":"基本都这样，都配个钥匙，没事就给马桶塞两个小石头，交学费长脑子，大家一起交，一起长","createdAt":"2024-04-29T10:11:47"},{"id":"01963dee-6dde-7055-a647-0fe392d1b327","parentId":null,"rootId":null,"fromId":258,"content":"莫名其妙，你怎么知道他是突然退的？","createdAt":"2024-04-29T11:14:07"},{"id":"01963dee-6de2-7374-9a09-6b0f3f336586","parentId":null,"rootId":null,"fromId":6987,"content":"真煞笔","createdAt":"2024-04-29T11:24:19"},{"id":"01963dee-6de7-73f8-9fc4-9cc82bb10fb2","parentId":null,"rootId":null,"fromId":1889,"content":"烽火哥，回QQ群摸鱼吧，Bob们想你了","createdAt":"2024-04-29T13:13:22"},{"id":"01963dee-6deb-712f-9a50-d8ecfd64a401","parentId":null,"rootId":null,"fromId":4140,"content":"一群煞笔过得不如意在这，跳脚，好笑，怎么我租房子租金都退了，自己不在合同上写明白，现在在这跳脚，小丑","createdAt":"2024-04-29T13:15:20"},{"id":"01963dee-6def-7155-b353-2cabe56bf554","parentId":null,"rootId":null,"fromId":4140,"content":"《有的说合同不到期，扣押金》，睁眼瞎是吧，他自己说的没到期就要退，当初签合同为什么不写进合同退租事宜，自己当初不写怪人家不退，还在这跳脚，一看就没什么文化，而且还过得不如意，笑死","createdAt":"2024-04-29T13:19:18"},{"id":"01963dee-6df4-727d-806b-ccc18d4c1e42","parentId":null,"rootId":null,"fromId":925,"content":"哈哈，这SB被说破心事恼羞成怒了。还“烧”，确实挺烧，这发烧没有200度，都说不出这话来。这文字水平和表达能力，看你这三段话，就知道脑袋里装了个什么玩意儿。你不是黑房东能跑出来给黑房东说话？","createdAt":"2024-04-29T15:14:04"},{"id":"01963dee-6df8-7243-9ac6-a9c3b291683f","parentId":null,"rootId":null,"fromId":4140,"content":"能碰上黑房东本身就说明你是个煞笔，连签合同最基本的东西都不写好，还在这吐槽，真是煞笔一个，为什么我碰不上，菜就多练，过得不好就承认，屌丝","createdAt":"2024-04-29T15:19:54"},{"id":"01963dee-6dfc-71d5-bfc5-9c17b9aced31","parentId":null,"rootId":null,"fromId":4174,"content":"不管谁骂烽火弟，我三五八团都得帮帮场子，有种群里说话","createdAt":"2024-04-29T15:26:22"},{"id":"01963dee-6e72-72ab-a3ae-ceb1651cffa3","parentId":null,"rootId":null,"fromId":267,"content":"别碰托管公司，变着花样坑人。","createdAt":"2024-04-29T15:41:27"},{"id":"01963dee-6e02-72b9-a032-09c270f7f832","parentId":null,"rootId":null,"fromId":6987,"content":"网络乐子人，你挺逗的，我宣布你以后就是这个网站的电子宠物了","createdAt":"2024-04-29T16:31:53"},{"id":"01963dee-6e0b-7096-ab12-e4a58e900813","parentId":null,"rootId":null,"fromId":4140,"content":"因为脑子正常的人，在退租之前一个月就会给房东打招呼，看看能不能退，不能退就押金抵房租了，多住一个月再找房子，现在房东不退，楼主在这问，肯定就是一月个之前就没问，这不就是突然退房吗，果然不是每个人都有脑子，理解你们毕竟你们要是都能想到了，你也不能这么大戾气在网络上发泄哈哈哈，对你们要求太苛刻了，你们就该吃亏，没脑子，做事也不提前考虑，一个字该","createdAt":"2024-04-29T17:18:01"},{"id":"01963dee-6e13-72c0-84bc-86c8167f7866","parentId":null,"rootId":null,"fromId":7257,"content":"这里问个问题，怎么还能碰上这种SB。\n退租也好，到期也好，我都会至少提前一个月联系房东。联系的时候一点事没有，交接也没问题，就是要押金的时候才开始说这些理由。\n合同不到期也是房东的理由。合同签了一年，第二年找房东续签的时候，房东说还是按那份合同走就是。大约半年后提前跟房东说退租，退租后找房东要押金，房东说我没到期，理由是没再满一年。\n租房这么多年，还没有见过哪份租房合同是由房客写的。你自己写合同，更加暴露了自己黑房东的事实。都是你写合同黑房客，恶心别人，自己当然碰不上这么恶心的事了。\n无论多长的一段话连个句号都没有，还写合同。呵呵，还写合同！跑这里冒充文化人？\n在这里狂犬吠日，是你的无耻给你的优越感吗？","createdAt":"2024-04-29T20:14:38"},{"id":"01963dee-6e18-73ed-b879-542de8be6b8c","parentId":null,"rootId":null,"fromId":4140,"content":"hh，自己傻逼就傻逼，我每次签租房合同我都会加上补充条款，你自己没法律意识，你自己傻逼，别把大多数人拉下水，我要是黑房动我也不退你押金，因为你太蠢了，蠢逼的钱活该被坑，打官司你也该赔，你自己没有法律意思还在这叫，懂什么叫合同吗，傻逼","createdAt":"2024-04-30T08:54:03"},{"id":"01963dee-6e1c-702d-b4fc-151a60f96cfc","parentId":null,"rootId":null,"fromId":5913,"content":"烽火哥不是啥好人啊","createdAt":"2024-04-30T09:06:18"},{"id":"01963dee-6e21-7059-a340-745657871e8c","parentId":null,"rootId":null,"fromId":7273,"content":"这个人人品是真拉，属疯狗的，逮谁咬谁。嘴闲就去舔马桶，少在这里叭叭。","createdAt":"2024-04-30T09:41:37"},{"id":"01963dee-6e25-7181-abd8-f2e11cb42b42","parentId":null,"rootId":null,"fromId":4174,"content":"烽火哥又出来指点江山了，你他娘的干点活吧","createdAt":"2024-04-30T16:07:21"},{"id":"01963dee-6eb8-736f-9032-39fac6c89934","parentId":null,"rootId":null,"fromId":1111,"content":"拨打12345投诉一下。","createdAt":"2024-04-30T16:58:17"},{"id":"01963dee-6e29-71b4-b12e-ef3a172b469b","parentId":null,"rootId":null,"fromId":2078,"content":"烽火哥就是我的摸鱼电子宠物，整天当小丑看哈哈哈哈哈，还觉得自己挺聪明，一条自以为是的狗罢了","createdAt":"2024-05-03T21:43:38"}]