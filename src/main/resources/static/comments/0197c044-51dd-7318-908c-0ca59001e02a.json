[{"id":"0197c39e-dffa-70f4-a6bc-827d8184e559","parentId":null,"rootId":null,"fromId":22186,"content":"2坨屎你问哪个好吃，这怎么选择呢","createdAt":"2025-07-01T09:34:18"},{"id":"0197c3ee-89a0-7185-a628-37391ca59870","parentId":null,"rootId":null,"fromId":24824,"content":"楼上说是两坨屎，那也是很多人想吃吃不上的，济南遍地都是屎","createdAt":"2025-07-01T11:01:19"},{"id":"0197c409-089c-737e-a78b-d016a4256992","parentId":null,"rootId":null,"fromId":6091,"content":"确实啊，我现在的按一楼说的屎都不如","createdAt":"2025-07-01T11:30:15"},{"id":"0197c410-4441-722a-abf3-d762426d23e3","parentId":null,"rootId":null,"fromId":25332,"content":"目前正准备从一坨屎跳槽到另一坨屎","createdAt":"2025-07-01T11:38:09"},{"id":"0197c431-ffba-7104-b8dc-ec46b81280f0","parentId":null,"rootId":null,"fromId":25351,"content":"相对来说哪个好点呢","createdAt":"2025-07-01T12:15:00"},{"id":"0197c432-27c4-730c-856b-7e12620e01ca","parentId":null,"rootId":null,"fromId":25351,"content":"哪里到哪里啊","createdAt":"2025-07-01T12:15:10"},{"id":"0197c45c-9ed2-70d0-87b5-ffce33d69539","parentId":null,"rootId":null,"fromId":24615,"content":"如果加班强度都差不多的话，我投浪潮一票，毕竟名声大","createdAt":"2025-07-01T13:01:33"},{"id":"0197c4a8-fbe2-7119-89f0-8be159de0ea2","parentId":null,"rootId":null,"fromId":5689,"content":"待遇差不多，而且都不轻快，我感觉半斤八两，就找个离家近的吧。","createdAt":"2025-07-01T14:24:58"},{"id":"0197c52b-989f-72c0-accd-0a2c8acbed30","parentId":null,"rootId":null,"fromId":6939,"content":"都是996，云鼎吧，因为我在浪潮待过，所以我选云鼎。","createdAt":"2025-07-01T16:47:38"},{"id":"0197c9ea-dba8-7341-b0f5-ae30d71ab5dc","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-07-02T14:55:01"},{"id":"0197c9fa-585a-720e-8444-4d7fb6c3a145","parentId":null,"rootId":null,"fromId":25526,"content":"我记得云鼎的offer里工资是50%基本工资50%绩效，感觉套路有点深","createdAt":"2025-07-02T15:11:56"},{"id":"0197cacd-ec3b-711c-ad0f-70c3f1ee353a","parentId":null,"rootId":null,"fromId":1733,"content":"云鼎是996，怎么可能会周末双休，想多了。正式员工当牲口用，外包员工当叉车用。","createdAt":"2025-07-02T19:03:02"},{"id":"0197caef-d6c0-704a-a6e6-26e6d94025a4","parentId":null,"rootId":null,"fromId":22024,"content":"那你说出俩比屎强的来","createdAt":"2025-07-02T19:40:05"},{"id":"0197cdc4-4d20-7283-a4a6-67b0e1b25f32","parentId":null,"rootId":null,"fromId":22186,"content":"多了，兄弟你没呆过好公司吧","createdAt":"2025-07-03T08:51:23"},{"id":"0197cf45-4bbc-7349-982a-315d72a9f207","parentId":null,"rootId":null,"fromId":22024,"content":"你倒是说啊","createdAt":"2025-07-03T15:51:54"},{"id":"0197cf46-5f0b-7321-bf7f-ad1eeb0361a9","parentId":null,"rootId":null,"fromId":22024,"content":"既然都是屎了，那比屎强的有很多，你到是说啊，我看看强在哪","createdAt":"2025-07-03T15:53:05"},{"id":"0197cf9e-e5f6-713b-a2cf-61613bd240d7","parentId":null,"rootId":null,"fromId":22186,"content":"俺不说，俺现在摸鱼的很，被有心人举报了可不好","createdAt":"2025-07-03T17:29:46"},{"id":"0197cfa3-fe26-7066-a5d3-c76d3e399040","parentId":null,"rootId":null,"fromId":22186,"content":"周末双休，单休都不错了，一天还让你加班","createdAt":"2025-07-03T17:35:20"},{"id":"0197cfa5-286f-724e-864b-60afa2ce66f4","parentId":null,"rootId":null,"fromId":22186,"content":"我在字节，你来吧，历下区","createdAt":"2025-07-03T17:36:36"},{"id":"0197d319-8a93-738c-a889-dd7e16f0d119","parentId":null,"rootId":null,"fromId":22024,"content":"待遇也不高啊，说了半天就憋出一个来，既然都是屎了，说出几十个比屎好的不过分吧，如果连十个都说不出来，那不说明大部分都不如屎，还是你在胡说","createdAt":"2025-07-04T09:42:35"},{"id":"0197d31a-ca88-72d0-9488-4759d36c6ebd","parentId":null,"rootId":null,"fromId":22024,"content":"云鼎可能这样，浪潮顶多让你周六去个半天也不强制，浪潮很多都是双休","createdAt":"2025-07-04T09:43:57"},{"id":"0197d473-0635-7125-adb6-355f1847c9b8","parentId":null,"rootId":null,"fromId":22186,"content":"兄弟真不想跟你杠，你想进都进不来，待遇也不高？你把工资截图发出来我看看，都失业多久了，有时间在这杠，不如找找工作","createdAt":"2025-07-04T15:59:57"},{"id":"0197d4af-043e-7298-a871-ac4c6331e50b","parentId":null,"rootId":null,"fromId":22024,"content":"那你先把工资截图发出来我看看，我没失业","createdAt":"2025-07-04T17:05:29"},{"id":"0197d4af-ab10-704c-99e7-f62742b2d822","parentId":null,"rootId":null,"fromId":22024,"content":"而且你也忽略了我的其他问题，你说不出来几个，就说不想跟我杠","createdAt":"2025-07-04T17:06:11"},{"id":"0197d4b3-9323-70c9-8ffc-6176263cc03f","parentId":null,"rootId":null,"fromId":22024,"content":"我搜的是不是很高，起码没有你们说的和屎的差别那么大，而且还有一个观点就是即使你所在公司待遇比这俩屎高，但是要有很多公司待遇比这俩高才能证明它真的是两坨屎，因为你一开始就说很多，当然你可以忽略，这是你的自由","createdAt":"2025-07-04T17:10:27"},{"id":"0197dcda-917a-7315-941e-2a55675df8d0","parentId":null,"rootId":null,"fromId":24428,"content":"老哥真是个人才，笑死我了","createdAt":"2025-07-06T07:10:01"},{"id":"0198c60c-48b6-7325-9116-bd6a172943f7","parentId":null,"rootId":null,"fromId":21986,"content":"快拉倒吧。浪潮现在依然有好多单位部门，周六强制加班","createdAt":"2025-08-20T13:55:50"},{"id":"019a4834-e6a3-7010-a6ab-f6e669c1bbf0","parentId":null,"rootId":null,"fromId":5689,"content":"我3年前从云鼎逃出来的（正式工），如果能忍受996的码农，可以过去，福利确实是可以的。但论时薪，比不上大部分的IT公司。","createdAt":"2025-11-03T13:33:37"},{"id":"019a483c-b396-712f-b1e5-1cc5f5ff45af","parentId":null,"rootId":null,"fromId":22250,"content":"2坨屎你问哪个好吃，这怎么选择呢","createdAt":"2025-11-03T13:42:09"}]