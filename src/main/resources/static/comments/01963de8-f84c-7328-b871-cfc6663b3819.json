[{"id":"01963de8-f8b4-7025-b2e4-73e272c89d41","parentId":null,"rootId":null,"fromId":5859,"content":"毕业两年在济南就能拿到11，而且还算轻松，说明公司很不错了！ 在上海16K不如济南11k舒服。南京的还不错，大公司 可以去镀镀金。建议做个规划，在南京工作几年？，将来打算在哪定居？","createdAt":"2023-10-13T16:57:16"},{"id":"01963de8-f8f9-723f-8372-8cb21a9ab140","parentId":null,"rootId":null,"fromId":5527,"content":"在济南能拿到11K主要是因为有出差补助，一个月3000多。目前的规划是去南京那家公司待一两年卷一卷，再往其他互联网公司跳。至于以后在哪定居没想过，现在只想赚钱攒钱，等钱攒多了再考虑买房定居吧","createdAt":"2023-10-13T17:02:59"},{"id":"01963de8-f8fe-715e-a893-9cab891a9a28","parentId":null,"rootId":null,"fromId":1401,"content":"不推荐外包，建议选南京的公司，学习一两年之后跳槽进更大的互联网公司","createdAt":"2023-10-13T17:53:48"},{"id":"01963de8-facb-73a7-9a7b-dd18d5414bd6","parentId":null,"rootId":null,"fromId":875,"content":"建议南京，不只是工资上的涨幅，出去也能开拓视野，以后留南京，去杭州都好说","createdAt":"2023-10-13T18:16:11"},{"id":"01963de8-fb0f-7038-9e04-10a581ea6eaa","parentId":null,"rootId":null,"fromId":2407,"content":"都是线上面试的吗?","createdAt":"2023-10-16T13:09:01"},{"id":"01963de8-fb54-7003-ab3c-1d437f5e55e1","parentId":null,"rootId":null,"fromId":5527,"content":"是啊  直接先问hr能不能线上面试  能线上面试的就面不能线上的就pass","createdAt":"2023-10-16T14:19:26"},{"id":"01963de8-fb59-7109-85a6-052dadf4d645","parentId":null,"rootId":null,"fromId":2407,"content":"那挺好，之前在上海被裁员，国庆后在济南面了一周没offer，回老家线上面了","createdAt":"2023-10-16T17:05:50"},{"id":"01963de8-fb5d-7383-ad0c-7a1f8dbd5fd5","parentId":null,"rootId":null,"fromId":2407,"content":"线上面的公司多吗？","createdAt":"2023-10-16T17:06:09"}]