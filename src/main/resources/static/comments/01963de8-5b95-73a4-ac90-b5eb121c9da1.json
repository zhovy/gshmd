[{"id":"01963de8-5bfb-73b8-9f8b-11155135b6fb","parentId":null,"rootId":null,"fromId":3749,"content":"要么忍，要么滚！\n大千世界，不能要求每个人都和你同频！","createdAt":"2023-09-18T18:36:28"},{"id":"01963de8-5c4b-7346-a7b6-4374e4e69540","parentId":null,"rootId":null,"fromId":933,"content":"你在暗指时代哥是吧","createdAt":"2023-09-19T08:40:36"},{"id":"01963de8-5c41-7008-8b0f-e110ebffb472","parentId":null,"rootId":null,"fromId":576,"content":"是你要顺应环境，而不是你要心烦某个人。地球不是因为你自己在转。每个人都是一种思想。","createdAt":"2023-09-19T08:41:32"},{"id":"01963de8-5c97-7357-85e8-d449ff43faa6","parentId":null,"rootId":null,"fromId":1932,"content":"不能跟我游总同频，那你就想想自己的出路，手动狗头","createdAt":"2023-09-19T08:52:54"},{"id":"01963de8-5cdd-73ef-8f72-237b410971e7","parentId":null,"rootId":null,"fromId":933,"content":"小战，我是游总，你来下我办公室","createdAt":"2023-09-19T09:06:08"},{"id":"01963de8-5ce2-73a6-8ae9-79f97ceb5fdc","parentId":null,"rootId":null,"fromId":3183,"content":"反思反思自己，跟游总同频了吗？","createdAt":"2023-09-19T09:11:33"},{"id":"01963de8-5c46-7062-95e6-4aa404ac92c7","parentId":null,"rootId":null,"fromId":5724,"content":"你肯定不在群里","createdAt":"2023-09-19T09:11:47"},{"id":"01963de8-5d30-7223-b86d-e0feb6d1707b","parentId":null,"rootId":null,"fromId":2572,"content":"跟游总同频？游总上班，是坐在单独的办公室，玩着手机吹着空调喝大茶。我们是坐在大通铺玩命干活儿，这能同频吗？","createdAt":"2023-09-19T09:22:17"},{"id":"01963de8-5d2a-7007-85fc-27626c489355","parentId":null,"rootId":null,"fromId":5724,"content":"游总是哪位？","createdAt":"2023-09-19T10:02:37"},{"id":"01963de8-5d77-7158-a6f2-dc68ae78028e","parentId":null,"rootId":null,"fromId":5732,"content":"还游总，就是个吹牛逼的屌丝","createdAt":"2023-09-19T10:10:25"},{"id":"01963de8-5c92-710e-8190-53b9cea5516c","parentId":null,"rootId":null,"fromId":5724,"content":"不是","createdAt":"2023-09-19T10:33:50"},{"id":"01963de8-5dbc-720c-a711-c45ad5545dc5","parentId":null,"rootId":null,"fromId":6434,"content":"你群主要是上班摸鱼用的。有几个技术水平比较强的哥们，他们发言的时候，群友一般也跟不上人家的话题，就只能唠自己的。","createdAt":"2024-01-08T11:30:09"}]