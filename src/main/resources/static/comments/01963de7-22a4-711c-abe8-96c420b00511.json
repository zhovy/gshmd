[{"id":"01963de7-2307-7163-839b-305b096aa356","parentId":null,"rootId":null,"fromId":3164,"content":"公司双休，工资不高但是不累，到点下班。","createdAt":"2023-08-30T08:09:48"},{"id":"01963de7-2350-7214-b5ab-26b607edbf77","parentId":null,"rootId":null,"fromId":875,"content":"几套房子，","createdAt":"2023-08-30T08:10:47"},{"id":"01963de7-2394-708e-a075-cfdd5ede0871","parentId":null,"rootId":null,"fromId":3801,"content":"项目很多但是你们交付不了是你们的问题，有这句就可以走了，如果因为回款问题拖欠个一两个月算正常，前提是领导要想法去解决这个问题，这样推卸责任我感觉公司好不了，建议还是早点走吧，然后要工资，不给的话走仲裁。","createdAt":"2023-08-30T08:13:26"},{"id":"01963de7-23dd-71eb-b5d8-f09a8d1ed778","parentId":null,"rootId":null,"fromId":875,"content":"不要跟领导谈感情，你跟人家共患难，人家发达的时候你跟着分一杯羹了嘛","createdAt":"2023-08-30T08:19:31"},{"id":"01963de7-2422-72b9-bacf-0f161ff121de","parentId":null,"rootId":null,"fromId":1037,"content":"跟上家公司那个烂情况一样，就知道画大饼，到最后把法人一换，仲裁都找不到人。每个人都欠了六七个月的工资，到现在都还没给。剩下那几个死猫烂狗的领导们，五个人注册了七八个公司，在那继续骗客户，客户都不知道这边连开发都请不起了。刚开始还抱点希望，觉得能发，再等等，结果后来发现就是无底深渊，只会越欠越多。所以趁着公司还在业赶紧离职，赶紧仲裁就完了。没必要听他们扯皮。","createdAt":"2023-08-30T08:42:43"},{"id":"01963de7-234b-70fc-ab59-f2176857b3af","parentId":null,"rootId":null,"fromId":3980,"content":"正常发工资可以 发不出来 多好 也是有隐患压","createdAt":"2023-08-30T08:47:31"},{"id":"01963de7-246a-7083-9d8a-7fc8e5b12967","parentId":null,"rootId":null,"fromId":875,"content":"工资托一周就得走了，还几个月","createdAt":"2023-08-30T08:55:01"},{"id":"01963de7-246f-73ff-9217-68c242562157","parentId":null,"rootId":null,"fromId":3164,"content":"我觉得不应该啊，这公司成立好久了，不像是那种骗子公司","createdAt":"2023-08-30T09:09:11"},{"id":"01963de7-247c-73c5-bacc-ccdd65ca90cf","parentId":null,"rootId":null,"fromId":1421,"content":"又套住了一个","createdAt":"2023-08-30T09:11:46"},{"id":"01963de7-2473-7037-bbb1-75c2e2b9416d","parentId":null,"rootId":null,"fromId":1037,"content":"我刚开始入职那家公司的时候，发工资挺准时，后期就完蛋了。我们也都想着等回款来了会给我们发的，结果那几个该死的领导，一有回款就出去大吃大喝。最开始也是觉得公司待我们不错，公司不景气不想在最缺人的时候走 ，可是最后呢，你善良他们善良了吗。","createdAt":"2023-08-30T09:24:52"},{"id":"01963de7-2478-72fb-b6e3-c6e9875ab140","parentId":null,"rootId":null,"fromId":1037,"content":"领导都把不回款怪到你们项目的问题上了，你还在这等啥呢。。。以后不发工资，他总会以这种借口来说事儿，他开公司为了钱又不是为了跟你谈感情。","createdAt":"2023-08-30T09:28:33"},{"id":"01963de7-24c0-72cb-919e-900ead662630","parentId":null,"rootId":null,"fromId":3705,"content":"不走等着喝西北风啊？","createdAt":"2023-08-30T09:54:44"},{"id":"01963de7-2507-71c0-accb-0dc8af0cacf4","parentId":null,"rootId":null,"fromId":1150,"content":"你报了公司名 大家才能帮着出主意  毕竟有些公司压根不能待着","createdAt":"2023-08-30T09:58:07"},{"id":"01963de7-2551-7320-9bc4-c3b2ab3f3b9a","parentId":null,"rootId":null,"fromId":21,"content":"楼主哪个公司啊，天建连吗","createdAt":"2023-08-30T10:07:09"},{"id":"01963de7-254c-7017-bbd2-62060b1e8265","parentId":null,"rootId":null,"fromId":3164,"content":"好聚好散啊，后面不发工资再报","createdAt":"2023-08-30T10:40:52"},{"id":"01963de7-2594-73a0-a8c2-a6bd7805768c","parentId":null,"rootId":null,"fromId":5519,"content":"这个公司是不是在长清","createdAt":"2023-08-30T11:17:02"},{"id":"01963de7-25d8-7177-b9d9-52b2327f0995","parentId":null,"rootId":null,"fromId":3164,"content":"高新","createdAt":"2023-08-30T11:58:43"},{"id":"01963de7-25dc-716b-bdf5-304d830296c5","parentId":null,"rootId":null,"fromId":629,"content":"瞳见啊\n","createdAt":"2023-08-31T10:48:43"},{"id":"01963de7-2620-70b0-b086-db17b04c8152","parentId":null,"rootId":null,"fromId":5529,"content":"别干了 小老弟","createdAt":"2023-08-31T14:25:55"},{"id":"01963de7-2665-73a6-a440-35acf17771a0","parentId":null,"rootId":null,"fromId":2935,"content":"哇哦，我是入职三个月发了一个半月，离职一个半月，才算是结清，你这是那个公司啊？这么牛逼","createdAt":"2023-09-01T23:52:42"},{"id":"01963de7-26ad-70be-8c0d-8f4cf512b72c","parentId":null,"rootId":null,"fromId":3879,"content":"某前央企子公司？","createdAt":"2023-09-05T08:56:16"},{"id":"01963de7-26f2-706a-a3e6-c34493aeee31","parentId":null,"rootId":null,"fromId":3164,"content":"更新：已经离职","createdAt":"2023-09-10T22:25:12"},{"id":"01963de7-273a-736e-9e3a-49351a59f0b5","parentId":null,"rootId":null,"fromId":1261,"content":"离职后发了吗","createdAt":"2023-09-10T22:52:03"},{"id":"01963de7-273e-724a-8660-106fbfa7c448","parentId":null,"rootId":null,"fromId":1398,"content":"那个公司？","createdAt":"2023-09-11T02:42:02"},{"id":"01963de7-2742-718e-bf45-7694324147ff","parentId":null,"rootId":null,"fromId":6797,"content":"请问是哪个公司？","createdAt":"2024-02-28T19:03:54"},{"id":"01963de7-2787-7181-b8f7-7fa82d81fd11","parentId":null,"rootId":null,"fromId":2815,"content":"济南按时发工资的都是好公司","createdAt":"2024-02-29T10:41:07"},{"id":"01963de7-27cb-71f3-affb-485c945abc8b","parentId":null,"rootId":null,"fromId":6274,"content":"瞳见科技吧","createdAt":"2024-02-29T15:17:59"}]