t":"北京挣的是项目奖，大额年终奖，全额缴纳社保公积金。\n济南挣的是死工资，200块公积金，吃的是大额回扣，产品咋样无所谓，关键是吃回扣，不管是拿项目还是干项目","createdAt":"2023-08-18T12:11:25"},{"id":"01963de6-83b4-72f7-b17a-764257771904","parentId":null,"rootId":null,"fromId":5403,"content":"几年三十一了，该结婚养孩子了。在济南也买好房子了。是回去还是北漂，求大佬指导。","createdAt":"2023-08-18T13:57:47"},{"id":"01963de6-822d-7042-a3f2-0e3b6ac492bb","parentId":null,"rootId":null,"fromId":1581,"content":"快回快回 别回来卷 在北京老老实实干着不好吗？回济南干啥\n","createdAt":"2023-08-18T16:20:28"},{"id":"01963de6-83ff-7004-bf62-644aaa1efb61","parentId":null,"rootId":null,"fromId":2935,"content":"回北京了","createdAt":"2023-08-18T21:28:22"},{"id":"01963de6-8445-73d3-b272-b1a539ce27a4","parentId":null,"rootId":null,"fromId":3596,"content":"北京现在咋样？","createdAt":"2023-08-18T21:46:29"},{"id":"01963de6-83b0-71a7-9320-e71d6e049e76","parentId":null,"rootId":null,"fromId":4165,"content":"有没有可能北京也有回扣","createdAt":"2023-08-19T09:05:05"},{"id":"01963de6-844a-7212-b53b-a9e4ef923c0e","parentId":null,"rootId":null,"fromId":875,"content":"济南就是考编，开饭馆，送外卖，没有别的出路","createdAt":"2023-08-19T18:30:12"},{"id":"01963de6-8493-7189-a107-778ff42fd91d","parentId":null,"rootId":null,"fromId":875,"content":"一级薪酬：无责任底薪，适用于门卫岗位，购买的是其工作时间。\n\n二级薪酬：无责任底薪+绩效+利润分红，适用于行政岗位，购买的是其工作质量。\n\n三级薪酬：无责任底薪+绩效+个人提成，适用于销售岗位，购买的其个人能力。\n\n四级薪酬：无责任底薪+绩效+个人提成+团队提成，适用于初级管理岗位如团队经理，购买的是其管理能力。\n\n五级薪酬：无责任底薪+绩效+个人提成+团队提成+部门分红，适用于中级管理岗位如部门总监，购买的是其管理能力和协调能力。\n\n六级薪酬：无责任底薪+绩效个人提成+超产奖+虚拟股分红，适用于高级管理岗位如副总经理，购买的是其管理能力和专业能力。\n\n七级薪酬：无责任底薪+绩效+个人提成+超产奖+虚拟股分红+股东分红，适合于总经理岗位，购买的是其管理能力和忠诚度。","createdAt":"2023-08-20T11:46:59"},{"id":"01963de6-84d7-71a7-be2c-3026cc0fa33d","parentId":null,"rootId":null,"fromId":875,"content":"程序员是哪个段位？？","createdAt":"2023-08-20T11:48:12"},{"id":"01963de6-84e0-71d0-bdf4-54656f3360a7","parentId":null,"rootId":null,"fromId":2890,"content":"别比比，没人拉着你不让你走，觉得不好赶紧滚回去","createdAt":"2023-08-20T16:50:40"},{"id":"01963de6-8532-722f-87ce-7584147bbfc6","parentId":null,"rootId":null,"fromId":875,"content":"北京吃一顿饭多少钱，济南吃一顿多少钱，北京租一个单间多少钱，济南租一个单间多少钱","createdAt":"2023-08-20T18:06:54"},{"id":"01963de6-83fb-7265-8925-8275df26d575","parentId":null,"rootId":null,"fromId":875,"content":"北京看上眼房子5万块，月薪两万五，济南看上眼房子两万五，月薪一万二，怎么选？","createdAt":"2023-08-20T18:09:13"},{"id":"01963de6-8525-73a0-b4a3-ce1c3048dbf4","parentId":null,"rootId":null,"fromId":875,"content":"不走，就这等着送外卖？","createdAt":"2023-08-20T20:29:02"},{"id":"01963de6-8231-7364-9610-a973972d74fe","parentId":null,"rootId":null,"fromId":875,"content":"吃屁了？","createdAt":"2023-08-20T21:27:31"},{"id":"01963de6-82dc-734d-992e-8ef68d44e997","parentId":null,"rootId":null,"fromId":875,"content":"单休，大小周，卷到35了干不动，送外卖开滴滴也不离开济南，卷死你们","createdAt":"2023-08-20T21:28:38"},{"id":"01963de6-8579-7003-bfdc-fb0cc9f509b5","parentId":null,"rootId":null,"fromId":3183,"content":"跟你说吧，除了租房其他基本是一样的，贵不了三块五块，甚至有的还便宜。\n\n租房我就按你济南1200，北京翻三倍，攒下的钱也比济南多多了。","createdAt":"2023-08-21T10:44:08"},{"id":"01963de6-857e-702b-a277-618beb7d4669","parentId":null,"rootId":null,"fromId":4142,"content":"两年经验本科在北京能要多少","createdAt":"2023-08-21T10:47:07"},{"id":"01963de6-85c3-7323-8b30-fee7f8bf23ca","parentId":null,"rootId":null,"fromId":4174,"content":"一万六左右吧","createdAt":"2023-08-21T10:57:39"},{"id":"01963de6-8529-73b6-b41b-2dd50eced4ab","parentId":null,"rootId":null,"fromId":4174,"content":"你搁这比比啥呢","createdAt":"2023-08-21T10:57:58"},{"id":"01963de6-84db-73a8-9d75-476715c4a71c","parentId":null,"rootId":null,"fromId":1261,"content":"超产奖是什么呢","createdAt":"2023-08-21T12:33:26"},{"id":"01963de6-85cd-71d1-97b0-a36b6915e3b6","parentId":null,"rootId":null,"fromId":21,"content":"包装5年经验  专升本 技术还算可以 去北京能要30K吗","createdAt":"2023-08-21T17:37:11"},{"id":"01963de6-8613-73dc-baa9-79a927f83dbf","parentId":null,"rootId":null,"fromId":1398,"content":"少了，至少50K","createdAt":"2023-08-21T17:41:36"},{"id":"01963de6-861c-730e-8262-787b00b128ce","parentId":null,"rootId":null,"fromId":1421,"content":"有啥后悔的，能一直北漂吗","createdAt":"2023-08-21T18:07:43"},{"id":"01963de6-8618-724f-b9c6-c47f6aac85c1","parentId":null,"rootId":null,"fromId":2436,"content":"哈哈哈","createdAt":"2023-08-22T08:46:48"},{"id":"01963de6-852d-732e-9296-fcf1e5d45c95","parentId":null,"rootId":null,"fromId":2890,"content":"不送外卖，有人把你绑这了吗？没人强留你，外面又那么好，为什么不赶紧走还在济南受虐？搞笑","createdAt":"2023-08-22T17:59:39"},{"id":"01963de6-8664-730f-a091-93c034150de6","parentId":null,"rootId":null,"fromId":5445,"content":"工作时间变成了，加班变多了，福利几乎没有了。。。","createdAt":"2023-08-23T11:23:16"},{"id":"01963de6-86ac-7191-8721-36b8d182deb3","parentId":null,"rootId":null,"fromId":3705,"content":"后悔个吊毛，后悔你有本事再回去啊。","createdAt":"2023-08-23T16:54:53"},{"id":"01963de6-86f3-7260-8b1c-da206447f792","parentId":null,"rootId":null,"fromId":4174,"content":"已经拿到offer 我的乖 别急哎","createdAt":"2023-08-23T17:16:14"},{"id":"01963de6-85c8-723a-a939-7b4b4b304941","parentId":null,"rootId":null,"fromId":4043,"content":"七年呢","createdAt":"2023-09-06T17:40:53"}]