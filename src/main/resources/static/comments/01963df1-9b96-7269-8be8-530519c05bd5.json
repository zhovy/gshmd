[{"id":"01963df1-9c02-7309-8dcc-5df176236bbe","parentId":null,"rootId":null,"fromId":3957,"content":"就这投了也不准搭理呢","createdAt":"2024-07-05T12:49:16"},{"id":"01963df1-9c46-710d-ace4-6c335d0ef299","parentId":null,"rootId":null,"fromId":3566,"content":"换个说法：现在还在找工作没稳定下来的都是啥烂人，挑挑拣拣剩下了你是不是就好理解了。","createdAt":"2024-07-05T13:49:51"},{"id":"01963df1-9c8a-71b9-9141-d8882fef39e0","parentId":null,"rootId":null,"fromId":6050,"content":"去你妈的，傻逼玩意，估计这傻逼就是上面的公司的狗","createdAt":"2024-07-05T16:38:37"},{"id":"01963df1-9ca4-7068-b4b1-2fe8e8848648","parentId":null,"rootId":null,"fromId":3566,"content":"不会是说到某人心坎里了把 哈哈哈","createdAt":"2024-07-05T17:29:37"},{"id":"01963df1-9c8f-712c-8f96-ac5e79c7bacc","parentId":null,"rootId":null,"fromId":267,"content":"外包公司的hr实际上就是销售啊","createdAt":"2024-07-07T12:34:16"},{"id":"01963df1-9ce9-726e-845d-ee8ddc7e9e9a","parentId":null,"rootId":null,"fromId":7550,"content":"我看了眼都震惊了，全tm外包，不夸张的说一个正经公司都没有，两年前还不是这样。","createdAt":"2024-07-08T12:58:10"},{"id":"01963df1-9c93-72f4-99c4-f1c35524e6de","parentId":null,"rootId":null,"fromId":403,"content":"啥年代了，还拿工作“稳定”来挤兑人，只有没什么本事的才对稳定有执念，这话包括体制内的人。在一个公司越“稳定”的，代表你越没竞争力。","createdAt":"2024-07-08T16:15:49"},{"id":"01963df1-9d2c-712c-8fda-d08d24ff3752","parentId":null,"rootId":null,"fromId":7746,"content":"正经公司都找外包 来做外协了?","createdAt":"2024-07-08T16:37:35"},{"id":"01963df1-9c97-71a8-a841-63f747966e86","parentId":null,"rootId":null,"fromId":6082,"content":"应该是上面公司的狗，还他妈乱咬人","createdAt":"2024-07-09T15:42:57"},{"id":"01963df1-9c9c-726c-946f-ce47fc0c2057","parentId":null,"rootId":null,"fromId":21053,"content":"你这种畜生真的不得好死","createdAt":"2024-07-11T08:52:45"},{"id":"01963df1-9ca0-73d3-bf7c-ceb2b7a58c08","parentId":null,"rootId":null,"fromId":4357,"content":"这年头还有工贼呢","createdAt":"2024-07-11T15:43:23"},{"id":"01963df1-9d31-708b-95bf-6b74be049187","parentId":null,"rootId":null,"fromId":3566,"content":"没有办法经济都啥样了，济南市1-6 月份卖地就卖了六七快递，挣了六七十个亿，五六月份连续两个月全国的财政收入增长都是负数；政府没钱了，不就是金主没钱了，济南有多少能直接面对消费者的公司，不都是以服务大企业大客户，政府类的为主。还招啥人啊，自己招投标都费劲巴拉的。","createdAt":"2024-07-11T20:51:19"}]