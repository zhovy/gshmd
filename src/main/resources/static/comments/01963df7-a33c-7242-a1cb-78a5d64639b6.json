[{"id":"01963df7-a39f-7048-bf46-c33aaa73bae2","parentId":null,"rootId":null,"fromId":2408,"content":"考公","createdAt":"2025-03-08T19:19:22"},{"id":"01963df7-a3e6-709c-893d-98b4e2defa93","parentId":null,"rootId":null,"fromId":875,"content":"人工智能不是选择题，而是生存题。要么与AI同进化，要么被AI淘汰","createdAt":"2025-03-08T21:51:29"},{"id":"01963df7-a429-73a4-9e20-d4053dcf388a","parentId":null,"rootId":null,"fromId":1398,"content":"牛啊","createdAt":"2025-03-09T21:09:37"},{"id":"01963df7-a473-7219-9119-9c1435aad2c8","parentId":null,"rootId":null,"fromId":4140,"content":"研究生是给你一个保底吧，保底会比你本科工资高一点，给你的机会多一点，有的岗位卡你学历，主要是一些国企，至于考公或者移动，你要是有关系能直接进去当然最好，没关系的话，我觉得还是读个研究生稳一点","createdAt":"2025-03-10T08:45:59"},{"id":"01963df7-a4bf-712a-8fb9-9cec3b63f90c","parentId":null,"rootId":null,"fromId":2246,"content":"你就是考上公务员也要继续读在职硕士。你既然已经考上了还是要读，学历这东西，趁早。","createdAt":"2025-03-10T11:29:22"},{"id":"01963df7-a509-7362-b009-3edcaf7939f4","parentId":null,"rootId":null,"fromId":5865,"content":"考研，提升学历，然后再想其他的。刚毕业一年还不算太晚。","createdAt":"2025-03-19T10:07:06"},{"id":"01963df7-a54f-7253-8a2f-c1db8539e550","parentId":null,"rootId":null,"fromId":4375,"content":"不要那么乐观觉着调剂就一定能上岸，就算能调剂上岸也得看你调剂了啥学校啥专业，我考研电子信息335分调剂到南方某学院环境科学，当时也是想着有个学上有个学历就行，结果去了没一个月果断退学走人","createdAt":"2025-03-19T16:42:37"},{"id":"01963df7-a594-7372-bd31-948d7e2e90ac","parentId":null,"rootId":null,"fromId":6208,"content":"后面工作了吗 还是又考了一年","createdAt":"2025-03-19T17:20:11"},{"id":"01963df7-a599-71c4-ae03-44de6c2fbb69","parentId":null,"rootId":null,"fromId":4375,"content":"没二战，直接工作了，现在也不后悔当时退学","createdAt":"2025-03-20T08:49:48"}]