[{"id":"019a56c6-0037-71d5-9cb9-a9ac99359b97","parentId":null,"rootId":null,"fromId":460,"content":"你在北京年薪吗？多钱","createdAt":"2025-11-06T09:26:48"},{"id":"019a56c6-1fc8-7223-8c37-70856301184d","parentId":null,"rootId":null,"fromId":23684,"content":"别回","createdAt":"2025-11-06T09:26:56"},{"id":"019a56d8-f768-7255-b467-21bdc3743c67","parentId":null,"rootId":null,"fromId":24615,"content":"我觉得学历好可以回（即使工作十年），学历差的话大概率得去外包公司或者看看能不能进华为od，可以继续干几年大头兵，尽快熟悉业务融入同事圈，现在房子也便宜不少了，在东边买房定居没啥大问题，最好是先在想买的小区租一段时间，看看小区质量、周边环境和居民素质等","createdAt":"2025-11-06T09:47:31"},{"id":"019a56d9-e958-7118-81f1-78ecb0aff797","parentId":null,"rootId":null,"fromId":3422,"content":"欢迎回来?","createdAt":"2025-11-06T09:48:32"},{"id":"019a56e6-75e7-7363-b003-2106ebf564d3","parentId":null,"rootId":null,"fromId":22702,"content":"昨天还看到 济南8年Java 投的简历都没人回 不知道是不是真假","createdAt":"2025-11-06T10:02:15"},{"id":"019a56f0-318f-7317-a81f-cbab65c6bc78","parentId":null,"rootId":null,"fromId":1401,"content":"差不多，现在在招聘的不多了","createdAt":"2025-11-06T10:12:53"},{"id":"019a56f4-feaf-728c-b1cb-54e1bec4dfe4","parentId":null,"rootId":null,"fromId":5624,"content":"你说的什么屌玩意，北京工作十年，在济南东边买个房子很难？","createdAt":"2025-11-06T10:18:07"},{"id":"019a56f8-3ca6-70a3-b182-cdb626d64359","parentId":null,"rootId":null,"fromId":23605,"content":"招的都是外包","createdAt":"2025-11-06T10:21:40"},{"id":"019a570d-6f23-70e5-aa40-c44f2b4ea73b","parentId":null,"rootId":null,"fromId":23959,"content":"薪资8000可以接受吗","createdAt":"2025-11-06T10:44:49"},{"id":"019a570e-5454-7160-afde-1aeae8781205","parentId":null,"rootId":null,"fromId":23959,"content":"通透","createdAt":"2025-11-06T10:45:48"},{"id":"019a5739-123c-706d-919a-0b4e42b72d2b","parentId":null,"rootId":null,"fromId":22972,"content":"我是题主，再多说一下我个人的情况，我个人目前34岁，单身，个人经济状况存款加公积金能出200。我目前考虑回去的原因一个是到年龄了，二是考虑到回去买个一般的房子压力也能小一些了。回去希望能尽快安稳下来，去考虑接下来的生活。在这提问也是希望大家能从多个方面给个建议，感谢。","createdAt":"2025-11-06T11:32:29"},{"id":"019a573e-3718-710c-b466-21085e6bf37f","parentId":null,"rootId":null,"fromId":27024,"content":"作为省会城市各种老爷们的利益纠葛和牛鬼蛇神太多了。例如：修路遇到Y企的地就变成断头路了。可以考虑潍坊、青岛、烟台","createdAt":"2025-11-06T11:38:06"},{"id":"019a5741-6ca2-7348-9fe2-0cdd52d411ae","parentId":null,"rootId":null,"fromId":5689,"content":"200的话可以在济南东普通小区定居了，但来济南要做断供的心理准备，贷款别太多就行，济南企业的不确定因素太多，没办法提供稳定的就业环境。","createdAt":"2025-11-06T11:41:36"},{"id":"019a5741-8d27-7270-8701-f1e0190dd5f1","parentId":null,"rootId":null,"fromId":1055,"content":"建议先去找个老婆，房子好买，工作不要随便换，除非能找到稳定些的","createdAt":"2025-11-06T11:41:45"},{"id":"019a5745-6b5c-717d-a5e2-8f4ec25d1131","parentId":null,"rootId":null,"fromId":22972,"content":"我的想法是买个一般的房子，争取不去贷款。","createdAt":"2025-11-06T11:45:58"},{"id":"019a5745-df57-7320-b5f4-39fc311adc8f","parentId":null,"rootId":null,"fromId":22972,"content":"对象的话只能说尽力吧，能找就找，找不到就一个人过。","createdAt":"2025-11-06T11:46:28"},{"id":"019a577f-2704-70de-8846-1f723cf112f7","parentId":null,"rootId":null,"fromId":875,"content":"你看看，在北京上班，落户越来越容易了，孩子上学高考，以后在北京老了领北京标准的退休金，享受中国最高的医疗条件，回来干什么，济南的空气不知比北京好了多少，就业也不知道比北京好了多少倍","createdAt":"2025-11-06T12:49:02"},{"id":"019a578f-e748-7240-95a9-234551fbbf31","parentId":null,"rootId":null,"fromId":246,"content":"找对象可比找工作难多了","createdAt":"2025-11-06T13:07:20"},{"id":"019a57c7-688b-732e-8122-f4063e54e16b","parentId":null,"rootId":null,"fromId":22024,"content":"你要是能找到稳定的满意的工作就回来呗，其他又不是什么问题","createdAt":"2025-11-06T14:07:57"},{"id":"019a580a-09ff-702b-bdb8-b8605f48f426","parentId":null,"rootId":null,"fromId":22699,"content":"我也是10+，现在济南的就业情况不是很乐观，我建议你先远程面试看看。我这有架构证，前后端+移动端+大数据，多少也了解一点云原生，主要干java，也懂点c++,python，现在的实际情况就是，很少有人招聘，即使有人招了，面试机会也少，要么就是小公司招聘，也不稳当。还是建议骑驴找马","createdAt":"2025-11-06T15:20:44"},{"id":"019a5816-31c5-738b-b90f-fa23ce213e37","parentId":null,"rootId":null,"fromId":27618,"content":"方便问下学历好点的话能有什么去向呀，会有国企社招吗","createdAt":"2025-11-06T15:34:00"},{"id":"019a5da9-220d-73fc-a7f1-c2dc1ae266a7","parentId":null,"rootId":null,"fromId":2408,"content":"别回，边工作，边考公吧","createdAt":"2025-11-07T17:32:36"},{"id":"019a6b6f-c4a5-71fe-8c69-bf5428e25b18","parentId":null,"rootId":null,"fromId":21821,"content":"建议能待着就别回来，济南就算你会AI也是给8k的事。看着招聘公告1W+，就算面试过了HR各个环节给你降工资","createdAt":"2025-11-10T09:44:38"},{"id":"019a6b9d-39dd-7062-8e57-00d9db540d28","parentId":null,"rootId":null,"fromId":26166,"content":"学历好的话，可以入职众阳，只要你学历够好，众阳很好进，也能哪一个不错的薪资，但是具体进去以后的工作内容建议看一下本贴吧最热话题再决定。","createdAt":"2025-11-10T10:34:17"},{"id":"019a6cfa-145f-71f3-8831-70b856ecdd7a","parentId":null,"rootId":null,"fromId":27708,"content":"不要回。千万不要回。两边距离不远，但是技术氛围 、公司正规化，得有个10年差距","createdAt":"2025-11-10T16:55:19"},{"id":"019a7202-de95-7124-a56c-d7a01819e48a","parentId":null,"rootId":null,"fromId":2056,"content":"go和k8s基本没岗，回不回来看你能接受多少工资。15以下能接受就回来，基本那都是外包公司","createdAt":"2025-11-11T16:23:02"},{"id":"019a722a-b76b-7198-aef2-2a01eaff0b85","parentId":null,"rootId":null,"fromId":1188,"content":"哪里有15的外包？求指条明路","createdAt":"2025-11-11T17:06:33"},{"id":"019a7ab5-4ce6-71ce-be27-c7985331c9b0","parentId":null,"rootId":null,"fromId":2056,"content":"东泰 神思","createdAt":"2025-11-13T08:54:53"},{"id":"019a8197-7145-7270-8b31-75ac12761fa9","parentId":null,"rootId":null,"fromId":26910,"content":"济南估计都找不到k8s的岗","createdAt":"2025-11-14T16:59:37"}]