[{"id":"01963deb-fda9-7088-96b1-31c7397d9955","parentId":null,"rootId":null,"fromId":4093,"content":"楼主说的很在理，外包公司还有很多很多，像去重汽，鲁软，浪潮，城商行的，基本上都会加班，存在感低，没有归属感，甚至甲方有的人想个土皇帝似的，说啥就是啥，看你的承受能力和薪资待遇了","createdAt":"2024-03-04T18:25:07"},{"id":"01963deb-fdf2-720b-802a-38ea0d7aadd9","parentId":null,"rootId":null,"fromId":6902,"content":"金现代，工作地点在高新区奥盛大厦，请问兄弟是外包吗，面的是软件售前工程师14-20k，确实挺高的，我还没去，不太放心","createdAt":"2024-03-06T11:43:10"},{"id":"01963deb-fe36-71c8-aafa-79e952053bec","parentId":null,"rootId":null,"fromId":5952,"content":"分部门","createdAt":"2024-03-06T13:18:40"},{"id":"01963deb-fe3a-7289-aba3-6bea260ed28c","parentId":null,"rootId":null,"fromId":3341,"content":"都是说分部门 看命","createdAt":"2024-03-06T15:54:41"},{"id":"01963deb-fded-7090-a41a-cc73dd660b4f","parentId":null,"rootId":null,"fromId":3341,"content":"重汽里面的人比鲁软傻逼的多","createdAt":"2024-03-06T15:55:12"},{"id":"01963deb-fe43-722e-8c5e-d7e3cf505c2f","parentId":null,"rootId":null,"fromId":7083,"content":"补充一下：技术差倒是不至于，也是分部门的。门槛低，现在今年也年限要到5年以上，本科学历了。这也是很夸张的","createdAt":"2024-04-02T16:32:32"},{"id":"01963deb-fe87-72c4-89e8-2a965879187f","parentId":null,"rootId":null,"fromId":3341,"content":"技术情况仁者见仁智者见智吧不同水平的去点评可能都不太一样 。\n年限可包装/学历非强制 也不是那么苛刻","createdAt":"2024-04-03T14:32:31"},{"id":"01963deb-fe8c-7281-bd77-28051902143f","parentId":null,"rootId":null,"fromId":7118,"content":"智和创 应届能去吗老哥","createdAt":"2024-04-08T11:16:21"},{"id":"01963deb-fe3f-732e-a1f6-45721670bb8a","parentId":null,"rootId":null,"fromId":21339,"content":"请问数据分析岗怎么样啊","createdAt":"2024-07-09T19:18:52"},{"id":"01963deb-fe95-7277-82ba-7285792614f1","parentId":null,"rootId":null,"fromId":6035,"content":"给工资可以，就很良心了。","createdAt":"2024-07-09T20:12:38"},{"id":"01963deb-fe90-7281-b42b-05a08f788eaf","parentId":null,"rootId":null,"fromId":21788,"content":"应届生实施运维岗推荐去嘛","createdAt":"2024-09-03T11:25:28"},{"id":"01963deb-fee3-73d4-8032-49e383553b31","parentId":null,"rootId":null,"fromId":21958,"content":"重汽 鲁软能不去就不去","createdAt":"2025-03-19T10:43:59"},{"id":"01963deb-ff2e-