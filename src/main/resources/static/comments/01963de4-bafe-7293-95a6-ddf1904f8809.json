[{"id":"01963de4-bb69-7396-ae4c-1ec8ceaf5cfe","parentId":null,"rootId":null,"fromId":460,"content":"济南西边的公司 慎重 不是一概而论 真的是慎重","createdAt":"2023-07-10T14:17:57"},{"id":"01963de4-bbad-724b-b684-4262e0a41db7","parentId":null,"rootId":null,"fromId":3828,"content":"感谢老哥提醒，西边的公司名声不太好吗","createdAt":"2023-07-10T14:19:14"},{"id":"01963de4-bbb1-71a0-95ec-958c78b3fa19","parentId":null,"rootId":null,"fromId":1150,"content":"这是啥西边啊，这是济南正儿八经老城区，护城河边上","createdAt":"2023-07-10T15:09:00"},{"id":"01963de4-bbb7-73bf-a2ad-169d875c522b","parentId":null,"rootId":null,"fromId":460,"content":"说的就是老城区的，还是来高新区吧 比较正规","createdAt":"2023-07-10T16:46:26"},{"id":"01963de4-bbbb-72de-a146-99fd658a7647","parentId":null,"rootId":null,"fromId":460,"content":"你可以去试几个西边的公司（所谓的老城区） 你就明白了   多吃吃亏 没坏处 ","createdAt":"2023-07-10T16:48:40"},{"id":"01963de4-bbfe-70df-9c3d-20450d020980","parentId":null,"rootId":null,"fromId":901,"content":"今天刚刷到","createdAt":"2023-07-10T17:57:48"},{"id":"01963de4-bc48-7038-99e7-8a90328dc3d0","parentId":null,"rootId":null,"fromId":3828,"content":"？老哥您知道点什么吗","createdAt":"2023-07-10T18:43:53"},{"id":"01963de4-bc4d-7166-a00a-c235da4a6a1d","parentId":null,"rootId":null,"fromId":117,"content":"跟秋林文化是一家，那个技术总监贼垃圾，问一堆不着调的东西，一点礼貌没有，没法交流","createdAt":"2023-07-12T14:33:33"},{"id":"01963de4-bc8f-7342-ac7a-f0c365ffbcae","parentId":null,"rootId":null,"fromId":224,"content":"这公司简直离了大谱，想去面试的建议现在知乎搜一下“秋文心理”或者“北京秋文”看看这个公司干的脏事。秋文心理商业模式主要靠发展分销商，但是涉及“三级分销”。分销商分为“服务商”“学院”“分院”，跟之前某课传奇如出一辙。老板是玩pua的一把好手，说白了，在秋文干不好，就被一顿pua，干好了他日东窗事发，也妥妥的跑不了要蹲局子。面试需要慎重考虑","createdAt":"2023-07-20T11:09:09"},{"id":"01963de4-bcd4-7273-a8e4-bfb5bb240b91","parentId":null,"rootId":null,"fromId":224,"content":"来这公司升职加薪就别想了，入职两年多涨薪三四百，还要逼着你上他们自己的课程（还要收费上课），都上来少说要2万多。其实就是打着心理学的幌子，课程解决不了什么问题。都是第一次做人，凭什么让别人花钱来你这里听你讲做人的道理","createdAt":"2023-07-20T11:19:23"},{"id":"01963de4-bd19-7166-a22b-15f1e746098b","parentId":null,"rootId":null,"fromId":224,"content":"企业文化：周二跑上晨跑、每周有周会、每月有月会；要写日报、周报、月报；少一样都要扣钱，美其名曰“乐捐”","createdAt":"2023-07-20T11:25:11"},{"id":"01963de4-bd5e-7150-b9b5-c9d63a59d5cb","parentId":null,"rootId":null,"fromId":224,"content":"作为秋文的前员工，必须要来说两句，面试的时候HR对专业技能一无所知，后来才知道就是替大老板李xx选秀的，女员工一定要长得漂亮才发offer，严重的歧视。入职之后发现，一帮试用期的总监，带着一群混日子的小员工瞎搞，三个月就要换一茬人，根本谈不上稳定发展，专业提升，建议求职的童鞋一定深圳","createdAt":"2023-07-20T11:26:20"},{"id":"01963de4-bda5-70c5-a723-a4dcd9751082","parentId":null,"rootId":null,"fromId":224,"content":"他们老板自己说的，在这公司3天以上就算老员工了","createdAt":"2023-07-20T11:28:59"},{"id":"01963de4-bdaa-73f7-9fc5-45e0d0956f4f","parentId":null,"rootId":null,"fromId":4049,"content":"这公司好像还在招人，招好久了吧？","createdAt":"2023-07-26T13:42:51"},{"id":"0197a1d8-0375-7205-bb3e-e7571168ff31","parentId":null,"rootId":null,"fromId":25360,"content":"Sb前端王林被辞了吗","createdAt":"2025-06-24T20:09:37"}]