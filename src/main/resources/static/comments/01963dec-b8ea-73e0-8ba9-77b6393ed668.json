[{"id":"01963dec-b952-728f-86e6-0cd114723033","parentId":null,"rootId":null,"fromId":6813,"content":"面试过，到场后面试官一直说工作经历不符啥的，这些内容我的简历中都写得清清楚楚。。。怀疑是被刷kpi了","createdAt":"2024-03-18T16:03:40"},{"id":"01963dec-b995-738b-a4c2-be17173038a1","parentId":null,"rootId":null,"fromId":5957,"content":"需要做行测题吗","createdAt":"2024-03-18T16:39:37"},{"id":"01963dec-b99a-71e0-9d3c-a097bc486155","parentId":null,"rootId":null,"fromId":6813,"content":"面试前有个线上测评，具体内容是啥忘了","createdAt":"2024-03-19T09:20:01"},{"id":"01963dec-b99e-7308-97a7-618db6b1ed8c","parentId":null,"rootId":null,"fromId":6972,"content":"一年前面过，在美莲广场南边，现在岗位还挂着，感觉是刷kpi的","createdAt":"2024-03-19T09:33:22"},{"id":"01963dec-b9e2-7229-926a-a9211133bfa9","parentId":null,"rootId":null,"fromId":5952,"content":"前两天刚面了，他们招人的原则是达不到要求就一直招，除非能满足人家的要求。面试官原话是这样说的：我们进一个人非常难，光材料走流程就得1个月。好处就是稳定，福利还行，加班好。如果你去面后端，你大概率会遇到一个网络工程师面你，会问你很不专业的东西，因为他不会后端，建议准备一些网络相关的，加上后端","createdAt":"2024-03-19T10:49:05"},{"id":"01963dec-ba26-72ab-86b5-cc9bb3079ddd","parentId":null,"rootId":null,"fromId":3892,"content":"老哥，都问你啥了？您是今年经验面得？","createdAt":"2024-03-19T11:15:37"},{"id":"01963dec-ba2a-7383-9df3-7dd4403455b6","parentId":null,"rootId":null,"fromId":5952,"content":"一年左右，问的东西和日常开发没啥关系，但是问完会结合你的简历，然后大概率刷人，他们本来就不缺人，你只要有一点毛病基本上就进不去，后续他们还有背调什么的，查到空窗期什么的可能都会卡你，或者休学这种","createdAt":"2024-03-19T11:28:29"},{"id":"01963dec-ba34-73ad-b1ba-d907a8b4fe28","parentId":null,"rootId":null,"fromId":6689,"content":"前几天刚面试完.先是做行测题,性格测试题.然后做完一周多没消息,一问,人事给忘了.然后面试感觉聊的还行,但是面试完又是一周左右没消息,主动问人事说没通过,也没说具体哪方面不合适. 感觉确实是刷KPI的","createdAt":"2024-03-19T11:52:52"},{"id":"01963dec-ba79-71c0-ab8f-bbd111ededd4","parentId":null,"rootId":null,"fromId":3892,"content":"这家公司这么难，估计面试十几个才能要一个","createdAt":"2024-03-19T12:00:49"},{"id":"01963dec-babf-7346-8e85-f9b13601ec98","parentId":null,"rootId":null,"fromId":6654,"content":"刷kpi的，害得我请假半天，一百多打水漂了。面试java，两个人一个是运维，一个是网络，全程没怎么问java","createdAt":"2024-03-20T17:40:05"},{"id":"01963dec-bb04-730f-b327-fc5c01d78964","parentId":null,"rootId":null,"fromId":3892,"content":"找运维和网络来面试java，这咋想的？","createdAt":"2024-03-20T19:13:59"},{"id":"01963dec-bb09-703c-9e24-825603fcd518","parentId":null,"rootId":null,"fromId":1249,"content":"先离职给离职证明再做背调审批，能接受风险就去，适合被裁的和校招生","createdAt":"2024-03-20T23:12:22"},{"id":"01963dec-ba2f-7076-b523-fcbffd9860bf","parentId":null,"rootId":null,"fromId":6523,"content":"老哥，加班情况和出差情况呢， 试用期工资多少呀","createdAt":"2024-04-23T10:16:17"},{"id":"01963dec-bb4e-715e-8045-4627f4038c29","parentId":null,"rootId":null,"fromId":21821,"content":"25年技术面过了，给定薪不高，手续麻烦时间挺长。最终没去，因为已经拿到其他单位的offer了","createdAt":"2025-02-10T15:38:23"}]