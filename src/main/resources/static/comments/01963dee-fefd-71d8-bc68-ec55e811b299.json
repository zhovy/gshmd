[{"id":"01963dee-ff60-7349-a4f9-a03d2ce359de","parentId":null,"rootId":null,"fromId":7510,"content":"面过，一轮产品和开发面，二轮总监面，后来不知道为啥面试没过...","createdAt":"2024-05-16T08:55:16"},{"id":"01963dee-ffa5-706e-8dbe-7c2503efb84e","parentId":null,"rootId":null,"fromId":6798,"content":"面试难度大么","createdAt":"2024-05-16T09:34:28"},{"id":"01963dee-ffa9-7336-a2a1-f2905e34ccfd","parentId":null,"rootId":null,"fromId":7510,"content":"我感觉难度不大，当时谈的挺好，等总监面的时候，就开始谈公司业务福利待遇了，聊天一样讲了很多，我都以为马上就要入职了。另外办公环境一般，1  楼，办公区没有窗?‍?","createdAt":"2024-05-16T10:27:24"},{"id":"01963dee-ffb3-72e7-98b4-9ed89893e6ac","parentId":null,"rootId":null,"fromId":113,"content":"面过，开发面试两轮，三轮经理面问为什么跳槽这么频繁问每次跳槽的原因，回答的不好没过","createdAt":"2024-05-16T10:44:17"},{"id":"01963dee-fff7-70c7-989f-dd653c225468","parentId":null,"rootId":null,"fromId":113,"content":"另外本来说经理面试过两天通知，我就坐公交车回家了（面试地点很远，在市中区，我在七里河住，坐公交得一个多小时）。在公交车上还有三四站到家的时候给我打电话说现在过来面试，然后我又下公交打了个车去的。本来前面面试都挺好的，问的问题也不难基本都回答的很好，感觉下一秒就要给我发offer了，结果最后让个这个胖子因为离职的原因不满意给我否了。","createdAt":"2024-05-16T10:50:04"},{"id":"01963dee-fffb-701a-b834-78bdb811ec87","parentId":null,"rootId":null,"fromId":3892,"content":"当时几年工作经验啊？","createdAt":"2024-05-16T10:55:02"},{"id":"01963dee-ffae-7373-ad1b-9dffe99387de","parentId":null,"rootId":null,"fromId":6798,"content":"估计还在面着其他人，在衡量","createdAt":"2024-05-16T11:08:15"},{"id":"01963def-0000-7009-a1b9-1016b21d2ff6","parentId":null,"rootId":null,"fromId":7510,"content":"对，就是这个理由。说我前期工作变动有点频繁，要再考虑一下。我说之前在一线城市的互联网行业，人员流动性本来就挺高","createdAt":"2024-05-16T13:10:32"},{"id":"01963def-0004-70c6-92e1-c883dd1a1111","parentId":null,"rootId":null,"fromId":113,"content":"3年","createdAt":"2024-05-17T10:43:44"},{"id":"01963def-0008-7309-8942-e275fdf23227","parentId":null,"rootId":null,"fromId":6368,"content":"你要是不会搞关系的千万别去","createdAt":"2024-05-17T15:58:57"},{"id":"01963def-004c-71c3-98b4-1dd8a112c2b1","parentId":null,"rootId":null,"fromId":691,"content":"怎么样？大佬们    里面产品岗的薪资待遇和同事啥的都可以吗？能不能说说大概的情况","createdAt":"2024-07-18T15:00:30"},{"id":"01963def-0096-7343-846e-2b2ff3dc6ed2","parentId":null,"rootId":null,"fromId":21429,"content":"驾校有推荐吗","createdAt":"2024-07-21T16:51:48"},{"id":"01963def-0092-7070-875b-bf090d364e4d","parentId":null,"rootId":null,"fromId":6687,"content":"面产品了吗 怎么样","createdAt":"2024-07-23T09:45:02"}]