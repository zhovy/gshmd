[{"id":"01963ddd-795d-72e0-8b1a-af4105b0420e","parentId":null,"rootId":null,"fromId":708,"content":"外包公司，不都这鸟样吗","createdAt":"2022-10-31T16:08:28"},{"id":"01963ddd-79a3-70ca-8cf2-ae020e6040f1","parentId":null,"rootId":null,"fromId":228,"content":"感同身受,真实经历.双休变大小周还是单休记不住了,找他们领导不承认,非让我去找他们人事对峙,笑死人.人家一个小姑娘知道啥?还不是听领导话办事.就这格局果断跑路,还外派到其他地方(就是外包).在这种所谓的领导下班干活有你受的了","createdAt":"2022-10-31T17:32:47"},{"id":"01963ddd-79e7-7124-a500-636158593ec6","parentId":null,"rootId":null,"fromId":1607,"content":"青桥不是培训的吗","createdAt":"2022-11-02T10:50:16"},{"id":"01963ddd-7a2c-7031-b725-c58fdee01fdb","parentId":null,"rootId":null,"fromId":2183,"content":"有培训，培训完就完事了，现在还在公司等着面试，一个都还没有面试成功","createdAt":"2022-11-10T13:58:58"},{"id":"01963ddd-7a7b-72f7-aa7a-281f32ae4b8c","parentId":null,"rootId":null,"fromId":1607,"content":"那你咋办？","createdAt":"2022-11-12T12:37:47"},{"id":"01963ddd-7ac0-7212-8675-b612fd4c50de","parentId":null,"rootId":null,"fromId":3190,"content":"青桥软件，踩坑，一开头忽悠你说打铁还需自身硬，转正之后至少6k，会有合作公司怎么样怎么样，忽悠你继续待在这里之后，接着让你2w的签培训协议，6个月之后还是得你自己出来找工作，而且晚上还得待在这里，8：30才能下班，如果你没有明确的目标，不是自主来参加培训的，兄弟们就别来遭罪了。要是没有天赋的，想我这种菜鸟，半吊子，完全就是来遭罪。","createdAt":"2023-04-04T10:31:43"},{"id":"01963ddd-7b05-70b5-adf8-69aa6bea8f1b","parentId":null,"rootId":null,"fromId":3372,"content":"我感觉公司还可以，至于培训啥的不清楚","createdAt":"2023-04-24T17:42:58"},{"id":"01963ddd-7b4c-72f7-9c70-9f543b9b950c","parentId":null,"rootId":null,"fromId":3973,"content":"问了，说没有加班费，没有调休，入职后交五险一金，福利太差，试用期不交五险一金，感觉不是诚信招人，随时赶你走的额感觉\n","createdAt":"2023-07-20T09:41:34"}]