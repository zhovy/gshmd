[{"id":"01991231-4a5a-7035-8580-eb41bfccd14b","parentId":null,"rootId":null,"fromId":3718,"content":"那就自己开公司啊，又没人拦你，现在注册公司非常简单，自己当老板，自己发展","createdAt":"2025-09-04T08:47:24"},{"id":"01991232-1306-702d-b14e-522bdd3fdf73","parentId":null,"rootId":null,"fromId":6091,"content":"现在老板都赔的蛋疼","createdAt":"2025-09-04T08:48:15"},{"id":"0199129f-5445-72f2-bbf2-1ea7d1d06237","parentId":null,"rootId":null,"fromId":22702,"content":"不是每个人都适合发展，硬要发展也能倾家荡产，有些老板为啥能把招的人当畜生，就是人承担了风险做了老板，但是这种抠搜的并且忽略人权的都是干不长远的公司。","createdAt":"2025-09-04T10:47:35"},{"id":"0199134f-51aa-72f7-a4b7-8d7a2fb2ab80","parentId":null,"rootId":null,"fromId":1538,"content":"开公司没这么容易,需要钱耶,普通人哪有这么多启动资金和延迟资金池","createdAt":"2025-09-04T13:59:49"},{"id":"01991350-7ace-720c-93fa-c22e376ef11c","parentId":null,"rootId":null,"fromId":1538,"content":"国家的税收其实并不低,开公司成本高的一批,弄不好就赔钱硬吊一口气在那","createdAt":"2025-09-04T14:01:05"},{"id":"019924b5-9119-71a4-94d4-7e46c88f5c80","parentId":null,"rootId":null,"fromId":2246,"content":"那什么不是拒绝发展","createdAt":"2025-09-07T23:05:03"}]