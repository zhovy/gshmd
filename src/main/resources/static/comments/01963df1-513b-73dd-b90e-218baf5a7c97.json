[{"id":"01963df1-519f-735e-980c-d7e64aa7d8e3","parentId":null,"rootId":null,"fromId":7294,"content":"本来工资就不高，请了一个月的病假，公司一分钱也不给发。","createdAt":"2024-06-28T16:19:01"},{"id":"01963df1-51e6-71e1-9592-bc09472c5e24","parentId":null,"rootId":null,"fromId":3892,"content":"连年假都没有吗？","createdAt":"2024-06-28T16:20:31"},{"id":"01963df1-5233-70c8-8e29-3497f77f8e1c","parentId":null,"rootId":null,"fromId":2658,"content":"合法啊 你请病假这么长时间谁给你发工资 产假能行","createdAt":"2024-06-28T16:21:43"},{"id":"01963df1-528c-72d7-b68c-b2ede321e2ce","parentId":null,"rootId":null,"fromId":3572,"content":"病假也是看公司，有的出示医院开具的病假条可以发部分薪资，不给也是合情合理","createdAt":"2024-06-28T16:28:00"},{"id":"01963df1-52d0-72d4-80b0-27aabe2c10c5","parentId":null,"rootId":null,"fromId":3801,"content":"这种情况的话，一般是先扣调休假，再扣年假，最后的部分需要扣工资了，你们公司没这些假的话就没办法了。","createdAt":"2024-06-28T16:55:27"},{"id":"01963df1-5317-721f-a415-06eb825d3c1d","parentId":null,"rootId":null,"fromId":7034,"content":"= = 只有产假才有工资吧","createdAt":"2024-06-28T17:05:19"},{"id":"01963df1-5360-71e0-9b75-3eeaf613c174","parentId":null,"rootId":null,"fromId":933,"content":"病假不是半薪吗","createdAt":"2024-06-28T17:06:30"},{"id":"01963df1-5365-7211-a67e-a278ad6888b6","parentId":null,"rootId":null,"fromId":4140,"content":"法律规定是按照工资的60%发放，不给你可以告他","createdAt":"2024-06-28T17:09:39"},{"id":"01963df1-53a9-73fd-8836-b8a37520fa39","parentId":null,"rootId":null,"fromId":6631,"content":"规定是有病条的病假，必须得批，并且发60%左右的工资（记不清了）。之前在另一个城市的时候，可能待的公司都比较人性化，也都是这样执行的。之前有同事滑雪摔断了腿，好像卧床休息了好几个月，公司的保险报销了一些，还发工资。哎嗨呀。","createdAt":"2024-06-28T17:14:05"},{"id":"01963df1-527a-7240-bb7f-637ac994d4a6","parentId":null,"rootId":null,"fromId":4140,"content":"职工患病或非因工负伤治疗期间，在规定的医疗期间内由企业按有关规定支付其病假工资或疾病救济费，病假工资或疾病救济费可以低于当地最低工资标准支付，但不能低于最低工资标准的80%。","createdAt":"2024-06-28T17:14:09"},{"id":"01963df1-53ef-7393-bfcd-bafc370e36fd","parentId":null,"rootId":null,"fromId":21157,"content":"ddd","createdAt":"2024-06-28T18:23:54"},{"id":"01963df1-5439-7270-bc8e-902c8c750ed0","parentId":null,"rootId":null,"fromId":875,"content":"一年六天带薪病假，可惜济南没有","createdAt":"2024-06-28T18:51:49"},{"id":"01963df1-547f-7247-bd6a-cc75141f7550","parentId":null,"rootId":null,"fromId":7623,"content":"我之前请过半个月的病假，按济南最低工资的百分之八十算的","createdAt":"2024-06-30T13:10:42"},{"id":"01963df1-522a-7101-ba8d-ecaad25e0864","parentId":null,"rootId":null,"fromId":6091,"content":"我现在都不知道年假啥意思","createdAt":"2024-06-30T14:17:52"},{"id":"01963df1-527f-70a8-ae91-3067f9b41ece","parentId":null,"rootId":null,"fromId":6091,"content":"病假应该有工资吧，事假没有","createdAt":"2024-06-30T14:18:26"},{"id":"01963df1-522f-7053-9a07-ab54f5c28477","parentId":null,"rootId":null,"fromId":7294,"content":"没有年假","createdAt":"2024-07-01T11:29:03"},{"id":"01963df1-5283-7162-b8c6-66cea97404a4","parentId":null,"rootId":null,"fromId":7294,"content":"可是，法律不是规定要发的吗。","createdAt":"2024-07-01T11:29:21"},{"id":"01963df1-54c5-73b1-8879-967af20c203a","parentId":null,"rootId":null,"fromId":7294,"content":"最低工资的80%？3K的 80%么","createdAt":"2024-07-01T11:30:12"},{"id":"01963df1-550f-7135-8ef4-804492b00f77","parentId":null,"rootId":null,"fromId":880,"content":"不合法，只要你提供医院的诊断证明或者正规医院开具的病假条，不给工资就不行。\n\n一、病假待遇国家规定是怎么样的？\n\n《劳动法》第四、五条对病假工资做了基本规定：\n\n第四条\n\n职工患病，医疗期内停工治疗在6个月以内的，其病假工资按以下办法计发：\n\n(一)连续工龄不满10年的，按本人工资的70%发给;\n\n(二)连续工龄满10年不满20年的，按本人工资的80%发给;\n\n(三)连续工龄满20年不满30年的，按本人工资的90%发给;\n\n(四)连续工龄满30年及其以上的，按本人工资的95%发给。\n\n经济效益好的企业，可在上述标准的基础上上浮5%。经济效益差，难以达到上述标准的企业，经本企业职工大会或职工代表大会审议通过，可以适当下浮。下浮的比例一般不超过各个档次标准的5%。如情况特殊超过5%的，应报所在区县(自治县、市)劳动和社会保障行政部门批准。\n\n第五条 职工患病，医疗期内停工治疗在6个月以上的，其病假工资按以下办法计发：\n\n(一)连续工龄不满10年的，按本人工资的60%发给;\n\n(二)连续工龄满10年不满20年的，按本人工资的65%发给;\n\n(三)连续工龄满20年及其以上的，按本人工资的70%发给。","createdAt":"2024-07-02T13:51:25"},{"id":"01963df1-5287-70ad-b1fa-281b9b9ad68d","parentId":null,"rootId":null,"fromId":880,"content":"翻翻劳动法吧","createdAt":"2024-07-02T13:52:13"}]