[{"id":"01963dd5-2c36-73d9-924f-fa1c5e1d8601","parentId":null,"rootId":null,"fromId":1959,"content":"有个刚入职的测试给我推荐了这个公司 只说了不加班 投了也没回应","createdAt":"2022-10-17T10:58:49"},{"id":"01963dd5-2c7f-70fd-996d-e4b3b996fc79","parentId":null,"rootId":null,"fromId":453,"content":"https://susong.tianyancha.com/1fc9421502db47079396732da08ce81a\n当年打的官司，有兴趣的可以看看这个公司有多搞笑","createdAt":"2023-02-28T11:18:20"},{"id":"01963dd5-2d0f-7283-a93e-0a857cb1f90c","parentId":null,"rootId":null,"fromId":6446,"content":"面试存在套方案嫌疑，一直在问你是如何处理实际项目中遇到的问题，最后忍不住直接问你他遇到的难题，哈哈哈哈","createdAt":"2024-08-06T11:13:39"},{"id":"01963dd5-2d55-72f9-b330-44dedf92d143","parentId":null,"rootId":null,"fromId":7183,"content":"支付对账啥的嘛 不知道那个项目交付了没","createdAt":"2024-08-06T12:06:14"},{"id":"01963dd5-2d5a-72c9-af57-f41e0dc54bcd","parentId":null,"rootId":null,"fromId":21302,"content":"具体项目我不知道，就是个腊鸡项目外包公司，办公地点一换再换，反正我去了都是俩刁毛面试我，具体能力就不说了，尤其是第二个人明目张胆的套你方案，见你不上套就直接提问了（其实这个问题是他现在遇到的问题暂时没想到好解决方案）","createdAt":"2024-08-08T12:49:02"},{"id":"01963dd5-2d64-7217-9692-36f8985cb666","parentId":null,"rootId":null,"fromId":22725,"content":"垃圾公司彻底完蛋了，研发降薪20%，双休改单休\n几个吊毛天天的就在那研究怎么恶心员工\n陆续都在跑路了，看到的千万别来这垃圾皮包公司","createdAt":"2025-02-13T14:13:03"},{"id":"01963dd5-2d60-7037-b6a3-1762af96c865","parentId":null,"rootId":null,"fromId":22734,"content":"待业中，看到这个忍不住想评论下，我之前呆的公司也参与过面试工作，除了技术栈对于高级点的研发也会问项目中遇到的问题怎么解决的种种，然后给出个场景让我去设计怎么实现的，看看技术、设计、思维能力，也不能一棒子打死把。还有就是面试官也是打工人吧，没有必要直接叫人吊毛吧，首先他们和你并没有任何关系，我都不敢想是不是也被人骂过。","createdAt":"2025-02-14T10:23:49"},{"id":"01963dd5-2daa-71c4-9f0b-0d947575d35e","parentId":null,"rootId":null,"fromId":1876,"content":"离职的多不多","createdAt":"2025-02-18T13:43:49"},{"id":"01963dd5-2daf-700d-9ad8-dfd477beda08","parentId":null,"rootId":null,"fromId":22649,"content":"不是20%，年前降薪30%，年后又降薪10%，双休变单休，公司代码屎山汇聚，公司薪资是2000多的底薪加绩效构成，如果干的不好，当月绩效全扣。老员工，目前已经离职。如果在公司请记住，总经理的话不可信，说一套是一套","createdAt":"2025-02-24T15:59:14"},{"id":"01963dd5-2db3-738b-a2fc-faad93b53de9","parentId":null,"rootId":null,"fromId":23102,"content":"不行就试试 ， 一试一个不吱声。只有想不到没有干不出来的。","createdAt":"2025-04-07T11:20:14"},{"id":"0197e9ac-36cd-703f-9c07-679ef5cd67e3","parentId":null,"rootId":null,"fromId":22704,"content":"哈哈哈哈哈","createdAt":"2025-07-08T18:54:27"},{"id":"019a4db2-9c82-7344-93f3-e60e654e99c7","parentId":null,"rootId":null,"fromId":24437,"content":"这是因为公司的老板是山东职业学员信息系软件班的JAVA老师","createdAt":"2025-11-04T15:09:02"}]