[{"id":"019715db-76f7-7038-8cff-557f0da6378c","parentId":null,"rootId":null,"fromId":5707,"content":"同问，还没面，薪资有点低，只有8k-11k","createdAt":"2025-05-28T15:46:33"},{"id":"01971ae1-cebb-7329-952c-6bbc3f2fe6fa","parentId":null,"rootId":null,"fromId":7425,"content":"是啊，确实有点低了","createdAt":"2025-05-29T15:11:35"},{"id":"0197f76c-85be-71a5-bf38-d79e04513e78","parentId":null,"rootId":null,"fromId":23605,"content":"面了吗","createdAt":"2025-07-11T10:59:33"},{"id":"0197f76c-c15f-72df-845f-8dfc2dc3da0b","parentId":null,"rootId":null,"fromId":23605,"content":"去了吗老哥","createdAt":"2025-07-11T10:59:49"},{"id":"0198ee3f-1f2a-71b3-9971-a009fc545570","parentId":null,"rootId":null,"fromId":2980,"content":"1、说是自研项目，其实就是个外包，只是在本公司开发，不需要去甲方而已\n2、工资给的极低\n3、说了不怎么加班，结果试用期疯狂加班，最后不给转正，老员工反馈这种情况很多，不是一两个人\n4、注意避坑，注意避坑，注意避坑","createdAt":"2025-08-28T09:16:10"},{"id":"0198eecf-09b5-7345-85b0-2cda2d92f411","parentId":null,"rootId":null,"fromId":23605,"content":"大多不都是这种模式吗","createdAt":"2025-08-28T11:53:22"},{"id":"019b5ed4-5b3d-72a4-b577-83fd4cd0fe7c","parentId":null,"rootId":null,"fromId":24043,"content":"这个公司有个特点，会把该属于你的薪资，美其名曰奖金，通过季度奖金的方式发放(仔细品)，还频繁调整发放制。有个好处不PUA哈，直接就是强制，绝对的服从。","createdAt":"2025-12-27T16:02:13"},{"id":"019b71ea-6920-72cc-b388-f3d4e72cc615","parentId":null,"rootId":null,"fromId":24043,"content":"做电力外包的，加班让你就得加，只谈奉献不谈回报，出差看命，有的出去个把月都见不到，出差一线城市250一天全包(住宿、打车、吃饭)，不够自己拿，五险一金最低","createdAt":"2025-12-31T08:59:06"},{"id":"019beaff-f7f6-72dd-82c2-a012dd852667","parentId":null,"rootId":null,"fromId":24043,"content":"Java就算了吧，新来的领导把做研发的搞臭了，来了一些啥都不懂的人来管技术，每天就会拿个小本本问你做了一些啥，现在各种东西都少了，少到100块钱的生日卡都不发了，笑死","createdAt":"2026-01-23T21:16:42"}]