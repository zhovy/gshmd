[{"id":"01987cb6-f115-7329-8df6-723e836ef4e6","parentId":null,"rootId":null,"fromId":371,"content":"总感觉他们觉得自己比其他外包的高人一等？","createdAt":"2025-08-06T08:10:20"},{"id":"01987cd4-0680-7299-b78c-b1dd7a848bce","parentId":null,"rootId":null,"fromId":21428,"content":"他们说自己是单位，不说公司.....","createdAt":"2025-08-06T08:42:06"},{"id":"01987cd5-da46-7318-b4f4-de1ed13b1ff0","parentId":null,"rootId":null,"fromId":1003,"content":"不是  都带通","createdAt":"2025-08-06T08:44:06"},{"id":"01987cd7-c00d-72cc-a78e-d5054d92a027","parentId":null,"rootId":null,"fromId":21428,"content":"央企外包联通办公，外不外包只有自己知道，给别人说在联通上班，懂得都懂只有校招的不是外包","createdAt":"2025-08-06T08:46:10"},{"id":"01987ce2-84da-7244-b7d1-036acef6ecd1","parentId":null,"rootId":null,"fromId":460,"content":"纠结这个干什么呢？都是得干活 不干活就得被辞退 大家都是一样的 我上次了解到一个联通内部员工 人家光学历就吓你们一跳 别羡慕人家了 你当时为啥不好好学习 考个好大学呢？ 再说工作岗位都是向社会大众开放的，你当时为什么不面试正式的工作岗位  和他们竞争一下呢？（唉 我是废了 我是社会边角料 我骄傲 哈哈哈哈哈哈）","createdAt":"2025-08-06T08:57:56"},{"id":"01987ce5-02fb-72bd-baa8-5e7276a244d6","parentId":null,"rootId":null,"fromId":21428,"content":"都是一样干活的内部和外包工资差距有多大","createdAt":"2025-08-06T09:00:40"},{"id":"01987ce6-3810-70ad-9b5d-fcb4fcdeb252","parentId":null,"rootId":null,"fromId":460,"content":"你当时为啥不应聘正式工呢？为什么呢？国家给过你工作机会 你面不过  你赖谁","createdAt":"2025-08-06T09:01:59"},{"id":"01987d4f-3786-714e-9e7e-19c26d0ade81","parentId":null,"rootId":null,"fromId":371,"content":"不是怨谁？是不清楚联通正式和保时通的区别？","createdAt":"2025-08-06T10:56:40"},{"id":"01987d6c-cbe0-7237-8dc0-468e7bab8992","parentId":null,"rootId":null,"fromId":21428,"content":"之前认识一个女的在联通干外包，都知道他是保时通的，他一张嘴都是我们单位，给人感觉他是公务员一样","createdAt":"2025-08-06T11:28:58"},{"id":"01987dee-3b45-73e8-ac23-559da2e03016","parentId":null,"rootId":null,"fromId":371,"content":"类似浪潮的世科 和 其他的外包公司","createdAt":"2025-08-06T13:50:21"},{"id":"01987e6a-5a72-7371-bfce-0b783f674d11","parentId":null,"rootId":null,"fromId":21302,"content":"黄锦某还在吗","createdAt":"2025-08-06T16:05:55"},{"id":"01987f04-fbe2-710e-9016-7cd68b2ed9aa","parentId":null,"rootId":null,"fromId":5536,"content":"保时通比合同制强，工资高其他福利基本一致，合同制就多了个还能不能拿到的养老金，工资高才是最关键很多人都比合同制高4-5倍，即使N+1赔偿也多，同样的裁员，同样的不续签合同制根本没有任何优势。","createdAt":"2025-08-06T18:54:49"},{"id":"01987f21-937e-7199-9529-213058607413","parentId":null,"rootId":null,"fromId":460,"content":"4-5倍？真的假的啊 看来你是内部人员啊  不都是合同制是大老爷吗？怎么回事？","createdAt":"2025-08-06T19:26:03"},{"id":"019881fe-81e5-710a-8393-090c6d1796fa","parentId":null,"rootId":null,"fromId":21428,"content":"合同制工资不高裁掉，保时通工资高不裁？没道理，裁员不都是裁工资高的，留下工资低的干活，是不是合同制的不干活给三千他们都嫌多了","createdAt":"2025-08-07T08:46:37"},{"id":"01988396-10f7-7227-9dec-f90b423f1c30","parentId":null,"rootId":null,"fromId":5536,"content":"肯定内部的啊，要是外部的能知道这么多吗？合同制都是校招的4000-5000到手，我也招聘过保时通的，保时通是社招只能说1.2w起吧一般，当然也有低的要8000，大部分1.2w起步，2w也不少","createdAt":"2025-08-07T16:11:46"},{"id":"01988399-cf44-72f4-b705-938d49657fad","parentId":null,"rootId":null,"fromId":5536,"content":"如果公司连裁员的钱都没了呢？合同制便宜裁一下赔个四五万八九万就可以了，而且保时通进来的大部分都是前几年经济好的时候工资高，裁一下赔的可不少，而且很多保时通都是领导亲戚，加上保时通这么多年很多都是中流砥柱的人了，而合同制校招最近五年最多了，之前基本都没怎么招聘过合同制的。\n然后现在这不是要批量整治保时通了，但是后面怎么处理我也不清楚。","createdAt":"2025-08-07T16:15:52"},{"id":"0198839a-3a13-713c-8b4e-97e27c05bf3a","parentId":null,"rootId":null,"fromId":5536,"content":"当然还有更低的3000+的","createdAt":"2025-08-07T16:16:19"},{"id":"019883a1-1230-726b-8e0e-194f658267e6","parentId":null,"rootId":null,"fromId":460,"content":"你就不害怕那些人 顺瓜摸藤的找出你来吗 然后就开始找你事 哈哈哈哈哈哈哈  勇士啊  领导的亲戚都敢说  看来你不想在这里长干了","createdAt":"2025-08-07T16:23:48"},{"id":"019883ed-9f25-72dc-894d-032593f47372","parentId":null,"rootId":null,"fromId":6050,"content":"还在啊","createdAt":"2025-08-07T17:47:24"},{"id":"01988722-94f0-7018-ac23-e098ed146119","parentId":null,"rootId":null,"fromId":5862,"content":"保时通比合同制强多了，保时通现在可不会整个绩效考核库库扣钱，最多扣个两三百","createdAt":"2025-08-08T08:44:07"},{"id":"01988723-24b9-7149-a3fb-c9e3397a4e7e","parentId":null,"rootId":null,"fromId":5862,"content":"领导亲戚确实多，合同制领3000的牛马更多","createdAt":"2025-08-08T08:44:44"},{"id":"01988778-7a90-7255-8cf5-a2fc56018c4f","parentId":null,"rootId":null,"fromId":24907,"content":"校招到手4000-5000的，公积金大概3k,年终奖也比较可观，算下来年包大概15，这应该是最低的了。感觉在济南对于一个新人来说工资还算可观。所以保时通单边250 双边500块的公积金和几乎没有的年终奖不能拿月薪比吧哈哈","createdAt":"2025-08-08T10:17:56"},{"id":"0198879d-74d9-7386-a2f8-22c5c496e983","parentId":null,"rootId":null,"fromId":5536,"content":"缺的这一块没人给我补啊","createdAt":"2025-08-08T10:58:19"},{"id":"019887c9-1787-7315-a225-68955cb6d0fb","parentId":null,"rootId":null,"fromId":21428,"content":"第一学历大专在保时通综合收入年包也是15到20","createdAt":"2025-08-08T11:45:59"},{"id":"01988886-970b-72cd-a42e-bd43ce17afe9","parentId":null,"rootId":null,"fromId":371,"content":"保时通的公积金保险比例怎么样？和合同制的一样吗？还是低于合同制","createdAt":"2025-08-08T15:12:58"},{"id":"019896ef-4198-726a-8b9f-67a1d7267d44","parentId":null,"rootId":null,"fromId":5862,"content":"你这是还在保护期呢，等你出了保护期看看，能不能每月拿到4000，看看你的年终奖还可观不","createdAt":"2025-08-11T10:21:59"},{"id":"019897af-f464-73db-8a03-3488f82830e5","parentId":null,"rootId":null,"fromId":5862,"content":"不用在乎这个了，马上保时通就全转外包了，现在都一样了","createdAt":"2025-08-11T13:52:27"},{"id":"019897d6-9c09-71ed-8d57-4d08fa3fc824","parentId":null,"rootId":null,"fromId":21428,"content":"保时通本来不就是外包吗","createdAt":"2025-08-11T14:34:41"},{"id":"0198987a-e658-72bd-9f3b-ff479a82bcd4","parentId":null,"rootId":null,"fromId":5536,"content":"原来叫内包、现在要变成外包了","createdAt":"2025-08-11T17:34:07"},{"id":"01989902-bb60-7179-9ffc-9b49571c2550","parentId":null,"rootId":null,"fromId":21428,"content":"工资有变化吗？","createdAt":"2025-08-11T20:02:29"},{"id":"01989c49-ccd6-7302-ba12-8dd04403726f","parentId":null,"rootId":null,"fromId":5536,"content":"还没改呢，咱也不知道啊","createdAt":"2025-08-12T11:18:59"},{"id":"0198f463-465f-7155-8a20-12b7339c56af","parentId":null,"rootId":null,"fromId":26662,"content":"保时通公积金按照最低的来的，合同制公积金应该高，但是工资确实比较低，5-6k 有年终奖 综合也得12左右","createdAt":"2025-08-29T13:53:23"}]