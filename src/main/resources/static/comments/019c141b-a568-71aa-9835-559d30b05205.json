[{"id":"019c14de-5b20-73ae-90c8-ea46c8892c1b","parentId":null,"rootId":null,"fromId":27172,"content":"不建议去不给配电脑的公司，因为不稳定。但是现在就业环境下，有工作就不错了。电脑现在内存涨价感觉贵一些，可以先等等，万一公司配电脑","createdAt":"2026-02-01T00:24:02"},{"id":"019c17b7-3a18-7116-91e6-bbbe366388fe","parentId":null,"rootId":null,"fromId":1398,"content":"找到工作再说?","createdAt":"2026-02-01T13:40:09"},{"id":"019c17ce-6e0b-71a8-aa28-ae04a9dafeff","parentId":null,"rootId":null,"fromId":22702,"content":"先找到工作再说吧","createdAt":"2026-02-01T14:05:30"},{"id":"019c1baf-03e4-7028-bddc-a0732a7aa198","parentId":null,"rootId":null,"fromId":5689,"content":"肯定是公司配电脑啊，电脑是生产工具，哪有企业不给生产工具的？某些外包公司因为人员流动大，一般是不给配电脑的，他们会选择每个月给电脑补助。","createdAt":"2026-02-02T08:09:40"},{"id":"019c1bed-620f-71e6-aa74-3eb34c663f68","parentId":null,"rootId":null,"fromId":24615,"content":"看你是找正式还是外包的工作，在确定工作之前，没有必要买","createdAt":"2026-02-02T09:17:47"},{"id":"019c2b7b-a885-7101-b89d-a8931facb741","parentId":null,"rootId":null,"fromId":22875,"content":"配电脑，说明公司还有点儿成本。连电脑都不配，只有你是成本","createdAt":"2026-02-05T09:47:30"}]