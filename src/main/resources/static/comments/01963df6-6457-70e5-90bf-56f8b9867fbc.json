[{"id":"01963df6-64bb-72a8-88af-9fa8bdd49cc0","parentId":null,"rootId":null,"fromId":21053,"content":"坑可太大了","createdAt":"2025-01-16T13:44:52"},{"id":"01963df6-6501-70a7-bdda-1c4db7629eb3","parentId":null,"rootId":null,"fromId":22624,"content":"忠告，别去","createdAt":"2025-01-16T14:06:35"},{"id":"01963df6-6547-706d-99a3-3b76c7d9f691","parentId":null,"rootId":null,"fromId":21585,"content":"我看着最近BOSS上这家的招聘信息贼多，看来是留不住人，年底都走了啊","createdAt":"2025-01-16T15:39:19"},{"id":"01963df6-658e-7188-a937-a4f8301b1528","parentId":null,"rootId":null,"fromId":21506,"content":"一个比较奇葩的公司，公司全年福利就是中秋一盒链家月饼，说好的13薪其实也不存在，周报月报绩效倒是一个不少。20%的绩效基本都会扣；年假满一年5天，每年固定不随工龄变化，工位有监控，氛围比较压抑。建议有别的选项就别去了。","createdAt":"2025-03-04T15:39:33"},{"id":"01963df6-661a-71a8-9a64-a69a47c76cd3","parentId":null,"rootId":null,"fromId":23135,"content":"公司领导看谁不顺眼就扣谁绩效，领导安排的任务不管你时间够不够，说明天上线就明天上线，把所有问题丢给开发，他不管你加班还是通宵啥的，只看结果。还有就是圈子文化非常重，千万别去！！！！","createdAt":"2025-04-14T17:13:41"},{"id":"01963df6-6665-71cb-b219-2bc6b498ce79","parentId":null,"rootId":null,"fromId":21506,"content":"济南出了名的垃圾公司","createdAt":"2025-04-14T17:17:42"}]