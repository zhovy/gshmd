[{"id":"01963de0-6ebe-71fa-84f3-63b89e199206","parentId":null,"rootId":null,"fromId":1240,"content":"楼主有兴趣可以交个朋友","createdAt":"2023-03-15T18:41:23"},{"id":"01963de0-6f04-73de-82b4-d34579ef3fe1","parentId":null,"rootId":null,"fromId":1656,"content":"牛逼 顶","createdAt":"2023-03-15T21:50:03"},{"id":"01963de0-6f4b-7023-a38a-3dbd38bf888a","parentId":null,"rootId":null,"fromId":1977,"content":"支持楼主，本人同作为在职技术总监认同老兄的见解，哪怕做到这个位置在他们眼中一样是“臭干活的”，悲哀的济南IT圈","createdAt":"2023-03-15T22:43:19"},{"id":"01963de0-6fb7-7261-b225-fc5af44bbc40","parentId":null,"rootId":null,"fromId":1656,"content":"我转行去当hr吧，兄弟们投简历就找我 ?","createdAt":"2023-03-15T23:01:59"},{"id":"01963de0-7001-70b0-b7a3-4bfeda7f788f","parentId":null,"rootId":null,"fromId":1889,"content":"我也面试过，拖欠工资，我就没去，还好那个人资姐姐告诉我拖欠工资了，真心谢谢她","createdAt":"2023-03-16T08:44:46"},{"id":"01963de0-7080-727c-8e70-be84fb5deb32","parentId":null,"rootId":null,"fromId":1336,"content":"楼主有见识有担当佩服","createdAt":"2023-03-16T13:08:43"},{"id":"01963de0-70d2-71e3-a0f1-d302a2095a86","parentId":null,"rootId":null,"fromId":2287,"content":"侠客，你好，交个朋友吧","createdAt":"2023-03-16T16:40:49"},{"id":"01963de0-711d-731f-8913-9fa9ae0a5c8f","parentId":null,"rootId":null,"fromId":2082,"content":"同样去面试过，感觉不像是在招人","createdAt":"2023-03-16T18:18:59"},{"id":"01963de0-7161-71f7-8c6a-4910feaa5d9f","parentId":null,"rootId":null,"fromId":14,"content":"???","createdAt":"2023-03-16T18:48:23"},{"id":"01963de0-71a9-702c-bdd7-6311bcf8db6b","parentId":null,"rootId":null,"fromId":953,"content":"牛逼 6666 老铁","createdAt":"2023-03-16T21:40:10"},{"id":"01963de0-71ef-71d9-be1e-b78fe10054ee","parentId":null,"rootId":null,"fromId":1563,"content":"逼逼叨叨一大堆。干了十多年就牛逼哄哄的。不适合找工作，适合当老板。","createdAt":"2023-03-17T08:26:58"},{"id":"01963de0-7233-7309-8d6e-6eb7610afaab","parentId":null,"rootId":null,"fromId":1977,"content":"楼上看样是老板","createdAt":"2023-03-17T08:35:41"},{"id":"01963de0-7284-72a1-83ed-c735608676f2","parentId":null,"rootId":null,"fromId":333,"content":"11楼不谈对错只谈态度是吧  楼主说自己求职没有受到平等对待 而且还没入职就收集个人隐私  这种不正常的职场环境你觉得正常是吧  自己跪的久了看不得别人站起来是吧","createdAt":"2023-03-17T09:33:14"},{"id":"01963de0-72d2-702b-a3ab-c27a3b7aebb0","parentId":null,"rootId":null,"fromId":1955,"content":"表示赞同，你只不过是接触了有个HR而已，他们公司上面的领导都这德行。曾经面试过技术经理，上来也是人身攻击，那意思你得注意身体之类的，好嘛我面试的是技术，又不是面试当鸭子，你管我高矮胖瘦呢","createdAt":"2023-03-17T12:45:07"},{"id":"01963de0-731c-7094-9d1d-fcdfbd1db7a4","parentId":null,"rootId":null,"fromId":2958,"content":"11楼一看就急了，哈哈\n简单填写个人信息是正确的，你一家公司表格一大串，来了填一大堆，简历是没写明白还是故意收集私人信息？一般公司hr瞅两眼就算了，本身就是走个流程，楼主这种该怼怼，省的面试公司当大爷","createdAt":"2023-03-18T17:57:42"},{"id":"01963de0-7364-710f-b0cd-336c355685f0","parentId":null,"rootId":null,"fromId":1889,"content":"11楼是猴子搬来的救兵","createdAt":"2023-03-18T19:05:32"},{"id":"01963de0-73ae-7148-8e15-5898d88f308a","parentId":null,"rootId":null,"fromId":455,"content":"怀疑11楼就是那个恶心人的hr","createdAt":"2023-03-20T09:25:57"},{"id":"01963de0-73f5-71af-bfdc-bd0c04658168","parentId":null,"rootId":null,"fromId":508,"content":"这公司在黑名单上有两个帖子，我仔细看了一下，没有说加班问题的。我又在BOSS上看了一下公司简介，写的双休不加班。推测这家公司可能真的很少加班。\n\n个人观点：\n工作本质就是公司花钱买个人的时间，某头部明星企业，HR不把研发当人，口碑稀烂，还不是一直进人。\n也有说拖欠工资的，但是后来又说补齐了。我从业多年，越拖越久的公司听过见过不少，拖欠工资还能补齐的公司真的屈指可数。\n我处理应聘登记表的方式会更委婉一点，但是态度和楼主一样坚决，个人相关的部分会填满，背调之类涉及他人隐私的，会表示尚未征求他人意见，入职前再提供。\n\n择业是个相互的过程，每个人的标准都不一样。在我看来，薪资满意，不加班，就是很好的公司了，想去试试，并且投了简历，不过没要我……\n\n就像谈恋爱，你看得上的，不一定看得上你，看得上你的，你不一定能看得上。\n\n另外我特别讨厌求职这个词，明明是一个双向选择的问题，搞得好像求着招聘方一样。","createdAt":"2023-03-24T09:09:59"},{"id":"01963de0-7439-73f3-818c-e14250b2f78b","parentId":null,"rootId":null,"fromId":576,"content":"这家公司我去年3月份就面过这个技术总管的位置了，直到现在也还是这个女高管呗，没想到语气还是那么差劲，里面的人确实工位零零散散。因为我面试过，也问过面试官一些技术栈跟业务上的问题，技术上基本就是his，医疗器械，技术扩展这些事，业务上我猜着她应该是找不到一条好的方向了，因为当时我就算是同行过去面试的。好吧，面试官当时也很年轻，跟我差不多的岁数。我也是前公司架构负责人身份过去面的，面试时间面试人最不易，面试官每天在公司上班还是可以的，可以提前准备面试题面试内容扫码的，这女高管不理解咋回事实在神奇。而且我也没咋看上它的工作环境，真不如我前东家，即使我前东家是个20人不到的团队。","createdAt":"2023-03-27T14:43:42"},{"id":"01963de0-747d-7392-a48e-40924905841d","parentId":null,"rootId":null,"fromId":1927,"content":"几年前去面过一次，印象中是每天要打四次卡好像，溜了","createdAt":"2023-04-17T17:11:24"},{"id":"01963de0-74c2-70d4-91cb-f1a4a8a5b2a1","parentId":null,"rootId":null,"fromId":3460,"content":"我去哥们，现在有技术总监了；他们找到了。但我要跑路了","createdAt":"2023-05-07T21:44:52"},{"id":"01963de0-7506-725a-9f71-0df653d890f1","parentId":null,"rootId":null,"fromId":929,"content":"楼主有兴趣可以交个朋友\n","createdAt":"2023-06-01T15:57:57"},{"id":"01963de0-754a-724b-8c01-358d8987d1d9","parentId":null,"rootId":null,"fromId":2516,"content":"博乐通现在薪资发放正常吗","createdAt":"2023-06-12T12:23:34"},{"id":"01963de0-758f-71f3-9387-e1b97d4de34a","parentId":null,"rootId":null,"fromId":4087,"content":"各种理由拖欠。","createdAt":"2023-07-16T08:58:05"},{"id":"01963de0-7593-7007-9e7a-465377e033b3","parentId":null,"rootId":null,"fromId":4087,"content":"山东博乐通信息科技有限公司 不光工资拖欠 社保也拖欠 让自己交 恶心不","createdAt":"2023-08-15T18:17:48"},{"id":"01963de0-7598-72eb-ac81-4c64ed02b047","parentId":null,"rootId":null,"fromId":4087,"content":"老赖 一年了。","createdAt":"2024-01-09T17:35:51"},{"id":"01963de0-759d-73fd-9181-b83d74fba514","parentId":null,"rootId":null,"fromId":4087,"content":"马上就过年了 老赖","createdAt":"2024-01-23T11:04:12"},{"id":"01963de0-75a9-7178-ada2-c45ee880b195","parentId":null,"rootId":null,"fromId":5957,"content":"好帖","createdAt":"2024-01-23T15:20:39"},{"id":"01963de0-75a1-719d-a699-23507c4c3718","parentId":null,"rootId":null,"fromId":4087,"content":"自己不发工资 让你问爹妈借生活费  这样的公司你可曾遇到过奇葩。","createdAt":"2024-01-23T16:10:33"},{"id":"01963de0-75ed-7239-b0eb-1c2b33868d4a","parentId":null,"rootId":null,"fromId":4087,"content":"入职立刻欠薪一个月，白嫖你一个月工作和工资。","createdAt":"2024-01-25T13:55:13"},{"id":"01963de0-7636-7245-9a4c-a709e7578401","parentId":null,"rootId":null,"fromId":4087,"content":"姓佟的老板 满嘴跑火车 拖欠工资一天又一天，去年的工资都没结算呢。","createdAt":"2024-01-30T14:19:40"},{"id":"01963de0-75a5-737b-abe4-bda53eda47f8","parentId":null,"rootId":null,"fromId":4087,"content":"现在马上都过年了  还没发去年的工资和报销呢。缺德。","createdAt":"2024-02-04T13:58:58"},{"id":"01963de0-763b-712a-9a00-e4cc73b98f03","parentId":null,"rootId":null,"fromId":7427,"content":"妙啊，妙    入职即失业","createdAt":"2024-05-17T15:37:05"},{"id":"01963de0-7685-7358-81ca-3fccf783e0e0","parentId":null,"rootId":null,"fromId":21571,"content":"咋的，佟狗给他父母买棺材的钱攒够了？还是说他得绝症了？","createdAt":"2024-08-03T22:04:52"},{"id":"01963de0-768a-71a6-9ddc-014ea0ecd4a8","parentId":null,"rootId":null,"fromId":21571,"content":"把员工的工资用来给父母买棺材，真是个孝顺的好狗","createdAt":"2024-08-03T22:08:01"},{"id":"01963de0-768e-72a6-abda-e9fc3f74fe19","parentId":null,"rootId":null,"fromId":22501,"content":"还好我没去面试?","createdAt":"2025-02-11T09:21:52"},{"id":"01963de0-76d2-7362-82ba-cf2c7dc1486f","parentId":null,"rootId":null,"fromId":267,"content":"很大的坑","createdAt":"2025-03-25T07:15:18"},{"id":"019b2f04-f43f-739a-a7c7-a069c39554a9","parentId":null,"rootId":null,"fromId":1751,"content":"我一般也是空着或者瞎填，再得寸进尺就直接撤了（不过还没遇到过），还有非双休和岗位要求与薪资差距大的直接不用面","createdAt":"2025-12-18T09:13:32"}]