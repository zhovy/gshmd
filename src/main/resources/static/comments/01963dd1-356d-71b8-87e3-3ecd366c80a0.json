[{"id":"01963dd1-35e9-7245-81cd-a08d4b38e51b","parentId":null,"rootId":null,"fromId":111,"content":"情况不实，每天工作结束就下班了","createdAt":"2022-03-02T13:59:42"},{"id":"01963dd1-362e-73c9-b890-ebe165e2e51a","parentId":null,"rootId":null,"fromId":986,"content":"公司老总喜欢开会，而且喜欢在会上骂人。说员工是屌丝。","createdAt":"2022-07-15T14:52:35"},{"id":"01963dd1-3674-7032-9682-b796d198f6df","parentId":null,"rootId":null,"fromId":2403,"content":"1，说是六点工作完成就可以走，实际上没人走。\n2，说是拿出公司效益20%发年终奖，实际上只发了400，没少打0，就是四百，笑死。\n3，喜欢开会，开会就是批评你，不停地批评。\n4，很吝啬，不给配电脑，让你用虚拟机，卡的根本没法用，只能自己带笔记本，也就没有电脑补贴\n5，社保不按实发工资缴纳。\n6，代码就是屎山，不可维护，不可拓展，让你重构升级，又让你研发新项目，还得处理客户bug等问题，你时间根本不够用\n•••","createdAt":"2023-01-20T13:45:15"},{"id":"01963dd1-36b9-7344-8ec5-cf477420a16c","parentId":null,"rootId":null,"fromId":2409,"content":"hr说是虚拟机相关的研发，有兄弟知道是什么样的业务吗","createdAt":"2023-01-28T10:40:56"},{"id":"01963dd1-36fe-720e-a147-5ae78d380903","parentId":null,"rootId":null,"fromId":2418,"content":"总是快到下班才开会，实习期没有五险一金。","createdAt":"2023-01-29T17:29:24"},{"id":"01963dd1-3745-70ed-a4a6-3655b6449611","parentId":null,"rootId":null,"fromId":3195,"content":"目前未经历过九九六的加班，更别说加班到死了，虽说言论自由，但作为成年人是不是应该有点真凭实据才能发言，否则就是恶意诽谤了","createdAt":"2023-04-04T15:48:34"},{"id":"01963dd1-378b-7354-a493-4b53df3702bd","parentId":null,"rootId":null,"fromId":3249,"content":"同意6楼说的，目前未经历过九九六的加班，一直是零零七。成年人说话要负责任，劝楼主好自为之","createdAt":"2023-04-11T18:04:23"},{"id":"01963dd1-37d3-7265-a455-ab7fd9986a58","parentId":null,"rootId":null,"fromId":3252,"content":"6楼你能回答下你公司为什么员工上下班不用打卡嘛？是怕付加班费还是怕离职的以此为证据找你要加班费？","createdAt":"2023-04-12T07:50:39"}]