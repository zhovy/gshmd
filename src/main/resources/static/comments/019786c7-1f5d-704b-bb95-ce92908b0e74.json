[{"id":"019786c9-05dd-7372-a0f9-e8a38ec6faf1","parentId":null,"rootId":null,"fromId":460,"content":"在职 你都是怎么面试的？","createdAt":"2025-06-19T14:03:30"},{"id":"019786d4-bbb1-7068-86c0-c857dd87d4e4","parentId":null,"rootId":null,"fromId":24009,"content":"请假、中间溜出去线上面试、晚上线上面试，这三种吧","createdAt":"2025-06-19T14:16:18"},{"id":"019786d7-d631-7291-8520-d788eb7b354c","parentId":null,"rootId":null,"fromId":6827,"content":"为什么非要30天？","createdAt":"2025-06-19T14:19:41"},{"id":"019786d8-182e-7028-aac1-657b15456b8d","parentId":null,"rootId":null,"fromId":24162,"content":"首先解决你30天的问题，改成一周两周左右  正常交接都没那么久","createdAt":"2025-06-19T14:19:58"},{"id":"019786f2-a58e-7157-8414-4d98e3ccd4f2","parentId":null,"rootId":null,"fromId":414,"content":"现在行情这么好了吗，通过好几个？","createdAt":"2025-06-19T14:48:58"},{"id":"019786f3-049f-72c0-b66e-f4b9e61f976c","parentId":null,"rootId":null,"fromId":1421,"content":"着急入职一般也会着急裁，正常招人基本都能等半个月，一般提离职公司也就卡半个月交接。","createdAt":"2025-06-19T14:49:22"},{"id":"019786ff-1c3e-71e0-a03a-adf056e5d4c9","parentId":null,"rootId":null,"fromId":25238,"content":"1","createdAt":"2025-06-19T15:02:35"},{"id":"019786ff-e95e-7035-aabe-6676e91764a7","parentId":null,"rootId":null,"fromId":926,"content":"为啥等30天呢，正常来说一周左右时间就够了，我之前离职最快的时候，3天就办理完离职流程了，各个环节打电话催办就行了。交接也没那么长周期","createdAt":"2025-06-19T15:03:27"},{"id":"0197870c-23fa-728c-81f3-9f84661d983b","parentId":null,"rootId":null,"fromId":2422,"content":"敢问面试的哪几家，我都是已读未回?","createdAt":"2025-06-19T15:16:49"},{"id":"01978729-e538-73b8-9440-b99e3c8a8a00","parentId":null,"rootId":null,"fromId":25238,"content":".","createdAt":"2025-06-19T15:49:19"},{"id":"01978747-9735-73b9-93d6-fa7d47574297","parentId":null,"rootId":null,"fromId":1049,"content":"像你这种情况，招聘方就人为你是在骑驴找马，在多方比较，不是诚心入职","createdAt":"2025-06-19T16:21:45"},{"id":"0197875a-7687-732d-af18-7856cc274328","parentId":null,"rootId":null,"fromId":25238,"content":"那你说一到两周啊","createdAt":"2025-06-19T16:42:22"},{"id":"0197879f-f212-7260-b766-378dd18b4e25","parentId":null,"rootId":null,"fromId":21742,"content":"boss收钱 可能是没充会员 没钱跟你聊天","createdAt":"2025-06-19T17:58:15"},{"id":"019787a0-281f-73ee-bcd8-3401008d0c29","parentId":null,"rootId":null,"fromId":21742,"content":"交接也就一两周吧","createdAt":"2025-06-19T17:58:29"},{"id":"019787ad-c50f-7252-85ad-92fc83672a33","parentId":null,"rootId":null,"fromId":22863,"content":"不用认为，就是骑驴找马，但是机会合适也是诚心入职啊，反而那些要快速入职的公司，我感觉有那么一点点不靠谱，很有可能是人员的短期短缺","createdAt":"2025-06-19T18:13:21"},{"id":"019787b8-2be3-7351-a23f-954abbbc3f07","parentId":null,"rootId":null,"fromId":1421,"content":"哪个听到30天入职哪个不拒才是有病","createdAt":"2025-06-19T18:24:43"},{"id":"019787c6-8e19-7381-9c59-23f98349dc84","parentId":null,"rootId":null,"fromId":5661,"content":"30天入职的，拿着offer继续面，面到合适的爽约之前的offer，大概率是这样，骑驴找马本身就不太地道","createdAt":"2025-06-19T18:40:26"},{"id":"019787e5-0aea-717a-9b02-ff0c59bf5d21","parentId":null,"rootId":null,"fromId":6344,"content":"评论区都怎么了，骑驴找马不是正常的吗？劳动法规定的交接一个月，正规点的公司交接都会满一个月","createdAt":"2025-06-19T19:13:44"},{"id":"01978816-1ad5-7198-a959-48ca4bc2650a","parentId":null,"rootId":null,"fromId":1421,"content":"如果都这样干，等一个月后爽约，然后再招个再是这种情况，企业不得崩溃","createdAt":"2025-06-19T20:07:19"},{"id":"01978849-aa5a-72a8-98cf-3fa2c07e4a15","parentId":null,"rootId":null,"fromId":22316,"content":"你要是裸辞hr就可以压价了，骑驴找马不好压","createdAt":"2025-06-19T21:03:38"},{"id":"01978af3-185d-73ef-83b1-a34139e7007b","parentId":null,"rootId":null,"fromId":6470,"content":"晚上线上面试的单位是不是都加班啊？","createdAt":"2025-06-20T09:27:56"},{"id":"01978c28-9252-72e0-b66c-4d96acbd1850","parentId":null,"rootId":null,"fromId":1049,"content":"企业也不傻，会有备选","createdAt":"2025-06-20T15:05:58"},{"id":"0197917c-c49a-725b-9519-ec5482ceaab2","parentId":null,"rootId":null,"fromId":1049,"content":"说实话，我招聘人我没有因为对方离职就压价，只要人合适，价格HR同意就行，反正又不是我出钱","createdAt":"2025-06-21T15:56:02"}]