[{"id":"01963de5-2fd5-700d-b8c0-f1dd3528401d","parentId":null,"rootId":null,"fromId":1398,"content":"兄弟，我也想去北京，有消息了踢我一下","createdAt":"2023-07-19T15:53:41"},{"id":"01963de5-301a-7014-8413-5979f77bce49","parentId":null,"rootId":null,"fromId":4037,"content":"本科985 211的话，两年全栈，可以拿到15-20左右。另算年终奖或者绩效奖励","createdAt":"2023-07-19T16:18:45"},{"id":"01963de5-301f-71d9-9d3b-f55e3941d253","parentId":null,"rootId":null,"fromId":4142,"content":"尴尬了，普本","createdAt":"2023-07-19T16:32:31"},{"id":"01963de5-3023-7269-8661-530c6913ad05","parentId":null,"rootId":null,"fromId":1164,"content":"担心个啥小兄弟，北京混子多，高中毕业都能找到软件开发，更不用说本科了","createdAt":"2023-07-19T16:50:21"},{"id":"01963de5-3030-709f-9dca-dbec7b46b53e","parentId":null,"rootId":null,"fromId":875,"content":"现在是招聘淡季，不好找工作，企业也不好招人，怕个锤子，两年没有两万我不干(北京)","createdAt":"2023-07-19T19:21:22"},{"id":"01963de5-3027-706f-8569-ba6fe55a2590","parentId":null,"rootId":null,"fromId":4037,"content":"不用担心，现在大环境不好。先找到工作再说。","createdAt":"2023-07-20T09:41:11"},{"id":"01963de5-302b-7352-b705-e02fa4c660d2","parentId":null,"rootId":null,"fromId":576,"content":"普本也可以拿12-16k，千万不能再降低标准了，再低你就要在北京活不下去了，我在北京0.5年经验拿8k的，一个月交2700社保跟1000公积金，这还是几年前的。","createdAt":"2023-07-24T10:22:53"}]