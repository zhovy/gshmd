[{"id":"0197bfae-a6d7-7280-a303-b1ac6d9866b2","parentId":null,"rootId":null,"fromId":2783,"content":"你看又急 字都打错了","createdAt":"2025-06-30T15:13:03"},{"id":"0197bfb3-83cb-7294-9259-fe0cbd4151c8","parentId":null,"rootId":null,"fromId":6435,"content":"时间长，也得诉讼","createdAt":"2025-06-30T15:18:22"},{"id":"0197bfd5-e5a3-734b-874c-bf4abcaca7a2","parentId":null,"rootId":null,"fromId":4087,"content":"舜泰 小缅北","createdAt":"2025-06-30T15:55:55"},{"id":"0197c002-cedb-719c-b8f6-2f8e347a9662","parentId":null,"rootId":null,"fromId":6738,"content":"气的难受，垃圾公司就该倒闭破产","createdAt":"2025-06-30T16:44:58"},{"id":"0197c003-38e7-7026-ba92-c0374f3b9206","parentId":null,"rootId":null,"fromId":6738,"content":"狗去了都得留下点东西","createdAt":"2025-06-30T16:45:26"},{"id":"0197c003-ec9d-731b-984f-83ab02a38770","parentId":null,"rootId":null,"fromId":6738,"content":"明天准备东西去仲裁，不知道没有对方身份证能不能仲裁","createdAt":"2025-06-30T16:46:12"},{"id":"0197c01c-dd64-71d4-b170-e75f541166e3","parentId":null,"rootId":null,"fromId":1421,"content":"与对方身份证没关系吧，你这是与公司仲裁，有公司信息就可以","createdAt":"2025-06-30T17:13:26"},{"id":"0197c028-d193-7236-ada9-e4a548bc6376","parentId":null,"rootId":null,"fromId":25037,"content":"已经提离职了吗？因为欠薪离职的话可以试试要补偿金。","createdAt":"2025-06-30T17:26:30"},{"id":"0197c499-9018-70a4-b788-58a7126d3dcf","parentId":null,"rootId":null,"fromId":6738,"content":"可以试试，不过这个公司肯定不会给，就看仲裁会不会认可了","createdAt":"2025-07-01T14:08:07"},{"id":"0197c9ec-9a9b-7029-9398-4aa596a6b79e","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-07-02T14:56:55"},{"id":"0197e359-c797-73d5-9214-eb7f39d9a745","parentId":null,"rootId":null,"fromId":25037,"content":"以拖欠工资为由和公司提出离职，补偿金肯定会有的。就是数额多少了，到时候可以和公司谈判。","createdAt":"2025-07-07T13:26:41"},{"id":"0197ed1d-a4c7-7117-ba22-58fff50b851f","parentId":null,"rootId":null,"fromId":3266,"content":"济南商迅在线计算机网络技术有限公司 \n山东简码物联网有限公司\n山东聚芯物联网有限公司\n拖欠工资严重并且已经是失信人，找工作的的小伙伴们避坑","createdAt":"2025-07-09T10:57:12"},{"id":"0197ed40-67c2-7371-aed0-51d1da39472e","parentId":null,"rootId":null,"fromId":3266,"content":"公司 老板 经理都是限制高消费人群 就是老赖了  官司比员工都多 哪有钱","createdAt":"2025-07-09T11:35:10"},{"id":"0197ee48-2190-7155-ab12-5b2b20df39f9","parentId":null,"rootId":null,"fromId":25037,"content":"不仲裁这个钱永远拿不到，胜诉是一份保障，不会因为时间和其他因素导致这个权益消失。走到执行那一步再说，执行中还能有很多方式要钱呢，比如追加公司股东之类的。现实中有很多这种情形，老板有不少都给钱了，他们赌的就是你怕麻烦不仲裁。任何纠纷都是有诉讼时效的，劳动仲裁才1年的时效，时效过了你想要都要不到了。","createdAt":"2025-07-09T16:23:14"}]