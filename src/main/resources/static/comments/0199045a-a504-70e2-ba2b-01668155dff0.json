[{"id":"0199046e-a989-706e-81f3-5177d5d3dbaf","parentId":null,"rootId":null,"fromId":7124,"content":"借网贷上班，笑死了","createdAt":"2025-09-01T16:39:45"},{"id":"01990485-6965-7323-940f-4b355a2adfcc","parentId":null,"rootId":null,"fromId":22250,"content":"老登也是没办法，离职了找不到工作还不如赖着，家里老婆孩子要养，几千元的房贷要还。他们始终觉得工资会给的，面包会有的，牛奶也会有的。这样的心态不能怪老登，要怪就怪为什么本身是个穷光蛋还要贷款买房，为什么房贷还会这么高，为什么工作这么难找，为什么没人帮他们解决眼下这个局面！久而久之，怨气戾气积攒爆发，社会就动荡了。","createdAt":"2025-09-01T17:04:36"},{"id":"0199048a-98ab-70b2-a573-63db6029f6e4","parentId":null,"rootId":null,"fromId":21818,"content":"真有房贷要还怎么耗得住啊，银行不找你要么","createdAt":"2025-09-01T17:10:15"},{"id":"0199048c-b938-721f-ba10-cbce433b5a58","parentId":null,"rootId":null,"fromId":6747,"content":"我还是不太明白，真要是行业的问题，他就是转行送外卖也比赖在这好。\n现在的情况是去年发了四个月的工资，今年发了两个月的工资，平均下来能拿到低保线吗？真就是赖着不死。","createdAt":"2025-09-01T17:12:35"},{"id":"01990495-b778-730a-909d-5ee3fe702533","parentId":null,"rootId":null,"fromId":24615,"content":"牛逼啊，一个月不发工资就得抓紧仲裁了","createdAt":"2025-09-01T17:22:24"},{"id":"019904b3-9ffb-705a-9edf-75d4c5df5b97","parentId":null,"rootId":null,"fromId":22250,"content":"花老本呗，花光了再说","createdAt":"2025-09-01T17:55:04"},{"id":"019904b7-e0bf-7300-804a-982ec33f4aeb","parentId":null,"rootId":null,"fromId":22250,"content":"送外卖这么累他们不想干，手里有个几万的存款，房贷还能勉强还上，班上着期待老板可以良心发现，万一哪天裁员可就傻眼了，只能再投简历，找个外包上着，真找不到就真的送外卖当保安了。","createdAt":"2025-09-01T17:59:43"},{"id":"019907c3-a7e3-725f-8912-1a4e733ff683","parentId":null,"rootId":null,"fromId":2246,"content":"社会动荡了你咋这么高兴","createdAt":"2025-09-02T08:11:27"},{"id":"019907d4-6ce3-73d3-a1ec-96bde93281d1","parentId":null,"rootId":null,"fromId":22250,"content":"只能说粉红都活该","createdAt":"2025-09-02T08:29:46"},{"id":"019907e2-e21a-7017-b2a6-e271ae6b6057","parentId":null,"rootId":null,"fromId":6747,"content":"@WHOAMI 速来逮捕","createdAt":"2025-09-02T08:45:33"},{"id":"019907ef-21d1-73c0-8c71-bbb510c64dd4","parentId":null,"rootId":null,"fromId":1049,"content":"只能说活该，不团结起来治老板，还助纣为虐","createdAt":"2025-09-02T08:58:56"},{"id":"019907f7-055f-73cf-90b1-1a6af694e97d","parentId":null,"rootId":null,"fromId":6747,"content":"说的没错，你不干我不干骗子公司自然开不起来。找了那么多接借口又是房贷车贷孩子老婆的，放在七十年前当伪军也是合情合理了？","createdAt":"2025-09-02T09:07:33"},{"id":"01990805-f09f-72bb-a74e-00049b2712d1","parentId":null,"rootId":null,"fromId":22250,"content":"逮捕了你爹，对你有什么好处，着急去奔丧还是认个外国爹？","createdAt":"2025-09-02T09:23:51"},{"id":"01990810-1beb-711e-80d7-c9ff98dca51f","parentId":null,"rootId":null,"fromId":6747,"content":"着急当苍蝇是吧，饥不择食了，美帝的苍蝇说是","createdAt":"2025-09-02T09:34:57"},{"id":"0199083e-413b-725d-8982-8585c788eecc","parentId":null,"rootId":null,"fromId":2572,"content":"被压迫的不行不行，盼望重新洗牌吧","createdAt":"2025-09-02T10:25:21"},{"id":"01990931-63aa-70eb-a5bb-442a7ecc1e0c","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-09-02T14:50:55"},{"id":"01990931-f5e5-7035-894c-d414a8002051","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-09-02T14:51:33"},{"id":"0199093c-664a-7210-aa5c-724c8e313d78","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-09-02T15:02:57"},{"id":"01990942-606d-73e6-8973-ea0545788a11","parentId":null,"rootId":null,"fromId":7344,"content":"经典电子宠物的5个阶段第一阶段，甜甜圈真好吃这个时候的他刚来到自己的精神故乡，刚刚沐浴到文明之光，开始疯狂跪舔灯塔的底座，不停的秀优越感，仿佛自己重获新生了，自认为来了精神故乡就能大富大贵。这个阶段一般是电子宠物在初始阶段，这个时候的他们怀揣着对精神故乡的无比热爱，殊不知精彩的还在后面呢，甜甜菜真好吃。第二阶段，愁眉苦脸在受到了文明的洗礼之后，丝毫没有了刚开始的得意，在这个人生地不熟的精神故乡，连饭都快吃不起了，拍摄视角多在车内。一向自我感觉良好的他开始怀疑自己，但就是不能怀疑精神故乡。第三阶段，疯狂咆哮，这个时候的他在肉体和精神上都被文明摧残了，已经不太正常了，开始变得暴躁。第4阶段，走火入魔，这个时候他的脑子已经彻底不正常了，完全生活在自己脑补的世界里，认为全世界都是种花家的间谍，就连老登也没放过。这一阶段是电子宠物的巅峰赛，也是最有节目效果的时候。第5阶段，化作尘烟，电子宠物的结局化作一捧泥土，融入金钱故乡的土地，而且是字面意义上的。","createdAt":"2025-09-02T15:09:29"},{"id":"01991284-6e8a-71e2-9f08-8378f670e427","parentId":null,"rootId":null,"fromId":22542,"content":"送外卖还行，周末跑跑弄个四百","createdAt":"2025-09-04T10:18:13"},{"id":"01992756-193e-72c6-9ae2-43debd48adbe","parentId":null,"rootId":null,"fromId":22389,"content":"nb","createdAt":"2025-09-08T11:19:38"}]