[{"id":"01998442-cd3e-728f-b709-e8a4d818fc9b","parentId":null,"rootId":null,"fromId":2854,"content":"这就不劳您费心了","createdAt":"2025-09-26T12:23:14"},{"id":"01998507-7b63-70e0-8ace-fb445a5f4bb3","parentId":null,"rootId":null,"fromId":22250,"content":"希望您不得善终","createdAt":"2025-09-26T15:58:04"},{"id":"0199852f-5972-71e4-8865-7caf7a9609fd","parentId":null,"rootId":null,"fromId":2246,"content":"医生啥时候发不起工资了？","createdAt":"2025-09-26T16:41:36"},{"id":"01998575-bd2b-7023-b305-ff6ac65cb0d6","parentId":null,"rootId":null,"fromId":460,"content":"我认识的一个主任，人家就真不缺那点工资，全指着外快（自己的本事）。很多各种机构请他去演讲和讲课，是请，而不是咱们投简历求着入职，注意这一点。都60了还在不断的有人请他，包括漂亮国也可以给他绿卡。想想自己当下吧，别老是埋怨。","createdAt":"2025-09-26T17:58:29"},{"id":"0199863b-b30f-7233-8fd3-21496afd66db","parentId":null,"rootId":null,"fromId":7000,"content":"如何见的血崩，哪里的医生发不下工资","createdAt":"2025-09-26T21:34:43"},{"id":"01998dbb-cd9d-7086-8998-e68e056207fe","parentId":null,"rootId":null,"fromId":6939,"content":"真就是张嘴就来啊，你要说收入不如以前我信，发不出工资来可能有个例但总体看来医生还是稳定的职业。","createdAt":"2025-09-28T08:31:59"},{"id":"0199984b-ece7-73ef-8a25-97b84041acb8","parentId":null,"rootId":null,"fromId":22970,"content":"县域级的尤其是中医院里边，确实有好多只有基本工资了，绩效经常性的发不了。听说人人阳的有个大靠山进去踩缝纫机了","createdAt":"2025-09-30T09:45:36"},{"id":"01999874-8dc7-7100-8b8a-700045f2cedc","parentId":null,"rootId":null,"fromId":460,"content":"人家在怎么着  人家过得比你好  就算套现 人家三辈子不用上班 好好上你的班得了  这么大的公司 如果出现利益冲突  你看看 先顾你的利益还是公司的利益 拿着你那点薪水 操这么多闲心","createdAt":"2025-09-30T10:29:59"},{"id":"0199c6aa-8e54-7047-8547-f097926935fd","parentId":null,"rootId":null,"fromId":21742,"content":"医院的很多护士反正是欠薪的","createdAt":"2025-10-09T09:51:30"}]