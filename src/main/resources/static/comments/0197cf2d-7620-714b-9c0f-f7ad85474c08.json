[{"id":"0197cf4d-de7c-72bb-b395-29699a1b2cbe","parentId":null,"rootId":null,"fromId":7566,"content":"只能这么说，有个证书比没有要强点，但是也强不到哪去。高级的证书肯定比中级的证书有用，但是也就那么回事。如果实在是没啥事干，可以考一个证书。我备考的时候都是在某宝买网课、看网课，然后刷题。","createdAt":"2025-07-03T16:01:16"},{"id":"0197cf85-78f6-722c-890a-accdf5ce055b","parentId":null,"rootId":null,"fromId":1372,"content":"也就有比没有强，基本没有看这证书的。","createdAt":"2025-07-03T17:02:00"},{"id":"0197d31d-594c-7113-8928-3904052c3d3e","parentId":null,"rootId":null,"fromId":5689,"content":"你说的是软考？我有个高级的架构师证书，作用也有，就是刚考出来的时候，让周围人都羡慕了一番-_-","createdAt":"2025-07-04T09:46:45"},{"id":"0197d344-bb13-70de-a712-271f072a4654","parentId":null,"rootId":null,"fromId":6039,"content":"有两个高级证，系统分析师，系统架构设计师，除了抵个税，让别人羡慕有两证，其它也没啥用","createdAt":"2025-07-04T10:29:46"},{"id":"0197d41b-5257-7302-8dc3-cf879372ef54","parentId":null,"rootId":null,"fromId":21364,"content":"高项考出来能免费坐公交哈哈哈哈。别的，接zf项目的小公司投标有需要，本身学历就不错的在大公司晋升有需要。考试还有啥准备，报个课开学就行了，高项数学得好","createdAt":"2025-07-04T14:24:09"},{"id":"0197d447-9798-714f-929c-d1e77cd09946","parentId":null,"rootId":null,"fromId":6039,"content":"怎么申请免费坐公交","createdAt":"2025-07-04T15:12:31"},{"id":"0197d476-b399-7073-8279-25bb78e65c55","parentId":null,"rootId":null,"fromId":4002,"content":".tongwen","createdAt":"2025-07-04T16:03:58"},{"id":"0197d4b5-161b-7003-addb-14ce08e97865","parentId":null,"rootId":null,"fromId":21364,"content":"高项考下来去369申请人才卡就行","createdAt":"2025-07-04T17:12:06"},{"id":"0197d525-abd8-71be-8a51-8f66f4d1bccb","parentId":null,"rootId":null,"fromId":25594,"content":"评职称有用，当然了，私企没有职称这一说","createdAt":"2025-07-04T19:15:05"},{"id":"0197d936-7561-7190-829b-67b43e25277d","parentId":null,"rootId":null,"fromId":25606,"content":"感觉没啥用","createdAt":"2025-07-05T14:11:54"},{"id":"0197ee3c-fe30-730d-a174-e27f5b0cf51c","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-07-09T16:11:04"},{"id":"01981202-8c8c-730e-be7c-f59c1eb580ed","parentId":null,"rootId":null,"fromId":7427,"content":"+1 私企不存在一说","createdAt":"2025-07-16T14:53:33"},{"id":"