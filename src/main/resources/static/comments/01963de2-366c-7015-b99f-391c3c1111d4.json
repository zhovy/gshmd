[{"id":"01963de2-36e7-71aa-a8e1-3d75a7f4e833","parentId":null,"rootId":null,"fromId":2114,"content":"是个正常人，就不要去鲁软，现在各种制度恶心死人了。","createdAt":"2023-05-09T14:31:16"},{"id":"01963de2-373a-7177-8f89-15e5951893c3","parentId":null,"rootId":null,"fromId":2613,"content":"去了就是作死","createdAt":"2023-05-09T16:24:28"},{"id":"01963de2-3788-7064-90c3-691a6b45dab2","parentId":null,"rootId":null,"fromId":875,"content":"全部都是外包，经常出差去外地","createdAt":"2023-05-09T19:15:06"},{"id":"01963de2-377f-73ab-9cdc-50ccb50047a8","parentId":null,"rootId":null,"fromId":1391,"content":"具体说下","createdAt":"2023-05-11T10:27:44"},{"id":"01963de2-3784-7187-a89a-2d97d6a55912","parentId":null,"rootId":null,"fromId":2613,"content":"外包你自己想想吧","createdAt":"2023-05-12T14:27:37"},{"id":"01963de2-37d0-736a-a0ab-81fd8aaf574b","parentId":null,"rootId":null,"fromId":3697,"content":"入职第一天就跑路了，得出差，经常去那种电网运营的地方，都高度保密，一出差星期，手机都不能带，人直接失联，跟老人打听，都说不好～","createdAt":"2023-06-01T14:44:08"},{"id":"01963de2-381a-721b-9aea-c98d9738522f","parentId":null,"rootId":null,"fromId":1391,"content":"666","createdAt":"2023-06-04T15:52:21"},{"id":"01963de2-385f-719a-85f2-473356b519bf","parentId":null,"rootId":null,"fromId":1391,"content":"坑坑","createdAt":"2023-06-04T16:24:49"},{"id":"01963de2-38a4-7171-9aca-1510adeb7a4f","parentId":null,"rootId":null,"fromId":4143,"content":"2015年在鲁软工作过几年(电网事业部和研发中心)，属于外包，我个人待过的项目感觉还是挺好的，同事相处融洽，并没有出现歧视现象，偶尔有出过差，可能不同的事业部项目类型不一样出差长短也不一样。\n技术上有些是用国网UAP框架，有些项目则不需要。\n之前管理还是比较松散的，可能现在越来越多的规矩了。\n我所待过的项目，应该是没有主动辞退的，项目比较多所以一直处于招人的那种，项目经理有权给提请涨级别。如果没有涨级别外包公司一般不会给涨工资，要涨的话也比较少。","createdAt":"2023-07-20T10:10:24"},{"id":"01963de2-38e8-712a-bb50-c8cd7d0bb055","parentId":null,"rootId":null,"fromId":2613,"content":"要多坑有多坑，首先是面试态度即为恶劣，各种看不起人，然后说入职，入职第一天让安装环境，使劲催你，第一种就各种让你加班，不加班那好走人，没有一点人情味，还有就是你主要有一点态度不好的意思，你问他们问题直接不鸟你。这是我待过最垃圾的外包公司，一周后果断走人","createdAt":"2023-08-02T18:06:51"},{"id":"01963de2-392c-7059-999a-89786092a868","parentId":null,"rootId":null,"fromId":1150,"content":"前两天跳楼的是这里么","createdAt":"2023-08-03T08:16:11"},{"id":"01963de2-3970-736a-96cb-46570e4dd62d","parentId":null,"rootId":null,"fromId":403,"content":"员工跳楼了，你说好不好？","createdAt":"2023-10-27T08:00:47"},{"id":"01963de2-3815-7206-b50c-148dd4081434","parentId":null,"rootId":null,"fromId":6631,"content":"啊，啥岗位要出差呀。java开发岗也需要出差吗，上周说我面试通过了，在走流程了，也忘记问是否要出差了。不想问外包公司的hr，感觉外包公司hr为了让入职肯定各种说好好好。如果要出差的话，有点难受了。刚回济南对这边的情况了解不多，期望得到您的回复。","createdAt":"2024-02-26T16:36:03"},{"id":"01963de2-37cb-736f-a418-c39ecaf5d075","parentId":null,"rootId":null,"fromId":6631,"content":"java开发岗位也需要出差吗。刚回济南对这边的情况实在了解不多，上周面试通过了。忘记问是否要出差了。","createdAt":"2024-02-26T16:36:52"}]