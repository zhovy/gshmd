[{"id":"0196d20f-8e2f-70c6-bf25-c1688cf8a25a","parentId":null,"rootId":null,"fromId":6798,"content":"估计应该有个hr的群","createdAt":"2025-05-15T11:49:16"},{"id":"0196d258-038c-70a3-b2d1-3103dd7c291a","parentId":null,"rootId":null,"fromId":414,"content":"何止hr，面试官都认识我之前两家公司的同事，圈子很小很小的","createdAt":"2025-05-15T13:08:25"},{"id":"0196d268-8278-70b6-bc79-3bfce3c3cc6c","parentId":null,"rootId":null,"fromId":22695,"content":"Hr 是有群的，但是如果不是特别奇葩的也不会随便往上面发，这事儿类似于黑暗森林，你发上去相当于把自己也暴露出来，很容易被凝视，毕竟hr也有可能离职被裁，没人想要个一点点小事就斤斤计较背后蛐蛐别人的同事。","createdAt":"2025-05-15T13:26:26"},{"id":"0196d270-fc4f-7232-9a29-c26f0e354939","parentId":null,"rootId":null,"fromId":23971,"content":"还有hr也经常刷这个网站","createdAt":"2025-05-15T13:35:42"},{"id":"0196d2d2-00d2-7230-868b-32a2d8f4a3fe","parentId":null,"rootId":null,"fromId":1285,"content":"1","createdAt":"2025-05-15T15:21:40"},{"id":"0196d770-c900-705b-b3f1-3110591d2726","parentId":null,"rootId":null,"fromId":6170,"content":"Hr的群叫啥，信息好像在hr那都是透明的","createdAt":"2025-05-16T12:53:35"},{"id":"0196d7c1-dafd-70e6-b0b3-e8a4db72f163","parentId":null,"rootId":null,"fromId":22276,"content":"咱们是不是有一个QQ群啊，去年还在里面水过一段时间，长时间不登QQ，怎么没有了？哪位老师拉一下。","createdAt":"2025-05-16T14:22:08"},{"id":"0196d7f1-1fab-709c-8323-a8f9a4ac1fa0","parentId":null,"rootId":null,"fromId":21742,"content":"HR肯定有群的","createdAt":"2025-05-16T15:13:45"},{"id":"0196d80a-43fa-7039-bbd4-7a22245374ad","parentId":null,"rootId":null,"fromId":113,"content":"HR是有群的，500人微信大群。当年刚毕业工作没多久经历裁员，有个傻逼HR还拿这个群威胁过我们，说如果闹事就发这个五百人大群曝光我们，还掏出手机来给我看了看，现在想想也是真搞笑。后来这个HR去了一个叫什么幼吾幼网络，挺傻逼的一个HR。","createdAt":"2025-05-16T15:41:13"},{"id":"0196d80b-9e9a-7313-b616-a918e7e89efd","parentId":null,"rootId":null,"fromId":113,"content":"戏剧的是这个HR后来也被裁了","createdAt":"2025-05-16T15:42:42"},{"id":"0196d830-9997-7305-93b7-c4c2758ff07a","parentId":null,"rootId":null,"fromId":5661,"content":"对，这个网站上比较热门的公司出来的人，hr都会格外注意","createdAt":"2025-05-16T16:23:05"},{"id":"0196e151-e8f5-71a7-b658-3bff04f7768c","parentId":null,"rootId":null,"fromId":267,"content":"我准备卧底进hr的群，然后获取他们违法信息后，反向发给当事人","createdAt":"2025-05-18T10:56:03"},{"id":"0196e5ad-5f7f-7041-9df8-a9bb6c850ded","parentId":null,"rootId":null,"fromId":22695,"content":"这个HR要是真敢发，大概率以后别想在济南人力圈里混了。不过据说HR确实会特别“关照”某些学院毕业的人，因为这些学院的学生会负责人力资源考试的监考","createdAt":"2025-05-19T07:14:26"},{"id":"0196e763-c407-707c-90da-6d02287e000c","parentId":null,"rootId":null,"fromId":22389,"content":"是的","createdAt":"2025-05-19T15:13:17"}]