[{"id":"01963de8-7637-7346-a385-6cfbb2629879","parentId":null,"rootId":null,"fromId":1553,"content":"1","createdAt":"2023-09-22T10:46:00"},{"id":"01963de8-769c-7294-800d-13343a91eb43","parentId":null,"rootId":null,"fromId":1553,"content":"妖怪集团下的子公司(青岛),帮山东商智伙伴(也是妖怪集团的子公司)招聘,入职山东商智伙伴,试岗期3天.公司刚搬家从万达写字楼,搬到了鑫盛大厦,发工资不及时,这个月分两批发放,基本工资+绩效,基本工资已发,绩效未发,9月份由原来的双休改为了大小周(不确定以后会不会恢复双休),项目忙肯定会加班,有加班餐,无加班费,周末加班有调休,不忙准时下班,公司同事都很好相处,但是能力不行,会被辞退,有赔偿,基本不拖.背靠大公司,相对稳定,五险一金入职缴纳(最低)","createdAt":"2023-09-22T10:52:42"},{"id":"01963de8-76e3-73f5-bcf6-800d1396adf1","parentId":null,"rootId":null,"fromId":2082,"content":"所言全部属实","createdAt":"2023-09-26T16:46:33"},{"id":"01963de8-76eb-72e3-a019-1e79592bfe1a","parentId":null,"rootId":null,"fromId":1553,"content":"还没发绩效工资，垃圾公司，避坑","createdAt":"2023-09-26T17:24:43"},{"id":"01963de8-76e7-7276-853e-b2513adf4f71","parentId":null,"rootId":null,"fromId":5955,"content":"连着三个月分开发了发工资时间都不稳定","createdAt":"2023-10-18T16:11:57"}]