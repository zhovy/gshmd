[{"id":"01963de9-8c13-733b-8406-388e409a9ccb","parentId":null,"rootId":null,"fromId":6037,"content":"刚才搜了一下阿拉易我草有点可怕","createdAt":"2023-11-06T20:05:41"},{"id":"01963de9-8c58-720d-9010-f95beb9bd898","parentId":null,"rootId":null,"fromId":3198,"content":"考研吧，换个赛道，别搞java了，混个研究生学历","createdAt":"2023-11-07T09:09:51"},{"id":"01963de9-8c9c-726d-83c0-dae0378c7e7e","parentId":null,"rootId":null,"fromId":6037,"content":"自己水平知道考研估计难","createdAt":"2023-11-07T12:38:50"},{"id":"01963de9-8ca4-70d7-aae5-acf4812f7a45","parentId":null,"rootId":null,"fromId":1656,"content":"大差不差，除了几家大公司，小公司实习经验含金量一般般","createdAt":"2023-11-07T13:37:29"},{"id":"01963de9-8ca0-7243-8a4a-358cc8af563a","parentId":null,"rootId":null,"fromId":1074,"content":"考编制吧。","createdAt":"2023-11-07T14:15:48"},{"id":"01963de9-8ce9-7036-8692-3cd6ed88d994","parentId":null,"rootId":null,"fromId":3671,"content":"再找找吧，不一定非要在济南啊","createdAt":"2023-11-07T15:20:15"},{"id":"01963de9-8d2f-70d8-a9cf-b16e6df506b2","parentId":null,"rootId":null,"fromId":1003,"content":"宇宙的尽头是编制","createdAt":"2023-11-07T15:34:19"},{"id":"01963de9-8d92-71e1-9068-34d391cdfd04","parentId":null,"rootId":null,"fromId":2408,"content":"别来卷java了，太恐怖了~","createdAt":"2023-11-07T15:45:42"},{"id":"01963de9-8de3-7248-abd2-9e02a711c51e","parentId":null,"rootId":null,"fromId":576,"content":"换城市，不在山东，哪里都行","createdAt":"2023-11-08T12:59:57"},{"id":"01963de9-8e27-709d-9e7c-ad88f261818b","parentId":null,"rootId":null,"fromId":140,"content":"这个时候就不要考虑钱多钱少了，实习就不要想着挣钱，过来人的经验，应该去规模大的，流程完备的，权责分明的，去学习怎么干事情，怎么学习，保证自己能活下去就行，剩下的多学习学习吧，我刚毕业的时候去了一家小公司，整个人都被蹂躏的不行了，虽然出来了，但是感觉是人生污点了","createdAt":"2023-11-08T22:52:58"},{"id":"01963de9-8e6a-7284-b87d-1478260ad054","parentId":null,"rootId":null,"fromId":6037,"content":"好的哥，明白","createdAt":"2023-11-09T15:40:44"},{"id":"01963de9-8e6f-7122-a5a7-d40f1294be25","parentId":null,"rootId":null,"fromId":5987,"content":"阿拉易好像就是之前的河流道，注意一下风评，另外，如果不怕远，比较建议试试北上广的大厂，济南本土没有东西，而且北上广也在裁员，一旦人员回流，你又啥都不会，直接就失业。","createdAt":"2023-11-09T16:17:19"},{"id":"01963de9-8eb4-73ab-b7df-aae5d802fd0e","parentId":null,"rootId":null,"fromId":5461,"content":"从去年开始，济南互联网大环境已经不行了，不光济南，全国都是。各个公司都在裁员，相对好找工作的还是本科相关专业3-5年经验左右的，虽然好找，但是工资也要不上去了，往后竞争会越来越激烈，建议考研，要么考编","createdAt":"2023-11-11T16:22:43"},{"id":"01963de9-8efb-7119-98af-b0579f481e36","parentId":null,"rootId":null,"fromId":6979,"content":"本科-计算机专业-4年，也不好找，两星期了就几个回复的，在这网站上面一搜，还都不是啥好公司，多少都有负面信息","createdAt":"2024-03-13T12:52:08"}]