[{"id":"019b6f22-dc22-721e-80d1-b73cb147a75d","parentId":null,"rootId":null,"fromId":875,"content":"放什么，济南空气质量这么差，还放","createdAt":"2025-12-30T20:01:54"},{"id":"019b71cb-080f-7280-8467-5c235af6e086","parentId":null,"rootId":null,"fromId":22250,"content":"好像你生病就是放烟花导致的，你穷光蛋就是你不努力造成的","createdAt":"2025-12-31T08:24:49"},{"id":"019b71ce-17c2-72c4-8208-4a5a2ede6b5b","parentId":null,"rootId":null,"fromId":793,"content":"你让济南的大烟筒关上，你就是天天放都没事","createdAt":"2025-12-31T08:28:10"},{"id":"019b71ef-60a4-737e-a241-6927d2ec58e0","parentId":null,"rootId":null,"fromId":3341,"content":"还你奶贝没放呢就你奶贝空气质量差，过年放两天又能你奶贝怎么治啊","createdAt":"2025-12-31T09:04:31"},{"id":"019b71ef-8d8f-7332-be29-832ccbc20113","parentId":null,"rootId":null,"fromId":7074,"content":"去章丘放啊，章丘每年放的那么多，空气质量反而更好了","createdAt":"2025-12-31T09:04:43"},{"id":"019b71f3-4fad-73ae-bf23-089e1d6ba0c0","parentId":null,"rootId":null,"fromId":27118,"content":"没毛病哈哈","createdAt":"2025-12-31T09:08:49"},{"id":"019b71f7-a8a3-72c2-9f4b-02c426874550","parentId":null,"rootId":null,"fromId":22250,"content":"今年白搭了，章丘一个小区物业囤烟花爆炸了，死了好几个，今年章丘一个烟花都别想放了","createdAt":"2025-12-31T09:13:34"},{"id":"019b7225-c0ac-7122-a20c-35eee783e251","parentId":null,"rootId":null,"fromId":2921,"content":"无妨，章丘可以坐8号线去唐冶了","createdAt":"2025-12-31T10:03:55"},{"id":"019b7321-1ad7-73f5-90dd-46755b4102d3","parentId":null,"rootId":null,"fromId":22945,"content":"唐冶公园也没了","createdAt":"2025-12-31T14:38:28"},{"id":"019b786b-16e2-72f8-8f2b-fb1e9f7c9a98","parentId":null,"rootId":null,"fromId":875,"content":"你穷光蛋肯定就是因为你不努力啊，这有什么毛病，少壮不努力，老大徒伤悲！","createdAt":"2026-01-01T15:17:22"},{"id":"019b8c10-c9cc-7249-b969-2442266979a8","parentId":null,"rootId":null,"fromId":7074,"content":"该放放呗，现在他们想一刀切完全禁了，但是又不敢，为了少担责任，只能是发些不盖章不带红头的禁令。","createdAt":"2026-01-05T10:51:09"}]