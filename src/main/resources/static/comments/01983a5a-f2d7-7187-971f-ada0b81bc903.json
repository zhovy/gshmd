[{"id":"01983a5d-3b45-7271-b9af-dec65f8a7920","parentId":null,"rootId":null,"fromId":7124,"content":"挖掘机","createdAt":"2025-07-24T10:57:25"},{"id":"01983a62-537a-7193-8368-7cbe130f226a","parentId":null,"rootId":null,"fromId":3608,"content":"信息化监理经验，以前在正中？赛宝？锐通？国佳基业？","createdAt":"2025-07-24T11:02:59"},{"id":"01983a63-bf67-70a0-9485-d286bc939515","parentId":null,"rootId":null,"fromId":7078,"content":"有出大片的地儿吗","createdAt":"2025-07-24T11:04:32"},{"id":"01983a74-500f-73c4-a9c9-eb2dc592c36c","parentId":null,"rootId":null,"fromId":6423,"content":"回答你第一个问题，感觉你的想法有点理想主义，姑且认为你说的老了是退休以后。年轻在济南买房，老了去云南买房。先不考虑你们以后是否能存下云南买房的钱，等你们退休之年，孩子已长大成人 结婚生子，大概率还是会在山东，买房你得掏钱，结婚得掏钱，有了后代也许你们还得帮衬带孩子。你们去云南买房定居生活了，能舍得下家人吗.... 除非说家里有钱，或者未来能赚到安排好一切的钱，不然打消这个念头吧，只能济南or云南","createdAt":"2025-07-24T11:22:37"},{"id":"01983a7e-e7d8-7048-8c82-c942435c4cb0","parentId":null,"rootId":null,"fromId":25532,"content":"80W以下的预算在市区只能是2室的了，三室的得去章丘那边可以买得到","createdAt":"2025-07-24T11:34:12"},{"id":"01983a90-8f55-718d-b08b-d973aeb1d803","parentId":null,"rootId":null,"fromId":5480,"content":"楼上说的对，你确实太理想化， 等你老了，你有可能是存在上有老下有小的情况，小的你带去云南上学啥的肯定不如在济南好，老的也带去济云南？其次，房子一年一个价，等你老了是个啥情况还不一定呢","createdAt":"2025-07-24T11:53:29"},{"id":"01983b08-6b61-7263-a603-a3bfe9641f29","parentId":null,"rootId":null,"fromId":23279,"content":"真是，现在的是还没看明白的，先看到老了以后的事了，不实际，难怪会迷茫啊","createdAt":"2025-07-24T14:04:24"},{"id":"01983b7e-2359-71af-9ff8-ad8353ca2af9","parentId":null,"rootId":null,"fromId":2122,"content":"老不了，你知道65岁退休，按照现在的社会环境，一直到2040年就业竞争都比较激烈，你再干几年事情会更多，两边家庭的琐事，工作上的事情，感情的变化，很多事你在现在这个节点还没有意识到，因为没有发生。现在最好的就是攒钱，如果想买房子想生孩子就要准备好迎接经济上的压力","createdAt":"2025-07-24T16:12:59"},{"id":"01983ee3-2347-7085-b1f8-2cee66e69e07","parentId":null,"rootId":null,"fromId":2246,"content":"你既然可能去云南，为啥要在济南买，买了就是赔","createdAt":"2025-07-25T08:02:09"},{"id":"01983efe-1cd9-7200-8e55-3332db56c399","parentId":null,"rootId":null,"fromId":25996,"content":"哎，好吧[叹气]，谢谢","createdAt":"2025-07-25T08:31:37"},{"id":"01983eff-1cc0-7377-8bb8-42998bc611df","parentId":null,"rootId":null,"fromId":25996,"content":"对，也就是两室了，家里条件还可以不缺房子，还收租子。所以不在乎父母来不来住（他们也不稀罕过来，除非需要照顾了）","createdAt":"2025-07-25T08:32:43"},{"id":"01983eff-cee1-7122-840b-c34f052d8612","parentId":null,"rootId":null,"fromId":25996,"content":"也是，房子可以搁置一下，主要事业这块，确实不知道走什么路子了，想换行业了","createdAt":"2025-07-25T08:33:28"},{"id":"01983f00-5f4c-7270-a458-8d8c1ac1d373","parentId":null,"rootId":null,"fromId":25996,"content":"好的，谢谢老师","createdAt":"2025-07-25T08:34:05"},{"id":"01983f01-0ada-70f0-9a09-738c1e6f9083","parentId":null,"rootId":null,"fromId":25996,"content":"给孩子留个选择吧算是。济南有个房子，孩子以后或者我们以后也可以过来住。","createdAt":"2025-07-25T08:34:49"},{"id":"01983f01-df6a-7248-9d7c-e21ba3f40e72","parentId":null,"rootId":null,"fromId":25996,"content":"没有，我拍人文人像多一些，风景的话，你可能比我知道的都多","createdAt":"2025-07-25T08:35:44"},{"id":"01983f02-116f-7041-ab21-427de1abe09b","parentId":null,"rootId":null,"fromId":25996,"content":"赛宝的","createdAt":"2025-07-25T08:35:56"},{"id":"01983f5b-0115-71e7-af30-0c93188988c0","parentId":null,"rootId":null,"fromId":3319,"content":"计划的还挺远，","createdAt":"2025-07-25T10:13:05"},{"id":"01983f76-12b0-733a-a81e-ac2da8ba8a0a","parentId":null,"rootId":null,"fromId":6344,"content":"对于你转行这件事，我的建议是做你想做的，趁着你年轻还有机会，至于你说具体的行业我不懂给不了建议，不过你都6.5k了，也尝试一下别的工作呗，反正工资也低不到哪里去了，换工作的时候说不定就找到了你想做的。因为我想在考虑转行，不过我和你不同的是我已有目标，且我比你大6岁","createdAt":"2025-07-25T10:42:39"},{"id":"0198446d-d8c3-71bf-a414-e20f3e692951","parentId":null,"rootId":null,"fromId":267,"content":"这个工资确实不高，济南这个地，这样工资的也很多","createdAt":"2025-07-26T09:51:46"},{"id":"019849ba-e0b5-72f8-b998-7469e9f1227d","parentId":null,"rootId":null,"fromId":6344,"content":"所以说建议你尝试一下别的行业，会开阔你的眼界，找到自己想要的","createdAt":"2025-07-27T10:34:00"},{"id":"01984eb6-0dc8-731c-acf0-34242b6002c1","parentId":null,"rootId":null,"fromId":25996,"content":"转行后6.5k的工作感觉都找不到，只要不是干开发","createdAt":"2025-07-28T09:46:50"},{"id":"01984eee-e343-712f-9556-6f5ebcf5d5bf","parentId":null,"rootId":null,"fromId":6344,"content":"没有你说的那么夸张，我老婆做个物业工作还7k呢","createdAt":"2025-07-28T10:48:55"}]