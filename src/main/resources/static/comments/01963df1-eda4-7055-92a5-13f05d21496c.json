[{"id":"01963df1-ee0b-7027-92a6-c38c1f5218b5","parentId":null,"rootId":null,"fromId":1261,"content":"小寒羊，天天排队","createdAt":"2024-08-02T12:22:05"},{"id":"01963df1-ee50-7165-82df-b3a53472df14","parentId":null,"rootId":null,"fromId":6517,"content":"上周日去的，没排队，12点的时候，坐的比较满，但没人排队","createdAt":"2024-08-02T14:19:05"},{"id":"01963df1-ee98-7395-a79d-f13658a87839","parentId":null,"rootId":null,"fromId":3341,"content":"一般开车去的话 停车也都挺方便吧？","createdAt":"2024-08-05T11:05:01"},{"id":"01963df1-ee9d-71ae-bebf-d80055566573","parentId":null,"rootId":null,"fromId":3341,"content":"去吃过了 小寒羊，周六中午去需要排队 但是排队时间不长20分钟左右可以吃上。\n生串自己烤，菜品品类不少，按照排队情况看 菜品都很新鲜，碳火很旺 自己考很快就熟，口味很好 好吃。\n不过价格相对略高一点，实惠谈不长 吃个口味没问题。单串个体不大。","createdAt":"2024-08-23T10:37:53"}]