[{"id":"01963dd1-3d70-7261-ba9e-31ea8ba8c955","parentId":null,"rootId":null,"fromId":76,"content":"千万不要去就对了，没有一点优点","createdAt":"2022-02-09T10:47:28"},{"id":"01963dd1-3db8-7165-8f9f-9e0292bdc560","parentId":null,"rootId":null,"fromId":2121,"content":"确实，拖欠工资，并且老板极度小心眼，工资分两次发，一次3000，一次绩效，还不能说，公司十几年了，二十来个人。发展不动了","createdAt":"2022-11-01T11:41:06"},{"id":"01963dd1-3e06-7358-a30c-a554990dc5b2","parentId":null,"rootId":null,"fromId":1875,"content":"有朋友在该公司，这家公司简直无耻到令人发指，济南真的是资本家的天堂。工资欠了两个月 ，有员工去要工资，公司说过两天发，第三天 就接到了 辞退通知 理由相当奇葩。此外该公司规定夏天室外温度不超过38度不能开空调。绝了","createdAt":"2023-02-16T10:14:07"},{"id":"01963dd1-3e4f-70d7-8cda-a13c2c82b213","parentId":null,"rootId":null,"fromId":1969,"content":"工资拖欠几个月，说是双休偶尔加班，事实上是偶尔不加班。某些人阴阳怪气、画大饼，说什么项目奖金、年终奖，结果毛都没有，工资都发不齐，千万不要来。","createdAt":"2023-03-07T16:13:33"},{"id":"01963dd1-3ea1-7346-810f-3b2692f79a3c","parentId":null,"rootId":null,"fromId":2367,"content":"前段时间去面试了，人资一脸的优越感，看不起人。","createdAt":"2023-03-21T09:38:13"},{"id":"01963dd1-3ee6-7234-9030-dd210043c569","parentId":null,"rootId":null,"fromId":1969,"content":"公司的绩效考核及其离谱，涨的没有，月月有扣的，工作量自己估，估了公司给压，做不完扣工资。","createdAt":"2023-05-17T16:30:23"},{"id":"01963dd1-3f2b-7054-9150-9c40ef25cc7a","parentId":null,"rootId":null,"fromId":1969,"content":"说双休，周六公司让加班，有事请假必须钉钉申请，扣一天工资。平常加班没有调休！！没有加班费！！天天都加，加的少了还不行","createdAt":"2023-05-17T16:32:07"},{"id":"01963dd1-3f6f-70a9-975d-3665244cce83","parentId":null,"rootId":null,"fromId":1969,"content":"夏天必须10点后才能开空调，而且室外温度必须高于34度，否则罚款。室外34度，室内可想而知。第一次见互联网公司这么抠搜的，工资目前拖欠半年了，多找几天工作也别来这种公司！！！！","createdAt":"2023-05-17T16:36:05"},{"id":"01963dd1-3fba-71dc-873e-4e4c4006fff6","parentId":null,"rootId":null,"fromId":3242,"content":"楼上说的都是真的，没有一点夸张。公司就守着几个屎山项目吃老本，几乎没有新技术可言。领导画饼五年内上市，公司每人分股能分多少多少股，四五年了还在画这张老饼给新人吃。20年公司拖欠公司四五个月，都以为是疫情导致，其实是老板用公司的钱在玖玺城买了套房","createdAt":"2023-05-22T15:57:54"},{"id":"01963dd1-4058-7229-b51e-99b2f53fbbe8","parentId":null,"rootId":null,"fromId":1575,"content":"一家营业20年的公司，最近这几年一直处在半死不活的状态，可想贵公司有多牛逼，但凡有点能力的人，千万别去。","createdAt":"2023-07-12T11:29:46"},{"id":"01963dd1-3fb5-73a7-b395-4c9b4d08374e","parentId":null,"rootId":null,"fromId":1575,"content":"以孙总的尿性劲，干得出来，老奸巨猾的玩意。","createdAt":"2023-07-18T17:20:32"},{"id":"01963dd1-40a2-711a-93c2-504c5aeffc91","parentId":null,"rootId":null,"fromId":3242,"content":"工资发到一月份了，没跑路的都是勇者。","createdAt":"2023-07-28T11:50:28"},{"id":"01963dd1-40e7-7394-9cd0-71a0bd330de1","parentId":null,"rootId":null,"fromId":1575,"content":"工资都发到一月份了还有没跑路的，真厉害。孙老板给你们划了多大的饼，让你们死心塌地的给他干。","createdAt":"2023-08-03T11:46:53"},{"id":"01963dd1-40ec-71e7-8473-c944fd885038","parentId":null,"rootId":null,"fromId":3242,"content":"孙老板说了，今年大环境不好，离职=失业。能发工资就行，还管啥时候发。手动狗头。","createdAt":"2023-08-08T10:14:09"},{"id":"01963dd1-40fe-71de-afca-7e919f84fab6","parentId":null,"rootId":null,"fromId":4057,"content":"面试的时候就感觉到端倪了，公司环境不行hr不专业，很冷漠，面试官当场录取，当场画大饼，直接不敢去啊","createdAt":"2023-08-08T12:24:58"},{"id":"01963dd1-4141-705e-978d-6724a673dd81","parentId":null,"rootId":null,"fromId":1969,"content":"不去就对咯，都没几个技术了能不当场录取吗，现在估计都是走个流程了","createdAt":"2023-08-08T16:50:46"},{"id":"01963dd1-40f1-73fa-8415-7eecc5271dc3","parentId":null,"rootId":null,"fromId":1969,"content":"孙总天天就会吹牛，拖几个月就发一个月工资，再继续拖，23年工资争取24年发完","createdAt":"2023-08-11T11:45:49"},{"id":"01963dd1-40f5-71b8-a4a9-a4ffe49164fd","parentId":null,"rootId":null,"fromId":4355,"content":"不开工资还不跑，家里有矿？","createdAt":"2023-08-15T17:30:24"},{"id":"01963dd1-4145-700e-b007-e2e024fe2d0b","parentId":null,"rootId":null,"fromId":4355,"content":"劝大家不要去，就一句话，孙老板人不咋地！！！","createdAt":"2023-08-15T17:33:13"},{"id":"01963dd1-418a-73a1-86a6-86d27ba297be","parentId":null,"rootId":null,"fromId":3242,"content":"孙老板和好几个公司合作，最后都是掀桌子散场。","createdAt":"2023-08-17T16:00:14"},{"id":"01963dd1-418e-7259-8013-6af5dacedbd8","parentId":null,"rootId":null,"fromId":1969,"content":"快不行了，一点格局都没有","createdAt":"2023-08-17T17:18:30"},{"id":"01963dd1-41a4-7081-a7b9-74b68c2dfdac","parentId":null,"rootId":null,"fromId":5408,"content":"别去就对了，这b公司一点优点没有，还自以为经营的很好，纯纯掩耳盗铃，纯纯牛马，狗鸡巴不是，欠薪半年，只发个基本工资老板还挺有优越感","createdAt":"2023-08-18T15:53:27"},{"id":"01963dd1-41f0-73da-9cff-fd7a1f2cab91","parentId":null,"rootId":null,"fromId":1969,"content":"空调都不怎么舍得开的，这格局可想而知了，夏天不太好过吧，问问拖欠的工资爱答不理，干个活和催命一样","createdAt":"2023-08-18T16:10:18"},{"id":"01963dd1-4239-7154-942f-ebd5ce58c27b","parentId":null,"rootId":null,"fromId":5408,"content":"兄弟，千万别去，工资发不下来，纯纯流氓企业","createdAt":"2023-08-28T17:16:36"},{"id":"01963dd1-427c-72f7-8d7f-4b7a74621fcf","parentId":null,"rootId":null,"fromId":1969,"content":"6YO956a76IGM5ZCn77yM5pep5pel6L+c56a76L+Z5Liq5Z2R77yM6Kej6ISx77yB","createdAt":"2023-08-30T10:51:45"},{"id":"01963dd1-42c4-7356-a96f-f5e2f9e03366","parentId":null,"rootId":null,"fromId":1969,"content":"base64","createdAt":"2023-08-30T10:51:58"},{"id":"01963dd1-42c8-72b6-8f8c-abfa156fefef","parentId":null,"rootId":null,"fromId":5408,"content":"都离职吧，早日远离这个坑，解脱！（解码后的，不谢）","createdAt":"2023-08-30T16:07:08"},{"id":"01963dd1-4193-7396-848a-5c01f8b5c3ce","parentId":null,"rootId":null,"fromId":6090,"content":"这人的确不行，很腹黑","createdAt":"2023-11-09T15:34:14"},{"id":"01963dd1-42cd-739f-ac4c-0ad7b8047d47","parentId":null,"rootId":null,"fromId":6090,"content":"公司做事很脏，千万不要去；慎重","createdAt":"2023-11-09T15:34:39"},{"id":"01963dd1-4197-72cc-9ee6-e78209cc4efd","parentId":null,"rootId":null,"fromId":6090,"content":"这人 的确不怎么样，道貌岸然","createdAt":"2023-11-28T14:41:41"},{"id":"01963dd1-4234-701c-965e-adec9982220f","parentId":null,"rootId":null,"fromId":6090,"content":"有个板凳就不错了","createdAt":"2023-11-28T14:42:41"},{"id":"01963dd1-4311-7268-aa1b-52b963830012","parentId":null,"rootId":null,"fromId":6090,"content":"千万别入坑，工资只发3500；快过年了年中 报销还没给呢。跟黑工厂似的","createdAt":"2023-12-14T15:30:06"},{"id":"01963dd1-404f-7083-8bd7-bd4eca1e96df","parentId":null,"rootId":null,"fromId":6090,"content":"老板没格局；吹嘘自己多有资源，但一个项目也搞不到；其实是人家不跟他玩；只卖自己那套检察院的系统，其他一概不行","createdAt":"2023-12-14T15:33:40"},{"id":"01963dd1-419b-70ec-929f-99ed1f88f9b3","parentId":null,"rootId":null,"fromId":6090,"content":"姓孙的确实不咋滴，还有穆yu wen感觉牛的跟个啥似的就是个舔狗、那个总工技术不敢恭维啊，","createdAt":"2023-12-16T14:58:34"},{"id":"01963dd1-3dfd-73ef-8f52-bbdb2e303036","parentId":null,"rootId":null,"fromId":6090,"content":"开发还处在20年前的水平","createdAt":"2023-12-16T14:59:01"},{"id":"01963dd1-4357-70d1-8f6c-1d0b01c663b1","parentId":null,"rootId":null,"fromId":3242,"content":"绩效工资发到六月份了吗?","createdAt":"2023-12-19T15:30:26"},{"id":"01963dd1-4360-73c2-84bc-2cfefc018be1","parentId":null,"rootId":null,"fromId":6362,"content":"离职后工资不当场结算清除，现在还欠这2个月的工资。\n后悔当初呀。","createdAt":"2024-02-04T16:17:27"},{"id":"01963dd1-43a3-73f1-9bb6-fb63f8992bb0","parentId":null,"rootId":null,"fromId":6627,"content":"幸好只有2个月，及时止损，在职的欠的更多","createdAt":"2024-02-05T16:56:48"},{"id":"01963dd1-435b-71c6-9736-38d433f46bdb","parentId":null,"rootId":null,"fromId":6627,"content":"发到7月了","createdAt":"2024-02-05T16:57:11"},{"id":"01963dd1-43a8-7322-9df2-b971b27ba2b8","parentId":null,"rootId":null,"fromId":6634,"content":"去面试了    让我两个月以后入职   你现在不招人面什么试啊   搁着刷kpi吗？","createdAt":"2024-02-06T15:44:18"},{"id":"01963dd1-43ed-70a6-a0be-88283b6d44ad","parentId":null,"rootId":null,"fromId":1969,"content":"你该面试前就来看看的，留时间去面试别的公司不好吗","createdAt":"2024-02-06T16:11:25"},{"id":"01963dd1-43f2-7131-8bd9-63e9c37e45eb","parentId":null,"rootId":null,"fromId":6090,"content":"让员工轮流给老板洗菜，涮火锅；这种公司可想而知","createdAt":"2024-02-25T15:57:33"},{"id":"01963dd1-443f-7318-8cbc-d23057ac1aff","parentId":null,"rootId":null,"fromId":6090,"content":"老板不怎么样，人资也全走了，基本新入职的也全部走了","createdAt":"2024-02-25T15:58:19"},{"id":"01963dd1-4490-72c2-b4cc-4d535e6a05c5","parentId":null,"rootId":null,"fromId":6632,"content":"我去整么坑的吗  我刚收到这家公司的offer","createdAt":"2024-02-26T13:45:48"},{"id":"01963dd1-4436-70d1-8419-c43440b05da2","parentId":null,"rootId":null,"fromId":1969,"content":"这是又出新花样了啊，太秀了","createdAt":"2024-02-27T15:17:18"},{"id":"01963dd1-44d4-7306-b507-caa740244c82","parentId":null,"rootId":null,"fromId":1969,"content":"在这公司不如去卖淀粉肠","createdAt":"2024-02-27T15:19:05"},{"id":"01963dd1-44d9-7377-87e7-7297ab3ac562","parentId":null,"rootId":null,"fromId":1875,"content":"程序员的梦 卖淀粉肠","createdAt":"2024-02-27T15:35:37"},{"id":"01963dd1-443b-7235-b965-e1f8b5e425e2","parentId":null,"rootId":null,"fromId":5408,"content":"没给你吃点嘛","createdAt":"2024-02-28T16:17:51"},{"id":"01963dd1-44e1-71dd-a214-76751b7f66c4","parentId":null,"rootId":null,"fromId":3242,"content":"公司框架 ssm+jsp，十几年前的技术，奉劝刚毕业和刚工作几年的伙计们千万不要来，技术经验积累不到工资还发不到手。","createdAt":"2024-03-01T14:54:36"},{"id":"01963dd1-4527-7031-b641-363cf21816c4","parentId":null,"rootId":null,"fromId":6632,"content":"最近换了 框架换成若依的了 不过感觉没啥用 公司都发不下来","createdAt":"2024-03-04T08:43:36"},{"id":"01963dd1-448c-70bd-ac49-4581989ea4a4","parentId":null,"rootId":null,"fromId":6632,"content":"我怎么说面试的时候 那人事和新人一样","createdAt":"2024-03-11T16:48:21"},{"id":"01963dd1-452b-721f-9b06-8bfc5b19e879","parentId":null,"rootId":null,"fromId":6090,"content":"公司老板很腹黑，说能做这能做那，多么有关系，结果啥也干不了，就是骗你方案。千万别去浪费时间","createdAt":"2024-03-17T09:53:35"},{"id":"01963dd1-4575-7360-890b-1555d777ed1d","parentId":null,"rootId":null,"fromId":5913,"content":"宏业","createdAt":"2024-03-17T15:24:54"},{"id":"01963dd1-45ba-7366-a9ea-f94cc6cad8d2","parentId":null,"rootId":null,"fromId":2783,"content":"没搜到这个公司呢","createdAt":"2024-03-17T18:10:09"},{"id":"01963dd1-45ff-7244-a681-ce2a2b5fee18","parentId":null,"rootId":null,"fromId":5913,"content":"boos改成山东宏业了","createdAt":"2024-03-17T19:23:57"},{"id":"01963dd1-4604-73eb-a77f-9b72ccdf9e9a","parentId":null,"rootId":null,"fromId":5408,"content":"不知道鸿业和宏业是不是同一个公司，我记得我在鸿业的时候就看到过宏业的招聘信息","createdAt":"2024-03-18T13:36:59"},{"id":"01963dd1-4608-71c0-9f6c-f5bd941e2d03","parentId":null,"rootId":null,"fromId":5913,"content":"好像不是一个","createdAt":"2024-03-18T13:49:03"},{"id":"01963dd1-44dd-73bc-8872-445499ba4dd9","parentId":null,"rootId":null,"fromId":2823,"content":"现在淀粉肠也没人吃了。。","createdAt":"2024-03-20T14:29:17"},{"id":"01963dd1-4655-7367-b00c-82b87a04e7be","parentId":null,"rootId":null,"fromId":1969,"content":"希望鸿业也好好提升，证明上述非鸿业行为，早日实现上市的目标 --","createdAt":"2024-08-07T17:24:09"},{"id":"01963dd1-465a-73dd-81bb-0691c4e7b933","parentId":null,"rootId":null,"fromId":7040,"content":"姓穆与姓付的就俩狗腿子，孙玉liang 就是个骗子，不发工资还吓唬员工，找了几个人在公司吃火锅，让员工轮流给他洗菜；难道在外边吃不起吗","createdAt":"2024-09-12T18:56:34"},{"id":"01963dd1-46a8-7235-ab7d-2c1003749458","parentId":null,"rootId":null,"fromId":6090,"content":"黑公司，抓紧撤","createdAt":"2025-01-14T11:26:01"},{"id":"01963dd1-3e01-7069-85ff-e067034f80fc","parentId":null,"rootId":null,"fromId":6632,"content":"对这个老孙就是个小人，经常当面检察院笑嘻嘻，背后就说人家的坏话，对员工也是一种不把你当人的态度，去了这公司就是他的玩物，他想怎么样就怎么样。","createdAt":"2025-02-15T00:26:12"},{"id":"01963dd1-3e9c-7300-8196-bf7c37bb56c8","parentId":null,"rootId":null,"fromId":6632,"content":"还年终奖，工资都发不下来的那种，还分两次发，还不能说，这老东西估计是拿着公司的钱潇洒的投资去了，员工在他眼里算个屁啊？","createdAt":"2025-02-15T00:28:14"},{"id":"01963dd1-4054-7249-ab09-917b03a20c01","parentId":null,"rootId":null,"fromId":6632,"content":"哈哈哈，人家检察院的人都瞧不起他的感觉。天天给人家吹嘘自己的那套老东西，换在哪里自以为是的感觉人家特别需要他的产品，其实人家都瞧不上他。","createdAt":"2025-02-15T00:31:29"},{"id":"01963dd1-41a0-7094-a50a-a5c1efa3e886","parentId":null,"rootId":null,"fromId":6632,"content":"孙老板确实不大行啊，人品烂的很，而且特别自恋，总以为自己了不起，瞧不起检察院，看不起浪潮集团。","createdAt":"2025-02-15T00:34:31"},{"id":"01963dd1-41ec-70d0-9a2e-25232a2d1312","parentId":null,"rootId":null,"fromId":6632,"content":"姓孙的说现在形式不好，在这里干活还有工资拿，出去就找不到活","createdAt":"2025-02-15T00:36:28"},{"id":"01963dd1-460c-73aa-8485-d4d91a32924f","parentId":null,"rootId":null,"fromId":6632,"content":"可不得改名吗，公司名声让老孙搞得臭的很，可不得赶紧套个壳继续骗啊","createdAt":"2025-02-15T00:40:13"},{"id":"01963dd1-469f-7108-928e-47b65fc73004","parentId":null,"rootId":null,"fromId":6632,"content":"涮火锅老东西抠得很，不想请人家去高档饭店，整了点超市的肉，自以为说他这里的肉干净，其实就是不想花那个钱。","createdAt":"2025-02-15T00:44:48"},{"id":"01963dd1-3db4-7133-a59e-01bcb00da8b9","parentId":null,"rootId":null,"fromId":6632,"content":"这公司老板，有项目了就招一些高级开发，然后开发完了就把人恶心走，或者开了","createdAt":"2025-02-17T18:26:12"},{"id":"01963dd1-46ec-73a2-8a9b-7b8d263bbca7","parentId":null,"rootId":null,"fromId":6090,"content":"这公司一窝骗子；那年骗我方案来，幸亏留了一手，做了一半，核心东西没出","createdAt":"2025-02-26T17:29:00"},{"id":"01963dd1-46a3-7377-aca9-460e3e3e87fe","parentId":null,"rootId":null,"fromId":22834,"content":"还有个副总，也挺能装的","createdAt":"2025-02-27T11:44:32"},{"id":"01963dd1-4731-700b-b405-498fbd916da9","parentId":null,"rootId":null,"fromId":6632,"content":"孙名副其实的白嫖王，就算留下来也会找各种理由挤兑你的","createdAt":"2025-04-01T14:39:48"},{"id":"01963dd1-40f9-7160-b3d9-f0323e30416e","parentId":null,"rootId":null,"fromId":6632,"content":"公司存在着 \"画饼文化\"（虚假承诺）、\"赛马机制\"（恶意内部竞争）等配套操作，把这群人都忽悠一愣一愣的","createdAt":"2025-04-01T14:48:54"},{"id":"0196667c-2ddb-721b-8238-82d0825c7188","parentId":null,"rootId":null,"fromId":6632,"content":"孙老板心眼很黑，不像是中国人，感觉是日本人生的杂种","createdAt":"2025-04-24T14:28:56"}]