[{"id":"01967190-fbda-7145-955a-828c73895837","parentId":null,"rootId":null,"fromId":1372,"content":"不买房不就行了。房地产这种阳谋为什么要上当？","createdAt":"2025-04-26T18:07:29"},{"id":"0196748d-79b9-705a-97f6-afd4f268a8c3","parentId":null,"rootId":null,"fromId":875,"content":"不买房怎么行，不买房相亲对象都不正眼看你一眼，不买房交10年房租你算算的多少多少钱，都够交首付的了","createdAt":"2025-04-27T08:02:30"},{"id":"019674bd-b981-7117-8a1a-f6ba11de60e5","parentId":null,"rootId":null,"fromId":4190,"content":"先买个便宜房住着，慢慢混","createdAt":"2025-04-27T08:55:13"},{"id":"019674c0-5f63-7252-8dc2-2b9c2906316e","parentId":null,"rootId":null,"fromId":22695,"content":"好像威海还有个新北洋？前几年的信儿不知道现在这个公司还活着不","createdAt":"2025-04-27T08:58:06"},{"id":"019674d8-4021-7160-86ee-ff115cf1a50f","parentId":null,"rootId":null,"fromId":3319,"content":"济南也不贵啊，码农大部分 都能买得起","createdAt":"2025-04-27T09:24:11"},{"id":"019674df-d1a9-71a8-8419-a3c334befb05","parentId":null,"rootId":null,"fromId":6939,"content":"硬买呗，刚需盘应该能买得起，我当初买的时候工资4000，房价7000，家里也出不了多少，缓了五六年才缓过来。","createdAt":"2025-04-27T09:32:27"},{"id":"019674e9-4b28-7230-a690-c295815fb026","parentId":null,"rootId":null,"fromId":6939,"content":"假如你能拿出20w首付，那你最高可以买120万左右的房子，月供大概4000-4500之间，下去几年可以提前还点，控制月供到3000以下就轻松了，到时候就算失业随便干点啥也能凑出这房贷来，如果首付能高点，贷款再高点，那还能有更多的选择，月供控制别超过工资的一半风险相对会小不少。","createdAt":"2025-04-27T09:42:48"},{"id":"01967519-101d-7317-a2a4-1f48853e9756","parentId":null,"rootId":null,"fromId":7281,"content":"这行情30来岁失业的可能极大，建议不买或者首付多付少贷一些。","createdAt":"2025-04-27T10:34:58"},{"id":"01967574-1e01-733d-be3e-7210c65aea40","parentId":null,"rootId":null,"fromId":875,"content":"7000块兄弟你捡大漏了，现在买怎么不得一万七起步","createdAt":"2025-04-27T12:14:26"},{"id":"01967576-6b65-7307-aef4-c35ee7b843f2","parentId":null,"rootId":null,"fromId":875,"content":"买个一室的公寓得了，背房贷没必要，要不就花800块钱租一间","createdAt":"2025-04-27T12:16:57"},{"id":"019675ef-ff08-7235-8a0f-f82b35c43af2","parentId":null,"rootId":null,"fromId":6939,"content":"兄弟你看看我当初的工资啊，我买的唐冶，这个价格都是10年前的价格了，而且当初唐冶还啥都没有呢，当初凑个20万的首付都费劲啊。","createdAt":"2025-04-27T14:29:44"},{"id":"01967671-9a39-712f-ad2a-9afdf34aa313","parentId":null,"rootId":null,"fromId":122,"content":"我一直纳闷一个问题 非济南/青岛本地土著 不是为了定居 何必来这打工？","createdAt":"2025-04-27T16:51:18"},{"id":"01967672-c8f8-70c7-9ae8-9647349eabc9","parentId":null,"rootId":null,"fromId":122,"content":"如果没有超半数的首付或稳定的还款能力 真不建议入手","createdAt":"2025-04-27T16:52:36"},{"id":"019676a0-15a5-7238-80f2-8cc687adc873","parentId":null,"rootId":null,"fromId":22875,"content":"10年房租应该是10w左右吧,在青岛和济南能交住宅的首付吗","createdAt":"2025-04-27T17:42:04"},{"id":"01967853-7a77-71a3-9265-175fa27c83b2","parentId":null,"rootId":null,"fromId":875,"content":"我也想不明白，那么多在济南找不到好工作，又不是本地人，还不去一线城市多挣钱，就算35开滴滴送外卖也要在济南图啥呢，就图个一个离家近点","createdAt":"2025-04-28T01:37:38"},{"id":"01967982-586a-707e-a991-c361ac8fa45d","parentId":null,"rootId":null,"fromId":875,"content":"努力吧，闷头写代码不看路，现在是早上7点钟，外卖小哥都忙起来了，你们都还在呼呼大睡","createdAt":"2025-04-28T07:08:27"},{"id":"01967a4d-72c5-7145-ab23-8f3b249937b0","parentId":null,"rootId":null,"fromId":22702,"content":"买房没有任何理由 你能抄到底 你就没有任何毛病 你要是和我一样 两年亏40万 什么结婚买房 都是放屁","createdAt":"2025-04-28T10:50:18"},{"id":"01967a6c-0bd0-7045-9296-443badb4ef27","parentId":null,"rootId":null,"fromId":3319,"content":"是的 既然租房 不如北上深","createdAt":"2025-04-28T11:23:43"},{"id":"01967cd3-c5fd-7204-b1ea-2d9100d449e5","parentId":null,"rootId":null,"fromId":22959,"content":"老家更没啥工作啊  大多数都贷款买房 没办法","createdAt":"2025-04-28T22:36:15"},{"id":"01968040-0967-739f-875b-1c728431e20d","parentId":null,"rootId":null,"fromId":21511,"content":"家里全款买的","createdAt":"2025-04-29T14:33:22"},{"id":"0196ae70-8db9-73d7-bfd2-a4c26a900aee","parentId":null,"rootId":null,"fromId":1933,"content":"找工资高和离家近的平衡点","createdAt":"2025-05-08T13:48:54"}]