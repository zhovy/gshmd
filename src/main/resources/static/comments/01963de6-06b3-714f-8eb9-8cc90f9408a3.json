[{"id":"01963de6-0723-71af-8b69-88f69740eceb","parentId":null,"rootId":null,"fromId":2921,"content":"招商引资从北京请来的大爷，人浮于事一地鸡毛，懂得都懂","createdAt":"2023-08-08T08:57:25"},{"id":"01963de6-0768-7158-bd6d-49151a6b8b73","parentId":null,"rootId":null,"fromId":4057,"content":"能展开说说吗,期望值很低,能正常发工资,没有996就行","createdAt":"2023-08-08T11:33:51"},{"id":"01963de6-076c-7289-8af2-8c0529ea0f51","parentId":null,"rootId":null,"fromId":4057,"content":"2020年公司成立,始终没有形成公司的支柱产业，一只找产业，找方向,做计划做方案多,落实的少,2023年春节后公司层换了领导,提倡工作日加班,周六加班,取消了一些福利,不知道未来会发展怎么样。\n——智联搜的","createdAt":"2023-08-08T11:57:01"},{"id":"01963de6-07b5-7093-8bf0-c5d2dc163d6b","parentId":null,"rootId":null,"fromId":4327,"content":"能正常发工资，遇到周末节假日提前发，不加班","createdAt":"2023-08-08T12:24:11"},{"id":"01963de6-07fc-73d7-a644-4f317daa66fc","parentId":null,"rootId":null,"fromId":916,"content":"在职员工说一下\n1.新的王总上来之后，福利待遇都没了，节假日福利也取消了\n2.周报安排上了，周六要求加班，会也多起来了，平时也需要加班\n3.下班不让到时间就走，需要呆一会\n4.离职了很多人，包括中层，公司人越来越少\n感觉在走下坡路，最近说是工资要走绩效+基本工资，明眼人都知道什么意思","createdAt":"2023-08-08T14:51:29"},{"id":"01963de6-083e-7034-af09-7041b8fa25fd","parentId":null,"rootId":null,"fromId":4057,"content":"一方面求职难,一方面又不敢去,哎","createdAt":"2023-08-08T15:40:52"},{"id":"01963de6-07f7-73b3-9501-33f36fc68d79","parentId":null,"rootId":null,"fromId":4057,"content":"楼上说加班捏","createdAt":"2023-08-08T15:41:28"},{"id":"01963de6-0859-73ba-84af-630f8b19f6e5","parentId":null,"rootId":null,"fromId":4327,"content":"公司正在准备上市，未来可期","createdAt":"2023-08-08T15:45:38"},{"id":"01963de6-08a1-711d-b06c-24734819289b","parentId":null,"rootId":null,"fromId":4057,"content":"啊?您是王总吗哈哈( •̀ ω •́ )✧","createdAt":"2023-08-08T15:54:07"},{"id":"01963de6-08a5-73d4-9f13-f9fc16fbfb7b","parentId":null,"rootId":null,"fromId":4081,"content":"需不需要加班啊","createdAt":"2023-08-08T15:57:30"},{"id":"01963de6-0844-7150-9404-2faf0102e8be","parentId":null,"rootId":null,"fromId":4057,"content":"绩效工资占比多少?","createdAt":"2023-08-08T16:34:19"},{"id":"01963de6-0848-722c-a6e7-169cad79d849","parentId":null,"rootId":null,"fromId":916,"content