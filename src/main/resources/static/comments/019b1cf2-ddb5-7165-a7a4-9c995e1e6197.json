[{"id":"019b1f78-c8ee-720a-914b-96092dd4cfa1","parentId":null,"rootId":null,"fromId":21511,"content":"SB","createdAt":"2025-12-15T08:46:08"},{"id":"019b1f80-e5c1-7289-8d69-8beee8360496","parentId":null,"rootId":null,"fromId":22250,"content":"是出全部高速费吗 ？","createdAt":"2025-12-15T08:54:59"},{"id":"019b1f8a-f07e-7227-aec2-fabec1f9ce2c","parentId":null,"rootId":null,"fromId":21511,"content":"对","createdAt":"2025-12-15T09:05:57"},{"id":"019b1f8e-eb92-718e-b0af-5626ef84335a","parentId":null,"rootId":null,"fromId":2664,"content":"高速费一般都是按人头平摊，你这有意思。","createdAt":"2025-12-15T09:10:18"},{"id":"019b1f8f-a1e1-711b-8e4d-4bb73591e842","parentId":null,"rootId":null,"fromId":2664,"content":"自己不累吗？牛逼","createdAt":"2025-12-15T09:11:05"},{"id":"019b1f95-af5f-725b-bb0d-783eb514f85b","parentId":null,"rootId":null,"fromId":926,"content":"狠人","createdAt":"2025-12-15T09:17:42"},{"id":"019b1f9c-95d8-7206-90c4-0f4ec215acc0","parentId":null,"rootId":null,"fromId":1955,"content":"大家  都上班","createdAt":"2025-12-15T09:25:14"},{"id":"019b1fa3-4a17-720a-9f0d-7f29d82ef225","parentId":null,"rootId":null,"fromId":22809,"content":"所以，这种假顺风车不能坐","createdAt":"2025-12-15T09:32:33"},{"id":"019b1fa7-7f1b-7338-8528-8296055b5cf1","parentId":null,"rootId":null,"fromId":1751,"content":"这种直接不接最好","createdAt":"2025-12-15T09:37:09"},{"id":"019b1fa8-616b-7216-bf71-21d6f774e0fb","parentId":null,"rootId":null,"fromId":21818,"content":"哪怕和司机平摊高速费呢，也叫顺风车。乘客自己出高速费也叫顺风车？","createdAt":"2025-12-15T09:38:07"},{"id":"019b1fa9-71f7-707e-aa75-19d09889f429","parentId":null,"rootId":null,"fromId":23959,"content":"如何操作与避免纠纷\n为了避免行程中产生不愉快的纠纷，建议你注意以下几点：\n\n下单时主动协商：这是最重要的步骤。在嘀嗒、滴滴等平台下单时，系统会提供关于高速费的备注选项。务必根据自身意愿选择，并在上车前与车主再次确认。\n\n了解“一口价”模式：顺风车通常采用“一口价”，但这笔费用一般不包含高速费。高速费属于额外产生的成本，需要单独协商。\n\n平台线上支付：如果协商好要分摊，务必通过顺风车APP内的线上支付功能完成。这样做能留下记录，方便后续维权，避免线下支付后扯皮。\n\n警惕常见违规行为：现实中，部分司机会要求乘客线下支付或向每位乘客收取全额高速费（例如，向车上3名乘客各收40元，但总高速费实际只有60元）。这都是不合理的行为，你有权拒绝。\n\n⚖️ 遇到问题如何维权\n如果发生司机未按约定路线行驶、多收高速费或“独享”订单被拼车等情况：\n\n保留证据：保存好订单截图、聊天记录、行车路线、支付凭证等。\n\n向平台投诉：第一时间通过APP向平台官方投诉，要求处理并退还多收费用。\n\n行政投诉：如果平台处理不力，可以拨打当地的 12328 交通运输服务监督电话进行投诉。\n\n总的来说，坐顺风车是否需要出高速费，核心在于“提前协商，明确规则”。如果方便的话，可以告诉我你准备从哪个城市出发、到达哪个城市，以及计划使用哪个平台，我可以帮你留意更具体的地方规定。","createdAt":"2025-12-15T09:39:17"},{"id":"019b1fb6-a98e-7077-b9aa-c94d33553413","parentId":null,"rootId":null,"fromId":22250,"content":"还是提前协商好靠谱点，谈不拢就不拉，不知道顺风车平台允不允许这么高，我没做过顺风车，顶多是打滴滴去机场有5块钱高速费我出过","createdAt":"2025-12-15T09:53:43"},{"id":"019b1fb9-8596-71a4-b5d0-eb0ba775c155","parentId":null,"rootId":null,"fromId":23971,"content":"小丑一个，不必理会","createdAt":"2025-12-15T09:56:50"},{"id":"019b1fc5-332d-7290-b8c2-9cc98af97278","parentId":null,"rootId":null,"fromId":5624,"content":"你是你，人家是人家，平台支持乘客可以选择是否承担高速费，不承认车主随意选择路线了。还有你这样的多了就成默认的了","createdAt":"2025-12-15T10:09:36"},{"id":"019b1fca-49b2-71e7-8e0c-7b2d16d855ab","parentId":null,"rootId":null,"fromId":2776,"content":"那你是真的下贱哈哈哈","createdAt":"2025-12-15T10:15:09"},{"id":"019b1fdc-cad3-720b-9b32-c0c45c9d6f08","parentId":null,"rootId":null,"fromId":6871,"content":"这种专业跑顺风车的真恶心人啊，还不如直接找拼车的","createdAt":"2025-12-15T10:35:22"},{"id":"019b20cb-d691-7047-8f63-1385fa852f2c","parentId":null,"rootId":null,"fromId":3242,"content":"你这是什么心理呢? 顺风车拉个人能挣个油钱就行呗, 高速费不拉人你不一样也得掏吗?纯纯恶心别人开心自己?自己也遭罪啊","createdAt":"2025-12-15T14:56:28"},{"id":"019b25e4-358a-73d3-b5b2-c71860ee96b0","parentId":null,"rootId":null,"fromId":26151,"content":"这是真sb","createdAt":"2025-12-16T14:41:11"},{"id":"019b4b98-1bf9-7316-9a1b-2dcb17b1f1ba","parentId":null,"rootId":null,"fromId":270,"content":"电车接了顺风车单，电池质保就没了吧？很多厂商禁止商用的","createdAt":"2025-12-23T22:23:38"},{"id":"019b6e4c-68cb-737e-9e99-6b6552b76aef","parentId":null,"rootId":null,"fromId":23620,"content":"你不是纯纯沙雕吗，还给大家分享，纯纯找骂","createdAt":"2025-12-30T16:07:39"},{"id":"019b724a-38b7-7107-a827-9b2eea331783","parentId":null,"rootId":null,"fromId":23274,"content":"杀敌一千，自损八百，你的时间，这么不值钱吗","createdAt":"2025-12-31T10:43:45"}]