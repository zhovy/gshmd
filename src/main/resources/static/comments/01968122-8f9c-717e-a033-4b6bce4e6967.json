[{"id":"0196813c-4548-70dc-8358-92585f0dfcdf","parentId":null,"rootId":null,"fromId":926,"content":"基本没有，多年前有","createdAt":"2025-04-29T19:08:52"},{"id":"01968442-8538-732c-aae9-16e968659573","parentId":null,"rootId":null,"fromId":6939,"content":"没有，不要想了！","createdAt":"2025-04-30T09:14:34"},{"id":"01968452-7fa1-7253-8c3c-79213e4262ea","parentId":null,"rootId":null,"fromId":7026,"content":"不会有的，之前我就是外包，当时部门里很缺我这个技术工种，几乎少了我就不行了，离职的时候部门里最大的领导来跟我谈，给了各种好处，就是不能转正，说是人力查的很严","createdAt":"2025-04-30T09:32:01"},{"id":"01968467-e2a2-7275-b446-6b5dc11719be","parentId":null,"rootId":null,"fromId":7566,"content":"给各种好处就是不给转正，还有这种玩法？","createdAt":"2025-04-30T09:55:22"},{"id":"01968537-3124-711e-8c20-8e9b77770d28","parentId":null,"rootId":null,"fromId":22576,"content":"能给的各种好处是领导职权范围内能做主的，转正，是领导做不了主的。\n之前面试浪潮，过五关斩六将，集团审批也通过了，最后董事长签字卡住了，说业绩不行，不招正式，尽量用外包。","createdAt":"2025-04-30T13:41:48"},{"id":"019685e2-4b28-71d0-89e3-c804c40e1aba","parentId":null,"rootId":null,"fromId":7091,"content":"有先例，你什么学历？","createdAt":"2025-04-30T16:48:42"},{"id":"01968676-abc3-70f3-b12b-de4caba1a615","parentId":null,"rootId":null,"fromId":7566,"content":"就是山科的一普通本科，学软件工程的","createdAt":"2025-04-30T19:30:46"},{"id":"01969e69-809c-7001-849a-e6ad65b4be4c","parentId":null,"rootId":null,"fromId":22458,"content":"所在部们之前有，类似山科本科的学历招进来就是正式的，也不清楚他们是怎么招进来的，看起来不像是有人的样子，不清楚是不是领导想上位卖的人情，hr也没管啊。主要是大部门里有好几个都是，至少我知道的就有5个。有外包想转正的，很惨，也不知道最后成没成功，反正是被领导画大饼，卖力加班干了一年多，不剥你一层皮你别想，毕竟一层层的都是这样剥削的，不剥削下面的他们上不去","createdAt":"2025-05-05T11:07:16"},{"id":"01969e6b-3882-707a-b805-8a0e4d60cfa9","parentId":null,"rootId":null,"fromId":22458,"content":"当然，正式的这几个有被压低薪资了，具体压了多少我也不知道","createdAt":"2025-05-05T11:09:09"},{"id":"0196a0aa-83e7-730c-9fc2-c5fc15fe6cee","parentId":null,"rootId":null,"fromId":926,"content":"在20年之前，山东有8所非985/211院校特批，可以校招、社招就给正式，山科、山师是其中的两所，后来不行了。","createdAt":"2025-05-05T21:37:31"},{"id":"0196a365-7ac3-7363-abc6-8ef939c6683c","parentId":null,"rootId":null,"fromId":6186,"content":"不可能","createdAt":"2025-05-06T10:20:58"},{"id":"0196a3a0-fb79-72f6-8360-aa3d7fcf4551","parentId":null,"rootId":null,"fromId":22458,"content":"青大、山师、山财、山科、齐鲁工业、山建、山理工，这是我想的到的知名度比较高的7所，8所那这不把山东的稍微拿出手的学校都包括了","createdAt":"2025-05-06T11:25:58"},{"id":"0196a482-296c-713a-8ab5-c810931474b7","parentId":null,"rootId":null,"fromId":23776,"content":"不可能，绝对不可能，除非你有关系，你有关系也就不去干外包了","createdAt":"2025-05-06T15:31:55"},{"id":"0196a48b-2201-716c-a950-58f9da54594a","parentId":null,"rootId":null,"fromId":7566,"content":"也是","createdAt":"2025-05-06T15:41:43"},{"id":"0196a4d6-1ab7-7329-9d9b-d0934b5620e8","parentId":null,"rootId":null,"fromId":7495,"content":"我是被hr卡了。。。","createdAt":"2025-05-06T17:03:37"},{"id":"0196a4d9-ef2e-71c5-a076-a3b44f0674d2","parentId":null,"rootId":null,"fromId":7566,"content":"领导都同意转正了，但是HR不同意转正？","createdAt":"2025-05-06T17:07:48"},{"id":"0196a8ab-83b8-72d4-9a34-bed2f09f95e8","parentId":null,"rootId":null,"fromId":23660,"content":"很难","createdAt":"2025-05-07T10:55:34"},{"id":"0196a8bb-bd5d-721c-90f4-b5b9f964409d","parentId":null,"rootId":null,"fromId":926,"content":"集团政策","createdAt":"2025-05-07T11:13:18"},{"id":"0196adac-5765-7203-befa-43d92da5736d","parentId":null,"rootId":null,"fromId":7381,"content":"几年前外包可以转合派，现在转合派也是天方夜谭了，不被优化就不错了","createdAt":"2025-05-08T10:14:35"},{"id":"0196aecf-5988-7359-abaa-a8d2f3cca3a4","parentId":null,"rootId":null,"fromId":5460,"content":"之前我在外包三年，一直没合派名额就润了，大概外包两三年转合派，再过三五年转正式，现在这行情怕是没戏了","createdAt":"2025-05-08T15:32:26"},{"id":"0196aed2-aaff-72d4-9abb-2d60fe50a7a9","parentId":null,"rootId":null,"fromId":926,"content":"现在没有合派这么一说了，合派比正式还稀有","createdAt":"2025-05-08T15:36:04"},{"id":"0196aed3-36a8-73ab-be2d-7b9fb593200e","parentId":null,"rootId":null,"fromId":926,"content":"浪潮不招合派了，内部也转不了了，就没合派一说了","createdAt":"2025-05-08T15:36:39"},{"id":"0196aef2-bcc7-7085-b9d0-5f21aa9c7589","parentId":null,"rootId":null,"fromId":21364,"content":"别想了老哥，除非学历够硬，否则谁同意也不好使，领导上面还有领导，集团还有流程，正式员工入职都费劲，外包转正基本没可能。","createdAt":"2025-05-08T16:11:05"},{"id":"0196aefe-70c5-71eb-9ba6-072a9c05b5ef","parentId":null,"rootId":null,"fromId":7381,"content":"就是改名叫劳务派遣人员了，其实就是一回事儿你我心知肚明 不要玩文字游戏了","createdAt":"2025-05-08T16:23:52"},{"id":"0196af9f-ff8c-706c-827b-156af2915c82","parentId":null,"rootId":null,"fromId":23228,"content":"我擦，那我这个干了八九年的大专，面试的项目经理是不是白搭了，通知我去复试呢","createdAt":"2025-05-08T19:20:20"},{"id":"0196b2e6-dae9-71fd-adf2-5aa89be59c26","parentId":null,"rootId":null,"fromId":7566,"content":"啥叫合派？合派是不是就是山东浪潮数字服务这个公司招的人？","createdAt":"2025-05-09T10:36:35"},{"id":"0196c239-ed4f-73da-aa5d-006f9f97190b","parentId":null,"rootId":null,"fromId":23823,"content":"想都不要想了哥们，后面不优化掉就不错了，还想着转正呢 哈哈哈  除非真就是特别硬的关系","createdAt":"2025-05-12T10:01:38"},{"id":"0196c8b8-ffc1-716d-8213-74021fb9269e","parentId":null,"rootId":null,"fromId":7381,"content":"数字服务是外包 合派是前程无忧之类的","createdAt":"2025-05-13T16:18:09"},{"id":"0196cc67-d4c6-70cc-8471-b25fd8d13eab","parentId":null,"rootId":null,"fromId":5460,"content":"那之前的合派人员呢？转外包了嘛","createdAt":"2025-05-14T09:27:58"},{"id":"0196d183-658e-7375-b2b3-a78c0e6d516c","parentId":null,"rootId":null,"fromId":21364,"content":"管理层不清楚，开发是不好转正","createdAt":"2025-05-15T09:16:11"},{"id":"01976874-f818-716d-b746-3ac27c62e8ca","parentId":null,"rootId":null,"fromId":3718,"content":"浪潮这正式的有啥用，我19年去的是正式的，也考核，不行的让你滚蛋，也没多发工资，该加班的一个也跑不了，该裁还是裁你。像电网那种正式的，才叫真正式，基本不裁人，福利待遇好，各种稳定。","createdAt":"2025-06-13T16:43:05"},{"id":"0197a1bf-e5f0-721c-83a3-e28e9f9d253e","parentId":null,"rootId":null,"fromId":24615,"content":"我说一个身边外包转合派的真实例子。对方是2016年985211本科毕业后来我们这干外包，干的是实施的活，周围很多人奇怪他这么好学历为啥会去当外包，后来在2022年转成功的。本来是要转正式员工，走流程经过层层审批，走到大boss那地方被卡了，最终以合派的方式入职，现在干的好好的","createdAt":"2025-06-24T19:43:17"}]