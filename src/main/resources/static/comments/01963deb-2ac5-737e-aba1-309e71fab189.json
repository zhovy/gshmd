[{"id":"01963deb-2b2e-7158-929d-36a26038ddc3","parentId":null,"rootId":null,"fromId":629,"content":"房子首付都五六十了吧，装修十到15个，彩礼目前基本六万六八万八，金子现在正是贵的时候，三金都不少了，五金更多，感觉得八九十个，淦","createdAt":"2024-02-04T10:37:09"},{"id":"01963deb-2b72-7024-9da6-6e80c0577589","parentId":null,"rootId":null,"fromId":2815,"content":"有什么想不开的，要结婚啊","createdAt":"2024-02-04T10:38:32"},{"id":"01963deb-2bb7-72d6-a15d-17969ada8201","parentId":null,"rootId":null,"fromId":2855,"content":"结那玩意干啥？","createdAt":"2024-02-04T10:44:30"},{"id":"01963deb-2c9a-72a1-9433-304d59ab0a69","parentId":null,"rootId":null,"fromId":6613,"content":"想不开吗","createdAt":"2024-02-04T11:16:18"},{"id":"01963deb-2cf7-7190-81f3-20f675e6e8a9","parentId":null,"rootId":null,"fromId":1398,"content":"还好没有女朋友，要不然得考虑这些东西","createdAt":"2024-02-04T11:17:55"},{"id":"01963deb-2d3e-702b-aa98-d79eb0bb71b5","parentId":null,"rootId":null,"fromId":3500,"content":"说来说去 大头就是房子和装修 除了首付还有贷款 房子就是一座大山","createdAt":"2024-02-04T11:24:35"},{"id":"01963deb-2d88-72f1-adee-5b5b05335d73","parentId":null,"rootId":null,"fromId":3500,"content":"你们菏泽6","createdAt":"2024-02-04T13:04:55"},{"id":"01963deb-2c82-71db-beaf-191f5f67adb3","parentId":null,"rootId":null,"fromId":4140,"content":"女方给了啥？","createdAt":"2024-02-04T13:17:23"},{"id":"01963deb-2c87-7114-9ce7-1a93bf29b63f","parentId":null,"rootId":null,"fromId":1492,"content":"嫁妆10床被子","createdAt":"2024-02-04T13:52:54"},{"id":"01963deb-2c8c-726e-b32b-989e1e1825af","parentId":null,"rootId":null,"fromId":6613,"content":"真好啊，夜里捂着被子使劲哭，外面一点听不到","createdAt":"2024-02-04T13:58:07"},{"id":"01963deb-2d91-72e5-888a-44c6e25f2474","parentId":null,"rootId":null,"fromId":6380,"content":"普通的都得100个左右呢，不是逼不得已真别结婚。。。","createdAt":"2024-02-04T14:23:08"},{"id":"01963deb-2dd7-726b-af1f-e104e7e28655","parentId":null,"rootId":null,"fromId":6344,"content":"我结婚的时候，自己这边出了一套价值200万的全款房子，30万重新装修，6万6彩礼，10多万酒席，没买三金，女方陪嫁20万的银行卡","createdAt":"2024-02-05T15:02:37"},{"id":"01963deb-2e2a-70ee-bd07-5a4272914134","parentId":null,"rootId":null,"fromId":2082,"content":"100个","createdAt":"2024-02-05T17:55:45"},{"id":"01963deb-2e1b-7176-b4fa-771e4d33cefa","parentId":null,"rootId":null,"fromId":4140,"content":"全款房没加名的话就不算结婚用的，也还是50多万，女方回了20万，也就是里外里花了30来万，还可以了要是房子加名了就得130多万了就有点扯淡了","createdAt":"2024-02-05T19:03:10"},{"id":"01963deb-2e20-72ca-b223-2c455ba59f16","parentId":null,"rootId":null,"fromId":6344,"content":"全款房不可能加名的，也没人提这无理的要求","createdAt":"2024-02-06T09:15:20"},{"id":"01963deb-2e6f-7211-8a71-fbbe359cfe7c","parentId":null,"rootId":null,"fromId":3519,"content":"都是什么水平啊，不敢想象，本人18年结婚的，置办酒席婚车三金一共加起来花了3W，彩礼6.6W带回来10W，俩人婚后没因为结婚欠账，家庭和睦。","createdAt":"2024-02-06T15:39:10"},{"id":"01963deb-2c90-727a-85dc-e57ec1e2412f","parentId":null,"rootId":null,"fromId":6683,"content":"住房装修婚礼和男的没关系呢呗","createdAt":"2024-02-20T09:52:37"},{"id":"01963deb-2c94-71ed-b6f9-82284864d16f","parentId":null,"rootId":null,"fromId":6683,"content":"暂且不说彩礼三金有没有带回来，这里面只有彩礼和三金是直给到女孩的吧","createdAt":"2024-02-20T09:53:50"},{"id":"01963deb-2d8c-72c6-aa87-e8f59a9cd9d4","parentId":null,"rootId":null,"fromId":7093,"content":"菏泽好像还有两倍三金的说法，给女方买两套三金，老婆一份，丈母娘留一份","createdAt":"2024-04-02T15:32:34"},{"id":"01963deb-2eb5-7203-83b0-13ddd95b7470","parentId":null,"rootId":null,"fromId":6221,"content":"我18年结婚，老婆青岛的，彩礼让我们看着给，多少都行。按我们习俗3.18w，只买了个金镯子，其他不喜欢。然后带回来5w。并没有很多繁文缛节。然后他们那边拆迁，又给了30w，哈哈","createdAt":"2024-04-03T09:03:32"},{"id":"01963deb-2f47-731b-964d-98b2802fdffe","parentId":null,"rootId":null,"fromId":629,"content":"哈哈哈哈","createdAt":"2024-04-03T09:41:13"},{"id":"01963deb-2efa-7112-b912-2421a41efc4e","parentId":null,"rootId":null,"fromId":629,"content":"真好啊命好兄弟嫂子也好，现在都攀比，现在这小姑娘都独立女性哈哈","createdAt":"2024-04-03T09:42:23"},{"id":"01963deb-2f4c-719e-a528-89c3d717a950","parentId":null,"rootId":null,"fromId":5768,"content":"烽火哥还需要准备钱结婚吗，直接给小舅子内推12000的全额五险，直接就能结了","createdAt":"2024-04-03T09:45:28"},{"id":"01963deb-2f8f-7046-b255-149c2b439a39","parentId":null,"rootId":null,"fromId":7100,"content":"22年结婚，彩礼20，首付130加名字，车车22，钻戒3.5 Emm...差不多这些吧，婚后生了个女娃，幸福的嘞","createdAt":"2024-04-03T10:45:19"},{"id":"01963deb-2fd4-71d9-a990-116f5c44f471","parentId":null,"rootId":null,"fromId":4140,"content":"都是男方出的吗？你杂七杂八下来得200w了","createdAt":"2024-04-03T10:51:42"},{"id":"01963deb-2fdd-702f-a4e8-99c6d83d61b2","parentId":null,"rootId":null,"fromId":4174,"content":"烽火哥这工作拿着当时入职发的offer，妥妥的比房产证强，直接结了","createdAt":"2024-04-03T10:53:22"},{"id":"01963deb-2fd9-7379-af3c-d54c75874e6e","parentId":null,"rootId":null,"fromId":7100,"content":"家里赞助了一部分，不都是为了好好生活么","createdAt":"2024-04-03T10:59:30"}]