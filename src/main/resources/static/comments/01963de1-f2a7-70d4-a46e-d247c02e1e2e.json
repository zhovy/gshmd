[{"id":"01963de1-f30d-70d0-978d-8897dbff4177","parentId":null,"rootId":null,"fromId":3286,"content":"楼主去面了吗  能否简单说下","createdAt":"2023-05-06T08:47:34"},{"id":"01963de1-f353-7180-a7c9-8d4cd3fad625","parentId":null,"rootId":null,"fromId":691,"content":"回复1楼，去面了，问的技术问题如下：\nArrayList底层\nHsahMap底层\nSpring是单线程还是多线程\nSpring是单例还是多例\nRabbitMQ死信，什么时候使用MQ\n了解哪些设计模式，谈谈策略模式，谈谈单例模式的视线\n如果一个对象被频繁创建，可以怎么优化(享元模式）\n怎么保证分布式的幂等性\n事物怎么处理，事物封装，分布式事物\nMysql怎么优化sql语句，(通过explan)，用explan你都关注哪些列\nMysql分页查询10万到10万零1千直接的数据怎么优化\nJvm的分区怎么划分的\nJvm优化，你是怎么优化jvm的，谈谈思路\nMysql的二级缓存\n接口中你怎么保证你的返回值和请求值能是json\nDubbo在项目中是用在哪里\n聊聊Seate\n物联网项目中每秒几千条数据，怎么优化程序\n线程池的核心参数\n聊聊你们项目中netty接收数据后的责任链模式\n怎么避免死锁\n聊聊syn，对象头中怎么存储的\n聊聊syn的锁膨胀\n聊聊线程的状态\n给两个多线程场景， 第一个：num加1，怎么保证num的线程安全 第二个：......\nspringboot自动装配","createdAt":"2023-05-08T16:02:42"},{"id":"01963de1-f3a5-7290-98c5-bd4c9fc789c4","parentId":null,"rootId":null,"fromId":691,"content":"人员配置：\n两三个前端，两个产品，两三个运维，四五个后端，做的是物联网的产品，属于自研，目前要做数字孪生的产品","createdAt":"2023-05-08T16:04:13"},{"id":"01963de1-f401-7271-9229-ddc78690b2de","parentId":null,"rootId":null,"fromId":691,"content":"公司用的是挺前沿的技术栈","createdAt":"2023-05-08T16:05:35"},{"id":"01963de1-f453-7246-a172-6ffdd98e1ee5","parentId":null,"rootId":null,"fromId":1656,"content":"牛，初创公司吗","createdAt":"2023-05-09T08:46:09"},{"id":"01963de1-f499-7187-89b7-67b16de28206","parentId":null,"rootId":null,"fromId":691,"content":"不算是初创公司了，看爱企查上显示创建四年了","createdAt":"2023-05-09T09:43:06"},{"id":"01963de1-f49e-7346-9467-738b4164097d","parentId":null,"rootId":null,"fromId":691,"content":"我觉得我这个面试问的问题算是中级的标准模板了，问的很全面，一般面试官老师会问你一个场景，这个场景内该怎么解决，也会问你一些源码的知识，你没看过源码的话也没有歧视你，总之面试感觉很好，人事老师也很好","createdAt":"2023-05-09T09:46:56"},{"id":"01963de1-f4a2-718d-83a2-f6f93c772702","parentId":null,"rootId":null,"fromId":2198,"content":"楼主入职了么","createdAt":"2023-05-21T22:24:25"},{"id":"01963de1-f4e6-70ba-a169-25455b0f8760","parentId":null,"rootId":null,"fromId":691,"content":"没过，说我实操不行","createdAt":"2023-06-12T14:37:48"},{"id":"01963de1-f4eb-705b-ba87-2afb1d62530e","parentId":null,"rootId":null,"fromId":4043,"content":"别去，内斗比较厉害。","createdAt":"2023-09-14T16:45:12"},{"id":"01963de1-f398-7361-959d-c9adfbf7be4d","parentId":null,"rootId":null,"fromId":1492,"content":"你要多少，问你这些","createdAt":"2023-09-14T16:53:34"},{"id":"01963de1-f52f-7048-bdfc-308fa91b1f54","parentId":null,"rootId":null,"fromId":5671,"content":"小公司有啥好斗的","createdAt":"2023-09-14T17:06:06"},{"id":"01963de1-f533-727f-8138-8dd8e1b7fd32","parentId":null,"rootId":null,"fromId":4043,"content":"你试试就知道了啊","createdAt":"2023-09-15T17:26:37"},{"id":"01963de1-f39c-723c-9c4f-5a86e803021c","parentId":null,"rootId":null,"fromId":4043,"content":"问的人也是现百度的，二逼罢了","createdAt":"2023-09-15T17:54:53"},{"id":"01963de1-f3a1-70d8-86b9-dbd8b85af3d5","parentId":null,"rootId":null,"fromId":691,"content":"我要了12K还是13K来着，忘记了，大概是这个数字","createdAt":"2023-09-21T14:27:12"},{"id":"01963de1-f538-708d-a2b7-4d721b36c0bf","parentId":null,"rootId":null,"fromId":5804,"content":"大佬，可以简单说说吗？","createdAt":"2023-09-25T12:47:10"},{"id":"01963de1-f53c-72eb-bb73-fd08de50caf1","parentId":null,"rootId":null,"fromId":5671,"content":"有人的地方就会有恩怨~","createdAt":"2023-09-25T16:58:18"}]