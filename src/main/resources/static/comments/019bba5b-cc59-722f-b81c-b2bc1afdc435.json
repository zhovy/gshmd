[{"id":"019bbb1b-9a93-71ff-bddc-b4613b354363","parentId":null,"rootId":null,"fromId":22695,"content":"有些项目竞标要用，不过因为是省级证书，不享受人社局补贴，总的来说没有高项性价比高","createdAt":"2026-01-14T14:05:07"},{"id":"019bbb46-14d8-71e2-a085-b4654affa484","parentId":null,"rootId":null,"fromId":2572,"content":"高项是什么","createdAt":"2026-01-14T14:51:30"},{"id":"019bbbd1-f6fe-71f0-b83b-9b5945f62270","parentId":null,"rootId":null,"fromId":23946,"content":"前两个月前考过了，贼简单，没啥用。。就是盖章麻烦","createdAt":"2026-01-14T17:24:18"},{"id":"019bbcbe-da0e-70f2-a6a7-266a888ae0fb","parentId":null,"rootId":null,"fromId":22695,"content":"信息系统项目管理师，考下来就相当于副高职称，人社局还给你发2000块钱","createdAt":"2026-01-14T21:43:02"},{"id":"019bbf4c-4a1d-7389-a286-46b74ef0458d","parentId":null,"rootId":null,"fromId":2572,"content":"那还不错，考试难度大吗","createdAt":"2026-01-15T09:36:46"},{"id":"019bbfa6-9033-71e1-b89d-cf7444efeab2","parentId":null,"rootId":null,"fromId":3835,"content":"这个2000补助 早就没有了吧","createdAt":"2026-01-15T11:15:22"},{"id":"019bc459-0702-7126-ae40-05a1c6e3ce8d","parentId":null,"rootId":null,"fromId":22695,"content":"一般情况，通过率在35%左右，主要是现在省级各种计算机类职称考试很多题都是高项考试的内容，先考这个再想考大数据什么的会比较容易","createdAt":"2026-01-16T09:08:47"},{"id":"019bc45c-35fb-71f7-a0ba-afbbb010ce15","parentId":null,"rootId":null,"fromId":22695,"content":"还有，长期的，只要你失业金参保超一年，就能领","createdAt":"2026-01-16T09:12:16"}]