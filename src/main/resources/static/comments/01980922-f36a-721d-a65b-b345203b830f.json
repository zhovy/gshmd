[{"id":"01980b89-b4ea-70b2-9d45-a087b45879f8","parentId":null,"rootId":null,"fromId":926,"content":"景新海景总教你做人","createdAt":"2025-07-15T08:43:50"},{"id":"01980ba1-7bfe-738d-96a6-ecbbc834ee96","parentId":null,"rootId":null,"fromId":25805,"content":"哥们，能详细说说吗，值不值得去","createdAt":"2025-07-15T09:09:49"},{"id":"01980ba3-9d93-7166-abcf-40963f75cf70","parentId":null,"rootId":null,"fromId":21267,"content":"济南没有值得去的公司","createdAt":"2025-07-15T09:12:08"},{"id":"01980bb2-55f6-7071-b786-2751dc908df2","parentId":null,"rootId":null,"fromId":6091,"content":"值得去的，我们进不去而已","createdAt":"2025-07-15T09:28:13"},{"id":"01980d5f-caef-719d-a86f-85634ed43895","parentId":null,"rootId":null,"fromId":926,"content":"中间件研发岗我不太清楚，我说下我知道的，我19年在中创金融三部待过不到三个月，正式员工，一天打四次卡，中午十二点半前后各一次，里面舔领导的氛围非常浓重，有自己宿舍，四人间来着吧，食堂自有，但是非常难吃，应该是中午管一顿饭来着，荤腥基本无。中创中间件后来做XC业务认识了个实施哥们儿，出差差补50，每天上下班都必须乘坐公共交通工具，如果需要打车，那不管多晚，给中创创始人兼董事长景新海景总发短信，批了才能打车。","createdAt":"2025-07-15T17:17:18"},{"id":"0198112d-d363-7368-97df-0b02ea6f3b30","parentId":null,"rootId":null,"fromId":25805,"content":"坑啊，太坑了","createdAt":"2025-07-16T11:01:12"},{"id":"01981282-8b19-70db-b7ed-c777a1083687","parentId":null,"rootId":null,"fromId":25858,"content":"1","createdAt":"2025-07-16T17:13:21"}]