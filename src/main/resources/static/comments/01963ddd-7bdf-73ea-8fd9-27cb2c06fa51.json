[{"id":"01963ddd-7c53-7220-9d69-7d4c3128d956","parentId":null,"rootId":null,"fromId":2113,"content":"老板高甲萌，这个人很坑，各种画饼，然后承诺的待遇和福利完全不兑现，问他怎么回事，就找各种理由不给。在那天天让找还没毕业的学生走他的外包，培训一两天就安排到项目上，实际上啥也不会就是背面试题，一个人头能抽50%","createdAt":"2022-10-31T17:08:43"},{"id":"01963ddd-7c97-7004-b7b4-48859ac79001","parentId":null,"rootId":null,"fromId":1336,"content":"这是啥熟人，推荐这种工作，确认不是仇家？","createdAt":"2022-11-01T14:18:42"},{"id":"01963ddd-7d21-72d0-a373-afb04687612a","parentId":null,"rootId":null,"fromId":2124,"content":"估计是推人有提成","createdAt":"2022-11-01T16:50:38"},{"id":"01963ddd-7d6d-73ed-8f10-c318eebecf32","parentId":null,"rootId":null,"fromId":2124,"content":"钱少事多，有难同享，提钱变脸。虽然干的是安全相关，但是还是外包公司的壳子。","createdAt":"2022-12-08T16:36:13"}]