[{"id":"01963de4-37d7-7254-8d98-dcac75192e58","parentId":null,"rootId":null,"fromId":1895,"content":"同问","createdAt":"2023-06-28T14:30:04"},{"id":"01963de4-381b-706c-9f87-f866c688a372","parentId":null,"rootId":null,"fromId":3949,"content":"全额公积金社保，按时发工资，试用期三个月且转正后全部返还剩余20%工资，氛围很nice 但是不一定好进","createdAt":"2023-06-30T22:23:35"},{"id":"01963de4-385f-7178-842f-fe313ca0181e","parentId":null,"rootId":null,"fromId":2056,"content":"加班吗。几号发工资？","createdAt":"2023-07-01T18:11:40"},{"id":"01963de4-3863-714c-a42b-9c4b2d532ae3","parentId":null,"rootId":null,"fromId":3949,"content":"到项目节点的时候会有加班 没有加班文化","createdAt":"2023-07-02T19:05:38"},{"id":"01963de4-3868-730a-ad2b-174fd77663c0","parentId":null,"rootId":null,"fromId":3949,"content":"每个月25号发上个月21号到本月20号的工资","createdAt":"2023-07-02T19:06:11"},{"id":"01963de4-3883-7342-89b2-30a7cf1fce2d","parentId":null,"rootId":null,"fromId":2621,"content":"大佬，可以说详细点吗？值不值得去","createdAt":"2023-07-04T10:27:42"},{"id":"01963de4-386c-73f4-a5e1-1677dd311046","parentId":null,"rootId":null,"fromId":2056,"content":"那挺好的","createdAt":"2023-07-04T18:03:28"},{"id":"01963de4-3870-73a5-92f9-a988d4b47425","parentId":null,"rootId":null,"fromId":2056,"content":"好像是内网环境？有不会的不能百度？","createdAt":"2023-07-04T18:19:49"},{"id":"01963de4-3875-710c-b7d2-16f76673a0fd","parentId":null,"rootId":null,"fromId":2056,"content":"还有就是试用期签三方？转正才签玖天？","createdAt":"2023-07-05T03:21:32"},{"id":"01963de4-38c8-735d-8f9e-6fb807f04002","parentId":null,"rootId":null,"fromId":880,"content":"北京的公司，突然来济南市为什么，降本啊，用多说什么呢","createdAt":"2023-07-07T14:32:12"},{"id":"01963de4-390c-7148-ad83-352ac38f42e1","parentId":null,"rootId":null,"fromId":3949,"content":"是跟山东电网这边有大项目","createdAt":"2023-07-07T23:04:58"},{"id":"01963de4-387a-7036-bb8d-b35a7c6ae9ea","parentId":null,"rootId":null,"fromId":3949,"content":"没有的事","createdAt":"2023-07-07T23:05:15"},{"id":"01963de4-3911-713c-9845-7790ffa7a512","parentId":null,"rootId":null,"fromId":2621,"content":"楼主去了吗？","createdAt":"2023-09-20T17:22:16"},{"id":"01963de4-3955-705a-9855-138bd118517c","parentId":null,"rootId":null,"fromId":6039,"content":"感觉是挺好的，福利啥的都很全，不过给电力干项目，总有一段时间得加班；哎，22年10月给的offer，还去现场看了看，但是被原公司的领导各种画大饼，搞兄弟长短那一套给留下了，结果22年奖金没有，23年工资没涨，有点后悔没去","createdAt":"2024-01-15T08:52:30"},{"id":"01963de4-3998-7354-9a98-1f2694f8e749","parentId":null,"rootId":null,"fromId":2056,"content":"后来谈着谈着成签第三方，五险一金也是最低的了。工资也没到预期。就没去","createdAt":"2024-02-27T14:25:42"},{"id":"01963de4-39dc-7075-b0b5-fceecba7eb5b","parentId":null,"rootId":null,"fromId":6039,"content":"我也是，最后说是没有名额，签一个外包，五险一金按外包公司的来，工资是一致，但外包公司这种就很难说了，项目进入维护期就调人去其他地方","createdAt":"2024-05-29T08:13:13"},{"id":"01963de4-39e1-723b-8c53-cb5d85285039","parentId":null,"rootId":null,"fromId":22283,"content":"老哥也是算法岗吗","createdAt":"2024-12-25T17:35:35"},{"id":"01963de4-387e-703a-9957-8e8d71ec149b","parentId":null,"rootId":null,"fromId":22283,"content":"老哥算法岗还招人吗","createdAt":"2024-12-25T17:38:51"},{"id":"0199e754-4fd8-7271-b09e-8b8ae71f439a","parentId":null,"rootId":null,"fromId":22283,"content":"老哥还在吗，现在还招人不","createdAt":"2025-10-15T18:04:46"}]