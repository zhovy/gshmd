[{"id":"01963df7-b940-73d2-863f-56b4321e84f6","parentId":null,"rootId":null,"fromId":4171,"content":"好冲的味道。","createdAt":"2025-03-12T17:12:49"},{"id":"01963df7-b984-7215-9c8d-0cb6f71e459c","parentId":null,"rootId":null,"fromId":6268,"content":"真味啊","createdAt":"2025-03-13T11:27:24"},{"id":"019c0fd6-7664-7119-96b0-ad17b48d429a","parentId":null,"rootId":null,"fromId":6641,"content":"听说又有老员工被排挤了，新潮就是这个鸟样的，干时间久了就会变成领导的眼中钉。特别是商务，从头到尾数一数，跟着lin干的没一个落好下场的，但人家会伪装而且心也狠，当面和你笑完背后就能笑着捅你一刀，但人家会打扮领导也都跪服在石榴裙下，所以每个部门都是想收拾就能收拾，商务、技术、销售、企管都害怕她，妥妥一霸。能早点走的就赶紧早点走，呆久了不会落好的。","createdAt":"2026-01-31T00:57:19"},{"id":"019c147a-38bd-7223-ac65-1f4e9e7fe284","parentId":null,"rootId":null,"fromId":21302,"content":"我只问你一句话：你与我讲的是儒家圣人口中的道理还是我手中的真理？","createdAt":"2026-01-31T22:34:40"}]