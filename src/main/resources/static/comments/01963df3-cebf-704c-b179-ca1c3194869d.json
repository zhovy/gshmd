[{"id":"01963df3-cf27-72ad-93d8-875a75a769a9","parentId":null,"rootId":null,"fromId":6458,"content":"去了浪潮也得出来。。","createdAt":"2024-10-17T15:35:03"},{"id":"01963df3-cf6c-703b-a59b-b278f65f3ec8","parentId":null,"rootId":null,"fromId":5954,"content":"你没看明白吗？就是给你两个选择。选哪个？技术烂到什么程度，但是他不会辞退你，让你干到退休","createdAt":"2024-10-17T15:35:58"},{"id":"01963df3-cf70-721e-8cc0-305cb90b093e","parentId":null,"rootId":null,"fromId":5954,"content":"大家意淫一下 手动狗头","createdAt":"2024-10-17T15:37:23"},{"id":"01963df3-cfb3-72bd-9389-7d2eda1a2fe3","parentId":null,"rootId":null,"fromId":3333,"content":"小浪？","createdAt":"2024-10-17T15:39:09"},{"id":"01963df3-cff7-7311-930d-f3495d1790cd","parentId":null,"rootId":null,"fromId":5954,"content":"手动狗头","createdAt":"2024-10-17T15:41:39"},{"id":"01963df3-d040-71ac-a2b7-11d047011c39","parentId":null,"rootId":null,"fromId":5954,"content":"挺中肯的 不错","createdAt":"2024-10-17T15:43:37"},{"id":"01963df3-d048-711b-98af-539f22fcae63","parentId":null,"rootId":null,"fromId":6406,"content":"浪哥，我要房子，什么时候给我","createdAt":"2024-10-17T15:46:12"},{"id":"01963df3-d091-70c7-a827-a148a4a522e6","parentId":null,"rootId":null,"fromId":22028,"content":"我选房子","createdAt":"2024-10-17T15:50:55"},{"id":"01963df3-d0d5-7239-96f0-41ff6a396b41","parentId":null,"rootId":null,"fromId":1,"content":"为了兴趣可能会选择工作，但是为了生活还是会选择房子。","createdAt":"2024-10-17T15:55:04"},{"id":"01963df3-d119-7288-912c-1b0ea3cfc188","parentId":null,"rootId":null,"fromId":2408,"content":"浪潮","createdAt":"2024-10-17T15:59:35"},{"id":"01963df3-d160-7221-b4ba-2e63a0915787","parentId":null,"rootId":null,"fromId":6517,"content":"济南历下2套了历城1套了已经，我选浪潮把","createdAt":"2024-10-17T16:29:05"},{"id":"01963df3-d1ab-72e3-90dd-632355549dec","parentId":null,"rootId":null,"fromId":3341,"content":"历下两套老房子 唐冶一套新的 再来一套的话 浪潮在我眼里就是依托答辩了。。。  租给你们你们去吧","createdAt":"2024-10-17T17:06:10"},{"id":"01963df3-d1ef-73cb-b4bd-037968a31d37","parentId":null,"rootId":null,"fromId":1372,"content":"120万的房子，按照浪潮给你1万一个月，才10年的工资。而你的人生肯定大于10年。综合收入而言，去浪潮。","createdAt":"2024-10-17T17:09:06"},{"id":"01963df3-d23c-7030-a55d-acf13fbf8d67","parentId":null,"rootId":null,"fromId":6221,"content":"各位，这种假如不存在的","createdAt":"2024-10-17T17:57:26"},{"id":"01963df3-d1a7-717f-977f-faed32f9a9be","parentId":null,"rootId":null,"fromId":22005,"content":"叉出去","createdAt":"2024-10-18T08:05:22"},{"id":"01963df3-d280-72bb-aad0-534964382b2c","parentId":null,"rootId":null,"fromId":2341,"content":"各位，这种假如不存在的","createdAt":"2024-10-18T09:04:02"},{"id":"01963df3-d237-72d6-81cc-1685969ffbb5","parentId":null,"rootId":null,"fromId":6979,"content":"选了房子又不是不工作了，除了软件行业不能干点别的吗？","createdAt":"2024-10-18T09:08:13"},{"id":"01963df3-d2c4-708b-b201-62a2b698bd69","parentId":null,"rootId":null,"fromId":6979,"content":"这个选项就像是退伍士官选择一次性退伍安置费还是选择部分安置费和基层公务员岗位一模一样","createdAt":"2024-10-18T09:10:08"},{"id":"01963df3-d30a-7168-9407-ecf28367c5f6","parentId":null,"rootId":null,"fromId":6979,"content":"房子120万，假设是2室一厅80-100平米左右，这个户型和面积的房子在济南的市区房租差不多一个月2000-3000左右，为何把房子不租出去，然后回老家干别的呢？？？？？（银行现在利息太低，还不如直接租给租房托管公司收益高）","createdAt":"2024-10-18T09:21:31"},{"id":"01963df3-d34e-7130-adff-344a882b04ad","parentId":null,"rootId":null,"fromId":7427,"content":"选房子吧","createdAt":"2024-10-18T13:40:42"},{"id":"01963df3-d392-7257-ab3a-a2211b6fa927","parentId":null,"rootId":null,"fromId":5954,"content":"及时行乐吧 120万先拿到手 再说 浪潮工作不确定性太多了  120万 先拿到手不香吗","createdAt":"2024-10-18T15:35:20"},{"id":"01963df3-d3dc-7297-a8ce-d44645d3ec08","parentId":null,"rootId":null,"fromId":2420,"content":"那必须先去大浪干到35 再买房子啊","createdAt":"2024-10-21T08:49:31"},{"id":"01963df3-d420-73ff-8c5a-a981c02f1ae0","parentId":null,"rootId":null,"fromId":3705,"content":"别yy了，好兄弟，天天点个外卖还得膨胀一下，哎","createdAt":"2024-10-21T17:05:56"},{"id":"01963df3-d044-73c3-8a7c-0f232dfde19e","parentId":null,"rootId":null,"fromId":22024,"content":"我就是这样，但是浪潮也赶不到退休，也裁人啊","createdAt":"2024-10-24T17:28:19"},{"id":"01963df3-d463-70f8-97c7-163bdb94e847","parentId":null,"rootId":null,"fromId":22024,"content":"你说的这俩我都有，但是浪潮也裁人的。你说的这俩假设，房子是有可能的，但没有这样的工作。\n\n假设都成立的话，那就选工作呗，10年就挣出来了。稳定的工作最重要，不然为啥那么多人选老师，考公之类的呢？","createdAt":"2024-10-24T17:31:46"},{"id":"01963df3-d4a9-7213-ab3f-aaf8a261a65f","parentId":null,"rootId":null,"fromId":1591,"content":"大浪35就辞退了，还是房子吧","createdAt":"2024-10-30T22:48:19"},{"id":"01963df3-d4f0-71d2-af74-db51b4fb08f3","parentId":null,"rootId":null,"fromId":7381,"content":"怎么还真选上了 醒醒","createdAt":"2024-11-14T14:13:08"}]