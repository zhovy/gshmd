[{"id":"01963df3-e24f-72a7-b86a-b9e0c6179301","parentId":null,"rootId":null,"fromId":5954,"content":"我如果待的公司很好很稳定，我是不会经常来这里逛吐槽的。只是我的习惯。不知道大家是怎么样的","createdAt":"2024-10-18T15:17:30"},{"id":"01963df3-e298-73e1-a8ab-fc308a76e5fd","parentId":null,"rootId":null,"fromId":21003,"content":"我目前的公司就很好了，双休法定节假日和法定加班费，年底发年终奖，全额五险一金","createdAt":"2024-10-18T15:19:08"},{"id":"01963df3-e2dc-73df-aa88-177709bbf849","parentId":null,"rootId":null,"fromId":5954,"content":"兄弟  能透漏一下不 嘿嘿","createdAt":"2024-10-18T15:19:36"},{"id":"01963df3-e2e0-720e-b56d-f9dfbe765c76","parentId":null,"rootId":null,"fromId":21003,"content":"私企 现在不咋招人了","createdAt":"2024-10-18T15:20:30"},{"id":"01963df3-e2e5-707c-aced-49be451ced75","parentId":null,"rootId":null,"fromId":3477,"content":"两年开发经验19k，全额公积金，双休，15薪","createdAt":"2024-10-18T15:25:50"},{"id":"01963df3-e342-70a3-b902-66521da30e40","parentId":null,"rootId":null,"fromId":6091,"content":"我觉的是20薪","createdAt":"2024-10-18T15:30:46"},{"id":"01963df3-e346-708d-b0a5-b3f3846d62cd","parentId":null,"rootId":null,"fromId":5954,"content":"使劲吹","createdAt":"2024-10-18T15:33:37"},{"id":"01963df3-e34f-7186-a476-9d47032c2f31","parentId":null,"rootId":null,"fromId":5705,"content":"我目前的公司虽然和别人的没得比，但是我觉得挺好了。五险一金最低，不过有双休有节假日有季度有年终有加班费有补贴","createdAt":"2024-10-18T15:58:48"},{"id":"01963df3-e397-718d-bb9f-01e5725edcf1","parentId":null,"rootId":null,"fromId":6091,"content":"感觉已经是良心公司，不是那种黑心资本家了","createdAt":"2024-10-18T16:07:59"},{"id":"01963df3-e3a0-7004-995b-6546bec543d5","parentId":null,"rootId":null,"fromId":7083,"content":"某外包公司，在走投无路的时候，还比上家高15%月薪入职，然后做到了双休","createdAt":"2024-10-18T16:11:47"},{"id":"01963df3-e294-7117-9722-a64ad1baf885","parentId":null,"rootId":null,"fromId":22023,"content":"其实可以来来联系一下同情心 O(∩_∩)O","createdAt":"2024-10-18T16:12:01"},{"id":"01963df3-e39b-7244-924c-e76d60d70d0b","parentId":null,"rootId":null,"fromId":22023,"content":"我感觉你现在应该是有点无欲无求了，估计是生活已经稳定下来了吧","createdAt":"2024-10-18T16:15:31"},{"id":"01963df3-e3e7-731f-b99d-3150ba25d3db","parentId":null,"rootId":null,"fromId":2408,"content":"不加班","createdAt":"2024-10-18T18:28:50"},{"id":"01963df3-e42e-7322-8587-59a8570cebb0","parentId":null,"rootId":null,"fromId":2577,"content":"私企，基本不加班，朝九晚五，下班准时领导带头走，主动发高温补贴，工资当月底发，虽然社保按最低这个没事。很舒心，怕干不好影响公司，基本很少划水","createdAt":"2024-10-21T07:36:12"},{"id":"01963df3-e3e3-71c8-899b-dba0dff1aa58","parentId":null,"rootId":null,"fromId":5790,"content":"软通，中软，华信，佰钧成。。。。。哪个？","createdAt":"2024-10-21T11:36:46"},{"id":"01963df3-e473-7209-bf0a-52c6e9d1755f","parentId":null,"rootId":null,"fromId":21176,"content":"好的公司大家说说名字啊","createdAt":"2024-10-22T12:09:31"},{"id":"01963df3-e4b8-73c2-8403-926ccb835350","parentId":null,"rootId":null,"fromId":508,"content":"优点：岗位比较好，技术栈很自由。如果按时发工资能算优点的话，再加上能发工资。\n没了，其他都是缺点。","createdAt":"2024-10-22T13:31:11"},{"id":"01963df3-e34b-7247-a9a0-a611fb9a2048","parentId":null,"rootId":null,"fromId":7425,"content":"还是保守了，我一年经验30K，全额 + 补贴公积金，上4休3，20薪","createdAt":"2024-10-26T16:29:55"}]