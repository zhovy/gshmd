[{"id":"01963df8-1ced-706a-bb2f-ec7860eb3e37","parentId":null,"rootId":null,"fromId":875,"content":"那肯定的，换一个水龙头一百块，修空调三四百起步","createdAt":"2025-03-25T20:55:28"},{"id":"01963df8-1d3c-70b5-b88e-a3b3904411d3","parentId":null,"rootId":null,"fromId":1398,"content":"怎么听别人说博士一年几十万那？","createdAt":"2025-03-25T23:29:46"},{"id":"01963df8-1d81-73fa-9053-f8e79967756a","parentId":null,"rootId":null,"fromId":3785,"content":"你这纯粹瞎扯，任何企业博士都是门面，你就看看济南的补贴政策","createdAt":"2025-03-26T08:23:17"},{"id":"01963df8-1d32-7027-862f-e1b90e530eeb","parentId":null,"rootId":null,"fromId":5954,"content":"水电工就是一千一个活，这些博士都不愿意去干","createdAt":"2025-03-26T08:36:18"},{"id":"01963df8-1d36-70c6-bef7-9ac757000d37","parentId":null,"rootId":null,"fromId":808,"content":"最近家电维修挺火的，自己学学，给自己家里省钱","createdAt":"2025-03-26T08:43:44"},{"id":"01963df8-1dd1-7336-8beb-686843c65581","parentId":null,"rootId":null,"fromId":6939,"content":"张口就来，周围学历高的大部分混的都不差，工资多少不知道，但是大部分都有房有车，周末节假日带着老婆孩子到处玩玩，我初中一同学博士，现在XX科学院，有钱又有闲，羡慕。","createdAt":"2025-03-26T08:54:02"},{"id":"01963df8-1e1f-7238-80f0-cfeee9e73a26","parentId":null,"rootId":null,"fromId":3333,"content":"贴主是初中生吗，说的真离谱啊","createdAt":"2025-03-26T09:10:12"},{"id":"01963df8-1dcc-736a-8eba-e7abd6d2ea43","parentId":null,"rootId":null,"fromId":875,"content":"买房补贴几十万，我看到了","createdAt":"2025-03-26T10:10:18"},{"id":"01963df8-1e63-729a-ba0c-a5eae2ad56bd","parentId":null,"rootId":null,"fromId":1933,"content":"你是拿日薪比的吧，你也说了水电工空闲时间多，好活可不是天天都有的。还有，说硕士可以，不要带上博士，博士含金量高高的","createdAt":"2025-03-31T17:30:18"}]