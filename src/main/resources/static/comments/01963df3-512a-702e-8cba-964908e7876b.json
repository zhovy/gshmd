[{"id":"01963df3-5194-73ac-bdcc-2bef45063780","parentId":null,"rootId":null,"fromId":1039,"content":"青岛还不如济南","createdAt":"2024-09-24T10:24:18"},{"id":"01963df3-51e2-7079-b2d3-15291d5f594d","parentId":null,"rootId":null,"fromId":3450,"content":"行业凉了,跟城市没关系","createdAt":"2024-09-24T11:11:32"},{"id":"01963df3-5227-7388-ab41-5396ba06f702","parentId":null,"rootId":null,"fromId":875,"content":"房贷利率降了，股市大涨突破2800，就业形势一片大好，北上广深杭州武汉郑州的程序员又该大涨工资了，好多人一线城市工资月薪三万五，新一线月薪两万","createdAt":"2024-09-24T11:22:02"},{"id":"01963df3-526c-71e6-8844-8f48988d625b","parentId":null,"rootId":null,"fromId":21053,"content":"跟城市有啥关系","createdAt":"2024-09-24T11:49:03"},{"id":"01963df3-52f9-71ca-80b1-ca7bf7a13e34","parentId":null,"rootId":null,"fromId":5584,"content":"好不好，自己去体验一下就知道了！","createdAt":"2024-09-24T12:23:48"},{"id":"01963df3-533d-72b8-9e54-ab9524fc5aa4","parentId":null,"rootId":null,"fromId":875,"content":"房贷二套比例首付降到15%了，300万的房子，首付60万来一套，买来扔给中介，一个月租5500，让大家来租帮忙换房贷","createdAt":"2024-09-24T17:32:37"},{"id":"01963df3-5382-72ef-babf-383000ee0df6","parentId":null,"rootId":null,"fromId":6517,"content":"我二环东房子420w的时候，才能租5000一个月，现在掉到350了，一个月就租4200，你别张口就来","createdAt":"2024-09-25T09:10:17"},{"id":"01963df3-5386-71cd-bb00-31574e1f9a3d","parentId":null,"rootId":null,"fromId":875,"content":"你整租当然便宜了，你看看历下高新区的房子有几个没隔断的，先扔给中介两年，然后收回来自己往外租，一间一千块钱往外租，跟房子多贵没关系，关键是有几间，客厅可能割出来一间，厨房可以再割出来一间，三室一厅五间起步，一共租5000不是事","createdAt":"2024-09-25T12:27:07"}]