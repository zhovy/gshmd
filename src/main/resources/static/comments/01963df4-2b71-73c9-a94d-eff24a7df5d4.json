[{"id":"01963df4-2bd5-72ab-b3a9-12a248430a7f","parentId":null,"rootId":null,"fromId":875,"content":"赶紧考公务员去吧，开发来济南爬不起来的","createdAt":"2024-10-27T10:58:20"},{"id":"01963df4-2c19-7207-ad73-38a49d58e2b2","parentId":null,"rootId":null,"fromId":21973,"content":"在山东考公感觉比找开发还压力山大啊，好几百人抢一个坑","createdAt":"2024-10-27T11:10:49"},{"id":"01963df4-2c1e-70dd-b177-4601002fd41c","parentId":null,"rootId":null,"fromId":5605,"content":"考验呢，可以进修一下，能有个92身份找工作也方便","createdAt":"2024-10-27T13:01:25"},{"id":"01963df4-2c61-700e-a796-c0ca0452fa36","parentId":null,"rootId":null,"fromId":2408,"content":"考公吧，或者事业单位，别干开发了","createdAt":"2024-10-27T13:30:59"},{"id":"01963df4-2ca9-70c5-8f22-bb8b3e995ebe","parentId":null,"rootId":null,"fromId":1401,"content":"今年相较往年的招聘量大大减少","createdAt":"2024-10-28T08:37:16"},{"id":"01963df4-2ced-71a8-9520-5b7aa879dd4b","parentId":null,"rootId":null,"fromId":4171,"content":"薪资要求如何，能接受加班与出差吗。在公司加班有加班费（不高）除固定加班天数外5点正常下班有班车周末有双休，出差有差补但无加班费，出差一般996","createdAt":"2024-10-28T09:06:40"},{"id":"01963df4-2d35-70c7-8393-fd4db56bc197","parentId":null,"rootId":null,"fromId":21973,"content":"你好，加班出差都可以接受，薪资转正大概6-7k，可以内推一下吗","createdAt":"2024-10-28T10:44:12"},{"id":"01963df4-2d3a-7331-9b01-07a1838b8b8e","parentId":null,"rootId":null,"fromId":1857,"content":"应届生不好找吗？","createdAt":"2024-10-28T11:11:19"},{"id":"01963df4-2d7f-717d-ab6d-c3d0f725ba95","parentId":null,"rootId":null,"fromId":21973,"content":"感觉济南的公司都没有招人的，不知道济南能去哪","createdAt":"2024-10-28T11:13:44"},{"id":"01963df4-2dcc-71de-8c75-a51d0918757b","parentId":null,"rootId":null,"fromId":21973,"content":"这么夸张吗，崩溃了。。。","createdAt":"2024-10-28T14:01:51"},{"id":"01963df4-2dd1-7164-bbd9-a76b2840301e","parentId":null,"rootId":null,"fromId":4140,"content":"4-5年java还8千可以转行了，别干java了，济南现在只要是正常本科学历，刚毕业6-7k，1-3年经验8-10k,3-5年经验10-12k，5年以上看机缘12-20k，10年以上0k-20k","createdAt":"2024-10-28T15:55:13"},{"id":"01963df4-2ddf-70cb-bcc3-b2ae8830a4fc","parentId":null,"rootId":null,"fromId":21396,"content":"咋这么卑微，去一线城市试试看","createdAt":"2024-10-28T15:55:24"},{"id":"01963df4-2e25-70da-9de8-102ff19bd5d6","parentId":null,"rootId":null,"fromId":4140,"content":"给你一个忠告，毕业实习公司待遇不重要，除非你是券商、银行这种的，别的类型公司基本上对你最有用的就是行业经验、业务方向，你如果去了就做大屏开发、低代码开发，你工资到顶也就是10k，可替代性极强。但是反过来做erp、sap前期待遇差不多，学起来也很难费劲，但是后面每跳槽一次基本上工资都能涨2-3k，能选一个累一点学到东西的才重要，不然很可能到最后你5年工龄还拿着7、8k的工资，说一句工作怎么这么难找，但是同时sap、erp工程师目前根本不愁失业的问题，就我知道的现在一个3-5年sap开发都14k+，5-10年sap都基本上快20k，选好方向，毕业第一份工作还是很重要的，别草草了事","createdAt":"2024-10-28T16:03:34"},{"id":"01963df4-2e69-72e8-ad6c-94f42d85aa75","parentId":null,"rootId":null,"fromId":3892,"content":"感觉erp开发薪水并不怎么高，而且erp利润很低吧","createdAt":"2024-10-28T16:20:40"},{"id":"01963df4-2e6d-73ff-9cb7-24ba5f576c5c","parentId":null,"rootId":null,"fromId":4140,"content":"看你是什么erp吧，自己拉个若依框架改改东西这种也能叫erp，金蝶、用友U8、U9也是erp，不知道你说的是哪种，真正的erp业务流程应该有完整的逻辑，你在小公司，拉个若依自己改改开发，这种说好听叫erp，不好听就叫管理系统吧。。","createdAt":"2024-10-29T08:43:31"},{"id":"01963df4-2e7b-73c0-b8aa-382a8179ccbf","parentId":null,"rootId":null,"fromId":1591,"content":"济南开发都走的差不多了，都去北上广了，工资太低，我们公司8年JAVA才8千块","createdAt":"2024-10-30T22:36:39"},{"id":"01963df4-2ece-7395-ad02-4e9325428abc","parentId":null,"rootId":null,"fromId":1376,"content":"你还没毕业啊，出来实习？","createdAt":"2024-10-31T09:11:56"},{"id":"01963df4-2ec5-73a1-9cb1-a6130a1c6924","parentId":null,"rootId":null,"fromId":5654,"content":"都走的差不多了？都去北上广了？8年JAVA拿8K有没有可能是人的问题。。。","createdAt":"2024-10-31T09:29:18"},{"id":"01963df4-2e72-7328-ba9d-a696d09be913","parentId":null,"rootId":null,"fromId":3892,"content":"浪潮数字企业的erp开发工资都不高，涨薪很难","createdAt":"2024-10-31T10:50:34"},{"id":"01963df4-2f19-7319-9590-d8ecc331dfa0","parentId":null,"rootId":null,"fromId":21973,"content":"秋招，找工作，目前依旧是0offer，[哭]","createdAt":"2024-10-31T11:30:19"},{"id":"01963df4-2f1d-724f-9edc-9d34a1cdcefe","parentId":null,"rootId":null,"fromId":22176,"content":"济南人吗","createdAt":"2024-10-31T16:49:34"},{"id":"01963df4-2dda-71df-8576-386ce8735785","parentId":null,"rootId":null,"fromId":2366,"content":"五年8k基本都简历造假的，我现在同事就有好几个。我认识的真干了五年的没有一个这么低","createdAt":"2024-11-15T09:22:06"},{"id":"01963df4-2eca-73de-ad22-d0ae71376ddb","parentId":null,"rootId":null,"fromId":5624,"content":"你可以不说，但是别误导人呀！！！","createdAt":"2024-11-22T08:53:22"},{"id":"01963df4-2f66-70cc-aaa9-4e92f9eb4a58","parentId":null,"rootId":null,"fromId":1248,"content":"这个十年以上0-20k看的我心酸了","createdAt":"2024-12-26T18:10:01"},{"id":"01963df4-2e76-73be-b98f-59534cc0d021","parentId":null,"rootId":null,"fromId":6208,"content":"很对 济南大部分都是走业务 感觉怎么把功能展示更重要 就是画个大屏 对java要求及其低 可以说应届生来 对Java技术没有提升更多的是提升业务能力。与其说济南招的是java工程师不如说招的是前端工程师","createdAt":"2024-12-27T09:26:53"}]