024-05-23T17:05:01"},{"id":"01963def-5b6d-71ad-a4c7-aa8f0fc759cb","parentId":null,"rootId":null,"fromId":21429,"content":"驾校有推荐吗","createdAt":"2024-07-21T16:51:49"},{"id":"01963def-5a70-714e-b679-9dd38f40aa2d","parentId":null,"rootId":null,"fromId":5624,"content":"哈哈哈","createdAt":"2024-07-31T21:24:27"},{"id":"01963def-5a28-739e-ba3a-e5aeea4a86d0","parentId":null,"rootId":null,"fromId":5624,"content":"哈哈哈","createdAt":"2024-07-31T21:24:31"},{"id":"01963def-5bb2-73f3-aad3-c48bc68f9852","parentId":null,"rootId":null,"fromId":3793,"content":"中软的外包其实很坑的，当时进来的时候说是很好，什么全额公积金，每年的涨薪，但是他不提的是，如果甲方（中软）或者客户方没有项目之后，每个月会给最低工资2000块钱，然后到指定地方打卡，每天写日报，一个月到手也就几百块钱。而且他想辞退你的时候会挑各种问题，比如毕业时间与工作开始时间不符，社保与工作时间不符等等，反正零成本辞退你，n+1甚至n都不要想。而且中软的还会在你的电脑上安装监控软件，实时监控你的一举一动，甚至是你微信的聊天记录。而且中软用的办公软件是华为的welink，定位打卡他妈的贼难用，有时候在办公室内都打不上卡。有时候还会定期开安全信息培训会，也就是听他们瞎逼逼，我们一边上班一边还要听她逼逼，最骚的操作是他怕有人不听，还会不定时点名念ppt，你能想象到在客户现场办公的时候，突然间就念与工作不符的东西吗","createdAt":"2024-12-31T13:56:01"},{"id":"0199e093-527f-72f4-a330-3c9e4867677d","parentId":null,"rootId":null,"fromId":2558,"content":"哥们  你去了吗","createdAt":"2025-10-14T10:36:15"}]