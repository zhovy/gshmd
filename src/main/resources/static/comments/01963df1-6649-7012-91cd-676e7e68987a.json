[{"id":"01963df1-66b4-70ee-aed7-bcfea0137aff","parentId":null,"rootId":null,"fromId":3592,"content":"靠谱，我朋友就是去外地考的，比较快，如果不急的话济南本地随便找个也行","createdAt":"2024-07-01T10:39:19"},{"id":"01963df1-66fd-7269-8aa8-533d1c68d79d","parentId":null,"rootId":null,"fromId":21083,"content":"好嘞，感谢","createdAt":"2024-07-01T10:41:50"},{"id":"01963df1-6702-7375-8aa6-f8f667623fd4","parentId":null,"rootId":null,"fromId":6580,"content":"去聊城考就行，休息日也能考，一天下证，济南比较难，时间还长，还只能周一到周五考","createdAt":"2024-07-01T10:47:15"},{"id":"01963df1-6746-7375-810d-22e43949b288","parentId":null,"rootId":null,"fromId":21083,"content":"我刚问了一个说是聊城简单，但是只能工作日面签和考试呢","createdAt":"2024-07-01T10:53:06"},{"id":"01963df1-6753-7394-9ed7-1df5ae7ff463","parentId":null,"rootId":null,"fromId":1492,"content":"不用，不知道你在济南哪，我同事都是在东边港西车管所那考的，900报的驾校，具体不知道，需要的话我问问，一上午出证。去聊城，得州太远。我之前去聊城考的，凌晨4点去面包车集合开过去，1200全包，太折腾，不过简单，只要不碰杆，就算你过","createdAt":"2024-07-01T11:27:25"},{"id":"01963df1-6798-70fc-8fc4-33f1d58e48f9","parentId":null,"rootId":null,"fromId":880,"content":"这么贵吗 现在","createdAt":"2024-07-01T11:40:28"},{"id":"01963df1-679c-72e1-b736-fa1dd266062c","parentId":null,"rootId":null,"fromId":7381,"content":"我德州考的，一天下，就是他妈的晒得不成人样了","createdAt":"2024-07-01T14:17:33"},{"id":"01963df1-674b-7383-bef9-20bd77d0e0b0","parentId":null,"rootId":null,"fromId":703,"content":"6","createdAt":"2024-07-01T14:22:11"},{"id":"01963df1-67e1-73dc-a533-a3f6ebadadc0","parentId":null,"rootId":null,"fromId":21233,"content":"6","createdAt":"2024-07-01T14:25:35"},{"id":"01963df1-67e6-72b4-9043-275f1612dba7","parentId":null,"rootId":null,"fromId":3341,"content":"没有靠谱不靠谱 没听说过考摩托还上当受骗的。。\n\n不管在哪里考无非一下几个区别：\n1:监考情况：电子监考还是人工监考（科二科三），人工的自然不如电子的严谨 所以人工好过一点，但是其实大差不差 人工的你碰的那个杆子瞎几把晃悠他也不给你过。\n2:时间：当天科目一到科目四全部考完拿证 ，有的是分好几次 考完一科 过几天再来一次 过几天再来一次 直到拿证\n3:考费：车管所直接报名不通过驾校应该是在460左右 ，要是走驾校就额外收你点。这个大差不差 一打听都能知道哪里贵哪里便宜了。\n参考以上情况自己选择适合自己的报名就行了","createdAt":"2024-07-01T14:49:35"},{"id":"01963df1-682a-723a-9cfa-a6f6be52b1ea","parentId":null,"rootId":null,"fromId":21000,"content":"现在没有一天下证了，在德州考的，刚拿证不久，一天面签/体检/转证，一天考试下证","createdAt":"2024-07-01T14:59:30"},{"id":"01963df1-674f-7010-a911-40374230a028","parentId":null,"rootId":null,"fromId":6580,"content":"那是又改革了，越来越难，尽快考吧","createdAt":"2024-07-01T15:38:29"},{"id":"01963df1-686f-73bc-94b2-1dee223e0bd6","parentId":null,"rootId":null,"fromId":5788,"content":"现在好像不让组团去外地考了，我问了好几个驾校都是这样；在济南考 900， 请半天假约考免签，过几天之后请半天假去考试（一般一上午考完，特殊情况比如考场系统老出问题，那就到下午才能考完），我在历城徐李路考的，那的系统真他妈垃圾","createdAt":"2024-07-09T08:21:00"},{"id":"01963df1-68b3-7128-83a8-e2ce005ce4b8","parentId":null,"rootId":null,"fromId":578,"content":"章丘城东驾考中心考的一天拿证，12123约个周一四科联考，周末随便练练车就差不多了","createdAt":"2024-07-19T14:42:51"},{"id":"01963df1-68fd-71a9-8506-3b0102281769","parentId":null,"rootId":null,"fromId":21429,"content":"现在考驾证麻烦吗","createdAt":"2024-07-21T16:41:16"},{"id":"01963df1-6940-705c-b126-55e64f25675d","parentId":null,"rootId":null,"fromId":21429,"content":"666","createdAt":"2024-07-21T16:43:09"}]