[{"id":"019777fa-0d1f-712f-98ca-facda65b9ef4","parentId":null,"rootId":null,"fromId":414,"content":"统计局发的东西你也信，失业不叫失业  叫待就业","createdAt":"2025-06-16T17:02:45"},{"id":"01977805-e8a9-7034-8985-a4f2b6ec48d6","parentId":null,"rootId":null,"fromId":24709,"content":"不信","createdAt":"2025-06-16T17:15:42"},{"id":"0197783b-4ef3-7387-90c2-ea8445796a2e","parentId":null,"rootId":null,"fromId":460,"content":"青年人的概念是 18-24岁 左右 然后就自己想想吧","createdAt":"2025-06-16T18:14:02"},{"id":"0197786a-2dea-731d-8396-269334622c6c","parentId":null,"rootId":null,"fromId":59,"content":"形势一片大好","createdAt":"2025-06-16T19:05:13"},{"id":"01977b4c-563d-734d-bdf2-43199edf1c9f","parentId":null,"rootId":null,"fromId":7566,"content":"18-22岁是读本科的年纪，22-24岁是读硕士的年纪，现在本科率和硕士率年年攀升，如果不统计这些读本科和硕士的年轻人，那就业率确实可以好起来","createdAt":"2025-06-17T08:31:29"},{"id":"01977b4e-9e38-70d7-90ab-57bfaf0f5807","parentId":null,"rootId":null,"fromId":7566,"content":"那是，稳中向好、好中向很好、很好中向特别好、特别好中向非常好、非常好中向极其好","createdAt":"2025-06-17T08:33:59"},{"id":"01977c7a-ca2c-71e7-aa77-aeec6ea01b1c","parentId":null,"rootId":null,"fromId":23300,"content":"GDP稳中有升，形势一片大好，人人有工作，月月有工资，幸福度直线飙升，跃居全球第一！","createdAt":"2025-06-17T14:01:51"},{"id":"01977ccc-2a70-71f7-a3a4-bceec9fb399f","parentId":null,"rootId":null,"fromId":22186,"content":"（备注：30以上不算青年）","createdAt":"2025-06-17T15:30:44"},{"id":"01977d22-00ed-7148-9e62-24c6df9e1ead","parentId":null,"rootId":null,"fromId":7566,"content":"人家叫灵活就业","createdAt":"2025-06-17T17:04:29"},{"id":"0197817e-336f-71ec-b904-4241177b6f9c","parentId":null,"rootId":null,"fromId":7344,"content":"666","createdAt":"2025-06-18T13:23:41"},{"id":"0197817e-660a-70c8-a194-a4c22ed0e8c2","parentId":null,"rootId":null,"fromId":1933,"content":"他们用的“调查失业率”搜一下啥意思","createdAt":"2025-06-18T13:23:53"},{"id":"019786fe-3c72-7126-9091-392a7d5e9010","parentId":null,"rootId":null,"fromId":25238,"content":"要脸不","createdAt":"2025-06-19T15:01:38"},{"id":"0197872e-d311-71cb-b4d2-433f8428a1a3","parentId":null,"rootId":null,"fromId":7566,"content":"它们还有脸？礼义廉耻，国之四维，现在还有哪一维？","createdAt":"2025-06-19T15:54:42"},{"id":"01978731-6fdd-733b-ba2d-dd032eadcbd8","parentId":null,"rootId":null,"fromId":7566,"content":"1、农村户口不统计，失业了可以回家种地；\n2、主动离职不统计；\n3、没交过失业保险的不统计，没交过失业保险说明没有就业过，那何谈失业；\n\n4、被辞退后不想找工作的不统计，没有就业意向；\n5、每周工作一个小时就算就业人员，哪怕每周只发了一个小时的传单，送了一个小时的外卖。\n这么看下来能成为失业人口还是有点难度的。","createdAt":"2025-06-19T15:57:33"},{"id":"0197875a-defd-7013-ab00-bd488c9dd5be","parentId":null,"rootId":null,"fromId":25238,"content":"1","createdAt":"2025-06-19T16:42:48"},{"id":"0197875b-2368-7386-ae5f-dccb3fcf2ab4","parentId":null,"rootId":null,"fromId":25238,"content":"赞同","createdAt":"2025-06-19T16:43:06"},{"id":"01978c12-ba8a-7381-bdeb-3ad2b1a8c380","parentId":null,"rootId":null,"fromId":21511,"content":"领失业金的才算失业","createdAt":"2025-06-20T14:42:07"},{"id":"01979bd0-3e46-712d-ba9e-67140fbba169","parentId":null,"rootId":null,"fromId":1933,"content":"没你想的这么复杂，调查失业率就等于采样统计，具体采样范围内就是他们说了算了。比如你可以在火车上调查大家有没有买到票","createdAt":"2025-06-23T16:03:25"}]