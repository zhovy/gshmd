[{"id":"01963dda-dc42-71b3-a0ce-61d92638356c","parentId":null,"rootId":null,"fromId":371,"content":"前几年面过，感觉某总监技术还停留在90年代","createdAt":"2022-07-15T13:54:57"},{"id":"01963dda-dc89-711e-877a-7352c6bb0974","parentId":null,"rootId":null,"fromId":800,"content":"记得是大小周","createdAt":"2022-07-15T13:56:24"},{"id":"01963dda-dccf-71fa-a85f-a0df61ea6b70","parentId":null,"rootId":null,"fromId":912,"content":"去年面过，记得当时说还有项目是ssh","createdAt":"2022-07-15T14:25:22"},{"id":"01963dda-dd16-72ab-bed6-4d1f91b7f1a8","parentId":null,"rootId":null,"fromId":983,"content":"公司价值观宣扬没有领导只有兄弟姐妹，实际上领导架子大的很","createdAt":"2022-07-16T08:45:52"},{"id":"01963dda-dd5d-70cf-9c57-8cb42154c589","parentId":null,"rootId":null,"fromId":604,"content":"我个人觉得某总监能力最多能干项目经理，做个总监真不行","createdAt":"2022-07-18T11:23:59"},{"id":"01963dda-dda7-73dd-8ad0-f3b959b453fc","parentId":null,"rootId":null,"fromId":1621,"content":"技术中心的王姓负责人，能力不行人品不行，人员流动非常大。不针对公司，只针对技术部","createdAt":"2022-09-14T22:15:13"},{"id":"01963dda-dded-7146-aad1-e8a801e1c0f9","parentId":null,"rootId":null,"fromId":1860,"content":"公司太垃圾了，各种假期不放，干的多和干的少的 工资相差很小，即使你拼命干 工资也高不了几百块钱，国庆七天假期，被通知放5天，然后又通知放4天，然后又通知放3天，还不给加班费，公积金是最低，工资不高，社保不高，假期不多， 加班多！在这没啥奔头，能走就赶紧走把，待遇太差了，","createdAt":"2022-09-28T17:38:53"},{"id":"01963dda-de38-7293-973b-2d31e1ac860d","parentId":null,"rootId":null,"fromId":1942,"content":"技术中心王姓负责人真的很垃圾，好赖话都让他说了，资源也协调不来","createdAt":"2022-10-12T14:41:06"},{"id":"01963dda-de7c-70b7-89af-e56d02e882e4","parentId":null,"rootId":null,"fromId":2156,"content":"我来补充一下，某王姓总监，他面试就等于走个流程，先问你做过什么，然后接下来就是沉默·······，然后就是你不合适，没见过这么奇葩的面试","createdAt":"2022-11-04T11:25:04"},{"id":"01963dda-dec5-73d4-b5ad-0d4e29c9a6d0","parentId":null,"rootId":null,"fromId":1234,"content":"总监王猛这个人实在有问题，公司的渣滓","createdAt":"2022-11-16T22:59:20"},{"id":"01963dda-df0a-731c-a714-2b62dde39cba","parentId":null,"rootId":null,"fromId":3175,"content":"目前公司两个技术中心了，一个王姓领导的内部信息化建设的中心，一个张姓领导的新零售相关的中心（后来新增的）。新零售中心的几个领导人还是不错的，是之前韩都衣舍的一帮人","createdAt":"2023-04-02T07:34:42"},{"id":"01963dda-df4e-7281-985e-4f2558b3d046","parentId":null,"rootId":null,"fromId":5410,"content":"听说这个公司苛扣员工绩效，强制性加班还不给加班费，有大佬补充吗","createdAt":"2024-01-17T14:23:28"},{"id":"01963dda-df92-733c-9215-16c9fa092b00","parentId":null,"rootId":null,"fromId":1049,"content":"这个公司欠薪吗？","createdAt":"2024-01-18T16:25:27"},{"id":"01963dda-dfdb-708f-9ad0-293d16204e0a","parentId":null,"rootId":null,"fromId":5410,"content":"不欠薪，但是有个叫张冰冰的傻逼leader只带组长团建吃饭，不带普通员工吃饭，把员工当牛马","createdAt":"2024-02-01T17:31:13"},{"id":"01963dda-dfe0-7366-bb6b-72547731748f","parentId":null,"rootId":null,"fromId":1049,"content":"这个公司发薪及时吗？","createdAt":"2024-03-05T17:28:59"},{"id":"01963dda-e031-72ce-aa82-7233c6766137","parentId":null,"rootId":null,"fromId":5410,"content":"公司里拉帮结派，工作环境很差，每次调整工位都能看见蟑螂。工资各种原因克扣，使劲压榨员工，而且大小周。","createdAt":"2024-03-08T17:04:23"},{"id":"01963dda-e076-7200-bfe9-c630418a78d6","parentId":null,"rootId":null,"fromId":1668,"content":"研发部们领导是个傻逼，无线PUA，加班就是白加班，晚上饿着肚子加班，周末加班只能调休，然后调休还容易不通过。","createdAt":"2024-03-21T08:28:27"},{"id":"01963dda-e0bc-72c4-b715-82168e2bd60d","parentId":null,"rootId":null,"fromId":1049,"content":"欠薪吗","createdAt":"2024-03-21T08:35:09"},{"id":"01963dda-e0c1-7156-94c9-ed3dfb3f9b69","parentId":null,"rootId":null,"fromId":5410,"content":"这公司谁去谁后悔","createdAt":"2024-03-22T09:27:22"},{"id":"01963dda-e0c6-729f-aea8-5d81c690c03f","parentId":null,"rootId":null,"fromId":1977,"content":"其实济南的公司去了不后悔的反而不多，真悲哀","createdAt":"2024-03-22T09:50:58"},{"id":"01963dda-e0cb-73ec-b5ee-6b1255174efb","parentId":null,"rootId":null,"fromId":21082,"content":"公司马上搬到孙村那边园区","createdAt":"2024-06-19T17:31:04"},{"id":"01963dda-e153-70bb-8368-bc03304e3c49","parentId":null,"rootId":null,"fromId":5724,"content":"你是个什么傻逼东西","createdAt":"2024-07-25T10:18:53"},{"id":"01963dda-e158-7376-aefe-a4ead7aaa744","parentId":null,"rootId":null,"fromId":21376,"content":"你是个什么傻逼东西","createdAt":"2024-07-30T20:08:22"},{"id":"01963dda-dec1-70fd-89e5-3c713b13132f","parentId":null,"rootId":null,"fromId":21363,"content":"刷kpi的吧","createdAt":"2024-08-08T09:08:28"},{"id":"01963dda-e15c-718e-9eac-0a003c01f2a9","parentId":null,"rootId":null,"fromId":1733,"content":"你是个什么傻逼东西","createdAt":"2024-08-08T09:42:01"},{"id":"01963dda-e161-733a-85c8-a26ed6c1a1a6","parentId":null,"rootId":null,"fromId":2381,"content":"公司大小周吗还是双休？五险一金缴纳情况咋样？有年终奖吗？","createdAt":"2025-02-07T10:15:00"}]