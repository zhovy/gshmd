[{"id":"01963ded-bf10-726b-a03b-4694506468a6","parentId":null,"rootId":null,"fromId":2658,"content":"第二个吧 第一个后端就一个人 感觉靠不住","createdAt":"2024-04-12T08:23:39"},{"id":"01963ded-bf56-73ca-aae4-4545d3712127","parentId":null,"rootId":null,"fromId":933,"content":"第一个","createdAt":"2024-04-12T08:57:02"},{"id":"01963ded-bf9a-732c-a6f8-0a992740496c","parentId":null,"rootId":null,"fromId":3801,"content":"闭眼第二个，不接受出差的话就再找找，第一个明显不靠谱，随时跑路的感觉。","createdAt":"2024-04-12T08:58:29"},{"id":"01963ded-bfde-71b5-ae55-336d581b5b2b","parentId":null,"rootId":null,"fromId":5954,"content":"出差这么多啊 加班也肯定不少的 第一个也明显不靠谱 要是实在缺钱或者有家庭了或者有房贷 就去出差 反之就去第一个 骑驴找马吧！先有工资再说吧 在职找","createdAt":"2024-04-12T09:15:57"},{"id":"01963ded-c021-7025-8e4d-39bfc043ab78","parentId":null,"rootId":null,"fromId":6517,"content":"13薪，感觉不好说能发下来 你当他12就行","createdAt":"2024-04-12T09:35:54"},{"id":"01963ded-c06e-716a-b33b-dd92d4f8849e","parentId":null,"rootId":null,"fromId":5408,"content":"第一个感觉不是很靠谱，就一个后端，要么是公司项目少一个后端就够了，要么是公司没有多余的钱继续招人","createdAt":"2024-04-12T09:41:33"},{"id":"01963ded-c0b8-700d-8a81-841fe3a7b8b0","parentId":null,"rootId":null,"fromId":1372,"content":"非要选一个的话就第2个吧。第一个明显是没钱嘛，更没保障。","createdAt":"2024-04-12T10:16:15"},{"id":"01963ded-c065-7055-82a7-2210951c0776","parentId":null,"rootId":null,"fromId":7107,"content":"之前从没找到过13薪的这种工作，为啥啊。。。或者说很多济南公司承诺13薪但是都不发？","createdAt":"2024-04-12T10:45:01"},{"id":"01963ded-c0ff-7280-9311-b87ce8c7d16e","parentId":null,"rootId":null,"fromId":333,"content":"在你不完全了解公司的前提下 还是选钱多的吧","createdAt":"2024-04-12T11:18:22"},{"id":"01963ded-c145-731c-a749-996eeb461667","parentId":null,"rootId":null,"fromId":3341,"content":"第二个 普联？","createdAt":"2024-04-12T11:41:00"},{"id":"01963ded-c18c-7161-83c3-06d544cc31a5","parentId":null,"rootId":null,"fromId":3341,"content":"错了错了 普华？","createdAt":"2024-04-12T11:41:37"},{"id":"01963ded-c191-70d6-99fb-3def4fe328c8","parentId":null,"rootId":null,"fromId":3341,"content":"哦 不对普华 公积金这块对不上","createdAt":"2024-04-12T11:41:55"},{"id":"01963ded-c06a-7318-8949-f6710c6cfea4","parentId":null,"rootId":null,"fromId":2420,"content":"13新就是年终奖，给你画大饼的！","createdAt":"2024-04-12T11:45:17"},{"id":"01963ded-c195-7046-bef5-6fc1f830f56f","parentId":null,"rootId":null,"fromId":875,"content":"看公司人数，济南低于100人的公司不能去，老板不懂管理，中层不懂业务，开发技术一塌糊涂，关键是公司里各种老板的亲戚还不少，一个个都得罪不起，你一个人要前后端通吃，会写代码也要会捋需求，会做ppt，还有要每周给公司打扫卫生，真是服了，保洁费都不出，厕所一年都没有手纸，还需要自己带","createdAt":"2024-04-12T18:56:25"},{"id":"01963ded-c1da-70b6-a0aa-06dcfba6780e","parentId":null,"rootId":null,"fromId":5506,"content":"怎么感觉你说的是xs呢","createdAt":"2024-04-13T11:50:14"},{"id":"01963ded-c1df-73e1-9b32-a6842967f7a1","parentId":null,"rootId":null,"fromId":1372,"content":"你是在说链上企客吗？","createdAt":"2024-04-13T19:51:23"}]