[{"id":"01963de3-3a63-718b-8ac2-765378be8819","parentId":null,"rootId":null,"fromId":3024,"content":"有人知道吗","createdAt":"2023-06-01T11:20:27"},{"id":"01963de3-3aa8-706e-973e-93c9fc090e78","parentId":null,"rootId":null,"fromId":2105,"content":"面试过，应该是刷kpi，没有通过。目前公司锁人事不锁人事的，入职好像给不了工资。问题基本上就八股文，准备一下试试吧。","createdAt":"2023-06-04T14:40:18"},{"id":"01963de3-3aad-728e-a52a-1eea31d52428","parentId":null,"rootId":null,"fromId":3024,"content":"能加个联系方式说说吗 \n","createdAt":"2023-06-20T15:39:46"},{"id":"01963de3-3ab1-7240-a7d5-feb2d24dc151","parentId":null,"rootId":null,"fromId":988,"content":"入职三月试用期，试用期工资80%。三月后定岗。公司属于银联体系公司，受央行指导","createdAt":"2023-06-20T23:14:34"},{"id":"01963de3-3b08-70c0-b2f0-3961fd63cffd","parentId":null,"rootId":null,"fromId":1398,"content":"楼主，咋样啊","createdAt":"2023-07-07T16:56:08"},{"id":"01963de3-3b4d-70d2-899e-7019e92ca9a5","parentId":null,"rootId":null,"fromId":4049,"content":"同问，咋样呀，是不是还要做笔试题？","createdAt":"2023-07-14T19:15:06"},{"id":"01963de3-3b92-7342-9050-a33185ce718a","parentId":null,"rootId":null,"fromId":3024,"content":"做完了 hr也爱答不理的 不给约面试时间  我就没去面","createdAt":"2023-07-19T11:18:19"},{"id":"01963de3-3b96-70e0-8c70-58e1c6056ade","parentId":null,"rootId":null,"fromId":2478,"content":"先让在线做一个说是类似考公的行测的选择题","createdAt":"2023-10-17T09:17:14"},{"id":"01963de3-3bdb-7011-9704-838806cef451","parentId":null,"rootId":null,"fromId":6221,"content":"面试经下了两次，先让我注册，再让我验证邮箱，服了","createdAt":"2023-12-04T10:51:33"},{"id":"01963de3-3c20-7177-b1c7-9aa3b2292e17","parentId":null,"rootId":null,"fromId":6221,"content":"1、线上行测、性格测试。该过程好像是总部来评定，通过测试后进入面试阶段，大约一周左右出结果\n2、现场一面。根据项目经验讨论相关技术问题，不单独问八股文，切合实际\n3、现场二面，谈钱、待遇，相关问题，确定是否可入职。\n4、入职材料准备，内容较多\n上述为个人面试入职流程，对于薪资，中等偏上，待遇基本天花板了。基本不加班、公积金全额。","createdAt":"2023-12-04T10:59:59"},{"id":"01963de3-3c65-739d-be1b-b7f800ae13f6","parentId":null,"rootId":null,"fromId":3722,"content":"行测的题目可以透露一下吗，方便加个联系方式吗","createdAt":"2024-01-29T14:07:19"},{"id":"01963de3-3c69-70a2-9d9b-c659ce01c767","parentId":null,"rootId":null,"fromId":3892,"con