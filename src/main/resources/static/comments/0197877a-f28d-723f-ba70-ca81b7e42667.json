[{"id":"01978ac0-f32f-70c6-851e-bbcebad06515","parentId":null,"rootId":null,"fromId":1955,"content":"我没别的意思，先去弄个学历吧。你这样8年经验，咱说心里话胜过一大片人，但是人家招聘的第一选择先把学历给你刷下去了，你那些阅历他们还没开始筛呢，学历给你刷没了，岂不是很不爽","createdAt":"2025-06-20T08:33:10"},{"id":"01978b0d-2dc3-72ce-8198-2d098058c2f7","parentId":null,"rootId":null,"fromId":1099,"content":"确实是这样的，但是我不确定在济南函授本科是否有公司承认","createdAt":"2025-06-20T09:56:26"},{"id":"01978b1c-e954-72c5-9da9-ae0f8800e896","parentId":null,"rootId":null,"fromId":7270,"content":"8年经验应该能判断出来了，这不是聊胜于无的东西吗。你现在开始弄也晚了，不得2.5年拿证","createdAt":"2025-06-20T10:13:37"},{"id":"01978ce1-7d38-7215-b7ed-4aa9db73f90a","parentId":null,"rootId":null,"fromId":1099,"content":"现在晚了吗","createdAt":"2025-06-20T18:27:57"},{"id":"01979ab2-ff3a-7312-9c24-1e2cc13f0d56","parentId":null,"rootId":null,"fromId":1039,"content":"我们在招，但是我都给朋友内推了，坦白讲，现在工作是找圈子，靠圈子内部的人内推","createdAt":"2025-06-23T10:51:51"},{"id":"0197a64d-01a4-7179-9f3d-0c0d609d2064","parentId":null,"rootId":null,"fromId":1099,"content":"还缺人不？","createdAt":"2025-06-25T16:55:54"}]