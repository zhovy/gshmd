[{"id":"01988307-c3c8-707a-a74c-1d79ab81fc4d","parentId":null,"rootId":null,"fromId":25906,"content":"没有必要，浪费学费，更浪费时间。","createdAt":"2025-08-07T13:36:20"},{"id":"01988308-0728-7362-98b8-c8acacc5cd5a","parentId":null,"rootId":null,"fromId":6344,"content":"建议你读好学校的博士，至少也得是个211","createdAt":"2025-08-07T13:36:38"},{"id":"01988308-4ce6-7055-bfae-21a787237ef1","parentId":null,"rootId":null,"fromId":23684,"content":"读","createdAt":"2025-08-07T13:36:56"},{"id":"01988308-bce9-726b-af64-bed1491b6f82","parentId":null,"rootId":null,"fromId":23684,"content":"读完直接留校呗","createdAt":"2025-08-07T13:37:24"},{"id":"01988309-a1fe-7281-969a-562013185648","parentId":null,"rootId":null,"fromId":5755,"content":"一边读书 一边考公","createdAt":"2025-08-07T13:38:23"},{"id":"0198830b-7dc2-7079-8fe5-0e5a517c161c","parentId":null,"rootId":null,"fromId":460,"content":"有条件就读呗 有的想读还读不了呢","createdAt":"2025-08-07T13:40:25"},{"id":"0198830d-c60c-7071-a639-55d2c58687a1","parentId":null,"rootId":null,"fromId":1003,"content":"有条件就读  就算不是985  211 有博士的坑也很厉害","createdAt":"2025-08-07T13:42:54"},{"id":"01988320-aa15-737e-b705-113951e28e4a","parentId":null,"rootId":null,"fromId":770,"content":"读吧","createdAt":"2025-08-07T14:03:32"},{"id":"01988326-9cd0-7398-88cb-7d3e75b84e83","parentId":null,"rootId":null,"fromId":1421,"content":"如果是211能通过肯定会读，但是目前没过硬的刊物不敢想","createdAt":"2025-08-07T14:10:02"},{"id":"0198832e-ce5a-7070-83dd-3c4f237a5f95","parentId":null,"rootId":null,"fromId":6344,"content":"双非好毕业还行，要不然就算了吧，太浪费时间精力了","createdAt":"2025-08-07T14:18:59"},{"id":"0198832f-b8d1-736b-9d46-314c9139eb6e","parentId":null,"rootId":null,"fromId":6344,"content":"不行的话就试试申请国外的博士把，没准有机会留下，国外不卷","createdAt":"2025-08-07T14:19:59"},{"id":"0198838c-69e4-73d3-b675-27adcfb032c3","parentId":null,"rootId":null,"fromId":21511,"content":"主要看博导   双非校长博导比985普通博导强多了","createdAt":"2025-08-07T16:01:14"},{"id":"01988396-2634-718a-a542-e7c9e0f7fd3d","parentId":null,"rootId":null,"fromId":21676,"content":"不要，你几年后读完，估计留在本校都难","createdAt":"2025-08-07T16:11:52"},{"id":"019883c3-f805-737e-a22a-2ccff1fb9789","parentId":null,"rootId":null,"fromId":21364,"content":"看你项目啊，要是项目好，读博毕业以后有好出路就读。研究生可能就只能再去当导员，好专业走走校招之类的。读博读出来还能多拿点补贴和安置费，也不亏，那你要是专业学校导师项目都不行，就不要读了，读出来没人接收还没经验，白读了。","createdAt":"2025-08-07T17:01:55"},{"id":"0198870f-3cd8-73e3-b4aa-c95c2aed0a59","parentId":null,"rootId":null,"fromId":2051,"content":"说个暴论，普通人读博士比不读对后面就业是有好处的，除非你硕士毕业就签了一个很好的单位，如高速、烟草、电网之类的，那就马不停蹄的上班，其他的还是建议读博","createdAt":"2025-08-08T08:22:59"},{"id":"0198873f-c8ea-7092-97c0-b03617232136","parentId":null,"rootId":null,"fromId":22809,"content":"楼上全扯淡，摸清导师真实目的再决定：\n1. 是你听话，免费让你再打几年工？\n2. 真为你好？为嘛不推荐你去211 985读博，凭他的人脉给个推荐信不难吧？ \n好好思考一下。","createdAt":"2025-08-08T09:16:01"},{"id":"01988785-2e7c-7199-aa8d-690b0686f5f8","parentId":null,"rootId":null,"fromId":4190,"content":"读啊，能读就读，学历可以给你筛去很多竞争对手","createdAt":"2025-08-08T10:31:49"},{"id":"01988786-250d-70c7-bc70-5f5a0aee1924","parentId":null,"rootId":null,"fromId":4190,"content":"但是要在你能顺利毕业的前提下","createdAt":"2025-08-08T10:32:52"},{"id":"019887aa-b466-7176-8239-bb8f2dad7623","parentId":null,"rootId":null,"fromId":1376,"content":"说实话，你学校不是985，读研都是浪费时间，还读博","createdAt":"2025-08-08T11:12:48"},{"id":"019887ba-fdd3-722c-98fa-4f5037e359d8","parentId":null,"rootId":null,"fromId":1421,"content":"说实话这种类型的问题早已超出这个论坛受众人群的认知了，能看到这问题的应该没个博士，反正我当时没继续读，很简单，经济状况+科研兴趣不大，其实博士延毕的很多，反正我们那届读博了解的就一个正常毕业，其他都是延毕","createdAt":"2025-08-08T11:30:35"},{"id":"019891d4-39d9-701c-a8a2-0c2b0494cf0d","parentId":null,"rootId":null,"fromId":2056,"content":"计算机专业的话，建议你读，很多好的公司，博士随便进，有些文科的博士，也可以进去混，工资也不低，他们需要高学历撑场面。有条件就读。","createdAt":"2025-08-10T10:34:21"},{"id":"019896b3-8cde-7129-8b67-10ba97c840b7","parentId":null,"rootId":null,"fromId":21511,"content":"这个论坛一堆大专  能给你提供什么好的建议？","createdAt":"2025-08-11T09:16:46"}]