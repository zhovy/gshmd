[{"id":"019ba114-95e4-7266-b20f-c15ef49e7fc7","parentId":null,"rootId":null,"fromId":5584,"content":"为啥要仲裁","createdAt":"2026-01-09T12:47:19"},{"id":"019ba12a-e7c9-70d5-bb63-44a3de17bc79","parentId":null,"rootId":null,"fromId":27388,"content":"目前排期在三个月左右","createdAt":"2026-01-09T13:11:42"},{"id":"019ba132-77ea-7044-9f93-8fbfda8da95a","parentId":null,"rootId":null,"fromId":3341,"content":"拖欠工资 恶意克扣","createdAt":"2026-01-09T13:19:57"},{"id":"019ba151-119e-7350-87dc-d0d9953de729","parentId":null,"rootId":null,"fromId":23971,"content":"22年的时候拖欠工资仲裁过，国务院app上提交的欠薪反馈，过了大概一个多月有工作人员联系我。后来老板接到电话直接怂了，把工资补给我让我去撤销仲裁。当然这是在老板认怂的情况下，要是老板要跟你一直杠到底，需要多久我就不知道了","createdAt":"2026-01-09T13:53:23"},{"id":"019ba255-1f63-738c-917e-5b678588b73f","parentId":null,"rootId":null,"fromId":5584,"content":"什么公司","createdAt":"2026-01-09T18:37:26"},{"id":"019ba5a7-2acd-73fd-9f21-17703f25d693","parentId":null,"rootId":null,"fromId":2846,"content":"国务院aop怎么提交欠薪反馈","createdAt":"2026-01-10T10:05:54"},{"id":"019bafde-9361-7015-91d8-68ca2c689b7c","parentId":null,"rootId":null,"fromId":3341,"content":"目前正处理阶段 暂时先不透露  避免些不必要的麻烦","createdAt":"2026-01-12T09:42:38"},{"id":"019bafde-de5d-7340-9fff-ea5b38f1752a","parentId":null,"rootId":null,"fromId":3341,"content":"类似个信访窗口","createdAt":"2026-01-12T09:42:57"},{"id":"019bb51a-b780-7329-9d7f-66e8c0ccb7e6","parentId":null,"rootId":null,"fromId":270,"content":"高新仲裁量特别大，我12月提交的材料，近几天回复我调解不成，说是现在走开庭的需要排队，近期开庭的都是11月的案子","createdAt":"2026-01-13T10:06:25"},{"id":"019bb61d-b233-705a-9b73-9990728aff30","parentId":null,"rootId":null,"fromId":4357,"content":"24年初申请的劳动仲裁，目前还在强制执行，到现在没拿到钱","createdAt":"2026-01-13T14:49:18"},{"id":"019bb62b-1cfc-72a7-b526-939988ac7d16","parentId":null,"rootId":null,"fromId":3341,"content":"说句安慰你的话 这样已经挺快了 哈哈哈","createdAt":"2026-01-13T15:03:57"},{"id":"019bb62b-69ca-7149-94d0-1895b2914e3a","parentId":null,"rootId":null,"fromId":3341,"content":"终审啥时候结束的？","createdAt":"2026-01-13T15:04:17"},{"id":"019bb687-4ee8-7309-95a6-50cc7ea254d5","parentId":null,"rootId":null,"fromId":4038,"content":"23年时是3个月，但是开庭判决不代表你能拿到工资","createdAt":"2026-01-13T16:44:39"},{"id":"019bb6ca-655d-7250-a59e-7a0a20a57739","parentId":null,"rootId":null,"fromId":3341,"content":"只要公司正常运营 强制执行 没问题吧？","createdAt":"2026-01-13T17:57:56"},{"id":"019bde69-e7c6-72af-a6ec-d80804288486","parentId":null,"rootId":null,"fromId":4038,"content":"仲裁庭没有强制权限吧  仲裁庭审完，如果拿不到钱 还需要到法院起诉强制","createdAt":"2026-01-21T10:37:21"}]