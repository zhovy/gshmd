[{"id":"01963de8-4e71-701e-9f04-7d9060e49bef","parentId":null,"rootId":null,"fromId":2890,"content":"你是23届的？考研二战？放弃了？","createdAt":"2023-09-17T07:46:16"},{"id":"01963de8-4ebc-7291-ac78-fa576e088b7f","parentId":null,"rootId":null,"fromId":2890,"content":"短时间内，第一次面不过后面就没机会了","createdAt":"2023-09-17T07:46:55"},{"id":"01963de8-4f01-7108-8df9-895524ac59eb","parentId":null,"rootId":null,"fromId":5688,"content":"24届","createdAt":"2023-09-17T12:43:13"},{"id":"01963de8-4f05-703f-b945-579f24100c7b","parentId":null,"rootId":null,"fromId":455,"content":"章丘除了地纬基本上没有软件开发公司了吧，运维实施都基本为0，地纬应该也是用自己内部的框架吧，低代码开发平台，之前有熟人在里面上班，后来从济南搬到章丘就不干了","createdAt":"2023-09-17T12:44:01"},{"id":"01963de8-4f48-7225-982d-68153848e594","parentId":null,"rootId":null,"fromId":5688,"content":"乐，章丘是这样的","createdAt":"2023-09-17T12:53:45"},{"id":"01963de8-4f4d-726a-af64-27c0e40b0bab","parentId":null,"rootId":null,"fromId":4052,"content":"同章丘人，不过我是23届。去年同学校招面过山大地纬，据说很简单。","createdAt":"2023-09-18T12:49:21"},{"id":"01963de8-4f95-70c9-8fcd-4138563dbddd","parentId":null,"rootId":null,"fromId":2169,"content":"我也章丘，没啥难的，笔试就是基础题。面试随便问问，就过了","createdAt":"2023-09-18T17:28:12"},{"id":"01963de8-4fe6-713b-b45b-090009503797","parentId":null,"rootId":null,"fromId":5584,"content":"这公司 有学历随便进","createdAt":"2023-09-18T17:41:02"},{"id":"01963de8-4f90-73a7-a426-e9bc5b6f09c4","parentId":null,"rootId":null,"fromId":5688,"content":"啊，那我有点信心了，放心学了。。。","createdAt":"2023-09-18T21:23:29"},{"id":"01963de8-4fd8-7211-b47b-2bac8387f27b","parentId":null,"rootId":null,"fromId":5688,"content":"请问笔试基础指的是javase和数据库的知识吗？","createdAt":"2023-09-18T21:23:58"},{"id":"01963de8-502a-7261-b984-a2fd6450dad2","parentId":null,"rootId":null,"fromId":5688,"content":"山财会不会被卡学历啊。。。","createdAt":"2023-09-18T21:24:14"},{"id":"01963de8-4fdd-7230-8d54-676ddefa8184","parentId":null,"rootId":null,"fromId":5688,"content":"对了，网申必须要有项目吗···项目还没来得及写","createdAt":"2023-09-18T22:12:45"},{"id":"01963de8-5033-709a-8d69-341ad30d9383","parentId":null,"rootId":null,"fromId":5584,"content":"山大地维的老板不知道咋想的？济南的不想来，想来的还卡学历卡学校的","createdAt":"2023-09-20T08:55:18"},{"id":"01963de8-502f-7120-9794-6af154b77b0f","parentId":null,"rootId":null,"fromId":2169,"content":"卡不了一点，山财不随便进？","createdAt":"2023-09-20T16:42:40"},{"id":"01963de8-5078-71bd-a62b-cb1957068995","parentId":null,"rootId":null,"fromId":3158,"content":"简单","createdAt":"2023-09-20T16:44:51"},{"id":"01963de8-4fe2-73a3-a60c-7f67dabdeb7b","parentId":null,"rootId":null,"fromId":2169,"content":"差不多吧，网申没说要有项目吧，你随便在网上找一个就行","createdAt":"2023-09-20T16:49:19"},{"id":"01963de8-50bd-7385-9f23-a6b6da9284dd","parentId":null,"rootId":null,"fromId":5909,"content":"主要做医保和医疗业务，公司有自己的园区，办公环境可以，吃住不需要花钱，需要笔试，然后线上面试，整体给的不是很高，并且要求提供薪资流水。去年给我1.3，我没去，如果章丘本地，选择一直干下去，山大地纬是个不错的选择，建议去之前先了解了解他们的业务，能线下面尽量不要线上面","createdAt":"2023-10-12T18:24:02"}]