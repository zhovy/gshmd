[{"id":"01963df2-29e1-70df-8624-2fe636773fab","parentId":null,"rootId":null,"fromId":5867,"content":"新人还没到浪潮就会被提醒注意不要住草山岭?","createdAt":"2024-08-10T22:39:31"},{"id":"01963df2-2a24-7237-977a-3bc787869916","parentId":null,"rootId":null,"fromId":875,"content":"济南二房东哪个不坑","createdAt":"2024-08-10T23:01:35"},{"id":"01963df2-2a28-7172-9106-dc73dc8f65ce","parentId":null,"rootId":null,"fromId":5737,"content":"也分片区，草山岭是最坑的","createdAt":"2024-08-11T10:59:53"},{"id":"01963df2-2a34-70ba-b470-ee8f2c0b7717","parentId":null,"rootId":null,"fromId":7631,"content":"你不交押金谁租给你","createdAt":"2024-08-11T12:28:24"},{"id":"01963df2-2a79-710d-b2a3-6caa3dc6536c","parentId":null,"rootId":null,"fromId":5867,"content":"我现在租的房子就不交押金，住了一年多，房东分两种，一种是搞长期靠客户口碑介绍互相信任的，一种纯宰客杀生的","createdAt":"2024-08-11T14:27:32"},{"id":"01963df2-2a7d-72fd-86a1-092ce28b09b7","parentId":null,"rootId":null,"fromId":875,"content":"租房价格不要超过你工作的5%.老家三线城市，800块能租一个两室一厅的房子，工资八千多","createdAt":"2024-08-11T14:59:36"},{"id":"01963df2-2ad4-727e-a78f-59eea95aa1ba","parentId":null,"rootId":null,"fromId":6517,"content":"不交押金，你万一把人家家里霍霍了，找不着你了","createdAt":"2024-08-11T22:13:23"},{"id":"01963df2-2ac2-732c-bfd0-18e2afecaa20","parentId":null,"rootId":null,"fromId":7226,"content":"150一个月的房子不好找啊","createdAt":"2024-08-12T09:00:04"},{"id":"01963df2-2b17-7274-8077-6484b1a5a04a","parentId":null,"rootId":null,"fromId":1238,"content":"工业北的避雷美乐家 垃圾中介","createdAt":"2024-08-12T09:23:28"},{"id":"01963df2-2b60-7172-be0c-5817c50fe2b8","parentId":null,"rootId":null,"fromId":403,"content":"我要是房东，不交押金我是不会出租的。以前遇到过一个租客，我也没收押金，临走时把我家里的电源插排和桌面摆件全都顺走了，卧室的好几块木地板也因积水泡烂了，关键是防盗门锁还给我换了，让我进不去，开门还要花几十块钱的开锁师傅。宁愿房子租不出去，也一定要押金。","createdAt":"2024-08-12T09:31:22"},{"id":"01963df2-2be7-73fc-b4eb-04d80af53b51","parentId":null,"rootId":null,"fromId":21396,"content":"不仅仅是济南，别的地方也是","createdAt":"2024-08-12T10:33:42"},{"id":"01963df2-2ac7-7141-b7d9-123315e7137f","parentId":null,"rootId":null,"fromId":21631,"content":"数学是体育老师教的，800占8000多少，还不超过5%。不超5%的能有多少。。。章口就来","createdAt":"2024-08-12T11:02:53"},{"id":"01963df2-2bec-7028-b827-e182849f4e29","parentId":null,"rootId":null,"fromId":21459,"content":"大哥，展开说说呗，避免下次踩坑","createdAt":"2024-08-12T11:21:13"},{"id":"01963df2-2bf0-7101-a5ac-a2b97e9785b2","parentId":null,"rootId":null,"fromId":4010,"content":"不是每个人都有素质，不交押金有损失谁赔？","createdAt":"2024-08-12T16:02:08"},{"id":"01963df2-2acb-708d-84da-469621bb89c3","parentId":null,"rootId":null,"fromId":875,"content":"数学是真不好，两室一厅，一间不是400?400/8000不是5%?","createdAt":"2024-08-12T20:05:32"},{"id":"01963df2-2b5c-7323-a207-9717d235651f","parentId":null,"rootId":null,"fromId":5913,"content":"也叫窝牛公寓","createdAt":"2024-08-12T20:44:43"},{"id":"01963df2-2acf-7076-afa8-e41e9c63cc6c","parentId":null,"rootId":null,"fromId":21631,"content":"666，你说的单间，服气","createdAt":"2024-08-13T10:46:35"},{"id":"01963df2-2c39-717c-b26b-11099f992a37","parentId":null,"rootId":null,"fromId":5695,"content":"楼上说的很对，在济南千万千万不要找东北人租房，无论说的多好听！现在正在退租维权，信访局的人告诉我，济南租房圈有个东北帮，专门靠租房坑人","createdAt":"2024-08-15T11:15:05"},{"id":"01963df2-2c85-70b1-9c00-3b40e8c3acb1","parentId":null,"rootId":null,"fromId":21327,"content":"东北人","createdAt":"2024-08-15T13:35:52"},{"id":"01963df2-2cc8-712c-8c89-9a9b9782fbd5","parentId":null,"rootId":null,"fromId":21327,"content":"租房别找东北人！别找东北人！","createdAt":"2024-08-15T13:37:11"},{"id":"01963df2-2d0c-73a2-b08f-5dedfb8012e2","parentId":null,"rootId":null,"fromId":4174,"content":"在北京的时候租房也是东北的坑人","createdAt":"2024-08-15T14:18:02"},{"id":"01963df2-2d5d-7383-8dfb-10c4b7d1a2a7","parentId":null,"rootId":null,"fromId":3341,"content":"怎么满世界到哪都有东北的 啊。。。。","createdAt":"2024-08-15T21:18:19"},{"id":"01963df2-2da7-72a8-bba0-5ddc4e42a804","parentId":null,"rootId":null,"fromId":2407,"content":"我在草山岭租了半年，走的时候也没什么问题。现在外面租房哪有没押金的","createdAt":"2024-08-16T16:05:55"},{"id":"01963df2-2ded-71f5-855d-a427e4639808","parentId":null,"rootId":null,"fromId":267,"content":"东北的，河北的，二房东大概99.9999999999%会扣押金","createdAt":"2024-08-23T03:06:51"},{"id":"01963df2-2df2-7200-ad86-9b644ee55f84","parentId":null,"rootId":null,"fromId":267,"content":"二房东几乎找不到靠谱的，我是被坑了一万七千四百多，要押金还被打了轻伤","createdAt":"2024-08-23T03:08:00"},{"id":"01963df2-2c7d-726a-934a-1bdfe9aa5752","parentId":null,"rootId":null,"fromId":267,"content":"这点，河北的多不多，还有滕州的多不多","createdAt":"2024-09-01T02:46:25"},{"id":"01963df2-2c80-722f-943c-6df038f6c307","parentId":null,"rootId":null,"fromId":267,"content":"确实不知道，只是打听打听","createdAt":"2024-09-01T02:46:46"},{"id":"01963df2-2a2c-7358-bc6e-ebe4f4259e63","parentId":null,"rootId":null,"fromId":267,"content":"不坑的非常非常少，但这并不是概率问题，普通人没时间去调查这个","createdAt":"2024-09-01T02:49:14"},{"id":"01963df2-2a30-7142-aa42-b5c71d7d875d","parentId":null,"rootId":null,"fromId":267,"content":"就是和上面那个兄弟说的。的确是有个“组织”，他们分工很明确，也有一定的法律知识，利用种种漏洞以出租的名义，去做诈骗的实质，会找职业背债人，法律威慑在他们看来是开玩笑的。。。","createdAt":"2024-09-01T02:52:01"},{"id":"01963df2-2df6-72c6-b6c1-db53167a2718","parentId":null,"rootId":null,"fromId":203,"content":"有个叫杨强的二房东，千万不要租他的房子，退房的时候押金一分都别想要。你退房的时候他不会露面，他叫你把房间打扫干净 钥匙放到房间里，等你照他说的都做完了之后 他就直接把你微信好友删了。据我了解，租他房子的人 还没有一个能把押金要回来的","createdAt":"2024-09-04T11:19:22"}]