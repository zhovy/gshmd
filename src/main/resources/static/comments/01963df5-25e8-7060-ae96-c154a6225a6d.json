[{"id":"01963df5-26a6-70ca-9036-753c3cc143c5","parentId":null,"rootId":null,"fromId":22173,"content":"济南作为么？还欠着吧","createdAt":"2024-12-03T15:18:26"},{"id":"01963df5-26ab-72e4-bc30-ef2339ef8502","parentId":null,"rootId":null,"fromId":3671,"content":"今天逛超市，听见收银员抱怨，12月份了，9月的工资还没发呢","createdAt":"2024-12-03T21:53:02"},{"id":"01963df5-26fe-7003-a141-9cf8b79ac72c","parentId":null,"rootId":null,"fromId":21912,"content":"因为只要有一个拖欠工资不被处理的，扣你工资放进自己钱包，老板为什么不去效仿？说到底还是自己不去争取自己的合法权益，指望谁帮你","createdAt":"2024-12-04T10:38:50"},{"id":"01963df5-274f-71dc-b28c-2f909d49c686","parentId":null,"rootId":null,"fromId":21642,"content":"确实，今年都喊着大环境不好。就都开始拖欠货款和工资了","createdAt":"2024-12-04T12:56:35"},{"id":"01963df5-2746-720d-a0fc-4ecefeee1b39","parentId":null,"rootId":null,"fromId":21818,"content":"反正现在老板的家庭住址，小孩上什么学校我都摸清了，别的现在找工作难找也就认了，工资少一个子是不可能的","createdAt":"2024-12-04T13:25:40"},{"id":"01963df5-2794-72ad-ab52-b4beaec3b9f3","parentId":null,"rootId":null,"fromId":22173,"content":"拖欠贷款银行饶不了吧。小老百姓拖着也就拖着，银行他们哪敢？","createdAt":"2024-12-04T13:43:08"},{"id":"01963df5-2798-709b-b999-18572904731c","parentId":null,"rootId":null,"fromId":21642,"content":"银行现在更恶心，他非常了解企业的经营状况，经营好的企业他求着你贷款帮他完成任务，经营不好的你求他都不贷给你","createdAt":"2024-12-04T15:48:32"},{"id":"01963df5-26fa-73b7-8b19-bf66fdb5d623","parentId":null,"rootId":null,"fromId":880,"content":"超市还是人挺多的啊，这个不至于吧","createdAt":"2024-12-04T17:20:13"},{"id":"01963df5-274b-73ae-8392-c8151f7f7a4c","parentId":null,"rootId":null,"fromId":267,"content":"底层工人不团结，从世界都出名啊","createdAt":"2024-12-08T11:39:17"},{"id":"01963df5-279c-7177-91b6-287c9942ba7c","parentId":null,"rootId":null,"fromId":267,"content":"只有工人和农民是软柿子呗","createdAt":"2024-12-08T11:40:05"}]