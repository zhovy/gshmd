[{"id":"019a380b-7dff-7302-aa12-d58f7505edcc","parentId":null,"rootId":null,"fromId":6517,"content":"我倒是觉得还挺多的，我工作6年，3个公司都是双休","createdAt":"2025-10-31T10:14:28"},{"id":"019a381a-0677-7325-896b-a5ea9a503a19","parentId":null,"rootId":null,"fromId":3450,"content":"周六上班谁挤着早高峰上，我都是11点出门上班","createdAt":"2025-10-31T10:30:21"},{"id":"019a381d-df5a-7320-8e4a-d711ddbd85c7","parentId":null,"rootId":null,"fromId":7124,"content":"周六早高峰经十路最起码少一半的车","createdAt":"2025-10-31T10:34:33"},{"id":"019a382b-6e99-733e-8392-b87ace78a6c3","parentId":null,"rootId":null,"fromId":23274,"content":"有没有可能，周末就没有早高峰","createdAt":"2025-10-31T10:49:21"},{"id":"019a385c-5fc7-7083-922b-8eceb62a0a7f","parentId":null,"rootId":null,"fromId":21818,"content":"周六上班的人当中还有一些是单双休的","createdAt":"2025-10-31T11:42:49"},{"id":"019a3861-2a6c-70fc-b782-d0fd64b668a5","parentId":null,"rootId":null,"fromId":5491,"content":"别在这里PUA人，人都是看本事，有能力找双休，没能力都天天加班，所以说  不用pa谁","createdAt":"2025-10-31T11:48:03"},{"id":"019a3905-5419-715e-a842-3152fc9cd363","parentId":null,"rootId":null,"fromId":21818,"content":"人与人之间差距没那么大的，只是好多人吃不了学习的苦不提升自己，反而整天无效内卷硬磨时间","createdAt":"2025-10-31T14:47:21"},{"id":"019a3919-fa5d-739b-8b15-bd3d622a6ff9","parentId":null,"rootId":null,"fromId":27428,"content":"我做的是it，感觉可能也是行业的问题，加班多；比如：之前的找的搬家公司的工人，人家到点了想干就干不相干就算了；还有身边从事别的行业的朋友，就算单休，平常加班也没这么多的","createdAt":"2025-10-31T15:09:55"},{"id":"019a391d-b72b-73c7-b780-397dc25c3dec","parentId":null,"rootId":null,"fromId":5689,"content":"看路上的车流量没用，我知道差不多50%的IT行业是没有事实上的双休的。有些公司周六上班，但相比平时可以晚到晚走。","createdAt":"2025-10-31T15:14:00"},{"id":"019a3927-299c-7086-83d0-60461aade33a","parentId":null,"rootId":null,"fromId":24202,"content":"从毕业到现在，至今公司全部双休","createdAt":"2025-10-31T15:24:19"},{"id":"019a392d-f21f-732a-bcca-aab41d90df93","parentId":null,"rootId":null,"fromId":27428,"content":"学历高或能力强的，更有机会获取好单位的机会把，他们的感受和普通一本二本乃至大专的感受大相径庭","createdAt":"2025-10-31T15:31:43"},{"id":"019a394c-5d83-7081-a815-fd80a2d5e474","parentId":null,"rootId":null,"fromId":5689,"content":"我软件行业工作20年，也全是双休，因为不是双休的工作我不去。","createdAt":"2025-10-31T16:04:57"},{"id":"019a68eb-5e45-7255-8f14-a4d059b45d13","parentId":null,"rootId":null,"fromId":5491,"content":"人最大的可悲是忙碌   还不能提升自己 ，说加班就能提升自己，对于没经验的可以，但是对于某些就是机械重复，而是真要提升","createdAt":"2025-11-09T22:00:46"}]