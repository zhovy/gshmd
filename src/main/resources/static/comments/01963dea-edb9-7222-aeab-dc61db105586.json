[{"id":"01963dea-ee1c-73fe-ae61-888a3d0ce168","parentId":null,"rootId":null,"fromId":3333,"content":"公司很不错，是济南为数不多的好公司，同事技术都很厉害，能学到东西，而且待遇也很好，高于济南平均标准，年终保底一个月，可以去试一下","createdAt":"2024-01-24T10:34:37"},{"id":"01963dea-ee5f-7099-8a71-70921a98fbc5","parentId":null,"rootId":null,"fromId":6268,"content":"搞电力的，没多少人，领导PUA人有一手的。","createdAt":"2024-01-24T10:41:18"},{"id":"01963dea-eea3-73bf-92c0-7a80016ee62b","parentId":null,"rootId":null,"fromId":3892,"content":"一楼二楼哪个说的是真的？","createdAt":"2024-01-24T11:41:55"},{"id":"01963dea-eeed-72a3-a948-f68005af6a8a","parentId":null,"rootId":null,"fromId":6268,"content":"规模搜一下，去面试感受感受不就知道了","createdAt":"2024-01-24T15:34:03"},{"id":"01963dea-eef2-725b-be3c-aca5d916f24b","parentId":null,"rootId":null,"fromId":3341,"content":"我估计一楼是演员","createdAt":"2024-01-24T16:48:28"},{"id":"01963dea-eefc-719e-9f23-978462f668e3","parentId":null,"rootId":null,"fromId":6233,"content":"代码用ssm，维护的代码基本上是18年，19年屎山代码，年终奖10%的人有，搞电网的研发也就八九个人吧，领导pua，不是天天加班，也基本大差不差，核心用的是C++，JAVA调接口","createdAt":"2024-01-27T20:41:03"},{"id":"01963dea-eef7-706a-b325-0b8e8d5a2952","parentId":null,"rootId":null,"fromId":6233,"content":"一楼是不是杨经理，还是hr，老板是个老头","createdAt":"2024-01-27T20:42:12"},{"id":"01963dea-ef42-731d-8439-f32c2a7818d8","parentId":null,"rootId":null,"fromId":1368,"content":"工资压得比较低，没有调薪，加班是常态。\n大领导画饼有一套。","createdAt":"2024-01-29T15:44:55"},{"id":"01963dea-ef89-725a-9d20-ccee1889583c","parentId":null,"rootId":null,"fromId":5559,"content":"之前去面试过，里面的技术挺装逼的","createdAt":"2024-03-05T13:01:54"},{"id":"01963dea-efcf-7228-a2de-5e813a72a8c4","parentId":null,"rootId":null,"fromId":5777,"content":"加班没有加班费，纯用爱发电。没有调薪，什么都得干，后端也得干前端，老板PUA有一手。工资远低于同行","createdAt":"2024-11-14T17:11:38"}]