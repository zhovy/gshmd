[{"id":"01963dd2-5fe2-733b-82b6-637e3e773465","parentId":null,"rootId":null,"fromId":14,"content":"别去，千万别去，以前叫北京艾迪信科技","createdAt":"2021-12-31T18:01:35"},{"id":"01963dd2-6029-7398-a3ae-198ce19b0258","parentId":null,"rootId":null,"fromId":203,"content":"千万别去，就是个外包的外包，忙的时候招人，项目做完不忙了就开始撵人，一年换好几批人。领导各种PUA，各种装逼，还甩锅。技术经理不思进取，整天睡大觉，技术水平还停留在JSP+Servlet时代。有点事就甩锅，找个理由就扣钱","createdAt":"2022-04-02T16:22:16"},{"id":"01963dd2-6071-71c2-8bcb-7dd4a82cb665","parentId":null,"rootId":null,"fromId":203,"content":"老板是个女的，满嘴脏话，像个泼妇一样","createdAt":"2022-06-07T15:37:22"},{"id":"01963dd2-60b6-7093-9bd0-43555a35ce58","parentId":null,"rootId":null,"fromId":203,"content":"垃圾公司，忙的时候招人，项目做完不忙了就各种理由扣钱撵人走，老板素质很低，“泼妇”3楼用词很准确","createdAt":"2022-06-07T15:51:48"},{"id":"01963dd2-60fb-7099-8ccd-957276d99405","parentId":null,"rootId":null,"fromId":203,"content":"这个公司逃税，明明从工资里扣了个人所得税，但却没有给人交税，个人所得税年度汇算的时候，我竟然还要自己补1000多块钱的税，要不是税务局给我发短信我都不知道呢，都产生滞纳金了，真狗啊这公司","createdAt":"2022-06-17T13:45:01"},{"id":"01963dd2-6145-73de-9b7d-1263dac896ee","parentId":null,"rootId":null,"fromId":428,"content":"感谢各位","createdAt":"2022-08-03T17:39:42"},{"id":"01963dd2-618b-731a-a2e6-7344705f9bdc","parentId":null,"rootId":null,"fromId":1215,"content":"非常感谢各位，这狗比公司，我去面试，感觉不对，就没下文了，哈哈","createdAt":"2022-08-04T15:19:17"},{"id":"01963dd2-61d0-73cd-8c1c-6929ca31ae46","parentId":null,"rootId":null,"fromId":808,"content":"这个公司很垃圾，几乎离职的人都被扣公司，老板素质非常差，各种扣钱，一个人干一整个项目，特别累，加班加点的","createdAt":"2022-08-16T11:03:20"},{"id":"01963dd2-6218-710c-b34d-b15192f616be","parentId":null,"rootId":null,"fromId":1889,"content":"我面试过这公司，两轮，都是女的，套别人方案。","createdAt":"2022-10-05T04:02:54"},{"id":"01963dd2-625c-70ca-821e-ed3a3a9eed37","parentId":null,"rootId":null,"fromId":203,"content":"艾迪信还没黄呢？","createdAt":"2022-12-29T13:08:51"}]