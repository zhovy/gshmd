[{"id":"01963dec-8316-70e5-8d41-5cb5a1ecf15c","parentId":null,"rootId":null,"fromId":4174,"content":"五环房租两千五左右，正常的房间，大多押一付三，准备一万块钱吧，工资么，2年本科能要到15k左右，专科稍微减点吧","createdAt":"2024-03-12T11:11:47"},{"id":"01963dec-835f-705b-8785-e31f81c2715e","parentId":null,"rootId":null,"fromId":4140,"content":"我同学，大专三年经验拿了16k，但是租的房子一个月5k，跟对象一起住，你要是能牺牲生活质量，租个一千两千的房子，可以去北京赚钱，现在两年大专大概率只能给到9k左右","createdAt":"2024-03-12T11:14:11"},{"id":"01963dec-83a3-708d-a68a-fb573c9afaf3","parentId":null,"rootId":null,"fromId":6915,"content":"别来了，北京大专找不到工作了，不是22年以前了","createdAt":"2024-03-12T11:35:44"},{"id":"01963dec-83e7-73f4-bd8a-2384988dc85c","parentId":null,"rootId":null,"fromId":6742,"content":"找个条件一般的合租或者远点的也不是很贵，不要被什么花里胡哨的名词内耗掉，你除了上下班，在家无非就是躺着，有什么优质生活可言？北漂的多了去了，住地下室，住城中村的多的是，到你这儿就不行了？能挣钱就行","createdAt":"2024-03-12T12:08:11"},{"id":"01963dec-835b-72fd-a834-c2a32cbd4ec3","parentId":null,"rootId":null,"fromId":875,"content":"怎么可能2500?你是整租？五环外，租个单间也就1000多块钱，1500主卧","createdAt":"2024-03-12T12:37:59"},{"id":"01963dec-842b-73fd-88b2-f6549321f3f6","parentId":null,"rootId":null,"fromId":875,"content":"实话，北京合租大家都晚上都很安静的，不像济南，合租隔壁有情侣的，晚上叫个不停","createdAt":"2024-03-12T12:51:48"},{"id":"01963dec-8433-73e6-9987-6334d7371ce6","parentId":null,"rootId":null,"fromId":3341,"content":"专的话 就不分统不统了。。。","createdAt":"2024-03-12T14:00:32"},{"id":"01963dec-8478-7283-ac56-2bd722219019","parentId":null,"rootId":null,"fromId":3754,"content":"我在朝阳东3、4环，房租1400，押一付一。莫不要听在济南谈论北京的那些人的，什么挣得多花的多=  =净扯淡","createdAt":"2024-03-12T14:02:37"},{"id":"01963dec-84bb-71cf-8217-73a891d60e58","parentId":null,"rootId":null,"fromId":3754,"content":"具体能挣多少钱，这个我不做评价，因为每个人水平不一样","createdAt":"2024-03-12T14:03:29"},{"id":"01963dec-84bf-72e0-8fe8-1269f2787e3b","parentId":null,"rootId":null,"fromId":2551,"content":"房租这个主要看你要在哪住了，很外环的也不是太贵的，租个单间甚至比济南还低，但是通勤时间可能就有点久了","createdAt":"2024-03-12T14:25:27"},{"id":"01963dec-84c4-713f-a58a-eff87436d918","parentId":null,"rootId":null,"fromId":3754,"content":"之前在5环左右住的单间是850一个月，独立厨卫，但是距离现在的工作地点有点远就换了，现在出门到地铁10分钟，地铁20分钟，地铁到公司十分钟，我觉得还行","createdAt":"2024-03-12T14:35:19"},{"id":"01963dec-84cc-7029-965e-2f7103239365","parentId":null,"rootId":null,"fromId":5410,"content":"专在北京更不好找","createdAt":"2024-03-12T15:27:54"},{"id":"01963dec-84c8-7324-b84a-4cbcdd37c34b","parentId":null,"rootId":null,"fromId":6039,"content":"我之前同事租房在立水桥那边小两居，一个月7000千，现在买房了","createdAt":"2024-03-12T15:31:22"},{"id":"01963dec-8512-7036-abce-99f08967a231","parentId":null,"rootId":null,"fromId":5987,"content":"其实别的都没啥，房租生活成本，吃饭啥的都不重要，主要是专科在北京现在不一定能找到工作了，大厂肯定不招人，一些大厂的外包都不要专科了。建议你远程面试过了再考虑去不去吧","createdAt":"2024-03-12T15:46:39"},{"id":"01963dec-8557-7275-b416-e34e67fcc30e","parentId":null,"rootId":null,"fromId":3754,"content":"这个说的实在，我普本，12月份远程面试了一个周才上岸","createdAt":"2024-03-12T16:12:40"},{"id":"01963dec-855d-703d-bbfa-979eb92eeae2","parentId":null,"rootId":null,"fromId":1049,"content":"好多在济南面试3个月了还没上岸[doge]","createdAt":"2024-03-12T16:27:30"},{"id":"01963dec-8561-735c-a655-5e87ea81552a","parentId":null,"rootId":null,"fromId":6915,"content":"我就在北京，现在外包几乎都是统本了","createdAt":"2024-03-12T16:32:55"},{"id":"01963dec-842f-7218-bfb6-6afe647e9b6d","parentId":null,"rootId":null,"fromId":7746,"content":"细说叫","createdAt":"2024-08-06T10:15:59"}]