[{"id":"01963df6-3b11-7287-9574-eb553f0979bd","parentId":null,"rootId":null,"fromId":22256,"content":"绩效说扣就扣了，带绩效的公司都是sb","createdAt":"2025-01-09T15:03:57"},{"id":"01963df6-3b56-71ab-926e-98f09b407e09","parentId":null,"rootId":null,"fromId":7251,"content":"和我说大小休，我一问加班多吗立马就不回了。","createdAt":"2025-01-09T17:04:36"},{"id":"01963df6-3b9b-7218-a891-86526f353405","parentId":null,"rootId":null,"fromId":267,"content":"不到万不得已 不去","createdAt":"2025-01-09T22:48:01"},{"id":"01963df6-3bdf-7378-b0f8-a97027fc2f4f","parentId":null,"rootId":null,"fromId":875,"content":"绩效高就是打算扣你钱的","createdAt":"2025-01-10T06:55:57"},{"id":"01963df6-3c24-7094-b367-a3a2e0d70889","parentId":null,"rootId":null,"fromId":1591,"content":"我一个同事24年待过三个月，项目进度慢，全体项目成员只发3000元基本工资，连续发了两个月，第三个月项目组的人都走了。我那个同事去了北京尚德通软科技有限公司在经二路客户的项目组，半年多没发工资了，也挺惨，仲裁还得去北京，大家注意吧。","createdAt":"2025-01-13T15:56:51"},{"id":"01963df6-3c69-737e-aa14-6be35fa7f934","parentId":null,"rootId":null,"fromId":22726,"content":"是吗，你说的我都不敢去了","createdAt":"2025-02-13T14:36:48"},{"id":"01963df6-3c6e-7153-8d12-00099826da60","parentId":null,"rootId":null,"fromId":22726,"content":"新知地济南项目 不能正常发工资吗","createdAt":"2025-02-13T14:43:07"},{"id":"01963df6-3c72-728e-a709-f7671a34e207","parentId":null,"rootId":null,"fromId":22831,"content":"跟评论里讲的差不多，办公地点刚搬到舜泰广场，北京的公司，在济南只是项目组，实习期6个月80%工资，大小周，工资底薪加绩效组成","createdAt":"2025-02-26T17:27:31"},{"id":"01963df6-3cbb-7326-9385-4a685e63a472","parentId":null,"rootId":null,"fromId":22966,"content":"有在职的吗？能说一下公司什么情况吗?","createdAt":"2025-03-18T09:40:22"},{"id":"01963df6-3cb6-716a-8c87-06197f229fc9","parentId":null,"rootId":null,"fromId":22966,"content":"工资按时发吗？领导怎么样","createdAt":"2025-03-18T09:41:15"},{"id":"01963df6-3cfe-71db-8073-b133f3e121a3","parentId":null,"rootId":null,"fromId":22726,"content":"你入职这家了吗","createdAt":"2025-03-22T22:14:23"},{"id":"01963df6-3d03-7030-ba32-c8382e59398b","parentId":null,"rootId":null,"fromId":22726,"content":"如果你能忍受领导的辱骂你就来吧！","createdAt":"2025-03-23T18:12:51"}]