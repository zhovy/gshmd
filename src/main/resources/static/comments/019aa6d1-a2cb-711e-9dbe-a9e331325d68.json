[{"id":"019aa6f2-37c7-72f2-9b4c-6b70f209b721","parentId":null,"rootId":null,"fromId":22352,"content":"行情好起来了","createdAt":"2025-11-21T23:04:43"},{"id":"019aa75c-3507-7062-b5ce-ad91db52343c","parentId":null,"rootId":null,"fromId":27800,"content":"？？？","createdAt":"2025-11-22T01:00:29"},{"id":"019aa8c8-60b6-73ad-b367-ae935b8f0739","parentId":null,"rootId":null,"fromId":875,"content":"降多少？降30%以内还可以接受，先猫着，现在公司也不容易，不好找","createdAt":"2025-11-22T07:38:15"},{"id":"019aa92c-bd4c-7310-9287-8b091be4f848","parentId":null,"rootId":null,"fromId":455,"content":"这位仁兄，咋分析出来的行情好起来了？我真没感觉","createdAt":"2025-11-22T09:27:52"},{"id":"019aa981-09cd-7328-86ad-cc633511e50e","parentId":null,"rootId":null,"fromId":1049,"content":"降薪只是第一步，后面会在你头上拉屎","createdAt":"2025-11-22T10:59:57"},{"id":"019aa996-544c-716b-bdef-c08c2df29c18","parentId":null,"rootId":null,"fromId":24162,"content":"没错只有一次和无数次","createdAt":"2025-11-22T11:23:12"},{"id":"019aaac7-fc90-703b-8a8a-a16159ba524f","parentId":null,"rootId":null,"fromId":3345,"content":"建议拒绝降薪，不开除你的话，就等发工资，钱少了就走被迫离职","createdAt":"2025-11-22T16:57:04"},{"id":"019aabfd-27ad-710c-8bc4-eb072f84cb69","parentId":null,"rootId":null,"fromId":3450,"content":"你别叫唤了，好在哪，我找工作找1年多了","createdAt":"2025-11-22T22:34:46"},{"id":"019aae8b-e125-70c0-9ea6-16b22acb0f15","parentId":null,"rootId":null,"fromId":24615,"content":"我都裁员降薪一年了，你们才降薪啊","createdAt":"2025-11-23T10:29:54"},{"id":"019aaef2-70b5-7245-ac3f-14f18ca25f5a","parentId":null,"rootId":null,"fromId":22316,"content":"准备跟公司死磕到底了","createdAt":"2025-11-23T12:21:55"},{"id":"019aaf80-fed8-73fb-9c9d-d19550a0867d","parentId":null,"rootId":null,"fromId":25236,"content":"哥们真准呀！30%  服了！","createdAt":"2025-11-23T14:57:38"},{"id":"019aaf81-80cb-72be-939b-49c830c485d9","parentId":null,"rootId":null,"fromId":25236,"content":"该来的终究还是来了","createdAt":"2025-11-23T14:58:11"},{"id":"019ab046-45c3-70e8-97b5-5eeec29a2850","parentId":null,"rootId":null,"fromId":2115,"content":"公司名字发下","createdAt":"2025-11-23T18:33:06"},{"id":"019ab300-c8d4-71d3-a73b-9953fa6c29ce","parentId":null,"rootId":null,"fromId":22695,"content":"没有用，先不说现在各个区的劳动仲裁都忙成什么鬼样子了，你就算是提仲裁至少半年后才能仲裁，劳动法是劳动法，劳动仲裁未必能支持你，但凡公司甩出来一份他们自己编写的公司制度，随便指一条出来说你复合上面的降薪规定，你就要不回来这笔钱。讲真，赶紧找别的活，找不到就苟着，总比到头来啥也没有强","createdAt":"2025-11-24T07:16:04"},{"id":"019ab4ab-8cf5-72ce-b9d1-60fc55deb364","parentId":null,"rootId":null,"fromId":3263,"content":"30%这么多都要接受吗？幅度太大了吧","createdAt":"2025-11-24T15:02:12"},{"id":"019ab4f2-73a3-730d-a3bb-1558363c8a4f","parentId":null,"rootId":null,"fromId":24162,"content":"第一：公司制度是需要公示，告知过才算数，编的肯定不行，即便不是编的，只要没告知没公示，员工完全不知道也可以不用管。第二：劳动仲裁受理后通常两个月左右基本就出结果  出不了的直接可以走法律程序。第三：仲裁是给一个商议的平台并不是说仲裁庭出的结果你一定要接受，差距太大 可以不接受然后走法庭 。“各个区的劳动仲裁都忙成什么鬼样子了” 这个确实是。如果没有出来能找到合适的工作信心， 个人建议还是骑驴找马。如果金额过小可以采取其他合法手段，如果确实需要走相关程序，建议保全材料准备战斗。走一次程序你就知道没那么复杂，前提是证据链完整。正好趁着还没离职 ，保留下证据，打卡记录等留痕，如果走被迫离职 更简单，搞一份被迫离职通知书，通知公司几号之前完成交接自动离职，几号结清你的欠薪+赔偿，过程做到合理，合法。普通人知道劳动法，但是不清楚劳动法的具体保护的内容（可以针对自己的情况去看一下劳动法，没有很多内容），其实劳动法还是有用的。前提是你的证据链完整，无过错。除非公司倒闭偿还不起，其他的就按法律来。自己实在不了解，建议打12348 免费的法律咨询电话，咨询自己的情况该怎么处理。\n方式：仲裁\n申请地点：《仲裁庭》    免费\n方式    法庭\n申请方式：《申请法律援助》 符合条件免费","createdAt":"2025-11-24T16:19:39"},{"id":"019ab4f4-4033-731b-b335-c2b00953be11","parentId":null,"rootId":null,"fromId":24162,"content":"看看我下面发的 ，希望对你有用","createdAt":"2025-11-24T16:21:37"}]