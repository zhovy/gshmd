[{"id":"01963df2-9778-73f0-bfce-ca5efb9dd6c5","parentId":null,"rootId":null,"fromId":1733,"content":"房子跟人一样，也会生病，也得需要养老。房子不单单是房子，更是老百姓的家。","createdAt":"2024-08-26T10:47:32"},{"id":"01963df2-97c0-720e-84e6-e5746fe115cd","parentId":null,"rootId":null,"fromId":1372,"content":"房地产这种阳谋都看不明白，被收割不冤枉。","createdAt":"2024-08-26T11:14:23"},{"id":"01963df2-9809-72ce-a38f-2099352a1028","parentId":null,"rootId":null,"fromId":2393,"content":"济南三大sb：牛子、阳光、灰太狼","createdAt":"2024-08-26T11:23:05"},{"id":"01963df2-9805-73e7-8315-768763177574","parentId":null,"rootId":null,"fromId":130,"content":"要知道买一套就拉倒了","createdAt":"2024-08-26T11:28:55"},{"id":"01963df2-984b-733f-a127-5e7456f358c7","parentId":null,"rootId":null,"fromId":2408,"content":"谁交谁煞笔","createdAt":"2024-08-26T12:16:11"},{"id":"01963df2-988e-72fd-b404-4605d4af826f","parentId":null,"rootId":null,"fromId":6334,"content":"以后得交五险二金了（手动狗头）","createdAt":"2024-08-26T14:35:05"},{"id":"01963df2-98d7-7299-8496-44b6d85d915f","parentId":null,"rootId":null,"fromId":875,"content":"济南两套房的人不少","createdAt":"2024-08-26T18:51:22"},{"id":"01963df2-9926-7201-bef5-8c92738fbd46","parentId":null,"rootId":null,"fromId":875,"content":"交了养老金，不用交房产税了吧","createdAt":"2024-08-26T19:02:22"},{"id":"01963df2-996d-70ab-af65-c41bf79eb338","parentId":null,"rootId":null,"fromId":4140,"content":"养老金的目的是转移矛盾，一、让你持有老破小的成本越来越高，你不交房屋养老金，给你房子评一个D级，不给你贷款，卖房子的时候逼你把养老金补全才能卖，逼着你降价，zf好低价收购，作为公租房。二、提高租售比，现在房租收益低，zf想搞公租房，但是没有资本看中这块市场，所以增加了房屋养老金让房东持有成本提高，最终还是租房的人买单，最终目的就是提高房租，同时打压老破小房价，把zf和租客的矛盾转移为房东和租客的矛盾，zf当老好人提供比房东便宜的房子出租，增加zf好感度。三、对于有买房需求的人，倒逼你买新的高品质商品房（利率低、容积率低、品质高、不用交房屋养老金），打压二手房交易（房屋养老金、契税、打压市场信心没有流通），二手房交易zf基本上没有收入，只有新房能够快速卖光，卖地才好卖，zf才有钱去搞公租房，至此闭环，国家早就给你答案了。","createdAt":"2024-08-27T09:32:31"},{"id":"01963df2-9969-723b-bef4-10faf12973bc","parentId":null,"rootId":null,"fromId":1376,"content":"你想的怪美，养老金是给你房子养老，房产税是地方财政开源，这俩不冲突","createdAt":"2024-08-28T09:16:12"}]