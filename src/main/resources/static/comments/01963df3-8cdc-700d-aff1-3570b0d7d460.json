[{"id":"01963df3-8d40-73e1-9564-1a511f43127f","parentId":null,"rootId":null,"fromId":21493,"content":"是不是有很多假装开发公司实际贷款培训的","createdAt":"2024-10-09T10:57:15"},{"id":"01963df3-8d84-7116-9f54-be794ae14ee0","parentId":null,"rootId":null,"fromId":7074,"content":"小额贷款公司很多，更有甚者，天天早上唱歌喊口号，有种进了传销窝的感觉","createdAt":"2024-10-09T10:58:29"},{"id":"01963df3-8d89-7111-bd39-ff722a57bc0b","parentId":null,"rootId":null,"fromId":7074,"content":"有的楼办公环境很差，楼道烟民多，弄得浑身都是烟味；厕所下水道堵过几次，往外喷屎的那种，有的电梯据说往下坠过，索性没有伤到人。","createdAt":"2024-10-09T11:00:43"},{"id":"01963df3-8d8d-70da-adb8-a24cad8cb6a3","parentId":null,"rootId":null,"fromId":21493,"content":"我在智联上投递的公司和微信联系我的没有一样的，感觉像是遇到骗子了","createdAt":"2024-10-09T11:02:42"},{"id":"01963df3-8dd3-70fa-8dd6-22fbfe421da7","parentId":null,"rootId":null,"fromId":21493,"content":"这算是信息泄露吗，从智联招聘上泄露了联系方式，boss直聘就不会","createdAt":"2024-10-09T11:03:44"},{"id":"01963df3-8e18-72af-8ea0-b095b9d08d6c","parentId":null,"rootId":null,"fromId":3341,"content":"看标题就知道是应届菜鸟，舜泰广场十来栋楼 你问的这个问题你不觉得太扯犊子了嘛。。。重点不突出 问了跟没问一样。\n直接说公司名 注意转培就行了。你这种最容易上转培的当","createdAt":"2024-10-09T13:41:04"},{"id":"01963df3-8e61-7033-a6d5-587132d9c991","parentId":null,"rootId":null,"fromId":578,"content":"有这种约面的可以直接在这里搜公司名找找看或者发出来问问","createdAt":"2024-10-09T13:49:44"},{"id":"01963df3-8eaa-71bd-aecb-c235d095a39c","parentId":null,"rootId":null,"fromId":21973,"content":"入职先让你培训的公司基本都不靠谱","createdAt":"2024-10-09T14:33:26"},{"id":"01963df3-8e5c-7070-ba18-02accd737c6d","parentId":null,"rootId":null,"fromId":21493,"content":"先培训2-3个月，发4000块，然后实习4000多，但是要扣培训费1200每月，扣一年，算吗","createdAt":"2024-10-09T14:53:00"},{"id":"01963df3-8eef-72a5-ad01-29e353b48b38","parentId":null,"rootId":null,"fromId":21493,"content":"公司名称都对不上，微信联系我的和面试我的说的不一样，还说是分公司","createdAt":"2024-10-09T14:53:39"},{"id":"01963df3-8f37-725c-9455-158d4b11c84a","parentId":null,"rootId":null,"fromId":21493,"content":"感觉我的垃圾简历只能招来骗子","createdAt":"2024-10-09T14:56:04"},{"id":"01963df3-8f7b-7164-93f8-f7a7363a505a","parentId":null,"rootId":null,"fromId":21493,"content":"学又学不下去","createdAt":"2024-10-09T14:56:22"},{"id":"01963df3-8f80-72c8-b62d-725445a15650","parentId":null,"rootId":null,"fromId":1376,"content":"千万不要去，他给你贷款","createdAt":"2024-10-09T16:39:40"},{"id":"01963df3-8fc5-7242-94db-2d9f41f13077","parentId":null,"rootId":null,"fromId":21493,"content":"大学生能贷款吗","createdAt":"2024-10-09T17:19:48"},{"id":"01963df3-8fca-71b8-a8a6-fb04fff1cea5","parentId":null,"rootId":null,"fromId":3705,"content":"舜泰算了吧，里面的厕所就跟网吧的厕所似的，脏乱差","createdAt":"2024-10-10T16:21:14"},{"id":"01963df3-8f33-739d-a42b-cfce96773a13","parentId":null,"rootId":null,"fromId":23046,"content":"是这样的","createdAt":"2025-03-28T11:54:17"}]