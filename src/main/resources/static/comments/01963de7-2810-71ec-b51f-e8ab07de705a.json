[{"id":"01963de7-2880-7056-b431-d57fc8596a14","parentId":null,"rootId":null,"fromId":5518,"content":"以前去面试过一次，情况差不多。那个面试官一上来就炫耀自己部门的制度，说连敲代码都要按照文档流程走。多么正式多么厉害。一顿操作猛如虎 一问工资三千八。 后来听说 好几个月没发工资了，招聘也是招着玩","createdAt":"2023-08-30T09:14:31"},{"id":"01963de7-28c9-71e7-9ab9-ea7d1d51f007","parentId":null,"rootId":null,"fromId":1398,"content":"6年要8k，我两年的要多少比较合适？","createdAt":"2023-08-30T11:48:59"},{"id":"01963de7-290b-711c-ba71-6bb71d5d6413","parentId":null,"rootId":null,"fromId":629,"content":"2k","createdAt":"2023-08-31T10:47:23"},{"id":"01963de7-2914-728c-bc13-1b73ff3594bd","parentId":null,"rootId":null,"fromId":3851,"content":"您好老哥 我也要去面试了 感觉环境咋样 ","createdAt":"2023-08-31T10:49:33"},{"id":"01963de7-296c-711c-a846-6e3e8cd568da","parentId":null,"rootId":null,"fromId":5517,"content":"一般，一个吃考核的公司，完成不了扣钱，祝你好运","createdAt":"2023-08-31T11:04:19"},{"id":"01963de7-2910-707f-b4d4-5b3c634f512c","parentId":null,"rootId":null,"fromId":5517,"content":"根据自己情况来，我6年其实会的东西不多，你是大神就往高了要，反正今年大环境不好","createdAt":"2023-08-31T11:06:11"},{"id":"01963de7-2971-71d3-8aa0-bb50ea8c4d0f","parentId":null,"rootId":null,"fromId":3851,"content":"谢谢老哥 ","createdAt":"2023-08-31T14:39:37"},{"id":"01963de7-298a-7235-94fe-149d0c88231d","parentId":null,"rootId":null,"fromId":5534,"content":"白毛说的没错，毕竟写代码左右多个空格都要算你一个bug，bug和个人绩效是挂钩的，怎么不算严格呢？(狗头)。每天都必须加班，不加班就会被点名约谈，忙的时候让你干到半夜也很正常，因为这家的领导大部分都比较乐于跟客户吹牛，然后底下的人只能拼命干活。涨不涨工资除了看你加班干的活，最重要的还要取决于其他同事年底考核给你打的分，多么优秀的考核制度！说不完啊说不完。。。","createdAt":"2023-08-31T16:16:09"},{"id":"01963de7-2975-727d-923e-e1d40f0c19fe","parentId":null,"rootId":null,"fromId":5534,"content":"楼主如果是男生，不建议去，这家公司学不到什么，适合女的养老","createdAt":"2023-08-31T16:22:30"},{"id":"01963de7-29d5-731d-974d-fe93367e0351","parentId":null,"rootId":null,"fromId":3851,"content":"老哥是公司出来的吗 可以细说吗","createdAt":"2023-08-31T16:43:02"},{"id":"01963de7-2979-7019-8ed3-10d53a498b9d","parentId":null,"rootId":null,"fromId":3851,"content":"老哥是公司出来的吗 可以细说吗 dd","createdAt":"2023-08-31T16:46:18"},{"id":"01963de7-297e-73b3-bca8-6371499170e2","parentId":null,"rootId":null,"fromId":5534,"content":"规范制度多 事多 加班多 女的多\n如果是刚毕业的，可以进这家学习下代码规范，规范到你想吐，要学技术就不要考虑来这了","createdAt":"2023-08-31T18:06:23"},{"id":"01963de7-2982-7217-886c-f3cabb4db551","parentId":null,"rootId":null,"fromId":3851,"content":"收到 谢谢老哥 我工作三年了给的8感觉是不是有点事多 我再考虑考虑 ","createdAt":"2023-09-01T10:51:08"},{"id":"01963de7-2986-7290-942e-8e0eeaf553d6","parentId":null,"rootId":null,"fromId":5534,"content":"三年经验给你8确实不少，这家干了10来年的也就1个达不溜","createdAt":"2023-09-01T12:27:38"},{"id":"01963de7-29d9-736c-b8ef-9ece2ba56974","parentId":null,"rootId":null,"fromId":1492,"content":"代码有规范制度是好，但这也太苛刻了，多个空格就算bug，罚款罚疯了。还有那bug也算绩效？谁能写个没有bug的程序，微软这么多年还一直打补丁呢","createdAt":"2023-09-01T13:37:06"},{"id":"01963de7-28c4-7071-938c-095f33dcb01e","parentId":null,"rootId":null,"fromId":4099,"content":"垃圾的要死，真不知道哪来的优越感，狗屁不是的公司，没去的建议避坑","createdAt":"2023-09-28T22:18:47"},{"id":"01963de7-29dd-7034-9659-c8bfb3b8d5e5","parentId":null,"rootId":null,"fromId":4099,"content":"人员一直减少，天天加班，基本不找公司，垃圾的不要不要的，建议避坑！！","createdAt":"2023-09-28T22:20:10"},{"id":"01963de7-2a22-7096-a9a5-762907af1727","parentId":null,"rootId":null,"fromId":22615,"content":"之前在这个公司上了半个月，我是4年工作经验8.5k，面试倒是没啥难的，他问的那底层结构问题纯弱智问题，然后面试到最后问我有啥问公司的吗，我就详细的问了一下公司结构，还有项目框架，还问了一下他底层的东西，那男的支支吾吾的也说不出来，找了个女的小组负责人过来也没说明白啥，倒是不拖欠工资，上班时间很压抑，分给我的那个小组经理就是当时面试后来的女的，人很好，很好说话。每天中午午休结束后还唱歌，我滴妈给我尴尬死了要。而且用的项目框架也巨老！！！还用fromwork那套老玩意。加班也很严重，明明大家都没事干，就是拖到七八点，上班时间把活干完就走就得了呗，我不惯着他到点就走","createdAt":"2025-01-15T18:11:27"},{"id":"0199f60d-2ec9-704b-b273-5125a4ed3003","parentId":null,"rootId":null,"fromId":23810,"content":"来了就是加班到死，唯小人与女子难养也","createdAt":"2025-10-18T14:41:23"}]