3:27"},{"id":"01963df7-3b84-7229-9aca-324b53ae66ef","parentId":null,"rootId":null,"fromId":1398,"content":"不会是 zh 吧","createdAt":"2025-02-25T10:07:46"},{"id":"01963df7-3bc8-7301-99aa-1544b6b406bf","parentId":null,"rootId":null,"fromId":4140,"content":"毕业前几年，钱不是最重要的，多跳槽混行业经验，比如电网、医疗、政府等等方向都混个熟，真正把公司架构都了解清楚，学这些的目的是为了让你面试的时候跟别人拉开差距，这才是程序员真正的壁垒，千万不要温水煮青蛙，哪怕国企很舒服，你在里面慢慢熬着拿着6、7千，真的熬到35啥也不会那才是废了","createdAt":"2025-02-25T10:08:46"},{"id":"01963df7-3b73-73d1-8479-c1330b8e4056","parentId":null,"rootId":null,"fromId":1401,"content":"HG应该是瀚高吧","createdAt":"2025-02-25T10:33:26"},{"id":"01963df7-3b77-711b-a807-0cf50bcea9f7","parentId":null,"rootId":null,"fromId":5725,"content":"我觉得是瀚高","createdAt":"2025-02-25T10:51:00"},{"id":"01963df7-3ad7-72a2-8d78-52a54845aed8","parentId":null,"rootId":null,"fromId":5725,"content":"那还是苟住吧","createdAt":"2025-02-25T10:51:23"},{"id":"01963df7-3b7b-712f-9e2e-438b1c70060a","parentId":null,"rootId":null,"fromId":22024,"content":"瀚高稳定吗？","createdAt":"2025-02-25T10:58:13"},{"id":"01963df7-3adb-728b-8db3-360dfee251c9","parentId":null,"rootId":null,"fromId":22542,"content":"怎么说   没结婚不是更自由一点","createdAt":"2025-02-25T10:59:38"},{"id":"01963df7-3b80-73e4-8b45-2838b68b55c4","parentId":null,"rootId":null,"fromId":22542,"content":"瀚高没了解过，不在瀚高","createdAt":"2025-02-25T11:00:03"},{"id":"01963df7-3814-71c7-a35e-5ae7b3abc85b","parentId":null,"rootId":null,"fromId":22542,"content":"是的，浪费了好几年，也不知道我都干了啥，虚度光阴了","createdAt":"2025-02-25T11:05:36"},{"id":"01963df7-3c0e-7380-bfa6-80c4f21ccd4a","parentId":null,"rootId":null,"fromId":875,"content":"北京杭州深圳程序员每天都活在股市大涨的恐惧中，年前持有的期权还是10万，现在变成50万了，冲呀，这几天写代码这几天越来越有劲了","createdAt":"2025-02-25T12:25:59"},{"id":"01963df7-3c52-7163-a8a8-b2694dbe47ad","parentId":null,"rootId":null,"fromId":22542,"content":"这么优秀吗哥","createdAt":"2025-02-25T14:06:03"},{"id":"01963df7-3c5b-71bd-ae2a-88ddc066a71f","parentId":null,"rootId":null,"fromId":1398,"content":"你找到了没","createdAt":"2025-02-26T09:12:35"},{"id":"01963df7-3ca0-70a3-be15-7ceb08ec398a","