[{"id":"01963df6-a23d-7309-a73b-a5c8d3d90026","parentId":null,"rootId":null,"fromId":875,"content":"deepseek一夜掀翻美国科技股，看看人家干的多漂亮，济南最厉害的软件公司在哪里干什么？","createdAt":"2025-01-27T21:45:52"},{"id":"01963df6-a282-704d-98d9-8b42fc5b1f7b","parentId":null,"rootId":null,"fromId":875,"content":"深度求索，杭州的一个公司，牛逼","createdAt":"2025-01-27T23:02:39"},{"id":"01963df6-a288-7246-9937-f3fca31414da","parentId":null,"rootId":null,"fromId":2408,"content":"让子弹飞一会儿","createdAt":"2025-01-28T21:18:14"},{"id":"01963df6-a2cd-7106-8eb3-4c741e9b140b","parentId":null,"rootId":null,"fromId":875,"content":"deepseek招的都是刚毕业一两年的，经验不重要，代码开源，所以说程序员的护城河是什么？只有股权","createdAt":"2025-01-29T01:34:38"},{"id":"01963df6-a313-724c-8b9b-2fe447467893","parentId":null,"rootId":null,"fromId":5471,"content":"4个人的公司开发出划时代的产品，反正我是不信","createdAt":"2025-01-31T14:02:10"},{"id":"01963df6-a358-71f1-8db7-a1373ba4e089","parentId":null,"rootId":null,"fromId":5471,"content":"又一个“姜萍”","createdAt":"2025-01-31T14:02:23"},{"id":"01963df6-a35e-7235-9a05-f8b24c294257","parentId":null,"rootId":null,"fromId":1372,"content":"说实话，感觉deepseek跨越太大了，让人觉得不真实。不了解，不评论，尊重事实。","createdAt":"2025-01-31T18:12:12"},{"id":"01963df6-a3a3-7337-9c7f-597f869b078e","parentId":null,"rootId":null,"fromId":6082,"content":"盗窃openai的数据，利用蒸馏技术训练出来的大模型，说白了就是偷来的，你要拭目以待什么？","createdAt":"2025-02-02T14:46:15"},{"id":"01963df6-a3ec-700a-a16d-93697783b6c0","parentId":null,"rootId":null,"fromId":875,"content":"月薪八千的人说人家月薪八万的程序员抄袭，可不能张嘴就来啊","createdAt":"2025-02-02T21:49:05"},{"id":"01963df6-a3f6-7107-801c-c7c4408d926f","parentId":null,"rootId":null,"fromId":875,"content":"纳斯达克指数看到一万七千点","createdAt":"2025-02-03T22:41:55"},{"id":"01963df6-a3f1-70f9-9918-4b6ffe370b1b","parentId":null,"rootId":null,"fromId":6082,"content":"是啊，就像你一样，抬扛可不张嘴就来啊","createdAt":"2025-02-04T12:37:51"},{"id":"01963df6-a43b-7370-83e5-bbbc1be78af9","parentId":null,"rootId":null,"fromId":21559,"content":"我试了下，确实非常好用。在我用过的几个大模型中，deepseek 给出的回答是准确率最高、干货最多的，就是还不够稳定，经常会服务器繁忙。","createdAt":"2025-02-04T18:08:06"},{"id":"01963df6-a483-7038-b2b7-5dcecdcd9897","parentId":null,"rootId":null,"fromId":875,"content":"2月6日登陆DeepSeek开放平台发现DeepSeek已暂停API服务充值，按钮显示灰色不可用状态。对此官方声明称，“当前服务器资源紧张，为避免对您造成业务影响，我们已暂停 API 服务充值。存量充值金额可继续调用，敬请谅解！”官方价目表显示，deepseek-chat 模型优惠期至北京时间2025年2月8日24:00，优惠结束后将按每百万输入 tokens 2 元，每百万输出 tokens 8 元计费。deepseek-reasoner 模型上线即按每百万输入 tokens 4 元，每百万输出 tokens 16 元计费。","createdAt":"2025-02-06T19:53:54"},{"id":"01963df6-a47e-70df-ab5e-4bbaa3c86800","parentId":null,"rootId":null,"fromId":297,"content":"一点也不好用，问它要个黄色网址都不给?","createdAt":"2025-02-07T08:12:41"}]