[{"id":"01963df0-be57-73a6-bdda-d4f7494e0fd6","parentId":null,"rootId":null,"fromId":1216,"content":"北大荒还不错，老品牌的实体企业，也有在做绿色有机。必普在高新区口碑不大好，据说是专骗合作伙伴哈哈哈哈","createdAt":"2024-06-16T10:40:22"},{"id":"01963df0-be9c-7193-8350-272b9d37ae02","parentId":null,"rootId":null,"fromId":1368,"content":"必普不要去，垃圾公司，专坑加盟商的，内部很乱，不是正规公司，去了估计就是让你拓展客户，谈加盟商；\n北大荒也不要去，门店运营模式，虽然有自己的会员基数，但是类似买保健品的，去了就废了；\n其他公司不了解。\n虽然实习，但建议转行。","createdAt":"2024-06-17T08:40:02"},{"id":"01963df0-bee3-73be-a843-c9251fe7730c","parentId":null,"rootId":null,"fromId":7226,"content":"必普不行","createdAt":"2024-06-19T08:34:08"}]