[{"id":"0197b412-9a36-70f6-81be-d8d26d332354","parentId":null,"rootId":null,"fromId":22825,"content":"不要听网上的瞎说，该公司领导为人亲善，尤其那个头发少少的(秃顶)很有亲和力，从来不搞针对，体贴下属，对女同事特别好。\n从来不加班\n双休(从来不占用你的周末)\n福利待遇好\n在里面的员工都是幸福满满\n欢迎你的加入","createdAt":"2025-06-28T09:06:47"},{"id":"0197b41f-695e-72a5-872b-7eaee866c2d6","parentId":null,"rootId":null,"fromId":24145,"content":"去试试吧 小马过河不是。。毕竟西边就没几个公司 离家近毕竟是个优点 离家近事少钱多 满足一两项不就行了","createdAt":"2025-06-28T09:20:46"},{"id":"0197bb18-f15f-70be-9fe6-4c961766145c","parentId":null,"rootId":null,"fromId":22825,"content":"你去过吗，你觉得怎么样","createdAt":"2025-06-29T17:51:03"},{"id":"0197bb25-4e87-73b2-a017-32d9789b671a","parentId":null,"rootId":null,"fromId":24145,"content":"没有","createdAt":"2025-06-29T18:04:33"},{"id":"0197be62-5a7a-72ff-82ca-563366ad78be","parentId":null,"rootId":null,"fromId":557,"content":"我是这家公司的老员工了。这家公司总部在北京。刚成立济南分公司的时候，我就辞职跑路了。因为老板想让我来济南。当时济南分公司的小伙伴，天天11点12点下班，加班比北京996都严重。老板呢，特别擅长pua。工资什么的比较抠门。去了这家公司基本上就相当于卖身了，见不到白天的太阳，只有无穷无尽的压榨剥削。","createdAt":"2025-06-30T09:10:06"},{"id":"0197bf21-20dd-7085-85ef-e53fe41f92ec","parentId":null,"rootId":null,"fromId":22825,"content":"6，兄弟你是真敢说啊","createdAt":"2025-06-30T12:38:28"},{"id":"0197c9f0-15d3-73aa-a479-9b81e374cd36","parentId":null,"rootId":null,"fromId":557,"content":"在分享一件事吧。有一次公司组织团建，去外面玩漂流。当时是周三周四两天去的。后来老板，要求接下来的两个周，周末加班，把这两天补回来。好笑不，在996，原本周六就上班的情况下，周日上班补回来。哈哈。","createdAt":"2025-07-02T15:00:44"},{"id":"0197d29b-baf6-703f-9974-2a9c40b0a695","parentId":null,"rootId":null,"fromId":22825,"content":"这公司怎么看也不能去啊，除了领导，里面其他负责人咋样","createdAt":"2025-07-04T07:25:10"},{"id":"0197d2e6-7173-716b-aee5-02e2d12ffcb7","parentId":null,"rootId":null,"fromId":557,"content":"pua你。辱骂你。","createdAt":"2025-07-04T08:46:47"},{"id":"0197d44b-66de-7202-a08e-2c50f4c688b1","parentId":null,"rootId":null,"fromId":22825,"content":"那个领导啊，这么狠，晚上睡觉不得睁一只眼","createdAt":"2025-07-04T15:16:40"},{"id":"0198c683-f276-71a5-acc4-7c3cc0b6ba1e","parentId":null,"rootId":null,"fromId":4016,"content":"这领导在boss上当时还说项目经理给2万多工资，我都没信，真拿两万不累死","createdAt":"2025-08-20T16:06:32"}]