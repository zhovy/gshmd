[{"id":"01963ddb-19c2-7280-9acf-7e07fff001a6","parentId":null,"rootId":null,"fromId":193,"content":"1","createdAt":"2022-07-24T10:50:51"},{"id":"01963ddb-1a07-7317-92ce-28649337980b","parentId":null,"rootId":null,"fromId":193,"content":"搜索UU乐跑腿小程序也能看了","createdAt":"2022-07-24T18:22:56"},{"id":"01963ddb-1a4b-7258-a42b-42f0550fda23","parentId":null,"rootId":null,"fromId":597,"content":"双色工装可太牛了","createdAt":"2022-07-25T09:09:47"},{"id":"01963ddb-1a94-7039-933c-df467e785ed1","parentId":null,"rootId":null,"fromId":1095,"content":"让员工买股份，强制绑定\n鸡汤一套又一套，把员工当傻子","createdAt":"2022-07-25T15:00:41"},{"id":"01963ddb-1ada-708a-b4a6-6ffdef3160ff","parentId":null,"rootId":null,"fromId":180,"content":"试用期不交五险一金, 入职期间, 不签劳动合同, 不打卡(让你不好仲裁！)\n\n找证据，仲裁。双倍工资啊，发啦","createdAt":"2022-07-28T14:43:03"},{"id":"01963ddb-1b20-70d6-82e6-ea50ad6052b9","parentId":null,"rootId":null,"fromId":1169,"content":"每天下班之后加班到八点以后，没有加班费","createdAt":"2022-07-29T21:07:18"},{"id":"01963ddb-1b64-72ab-84c8-7c16aadc1569","parentId":null,"rootId":null,"fromId":1195,"content":"有幸在这个公司做了1个月的行政前台  别的不说 我还没有赚到钱 就开始说我的着装不够正规，而且还PUA楼下的工装  人家是公司统一规定的采购的  这能比嘛？动不动就指定目标  动不动就沙龙演讲 （都是下班时间 不下班不演讲）老板是讲股权机制 （就是忽悠你 说只要你好好干 就给你股权，年底分红）早晨每天八点必读企业文化（很可怕，每天必须保持自己很上进要不扣分）最后说一下公司夫妻合伙开公司  人力资源是老板媳妇的妹妹  技术总监是亲戚 一个月说开3800就给了我2500左右 各种扣钱","createdAt":"2022-08-02T15:34:14"},{"id":"01963ddb-1ba9-728d-8a54-277b599e41dc","parentId":null,"rootId":null,"fromId":1390,"content":"加班加班天天加班 没有加班费！工装自己出钱买，不买不行！这么热的天不舍得开空调！桌上有蟑螂！！！每天一早喊口号，企业文化得背过！领导层个个神经兮兮的，没有一个正常的！公司不到十个人，六七个有股份都是领导！","createdAt":"2022-08-19T16:19:23"},{"id":"01963ddb-1bef-72be-831c-6b67f38600f4","parentId":null,"rootId":null,"fromId":1855,"content":"是所有员工都要这样吗","createdAt":"2023-02-16T18:02:44"},{"id":"01963ddb-1c34-70bb-b881-6362369c3509","parentId":null,"rootId":null,"fromId":2542,"content":"哈哈哈我待了3天，每天加班8点，要命的是一直不给我说工资多少，就跑了这公司不正常，企业文化也很可怕","createdAt":"2023-02-28T23:01:17"},{"id":"01963ddb-1c7d-736c-9755-ff7e251422ee","parentId":null,"rootId":null,"fromId":2542,"content":"最可怕的一个公司，有幸待了3天","createdAt":"2023-02-28T23:05:31"}]