[{"id":"01963dd3-eae1-72f1-b3b4-94cf163d8c88","parentId":null,"rootId":null,"fromId":91,"content":"在鑫盛大厦也有一家雅讯东方，项目经理很老 问技术问题不给解答，让你去找带你的人去解决。项目组长有个女的不咋懂技术，只会跟你捋逻辑 解决不了的问题只能去找其他人。","createdAt":"2022-02-16T09:49:29"},{"id":"01963dd3-eb26-71a9-97a7-565039cffe31","parentId":null,"rootId":null,"fromId":91,"content":"项目经理不懂技术，外行领导内行。","createdAt":"2022-02-16T09:50:25"},{"id":"01963dd3-eb6b-73b6-8255-777200be46ea","parentId":null,"rootId":null,"fromId":1191,"content":"拖欠工资是常态，这最近几年每年都会拖欠，记得 20年拖欠四个月老板给媳妇喜提宝马，公司内部还有一个其他的公司只有小圈子的人进去，然后在里面分红，海关的项目广州的慢慢做吧，这个公司 基本上技术大拿都走完了。","createdAt":"2022-08-02T11:41:50"},{"id":"01963dd3-ebb4-71d0-8224-d6b97bc64164","parentId":null,"rootId":null,"fromId":1989,"content":"确实是酱紫,已经仨月没发工资了","createdAt":"2022-10-17T16:17:14"},{"id":"01963dd3-ebfc-73a8-b047-857eaea27b52","parentId":null,"rootId":null,"fromId":2289,"content":"工资拖欠严重管理混乱，没有理由的加班，只有你加班才能体现出工作态度，每个领导自己都不知道自己想要什么，所以根本不知道想要的是什么，这公司之前的技术大拿很多，后来某龙，某帅都走了，之后也就那样老田还没走依旧不受用","createdAt":"2022-12-15T10:17:47"},{"id":"01963dd3-ec42-736f-8d43-0c7bd9e17282","parentId":null,"rootId":null,"fromId":181,"content":"傻逼公司倒闭了已经","createdAt":"2023-05-17T17:53:27"},{"id":"01963dd3-ecbe-71ca-a13b-0a5580eabeb4","parentId":null,"rootId":null,"fromId":1989,"content":"怎么倒闭了，还欠我九百多没发我呢，奶奶滴","createdAt":"2023-07-12T09:19:13"},{"id":"01963dd3-ed18-7141-ac2f-c05765e2743b","parentId":null,"rootId":null,"fromId":3219,"content":"哈哈哈哈，怎么欠的","createdAt":"2023-07-12T09:27:21"}]