[{"id":"01963de6-5789-70d8-b100-239ee233d8f4","parentId":null,"rootId":null,"fromId":2545,"content":"就是不跟你签劳动合同，你给他干活属于商业合作。建议按照期望工资的两倍以上要钱","createdAt":"2023-08-15T16:01:20"},{"id":"01963de6-57d8-7323-882d-eac494734d40","parentId":null,"rootId":null,"fromId":1157,"content":"谢了老铁","createdAt":"2024-02-27T13:29:01"},{"id":"01963de6-57dc-7232-8333-4382162727a1","parentId":null,"rootId":null,"fromId":6564,"content":"这家公司可以说是另类，参考共享员工模式。签的是合作协议，但是需要遵循他们的工作时间，单休，不交社保等等。换句话说，没有各种保障的情况下，听从他们的指挥，比外包还那啥，问题钱也不多。。。。。。","createdAt":"2024-04-20T14:16:28"},{"id":"01963de6-5823-720d-baf0-1da1fd48e5e0","parentId":null,"rootId":null,"fromId":6564,"content":"避坑吧","createdAt":"2024-04-20T14:16:44"},{"id":"01963de6-5868-7207-be73-3591482a2c07","parentId":null,"rootId":null,"fromId":6564,"content":"要是找不到工作，可以临时过渡一下，若是闲着没事儿去面试，可以往高要钱。","createdAt":"2024-04-20T14:17:42"}]