[{"id":"019a7c93-9257-721f-821f-f2a298199a3b","parentId":null,"rootId":null,"fromId":27024,"content":"做管理还不去？揩点女下属的油，搞点男下属的贿赂。美滋滋","createdAt":"2025-11-13T17:37:17"},{"id":"019a7caa-48c6-731d-8726-06da492c7284","parentId":null,"rootId":null,"fromId":22250,"content":"你他娘的就跟现在当官的一个鸟样，社会有你这样的败类才会一步步变得越来越糟糕","createdAt":"2025-11-13T18:02:05"},{"id":"019a7cac-29a9-7034-8993-3876459dbd13","parentId":null,"rootId":null,"fromId":21641,"content":"傻逼，乌烟瘴气","createdAt":"2025-11-13T18:04:09"},{"id":"019a7e4e-09a1-72c8-a2c2-0ac29e43adb9","parentId":null,"rootId":null,"fromId":21294,"content":"被揩油的要是你老婆，你姐姐，你妹妹呢？你也希望他去吗？","createdAt":"2025-11-14T01:40:34"},{"id":"019a7fac-89a1-737d-8112-d51e60384c2c","parentId":null,"rootId":null,"fromId":4140,"content":"你这几条完全都是为了孩子考虑，该去去呗，但是你要弄明白，你到底要你孩子有兴奋童年还是希望她将来考个好大学找好工作？想清楚这个，别本末倒置，如果奔着素质教育去的，就多陪孩子别考虑报班啥的，不能既要又要，咋们都是普通人，难免顾此失彼，确定自己要什么，轻松加陪伴孩子加孩子教育都解决了，很完美了，工资就没那么重要了，当然前提是你的生活压力没那么重的话（房贷好五六千这种）","createdAt":"2025-11-14T08:03:25"},{"id":"019a7fe9-9d7c-714c-8618-a8b8d52c5d26","parentId":null,"rootId":null,"fromId":27591,"content":"山大附中教育绝对没问题，我个人觉得能让孩子接受素质教育的机会是可遇不可求的。何况作为济南数一数二的学校，又有山大背书，起码师资也是顶尖的\n成绩靠不靠辅导班这点真是因人而异，我一山大附中的哥们基本没报过辅导班不影响人家上清华。再说哪怕上别的学校辅导班该报还是得报","createdAt":"2025-11-14T09:10:07"},{"id":"019a8014-8f93-7161-91c2-377fb66c938c","parentId":null,"rootId":null,"fromId":2921,"content":"@admin ban一下吧","createdAt":"2025-11-14T09:57:02"},{"id":"019a8031-897a-738e-8eb1-ad8a5986eb05","parentId":null,"rootId":null,"fromId":27024,"content":"网络里面仗义执言的，线下有几个敢BB的？某公司多个领导多次睡下属，睡代理商。玩弄新女员工感情闹的人屡屡升官的时候没见一个站出来的？","createdAt":"2025-11-14T10:28:41"},{"id":"019ab4cc-272e-706b-9de8-77cf0be8e97e","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-11-24T15:37:49"},{"id":"019ab4ce-2d14-70f4-9d56-29a83d42f697","parentId":null,"rootId":null,"fromId":6091,"content":"那个公司？","createdAt":"2025-11-24T15:40:02"},{"id":"019ab4d3-96ea-73b8-aa09-e32fa1c4b92b","parentId":null,"rootId":null,"fromId":2572,"content":"浪潮吗","createdAt":"2025-11-24T15:45:56"}]