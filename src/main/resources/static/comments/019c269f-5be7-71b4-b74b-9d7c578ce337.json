[{"id":"019c269f-8c6b-7169-81cd-01a7f24c0a0d","parentId":null,"rootId":null,"fromId":27024,"content":"我是24年底逃离济南的目前在浙江。双休，平时偶尔加班，全额五险一金。大部分人到点就走，平时加班多的年底评分必定是A。\n  4个月年终奖 or 期权激励。平时表现优异的月月有奖励。不太懂大家为啥非要烂在济南的一些中小公司里面。之前我在济南的时候领导PUA，睡女下属，睡女代理，克扣年终奖，排挤别人。","createdAt":"2026-02-04T11:08:36"},{"id":"019c26ad-a72b-7354-a0d6-60014ed8eb23","parentId":null,"rootId":null,"fromId":5480,"content":"山东人啥性格，啥心态你不懂吗？再者，万一是有家庭上有老下有小的，哪有说走就走这么容易？也有不是济南本地的，图一个在济南干活回家的话距离也不是太远，出了省，你还让这些人回家不？大家不是不愿意走，是走不开，没法走","createdAt":"2026-02-04T11:24:00"},{"id":"019c2717-8c93-71f7-ad51-ca39298756f2","parentId":null,"rootId":null,"fromId":28575,"content":"离家近啊","createdAt":"2026-02-04T13:19:40"},{"id":"019c271f-b15d-70c9-b274-71ea5003db8e","parentId":null,"rootId":null,"fromId":24428,"content":"后面可以考虑去杭州了","createdAt":"2026-02-04T13:28:34"},{"id":"019c2734-0afa-70c0-a014-86da811a07dd","parentId":null,"rootId":null,"fromId":2198,"content":"朋友 ，浙江有哪些公司推荐关注的吗","createdAt":"2026-02-04T13:50:48"},{"id":"019c2740-719f-722c-8a09-17aea0bc293e","parentId":null,"rootId":null,"fromId":557,"content":"要不是家是济南的，早跑了。","createdAt":"2026-02-04T14:04:20"},{"id":"019c2747-53bd-729e-b022-28785864e27d","parentId":null,"rootId":null,"fromId":26671,"content":"楼主公司是做什么方向的，有嵌入式的岗位吗","createdAt":"2026-02-04T14:11:51"},{"id":"019c2758-28fd-72bf-846f-d4cb44ea08f2","parentId":null,"rootId":null,"fromId":2572,"content":"领导PUA，睡女下属，睡女代理，克扣年终奖，排挤别人。哪个公司？说出来大家避雷","createdAt":"2026-02-04T14:30:15"},{"id":"019c2764-97cb-730b-acb9-bc6f0c55b513","parentId":null,"rootId":null,"fromId":6939,"content":"年轻人去哪都行，定居的没办法。","createdAt":"2026-02-04T14:43:49"},{"id":"019c27a8-9217-7303-9459-05a3049285fe","parentId":null,"rootId":null,"fromId":27024,"content":"作为孩子的父母难道因为自己不想走，就把孩子也放在这种地方吗？孟母三迁的故事只能在嘴上说，不能学习一点吗？现代社会的搬家比孟母三迁还难吗？为啥自己应该受到委屈了，还能让孩子继续受这种委屈？","createdAt":"2026-02-04T15:58:04"},{"id":"019c27a8-d567-730c-b766-f2103606d6cb","parentId":null,"rootId":null,"fromId":27024,"content":"作为孩子的父母难道因为自己不想走就把孩子也放在这种地方吗？孟母三迁的故事只能在嘴上说，不能学习一点吗？现代社会的搬家比孟母三迁还难吗？为啥自己应该受到委屈了，还能让孩子继续受这种委屈？","createdAt":"2026-02-04T15:58:22"},{"id":"019c27b3-5fa3-7115-a73a-e8b3d743efed","parentId":null,"rootId":null,"fromId":59,"content":"省内就济南、青岛；离家近，二三百公里回去了，出去不知道去哪。也想逃离了","createdAt":"2026-02-04T16:09:52"},{"id":"019c27b5-a3aa-723f-8342-8284cf56cb49","parentId":null,"rootId":null,"fromId":59,"content":"还有  没吃过好的，在济南也还行  虽然难找，但是还能找到","createdAt":"2026-02-04T16:12:21"},{"id":"019c27bc-fec3-7333-9212-1166fcf4ab54","parentId":null,"rootId":null,"fromId":5480,"content":"首先，你肯定没有孩子也没有结婚，你说的这都是理论，理论谁不会啊，带着孩子搬个家有你说的这么简单？你去了不落户，不考虑孩子上学的事，有的是你操心的， 你以为你自己呢？真有了你试试再说。","createdAt":"2026-02-04T16:20:23"},{"id":"019c27bf-f67f-738a-8a1f-edd29a58cc76","parentId":null,"rootId":null,"fromId":4043,"content":"这么刺激的么，啥公司啊","createdAt":"2026-02-04T16:23:37"},{"id":"019c28f1-8019-7367-bab6-9102f07cc36e","parentId":null,"rootId":null,"fromId":24615,"content":"在济南已经定居的路过，孩子小，还有老人，想搬家可太难了","createdAt":"2026-02-04T21:57:21"},{"id":"019c2b4b-883a-71a0-b50c-8b76b6581e89","parentId":null,"rootId":null,"fromId":557,"content":"还孟母三迁。就会当当键盘侠。那你去北京吧，在北京落户买房，给你孩子一个好的生长环境。","createdAt":"2026-02-05T08:54:56"},{"id":"019c2b4d-6166-7002-b25d-953e62f482db","parentId":null,"rootId":null,"fromId":267,"content":"山东人有所谓的家乡情结，尤其是男士，女士反而不一样","createdAt":"2026-02-05T08:56:57"},{"id":"019c2bae-c230-710c-a6df-c4e36d71145c","parentId":null,"rootId":null,"fromId":27024,"content":"我结婚了带着孩子今年2岁。上学有积分，公司可以落集体户口。","createdAt":"2026-02-05T10:43:19"},{"id":"019c2bb0-8ec2-7227-a3c6-e46a08337726","parentId":null,"rootId":null,"fromId":27024,"content":"是有打算去上海。稳定过今年就去上海面试。积分落户了解的差不多了。应该会去上海。","createdAt":"2026-02-05T10:45:17"},{"id":"019c2bb2-51ad-714c-9c14-1b3e7653ad54","parentId":null,"rootId":null,"fromId":27024,"content":"嵌入式可以考虑东莞、苏州、重庆 ，房价还可以。工业厂子比较多。不太能担心失业的问题","createdAt":"2026-02-05T10:47:12"},{"id":"019c2bb4-b8ec-7303-8a9b-9893722831bc","parentId":null,"rootId":null,"fromId":27024,"content":"我是买房了。已婚。孩子2岁，不过爷爷奶奶都过世了。可以带父母走。有爷爷奶奶需要照顾的会难一点。我是浙江有一个先谈好的工作，后期会往上海靠。程序员全额社保走积分落户上海可能性还是比较大的。","createdAt":"2026-02-05T10:49:50"},{"id":"019c2bb7-2f09-737c-be8a-62b95f148a4f","parentId":null,"rootId":null,"fromId":27024,"content":"我就是因为是一个小孩是小女孩，前公司还不算小，几个领导想办法睡同一个女下属。济南待不了一点。","createdAt":"2026-02-05T10:52:31"},{"id":"019c2bff-0b10-714d-9a3b-26e84484d62b","parentId":null,"rootId":null,"fromId":6827,"content":"你不想呆可以走，我觉得济南挺好，消费低，离家近，工资还行，至少我现在的薪资不比大城市低很多，你这标题看见就烦","createdAt":"2026-02-05T12:11:00"},{"id":"019c2c36-e498-706d-b0f1-da76794ac43f","parentId":null,"rootId":null,"fromId":2420,"content":"细说 薪资多少 加班多吗","createdAt":"2026-02-05T13:12:00"},{"id":"019c2c52-2785-72c2-918a-cd58acc223fc","parentId":null,"rootId":null,"fromId":1376,"content":"上海落户可太难了，你啥学历啊","createdAt":"2026-02-05T13:41:47"},{"id":"019c2d1e-58a7-7166-934e-ecc49b8b6556","parentId":null,"rootId":null,"fromId":6827,"content":"17.5*13  加班多，但有偿","createdAt":"2026-02-05T17:24:49"},{"id":"019c305d-7faf-7003-8f0c-30fa1fc540ac","parentId":null,"rootId":null,"fromId":557,"content":"牛逼 想搞群P","createdAt":"2026-02-06T08:32:39"},{"id":"019c30bb-e062-705d-b8a7-a326c3701861","parentId":null,"rootId":null,"fromId":27024,"content":"我是本科。居住证持有7年。持有期间社保缴纳必须要高。","createdAt":"2026-02-06T10:15:44"},{"id":"019c30bd-6e22-73fb-bee4-733919bc8f3f","parentId":null,"rootId":null,"fromId":27024,"content":"缴纳基数要在2W2以上","createdAt":"2026-02-06T10:17:26"},{"id":"019c30c0-c870-7067-ab78-8107f2d03d86","parentId":null,"rootId":null,"fromId":27024,"content":"你这工资确实没必要走。我觉得年薪到手有12W的都没必要走。我之前在济南还算可以，我看有很多都7年不到1W的兄弟，有很多找不到工作去小公司被骗的兄弟。","createdAt":"2026-02-06T10:21:06"}]