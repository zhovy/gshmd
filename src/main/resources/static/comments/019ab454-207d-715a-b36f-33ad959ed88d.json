[{"id":"019ab4ce-f06e-717b-93bc-ca8ab96cd1c7","parentId":null,"rootId":null,"fromId":7078,"content":"不礼貌，念我身份证干什么","createdAt":"2025-11-24T15:40:52"},{"id":"019ab50b-d004-724e-9528-92c7cd37bee2","parentId":null,"rootId":null,"fromId":21511,"content":"看来是经历过，不然细节写不了这么清楚","createdAt":"2025-11-24T16:47:21"},{"id":"019ab51f-4704-73af-bfd3-ace0bd3b7706","parentId":null,"rootId":null,"fromId":21818,"content":"失业那段时间和楼主说的一模一样","createdAt":"2025-11-24T17:08:37"},{"id":"019ab562-4096-73d0-b6a5-8db632be4dfd","parentId":null,"rootId":null,"fromId":23223,"content":"摄像头？拆？","createdAt":"2025-11-24T18:21:46"},{"id":"019ab5b7-3391-738f-9429-4aa2773e8809","parentId":null,"rootId":null,"fromId":21302,"content":"巧了么这不是，我失业三个多月，每天6点起床锻炼30分钟，刷40分钟单词，然后去图书馆学习，晚上11点睡，唯一不好的一点就是余额越来越少。","createdAt":"2025-11-24T19:54:33"},{"id":"019ab8ac-fc02-7288-ab7a-c2cb03e0c5ce","parentId":null,"rootId":null,"fromId":21818,"content":"失业的时候昼夜颠倒不知日月，上了班日子赶着日子仿佛永远过不去上班的这一天","createdAt":"2025-11-25T09:42:15"},{"id":"019ab8cc-899a-7027-8de3-4536a5a53646","parentId":null,"rootId":null,"fromId":23223,"content":"人生凭自己把控，是一种很自在的感觉，置身事外，没有工作消息打扰。有朋友就去约球玩乐，爽不爽看钱存的多少。反正不结婚没房没车的人占多数，也没有负担和压力","createdAt":"2025-11-25T10:16:43"},{"id":"019ab91c-edfb-7226-b491-91fd57da8e5c","parentId":null,"rootId":null,"fromId":1049,"content":"你要出国吗？","createdAt":"2025-11-25T11:44:32"},{"id":"019ab95d-66dd-73e9-8235-f4e00a516f31","parentId":null,"rootId":null,"fromId":23888,"content":"偷窥我的生活？","createdAt":"2025-11-25T12:54:57"},{"id":"019ac8ff-d805-7067-a079-22f0f0a89434","parentId":null,"rootId":null,"fromId":23910,"content":"舒服的很 没有贷款不结婚生子  就是玩","createdAt":"2025-11-28T13:46:41"}]