[{"id":"01963dea-63c8-7053-b31c-8a39c5f7e85c","parentId":null,"rootId":null,"fromId":4140,"content":"你问多少k没有意义，全额五险一金8k>最低五险一金的10k,正常全额五险一金本6-8k，研究生比这个多1k差不多，这是java的情况，c++的能比这个多个1k左右吧，反正济南就这个情况差不多","createdAt":"2023-12-28T10:43:54"},{"id":"01963dea-6418-72ab-8a07-286d8d60a439","parentId":null,"rootId":null,"fromId":4305,"content":"老哥 能不能解释一下是不是全额五险一金的区别体现在哪 为什么8>10.还有就是大数据方向怎么样","createdAt":"2023-12-28T10:56:15"},{"id":"01963dea-641c-7120-bdad-b790cc250317","parentId":null,"rootId":null,"fromId":4140,"content":"济南社保，个人缴纳总比例是10.3%，企业是27%，一金各12%，企业负担的五险一金成本是39%，也就是8*0.39=3.12k，最低五险一金3000*0.27+3000*0.05=0.96k，3.12-0.96=2.16k，所以全额五险一金8k>私企10k，而且私企你10k交的个税也多，一年也能多个几百到一千块钱吧，而且能全额五险一金的公司，基本上福利待遇都好，也不咋加班，私企嘛就不说了双休都不一定","createdAt":"2023-12-28T11:20:52"},{"id":"01963dea-6465-737e-8c04-dfaceeeb0c14","parentId":null,"rootId":null,"fromId":5913,"content":"啥技术栈啊","createdAt":"2023-12-28T12:04:04"},{"id":"01963dea-64b1-7090-847f-5d1558b76d96","parentId":null,"rootId":null,"fromId":4305,"content":"大数据 或者 java  在考虑","createdAt":"2023-12-28T12:24:58"},{"id":"01963dea-6461-71d3-af5d-553b05817aab","parentId":null,"rootId":null,"fromId":875,"content":"公积金最低不对，济南有私企最低基数2100，比例5%","createdAt":"2023-12-28T12:46:34"},{"id":"01963dea-64b5-7283-bdcc-20fb71d7d5bb","parentId":null,"rootId":null,"fromId":1398,"content":"只要你敢要，多少工资都能拿到","createdAt":"2023-12-28T12:55:40"},{"id":"01963dea-6519-7223-b05a-94c6670bcd8d","parentId":null,"rootId":null,"fromId":352,"content":"你在逗我？济南哪有大数据？","createdAt":"2023-12-29T10:33:57"},{"id":"01963dea-656f-7168-a76b-bab23a63e94f","parentId":null,"rootId":null,"fromId":875,"content":"购房补贴 10万，硕士毕业来济南，先领租房补贴2万，然后领购房补贴，三年后把房子卖了，换个地继续领10万","createdAt":"2023-12-30T09:36:02"},{"id":"01963dea-65b8-7129-b211-aaca6ff42ad2","parentId":null,"rootId":null,"fromId":3446,"content":"今年有难度","createdAt":"2024-01-02T16:40:49"},{"id":"01963dea-65b4-71da-8d8e-53146e076a2e","parentId":null,"rootId":null,"fromId":6797,"content":"那也呆先买房子了，才能领购房补贴","createdAt":"2024-02-28T19:06:30"}]