[{"id":"01963def-79e1-7219-89cb-06167b2b6b3c","parentId":null,"rootId":null,"fromId":7584,"content":"挺好的公司，我朋友在，都不愿意走","createdAt":"2024-05-22T09:38:49"},{"id":"01963def-7a29-73ff-afb1-fd35685cbaf7","parentId":null,"rootId":null,"fromId":3180,"content":"真的假的，大哥，能给个微信不","createdAt":"2024-05-22T09:45:16"},{"id":"01963def-7a2e-7237-a873-100166cddd51","parentId":null,"rootId":null,"fromId":7584,"content":"不忍心骗你，工资给的可以，仅此而已，996生活，我朋友在，跟我说，傻逼公司，别来，加班到凌晨2、3点都是常事，你要是愿意加班可以去","createdAt":"2024-05-22T11:27:59"},{"id":"01963def-7a72-73d4-b4a2-1ef76675eb53","parentId":null,"rootId":null,"fromId":3180,"content":"谢谢老哥","createdAt":"2024-05-22T13:03:02"},{"id":"01963def-7a76-7044-b247-298daf8b4a53","parentId":null,"rootId":null,"fromId":4057,"content":"996是常态吗","createdAt":"2024-05-22T19:54:29"},{"id":"01963def-7a7b-70ff-93f7-5f6963289c8b","parentId":null,"rootId":null,"fromId":3450,"content":"大哥，能有个准信不，刚拿到offer，犹豫要不要去","createdAt":"2024-05-22T22:11:38"},{"id":"01963def-7abf-7240-acd4-c4d6b42605cc","parentId":null,"rootId":null,"fromId":3450,"content":"跪谢各位大哥说句实话，孩子真的很需要一份工作","createdAt":"2024-05-22T22:12:05"},{"id":"01963def-7acc-721f-ba29-480321010d94","parentId":null,"rootId":null,"fromId":1372,"content":"本人在里面待过，目前已离开。\n1、看你做什么项目，如果是做济南这边的项目，那加班不加班，是否996就看项目了。一般项目前期都要加班。\n      不过听说济南这边已经没项目了。\n2、如果不做济南的项目，八成做大连那边的项目。那么加班就没跑了。你不加班大连那边的傻逼领导都会投诉 \n      你。\n3、别指望学什么东西和往上爬，就是一个外包公司。\n4、优点是不拖欠工资，社保和公积金都有。别指望年终奖。\n5、济南这边负责人-老贾。老狐狸一个，不过不阴险。","createdAt":"2024-05-23T11:43:19"},{"id":"01963def-7b10-73a8-8252-bc5e51eaa342","parentId":null,"rootId":null,"fromId":4057,"content":"感谢老哥","createdAt":"2024-05-23T12:51:00"},{"id":"01963def-7b15-708a-bd58-58c391d69a77","parentId":null,"rootId":null,"fromId":4057,"content":"不知道是济南的还是大连的，工作地都是齐盛广场吗","createdAt":"2024-05-23T12:52:47"},{"id":"01963def-7b19-70bc-8bf7-74d6e96e4455","parentId":null,"rootId":null,"fromId":1372,"content":"做大连的项目，可能去北京、大连，也可能在济南远程做。","createdAt":"2024-05-23T15:55:17"},{"id":"01963def-7ac4-7130-adeb-6a3acaef2f2f","parentId":null,"rootId":null,"fromId":7581,"content":"大哥，你进入这家公司了吗","createdAt":"2024-06-13T10:38:58"},{"id":"01963def-7ac8-713a-8730-9f44d9aef2c0","parentId":null,"rootId":null,"fromId":21386,"content":"老哥面试都问啥，能给到多少","createdAt":"2024-07-15T17:28:54"},{"id":"01963def-7b1d-73f3-a5b4-55d4d5fdcedb","parentId":null,"rootId":null,"fromId":21429,"content":"驾校有推荐吗","createdAt":"2024-07-21T16:51:49"},{"id":"01963def-7b60-7380-8926-aa7d3336146e","parentId":null,"rootId":null,"fromId":21878,"content":"朋友说入职前后承诺不一致，里面没几新人，老人都是岁数很大的而且抱团严重。","createdAt":"2024-09-14T18:59:40"}]