[{"id":"01963de9-67e6-7076-9e38-d69e2b5b9155","parentId":null,"rootId":null,"fromId":3892,"content":"老哥，这里99.999%的人都远远不如你，你得不到答案","createdAt":"2023-10-30T21:07:14"},{"id":"01963de9-682b-717c-881c-17958aab8cfa","parentId":null,"rootId":null,"fromId":875,"content":"哈哈，你问错地方了，你应该去知乎，那里年薪百万的人有一大堆，这里二十万都是大佬了","createdAt":"2023-10-30T21:40:24"},{"id":"01963de9-687b-73fd-a17a-fb5084968596","parentId":null,"rootId":null,"fromId":1398,"content":"把我内推进去，我给你打下手，你以后就是我的领导","createdAt":"2023-10-30T22:44:06"},{"id":"01963de9-68bf-7233-ae1b-e8f1607ce384","parentId":null,"rootId":null,"fromId":875,"content":"想再进一步要么去北京杭州等大城市，要么就是在济南跪舔领导，溜须拍马，熬到总监副总级别，一年搞个五六十万基本都到头了。再往上在济南除非你自己创业，否则50万就是你的顶。前提还得是会舔，要舔的领导舒服","createdAt":"2023-10-31T00:45:44"},{"id":"01963de9-6904-7393-81bd-732361666218","parentId":null,"rootId":null,"fromId":5954,"content":"这里的人不会给你答案，也没有资格回答你，你这都是啥级别的了，这里大部分都是年薪20万以下打工人","createdAt":"2023-10-31T08:28:07"},{"id":"01963de9-694b-722e-bf2b-98dd35a982c4","parentId":null,"rootId":null,"fromId":4140,"content":"你想晋升需要有backup，你把推进去我当你的backup","createdAt":"2023-10-31T10:06:16"},{"id":"01963de9-6990-717f-b90a-7580ff3421f7","parentId":null,"rootId":null,"fromId":4016,"content":"你才是大佬，你走，我去","createdAt":"2023-10-31T11:55:51"},{"id":"01963de9-69d4-7126-9fb5-d43878123b22","parentId":null,"rootId":null,"fromId":2408,"content":"大家散了吧，这是来凡尔赛的","createdAt":"2023-10-31T13:03:47"},{"id":"01963de9-6a18-73e7-b523-ec013d90406d","parentId":null,"rootId":null,"fromId":3671,"content":"人啊，不知足啊","createdAt":"2023-11-01T16:14:46"},{"id":"01963de9-6a5f-7105-bc50-186e630c2bb9","parentId":null,"rootId":null,"fromId":576,"content":"25-26这个标准，是985，硕博的标准。希望你看清济南的现实再要答案。","createdAt":"2023-11-06T09:10:19"}]