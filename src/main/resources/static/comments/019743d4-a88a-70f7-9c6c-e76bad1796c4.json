[{"id":"019743e6-abd8-70e6-b397-d6763bed53be","parentId":null,"rootId":null,"fromId":23959,"content":"比如不交社保吗","createdAt":"2025-06-06T14:21:20"},{"id":"019743e7-5d0a-721d-80fd-e3dfd350e758","parentId":null,"rootId":null,"fromId":460,"content":"都不交社保了  你以为还能发出工资吗？","createdAt":"2025-06-06T14:22:05"},{"id":"019743e9-3c69-731f-b2dd-ce8f23d858ff","parentId":null,"rootId":null,"fromId":23959,"content":"外包？","createdAt":"2025-06-06T14:24:08"},{"id":"019743ea-7587-71e2-9ca8-19e3a23e59e8","parentId":null,"rootId":null,"fromId":460,"content":"比如加一段时间班 大家辛苦辛苦哈  过了这段时间 就好了","createdAt":"2025-06-06T14:25:28"},{"id":"019743f4-e04d-7367-a215-341d7ae94191","parentId":null,"rootId":null,"fromId":24162,"content":"事情贼多。加班（不付加班费，甚至调休都不行，接受了一次，以后都得受罪），降薪（这一点，要明确一点，降薪容易，涨上来可不容易） 政策考核（开源节流，抓住考核的不合理性，并不是他出个考核想扣钱就扣钱的），裁员（发现人少也能撑一撑，这个我觉得都算是最合理的，只要正常付赔偿金），pua等。太多了有些太露骨不好说","createdAt":"2025-06-06T14:36:51"},{"id":"01974401-5532-7261-98f1-48db717abade","parentId":null,"rootId":null,"fromId":1421,"content":"其实人性，也可以说是几千年的文化传统，既得利益者可以把权力资源用到极限，底层最终只能通过流血和牺牲生命去捍卫自己的生存。","createdAt":"2025-06-06T14:50:27"},{"id":"01974e12-d362-71f8-b29d-fa7771fa6a1f","parentId":null,"rootId":null,"fromId":22724,"content":"比如不给劳动合同？","createdAt":"2025-06-08T13:45:46"},{"id":"01974fdb-d18a-7302-bdb8-39d70bcf8c52","parentId":null,"rootId":null,"fromId":23223,"content":"劳动者受欺负活该，自己权益不争取怪谁。山东教育也很成功，劳动力质量高还都那么听话，怪不得很多企业来山东开分公司并且把人力成本都放山东","createdAt":"2025-06-08T22:04:55"},{"id":"01975e6e-65b2-7304-ad97-92c56fbc0f9a","parentId":null,"rootId":null,"fromId":21742,"content":"不交社保 不交公积金  单休 无偿加班  绩效扣钱","createdAt":"2025-06-11T17:59:42"},{"id":"0197674d-4250-721a-96f0-3b57a21ca631","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-06-13T11:20:05"}]