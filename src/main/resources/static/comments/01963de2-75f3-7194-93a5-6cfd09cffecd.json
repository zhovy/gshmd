[{"id":"01963de2-7656-71ee-899e-1d57aceea4c5","parentId":null,"rootId":null,"fromId":1656,"content":"大小周","createdAt":"2023-05-15T16:11:21"},{"id":"01963de2-769a-72b1-890f-b0e985b5b100","parentId":null,"rootId":null,"fromId":168,"content":"好几年前呆过一个月左右，一天四次人脸打卡，不知道现在有没有变化","createdAt":"2023-05-16T00:03:51"},{"id":"01963de2-76de-706b-885d-360566fcf264","parentId":null,"rootId":null,"fromId":2079,"content":"工资总会拖延几天\n工资很低\n技术老旧","createdAt":"2023-05-16T11:59:47"},{"id":"01963de2-7724-7338-8426-4412523fee5b","parentId":null,"rootId":null,"fromId":2079,"content":"现在还是一天打卡4次","createdAt":"2023-05-16T12:00:18"},{"id":"01963de2-7768-7372-bd34-7a7c9a8bedcf","parentId":null,"rootId":null,"fromId":2664,"content":"之前去面试过，不怎么样，面了好几轮，差不多一个小时，最后给我打电话说薪资给不到那么高，问可以接受吗？五年经验就按照两三年工作经验给薪资，你说我愿意吗，（脏字省略...）hr不是说你学历不行就说你和他们的技术方向不是很对口，以此说薪资为啥给得低（本人大专），在去面试和电话沟通中他们领导和员工都莫名有种优越感，说话总爱把高调，让人很不舒服，最后没去公司。","createdAt":"2023-05-17T09:37:27"},{"id":"01963de2-77b0-703e-828b-87246ec9855b","parentId":null,"rootId":null,"fromId":2079,"content":"来这的基本上都是降薪进来的。和预期的工资差距很大。\n面试官态度确实很高傲，觉得自己平台牛的不行。其实也马上就是夕阳产业了\n离职当月工资下下个月发，而且扣了不少。问也说不明白，懒得去找他们了","createdAt":"2023-06-01T08:34:45"},{"id":"01963de2-77f5-718b-9ae3-bd841b6f0574","parentId":null,"rootId":null,"fromId":2079,"content":"压力倒是小，适合养老。待久了容易和外边的公司产生技术代沟。\n五险一金很低，试用期好像也没有五险一金\n工资会迟发\n产品、项目经理等专业能力和技术能力很差","createdAt":"2023-06-01T08:39:09"},{"id":"01963de2-783e-70d0-b116-9059e3e6e33b","parentId":null,"rootId":null,"fromId":2079,"content":"有时候会要求强制性加班，按月的那种","createdAt":"2023-06-01T08:52:18"},{"id":"01963de2-7886-72f9-83c7-6b3dffdfc6f4","parentId":null,"rootId":null,"fromId":2079,"content":"明明说加班可以调休，等离职之后全都按照事假来算了，呵呵\n而且离职那个月的工资压两个月发，就是很扯淡","createdAt":"2023-06-05T14:08:10"},{"id":"01963de2-78cb-70ad-92f7-186decae5865","parentId":null,"rootId":null,"fromId":2079,"content":"有其他地方尽量别去，前面的评论大多都属实","createdAt":"2023-07-20T19:43:16"},{"id":"01963de2-790e-738f-b496-0830a1867501","parentId":null,"rootId":null,"fromId":4374,"content":"垃圾，之前找工作顺路去面试的，面试官话都说不清楚，我直接啥都不会就走人。","createdAt":"2023-08-11T16:29:30"},{"id":"01963de2-7997-73a9-a656-b42586bcf7cc","parentId":null,"rootId":null,"fromId":4377,"content":"据说技术中心开始全员降薪了","createdAt":"2024-10-16T15:33:43"},{"id":"01963de2-79dd-722b-86aa-a861c1e06278","parentId":null,"rootId":null,"fromId":174,"content":"工资制度偷偷摸摸的改，辞退不给赔偿，慎入，慎入","createdAt":"2025-03-28T14:03:15"},{"id":"01963de2-7a22-7260-b024-3585b9d10555","parentId":null,"rootId":null,"fromId":174,"content":"现在每天都得写日报了，制度越来越麻烦，绝逼不要入","createdAt":"2025-04-07T11:16:42"},{"id":"01995a4b-ddc4-7224-9290-64358f3a2098","parentId":null,"rootId":null,"fromId":174,"content":"此公司辞退不给赔偿，偷偷抱走员工电脑，节假日放假全是单休，内卷严重","createdAt":"2025-09-18T08:49:05"},{"id":"01995a51-2223-7197-9836-dc8413e89388","parentId":null,"rootId":null,"fromId":22250,"content":"那你还不抓紧走？墨迹啥","createdAt":"2025-09-18T08:54:50"}]