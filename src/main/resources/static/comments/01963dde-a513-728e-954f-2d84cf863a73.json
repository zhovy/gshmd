[{"id":"01963dde-a584-7031-bf1f-600b587b2de5","parentId":null,"rootId":null,"fromId":2147,"content":"你至少写上你是干啥的吧","createdAt":"2023-02-10T17:32:19"},{"id":"01963dde-a5cd-7165-9f35-90195b55c04f","parentId":null,"rootId":null,"fromId":2495,"content":"java开发 3年","createdAt":"2023-02-10T17:32:48"},{"id":"01963dde-a613-710a-8a10-d2481de6ab9b","parentId":null,"rootId":null,"fromId":1656,"content":"1","createdAt":"2023-02-10T17:33:24"},{"id":"01963dde-a659-707d-a7dd-800ff4b2fd23","parentId":null,"rootId":null,"fromId":1656,"content":"不行就去软通哎","createdAt":"2023-02-10T17:33:54"},{"id":"01963dde-a6a0-73e3-8e2f-b3ea20e44471","parentId":null,"rootId":null,"fromId":1656,"content":"银行的驻场有了解的吗？","createdAt":"2023-02-10T17:36:41"},{"id":"01963dde-a6e5-7374-9087-7f87c4b293a1","parentId":null,"rootId":null,"fromId":1240,"content":"稍等等我们可以联系","createdAt":"2023-02-10T20:25:18"},{"id":"01963dde-a73c-72a8-8c96-435a790ae6a8","parentId":null,"rootId":null,"fromId":557,"content":"感觉今年的金三银四还不如去年，去年我二月份还拿了4个offer呢，现在别说offer了，我连一个靠谱的面试都没有，大部分都是已读不回，面试的公司也感觉不咋地。今年真的寒冬了吗。","createdAt":"2023-02-10T21:53:08"},{"id":"01963dde-a781-72a0-aaf8-89b6dcd9ebf4","parentId":null,"rootId":null,"fromId":1656,"content":"确实","createdAt":"2023-02-11T09:35:29"},{"id":"01963dde-a7c6-703e-84fa-2feb76b7826b","parentId":null,"rootId":null,"fromId":1656,"content":"去年下半年行情一下子就不行了","createdAt":"2023-02-11T09:35:59"},{"id":"01963dde-a80b-72f5-8922-2f89928042b3","parentId":null,"rootId":null,"fromId":2407,"content":"3年java，好找工作吗？想从上海回济南找工作，现在都不敢辞职","createdAt":"2023-02-11T09:45:02"},{"id":"01963dde-a856-7259-b86c-1f0d987f722e","parentId":null,"rootId":null,"fromId":1563,"content":"大部分公司现在招Java，都6年~8年，压低工资。3年左右的 连面试机会都没有，反正 最近人力是这么干。","createdAt":"2023-02-11T15:35:47"},{"id":"01963dde-a89d-72cb-8b7d-dc64582ad8dd","parentId":null,"rootId":null,"fromId":1563,"content":"现在Java行情是内卷严重，加上疫情刚刚散去，互联网红利慢慢褪去，行业内僧多肉少。一个明明2~3年就可以胜任的工作，HR有大把简历去选择6年以上的人选。况且这部分都已成家立业，要求更低，相对来说，更稳定，办事更牢靠。仅此而已。","createdAt":"2023-02-11T15:40:43"},{"id":"01963dde-a8e4-72f1-a224-64fd29fba409","parentId":null,"rootId":null,"fromId":1656,"content":"难啊，咋整兄弟们，3年要多少钱","createdAt":"2023-02-11T20:03:13"},{"id":"01963dde-a92b-72a7-a24c-1af413eaff08","parentId":null,"rootId":null,"fromId":2407,"content":"3年java要到12k容易吗？有机会的话立马从上海辞职回济南","createdAt":"2023-02-12T22:35:46"},{"id":"01963dde-a970-7009-a14c-47d7e0bb8a6d","parentId":null,"rootId":null,"fromId":1656,"content":"12有困难","createdAt":"2023-02-12T22:50:39"},{"id":"01963dde-a9b4-705d-9a78-e588b239bfd9","parentId":null,"rootId":null,"fromId":875,"content":"济南基本上都是大小周，北京基本上都是双休。济南五险一金最低基数，北京公积金全都12%","createdAt":"2023-02-12T22:53:57"},{"id":"01963dde-a9fc-728b-b191-55bcf48ce134","parentId":null,"rootId":null,"fromId":896,"content":"三年java，外包12还是没问题的","createdAt":"2023-02-13T15:51:08"},{"id":"01963dde-aa42-7267-a5c6-5551584b40db","parentId":null,"rootId":null,"fromId":1188,"content":"参考路边门头房，挣钱的话谁会转让？现在挣钱的岗位是不会缺人的，缺的职位，都是前人留下的坑。","createdAt":"2023-02-14T09:57:53"},{"id":"01963dde-aacb-7237-b6fc-39aecc8d5e6d","parentId":null,"rootId":null,"fromId":1933,"content":"一周加一两天班，月底前发工资，你这一下就pass了所有的公司，只能考编了","createdAt":"2023-02-14T11:22:05"},{"id":"01963dde-ab16-7337-b971-5786539baf88","parentId":null,"rootId":null,"fromId":1656,"content":"月底发上个月工资不算多好吧，我公司15号发上个月，没活就六点多下班，可惜不招人了呀","createdAt":"2023-02-14T11:25:42"},{"id":"01963dde-ab5a-73cf-81da-655579d49f4e","parentId":null,"rootId":null,"fromId":2551,"content":"昨天翻了一下，怎么感觉济南所有公司都在黑名单上啊，曾经的几个单位都在黑名单","createdAt":"2023-02-15T09:04:47"},{"id":"01963dde-aba3-7074-9656-8a2f84e253ce","parentId":null,"rootId":null,"fromId":2495,"content":"我的意思是月底发上个月的，哈哈，当月发工资那肯定没有","createdAt":"2023-02-15T09:05:07"},{"id":"01963dde-abe7-7364-8943-6200dbd07afb","parentId":null,"rootId":null,"fromId":2347,"content":"这么一比较，双休，加班可调休，节日福利，法定节假日，五险一金，15号准时发工资，我们公司真是为数不多的好公司了。","createdAt":"2023-02-15T09:17:08"},{"id":"01963dde-ac43-72d2-9b26-36f7b3c8c1cd","parentId":null,"rootId":null,"fromId":608,"content":"出差较多能接受不  还有期望薪资是多少。","createdAt":"2023-02-15T09:20:08"},{"id":"01963dde-ac88-73d7-8878-9e3610198502","parentId":null,"rootId":null,"fromId":1656,"content":"24楼啥公司还招人不?","createdAt":"2023-02-15T10:19:34"},{"id":"01963dde-accc-7035-ba6c-cc7f00fbf2e9","parentId":null,"rootId":null,"fromId":2543,"content":"24楼啥公司还招人不","createdAt":"2023-02-15T14:47:34"},{"id":"01963dde-ad10-7136-97b7-bfb13dd7dc87","parentId":null,"rootId":null,"fromId":2347,"content":"我是24楼，我们公司行业比较窄，目前只招硬件，要求硕士、电气工程专业。其他岗位不太缺。这里也不合适说公司名字，简历合适的可以加QQ2659637472","createdAt":"2023-02-16T08:51:52"},{"id":"01963dde-ad57-70d3-a4a0-85f885562ecc","parentId":null,"rootId":null,"fromId":1656,"content":"硕士 那白搭了","createdAt":"2023-02-16T15:34:47"},{"id":"01963dde-ad9e-73a2-90ad-6d1e83c5de56","parentId":null,"rootId":null,"fromId":1646,"content":"要学会仔细看看评论区啊，别被一些人带歪了。有些人可能自己犯了错误故意抹黑公司，只说缺点，但是优点丝毫不提，很片面。","createdAt":"2023-05-10T19:35:39"},{"id":"01963dde-ac32-705c-9cf9-358e67921b11","parentId":null,"rootId":null,"fromId":4020,"content":"众阳？\n","createdAt":"2023-07-10T15:08:41"},{"id":"01963dde-ac36-71ac-95d3-563478c81a0f","parentId":null,"rootId":null,"fromId":5891,"content":"我这边双休，不加班，5.30准点下班，节日福利，法定节假日，五险一金，5号准时发工资，十天年假，六天病假都是全薪，事假只扣除绩效工资，公积金是全额7%，私企","createdAt":"2023-10-11T10:07:36"},{"id":"01963dde-ac3a-7149-919c-5c2a695e6ff7","parentId":null,"rootId":null,"fromId":629,"content":"你这是哪，留个联系方式找人的话","createdAt":"2023-10-11T13:44:36"},{"id":"01963dde-ac3f-7002-9c17-a50d54703866","parentId":null,"rootId":null,"fromId":629,"content":"5号发工资我楼上这位兄弟","createdAt":"2023-10-11T13:45:09"}]