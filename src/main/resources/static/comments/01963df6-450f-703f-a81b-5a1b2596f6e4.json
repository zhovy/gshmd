[{"id":"01963df6-4575-738c-9ade-46f832dff322","parentId":null,"rootId":null,"fromId":875,"content":"公积金全额缴纳，听说","createdAt":"2025-01-10T15:42:55"},{"id":"01963df6-45ba-70cb-a2a0-1c80c4cdd872","parentId":null,"rootId":null,"fromId":5491,"content":"绝对大公司，在孙村那边，占地很大的一个工业园，光这个占地面积就说明水平不一般。里面人很多。招投标合作过几次，挺专业的，加班和薪资啥的具体不清楚。","createdAt":"2025-01-10T21:09:01"},{"id":"01963df6-4600-7029-9adf-076ab132c355","parentId":null,"rootId":null,"fromId":267,"content":"正式 外包待遇差别很大吧","createdAt":"2025-01-10T22:16:19"},{"id":"01963df6-464d-715a-9ef1-dcc45643319a","parentId":null,"rootId":null,"fromId":4171,"content":"五险一金按全额工资缴纳，公积金是7%，14薪，加班有补贴但不算高，出差没有加班补贴，有差补，超一线城市跟西藏新疆补贴会增加。园区有宿舍，四人间上床下周独卫，有食堂，正式员工每天在公司打卡有餐补。出差补助外包跟正式一样，外包的五险一金由外包公司交。","createdAt":"2025-01-11T14:40:27"},{"id":"01963df6-4691-7029-a81f-a7b34b0bc7e1","parentId":null,"rootId":null,"fromId":4171,"content":"研发岗的加班强度跟出差强度看产品线，有高有底。","createdAt":"2025-01-11T14:42:59"},{"id":"01963df6-4695-7303-8904-a7683d04e40f","parentId":null,"rootId":null,"fromId":22176,"content":"你好，请问这个公司有什么不好，或者不太合理的缺点吗","createdAt":"2025-01-15T10:04:06"},{"id":"01963df6-469a-71d9-9c4c-48255c9e7d07","parentId":null,"rootId":null,"fromId":4171,"content":"年终奖改成3月底发了。","createdAt":"2025-01-15T15:15:43"},{"id":"01963df6-46a2-7351-8d8b-0d15a91e802c","parentId":null,"rootId":null,"fromId":403,"content":"软件人才需求好象不是很多，很少听他们招人的。估计招人也是嵌入式的吧？","createdAt":"2025-01-17T08:48:18"},{"id":"01963df6-46ec-7140-8c80-ba4e0ac52d22","parentId":null,"rootId":null,"fromId":22176,"content":"招c++的，招不满","createdAt":"2025-01-21T10:12:46"},{"id":"01963df6-469e-715f-bc47-395f646d69b2","parentId":null,"rootId":null,"fromId":22746,"content":"研发经常出差，管理层决策偏极度保守，技术栈老旧，论资排辈现象比较严重；优点是因为保守，所以也能一直在里面混下去饿不死","createdAt":"2025-02-16T00:32:22"},{"id":"01993243-9442-7093-be3b-e9bad43af0be","parentId":null,"rootId":null,"fromId":26671,"content":"嵌入式的出差多吗","createdAt":"2025-09-10T14:15:13"}]