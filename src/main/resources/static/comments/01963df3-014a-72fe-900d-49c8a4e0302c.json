[{"id":"01963df3-01af-73de-bf87-4cf4002f8013","parentId":null,"rootId":null,"fromId":2598,"content":"外包公司，总部在上海，强度看项目，神思那边这两年被山东能源收购，如果是坐能源的项目，那就做好心里准备","createdAt":"2024-09-10T16:42:51"},{"id":"01963df3-01f3-709b-a1d6-c61ffb5ebdfd","parentId":null,"rootId":null,"fromId":21832,"content":"这样啊，会有项目结束就赶人之类的吗？要是没有的话那我先答应他，他说会跟神思那边的人有个面试，到时候问问是什么项目吧，先留着兜底","createdAt":"2024-09-10T16:53:18"},{"id":"01963df3-01f8-702a-b6bc-b8ee131f314a","parentId":null,"rootId":null,"fromId":3341,"content":"项目多半是外包性质，总部上海，工作强度看项目 有强有弱，劳务派遣到深思的话 就看那边领导什么情况。PS：面试后HR爱压工资。别的没啥","createdAt":"2024-09-10T18:25:08"},{"id":"01963df3-023d-72ba-8a0f-553ed95a4346","parentId":null,"rootId":null,"fromId":21832,"content":"压工资确实，我要12，他说最多10","createdAt":"2024-09-10T22:23:41"},{"id":"01963df3-0246-71be-86f3-c04218eaf5b7","parentId":null,"rootId":null,"fromId":5584,"content":"996干死你！","createdAt":"2024-09-11T04:04:21"},{"id":"01963df3-028c-71f3-9721-0baa9251c973","parentId":null,"rootId":null,"fromId":21832,"content":"吓人","createdAt":"2024-09-11T09:41:52"},{"id":"01963df3-0290-7262-b92d-d4e5caa0d446","parentId":null,"rootId":null,"fromId":6616,"content":"有幸在这个公司干了两年，去出差，强制996，当时疫情的时候，不管个人安危还要你去上海出差，索性辞职了","createdAt":"2024-09-11T11:33:33"},{"id":"01963df3-02d6-70eb-9e00-011cccc33166","parentId":null,"rootId":null,"fromId":444,"content":"面试过，好像是做汽车主机厂相关的，面试的岗位是项目经理，要长期出差驻场，笔试类似PMP的题目，当时没学过PMP笔试的不好，没拿到offer","createdAt":"2024-09-11T14:21:22"},{"id":"01963df3-031b-7266-a261-25d55c0fb99f","parentId":null,"rootId":null,"fromId":1978,"content":"几年经验呀？最多10？","createdAt":"2024-09-12T13:39:37"},{"id":"01963df3-0242-71b7-b9be-1a1d94130a7c","parentId":null,"rootId":null,"fromId":3341,"content":"那就是单纯为了压而压。。。","createdAt":"2024-12-24T17:01:20"},{"id":"0197ee85-460e-70b5-9ed7-c48197a26299","parentId":null,"rootId":null,"fromId":21821,"content":"以前一个帖子写过鸿冠的情况，很详细，不过后来给删了。不知道是不是因为接下来几个原因删的，就是因为绩效不好，和员工面谈，要求员工主动提交辞职申请，无赔偿。然后绩效不好员工没年终，领导年底就买了套豪宅。员工差不多一半是外包，就像博主说的神思，就是入职面试是甲方给你面，过了你就入职乙方，没过就是你不符合乙方要求；","createdAt":"2025-07-09T17:30:01"},{"id":"01980234-9143-7347-aa55-5b36b0588959","parentId":null,"rootId":null,"fromId":781,"content":"如果不明白什么叫卸磨杀驴，你就去","createdAt":"2025-07-13T13:14:16"}]