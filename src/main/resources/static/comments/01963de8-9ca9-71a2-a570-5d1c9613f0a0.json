[{"id":"01963de8-9d13-732d-9c1c-aeedf6c071c3","parentId":null,"rootId":null,"fromId":5829,"content":"面试了吗？","createdAt":"2023-09-28T10:10:06"},{"id":"01963de8-9d58-71fb-a923-ce5e9c98c88e","parentId":null,"rootId":null,"fromId":4140,"content":"没面试，但是电话给我沟通了，感觉还行吧，现在这个部门好像刚成立就五个人，毕竟缺人","createdAt":"2023-09-28T13:32:19"},{"id":"01963de8-9d61-728a-8ae6-4dea6036ffac","parentId":null,"rootId":null,"fromId":4140,"content":"入职4天了，一点不加班，5.30回头一看人没了，坐班车走的，去食堂吃饭的，虽然不加班双休，但是对工作能力要求比较高，因为是二次开发，项目也很大，坑爹的是没有设计文档，数据库文档都是英文，每个人都忙自己的事，给你分配任务也比较抽象，都是现在有什么什么功能，你对照这个功能把那个问题解决了，这种的开发任务比较多，就得要求你，前后端挨个去做断点去看看项目怎么跑的，去做调试，弄明白后再开发，总体来说有能力前期需要一段时间适应，但是后面就比较轻松了","createdAt":"2023-11-16T15:40:31"},{"id":"01963de8-9dad-7158-8d11-148d6acaef2a","parentId":null,"rootId":null,"fromId":6911,"content":"老哥，可以给个内推机会吗？","createdAt":"2024-03-06T20:21:36"},{"id":"01963de8-9db2-7199-a362-304ab9b05e71","parentId":null,"rootId":null,"fromId":7009,"content":"有人说工作期间还需要去车间操作，不让带任何通讯设备，这是什么岗位啊，而且偶尔也加班?","createdAt":"2024-03-14T10:07:05"},{"id":"01963de8-9d5d-733e-a2ce-0f15caed3f21","parentId":null,"rootId":null,"fromId":3632,"content":"后续有啥面试结果吗","createdAt":"2024-05-09T11:03:45"}]