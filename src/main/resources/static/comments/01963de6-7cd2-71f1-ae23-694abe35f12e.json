[{"id":"01963de6-7d44-733d-9450-8de940f17d54","parentId":null,"rootId":null,"fromId":561,"content":"1.两套房子，一套自住，一套收租，勉强半退休。\n2.一套房子无贷款，体制内，无晋升心思，半退休","createdAt":"2023-08-18T08:43:23"},{"id":"01963de6-7d8a-7319-b937-937645c670ec","parentId":null,"rootId":null,"fromId":460,"content":"收到","createdAt":"2023-08-18T08:45:25"},{"id":"01963de6-7d98-702d-8a80-54aa368246c3","parentId":null,"rootId":null,"fromId":3671,"content":"个人觉得，房车无贷，有几十万存款，就可以随便找个轻松的活，一个月三四千就行，半养老","createdAt":"2023-08-18T08:55:43"},{"id":"01963de6-7de4-7184-a040-8f3a5d134290","parentId":null,"rootId":null,"fromId":4151,"content":"既然你说要找个轻松点的活，还能有点收入，那么下限是200w存款+自己的住房。一家三口的话翻个倍吧。。。","createdAt":"2023-08-18T08:56:26"},{"id":"01963de6-7e29-72bc-a329-7529cfab3ccb","parentId":null,"rootId":null,"fromId":2382,"content":"济南其实不适宜半退休，东部沿海的省份生活成本还是太高了。如果硬要退的话，200万应该够了（前提是不结婚、生子）\n拿180万买理财，收益4%-5%的一年收入平均能到7万多，一个月6000块自己做饭的话，买个人医保社保的话肯定够了。剩下的存短期，用来不备之需。\n6K的收入，租房2500（含物业水电宽带），吃饭2000，剩余衣服/日用品1000，最后的500还可以用来买点自己喜欢的小东西","createdAt":"2023-08-18T08:56:53"},{"id":"01963de6-7ddf-726d-a19c-c6ef24447ff6","parentId":null,"rootId":null,"fromId":2628,"content":"有孩子了就不行了，一个孩子成本太高了","createdAt":"2023-08-18T09:09:00"},{"id":"01963de6-7e6f-725a-9e50-b3983c4e24aa","parentId":null,"rootId":null,"fromId":460,"content":"如果结婚生子了，那至少该是多少","createdAt":"2023-08-18T09:18:07"},{"id":"01963de6-7eb5-73bd-9f9b-20c111c20af8","parentId":null,"rootId":null,"fromId":561,"content":"大概得翻倍吧","createdAt":"2023-08-18T09:52:56"},{"id":"01963de6-7d8e-71df-99ae-2ed98f0db06e","parentId":null,"rootId":null,"fromId":561,"content":"不包括对象和孩子可以这样吧","createdAt":"2023-08-18T16:53:26"},{"id":"01963de6-7eba-727c-9ff4-a15a84f0bc72","parentId":null,"rootId":null,"fromId":875,"content":"吹水","createdAt":"2023-08-19T12:50:11"},{"id":"01963de6-7d92-7120-820b-7730f09d072a","parentId":null,"rootId":null,"fromId":460,"content":"但是包括孩子和对象，这条件在济南也算还可以是吧","createdAt":"2023-08-19T18:59:24"},{"id":"01963de6-7eff-7360-a2a6-1b5c4657e83e","parentId":null,"rootId":null,"fromId":875,"content":"秀，是你嘛","createdAt":"2023-08-20T21:23:37"},{"id":"01963de6-7f46-72e5-b702-ae5c6e1ed100","parentId":null,"rootId":null,"fromId":1110,"content":"哈哈又是那个人","createdAt":"2023-08-21T11:55:17"},{"id":"01963de6-7f8b-71b4-9122-083c795f7318","parentId":null,"rootId":null,"fromId":1110,"content":"是你吗，秀，招不到人不看看自己什么问题，来这里秀儿来了","createdAt":"2023-08-21T11:55:56"}]