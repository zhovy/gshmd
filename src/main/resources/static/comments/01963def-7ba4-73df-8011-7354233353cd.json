[{"id":"01963def-7c15-7115-845e-f604a38fa93a","parentId":null,"rootId":null,"fromId":1137,"content":"依稀记得面试的时候那个老板说过的一句话，大体意思是干的好不好，绩效高不高看我心情。而且这老板还说之前招了八个辞了八个，瞬间感觉是个大坑。","createdAt":"2024-05-22T20:16:10"},{"id":"01963def-7c5a-7026-8b79-49a263dfeea3","parentId":null,"rootId":null,"fromId":7224,"content":"面试时候告诉项目急，去了就得加班","createdAt":"2024-05-24T12:39:12"},{"id":"01963def-7ca3-73db-95e4-81becdb445d4","parentId":null,"rootId":null,"fromId":21429,"content":"驾校有推荐吗","createdAt":"2024-07-21T16:51:49"},{"id":"01963def-7ce8-710e-900d-8a028e8e765f","parentId":null,"rootId":null,"fromId":5584,"content":"兄弟说的都是反话吧","createdAt":"2024-09-12T20:17:29"},{"id":"01963def-7d2d-73df-85cf-80729f3db63c","parentId":null,"rootId":null,"fromId":5584,"content":"楼上说的很对！你工资要的多了，你不加班，就跟歉他是的，老板总觉得你的产出达不到他的预期，因为你不加班。只干自己的活不行！不过，优点是，老板能当场给你结算工资","createdAt":"2024-09-15T15:06:17"},{"id":"01963def-7c9f-72d5-8fba-502440124bfd","parentId":null,"rootId":null,"fromId":5584,"content":"真是这样的！凡是招人的，工资给的高的，都是急项目！","createdAt":"2024-09-15T15:07:16"}]