[{"id":"0198d09d-d290-73d2-899d-93f21a855286","parentId":null,"rootId":null,"fromId":6747,"content":"有没有转力工的，风里雨里我在工地等你！","createdAt":"2025-08-22T15:11:00"},{"id":"0198d0a2-770d-7274-8b27-0aef9a5efae8","parentId":null,"rootId":null,"fromId":2921,"content":"程序员士可杀不可辱，铁人三项才是正经归宿","createdAt":"2025-08-22T15:16:05"},{"id":"0198d0a3-52f2-7043-a2a5-f363e77fb565","parentId":null,"rootId":null,"fromId":21818,"content":"Cursor一直在用，距离替代人还是有差距","createdAt":"2025-08-22T15:17:01"},{"id":"0198d0a5-1c99-7094-8354-d859b746564e","parentId":null,"rootId":null,"fromId":7344,"content":"你不是搞装修的吗","createdAt":"2025-08-22T15:18:58"},{"id":"0198d0ac-57dd-718e-b190-baa411b38cb7","parentId":null,"rootId":null,"fromId":6747,"content":"装饰装修也有力工啊，正经装修不是家装","createdAt":"2025-08-22T15:26:52"},{"id":"0198d0cb-8e17-705f-93de-075c174081ed","parentId":null,"rootId":null,"fromId":22023,"content":"本来不想说的，我就想问一下，你们觉得开发到底是干什么的？非专业人士有三次脑残操作，第一次出现编程，以为编程想干嘛干嘛，结果呢？第二次 低代码平台，以为低代码平台可以取代开发，结果呢？第三次 ai生成代码，你们平时用不用ai，错误百出，还瞎编，怎么取代开发，这还是低端的编程。","createdAt":"2025-08-22T16:00:57"},{"id":"0198d0cc-8ac6-7255-9579-2af77e3603b8","parentId":null,"rootId":null,"fromId":1421,"content":"现在其实影响没这么大，其实如今的AI代码开发，就像是在一座“屎山”之上继续堆砌“屎块”，这个屎块最后都维护不下去，重新堆，现在AI也就是火绳枪的时代，到全自动化步枪时代大多数行业都没存在的必要了，不仅仅是程序员了","createdAt":"2025-08-22T16:02:02"},{"id":"0198d0ef-4532-71f4-905b-da06494c15e9","parentId":null,"rootId":null,"fromId":6091,"content":"人也没有存在的必要了","createdAt":"2025-08-22T16:39:58"},{"id":"0198d104-ff58-7201-ab0f-095c848aa707","parentId":null,"rootId":null,"fromId":1421,"content":"其实现在不做技术的都以为ai无所不能，其实做技术的都知道ai到agi还有很长的路要走(看看ai的基础理论到工程落地走了多少年)，其实这种焦虑与ai无关","createdAt":"2025-08-22T17:03:42"},{"id":"0198d106-55fb-73e4-b129-5c3610f21747","parentId":null,"rootId":null,"fromId":21644,"content":"哦","createdAt":"2025-08-22T17:05:10"},{"id":"0198d10a-ab50-70b0-a46d-e5fa8c491e96","parentId":null,"rootId":null,"fromId":4174,"content":"他可以背锅么","createdAt":"2025-08-22T17:09:54"},{"id":"0198d12d-ea54-72ee-b482-70e37400a949","parentId":null,"rootId":null,"fromId":1421,"content":"还有吹ai的，基础设施都没搞定，还在这杞人忧天","createdAt":"2025-08-22T17:48:24"},{"id":"0198d148-7f44-7338-a741-4d3b0cab5a28","parentId":null,"rootId":null,"fromId":2256,"content":"太搞笑了，你用没用过","createdAt":"2025-08-22T18:17:26"},{"id":"0198d4bd-5679-706a-a483-ed72b3c650fa","parentId":null,"rootId":null,"fromId":926,"content":"能调解的，一步步指导AI修正就可以了","createdAt":"2025-08-23T10:23:55"},{"id":"0198d4bd-a082-71b6-b83d-cd5458586eb1","parentId":null,"rootId":null,"fromId":926,"content":"调教","createdAt":"2025-08-23T10:24:13"},{"id":"0198ded0-49b9-7371-8426-1280eab8040c","parentId":null,"rootId":null,"fromId":5471,"content":"AI到死也只能是辅助，不可能完全替代","createdAt":"2025-08-25T09:20:49"},{"id":"0198ded2-858e-7070-8bfa-f51670752d6f","parentId":null,"rootId":null,"fromId":22250,"content":"错，完全可以完全替代","createdAt":"2025-08-25T09:23:15"},{"id":"0198ded3-382b-71aa-9c55-236b73b58515","parentId":null,"rootId":null,"fromId":22250,"content":"本人奥特曼，你说用过吗","createdAt":"2025-08-25T09:24:01"},{"id":"0198df20-f675-70d7-ac51-5c293133d9b1","parentId":null,"rootId":null,"fromId":23304,"content":"做一个12306？","createdAt":"2025-08-25T10:48:56"},{"id":"0198e03f-cec4-7377-83cb-8d58a212f2ae","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-08-25T16:02:14"},{"id":"0198e073-a6fb-72a8-838e-fd2dc8fc031d","parentId":null,"rootId":null,"fromId":22023,"content":"https://mp.weixin.qq.com/s/Qo8P1gFsLH-dJMl6gojbGg    这篇文章就能很好解决乱七八糟的想法","createdAt":"2025-08-25T16:58:52"},{"id":"0198e3ca-b9ae-703a-833a-87a8f3358e75","parentId":null,"rootId":null,"fromId":24162,"content":"济南的保洁要没了，因为有扫地机器人；济南的厨师要没了，因为有自动炒菜机。济南的交警要没了，因为有红路灯和静态交通。。 不是制造蕉绿！不是制造蕉绿！不是制造蕉绿！  我是在吹牛逼！！！我是在吹牛逼！！！我是在吹牛逼！！！","createdAt":"2025-08-26T08:32:50"},{"id":"0198e436-1951-700d-824d-410591453e49","parentId":null,"rootId":null,"fromId":7746,"content":"何止程序员，打电话有外呼机器人，送外卖送快递有无人车无人机，流水线有机械臂，我甚至觉得ai比人做的决定要聪明，出问题概率小，干脆当官的也让Ai来干吧，把人都替代了吧。光情着享福就行了。","createdAt":"2025-08-26T10:30:07"},{"id":"0198e437-59f8-72e2-9201-e9bf4c472866","parentId":null,"rootId":null,"fromId":7746,"content":"哈哈哈，静态交通是人动态的去管理哈哈哈哈哈哈哈哈哈","createdAt":"2025-08-26T10:31:29"},{"id":"0198e44b-1abb-701b-8b79-e96bbb072c2f","parentId":null,"rootId":null,"fromId":21818,"content":"如果可以完全替代程序员，那能替代的绝不止程序员。人类生存的必要生产力至少可以替代80，乐观点95%都有可能","createdAt":"2025-08-26T10:53:04"},{"id":"0198e554-b1cd-73ed-aa35-90b312233ae7","parentId":null,"rootId":null,"fromId":23910,"content":"脑残吧","createdAt":"2025-08-26T15:43:09"},{"id":"0198e58d-515c-72e6-bf59-91f61b6a039e","parentId":null,"rootId":null,"fromId":24162,"content":"哈哈，不要在意这些细节","createdAt":"2025-08-26T16:45:00"}]