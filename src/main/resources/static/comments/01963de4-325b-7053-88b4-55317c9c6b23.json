[{"id":"01963de4-32cf-71c5-83d4-28b24619bce9","parentId":null,"rootId":null,"fromId":2408,"content":"老哥想去南京发展吗？","createdAt":"2023-06-27T17:41:59"},{"id":"01963de4-332d-71d8-a543-1619aba3abe9","parentId":null,"rootId":null,"fromId":3705,"content":"行情全国都一个样，不过听说南京给的钱多点。","createdAt":"2023-06-27T17:46:15"},{"id":"01963de4-3373-7176-9a06-2be0c5cd1b12","parentId":null,"rootId":null,"fromId":691,"content":"要去南京发展了","createdAt":"2023-06-27T18:04:12"},{"id":"01963de4-3327-7088-a45d-549c2b6094c8","parentId":null,"rootId":null,"fromId":691,"content":"要去南京发展了","createdAt":"2023-06-27T18:04:20"},{"id":"01963de4-33be-70c6-9fd7-32f2d8f8a1b3","parentId":null,"rootId":null,"fromId":330,"content":"南京号称外包之城，基本上全是大公司的外包","createdAt":"2023-06-27T18:06:09"},{"id":"01963de4-3403-713d-8a0f-5628f9b23f50","parentId":null,"rootId":null,"fromId":3684,"content":"待了四年多，刚回来两个月左右。\nit情况差不多，南京外包不比济南少，很多外包都是去华为研究所，比如：软通，中软，润和，诚迈，法本等等，当初毕业二年找工作，100多家公司主动找，80%都是外包。\n薪资和公司情况，薪资比济南高至少30%。公司整体情况比济南好，拿得出手的公司多，独角兽上市公司也不少，相对应机会也多。不过今年行情很差，都不怎么招人了，很多公司我内推都进不去，很多南京朋友被裁都2-3个月失业期，最后都去了苏州或上海。\n建议：如果哥们去南京有别的目的我就不说了。如果只是想去南边发展，建议不要局限于那一个城市，附近城市也找找，性价比不比南京差，甚至薪资也可能更高。","createdAt":"2023-06-27T18:06:35"},{"id":"01963de4-3459-711b-b9fe-0084f8cb5214","parentId":null,"rootId":null,"fromId":875,"content":"杭州不行嘛，去杭州无锡武汉，去哪都比济南强","createdAt":"2023-06-27T22:33:14"},{"id":"01963de4-3448-70d4-ab59-d302f3fce65a","parentId":null,"rootId":null,"fromId":691,"content":"感谢老哥的建议，非常受用，之前考虑过的城市有苏州、杭州、南京，一开始定的是苏州，但是据我了解苏州基本上都是工厂，杭州又都是卷王，所以目前定的是南京，就想了解一下南京的情况","createdAt":"2023-06-28T08:43:52"},{"id":"01963de4-349f-71f3-bf33-be6dced9c2e3","parentId":null,"rootId":null,"fromId":691,"content":"杭州太卷了，无锡的IT行业比南京、苏州都差，武汉倒是没了解过","createdAt":"2023-06-28T08:44:42"},{"id":"01963de4-344c-72c2-b31e-d2d1d2c515b4","parentId":null,"rootId":null,"fromId":691,"content":"还想问一下老哥，我对苏州的印象就是工厂多，苏州的IT跟南京差不多呢，还是苏州比南京更好一些","createdAt":"2023-06-28T08:46:19"},{"id":"01963de4-3450-706d-8dd2-5886051ee8bf","parentId":null,"rootId":null,"fromId":3684,"content":"差不多，不过据说比南京更宜居","createdAt":"2023-06-28T11:55:02"},{"id":"01963de4-34a4-7259-ac6c-eb3eb172b77f","parentId":null,"rootId":null,"fromId":875,"content":"杭州创业环境好，武汉也不错，西安宜居，无锡集成电路传感器，苏州工业园，都比济南外包城好，上班堵，空气差，工资低，张嘴就来体制内国企。。。","createdAt":"2023-06-28T21:31:59"},{"id":"01963de4-34f5-718d-aeaf-124a53f75ed8","parentId":null,"rootId":null,"fromId":875,"content":"终于知道为啥济南it工资为啥低了，拿项目都是一起吃回扣，项目再垃圾只要关系到位，钱到位，无论怎样都能卖出去，这样的话技术就不值钱了","createdAt":"2023-06-29T05:50:31"},{"id":"01963de4-34f1-715c-8818-042bbdf0a974","parentId":null,"rootId":null,"fromId":21,"content":"你在哪儿","createdAt":"2023-06-30T09:53:54"},{"id":"01963de4-353b-7102-af0f-588a6f32c24f","parentId":null,"rootId":null,"fromId":59,"content":"说的真对；有次3个方案；偏偏选耗时耗钱最多的方案，还死压时间；就是因为上头有人；所以选了这个方案","createdAt":"2023-07-01T17:07:24"},{"id":"01963de4-353f-7053-a464-0f6c82d99796","parentId":null,"rootId":null,"fromId":2363,"content":"老哥有南京it讨论资源吗，南京恺恩泰科技咋样，最近在面试这个。谢谢","createdAt":"2023-09-03T08:52:08"},{"id":"01963de4-3583-72c8-96ce-bddd6b38426a","parentId":null,"rootId":null,"fromId":691,"content":"我打算是明年去，暂时没有南京IT讨论资源","createdAt":"2023-09-21T14:30:09"},{"id":"01963de4-3455-728e-82e7-bae049bb963c","parentId":null,"rootId":null,"fromId":2436,"content":"我待了不到两年，情况基本差不多，没回济南之前，就感觉南京外包最多，不过都是大型的专做人力的外包。毕竟也算新一线城市，薪资的话济南还是有差距的","createdAt":"2023-09-21T16:29:30"}]