[{"id":"01963df2-94f9-7345-92bc-53356fbfe999","parentId":null,"rootId":null,"fromId":7251,"content":"好公司谁天天招人啊？boss上每天都招人的基本都不咋地。","createdAt":"2024-08-26T11:26:45"},{"id":"01963df2-9543-73c9-9571-428c5e46c80a","parentId":null,"rootId":null,"fromId":1,"content":"hr有“积极约面”称号的，都是虚假岗位。","createdAt":"2024-08-27T17:14:58"},{"id":"01963df2-958d-715a-a15e-7934401c2086","parentId":null,"rootId":null,"fromId":203,"content":"我是HR，boss是双向收费的，HR发布职位要付费，而且有效期就三个月。要想能搜索到牛人简历 也是需要购买会员的，所以找工作难，企业招人更难","createdAt":"2024-09-04T11:42:22"},{"id":"01963df2-95d0-737f-b9bf-b46bbc37a783","parentId":null,"rootId":null,"fromId":203,"content":"不购买boss会员的话，能查看到的简历寥寥无几，必须购买会员才能查看到更多的简历","createdAt":"2024-09-04T11:44:00"}]