[{"id":"0197e8ad-8055-7336-b4f1-438c4fb1e652","parentId":null,"rootId":null,"fromId":6446,"content":"分析啥，邻居准备生三胎，老板准备换大房子，我准备黄袍加身，我们都有美好的生活。","createdAt":"2025-07-08T14:16:14"},{"id":"0197e8ae-577c-70d6-8256-a6108a98ba19","parentId":null,"rootId":null,"fromId":23605,"content":"红袍有五险一金哥们","createdAt":"2025-07-08T14:17:09"},{"id":"0197e8af-4e1c-7210-a4ed-432f7d42f315","parentId":null,"rootId":null,"fromId":6446,"content":"我还是喜欢喝开水，不想当兄弟","createdAt":"2025-07-08T14:18:12"},{"id":"0197e8b3-23ef-70e2-a4c1-f9fedd7a5bb3","parentId":null,"rootId":null,"fromId":24824,"content":"没有新的经济增长点，以后得开发会偏高端化，搬运工和CRUD工程师会大幅减少","createdAt":"2025-07-08T14:22:23"},{"id":"0197e8cf-fe9f-7056-894b-8a84c6f47ec7","parentId":null,"rootId":null,"fromId":22702,"content":"房价就是缩影 降价的主要原因 不是炒房团不炒房了 是脚下站不稳了","createdAt":"2025-07-08T14:53:54"},{"id":"0197e8d4-e53f-739c-8079-f27105788244","parentId":null,"rootId":null,"fromId":1372,"content":"凡是提倡的，你不参与，也许会错过机会，但不会吃亏。","createdAt":"2025-07-08T14:59:15"},{"id":"0197e8db-fda9-70ae-a7dc-cac39aeb10c3","parentId":null,"rootId":null,"fromId":2246,"content":"降价是因为房价本来就没那么高","createdAt":"2025-07-08T15:07:00"},{"id":"0197e8e6-f370-7185-a13d-553efcbbdfda","parentId":null,"rootId":null,"fromId":23684,"content":"等着收复湾湾","createdAt":"2025-07-08T15:18:59"},{"id":"0197e8e9-f2ae-703b-b5f6-7b6ef1c868e3","parentId":null,"rootId":null,"fromId":23605,"content":"你这不是政治","createdAt":"2025-07-08T15:22:15"},{"id":"0197e906-fbf4-714d-93c4-80de72f225fd","parentId":null,"rootId":null,"fromId":6054,"content":"各行各业其实都和土木有相似之处，市场极度饱和，后续增长都普遍乏力；\n新的经济增长点目前也没什么眉目，大模型除了让代码，写文件更方便些以外，也没有爆发什么生活和社会层面革命；国内新能源汽车倒是发展迅速，但是大家也能看出来，对社会经济和就业岗位的贡献也没有想象中那么大，现在连大洋对岸的川普都不想给马斯克新能源补贴了，未来还有多大发展潜力很存疑；其他像什么低空飞行器，人形机器人那更是空中楼阁，遥遥无期；\n还有一个很糟糕的现象越来越明显，一个普通大学生除非是很顶尖的985和部分211，就连差一点的211大学就业都是大难题了，我身边毕业就失业的大学生一抓一大把，其中不乏硕士学历，读书无用论好像说的也没错了，尤其是文科生，毕了业除了去当销售，就是去考公，根本没什么正经出路。。","createdAt":"2025-07-08T15:53:58"},{"id":"0197e90b-3c33-7178-9da0-1c44bf364548","parentId":null,"rootId":null,"fromId":6091,"content":"什么是正经出路","createdAt":"2025-07-08T15:58:37"},{"id":"0197e91d-20c3-7353-9512-156a5c914f18","parentId":null,"rootId":null,"fromId":6054,"content":"普通企业销售当然没问题，但是我指的是在各大写字楼里打推销电话，做营销号视频挂小黄车，要不就是向亚非拉卖假冒伪劣产品的销售，这些岗位连个社保都交不齐，公司普遍几年就倒闭，老板卷一波钱换个皮再开一个，济南这种公司真是多如牛毛","createdAt":"2025-07-08T16:18:09"},{"id":"0197e920-8be4-72a0-a3a2-2500322ff290","parentId":null,"rootId":null,"fromId":24615,"content":"没有大家没有信心消费，国家出台各种政策刺激大家消费。国际形式不乐观，美国的经济政策对中国不利。外企裁员自救，因为现在都是一根绳子上的蚂蚱，国内企业也受影响裁员","createdAt":"2025-07-08T16:21:53"},{"id":"0197e94b-99c3-7323-bde9-9c021fcbcadb","parentId":null,"rootId":null,"fromId":4002,"content":".","createdAt":"2025-07-08T17:08:55"},{"id":"0197eca1-588e-725c-ae59-5891f41969de","parentId":null,"rootId":null,"fromId":24162,"content":"消费不起了，如果消费的起 ，她得泡沫会一直在。毕竟有钱就会想换好的 ，买的人多就不会降价，不管他值不值，只要供不应求就是贵。没人买是主要原因。","createdAt":"2025-07-09T08:41:26"},{"id":"0197eca8-652f-72ad-bd7d-171cb1c2af28","parentId":null,"rootId":null,"fromId":21267,"content":"先自己吃饱饭再说，弯弯比你生活好，别去祸害人家了，粉红兄弟","createdAt":"2025-07-09T08:49:08"}]