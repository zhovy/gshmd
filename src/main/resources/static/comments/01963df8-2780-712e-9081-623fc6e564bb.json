[{"id":"01963df8-27e6-72fd-a890-c001a8b1feaa","parentId":null,"rootId":null,"fromId":875,"content":"黄金一年涨了36%","createdAt":"2025-03-27T07:35:57"},{"id":"01963df8-2830-7143-a14c-ae2198c66cc4","parentId":null,"rootId":null,"fromId":3801,"content":"金融IT普本15左右，再高了不好要，仅供参考。","createdAt":"2025-03-27T08:52:52"},{"id":"01963df8-288e-73dc-9531-1687ec2dff88","parentId":null,"rootId":null,"fromId":6939,"content":"15都悬，去的人越来越多了，都开始压价了。","createdAt":"2025-03-27T09:24:22"},{"id":"01963df8-2889-71ef-a139-70820046c573","parentId":null,"rootId":null,"fromId":1398,"content":"感觉It现在北京好多都是招银行的","createdAt":"2025-03-27T15:09:18"},{"id":"01963df8-28d2-735b-baf3-7adebaea1963","parentId":null,"rootId":null,"fromId":1398,"content":"啊Σ(ﾟдﾟ;)","createdAt":"2025-03-27T15:09:28"},{"id":"01963df8-28d6-7255-bf41-67453532b1e9","parentId":null,"rootId":null,"fromId":6939,"content":"你想要多少，我前同事两年多去的差不多5年了也才16。","createdAt":"2025-03-27T15:52:34"},{"id":"01963df8-28dc-70ff-a8db-a746e705b6b9","parentId":null,"rootId":null,"fromId":1398,"content":"15就差不多，那一个月能存多少钱？","createdAt":"2025-03-28T08:31:07"},{"id":"01963df8-28e1-71f0-aa1d-e01e884fc613","parentId":null,"rootId":null,"fromId":6939,"content":"存多少取决你花多少，有房租2000一个月的，有6000一个月的，还有住燕郊每天早上5点赶车的，吃的方面，自己做花费不多，大头在社交聚餐，还有杂七杂八的。北京贵在通勤成本，别的我觉的比济南没多到哪去。","createdAt":"2025-03-28T09:52:09"},{"id":"01963df8-28e5-7089-aa71-02c3762d3fb7","parentId":null,"rootId":null,"fromId":875,"content":"北京一年一百万不想要，我就想一年10万济南","createdAt":"2025-03-30T20:10:28"},{"id":"01963df8-28e9-72b9-9e29-c1c56502fe0e","parentId":null,"rootId":null,"fromId":23085,"content":"boss上看工作经验在3-5年大约在13-15，但是能给到这些的还是保持怀疑态度，我2.5年（从毕业后入职第一份工作算），在北京面了一家上市企业（百度查着是大厂），工资才给到12k，而且五险一金按照北京最低交","createdAt":"2025-04-03T11:17:15"},{"id":"01963df8-2933-7340-85b0-160e5e90390b","parentId":null,"rootId":null,"fromId":6939,"content":"中肯，部分人神话北上广的薪资了，其实北京除去租房成本、通勤成本，比济南多不了多少，主要现在济南是真的不好找工作，可能北京的就业环境会稍微好点，但是人都往北京跑了，就业环境变差也只是时间的问题。","createdAt":"2025-04-07T09:35:03"}]