[{"id":"01963df2-0c9c-721c-b902-c630749734d2","parentId":null,"rootId":null,"fromId":3785,"content":"真是牛逼，我13年毕业北京工资4000","createdAt":"2024-08-05T08:24:08"},{"id":"01963df2-0ce0-707f-94ef-48c9d0ddbfed","parentId":null,"rootId":null,"fromId":7437,"content":"没错，刚交了首付","createdAt":"2024-08-05T09:15:25"},{"id":"01963df2-0d25-72e7-95fb-04afa9d724df","parentId":null,"rootId":null,"fromId":7437,"content":"而且你说少了，公积金100万左右","createdAt":"2024-08-05T09:16:48"},{"id":"01963df2-0d70-7356-be54-02aeae397712","parentId":null,"rootId":null,"fromId":875,"content":"房子都没有，谈生活品质有意义吗","createdAt":"2024-08-05T19:13:23"},{"id":"01963df2-0d79-73cc-952e-421d74bf64b5","parentId":null,"rootId":null,"fromId":5654,"content":"270万的收入没有扣除个人缴纳五险一金的部分、个人所得税、租房吃饭及其他开支\n1.按照双边一共35万的公积金，可以算出平均每月个人支付五险一金部分10年也在35万\n2.个税按平均每月2.25的收入，每月纳税大约在2000左右，10年24万\n3.租房2000、吃饭2000、其他开支1000，生活成本10年60万\n综上，不计算其他大件电子产品和人情支出，手头现金理想的情况是270-35-24-60=151万，再加35万公积金","createdAt":"2024-08-07T10:00:17"},{"id":"01963df2-0dbb-7152-8207-57df4d685cb5","parentId":null,"rootId":null,"fromId":875,"content":"270万没算年终奖，年终奖10年也得有个二三十万吧","createdAt":"2024-08-07T12:43:20"},{"id":"01963df2-0dc0-7183-a9ae-4fce7b9568bb","parentId":null,"rootId":null,"fromId":7124,"content":"只是让矮一点的人也够到上吊的绳子罢了","createdAt":"2024-08-07T17:48:29"}]