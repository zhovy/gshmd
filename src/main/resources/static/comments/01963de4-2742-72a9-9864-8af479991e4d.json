[{"id":"01963de4-27ae-736c-bd29-d0ebc7c9e8d4","parentId":null,"rootId":null,"fromId":1895,"content":"额，你知道为什么招人么？不忙的也不会招人啊。","createdAt":"2023-06-27T11:15:47"},{"id":"01963de4-27f2-7395-9d1b-eb3f2817d460","parentId":null,"rootId":null,"fromId":2197,"content":"刚看到这个公司招网络工程师的，不知道是不是外包","createdAt":"2023-06-27T11:28:52"},{"id":"01963de4-2837-7242-b96c-437097bb6f60","parentId":null,"rootId":null,"fromId":1235,"content":"是联通集成的外包，联通给自己整的一个外包公司给自己招人，在那呆过一段时间，不知道是不是巧合，那段时间加班就挺厉害的，推荐技术组","createdAt":"2023-06-27T14:41:04"},{"id":"01963de4-287c-735a-9730-4b8490f7a63a","parentId":null,"rootId":null,"fromId":1656,"content":"996","createdAt":"2023-06-27T19:05:13"},{"id":"01963de4-28c1-7076-be91-734ac7b402ab","parentId":null,"rootId":null,"fromId":1372,"content":"别去，技术很一般，加班很严重。996是常态。官僚气息严重，加班不只是因为活那么多，而是变态加班。","createdAt":"2023-06-27T19:49:39"},{"id":"01963de4-290f-710e-9fc8-82ef4e91e32c","parentId":null,"rootId":null,"fromId":4374,"content":"朋友以前在那里，欠的加班费还不给。","createdAt":"2023-08-11T16:19:21"},{"id":"01963de4-2957-71c7-a74c-89f77afbc57a","parentId":null,"rootId":null,"fromId":4333,"content":"这个单位出差多，五险一金低，待遇不能超过上一家的工资，如果都不如上一家的工资高，为什么去你这里，你只是个外包，又不是联通编制，真是奇怪，面试要求还挺高，最少两面","createdAt":"2023-09-01T11:49:35"},{"id":"01963de4-299d-7391-9f2c-3b0bd1ac4e9c","parentId":null,"rootId":null,"fromId":21418,"content":"谁知道保时通智家工程师咋样啊？加班严重不。我看还有产品推广销售任务完不成扣钱吗？工资多少不拖欠吗？","createdAt":"2024-07-18T16:42:13"}]