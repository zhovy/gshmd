[{"id":"01963df1-2af4-709c-9c06-0bf98a4dedfe","parentId":null,"rootId":null,"fromId":3341,"content":"你傻逼？不知道先搜一下？评价多得是。垃圾公司","createdAt":"2024-06-25T09:20:43"},{"id":"01963df1-2b37-7104-bf1b-2eaf35844a1a","parentId":null,"rootId":null,"fromId":6380,"content":"https://gshmd.vip/company/689   参照这个","createdAt":"2024-06-25T09:21:33"},{"id":"01963df1-2b7c-73ec-b36c-0ecbe5114bdb","parentId":null,"rootId":null,"fromId":933,"content":"国企轮的到你？","createdAt":"2024-06-25T09:58:58"},{"id":"01963df1-2bc0-713c-b74c-1b913dd03dd0","parentId":null,"rootId":null,"fromId":875,"content":"国企哦，社保公积金全额缴纳嘛，有年终奖吗，有补充医疗保险嘛，有企业年金吗，要是都有，，每天写日报汇报领导二把刀啥的都不算啥","createdAt":"2024-06-25T12:37:49"},{"id":"01963df1-2c09-72f0-a0f2-e1f388d49512","parentId":null,"rootId":null,"fromId":67,"content":"我屮艸芔茻，看见这个公司就来气，当时让我去面试，hr说10~15，见了面一个HR总监还是个什么东西，让我做题，做完了又跟我说不用做，这是给有经验的做的，（我那时候刚毕业），然后问我想要多少钱，我说你们给的这个就可以，然后问我说hr跟我说多少，然后跟我说不可能这么多，面试问的问题，什么买东西，拿了假钱，然后巴拉巴拉找钱，问谁赔钱了，还有三个杯子还是两个杯子倒水的问题，还有一个住店的问题，mdzz，很明显，我现在想起来还生气","createdAt":"2024-06-27T10:30:25"},{"id":"01963df1-2c4e-7051-a887-c2117f0c4c32","parentId":null,"rootId":null,"fromId":5952,"content":"答题这个估计是他们不专业的问题，倒水这种问题考验思维能力的，公务员面试也有可能考，怎么到你这就不乐意了？","createdAt":"2024-06-27T11:36:57"},{"id":"01963df1-2c52-705a-b7fc-cd2d561f414f","parentId":null,"rootId":null,"fromId":5405,"content":"工作氛围不好，天天写日报？","createdAt":"2024-06-27T11:53:39"},{"id":"01963df1-2c56-735b-9063-c74593ed9b1d","parentId":null,"rootId":null,"fromId":4174,"content":"那个撒比也面过我，什么小车拉油能跑多远的问题。。","createdAt":"2024-06-27T17:28:14"},{"id":"01963df1-2c5b-700e-b714-75b6b39d8800","parentId":null,"rootId":null,"fromId":6559,"content":"外协转正什么条件？好转正吗？跟正式差距大不大啊","createdAt":"2024-06-28T09:50:55"},{"id":"01963df1-2ca3-70bb-a13e-3841e2f88fb0","parentId":null,"rootId":null,"fromId":5405,"content":"我也想问 你入职了吗","createdAt":"2024-06-29T12:14:40"},{"id":"01963df1-2ca7-71f8-aa79-c0bf054e72ec","parentId":null,"rootId":null,"fromId":2627,"content":"1. 工资还行，社保公积金都是顶额，而且公积金每年1月调整。另外每个月还有0-3000的奖金\n2. 工作环境还行，有车库、有食堂 ，有饭补 晚上加班餐自助。 \n3. 工作氛围还行，现在的几个领导包括大领导都比较务实\n4. 工作强度还行，晚上吃加班餐要加到8点，但周末不加班。\n总体来说我觉得在济南已经挺好了！","createdAt":"2024-07-18T13:52:36"},{"id":"0198a2c7-971d-70c9-a9b8-15caa7377942","parentId":null,"rootId":null,"fromId":26185,"content":"说是国企，实际上是签外包，有个毛用","createdAt":"2025-08-13T17:34:06"},{"id":"0198e5c4-b9fb-731c-95f5-4ea4b2270e14","parentId":null,"rootId":null,"fromId":6559,"content":"看来是没有转正了","createdAt":"2025-08-26T17:45:31"}]