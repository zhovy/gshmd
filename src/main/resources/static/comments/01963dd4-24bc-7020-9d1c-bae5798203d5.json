[{"id":"01963dd4-2528-735d-95b8-2c5aa1088b5e","parentId":null,"rootId":null,"fromId":185,"content":"知工程是吧\nios第一版是我做的，付佩佩是这个公司最大的蛀虫","createdAt":"2022-03-29T17:12:19"},{"id":"01963dd4-256d-7335-9163-8b74f0ff89bc","parentId":null,"rootId":null,"fromId":321,"content":"上面两个人说的完全没说到自己的问题第一人个面试的吹得啥都会，同一时间进来的人为啥就把你辞退了，自己不反思一下吗？\n第二个人ios第一版还好意思说，别人接手你的东西要当于重新开发的，这像是一个工作四五年的人开发出来的app吗。自己的工作做不好不辞退你们辞退谁","createdAt":"2022-05-10T22:15:31"},{"id":"01963dd4-25b1-7150-a572-fdf0d4723e76","parentId":null,"rootId":null,"fromId":185,"content":"哈哈，技术负责人是个多年的老java，写的东西烂的一批，说他弄错了还非要甩锅。辞退我是因为前端和安卓离职，他把ios ui 测试 产品 全都换成自己熟人，一开始还纳闷新来的同事怎么都这么玩的开，新ios进场我才知道人家是大换血","createdAt":"2023-01-29T11:58:02"},{"id":"01963dd4-25fa-714b-9626-0d7a0cbf5699","parentId":null,"rootId":null,"fromId":185,"content":"接手别人完成的项目还要重新开发，看不懂别人写的，能力也是差的不行","createdAt":"2023-03-17T16:02:14"},{"id":"01963dd4-25f7-71d9-80c2-9e8aa9ee3a8f","parentId":null,"rootId":null,"fromId":1110,"content":"确实心机比较深，不听话就会干掉你，力所能及的干掉你","createdAt":"2023-12-17T14:14:10"},{"id":"01963dd4-265c-73c0-96e1-83639ebfb7a9","parentId":null,"rootId":null,"fromId":1110,"content":"咋说呢，缺少领导该有的胸怀不够大气","createdAt":"2024-01-10T19:32:41"},{"id":"01963dd4-26e9-7107-aa33-1f557442098c","parentId":null,"rootId":null,"fromId":1110,"content":"搞java的技术经理高中毕业，整天就知道拉帮结派，去了就知道了，正经事啥也不干，啥都会点啥都水的一逼，打压下属倒是有一套","createdAt":"2024-08-17T08:17:39"},{"id":"019c086b-2799-7033-abaa-5db048df2cf4","parentId":null,"rootId":null,"fromId":2420,"content":"公司福利支付 还有其他的加班咋样，老板会卡试用期吗","createdAt":"2026-01-29T14:22:46"}]