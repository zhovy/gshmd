[{"id":"01963ddc-957a-7318-8225-3cea1845e637","parentId":null,"rootId":null,"fromId":51,"content":"这公司纯SM ，入职的时候也没说啥试岗期，说去了就是试用期，结果7天以后项目写完了，说我试岗期不合格，纯纯垃圾，那人事还给老板告状","createdAt":"2022-09-21T10:18:22"},{"id":"01963ddc-95be-71e8-aef3-75e7d01f9be7","parentId":null,"rootId":null,"fromId":933,"content":"这公司原先是不是在千佛山那边","createdAt":"2022-09-23T09:12:55"},{"id":"01963ddc-9603-73a9-a3ad-c34403005ea5","parentId":null,"rootId":null,"fromId":1725,"content":"对","createdAt":"2022-09-23T16:33:24"},{"id":"01963ddc-9649-713f-a3b6-1d2523edb325","parentId":null,"rootId":null,"fromId":1876,"content":"这家公司就是靠骗政府的扶持奖金活着，老板和人事是穿一条裤子的垃圾，拖欠工资。公司没几个人所以你得干好几个人的活，加班到12点之后都是经常的事，第二天必须还得准时到，劳动仲裁老板撒泼，说签的合同就是两千块钱，一定要擦亮眼睛别被骗了。","createdAt":"2022-09-29T10:23:11"},{"id":"01963ddc-968f-71d9-b5dc-3bdcfe564318","parentId":null,"rootId":null,"fromId":1876,"content":"这公司有两个名字，一个叫豪创网络，一个叫站站宝，之前在千佛山，现在搬到了舜泰，就是来这边骗政府补助的，专门骗涉世未深的的学生来应付上级检查的，偶尔接的项目做出来也是垃圾，客户都不用，纯纯的骗子，骗员工，骗客户，拿网上开源的东西改数据库，改设计说是自己的，尤其是那个人事，千万别被她骗了，长的挺好的小姑娘没想到是老板的忠实舔狗，她既是人事，也是财务，掌握着你的合同和考勤，呃，想想在那里上了快一年的班，真不知道自己怎么熬过来的。","createdAt":"2022-09-29T10:29:13"},{"id":"01963ddc-96d6-7223-afea-07718ec3d5cf","parentId":null,"rootId":null,"fromId":1876,"content":"给还在这里干的员工提个醒，如果工资拖延发一定要注意了，做好记录，否则很大可能要不出来了。","createdAt":"2022-09-29T10:31:03"},{"id":"01963ddc-971e-70da-b009-09812dfa614d","parentId":null,"rootId":null,"fromId":2377,"content":"金女士吗？","createdAt":"2023-02-13T10:22:17"},{"id":"01963ddc-9766-7138-b0ef-623d1211ae9a","parentId":null,"rootId":null,"fromId":2114,"content":"豪创网络就是个大坑，人事兼财务金女士是老板的小秘，他俩啥关系，猜不透，说不清。不明不白，中午一起吃饭呢还，经常告状。\n项目都是垃圾，没有前景，之前有个大项目干黄了，还给人告了，6。\n老板人品不行，曾经骚扰过女员工，说过一些恶心的话，拒绝以后就给人穿小鞋。恶心至极！！","createdAt":"2023-03-09T15:12:01"},{"id":"01963ddc-97b2-7293-8190-6d6fa3297b11","parentId":null,"rootId":null,"fromId":1876,"content":"这个帖子不能停，得接着喷","createdAt":"2023-04-28T09:28:37"},{"id":"01963ddc-97fa-72ed-ac11-e5f63661ec4a","parentId":null,"rootId":null,"fromId":3479,"content":"刷简历看招技术经理，不敢投了","createdAt":"2023-05-11T10:49:32"},{"id":"01963ddc-984c-7320-84b4-30e5b8afc7f9","parentId":null,"rootId":null,"fromId":1876,"content":"老板和人事是傻逼","createdAt":"2023-05-16T12:39:09"}]