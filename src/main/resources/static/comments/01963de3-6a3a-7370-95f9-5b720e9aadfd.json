[{"id":"01963de3-6aa6-7151-8208-567a9f28b588","parentId":null,"rootId":null,"fromId":2367,"content":"楼主还在这个公司么？更新下目前的状况呗","createdAt":"2024-06-25T15:56:05"},{"id":"01963de3-6aec-72f7-9284-8bd606354d06","parentId":null,"rootId":null,"fromId":3608,"content":"公司半死不活，有项目但是回不来款，公司没钱，报销压半年，工资拖一两个月，有去处尽量别来这","createdAt":"2024-07-18T15:53:46"},{"id":"01963de3-6af4-7089-b0f5-22b840dfc48e","parentId":null,"rootId":null,"fromId":3670,"content":"加班多吗楼主，平时会很忙吗","createdAt":"2024-07-24T09:53:01"},{"id":"01963de3-6af0-73b0-afee-353cf6e1ea9b","parentId":null,"rootId":null,"fromId":2367,"content":"哎 想去也去不了","createdAt":"2024-07-24T10:01:23"},{"id":"01963de3-6b39-72ab-b55c-3b1d9faf9cb5","parentId":null,"rootId":null,"fromId":3608,"content":"1","createdAt":"2024-08-08T14:52:05"},{"id":"01963de3-6b3d-734e-a6c8-5c9984903a2e","parentId":null,"rootId":null,"fromId":3608,"content":"偶尔会加班，但是公司不强制加班，加班有调休，三倍薪资的时候是给加班费，整体来说不会很忙","createdAt":"2024-08-08T14:53:16"},{"id":"01963de3-6b42-7005-8683-3b6a6c96007b","parentId":null,"rootId":null,"fromId":2032,"content":"最近怎么样？招聘还联系我了","createdAt":"2024-08-09T11:23:59"},{"id":"01963de3-6b86-710c-8846-187ea0f9ca01","parentId":null,"rootId":null,"fromId":21948,"content":"有在职的哥哥姐姐吗 现在整体情况如何","createdAt":"2025-03-16T00:55:59"},{"id":"019662ff-225d-733a-b15e-fcdac0e87af4","parentId":null,"rootId":null,"fromId":23682,"content":"我朋友还在这家公司，做监理的公司里面算是比较自由一些的，济南做监理的就那么几家公司。目前工资基本上不算拖欠，偶尔也就是延迟发放一个月（新入职的员工工资会准时发放）。目前好像公司一共二十来个人，现在监理分了两个部门，一个部门大概六七个人。","createdAt":"2025-04-23T22:13:29"},{"id":"019b039d-8dde-725c-825a-93bf7747dd88","parentId":null,"rootId":null,"fromId":27290,"content":"请问楼主还在吗   这家公司还拖欠工资吗？  是不是每周六上午都来上班？","createdAt":"2025-12-09T22:56:55"},{"id":"019b039f-acb7-7382-a62f-7229b6d50c96","parentId":null,"rootId":null,"fromId":27290,"content":"还有在职的哥哥姐姐们吗？想了解一下现在什么情况啦","createdAt":"2025-12-09T22:59:14"},{"id":"019b05e5-d35e-7361-b059-09d0ab91cf95","parentId":null,"rootId":null,"fromId":21575,"content":"评论区里好多洗地的","createdAt":"2025-12-10T09:35:06"},{"id":"019b05ee-f7b4-722a-b7e5-250cee497af2","parentId":null,"rootId":null,"fromId":3608,"content":"雷打不动周六上午上班，主要是开会对项目进度安排下一周工作，工资具体不是很清楚了，应该还是会有拖欠情况，不过应该不会很严重","createdAt":"2025-12-10T09:45:05"},{"id":"019b10b6-8233-71d6-8f7c-8d6ec03514b7","parentId":null,"rootId":null,"fromId":27290,"content":"确实第一次见 每周六上午上班的 公司  是不是一般都驻场  加班狠不狠？","createdAt":"2025-12-12T11:59:14"},{"id":"019b2505-51fa-7252-830e-dc4a10036d59","parentId":null,"rootId":null,"fromId":27290,"content":"他家有招聘了  哈哈一直拖结果 每周六上午开会 也不知道咋样 什么情况 不知道要不要去","createdAt":"2025-12-16T10:37:44"},{"id":"019b25fd-b22f-709e-82ea-0a8b45c0dbc5","parentId":null,"rootId":null,"fromId":3608,"content":"给你面试的叫啥名知道吗，我可以给你问问面试过没过","createdAt":"2025-12-16T15:09:01"},{"id":"019b268d-e7b9-7224-a69d-c6b1548c9e9f","parentId":null,"rootId":null,"fromId":27290,"content":"值得去吗","createdAt":"2025-12-16T17:46:32"}]