[{"id":"01963de1-db0b-706c-bbb3-ed627e813c03","parentId":null,"rootId":null,"fromId":2509,"content":"同问","createdAt":"2023-04-28T08:24:08"},{"id":"01963de1-db57-7189-a2e5-b2e12c43e494","parentId":null,"rootId":null,"fromId":2509,"content":"六险一金 12%全额公积金貌似是这些","createdAt":"2023-04-28T08:25:00"},{"id":"01963de1-dba1-7212-800a-12ac4fe00086","parentId":null,"rootId":null,"fromId":2897,"content":"一天一百补助，也不错啊","createdAt":"2023-04-28T11:31:02"},{"id":"01963de1-dba6-73ec-b17b-b3f7330acbed","parentId":null,"rootId":null,"fromId":2598,"content":"非计算机专业要吗？为啥已读不回啊","createdAt":"2023-04-28T14:30:39"},{"id":"01963de1-dbf8-72ec-bfe9-36181919061f","parentId":null,"rootId":null,"fromId":3117,"content":"总部在北京，做信贷的，创始人啥的都是国外留学过的。济南这边研发全算上目前5到10人，希望招的是能出差的且偏实施的（我猜除了北京外，研发都是类似这种性质），最好有相关业务经验。周末很少加班，平时看自己，一般都加一会。早上9-10点弹性上班，平时加班8点（也可能是9点）有加班餐可以报销，就是流程很麻烦。2楼说的是事实，项目性质的出差是隔一段时间可以回一趟济南","createdAt":"2023-05-06T01:18:35"},{"id":"01963de1-dc64-7105-b053-b8758299ccb9","parentId":null,"rootId":null,"fromId":2897,"content":"平时都加班到八九点吗，不按点下班吗？","createdAt":"2023-05-06T17:04:42"},{"id":"01963de1-dc6a-7185-9e94-3cf6a1ae9690","parentId":null,"rootId":null,"fromId":3117,"content":"看自己，不强制加班，结果导向的","createdAt":"2023-05-06T21:29:58"},{"id":"01963de1-dc6e-725c-ab32-3d125b3a422c","parentId":null,"rootId":null,"fromId":2198,"content":"这些加班情况是出差的作息，还是本地的作息。","createdAt":"2023-05-18T22:50:10"},{"id":"01963de1-dc72-7157-b69c-e737769ba5a9","parentId":null,"rootId":null,"fromId":3117,"content":"肯定是济南的作息了，出差的时候是作为乙方的，具体作息按照甲方大爷的要求了，6点下班的、周末加班的甲方都见过  /苦笑不得","createdAt":"2023-05-24T17:27:31"}]