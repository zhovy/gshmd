[{"id":"01963df2-518b-72bc-8a93-b0118a2d4908","parentId":null,"rootId":null,"fromId":7550,"content":"打错了，东泰那边的外包","createdAt":"2024-08-16T19:07:33"},{"id":"01963df2-51d1-70f9-b5d0-8a89f03c8303","parentId":null,"rootId":null,"fromId":7083,"content":"鲁软啊，你现在来得考安规，90分及格。忙的时候真忙，不忙的时候也有。我记得有待好几年的。不过现在好像不招人了，来的时候记得问清，是人员外包还是项目外包，项目外包谨慎点，项目没了真让你走人！","createdAt":"2024-08-16T20:06:29"},{"id":"01963df2-5219-71b3-8b8e-76b204a8c035","parentId":null,"rootId":null,"fromId":1391,"content":"不是项目外包，一样让你走人，凡是经常招人的公司请远离，以免毁了简历","createdAt":"2024-08-18T21:17:53"},{"id":"01963df2-525e-7022-9a8a-c775ce7479cd","parentId":null,"rootId":null,"fromId":7083,"content":"好像鲁软最近不咋招人了，除了前一阵风控2.0，拼命拉人干活。人员外包咋还有裁员的？不涨工资是真的，但是好像不犯错没有被裁员的吧","createdAt":"2024-08-18T23:34:04"},{"id":"01963df2-5262-7027-8294-44b40c087363","parentId":null,"rootId":null,"fromId":4143,"content":"工作过，加班少，有加班费，项目组人都挺好，工作不忙，有充足的学习时间。一家之言，不同的项目组和不同的事业部可能不一样。入职前和外包公司谈好薪资待遇就行了。项目外包没接触不了解。\n五险一金最低基数，可以和外包公司谈把公积金提高基数（多的自己缴纳，避税）。\n合适时机还想回去，寻找志同道合的小伙伴干项目是我职场的终极目标。","createdAt":"2024-09-09T09:08:04"},{"id":"01963df2-52a7-71f4-8e7a-df5eca825af5","parentId":null,"rootId":null,"fromId":7530,"content":"你不是舔子我真不信","createdAt":"2024-09-21T11:15:30"},{"id":"01963df2-52ab-70e6-9297-03a2c473ae72","parentId":null,"rootId":null,"fromId":6170,"content":"老哥，留个联系方式","createdAt":"2025-02-09T16:31:58"}]