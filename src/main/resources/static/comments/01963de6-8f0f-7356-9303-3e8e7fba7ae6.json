[{"id":"01963de6-8f78-70b1-8d44-4e560363c206","parentId":null,"rootId":null,"fromId":2572,"content":"浪潮数字，领导强制要求加班，95%的领导毛线技术不懂还爱瞎指挥，经常悄无声息的站在员工工位后面监视员工，干啥啥不行，吃饭可积极了。还经常对员工进行人生哲理指导，在员工面前装大牌，拽的跟二五八万似的。","createdAt":"2023-08-19T08:49:29"},{"id":"01963de6-8fbf-7346-adaf-30e28bc12644","parentId":null,"rootId":null,"fromId":2241,"content":"谢谢朋友 这个部门说是从浪潮国际拆出来的 感觉现在浪潮把很多部门拆成了子公司","createdAt":"2023-08-19T09:53:58"},{"id":"01963de6-8fc4-7350-bb3a-07fb28556baf","parentId":null,"rootId":null,"fromId":4152,"content":"楼主去了没？怎么样？","createdAt":"2023-08-23T17:14:53"},{"id":"01963de6-900b-733a-906f-869051f42448","parentId":null,"rootId":null,"fromId":5740,"content":"粮储这个业务浪潮做的挺好的","createdAt":"2023-09-19T21:26:19"},{"id":"01963de6-9051-7314-9f3f-655af2e2e5ab","parentId":null,"rootId":null,"fromId":22541,"content":"好毛线","createdAt":"2024-12-30T12:58:31"},{"id":"01963de6-9055-7121-85d5-af2cb303f891","parentId":null,"rootId":null,"fromId":22541,"content":"别来 非常垃圾的公司 不把员工当人看","createdAt":"2024-12-30T12:58:42"}]