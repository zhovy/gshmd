[{"id":"01963deb-2663-73a0-819c-3c57fd5da1b8","parentId":null,"rootId":null,"fromId":875,"content":"一年10w","createdAt":"2024-02-02T22:47:51"},{"id":"01963deb-26a9-73dd-ade8-f675bcb95dfc","parentId":null,"rootId":null,"fromId":5954,"content":"本地的毕业三年如果不是家里特别困难的，毕业有份工作就可以满足了。如果是外地的，家里再普通点，就不好说了。如果家里特别富有，那就另外说了，有钱嘛，玩两年也正常，各种美女，夜店啥的，再说这种的大多数也不上班吧？","createdAt":"2024-02-02T23:09:42"},{"id":"01963deb-26ee-70d9-887d-570460175697","parentId":null,"rootId":null,"fromId":1398,"content":"你是男孩子还是女孩子","createdAt":"2024-02-03T00:52:27"},{"id":"01963deb-2730-731b-9f08-e0b4743c2eab","parentId":null,"rootId":null,"fromId":1,"content":"刚毕业3年能攒10w就很可以了","createdAt":"2024-02-03T14:53:09"},{"id":"01963deb-2774-7185-b7cf-a79708430132","parentId":null,"rootId":null,"fromId":4357,"content":"22届毕业，到现在才攒了不到三万?","createdAt":"2024-02-04T08:25:34"},{"id":"01963deb-27be-7090-bfa2-afe532a7796e","parentId":null,"rootId":null,"fromId":875,"content":"济南三年有15万，北京三年有30万","createdAt":"2024-02-04T09:21:14"},{"id":"01963deb-2802-7038-9b75-fce58134de90","parentId":null,"rootId":null,"fromId":403,"content":"我刚毕业三年时候（即09年）差不多攒了2W吧，那时候月工资只有1500RMB，买房时候我的钱只够付定金。","createdAt":"2024-02-04T09:41:34"},{"id":"01963deb-2890-7132-a84b-b38965afa622","parentId":null,"rootId":null,"fromId":629,"content":"同三年，手里只有四千多，月光，老家买的房子添了两万那时候，房贷还了一年多得有五万多，攒了一万六的金子，没这些事的话手里也有个八九万，普通家庭没办法，自己能出的自己出了，走一步看一步，工资也不高，攒不住钱还租房子在济南，本事就那些，普通的不能再普通","createdAt":"2024-02-04T10:41:56"},{"id":"01963deb-28e0-7341-bda2-312e21fdc324","parentId":null,"rootId":null,"fromId":3519,"content":"毕业8年手里只有不到一万，还欠银行90多个W","createdAt":"2024-02-04T15:52:18"},{"id":"01963deb-2927-7194-a6fa-c7e8000b6789","parentId":null,"rootId":null,"fromId":6613,"content":"毕业三年，欠银行90多个","createdAt":"2024-02-05T09:31:44"},{"id":"01963deb-2972-730e-9bf2-13961e979e74","parentId":null,"rootId":null,"fromId":4174,"content":"毕业四年，欠银行80个。手里1w","createdAt":"2024-02-05T09:52:43"},{"id":"01963deb-29bf-71ec-b706-972b34a52c9f","parentId":null,"rootId":null,"fromId":4396,"content":"12年毕业做交付，出差挺多，前三年攒了10w。\n现在工资水平比10年前翻了一倍，当然生活成本和消费项目也多多了。\n如果你的目标是攒钱买房、娶妻生子，我认为应该紧衣缩食，每月只花基本开支其他都攒起来。\n如果你比较佛系，也建议你留个应急款，每年存两万，人生无常大肠包小肠，对自己和父母有个交代，虽然交代不多。","createdAt":"2024-02-05T10:26:15"},{"id":"01963deb-28d7-7060-9684-cca3eefc9f17","parentId":null,"rootId":null,"fromId":3219,"content":"你今年多大了","createdAt":"2024-11-20T13:31:03"},{"id":"01963deb-296e-70ad-ba1d-7800c04b877d","parentId":null,"rootId":null,"fromId":3219,"content":"买房首付了多少","createdAt":"2024-11-20T13:31:24"},{"id":"01963deb-29bb-7064-b794-201b9ec65d9a","parentId":null,"rootId":null,"fromId":3219,"content":"买房首付了多少","createdAt":"2024-11-20T13:31:39"},{"id":"01963deb-2923-730e-9188-9e81833e66bd","parentId":null,"rootId":null,"fromId":3219,"content":"买房首付了多少","createdAt":"2024-11-20T13:31:50"},{"id":"01963deb-27b9-70da-a248-2a812de5b90c","parentId":null,"rootId":null,"fromId":22316,"content":"同22届毕业生，我自己攒的刚到四万，家里给了我十几万让我买车，都舍不得买。不过工作之后把平板台式机手机都升级了一遍","createdAt":"2024-11-22T09:47:11"},{"id":"01963deb-28dc-739f-9fe0-1b7d48385992","parentId":null,"rootId":null,"fromId":629,"content":"现在手里有1.4w，一年就攒一万才，我真垃圾","createdAt":"2024-11-22T10:15:19"},{"id":"01963deb-2a77-7010-8f88-2de3d0dff66c","parentId":null,"rootId":null,"fromId":3450,"content":"毕业10年,欠银行200w,手里4000块","createdAt":"2024-11-22T10:27:54"},{"id":"01963deb-2ac0-7082-99c8-9f7d74190f5c","parentId":null,"rootId":null,"fromId":3219,"content":"买房了吗，首付多少","createdAt":"2024-11-22T10:29:44"}]