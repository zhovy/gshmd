[{"id":"01963df6-d6e5-7002-bb1e-d861ad320527","parentId":null,"rootId":null,"fromId":6743,"content":"今年37岁了，不出意外未来五年还能继续干这行。\n找家公司苟着，苟到公司倒闭或者被裁，等到40以后自由择业，保安保洁 黑车司机都行，苟的好说不定多苟两年都是赚的。\n不过一般来说 除非划水比较严重，团队里面占住核心位置，这么多年的经验总比小年轻还是多两把刷子的吧。","createdAt":"2025-02-11T14:31:27"},{"id":"01963df6-d72e-71a5-a261-0a48d2708238","parentId":null,"rootId":null,"fromId":21821,"content":"目前还是java研发吗？方便的话聊一聊，Q我280411714","createdAt":"2025-02-11T14:42:29"},{"id":"01963df6-d73b-7308-af91-08a7d47b4f0e","parentId":null,"rootId":null,"fromId":22256,"content":"我是没房贷车贷的，济南还有3套。我到了35估计手里攒个100w，到时候理财退休就好了","createdAt":"2025-02-11T14:56:33"},{"id":"01963df6-d783-716b-9128-bfa2d52f4a03","parentId":null,"rootId":null,"fromId":21821,"content":"这个比不了0.0......","createdAt":"2025-02-11T14:58:05"},{"id":"01963df6-d787-71f4-b3a0-e6aebb8d4620","parentId":null,"rootId":null,"fromId":21821,"content":"希望前辈能给传授点经验，目前30了，前程迷茫","createdAt":"2025-02-11T14:58:47"},{"id":"01963df6-d7cd-723a-985f-c60e0727cb78","parentId":null,"rootId":null,"fromId":21821,"content":"加Q280411714","createdAt":"2025-02-11T14:58:58"},{"id":"01963df6-d732-7114-bfbb-2f9baaf9daf1","parentId":null,"rootId":null,"fromId":6939,"content":"今年38岁，同意你最后的一句话，除非你太菜、太废、太懒，一般都能在公司混住的，能混多久谁知道呢，趁着还能混住先混着呗。","createdAt":"2025-02-11T16:20:07"},{"id":"01963df6-d737-73f1-a318-4af503ff4cb6","parentId":null,"rootId":null,"fromId":5725,"content":"对，先混着，能多交两年社保多交两年社保","createdAt":"2025-02-11T16:44:14"},{"id":"01963df6-d7d2-730d-bc0c-e6e1ff11701e","parentId":null,"rootId":null,"fromId":3319,"content":"30岁把房贷车贷清掉。干到40多存款，财富小自由，40之后多自由择业即可，多干一天都是赚的","createdAt":"2025-02-11T16:52:03"},{"id":"01963df6-d81f-7374-af0e-1b8ab96b276c","parentId":null,"rootId":null,"fromId":21821,"content":"希望大家有经验没经验的都分享点经验，说不定这些迷茫的人群中能出现一盏指明灯呢","createdAt":"2025-02-11T17:47:27"},{"id":"01963df6-d862-7291-8def-196011062db8","parentId":null,"rootId":null,"fromId":875,"content":"能说会道的转行销售，不善言辞的在济南开店，送外卖，跑滴滴，当中介卖房子，回老家进村委会，回老家包地搞养殖;","createdAt":"2025-02-11T20:15:43"},{"id":"01963df6-d816-