[{"id":"01990ac8-79b5-70b4-84cb-70ca0bc4fb9d","parentId":null,"rootId":null,"fromId":3450,"content":"山大的科研助理是吧，别去，里面所有人都眼高于顶，每个人都会嘲讽你，你也没有真正的休息日，完全是教授的奴隶，随时会给你发消息让你给他干活，工资也到不了10k，没科研经费了，你就是个白打工的","createdAt":"2025-09-02T22:15:34"},{"id":"01990cd4-84b6-711b-9294-569463be998a","parentId":null,"rootId":null,"fromId":2056,"content":"你做过？写的不还有寒暑假吗","createdAt":"2025-09-03T07:47:58"},{"id":"01990cd5-01dd-7059-9eea-bb4018ddbce0","parentId":null,"rootId":null,"fromId":2056,"content":"你跟的哪个老师","createdAt":"2025-09-03T07:48:30"},{"id":"01990d05-5f18-719b-8d39-a20f36126b60","parentId":null,"rootId":null,"fromId":4367,"content":"笑死，这情商别去高校了，人家说的那么具体，你上来就反驳。跟的哪个老师，说出来就能对上人那么隐私的问题，你张嘴就问。","createdAt":"2025-09-03T08:41:19"},{"id":"01990d53-e728-7210-8a00-bb84c10df4c1","parentId":null,"rootId":null,"fromId":1049,"content":"说的很对，习惯性反驳","createdAt":"2025-09-03T10:07:06"},{"id":"01990d5c-9502-7376-841b-aa607fbd23a5","parentId":null,"rootId":null,"fromId":2056,"content":"首先我面试没有感觉到他说的这个问题，四个博士面试，问的问题我都能答上。其次一个学校同姓的老师多了去了，你就能确定能暴露隐私。最后，我面试这个科研组，现在并没有其他助理。","createdAt":"2025-09-03T10:16:35"},{"id":"01990d73-3a4b-73ac-8253-7313b66029d5","parentId":null,"rootId":null,"fromId":2598,"content":"有没有可能是上个助理实在受不了跑路了，然后又招的呢","createdAt":"2025-09-03T10:41:19"},{"id":"01990d73-412b-7146-9bca-a61a8d672d86","parentId":null,"rootId":null,"fromId":23971,"content":"放下助人情节，尊重他人命运","createdAt":"2025-09-03T10:41:21"},{"id":"01990d80-c07b-717d-997b-f0757499bea3","parentId":null,"rootId":null,"fromId":1049,"content":"放下助人情节，尊重他人命运，用户画像已出，到此结束","createdAt":"2025-09-03T10:56:05"},{"id":"01990d8e-503e-7084-8455-c1d3152d9fe6","parentId":null,"rootId":null,"fromId":2233,"content":"有一句话说得好 好言难劝该死的鬼","createdAt":"2025-09-03T11:10:54"},{"id":"01990e0c-f477-7012-98e0-662e8f590b51","parentId":null,"rootId":null,"fromId":23274,"content":"挂着山东大学招聘的那个吗？前两年就在招，也不是新的岗位了，23年的时候面过一次，一言难尽","createdAt":"2025-09-03T13:29:14"},{"id":"01990e2b-e29c-729c-9ad4-37d343ddb4ea","parentId":null,"rootId":null,"fromId":26151,"content":"多余搭理它","createdAt":"2025-09-03T14:03:01"},{"id":"01990e82-b00a-7130-9278-fb210e66f761","parentId":null,"rootId":null,"fromId":3450,"content":"我就干了1个月，根本不是人干的活，里面真不拿你当人看，寒暑假不清楚，我根本熬不到那个时候","createdAt":"2025-09-03T15:37:49"},{"id":"01990f26-48fb-72bf-b613-daacd0538d9c","parentId":null,"rootId":null,"fromId":22724,"content":"大学一般不会对外招聘科研助理，除非学校的学生都不乐意当了","createdAt":"2025-09-03T18:36:31"},{"id":"019912a3-67a0-71d1-8d5f-096906157cf0","parentId":null,"rootId":null,"fromId":22702,"content":"哈哈哈 你可算说到重点了 那么多大学生可都是免费廉价劳动力","createdAt":"2025-09-04T10:52:02"}]