[{"id":"01963ddc-bd75-72e1-a133-115ae5690c39","parentId":null,"rootId":null,"fromId":1781,"content":"叼毛公司天天有，长见识","createdAt":"2022-09-30T14:41:35"},{"id":"01963ddc-bdbb-72cf-83da-8bfc32fe971a","parentId":null,"rootId":null,"fromId":771,"content":"去面试过，研发一共仨人，面试官说话感觉都不利索","createdAt":"2022-10-01T16:24:09"},{"id":"01963ddc-be0b-70c2-a7d2-5ad39e9e23ab","parentId":null,"rootId":null,"fromId":880,"content":"就算干了一天，离职了，也需要支付工资，如果不给，直接打劳动执法大队电话即可，很快可以解决哦","createdAt":"2022-10-03T18:46:29"},{"id":"01963ddc-be66-7183-99bc-27b1848e9d4e","parentId":null,"rootId":null,"fromId":1857,"content":"2楼你幸好没去，说起面试官来了，这个姓张的技术领导，就是纯SB，没见这么这么装B的，天天耀武扬威，对员工呼来焕去。他应该是有生理期，好的时候对你很好，坏的时候就跟欠他钱式的，没个好脸。","createdAt":"2022-10-11T10:18:03"},{"id":"01963ddc-bee3-7308-861a-3fb49e589219","parentId":null,"rootId":null,"fromId":1780,"content":"那个面试官说话确实不利索  有个面试题问我linkedlist是单链表还是双链表 我说双链表 面试官说 这种基础问题你都能错 是单链表","createdAt":"2022-10-11T11:35:41"},{"id":"01963ddc-bf2b-713f-b3ce-3e8766445693","parentId":null,"rootId":null,"fromId":2572,"content":"1.试岗期7天，试岗期不过，一分钱没有；\n2.试用期3个月，不给交社保，没有五险一金，试用期发工资通过微信转账，不通过银行卡；\n3.每天写日报，忘记交的话，一次扣10元；周末写周报，忘记交的话，一次扣20元；\n4.每天要打扫卫生，卫生不合格，扣钱；\n5.每个月有两次听混沌大学的直播课，还让考试，考不过，扣钱；\n6.工资拆成好几部分，全勤奖包含在工资里面，但凡这个月请一分钟假，没有全勤，工资会被扣；\n7.团建必须参加，不参加，团建几天，扣几天工资。","createdAt":"2023-02-17T13:49:38"},{"id":"01963ddc-bf6f-7245-819d-4dfa2d4000ff","parentId":null,"rootId":null,"fromId":2613,"content":"能不能展开说说这家公司","createdAt":"2023-03-21T10:47:53"},{"id":"01963ddc-bfba-7342-970b-5d0d69019f28","parentId":null,"rootId":null,"fromId":2613,"content":"据了解是个坑比的公司","createdAt":"2023-03-21T11:05:29"},{"id":"01963ddc-bfff-73a3-a197-5a94e2b6b278","parentId":null,"rootId":null,"fromId":3889,"content":"天天加班  试用期不过 会说别的部门不让过 就是逼着你走 天天耀武扬威 说话十分难听 全凭他心情 迟到一次就一天工资   出了问题就推卸责任  用完你就辞退你  各种办法让你自己走","createdAt":"2023-06-25T10:48:18"},{"id":"01963ddc-c044-72b8-90f1-3e7a0f5f1979","parentId":null,"rootId":null,"fromId":2613,"content":"我在那，那个技术出身的领导确实跟傻逼，感觉很坏，我负责前端，经常跟他争论没必要的东西","createdAt":"2023-07-14T08:32:21"},{"id":"01963ddc-c049-710a-8296-12c606e2bad2","parentId":null,"rootId":null,"fromId":2572,"content":"它确实坏到极点了，一个项目让从数据库结构重新设计，到业务开发，到前端接口，给一周的时间。它是不是叫张cj？","createdAt":"2023-07-14T08:48:21"},{"id":"01963ddc-c04d-72ff-8598-79abe4f18a54","parentId":null,"rootId":null,"fromId":2572,"content":"它确实坏到极点了，一个项目让从数据库结构重新设计，到业务开发，到前端接口，给一周的时间。它是不是叫张cj？","createdAt":"2023-07-14T08:48:36"},{"id":"01963ddc-c050-7154-bd96-25af3f8dd914","parentId":null,"rootId":null,"fromId":2613,"content":"对，不知道为什么这么坏，估计是之前被虐太狠","createdAt":"2023-07-28T18:48:52"},{"id":"01963ddc-c058-7377-bfec-509f1d54ff8d","parentId":null,"rootId":null,"fromId":2613,"content":"破公司就特么两个开发，并且对人要求还挺高","createdAt":"2023-08-07T16:23:08"},{"id":"01963ddc-c054-733f-ac1e-874251ff414e","parentId":null,"rootId":null,"fromId":2572,"content":"它叫张成基，那就是个傻X","createdAt":"2023-09-08T08:40:55"},{"id":"01963ddc-c09d-702b-bcc7-64cb332cac6b","parentId":null,"rootId":null,"fromId":3727,"content":"领导又怂又SB，只会窝里横，对自己部门的员工吆五喝六的，和欠他钱的一样，天天不给好脸，对别的部门的员工，各种舔，和他dad似的。面试的时候说话磕磕巴巴的，还感觉自己牛逼轰轰的，试用期也是，一般都是7天了和你说不合适，也不给工资，工资也是给拆的七零八碎的，各种考核，去了上班天天加班没有加班费就算了，迟到一分钟，除了扣全勤还扣工资，一次好几百，各种坑，总之领导SB,公司SB,人事的胖大姐更SB","createdAt":"2023-10-26T18:19:25"},{"id":"01963ddc-c0e2-7263-b03f-4aaddf446459","parentId":null,"rootId":null,"fromId":2572,"content":"那个傻X领导是不是叫张成基？","createdAt":"2023-10-30T10:22:59"},{"id":"01963ddc-c0e7-7251-813c-088aaa3b099f","parentId":null,"rootId":null,"fromId":1857,"content":"看来大家对张XX的人品，都有目共睹","createdAt":"2024-01-09T19:16:19"},{"id":"01963ddc-c12b-70d4-8987-5da965d8750b","parentId":null,"rootId":null,"fromId":2572,"content":"那王八蛋没啥人品，顶多叫狗品","createdAt":"2024-10-17T09:29:47"}]