[{"id":"0199132a-8961-71ab-95e3-5f32ff6d8cb9","parentId":null,"rootId":null,"fromId":22250,"content":"浪潮出了名的加班多，B事多，不要去，就看着浪潮倒闭就行了","createdAt":"2025-09-04T13:19:38"},{"id":"01991362-35cf-7114-bfe9-6808313cf335","parentId":null,"rootId":null,"fromId":25332,"content":"谢邀，刚从软件科技跑路，只能说加班看项目，长期出差必不可少，我走之前是全员2年没调薪没年终了","createdAt":"2025-09-04T14:20:27"},{"id":"019913e6-df5c-7178-ad7c-4c1c49be7b1b","parentId":null,"rootId":null,"fromId":3381,"content":"只能说浪潮没有不加班的，不加班的就不是浪潮，名义上领导不提倡加班实际全是义务劳动","createdAt":"2025-09-04T16:45:21"},{"id":"019913ed-89df-70c9-a835-39c06b78154f","parentId":null,"rootId":null,"fromId":23605,"content":"这年头有份工作能正常给钱就不错了 条件还几把这么多","createdAt":"2025-09-04T16:52:38"},{"id":"01991400-c29e-70d5-8ea3-1817db62d88e","parentId":null,"rootId":null,"fromId":25106,"content":"感谢感谢","createdAt":"2025-09-04T17:13:38"},{"id":"01991401-d375-7302-becb-2fb9c990b777","parentId":null,"rootId":null,"fromId":25106,"content":"好的好的，我也接受加班，毕竟现在找工作不容易，就是想了解一下情况","createdAt":"2025-09-04T17:14:48"},{"id":"01991402-037a-710d-900b-4b68e5d7a85f","parentId":null,"rootId":null,"fromId":25106,"content":"哈哈哈哈了解了","createdAt":"2025-09-04T17:15:00"},{"id":"0199141e-d187-70f0-8663-de6ec3c1e6b4","parentId":null,"rootId":null,"fromId":1538,"content":"欢迎你加入加班浪潮","createdAt":"2025-09-04T17:46:28"},{"id":"019917ad-3edf-73ff-8d35-f5a8a7fe3e01","parentId":null,"rootId":null,"fromId":2246,"content":"以前听过浪潮软件，软件科技是什么东西。","createdAt":"2025-09-05T10:20:53"},{"id":"0199315f-a7b6-7101-9c8a-19a90480b324","parentId":null,"rootId":null,"fromId":21986,"content":"那不叫加班，那叫主动贡献度。浪潮现在效益严重下滑，整体在裁员。好多低学历的老员工，生怕自己被裁，主动加班，主动贡献。你不主动贡献，立马给你评级C，走人","createdAt":"2025-09-10T10:06:16"},{"id":"01993319-5041-7371-8386-36a49f114c44","parentId":null,"rootId":null,"fromId":1552,"content":"加班多，逼事多，社招的更是难，没有人情味。会甩锅，不在乎的可以来，毕竟这破行情，有人要给工资就不错了。","createdAt":"2025-09-10T18:08:41"}]