[{"id":"01963df7-f55b-722d-ac17-7ef1104c2238","parentId":null,"rootId":null,"fromId":2598,"content":"老哥是前端吗，在华强广场？\n让你去公司了没，我去面试直接在一个4楼的外边平台聊的","createdAt":"2025-03-20T17:39:07"},{"id":"01963df7-f5a0-737e-b6e9-2cdfc625e1c7","parentId":null,"rootId":null,"fromId":1490,"content":"都跟你说啥了，不知道靠不靠谱？说现在搞个新团队，年前的团队都有的被裁了。有的离职了。这个到底靠不靠谱啊？？","createdAt":"2025-03-20T19:13:46"},{"id":"01963df7-f5a5-73be-adf5-109e2fb43808","parentId":null,"rootId":null,"fromId":2598,"content":"说是目前有一个前端要离职，然后组件个团队，一个后端然后招两个前端，我也打怵呢，不知道靠不靠谱，是不是给你说做婚恋平台的，第一个月不给交社保","createdAt":"2025-03-20T19:36:28"},{"id":"01963df7-f5a9-7247-b85c-d9a76a826e0c","parentId":null,"rootId":null,"fromId":1490,"content":"你先去看看，试试万一行呢，单双休，又是压榨劳动力啊，要是工资可以的话，主要是稳定，不稳定的话就多要钱不然也没别的办法","createdAt":"2025-03-20T21:36:45"},{"id":"01963df7-f5ad-70d7-b24a-87ff85e895a2","parentId":null,"rootId":null,"fromId":2598,"content":"哈哈哈，你是前端吗","createdAt":"2025-03-20T21:44:25"},{"id":"01963df7-f5b2-7385-b4e1-c7f96f001fc5","parentId":null,"rootId":null,"fromId":1490,"content":"是的，后端也会，只不过用前去找，全栈真的很傻逼，一分钱两个活，你是后端？","createdAt":"2025-03-21T09:20:32"},{"id":"01963df7-f5b6-7185-a54a-0caabe0b20ed","parentId":null,"rootId":null,"fromId":254,"content":"很着急让人入职 还有什么试岗期","createdAt":"2025-03-24T17:50:39"},{"id":"01963df7-f603-719b-90bb-8cf3b2702059","parentId":null,"rootId":null,"fromId":22699,"content":"1.拖欠工资，公司实际掌权人为失信人，2005年开始就是老赖，失信人执行网可查。\n\n2.公司运营混乱，管理出纳出身，什么也不懂，按自己意愿做事。\n\n3.市中万达有车位，已被法院查封，根本卖不出去。\n\n之前有人评论~不保证真实性","createdAt":"2025-03-26T17:02:44"},{"id":"01963df7-f5ff-7382-ab6f-7070fe436a16","parentId":null,"rootId":null,"fromId":2598,"content":"去了吗老哥","createdAt":"2025-03-26T17:16:28"}]