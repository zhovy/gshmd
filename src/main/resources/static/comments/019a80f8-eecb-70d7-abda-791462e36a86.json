[{"id":"019a8163-2a30-7231-9324-f227cb18cc77","parentId":null,"rootId":null,"fromId":22250,"content":"新冠疫苗之后生病的人越来越多\n药越来越贵\n保健品死贵，大爷大妈被坑的起飞","createdAt":"2025-11-14T16:02:31"},{"id":"019a828d-8525-7334-b932-0e045383480d","parentId":null,"rootId":null,"fromId":21302,"content":"那咋了，只要大爷大妈白花花的退休金消费了就行，钱流通起来我们才能喝点汤","createdAt":"2025-11-14T21:28:24"},{"id":"019a82dc-928c-71e5-9b2f-0ea4c4f530fa","parentId":null,"rootId":null,"fromId":2408,"content":"去药店买药，亲眼看见药店忽悠老年人买100多的钙片，哎","createdAt":"2025-11-14T22:54:44"},{"id":"019a8c42-3f2d-71eb-980f-7b9abe1707ca","parentId":null,"rootId":null,"fromId":875,"content":"别光说老年人，换个机油，200多，又被忽悠说时间到了，公里数到了的时候换火花塞和刹车油，花了500多，途虎业绩今年也得井喷吧","createdAt":"2025-11-16T18:42:23"},{"id":"019a8f53-f617-705e-80cd-76a89046c49a","parentId":null,"rootId":null,"fromId":22250,"content":"不要看时间，看里程数，超过5000公里再换","createdAt":"2025-11-17T09:00:35"}]