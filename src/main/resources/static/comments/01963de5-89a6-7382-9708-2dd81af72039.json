[{"id":"01963de5-8a15-72c0-84b9-0e9c6d8fcd83","parentId":null,"rootId":null,"fromId":4172,"content":"标题打错了，是14k","createdAt":"2023-07-27T17:40:45"},{"id":"01963de5-8a5b-71e1-98ed-ec56db66b11e","parentId":null,"rootId":null,"fromId":4172,"content":"年终奖很少","createdAt":"2023-07-27T17:42:12"},{"id":"01963de5-8a9f-737c-8c44-0c09e84a0c61","parentId":null,"rootId":null,"fromId":875,"content":"社保公积金全额缴纳嘛，不全额缴纳工资有点低了","createdAt":"2023-07-27T20:18:12"},{"id":"01963de5-8ae8-72f1-a717-4802bfec2598","parentId":null,"rootId":null,"fromId":875,"content":"5年至少15k","createdAt":"2023-07-27T22:04:32"},{"id":"01963de5-8b36-724a-b51d-fdb08f6d39c2","parentId":null,"rootId":null,"fromId":875,"content":"值不值得去，就是跳槽嘛，留在现在的公司技术有提升吗？每年有涨薪吗？去新公司发展前景大嘛，如果只是涨一千块不值当的，不如继续狗到年底看看，跳槽至少涨两千块，往涨三四千块要","createdAt":"2023-07-27T22:31:54"},{"id":"01963de5-8b7f-7190-a9c5-5603e2bb8fda","parentId":null,"rootId":null,"fromId":4196,"content":"一般般吧","createdAt":"2023-07-28T10:43:14"},{"id":"01963de5-8bc4-70c1-b109-f996d41bf9dc","parentId":null,"rootId":null,"fromId":3333,"content":"如果不加班不出差的话，性价比还是可以的，现在行情不好，5年14正常水平，前几年可以要到15，16","createdAt":"2023-07-28T11:38:24"},{"id":"01963de5-8c0e-70a3-978f-bbe4efbbe992","parentId":null,"rootId":null,"fromId":3333,"content":"今年没跳槽的别瞎几把说了，知道现在什么行情吗，外面招聘的大部分都是外包，自研的岗位很少，有一两个岗位几十人上百人应聘，今年环境比疫情三年还差，不管是外包还是自研，工资都比前几年少了1-2K，很多5年以上的老选手跳槽都得平薪或者降薪了","createdAt":"2023-07-28T11:44:22"},{"id":"01963de5-8b31-73c0-9e94-24d278acbae1","parentId":null,"rootId":null,"fromId":3706,"content":"外包？","createdAt":"2023-07-28T14:13:39"},{"id":"01963de5-8c54-7010-b1a0-4c575cbf2bf0","parentId":null,"rootId":null,"fromId":4142,"content":"去北京会好点么","createdAt":"2023-07-28T14:16:25"},{"id":"01963de5-8c5d-70de-8774-34264c9e34b1","parentId":null,"rootId":null,"fromId":875,"content":"干开发是没有钱途的，销售提成1.5～2个点，一年搞个一千万的单子，提成轻松二十万，再加上底薪，济南软件销售普遍年入二三十万","createdAt":"2023-07-28T21:23:34"},{"id":"01963de5-8cae-71f1-9e30-a2108255ca31","parentId":null,"rootId":null,"fromId":1656,"content":"想去就去，确实少点","createdAt":"2023-07-30T17:49:36"},{"id":"01963de5-8ca5-709a-821c-1668ac84cc26","parentId":null,"rootId":null,"fromId":4057,"content":"你到处在说销售赚钱,你转吧","createdAt":"2023-07-31T09:11:39"},{"id":"01963de5-8caa-7300-bc15-dcea031fe152","parentId":null,"rootId":null,"fromId":1751,"content":"你是亲身经历还是道听途说。。。。。","createdAt":"2023-07-31T11:31:12"},{"id":"01963de5-8cf7-7369-b74b-0832738ad9e9","parentId":null,"rootId":null,"fromId":2890,"content":"太少了，济南5年正常水平15k吧，还要全额公积金那种，自己算算总包，达不到这个数都属于偏低","createdAt":"2023-08-01T19:48:32"},{"id":"01963de5-8c59-720e-bce0-4f906125be1b","parentId":null,"rootId":null,"fromId":4010,"content":"北京裁员很厉害，听在北京的同学说的，各大厂从去年开始都在大幅裁","createdAt":"2023-08-04T16:50:33"},{"id":"01963de5-8d5c-71fb-99ee-753451a8fea0","parentId":null,"rootId":null,"fromId":2890,"content":"同意","createdAt":"2023-08-13T16:33:36"}]