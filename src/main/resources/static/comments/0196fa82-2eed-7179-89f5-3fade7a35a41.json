[{"id":"0196fa90-4141-7152-b7fc-c97e0a6ba9c2","parentId":null,"rootId":null,"fromId":460,"content":"这个岁数正当年啊 可以的 去试试吧","createdAt":"2025-05-23T08:34:40"},{"id":"0196faa6-a1ed-71eb-b244-4d4b7082047d","parentId":null,"rootId":null,"fromId":23971,"content":"才工作三年你怕啥","createdAt":"2025-05-23T08:59:06"},{"id":"0196faad-4766-72d6-8c0f-34b1f562338f","parentId":null,"rootId":null,"fromId":1372,"content":"很合适，工作几年要是觉得不合适，刚三十出头，再调整也来得及。","createdAt":"2025-05-23T09:06:22"},{"id":"0196fae3-2f1e-7037-8070-e638c143a395","parentId":null,"rootId":null,"fromId":24162,"content":"刚从北京回来，可以去，考虑长远一点。赚快钱？定居？干几年后下面的规划。。是回来还是坚持一直干。。。也可以不想 哈哈哈  总得来说工资上北京高一点，支出租房是大头（要么容忍通勤时间住远一点）其他差不多。。。","createdAt":"2025-05-23T10:05:14"},{"id":"0196fae6-d0e3-73c5-b49c-2eae8b514d7d","parentId":null,"rootId":null,"fromId":5725,"content":"快去吧，别卷我们这些离不开济南的人了","createdAt":"2025-05-23T10:09:12"},{"id":"0196fb0b-b180-714c-8ef8-24169f252a60","parentId":null,"rootId":null,"fromId":7566,"content":"请问除了租房以外其余的支出和济南真的都差不多吗？","createdAt":"2025-05-23T10:49:29"},{"id":"0196fb0d-c0ae-7148-b272-4f5b02ddab30","parentId":null,"rootId":null,"fromId":7566,"content":"就卷你们，就卷你们","createdAt":"2025-05-23T10:51:44"},{"id":"0196fb1b-faf4-729f-a2c5-3244601e5f6e","parentId":null,"rootId":null,"fromId":2246,"content":"二十六七相当合适啊，干个七八年","createdAt":"2025-05-23T11:07:17"},{"id":"0196fb40-0573-7247-ae31-d782ef1e69c6","parentId":null,"rootId":null,"fromId":21742,"content":"如果无牵无挂的 去就是","createdAt":"2025-05-23T11:46:39"},{"id":"0196fb45-eeae-7063-8505-415fafcd5d32","parentId":null,"rootId":null,"fromId":24162,"content":"举个例子比济南差别大的。。","createdAt":"2025-05-23T11:53:06"},{"id":"0196fbe6-3f11-73ee-b924-77efd38296ed","parentId":null,"rootId":null,"fromId":23531,"content":"那边吃饭我感觉差不多，你像昌平这种地方小盒饭常见的外卖都有，和济南点外卖差不多。通勤我之前是昌平到海淀，地铁四五块好像，具体忘了。租房你要是自己一个人租个开间，基本一千三四，带卫生间和空调。我个人体验来讲最大的问题是人太多了，早上坐地铁都不是有没有座位的问题，是能不能挤上地铁的问题","createdAt":"2025-05-23T14:48:12"},{"id":"0196fbeb-6bce-7149-866d-39266e8f0aa0","parentId":null,"rootId":null,"fromId":23531,"content":"在公司周围吃午饭的话，要贵一些。之前我那边自选贵很多，套餐的话面啊、炒饭啊之类的一般二十四五吧。","createdAt":"2025-05-23T14:53:51"},{"id":"0196fc3a-734e-73d7-b250-07194aad8659","parentId":null,"rootId":null,"fromId":24162,"content":"比起工资差距这个真不算啥。","createdAt":"2025-05-23T16:20:11"},{"id":"01970f55-64e6-73ec-a0a1-716d73dd5a56","parentId":null,"rootId":null,"fromId":24504,"content":"good","createdAt":"2025-05-27T09:22:24"},{"id":"0197112a-6f98-7075-bcc5-958ad3d06c25","parentId":null,"rootId":null,"fromId":24535,"content":"这个年纪正壮年适合去，北京是一个适合赚钱，生活气息少一些的地方，北京很包容，房租会贵一些。没成家有baby的话自己怎么都好说，现在你的年纪也不大。但成家有孩子继续呆在北京就会很困难，因为孩子带来生活成本的指数级增加、需要有人照顾baby还有家庭关系会迎来质的变化。所以如果近五年没有生子打算就建议去","createdAt":"2025-05-27T17:54:43"},{"id":"01971476-fc59-704b-bdeb-210828863864","parentId":null,"rootId":null,"fromId":7566,"content":"可是父母也要求我早点在济南结婚生孩子，我也算是比较传统的人，所以很纠结","createdAt":"2025-05-28T09:17:11"},{"id":"01975920-d0bb-7253-9ac4-de2e34851612","parentId":null,"rootId":null,"fromId":23974,"content":"可以加微信交流一下","createdAt":"2025-06-10T17:16:52"},{"id":"01976102-926d-7289-880b-eab64ee22fa5","parentId":null,"rootId":null,"fromId":25017,"content":"我也想去北京闯闯，一般工资翻多少倍合适","createdAt":"2025-06-12T06:00:47"},{"id":"01976174-794a-70ea-9b44-041141cd0dbe","parentId":null,"rootId":null,"fromId":1261,"content":"一般两倍，也得看现有工资，现在1W，北京给到2W以上才考虑，现在2W，北京也很难给到4啊","createdAt":"2025-06-12T08:05:12"},{"id":"01976195-0964-72a6-8c19-06476c2a3482","parentId":null,"rootId":null,"fromId":460,"content":"我也想去北京闯闯，一般工资翻多少倍合适","createdAt":"2025-06-12T08:40:46"},{"id":"01979bac-fbf1-72b4-9cc9-8ffc513cb18e","parentId":null,"rootId":null,"fromId":7566,"content":"您好，请问您的QQ号或vx号是多少呢？","createdAt":"2025-06-23T15:24:54"}]