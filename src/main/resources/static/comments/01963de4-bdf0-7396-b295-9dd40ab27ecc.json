[{"id":"01963de4-be54-704a-8598-cd251349e770","parentId":null,"rootId":null,"fromId":3198,"content":"打电话问社保局，不比在这儿问靠谱且高效吗","createdAt":"2023-07-10T14:59:17"},{"id":"01963de4-be98-71b7-b034-b876b2f270bd","parentId":null,"rootId":null,"fromId":576,"content":"你直接去实体办公地点问专职人员比在这里问要更清晰，去民政大厅或者12345咨询，就注意两点，人家周六周日是不上班的，可能你一趟不一定能办成。","createdAt":"2023-07-10T15:25:42"},{"id":"01963de4-bedd-712e-b411-37d694c351ff","parentId":null,"rootId":null,"fromId":1,"content":"没啥影响，就2个月的没缴没事。超过3个月，生大病医院报销就得第二年了好像。\n\n另外补充：\n3种办法\n\n1、如果你缴纳社保（失业保险）超过一年及以上，离职原因不是个人，可以申请失业保险（济南一个月应该1850）。领取失业保险期间你的医疗保险失业中心会帮你缴纳。（只有医疗保险）\n2、灵活就业，去当地的街道办事处登记灵活就业就可以在支付宝、微信里自己缴纳医疗养老保险了。\n3、找代缴公司。","createdAt":"2023-07-10T15:52:42"},{"id":"01963de4-bf27-71f6-9c75-1078392b4231","parentId":null,"rootId":null,"fromId":875,"content":"无忧保代缴","createdAt":"2023-07-10T20:44:26"},{"id":"01963de4-bf6b-732f-ad19-6a2f1a3cbcc5","parentId":null,"rootId":null,"fromId":1656,"content":"无所谓","createdAt":"2023-07-11T00:59:33"},{"id":"01963de4-bfb0-71b8-8143-0d1866a96f6f","parentId":null,"rootId":null,"fromId":875,"content":"济南退休金比北京深圳少一半哦，代缴北京社保","createdAt":"2023-07-11T07:32:55"}]