[{"id":"01963deb-b09f-71f8-b2df-0a22b732fd8d","parentId":null,"rootId":null,"fromId":6613,"content":"之前面试过，类似于移动的外包，公司好像不差钱，开的工资都挺高，不过上班时间挺早的，8点就开始上班，有食堂管饭","createdAt":"2024-02-27T15:02:36"},{"id":"01963deb-b0e3-7191-84f0-34fe6a863889","parentId":null,"rootId":null,"fromId":6631,"content":"谢谢回复了，，给我开的工资好低呀，我看招聘上写的薪资范围7-12k，给我的都不到10k。哎，好犹豫呀。","createdAt":"2024-02-27T17:41:48"},{"id":"01963deb-b0eb-71da-8231-a3707b4a2df9","parentId":null,"rootId":null,"fromId":1398,"content":"几年经验啊？","createdAt":"2024-02-28T00:48:45"},{"id":"01963deb-b0e8-7182-9328-991dd6a35036","parentId":null,"rootId":null,"fromId":6613,"content":"多对比对比","createdAt":"2024-02-28T09:07:10"},{"id":"01963deb-b130-72c2-bd59-9151dc116720","parentId":null,"rootId":null,"fromId":6446,"content":"不到10k可以了，20年刚成立济南开发部的时候，我们都是8k，但有个安全工资挺高，不过我们那批人基本上都走了。管饭而且劳保，反正我那几年没买过洗漱用品和米面粮油哈哈哈。总结：养老可以","createdAt":"2024-02-28T15:13:22"},{"id":"01963deb-b177-716f-a50d-65bfe2b01e5c","parentId":null,"rootId":null,"fromId":5954,"content":"开发工作难不难，经常加班吗？","createdAt":"2024-02-28T15:15:54"},{"id":"01963deb-b180-72a0-93b5-e06d70e78687","parentId":null,"rootId":null,"fromId":1730,"content":"22年面试的时候，4年工作经验才给到8还是9，有点忘记了。但是公积金社保好像是最低档的","createdAt":"2024-02-29T15:24:05"},{"id":"01963deb-b1ca-713c-89c5-de650512d2aa","parentId":null,"rootId":null,"fromId":4305,"content":"楼主你好 几年经验 不到10k？","createdAt":"2024-03-04T09:20:43"},{"id":"01963deb-b17c-7232-83cd-22abf50c8852","parentId":null,"rootId":null,"fromId":6631,"content":"谢谢回复了。我已经放弃了，当时非常非常的纠结，因为距离我住的地方特别近，可以步行过去；有管饭和劳保；如果不考虑薪资，真的是非常不错的地方；虽然加班情况不知道；养老估计是不可以的，因为和第三方签合同，所以是有期限的；接了一个外包的offer，多出来的薪资可以覆盖好多劳保和饭钱以及交通费；终究还是个爱财的俗人；","createdAt":"2024-03-04T13:35:52"},{"id":"01963deb-b1c5-7281-9c35-62c2ccf767c5","parentId":null,"rootId":null,"fromId":6631,"content":"嗯，公积金挺低的。","createdAt":"2024-03-04T13:36:55"},{"id":"01963deb-b20e-73f7-a601-3c5633e32a8b","parentId":null,"rootId":null,"fromId":6631,"content":"囧，6年多的经验了。哈哈哈哈。。。。偶尔真想离开济南，但是又忍受不了离家的痛苦，唉，就这样吧，走一步看一步吧。","createdAt":"2024-03-04T13:38:31"},{"id":"01963deb-b214-70ff-a2a2-19871a195808","parentId":null,"rootId":null,"fromId":1110,"content":"兄弟请问你入职了吗我也收到了确实低","createdAt":"2024-03-05T07:57:22"}]