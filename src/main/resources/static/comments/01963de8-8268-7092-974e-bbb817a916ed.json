[{"id":"01963de8-82d2-731b-8164-8ce0bcbf5ae7","parentId":null,"rootId":null,"fromId":5792,"content":"另外学历是山东省属院校，双非本科","createdAt":"2023-09-23T15:21:38"},{"id":"01963de8-8318-701c-8afb-80c56f450274","parentId":null,"rootId":null,"fromId":3493,"content":"14","createdAt":"2023-09-23T16:11:43"},{"id":"01963de8-835d-734d-a5d7-959eee9194bd","parentId":null,"rootId":null,"fromId":875,"content":"外包是最低基数社保，公积金每月200吧，那的确有点少啊，5年Java得15K，最低基数社保公积金的话，全额社保公积金可以是12K。","createdAt":"2023-09-23T18:20:31"},{"id":"01963de8-83a3-7107-9979-9af1d4eafc2e","parentId":null,"rootId":null,"fromId":875,"content":"总监一年50万，经理级别一年30万，开发一年20万就是顶，你说怎么办","createdAt":"2023-09-24T19:52:59"},{"id":"01963de8-83e9-7211-a94d-7ad6709c3d4e","parentId":null,"rootId":null,"fromId":576,"content":"以本科为前提。你的公司要是参与投标国家项目，那你可以要个15k（不是到手）。要是不参与，12，,13k（不是到手）。996就是15k，855就是10k。","createdAt":"2023-09-25T09:14:59"},{"id":"01963de8-842c-7221-899c-4e50e0365ee0","parentId":null,"rootId":null,"fromId":1372,"content":"软考在一般私企没啥用。国企和事业单位另说。主要还是看个人实力。5年一般在 10-15之间吧。","createdAt":"2023-09-25T17:43:34"},{"id":"01963de8-8472-734f-a667-ac323f714271","parentId":null,"rootId":null,"fromId":508,"content":"软考证书有啥用，在应聘或工作中有用到吗","createdAt":"2023-09-26T08:46:41"},{"id":"01963de8-84c0-7260-83c8-eef94ffae09e","parentId":null,"rootId":null,"fromId":5820,"content":"上家18","createdAt":"2023-09-27T10:33:50"},{"id":"01963de8-84bc-7242-8905-b61e107f57d3","parentId":null,"rootId":null,"fromId":5792,"content":"好点的公司能给点补贴，大部分也就是跳槽时会优先考虑罢了，一毛不拔","createdAt":"2023-09-27T21:17:52"},{"id":"01963de8-8506-71a6-ad8e-df8b095510dc","parentId":null,"rootId":null,"fromId":403,"content":"疫情前兴许能要到15，现在感觉要不到，加班多的另说。我做开发十七年了，在一个效益不错的公司做技术负责人，依然在写代码，只能拿17，优点是朝九晚五，保证双休，社保基数高，再就是自由度高，比较人性化，公司发展前景好。我前一家工资是22，但综合来说对现在的环境十二分满意。","createdAt":"2023-10-05T17:30:53"},{"id":"01963de8-8550-7292-a8ac-867c7b27f693","parentId":null,"rootId":null,"fromId":4014,"content":"还招人吗","createdAt":"2023-10-12T21:54:48"},{"id":"01963de8-8554-708c-ba41-85124a271d9b","parentId":null,"rootId":null,"fromId":7071,"content":"还招人吗","createdAt":"2024-04-01T19:26:16"},{"id":"01963de8-8559-72b5-a76c-6f4b14cfd7f2","parentId":null,"rootId":null,"fromId":7087,"content":"还招我吗","createdAt":"2024-04-01T22:05:45"},{"id":"01963de8-855d-7043-a86c-e30b3ea56609","parentId":null,"rootId":null,"fromId":1049,"content":"还招人吗，大佬","createdAt":"2024-04-02T11:06:43"},{"id":"01963de8-8561-7005-8172-0e559c8c093e","parentId":null,"rootId":null,"fromId":3024,"content":"高速外包怎么去呀","createdAt":"2024-04-09T09:50:06"}]