[{"id":"01963dd2-890b-71a2-ac23-a59bddabcab3","parentId":null,"rootId":null,"fromId":1164,"content":"这个公司姓催的技术，吊的一批，人品有问题","createdAt":"2022-07-29T12:57:40"},{"id":"01963dd2-8956-7273-a7ef-863606225c8a","parentId":null,"rootId":null,"fromId":2158,"content":"薪酬咋样，加班严重吗","createdAt":"2022-11-12T00:15:55"},{"id":"01963dd2-899c-7069-a9da-6b96ee9b46e5","parentId":null,"rootId":null,"fromId":4375,"content":"大佬们，面试问的是什么内容呢","createdAt":"2023-08-21T14:10:28"},{"id":"01963dd2-89e1-72bc-b95d-e64391749a50","parentId":null,"rootId":null,"fromId":1150,"content":"这种破地方不去也罢","createdAt":"2023-08-22T08:47:21"},{"id":"01963dd2-8a26-70e4-b943-e9949d454356","parentId":null,"rootId":null,"fromId":5579,"content":"面试过，没要我","createdAt":"2023-09-06T12:21:37"},{"id":"01963dd2-8a69-7092-a25c-11a6167a4bfe","parentId":null,"rootId":null,"fromId":5579,"content":"碰上面试的人还挺好，但是工资挺低，平均低20%吧，想去但是人家没要。\n咋说呢，要是零几年的时候，齐鲁晚报如日中天时，像我这种屌丝根本就甭想，虽然现在没落了，但还是想着进去体验下?","createdAt":"2023-09-06T12:27:00"},{"id":"01963dd2-8a6e-7228-9d7d-375420fae022","parentId":null,"rootId":null,"fromId":5737,"content":"是正式员工吗？还是外包？","createdAt":"2023-10-02T19:07:55"},{"id":"01963dd2-8af7-727c-a42e-fbeb0e0364bc","parentId":null,"rootId":null,"fromId":7533,"content":"看正式员工还是外包，正式员工在技术部门的话还是很不错的，在当下这个环境看，比济南大部分公司要强多了；外包的话就不了解了","createdAt":"2025-03-01T17:18:08"},{"id":"01963dd2-8950-73e2-a69f-cc8d3702b0c3","parentId":null,"rootId":null,"fromId":7533,"content":"不同人不同看法吧，这东西本身主观性就很强","createdAt":"2025-03-01T17:19:12"},{"id":"019bdfcc-ebe3-73ad-ae03-1dd0114c9f4a","parentId":null,"rootId":null,"fromId":557,"content":"技术中心主任，是技术总监吗？还是技术部门的经理？","createdAt":"2026-01-21T17:05:07"}]