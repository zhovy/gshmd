[{"id":"01978b19-50a7-7280-8e8a-2f4685aaaa43","parentId":null,"rootId":null,"fromId":7270,"content":"起码简历上可以写本科，我觉得对于小公司多少有点用处。","createdAt":"2025-06-20T10:09:41"},{"id":"01978b1e-9cec-720d-8009-dab48426a278","parentId":null,"rootId":null,"fromId":6091,"content":"有总比没有强","createdAt":"2025-06-20T10:15:28"},{"id":"01978b24-f186-708d-ac3d-d4fe5763d330","parentId":null,"rootId":null,"fromId":23959,"content":"学信网可查吗","createdAt":"2025-06-20T10:22:23"},{"id":"01978b28-58db-71b7-a3be-20fbdbc902b4","parentId":null,"rootId":null,"fromId":21742,"content":"有比没有强","createdAt":"2025-06-20T10:26:06"},{"id":"01978b34-d8d3-7202-9be3-a5fefb6b949d","parentId":null,"rootId":null,"fromId":22186,"content":"对于评职称可能有点用","createdAt":"2025-06-20T10:39:45"},{"id":"01978b3b-ea08-72e3-91a6-326b79e0a0c4","parentId":null,"rootId":null,"fromId":24615,"content":"小公司有用，毕竟自己可以说是本科，并且学信网可查。大公司没用，人家看第一学历","createdAt":"2025-06-20T10:47:29"},{"id":"01978b57-e41e-72a2-8f88-944d78ea214f","parentId":null,"rootId":null,"fromId":23274,"content":"大公司没用，因为都看统本。小公司也没用，小公司没那么看重学历，大专能力强也是可以的。","createdAt":"2025-06-20T11:18:02"},{"id":"01978b70-fdaf-71aa-808c-8afff0bb9997","parentId":null,"rootId":null,"fromId":24009,"content":"你干不过统招本科，但是你能干过那些专科呀。\n另外你能做ERP吗？现在工资多少？\n我快离职了，我们公司可能要招新人。","createdAt":"2025-06-20T11:45:27"},{"id":"01978b7e-397d-7117-95a3-c10a1d0d1844","parentId":null,"rootId":null,"fromId":1372,"content":"有比没有强。函授本科你付出的仅仅是考一次试，一年两三千块钱的学费而已。毕业是国家承认的学历，那帮狗日的公司和HR承认不承认那就是见仁见智了。","createdAt":"2025-06-20T11:59:54"},{"id":"01978c2e-e020-719d-9a24-37612c14ca37","parentId":null,"rootId":null,"fromId":508,"content":"评职称有用，考研有用，落户有用，内推有时候有用。找工作没用，函授能进的公司，统招大专一般也能进。","createdAt":"2025-06-20T15:12:51"},{"id":"01978cdf-4927-72bb-bb0c-22bd3082450d","parentId":null,"rootId":null,"fromId":1099,"content":"能做的哥们，公司名叫啥，能内推吗","createdAt":"2025-06-20T18:25:32"},{"id":"01979aac-25db-7218-8be7-99c0e3c18406","parentId":null,"rootId":null,"fromId":1039,"content":"同产品，经历过大小公司，小公司有用，大公司会看第一学历，进不来","createdAt":"2025-06-23T10:44:22"},{"id":"0197a08d-7b2d-700b-9ac6-c57d3b53e23b","parentId":null,"rootId":null,"fromId":24009,"content":"抱歉了哥们，这公司不招人了；\n走的还剩俩个技术在这维护维护系统，没啥前途了。","createdAt":"2025-06-24T14:08:36"}]