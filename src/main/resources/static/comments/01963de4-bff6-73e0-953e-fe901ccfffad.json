[{"id":"01963de4-c068-719d-826e-6542e1f85ed3","parentId":null,"rootId":null,"fromId":1164,"content":"..伟业这类的公司一般都是家族企业，擅长这类斗争的伙计可以尝试一下，说不定就跟对老板了","createdAt":"2023-07-10T14:59:21"},{"id":"01963de4-c0ae-73d1-8e39-61ec3ed220e3","parentId":null,"rootId":null,"fromId":2946,"content":"还有这种说法？","createdAt":"2023-07-10T15:51:55"},{"id":"01963de4-c0b3-728c-8808-d4fbc6f9e644","parentId":null,"rootId":null,"fromId":3112,"content":"混口饭吃 ，家族不家族无所谓 ，打工人而已","createdAt":"2023-07-11T08:34:14"},{"id":"01963de4-c0c0-7215-b707-d15e819684d6","parentId":null,"rootId":null,"fromId":414,"content":"我想知道的是是否拖欠工资，加班情况，氛围啥滴","createdAt":"2023-07-11T08:55:20"},{"id":"01963de4-c103-711c-8e2c-76d93d34bf03","parentId":null,"rootId":null,"fromId":3059,"content":"绩效考核玩死你，就这么说吧，你不是领导层，你百分百被扣钱，人都走两波了，经理都跑了，我走的时候就5个人了，河北大于北京大于济南，是的，济南分公司就是最底层，背锅就是你，加班那不是常事么，氛围嘛，人都换两波了，氛围现在啥样还真不知道","createdAt":"2023-07-11T14:19:02"},{"id":"01963de4-c108-7181-818b-1149466337e3","parentId":null,"rootId":null,"fromId":3059,"content":"艹，看错公司了，回复错了，同智伟业也一般般，养老还行，跟浪潮干活的","createdAt":"2023-07-11T14:20:40"},{"id":"01963de4-c10c-72cc-95b6-e6403480d075","parentId":null,"rootId":null,"fromId":3828,"content":"这是哪个公司啊?","createdAt":"2023-07-11T15:36:32"},{"id":"01963de4-c111-71c7-b7f7-93e6232655d1","parentId":null,"rootId":null,"fromId":3828,"content":"这是哪个","createdAt":"2023-07-11T15:37:00"},{"id":"01963de4-c0b7-7291-bee4-fbdc69844c68","parentId":null,"rootId":null,"fromId":4087,"content":"不是亲戚 又不是亲信  混口饭吃就行  现在中高层都被大批中孚离职的占据管理位置  ","createdAt":"2023-07-16T01:04:18"},{"id":"01963de4-c115-73bf-ad18-c2a084f5dbf2","parentId":null,"rootId":null,"fromId":3667,"content":"我目前就在这家公司，现在公司拖欠公司，刚发5月份的工资，6月份的工资还欠着呢，基本就是欠一个月，各种扣钱，绩效每个月都要扣，各种坑，最好是别来，已经走很多人了。","createdAt":"2023-07-17T10:21:53"},{"id":"01963de4-c15a-7250-8583-98316c43b1c3","parentId":null,"rootId":null,"fromId":4087,"content":"3楼说的对，很多老员工全都走了。","createdAt":"2023-08-07T10:20:51"},{"id":"01963de4-c15f-7306-9f2d-539e978a03cb","parentId":null,"rootId":null,"fromId":4087,"content":"干了很久的老员工 不涨工资 不给年终奖 当然亲信除外 不走就这样","createdAt":"2023-08-15T18:26:07"},{"id":"01963de4-c163-71d5-9bbe-06675a4d3ec9","parentId":null,"rootId":null,"fromId":2127,"content":"三天一大调整，两天一小调整，折腾你，你死不死。","createdAt":"2023-08-24T15:57:01"},{"id":"01963de4-c167-73a7-a231-18d13661f6cb","parentId":null,"rootId":null,"fromId":2127,"content":"劳动法在这个公司就是个der","createdAt":"2023-08-24T15:59:35"},{"id":"01963de4-c16b-71db-a406-3a8dc428e993","parentId":null,"rootId":null,"fromId":4087,"content":"9月份  10月份的工资都没发。","createdAt":"2023-10-09T11:53:49"},{"id":"01963de4-c0bc-73cc-ab0c-9b8f803bb3ec","parentId":null,"rootId":null,"fromId":5909,"content":"认可，好多中高层位置被中孚占据着，之前中孚裁员，好多去了同智伟业，中孚的人去面试，工资能给开的很高，非中孚的人去面试，工资也就那么一丢丢，但公司整体还可以，从中孚出来的可以考虑下同智伟业，毕竟里面有熟人好办事。","createdAt":"2023-10-12T18:46:12"},{"id":"01963de4-c174-734b-8901-d84b314fdd02","parentId":null,"rootId":null,"fromId":4087,"content":"过年过节，还背着大部分员工，只给嫡系发红包。过节礼物都是员工只发一份 ，私下里再给亲信发双份。说好全员都不发年终奖，但是私下聚会小群里发红包。给几个小人涨工资。 不要怪员工离心离德，看看自己做的那些恶心事，还说都是员工的不是。","createdAt":"2023-10-13T16:39:01"},{"id":"01963de4-c1b9-728e-8ef8-aea1fb3eb0f7","parentId":null,"rootId":null,"fromId":5983,"content":"玩的挺花啊，一直以为都没有呢....","createdAt":"2023-10-21T17:36:08"},{"id":"01963de4-c16f-7075-8384-a36a7ab1c7b6","parentId":null,"rootId":null,"fromId":4087,"content":"忽悠员工上市IPO  其实就是为了集资套现离场    最后肯定都兑现不了 股票和集资基本上都是废纸了","createdAt":"2024-04-18T11:36:11"},{"id":"01963de4-c1bd-73af-bf74-6efe58c96ba4","parentId":null,"rootId":null,"fromId":6880,"content":"这个月到底发不发工资啊 要吃土了","createdAt":"2024-04-18T16:27:31"},{"id":"01963de4-c202-7336-9518-40b88d2e3549","parentId":null,"rootId":null,"fromId":4087,"content":"要是发了 你们岂不是不会主动离职 还要给补偿 所以不发了 你们自己走什么都省了。","createdAt":"2024-04-18T16:43:04"},{"id":"01963de4-c207-70b7-ad03-a8cbae970a52","parentId":null,"rootId":null,"fromId":6221,"content":"你们只知道你们没发，但你们不知道有人发","createdAt":"2024-04-19T17:33:54"},{"id":"01963de4-c24d-73f3-90b4-dd416e408d73","parentId":null,"rootId":null,"fromId":5768,"content":"别阴谋论了","createdAt":"2024-04-19T22:10:13"},{"id":"01963de4-c251-72c2-a6f2-ad0f41a7d316","parentId":null,"rootId":null,"fromId":6404,"content":"最近这个公司咋样了，也不见有消息呢，听说政府行业部的销售总监没了？","createdAt":"2024-09-11T14:09:05"},{"id":"01963de4-c299-7302-a7bc-f907519ba52a","parentId":null,"rootId":null,"fromId":5768,"content":"好 快来","createdAt":"2024-09-13T09:53:44"},{"id":"01963de4-c29d-70a1-9f5f-7a95ce761a11","parentId":null,"rootId":null,"fromId":22523,"content":"离职的那批人结算的工资都开始拖欠喽","createdAt":"2024-12-26T14:48:00"}]