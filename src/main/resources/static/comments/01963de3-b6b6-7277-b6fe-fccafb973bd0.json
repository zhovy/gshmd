[{"id":"01963de3-b719-71af-b79e-ee6f7024f228","parentId":null,"rootId":null,"fromId":333,"content":"啥情况也不说 给啥意见","createdAt":"2023-06-13T17:27:24"},{"id":"01963de3-b761-70d0-b4a1-bfd18c21110b","parentId":null,"rootId":null,"fromId":875,"content":"嫌济南找工作难的，去北京呀，前端技术好的至少两万起步","createdAt":"2023-06-13T17:52:49"},{"id":"01963de3-b7ab-7297-b9b1-663212f1bd22","parentId":null,"rootId":null,"fromId":1039,"content":"应届生985起招，非应届生5年工作经验起招，薪资1.3以下     这就是济南好点公司的现状","createdAt":"2023-06-13T18:04:23"},{"id":"01963de3-b7f9-731e-900e-63c56bf9abc5","parentId":null,"rootId":null,"fromId":576,"content":"我这刚好有老板想组建团队，如果我过去的话，现在应该就是缺个前端了。","createdAt":"2023-06-13T19:00:14"},{"id":"01963de3-b7f0-72ad-92bd-3fdbf70b8eff","parentId":null,"rootId":null,"fromId":2324,"content":"我不明白985211为啥不得留在济南","createdAt":"2023-06-14T09:14:34"},{"id":"01963de3-b85b-7097-bf67-38926fc29316","parentId":null,"rootId":null,"fromId":3475,"content":"1、改简历（HR第一眼看的是在线简历，所以在线简历也要好好改）\n2、上魔法（如果因为工作经验不多，缺少面试机会，直接包装）\n3、背面试题（面试造飞机，工作拧螺丝，这台正常了。）","createdAt":"2023-06-14T09:18:43"},{"id":"01963de3-b7a7-7332-a5e7-0c2be3ee9361","parentId":null,"rootId":null,"fromId":557,"content":"你阴阳怪气什么啊，北京的行情就好了？？你nt一个。","createdAt":"2023-06-14T15:00:32"},{"id":"01963de3-b7f4-728c-ad16-2c2013eb596a","parentId":null,"rootId":null,"fromId":875,"content":"怎么可能。我们公司招了一个毕业生，不是985211，但是工资也给到一万了，私企，容易的很，前提得是长的好看，男的长的得像小鲜肉符合人力老阿姨的审美，女的得前凸后翘，符合经理们的审美口味。","createdAt":"2023-06-19T19:00:14"},{"id":"01963de3-b8a3-7285-9495-e4c1bb118e9c","parentId":null,"rootId":null,"fromId":875,"content":"找到了吗","createdAt":"2023-06-19T22:12:36"}]