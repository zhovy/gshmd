[{"id":"01963dee-4aa6-72d7-890f-80126a42cb49","parentId":null,"rootId":null,"fromId":1049,"content":"好好好","createdAt":"2024-04-26T08:23:33"},{"id":"01963dee-4aee-7354-b1cb-058f62e7fde1","parentId":null,"rootId":null,"fromId":3853,"content":"外卖也这么卷？？？？？","createdAt":"2024-04-26T08:56:07"},{"id":"01963dee-4b33-7113-a52c-825357b7ef19","parentId":null,"rootId":null,"fromId":576,"content":"好一个外卖小能手","createdAt":"2024-04-26T09:42:47"},{"id":"01963dee-4b77-7341-b0f2-b1283117c2c6","parentId":null,"rootId":null,"fromId":4174,"content":"此刻已成艺术","createdAt":"2024-04-26T10:42:00"},{"id":"01963dee-4bbc-7336-9fa8-2969e19b071e","parentId":null,"rootId":null,"fromId":403,"content":"送个外卖还问算法题 ，美团有病吗？","createdAt":"2024-04-26T14:57:19"},{"id":"01963dee-4bff-71cf-a8a7-01b2e5efb4f4","parentId":null,"rootId":null,"fromId":6623,"content":"《讲一下锂电池工作原理》","createdAt":"2024-04-26T16:21:30"},{"id":"01963dee-4c50-70fd-b0f6-a57b5b870ea5","parentId":null,"rootId":null,"fromId":7319,"content":"外卖这样子卷？","createdAt":"2024-04-26T16:59:39"},{"id":"01963dee-4c96-7037-87ba-652d4a14039a","parentId":null,"rootId":null,"fromId":5444,"content":"不是哥们，真有人以为这是外卖会问的啊(￣▽￣)\"","createdAt":"2024-04-26T20:43:46"},{"id":"01963dee-4cdb-71a6-a8ba-6fa8a366ae35","parentId":null,"rootId":null,"fromId":561,"content":"面试官：看了你的简历，了解到你有两年半的送外卖经验，可以简单说下平时是怎么送外卖的吗？\n我：我首先在平台上接单，然后到店里取餐，取到餐后骑电动车到顾客留下的地址，再通知顾客取餐。\n面试官：你们也用电动车来配送啊，那能说一下电动车的运行原理吗？\n我：电动车的工作原理是通过锂电池释放存储的电能，经过电控系统将电能转化为电动机的机械能，然后电动机驱动电动车的机械结构，从而推动电动车行驶。\n面试官：锂电池是怎么把化学能转化为电能的呢？锂电池化学成分以及反应方程式有了解过吗？\n我：这个不太了解。\n面试官：没关系，平时有空应该多研究电动车的底层实现，这样才能提升送外卖水平。对了，你们平时开什么品牌的电动车？\n我：我们平时用雅迪电动车，还有深远电动车。\n面试官：我们团队用的是小刀电动车，看来我们的技术栈不太匹配，这次面试就到这里吧，我们过两天会通知您面试结果。","createdAt":"2024-04-28T15:26:21"},{"id":"01963dee-4d20-70b3-ada4-c6ff39bb0cda","parentId":null,"rootId":null,"fromId":4037,"content":"哥们  你也是个闲的蛋疼的牛人","createdAt":"2024-04-28T15:41:54"},{"id":"01963dee-4d24-7305-aa1b-d478a425e550","parentId":null,"rootId":null,"fromId":5725,"content":"我还是入职饿了么吧","createdAt":"2024-04-28T16:01:03"}]