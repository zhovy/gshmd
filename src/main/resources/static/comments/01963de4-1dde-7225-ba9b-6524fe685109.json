[{"id":"01963de4-1e40-7137-b1e5-2a5217509daf","parentId":null,"rootId":null,"fromId":875,"content":"国核哈哈哈，是不是招不到人了，一年从头到尾都在招人，给的工资低，还是外包，说什么委托直管以后能转正我是不信，也就社保公积金基数全额缴纳，餐补多点，出差也多点，不怕的可以去试试，编制你想都不要想","createdAt":"2023-06-26T18:24:39"},{"id":"01963de4-1e88-72c6-841f-af11833cc581","parentId":null,"rootId":null,"fromId":2598,"content":"外包五险一金最近基数。。。\n出差很多嘛？加班咋样","createdAt":"2023-06-26T18:46:25"},{"id":"01963de4-1ece-719f-85cf-a82a00f6b8e0","parentId":null,"rootId":null,"fromId":875,"content":"你外包最低基数？外包难道还分好几种？主营风电光伏，出差多不多你说呢","createdAt":"2023-06-26T19:24:26"},{"id":"01963de4-1ed2-738a-8b3e-1b8128152a71","parentId":null,"rootId":null,"fromId":460,"content":"我面过试 给的工资巨底 压工资 所以我没去 工资超低 编制你就别想了 我发现你们怎么老想好事？要是有这种好事 还能轮到老百姓？","createdAt":"2023-06-27T08:36:36"},{"id":"01963de4-1f17-709c-9e2b-b367cb6395d6","parentId":null,"rootId":null,"fromId":576,"content":"老百姓是牛马吗?","createdAt":"2023-06-27T10:48:01"},{"id":"01963de4-1f1b-716c-91bb-c45392f7ad4f","parentId":null,"rootId":null,"fromId":875,"content":"说的对，压工资是真的，给的工资巨低，还是外包，编制就别想了，都是骗人的","createdAt":"2023-06-27T11:55:45"},{"id":"01963de4-1f1f-724d-8e1a-c79fd0e5e26b","parentId":null,"rootId":null,"fromId":113,"content":"老百姓不是牛马，老百姓是生产队的驴","createdAt":"2023-06-27T13:09:56"},{"id":"01963de4-1f24-7362-98ab-3aae629a484d","parentId":null,"rootId":null,"fromId":460,"content":"你也不想想，你家里要是有门路，家里有当官的，还漫无目的的找工作面试吗？在编制的人，绝大多数是不靠工资的，包括刚毕业的小孩。靠工资生活的，都是特别优秀的人。想想烟厂，油厂，电厂，各种局，各种央企 国企。。。。。。。","createdAt":"2023-06-27T13:50:50"},{"id":"01963de4-1f28-7059-bf6a-7593c225d89f","parentId":null,"rootId":null,"fromId":460,"content":"我说的是有编制的","createdAt":"2023-06-27T13:51:28"},{"id":"01963de4-1f2c-723e-ae8c-7e06305ad0eb","parentId":null,"rootId":null,"fromId":1164,"content":"原来是外包？？那面试的那个货看着屌屌的，什么玩意","createdAt":"2023-07-03T09:07:28"},{"id":"01963de4-1f71-7324-a5f5-d927b12891d8","parentId":null,"rootId":null,"fromId":2613,"content":"之前也遇到那个面试官很叼跟傻逼，工资又低傻逼才去呢","createdAt":"2023-08-03T10:29:55"},{"id":"01963de4-1f75-722c-9925-d79705ea56b1","parentId":null,"rootId":null,"fromId":4014,"content":"面试的啥职位呀","createdAt":"2023-08-04T00:39:21"},{"id":"01963de4-1e84-723c-9dbe-f8ef5bdce771","parentId":null,"rootId":null,"fromId":4014,"content":"您好，还想问下，国核这边薪资待遇大概什么水平啊，搞技术，七八年经验","createdAt":"2023-08-07T17:15:10"}]