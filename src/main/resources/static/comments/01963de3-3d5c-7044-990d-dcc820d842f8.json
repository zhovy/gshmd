ntId":null,"rootId":null,"fromId":3138,"content":"薪资压的确实低","createdAt":"2023-06-08T17:07:49"},{"id":"01963de3-3f52-739d-88f2-719c6f5cf261","parentId":null,"rootId":null,"fromId":4016,"content":"改名了，奥维数字科技有限公司","createdAt":"2023-07-12T22:17:47"},{"id":"01963de3-3f9a-7076-92d8-49094b62f8c9","parentId":null,"rootId":null,"fromId":4376,"content":"我是17年在公司待过，外包转内部，在顺泰广场的总部还不错，氛围挺好，尤其是项目经理张晨，人很好，技术也很好。几个总经理也不错，待遇上13薪水，人事也都挺好。\n但是外包的就分情况了，反正外包到国电的带我的人太他妈垃圾了，一个男的戴眼镜，不高，叫高啥来，妈的，只知道让人干活，干不出来还嘲笑新人，什么东西，里面的女的嗲声嗲气的，哎呦受不了，30好几的人了。架构师。算法人都挺好。\n","createdAt":"2023-08-12T17:25:51"},{"id":"01963de3-3fe0-7259-8aef-a2a76ddb654e","parentId":null,"rootId":null,"fromId":4253,"content":"现在改名了，叫奥维数字科技有限公司","createdAt":"2023-08-21T14:34:41"},{"id":"01963de3-3e09-7127-a76f-3401b2847b51","parentId":null,"rootId":null,"fromId":5424,"content":"怎么样，楼主去了吗？","createdAt":"2023-08-25T10:15:01"},{"id":"01963de3-4028-703c-9cb2-24c2adeed72d","parentId":null,"rootId":null,"fromId":2408,"content":"薪资压的很低是多少？","createdAt":"2024-06-02T09:00:46"}]