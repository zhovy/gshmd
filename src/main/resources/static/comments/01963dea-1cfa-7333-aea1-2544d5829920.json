[{"id":"01963dea-1d5f-71c4-9dca-701f292f90b9","parentId":null,"rootId":null,"fromId":1401,"content":"帝都大概什么工资水平呢？","createdAt":"2023-12-13T16:52:15"},{"id":"01963dea-1da5-72b7-93fc-007130708300","parentId":null,"rootId":null,"fromId":875,"content":"工资翻倍，社保公积金全额缴纳","createdAt":"2023-12-13T19:22:57"},{"id":"01963dea-1da9-711c-bce8-77791506fe7d","parentId":null,"rootId":null,"fromId":1948,"content":"帝都啥公司","createdAt":"2023-12-14T08:59:29"},{"id":"01963dea-1df3-71d9-a7d5-a7d95beb7c01","parentId":null,"rootId":null,"fromId":3219,"content":"日常开销大吗？房租多少","createdAt":"2023-12-14T09:22:53"},{"id":"01963dea-1e37-724d-b237-0ae2bf8999c3","parentId":null,"rootId":null,"fromId":3754,"content":"工资翻倍倒不至于，北京也没有社保公积金给全额缴纳的。字节、搜狐什么的可能会有，这个不清楚。\n19-21年的时候住在昌平消费不算大，现在住在朝阳，消费贵的一批。","createdAt":"2023-12-14T09:54:46"},{"id":"01963dea-1e7c-709c-8085-65dcc73da63b","parentId":null,"rootId":null,"fromId":4140,"content":"几年经验，现在在帝都收入什么水平，之前什么水平，五险一金什么情况？","createdAt":"2023-12-14T10:19:19"},{"id":"01963dea-1ec1-738e-8cd6-f86a36ad6103","parentId":null,"rootId":null,"fromId":875,"content":"2周离职，与HR的入职沟通有很大的关系；\n3个月内离职，与不能适应工作与工作内容本身有关；\n6各月离职，与直接上级有关；\n2年左右离职，与企业文化有关；\n3至5年离职，与晋升空间受阻有关；\n5年以上离职，与厌倦与进步速度不平衡有关。","createdAt":"2023-12-15T22:21:00"},{"id":"01963dea-1f06-731f-8670-d1eaeaaae6bf","parentId":null,"rootId":null,"fromId":2408,"content":"大厂还是小厂？现在北京环境如何？","createdAt":"2023-12-15T22:52:59"},{"id":"01963dea-1f4d-72c0-bdb3-fb351ef99e03","parentId":null,"rootId":null,"fromId":6307,"content":"我刚从帝都回来，你却去了帝都","createdAt":"2023-12-18T22:04:41"},{"id":"01963dea-1f91-724e-b79a-ea7cc4c93f9c","parentId":null,"rootId":null,"fromId":3754,"content":"消费都差不多，但是济南环境太差了，钱少事多。","createdAt":"2023-12-25T14:22:29"},{"id":"01963dea-1f96-71bb-9719-02b29384287a","parentId":null,"rootId":null,"fromId":3395,"content":"我同学吵着要回来，我吵着要出去。。有点迷了","createdAt":"2023-12-26T16:19:24"}]