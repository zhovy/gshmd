[{"id":"01963ddd-f819-71b7-b772-11b51ad3f5ce","parentId":null,"rootId":null,"fromId":1712,"content":"好像常年招人 一般","createdAt":"2022-12-26T13:47:42"},{"id":"01963ddd-f85e-71b1-9f53-e84f85b601fe","parentId":null,"rootId":null,"fromId":3500,"content":"有人知道这个公司吗","createdAt":"2023-09-09T11:25:06"},{"id":"01963ddd-f8a2-70d9-8d11-0dd894b75baf","parentId":null,"rootId":null,"fromId":6196,"content":"大佬，去这个公司了吗？说是大小周","createdAt":"2023-11-29T09:21:41"},{"id":"01963ddd-f8a7-73d3-a936-241a63b98e41","parentId":null,"rootId":null,"fromId":6677,"content":"是的 我一个朋友在那 大小周","createdAt":"2024-02-19T16:06:34"},{"id":"01963ddd-f8ec-7334-9db1-5a9b18a6f7ee","parentId":null,"rootId":null,"fromId":6842,"content":"大小周","createdAt":"2024-03-01T15:48:33"},{"id":"01963ddd-f933-73d3-bc92-799eaab69e17","parentId":null,"rootId":null,"fromId":6842,"content":"大小周，好像总部在聊城，老板要求特别多，天天要求员工朋友圈转发广告。\n1、强制要求每天都转发广告到朋友圈，违反者罚款200\n2、强制要求每个月在公司商城上刷单三次，违反者罚款200\n3、强制要求每天直播2小时推广公司平台，节假日也要直播，违反者每日扣100\n4、经常性加班，没有工作也要在那耗着，每月统计加班时长，领导根据表现评绩效。\n5、年终奖直接取消，并要求每个月从部门中选出20%员工，扣除其全部绩效工资。\n总之，朋友说他们老板想让马儿跑，又想让马儿不吃草。","createdAt":"2024-03-01T16:00:35"},{"id":"01963ddd-f97c-717a-99bc-b2b044dcd3ca","parentId":null,"rootId":null,"fromId":3500,"content":"在这刚离职的表示层主说的没错","createdAt":"2024-04-22T13:30:01"},{"id":"01963ddd-f98e-735d-9c26-6179227b8716","parentId":null,"rootId":null,"fromId":21159,"content":"刚刚面试这家公司的运维工作，从头到尾在问你以前公司实现的架构，用到的服务器的配置，k8s用的版本，nacos用的啥版本，elk日志收集怎么收集的，监控怎么做的，中间过程还问了下 查看服务器磁盘命令，内存命令 我笑了 ，整体过程不像是在招人 像是在白嫖你，面试完后 问人力咋样 然后告诉我基础不过关不适合，就问了2条不是运维都知道命令 然后我告诉我基础不过关。大家注意点吧","createdAt":"2024-06-26T16:54:45"},{"id":"01963ddd-f9d5-7379-a15b-16f988a5068e","parentId":null,"rootId":null,"fromId":21273,"content":"有什么想说的吗","createdAt":"2024-07-04T14:51:16"},{"id":"01963ddd-fa19-70a9-8fde-e01c6b27802d","parentId":null,"rootId":null,"fromId":2408,"content":"这个公司为啥常年招聘？","createdAt":"2024-07-04T15:13:50"},{"id":"01963ddd-fa66-7072-874e-2d44db297d6b","parentId":null,"rootId":null,"fromId":21273,"content":"你看看现在还招吗","createdAt":"2024-07-04T15:16:39"},{"id":"01963ddd-f981-725c-a077-17dbca370d5a","parentId":null,"rootId":null,"fromId":1712,"content":"这么傻逼的公司吗，这种人就该死","createdAt":"2024-07-04T15:25:53"},{"id":"01963ddd-f985-7292-979f-c9ce1ea30a84","parentId":null,"rootId":null,"fromId":21286,"content":"懂得都懂 自己判断吧","createdAt":"2024-07-04T15:29:21"},{"id":"01963ddd-fa6b-731b-b5c9-3b5fe96cd308","parentId":null,"rootId":null,"fromId":21273,"content":"这个公司现在什么情况听说裁员很厉害，还不发工资？有懂的吗","createdAt":"2024-07-19T10:28:55"},{"id":"01963ddd-fab0-705b-b596-50a489646f44","parentId":null,"rootId":null,"fromId":2408,"content":"啊？","createdAt":"2024-07-19T10:34:30"},{"id":"01963ddd-fab7-7320-b499-5a4468411ee7","parentId":null,"rootId":null,"fromId":3500,"content":"有公司员工说下情况吗","createdAt":"2024-07-19T16:16:31"},{"id":"01963ddd-fb48-7110-ad1b-d857a3894b3f","parentId":null,"rootId":null,"fromId":2408,"content":"公司怎么样？","createdAt":"2024-07-24T12:01:17"},{"id":"01963ddd-fb8e-7037-8af7-2a5319ce1ea6","parentId":null,"rootId":null,"fromId":21888,"content":"dddd","createdAt":"2024-09-18T14:17:01"},{"id":"01963ddd-fbd3-73a7-868e-8b8b265e83d8","parentId":null,"rootId":null,"fromId":584,"content":"是个诈骗公司，被公安定罪非吸了，诈骗了好多亿","createdAt":"2024-12-03T15:23:08"},{"id":"01963ddd-f989-7316-9d49-e4ed585505de","parentId":null,"rootId":null,"fromId":22516,"content":"说得非常到位，我是早已离职的老老员工了，老板是一个老头姓周，跟周扒皮一家的，开会说让我们晚上加班是给我们表忠心的机会，这特么比福报都狠","createdAt":"2024-12-25T14:45:33"}]