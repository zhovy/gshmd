[{"id":"01963df6-4e22-720f-9965-ac17a4a144d8","parentId":null,"rootId":null,"fromId":2408,"content":"10？","createdAt":"2025-01-11T20:20:37"},{"id":"01963df6-4e6a-7275-9536-471b65dbddcf","parentId":null,"rootId":null,"fromId":875,"content":"至少四千块","createdAt":"2025-01-11T21:04:55"},{"id":"01963df6-4eb1-7325-8e59-e4ed92bbb07f","parentId":null,"rootId":null,"fromId":3279,"content":"外行算一下，一头牛马15K是毛利，公司开劳务发票纳税，按最低3%就是450；五险一金，按照最低交的话，公司要拿接近2500；再加上人事管理、财务、空闲牛马等成本，一头牛马净利润最多1万。给你8K，逢年过节再给些小礼品搞个小团建，就已经是良心公司了。","createdAt":"2025-01-11T21:45:14"},{"id":"01963df6-4efb-729b-ab86-da407fe6b09c","parentId":null,"rootId":null,"fromId":3749,"content":"一般情况是你的工资乘以2就是外包公司给上家要的钱","createdAt":"2025-01-12T14:23:26"},{"id":"01963df6-4f3f-720c-940d-3ea8789c49bb","parentId":null,"rootId":null,"fromId":875,"content":"开外包公司真的挣钱，简直比卖房子还挣钱","createdAt":"2025-01-12T19:19:36"},{"id":"01963df6-4f48-71e5-b815-96c702e27eec","parentId":null,"rootId":null,"fromId":4174,"content":"最多10k，一般8.5k","createdAt":"2025-01-13T08:54:16"},{"id":"01963df6-4f8c-730f-a07f-8691de45ad96","parentId":null,"rootId":null,"fromId":22552,"content":"济南真多外包，看上眼的都是外包，奶奶的","createdAt":"2025-01-13T10:12:51"},{"id":"01963df6-4fd4-7199-84d6-8a0d8ffe762d","parentId":null,"rootId":null,"fromId":3801,"content":"不好说，反正我经历过的公司有能在单人头上赚大几千的，也可以只在一个人身上保本的，就看公司怎么看待你的位置了。","createdAt":"2025-01-13T10:20:15"},{"id":"01963df6-5019-73b6-9739-ef02fad36229","parentId":null,"rootId":null,"fromId":3801,"content":"当然赔本是肯定不行的，比如15K，去掉五险一金什么的，公司可以都发到你手上，但是加起来多于15肯定不行的，这样的问题就是甲方不提你的级别，基本你在公司就这样了。","createdAt":"2025-01-13T10:24:12"},{"id":"01963df6-4fd0-70a8-8800-6becd42b9689","parentId":null,"rootId":null,"fromId":22552,"content":"都是外包，从来没在外包带过，外包怎么样啊","createdAt":"2025-01-13T15:09:59"},{"id":"01963df6-5023-724b-95e9-e243f605c369","parentId":null,"rootId":null,"fromId":1591,"content":"40%-50%，公司费用30%，人资工资10%，还有人资的五险一金。15K，到手在8-9K吧，五险一金300元。","createdAt":"2025-01-13T15:28:27"},{"id":"01963df6-4f43-7185-919d-50b060be4199","parentId":null,"rootId":null,"fromId":59,"content":"你想多了\n公司给你1.5  甲方给公司3W？\n看合作模式啥的   1.5算  少的能赚四五千  多的确实能超1W,但是1.5不可能","createdAt":"2025-01-13T16:22:04"},{"id":"01963df6-501f-7248-9372-bccbf1393f96","parentId":null,"rootId":null,"fromId":59,"content":"中肯，少的四五千甚至要的急的话两三千，多的也超不过1W","createdAt":"2025-01-13T16:24:32"},{"id":"01963df6-5069-724f-8fe4-e59de1e14cc3","parentId":null,"rootId":null,"fromId":3345,"content":"外包牛马现身说法，  甲方给公司20，公司给我14，都是税前，五险一金最低档缴纳。","createdAt":"2025-01-14T10:25:09"},{"id":"01963df6-50b5-701c-a273-f317fa7656cf","parentId":null,"rootId":null,"fromId":3450,"content":"外包牛马现身说法， 甲方给公司13，公司给我9，都是税前，五险一金最低档缴纳。","createdAt":"2025-01-14T10:26:30"},{"id":"01963df6-50fa-73a4-a4dd-d05905c7694c","parentId":null,"rootId":null,"fromId":4087,"content":"济南很少有正事工 都是外包外包 劳务","createdAt":"2025-01-14T13:48:20"},{"id":"01963df6-513d-7322-8804-5ef00100534f","parentId":null,"rootId":null,"fromId":6371,"content":"你除非自己搞外包公司不然你在这里问没有任何意义，你的年限就是死的公认你就值这个钱，外包公司你不干自有人干，外包根本不在乎你提出的多少，没人会在意你这种小卡乐咪，想提高自己工资就堆年限就行","createdAt":"2025-01-16T08:48:08"},{"id":"01963df6-5184-7368-9617-e6d57eb2b963","parentId":null,"rootId":null,"fromId":21585,"content":"看给谁供吧，反正我知道的一些国企单位，供人员外包是按开发2.5/月，项目经理、美工按3/每月计算，这些都是有明文规定的，实际到员工手里工资可能也就几千块吧，跑去公司缴纳社保费用等，当然也有可能有员工福利啥的，反正公司能赚到50%最低。","createdAt":"2025-01-16T15:54:53"},{"id":"01963df6-51c7-7087-8bf2-80afc76e5b5a","parentId":null,"rootId":null,"fromId":22677,"content":"南的外包公司少说几百家，遇到黑的能扣你60%以上，比如有个叫h科的","createdAt":"2025-02-07T15:57:22"}]