[{"id":"01963de0-4fa7-732b-b00e-c90eae12dd22","parentId":null,"rootId":null,"fromId":933,"content":"看公司做什么产品，公司成员普遍是什么学历，几年经验","createdAt":"2023-03-14T15:38:24"},{"id":"01963de0-4feb-720e-9d44-1559f69bd681","parentId":null,"rootId":null,"fromId":1977,"content":"这个形势下，先有饭吃，再考虑饭好不好吃吧","createdAt":"2023-03-14T15:42:11"},{"id":"01963de0-502f-71f2-8878-4ba088418dac","parentId":null,"rootId":null,"fromId":2495,"content":"就怕这饭吃不了几个月就没饭了?","createdAt":"2023-03-14T15:46:30"},{"id":"01963de0-5073-7332-8483-96d45f03edd8","parentId":null,"rootId":null,"fromId":2910,"content":"小公司靠谱先不考虑，一般加班会多，体制不健全，福利待遇自然保证不是多好。看你承受得了不，工资可以的话就干着。先踏实干再说。经验都是积攒的。","createdAt":"2023-03-14T16:20:18"},{"id":"01963de0-50b6-73c4-96c4-e11018b6ac22","parentId":null,"rootId":null,"fromId":875,"content":"小公司肯定不靠谱，公积金全额交的话可以考虑","createdAt":"2023-03-14T19:00:03"},{"id":"01963de0-50fb-72f2-a4ac-09c55021d208","parentId":null,"rootId":null,"fromId":2874,"content":"现在的环境还管靠不靠谱，能找到工作都挺好的了，现在外包都需要抢着进了","createdAt":"2023-03-17T19:29:21"}]