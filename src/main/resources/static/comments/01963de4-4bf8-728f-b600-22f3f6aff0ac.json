[{"id":"01963de4-4c5f-7295-90a4-e42bd583a223","parentId":null,"rootId":null,"fromId":1421,"content":"去面过，北京的hr邀请面试，本地的面试官感觉丝毫不了解情况","createdAt":"2023-06-29T10:56:46"},{"id":"01963de4-4ca4-71cc-9060-f09fad51f72d","parentId":null,"rootId":null,"fromId":481,"content":"期望17？ 面试给9？ 这什么情况，你也去了吗","createdAt":"2023-06-29T14:16:06"},{"id":"01963de4-4ce8-7200-ad9c-06b557921f50","parentId":null,"rootId":null,"fromId":2408,"content":"离谱~","createdAt":"2023-06-29T15:52:25"},{"id":"01963de4-4d4d-714a-ae4a-f239a054a4a3","parentId":null,"rootId":null,"fromId":6750,"content":"公司规模不大，跟作坊一样，项目需要长期驻场开发，不建议去。","createdAt":"2024-09-29T11:18:00"},{"id":"01991caf-fb37-70da-b2ae-e77bf46def46","parentId":null,"rootId":null,"fromId":26736,"content":"作为公司前员工说一下，加班确实严重，项目研发需求一直整改变化，导致出现很多次加班，其次后期公司开始拖欠工资了，也从原来的联合财富广场更换到一个小区里面，有出差，去北京那边，如果不是驻场的，就是住在公司里面，给你一个折叠床当做晚上睡得地方，白天在其他人来之前要收拾好，现在我了解济南这边的已经倒闭了","createdAt":"2025-09-06T09:41:59"}]