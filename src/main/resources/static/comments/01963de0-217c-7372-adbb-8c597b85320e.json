[{"id":"01963de0-21e9-715c-b2f9-9117e7ace183","parentId":null,"rootId":null,"fromId":2839,"content":"我明天面它，过去看看","createdAt":"2023-03-07T22:21:21"},{"id":"01963de0-2232-7155-8277-eb8f982812b4","parentId":null,"rootId":null,"fromId":783,"content":"小白同学， 你说的那种打着招聘名义的培训机构，很久之前有，现在几乎没有了。你说的那几个公司，我估计绝大部分人都没有听过。\n既然是刚毕业，能找到好的公司最好了，找不到的话，就其他帖子里面看看坑货公司，面试一下，接受一下社会的毒打，快速增长经验，在一定程度上是好事","createdAt":"2023-03-08T09:13:08"},{"id":"01963de0-2276-7213-8e15-733e63026e02","parentId":null,"rootId":null,"fromId":2742,"content":"百度了一下，公司成立时间太短了，问问公司目前多少人，如果太少还是不要去浪费时间了","createdAt":"2023-03-08T09:34:05"},{"id":"01963de0-22bb-7097-8ff7-2df8602c2ac2","parentId":null,"rootId":null,"fromId":1492,"content":"多面试吧，把技术面试官的问题，都记录下，做个word或者excel，每次面试前都拿出来看看。他们问的题，其实也就那么多，每次都要重复的","createdAt":"2023-03-08T10:06:44"},{"id":"01963de0-2304-71fb-86a4-700429b57fed","parentId":null,"rootId":null,"fromId":2839,"content":"兄弟，在这平台查查柏煜就知道了，就当出来玩了","createdAt":"2023-03-08T10:25:48"},{"id":"01963de0-234e-72b0-a5f4-4176427c352d","parentId":null,"rootId":null,"fromId":2839,"content":"公司电梯门口有氪星球实训中心","createdAt":"2023-03-08T10:54:29"},{"id":"01963de0-2393-7360-91ba-2054e387a625","parentId":null,"rootId":null,"fromId":2633,"content":"谢谢各位老师的建议和提醒?","createdAt":"2023-03-08T11:29:48"},{"id":"01963de0-23d8-72a6-af3c-baa392834527","parentId":null,"rootId":null,"fromId":2856,"content":"老哥怎么样啊","createdAt":"2023-03-08T14:48:02"},{"id":"01963de0-241d-7030-b267-1f063aa1ed01","parentId":null,"rootId":null,"fromId":177,"content":"不知道你是什么学校和自己的技术水平，根据你的描述给你推荐几家公司去试试，虽然有各种不好，但是可以锻炼自己水平。神思电子、山大华天、山大地纬、金现代、鸥玛软件、浪潮思科。不要怂，抓紧背背面经，敲敲代码，祝顺利。上面那些公司可能不是很好，但是在济南来说相对正规一些，也大都是上市公司。","createdAt":"2023-03-08T16:48:37"},{"id":"01963de0-2462-711d-9e6d-a7cdd3f7000b","parentId":null,"rootId":null,"fromId":2137,"content":"我记得我之前发过这个破培训机构来着\n地点在中铁财智的那个 纯纯骗子","createdAt":"2023-03-14T13:00:04"},{"id":"01963de0-24a8-73aa-ad72-a5df2bd2f2a0","parentId":null,"rootId":null,"fromId":2993,"content":"咋样咋样，我明天面它 o(╥﹏╥)o","createdAt":"2023-03-23T10:00:50"},{"id":"01963de0-24ec-73e5-ad9f-525662b4897a","parentId":null,"rootId":null,"fromId":3951,"content":"ok，今天刚来，跟柏煜是一家，20楼进门就是柏煜，看看一会面试咋忽悠吧","createdAt":"2023-07-01T14:05:43"}]