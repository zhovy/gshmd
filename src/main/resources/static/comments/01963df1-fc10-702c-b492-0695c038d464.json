[{"id":"01963df1-fc73-73d5-b2c0-6b180fd351a4","parentId":null,"rootId":null,"fromId":21360,"content":"老家哪的","createdAt":"2024-08-03T14:01:10"},{"id":"01963df1-fcbb-727a-881f-44142ccbe409","parentId":null,"rootId":null,"fromId":875,"content":"回家开个菜鸟驿站也不错","createdAt":"2024-08-03T15:07:28"},{"id":"01963df1-fcb7-73a2-8ffe-40f83d102068","parentId":null,"rootId":null,"fromId":2408,"content":"德州","createdAt":"2024-08-03T15:32:08"},{"id":"01963df1-fd05-7246-accf-0e04a16df3dc","parentId":null,"rootId":null,"fromId":875,"content":"回家开个药店","createdAt":"2024-08-04T07:09:09"},{"id":"01963df1-fd4a-71f6-8282-9901c3118b42","parentId":null,"rootId":null,"fromId":2408,"content":"开药店要有医师资格证吧？你想开就开？","createdAt":"2024-08-04T12:15:09"},{"id":"01963df1-fd4f-73ac-845b-d776b5a468db","parentId":null,"rootId":null,"fromId":875,"content":"这么死板吗？没有证可以考，考不上可以花钱雇人，你看济南的药店老板有几个自己有证的\n\n\n\n\n\n7月25日，山东华杰人力资源管理有限公司官方网站发布“济南高新区舜华路街道办事处2024年专职网格员招聘公告”。其内容显示，本次招聘计划聘用人员74人，年龄在45周岁以下（1978年7月以后出生），录用后拟聘用人员将享受五险一金，薪酬约每月3700元的待遇。","createdAt":"2024-08-04T14:05:50"},{"id":"01963df1-fd53-70f2-8d2f-fcb900a83a72","parentId":null,"rootId":null,"fromId":2408,"content":"投资这东西成本太高了，没有可行性，对了，你的药店在哪？","createdAt":"2024-08-04T19:10:57"},{"id":"01963df1-fd00-7360-8ec6-4ad84db0d97d","parentId":null,"rootId":null,"fromId":3341,"content":"菜鸟驿站真累啊是，在县城的话 需要自己每天去拉货两次 拉货过程中装协全是自己，一单好像7分还是7毛 ，好像最近又低了，365天全年无休 ，一个人干累 没有喘气儿的时候 两个人干不合适 还不如打工挣得多","createdAt":"2024-08-05T11:09:24"},{"id":"01963df1-fd57-70f0-8b18-9e6c7c3eba49","parentId":null,"rootId":null,"fromId":21656,"content":"老乡啊，我也想回老家发展了，但是一直没发现有啥工作 ，大部分都是销售","createdAt":"2024-08-14T10:52:24"},{"id":"01963df1-fd9b-71b4-8aa6-0fa298fdcffd","parentId":null,"rootId":null,"fromId":3792,"content":"请问德州有什么产业啊，老乡，我也想回去","createdAt":"2024-08-14T17:20:29"},{"id":"01963df1-fde3-704b-b87b-fb2a04390493","parentId":null,"rootId":null,"fromId":21687,"content":"回德州 报团取暖吧","createdAt":"2024-08-19T10:35:10"},{"id":"01963df1-fe2c-70a8-adbc-9c8fa6e7a026","parentId":null,"rootId":null,"fromId":21755,"content":"想去德州","createdAt":"2024-08-28T10:03:19"},{"id":"01963df1-fddf-725b-af38-7f818e21de3d","parentId":null,"rootId":null,"fromId":7226,"content":"扒鸡","createdAt":"2024-08-28T11:16:37"}]