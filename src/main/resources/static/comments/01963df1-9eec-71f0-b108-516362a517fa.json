[{"id":"01963df1-9f54-7100-bbb7-179a42311846","parentId":null,"rootId":null,"fromId":7009,"content":"25W","createdAt":"2024-07-05T16:14:32"},{"id":"01963df1-9f99-72ac-8831-48de63beabb8","parentId":null,"rootId":null,"fromId":3341,"content":"嗯 差不多 挺中肯了 毕业后五年 存25或者有固定财产25","createdAt":"2024-07-05T16:21:59"},{"id":"01963df1-9f9d-72be-b825-63fa81df89f1","parentId":null,"rootId":null,"fromId":4140,"content":"25w每年存5w，每个月存4200，房租水电1000，吃饭加日常用品消费2000，其他消费一个月1000，工资自少8200到手，全额五险一金的话工资税前至少10555，最低五险一金税前8700多，也就是说毕业到工作五年后的平均工资到8700最低五险或者全额10555，才能攒25w现金，而且你还得没有乱七八糟的消费，不买电子产品、补旅游、不谈对象，反正我工作三年就攒了5w多，主要电子产品（4w）和旅游(3w)花的多，对象一年花(2w)","createdAt":"2024-07-05T16:34:01"},{"id":"01963df1-9fa2-7182-9633-8949b0fbeca7","parentId":null,"rootId":null,"fromId":5408,"content":"25w太多了吧，我觉得15w差不多","createdAt":"2024-07-05T16:53:52"},{"id":"01963df1-9fae-7104-9569-61bf33be5c9e","parentId":null,"rootId":null,"fromId":3450,"content":"像我这种背了200w贷款的人都不敢奢望有存款","createdAt":"2024-07-05T16:58:43"},{"id":"01963df1-9fa6-71f6-9e08-ad60812c8c55","parentId":null,"rootId":null,"fromId":3219,"content":"烽火哥三年才存5w有点说不过去了吧","createdAt":"2024-07-05T17:19:34"},{"id":"01963df1-9ffb-72a8-993c-84892fd49a44","parentId":null,"rootId":null,"fromId":875,"content":"不是一年存10万块钱嘛，毕业5年在济南存50万比较正常，考虑到20年的特殊情况，5年在济南存40万，要是在北京5年差不多50万多，人家北京有年终奖","createdAt":"2024-07-05T18:59:39"},{"id":"01963df1-a043-722d-930b-9f1c9df8969e","parentId":null,"rootId":null,"fromId":5768,"content":"能活下来就不错了还存钱","createdAt":"2024-07-06T08:33:15"},{"id":"01963df1-a087-739c-bca2-5b85dc1188ef","parentId":null,"rootId":null,"fromId":6276,"content":"不知道，反正曾经最多一个月流水200多万","createdAt":"2024-07-06T11:18:58"},{"id":"01963df1-a0cb-731c-943f-49c770c22fa2","parentId":null,"rootId":null,"fromId":3671,"content":"一年5w，感觉比较正常","createdAt":"2024-07-06T13:15:36"},{"id":"01963df1-a111-720f-b093-3a64637b60a9","parentId":null,"rootId":null,"fromId":875,"content":"存啥钱，黄金一年涨了20%，纳斯达克一年涨了多少?印度股市涨了多少？","createdAt":"2024-07-06T15:07:08"},{"id":"01963df1-a155-7349-9820-b47fe77562e6","parentId":null,"rootId":null,"fromId":875,"content":"窝在济南赚不了什么钱，走出去，放眼全国才能赚到钱，趴在A股只能被套，投资全球才能一年稳赚不赔","createdAt":"2024-07-06T22:16:43"},{"id":"01963df1-a03f-72c9-b306-59c6b2c685b3","parentId":null,"rootId":null,"fromId":3663,"content":"6","createdAt":"2024-07-07T16:01:15"},{"id":"01963df1-a199-7274-b6c4-19820faddef2","parentId":null,"rootId":null,"fromId":7581,"content":"还是看工作情况吧，我一开始工作的时候，一个月到手才4500，减去房租啥的，一年就攒了一万五千元，后面工资涨上来之后，三年攒了20w，现在又开始慢慢攒了","createdAt":"2024-07-07T18:23:25"},{"id":"01963df1-a1e1-71fb-86f3-f1cea899c68a","parentId":null,"rootId":null,"fromId":3341,"content":"每个人情况都不一样。看自己吧\n你可以这么问 月入（你的工资）五年存多少合适？\n但是你问工作五年存多少合适 没有什么合适的答案给你 ，有的人一万七八 有的七千八 这个每个人他不一样啊","createdAt":"2024-07-08T09:31:16"},{"id":"01963df1-a226-70d0-b30d-b7f6e77053bc","parentId":null,"rootId":null,"fromId":875,"content":"一套大平层，300多万，算一下，存几年可以把它买下来，退休前刚刚好把它买下来","createdAt":"2024-07-08T13:11:08"},{"id":"01963df1-a26f-72a7-9024-59de0831f5ed","parentId":null,"rootId":null,"fromId":7381,"content":"15-25吧","createdAt":"2024-07-08T14:54:47"},{"id":"01963df1-9ff7-7090-aea3-1c61cd030eba","parentId":null,"rootId":null,"fromId":5624,"content":"是房贷就说清楚，没必要自潮","createdAt":"2024-07-11T16:56:40"},{"id":"01963df1-9faa-725a-8bc9-8217abaa9721","parentId":null,"rootId":null,"fromId":4174,"content":"按烽火哥的算法他一年到手是10.8万，毕竟是全额五险一金","createdAt":"2024-07-12T09:56:05"}]