[{"id":"01963ddc-8b1c-73f7-8e1c-39429d15f946","parentId":null,"rootId":null,"fromId":1630,"content":"兄弟这种情况你们都能忍这么长时间，我也是佩服","createdAt":"2022-09-16T14:46:39"},{"id":"01963ddc-8b71-7286-b208-27e9fa8dc60b","parentId":null,"rootId":null,"fromId":35,"content":"老板是哪个？我是19年从河马出来的","createdAt":"2022-09-16T15:31:43"},{"id":"01963ddc-8bb9-70ff-b16a-1810f30168d8","parentId":null,"rootId":null,"fromId":1712,"content":"好笑，还等良心呢，你这是什么心里啊；还不马上准备仲裁，等过年吗，拖欠一天都可以仲裁了","createdAt":"2022-09-20T11:57:48"},{"id":"01963ddc-8c01-71b2-9310-a0b855133a86","parentId":null,"rootId":null,"fromId":1730,"content":"就这种公司还不如不干呢，心里不压抑吗。是真的找不到工作还是老板承诺给你们年薪百万呢？？","createdAt":"2022-09-23T09:19:39"},{"id":"01963ddc-8c55-710c-9a30-71e469d8eb50","parentId":null,"rootId":null,"fromId":2091,"content":"离职,老板恶意的不做社保减员,导致大家好几个月没有社保,良心坏透了.","createdAt":"2022-10-28T13:03:28"}]