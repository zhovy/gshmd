[{"id":"019ad76c-28f3-71eb-b4ab-353442fefd30","parentId":null,"rootId":null,"fromId":6449,"content":"确实挺堵的，问一声，地铁快开了，会有一部分转向地铁吗","createdAt":"2025-12-01T08:59:41"},{"id":"019ad76f-458a-7309-b187-70694aecf124","parentId":null,"rootId":null,"fromId":926,"content":"啥啊，见过世面吗，每周一早上都是最堵的。","createdAt":"2025-12-01T09:03:05"},{"id":"019ad770-6538-72fe-becd-be477e9219be","parentId":null,"rootId":null,"fromId":22250,"content":"没见过，可怜的牛马还挺自豪","createdAt":"2025-12-01T09:04:18"},{"id":"019ad776-ffc7-719c-a518-96154f2e58f8","parentId":null,"rootId":null,"fromId":27151,"content":"你可拉倒吧 今早是最堵了 之前没有这么堵  主要今天是中建三局门口停了特别多的车 还有个大货车","createdAt":"2025-12-01T09:11:31"},{"id":"019ad777-84f0-7214-b1dc-3e0644881d1a","parentId":null,"rootId":null,"fromId":926,"content":"比你这想当牛马都当不了牛马的强","createdAt":"2025-12-01T09:12:05"},{"id":"019ad77f-22d5-70a3-9322-47641fd49b17","parentId":null,"rootId":null,"fromId":27118,"content":"如果你不是牛马有钱够花那你赢了，否则你这种人真挺可笑的","createdAt":"2025-12-01T09:20:24"},{"id":"019ad797-5062-7157-8cec-fe4284c242c4","parentId":null,"rootId":null,"fromId":2921,"content":"其实是去老板门口堵门要工资的","createdAt":"2025-12-01T09:46:49"},{"id":"019ad79b-45b7-72da-9f79-371d5db4db5e","parentId":null,"rootId":null,"fromId":4137,"content":"就因为今天的大堵车迟到了，就是中建三局那边停车停的，交警怎么不去查？","createdAt":"2025-12-01T09:51:08"},{"id":"019ad7a1-b32e-7228-8b9b-8a62c235dff1","parentId":null,"rootId":null,"fromId":22250,"content":"就经十路那边一个辅警，民警在办公室喝茶呢","createdAt":"2025-12-01T09:58:09"},{"id":"019ad7a2-12e3-72da-bc19-505af39be4f7","parentId":null,"rootId":null,"fromId":22250,"content":"对，我看手里都拿着铁锹还有啤酒瓶","createdAt":"2025-12-01T09:58:34"},{"id":"019ad7c3-b262-732f-b8f2-e3b9e0360b7f","parentId":null,"rootId":null,"fromId":27151,"content":"那个辅警看着挺可怜的 凤凰路经十路这么大的路口 就他一个人","createdAt":"2025-12-01T10:35:17"},{"id":"019ad854-a7f3-7152-a479-0fbdb5234b60","parentId":null,"rootId":null,"fromId":22250,"content":"是啊，拿着3000快的工资干着与自身能力不匹配的事儿，也没有其它辅警来帮帮他","createdAt":"2025-12-01T13:13:38"},{"id":"019ad856-990c-731a-873d-41b0922b2954","parentId":null,"rootId":null,"fromId":22250,"content":"有没有打12345的，给目前经十路的这个辅警多找几个小伙伴，瘦弱的小辅警明显吃不消上下班的流量","createdAt":"2025-12-01T13:15:45"},{"id":"019adc55-1bd7-72d7-ad7b-d797fc0a3919","parentId":null,"rootId":null,"fromId":875,"content":"打12345要求九点上班，分时错峰，太堵了","createdAt":"2025-12-02T07:52:36"}]