[{"id":"019a68d8-1cb1-7122-b6ea-63d8e76d9f03","parentId":null,"rootId":null,"fromId":22316,"content":"之前面过，单休还加班，跟山东八骏有关系，记得之前网站上有帖子就没去，现在帖子好像被删了","createdAt":"2025-11-09T21:39:44"},{"id":"019a6bc3-09cd-716f-b377-d6b85e2026c9","parentId":null,"rootId":null,"fromId":2558,"content":"初试过了，一个复试的女的面的我，这个女的好像一个怨妇，一大半在吐糟离职的一个前端 连带我一起喷，还是单休，把单休的责任推到离职的前端身上,说公司变成单休都是离职员工的问题","createdAt":"2025-11-10T11:15:35"},{"id":"019a6bc7-7398-719f-abd1-a7c15357ff40","parentId":null,"rootId":null,"fromId":2558,"content":"待遇一般，公司单休，主营业务好像是流量卡和随身wife这些的","createdAt":"2025-11-10T11:20:24"},{"id":"019a7c6f-a577-7326-86ac-fe6255338ebc","parentId":null,"rootId":null,"fromId":27551,"content":"哥们入职了吗","createdAt":"2025-11-13T16:58:02"},{"id":"019a94cf-ca8e-7374-b838-608394b24661","parentId":null,"rootId":null,"fromId":2558,"content":"我没去，哈哈，复试没过，那个女的问我，知道面试官是啥职位吗，知道公司为啥招人吗？知道前一个员工为啥离职吗？我说我不知道，然后就开始喷了，你们这些技术员就只知道技术牛逼就可以随便换公司，对公司一点都不了解，我听她喷了二十分钟，就没然后了","createdAt":"2025-11-18T10:33:57"},{"id":"019aa7e2-64f8-707e-a433-bc412dc41f1b","parentId":null,"rootId":null,"fromId":267,"content":"更年期的女人，你懂的。。。","createdAt":"2025-11-22T03:27:03"},{"id":"019ac94b-51cd-7121-b20f-a09949dbbed6","parentId":null,"rootId":null,"fromId":25907,"content":"是先改的单休，然后人都走了，宣布的时候开会说想走的当场提，她当场批，分分钟重新招一批人进来，我只能说不走对不起她说的这种话，于是乎大家都走了","createdAt":"2025-11-28T15:09:07"},{"id":"019ac94d-2f0c-7384-a8ea-d6c2b29647c1","parentId":null,"rootId":null,"fromId":25907,"content":"之前那个写的太全了，还怎么骗人进去","createdAt":"2025-11-28T15:11:10"},{"id":"019ac956-1d69-7067-b4ad-64d503bfd127","parentId":null,"rootId":null,"fromId":25907,"content":"她这是在说啥呢，怎么就跟急了似的，真知道你啥情况还会来面试吗，笑死，为啥删之前的帖子啊","createdAt":"2025-11-28T15:20:55"},{"id":"019ac96f-ee0d-7371-a4b8-daa18f482391","parentId":null,"rootId":null,"fromId":25907,"content":"好奇是哪个女的，是高高瘦瘦的长发中年女人，还是高高瘦瘦的长发年轻女人，还是矮矮胖胖的短发中年女人。","createdAt":"2025-11-28T15:49:07"},{"id":"019ad771-c743-7192-a02f-82446228ba81","parentId":null,"rootId":null,"fromId":2558,"content":"原来这样啊 还好没过。","createdAt":"2025-12-01T09:05:49"},{"i