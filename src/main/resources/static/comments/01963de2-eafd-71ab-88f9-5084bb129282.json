[{"id":"01963de2-eb62-7109-aacc-d256ca580a8a","parentId":null,"rootId":null,"fromId":1656,"content":"你信有不加班的公司吗？","createdAt":"2023-05-24T12:08:30"},{"id":"01963de2-ebab-7313-9c65-5c478c1a35c7","parentId":null,"rootId":null,"fromId":258,"content":"一个月偶尔加一两次算吗","createdAt":"2023-05-24T13:22:56"},{"id":"01963de2-ebb0-7392-9256-13719a6731b5","parentId":null,"rootId":null,"fromId":3506,"content":"我呆过的公司少，不过上家确实不加班，我到点就走，其他人可能呆半小时这样，不知道这算不算加班","createdAt":"2023-05-24T13:35:36"},{"id":"01963de2-ebb4-7038-a6be-bda67acac7b3","parentId":null,"rootId":null,"fromId":3506,"content":"这种我觉得算不加班的了，谁没个突发情况","createdAt":"2023-05-24T13:36:59"},{"id":"01963de2-ebb8-7096-86f9-77b54904d0fe","parentId":null,"rootId":null,"fromId":2598,"content":"你上家公司叫啥?","createdAt":"2023-05-24T14:34:03"},{"id":"01963de2-ebbd-73fa-9ecb-e2890574290b","parentId":null,"rootId":null,"fromId":1862,"content":"那怎么走了呢","createdAt":"2023-05-24T17:00:24"},{"id":"01963de2-ebc1-704a-bc18-7505d064c0d6","parentId":null,"rootId":null,"fromId":1072,"content":"主要是得看给的多高啊","createdAt":"2023-06-03T16:16:09"},{"id":"01963de2-ebc7-71b1-8a8b-621dea703905","parentId":null,"rootId":null,"fromId":4144,"content":"听劝，千万别去。那边项目的总负责人姓孙，副的姓殷，接的中建八局的外包项目，六、七楼都有。手下的人，除了几个老员工，基本几个月换一茬，所以他们全年都在招人，你细品吧。去了第一天就给你把活排满，不给时间熟悉框架技术和业务，目的让你跟不上节奏，然后开始pua你加班。996是常态，一个人同时参与几个项目是常态。周末加班给调休，但基本不会让你有机会调完。新人用完就扔的情况也存在，看你不顺眼或者感觉骗你进来时钱给多了试用期卡你一下逼你离职。合同直签浪潮数字的还好，算是浪潮内部人员，但待遇比浪潮其他部门差一截，自己去搜浪潮数字服务的待遇吧。如果签的外协公司，那你去晨鸣就相当于被外包出去两次，你们公司人力外包浪潮，浪潮项目外包中建八局。而且晨鸣那边不安全，周边偷电瓶车的很多。","createdAt":"2023-07-20T13:40:09"},{"id":"01963de2-ec0f-71b6-9668-61f0f85a8602","parentId":null,"rootId":null,"fromId":236,"content":"歪日 刚给了offer 让下周去呢 这下纠结了","createdAt":"2023-07-28T14:30:43"},{"id":"01963de2-ec13-7275-b487-55c3fc1a4192","parentId":null,"rootId":null,"fromId":1398,"content":"现在咋样了","createdAt":"2023-08-03T15:57:00"},{"id":"01963de2-ec18-7073-858e-0be0ab4ccad5","parentId":null,"rootId":null,"fromId":1110,"content":"谢谢兄弟，你说的我信","createdAt":"2023-08-18T15:54:58"},{"id":"01963de2-ec1c-7247-8640-f0509359911d","parentId":null,"rootId":null,"fromId":561,"content":"这么变态吗","createdAt":"2023-08-18T16:50:45"}]