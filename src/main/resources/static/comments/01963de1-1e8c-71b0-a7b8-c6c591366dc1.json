[{"id":"01963de1-1f06-730e-933d-afb6c4065971","parentId":null,"rootId":null,"fromId":965,"content":"哈哈，真恶心，避坑","createdAt":"2023-04-07T09:44:16"},{"id":"01963de1-1f57-7223-a6b9-6a7df16404a8","parentId":null,"rootId":null,"fromId":258,"content":"https://gshmd.vip/company/589","createdAt":"2023-04-07T10:53:41"},{"id":"01963de1-1f9d-72f2-8077-2eabf52c9052","parentId":null,"rootId":null,"fromId":258,"content":"这个垃圾公司还没倒闭","createdAt":"2023-04-07T10:54:16"},{"id":"01963de1-1fe8-72a1-8b13-88f8112522d6","parentId":null,"rootId":null,"fromId":2935,"content":"今天4月10日，刚去面试了一下，岗位是项目总监。办公环境nice，楼主说的长时间等待并没遇见，面试官问的问题也挺专业的，PUA的环节没遇见（不知道是不是复试内容？）也跟面试官坦诚的沟通了一下上了黑名单的事情，面试官给的说法是“去年招来了几个app的开发，不出活，所以辞退后给上了黑名单”，因为只是面试，未实际入职，仅从本次面试经历来说吧，感觉沟通还是挺不错的，双方的问题交流还是很坦率的。","createdAt":"2023-04-10T16:03:57"},{"id":"01963de1-2049-7274-9e0f-79bfca6278c4","parentId":null,"rootId":null,"fromId":654,"content":"之前面试过 到那等了一个小时 绝了 ，反正印象不好","createdAt":"2023-04-10T16:23:59"},{"id":"01963de1-2093-7294-9b27-0202eb1585bf","parentId":null,"rootId":null,"fromId":3331,"content":"印象不好，听说去年疫情直接无薪休假一个月，绩效也发不全","createdAt":"2023-04-20T14:23:04"},{"id":"01963de1-202f-7360-9dd3-38782649fd87","parentId":null,"rootId":null,"fromId":267,"content":"别洗了。第一，黑名单五年以前就上了，补充黑名单更是家常便饭，何来去年之说？第二，这家公司对技术岗管理堪称“地狱式折磨”，这是公认的。第三，你运营本就不是技术岗，也没有发言权。","createdAt":"2023-04-25T02:00:33"},{"id":"01963de1-1f52-712d-b017-3154df002d47","parentId":null,"rootId":null,"fromId":267,"content":"这家公司特别恶心，与他们公司文化有关：管理层以“压榨员工、迫害员工、折磨员工”为最高乐趣。他们离职率特别高人员变动频繁，赖先生亲口承认“太吓人了（人员离职变动）”，有录音为凭证","createdAt":"2023-04-25T02:10:50"},{"id":"01963de1-20e0-7312-968d-0aaa85856bd7","parentId":null,"rootId":null,"fromId":3400,"content":"听说通过扣绩效的方式恶意降薪?","createdAt":"2023-04-26T18:08:57"},{"id":"01963de1-20dc-7381-b015-5f13f535b415","parentId":null,"rootId":null,"fromId":3803,"content":"十一薪实锤","createdAt":"2023-06-13T20:52:08"},{"id":"01963de1-2172-7212-b5aa-93fcffaf2f80","parentId":null,"rootId":null,"fromId":3861,"content":"HR也挺不容易的，不把人坑过去面试，绩效也要被扣很多啊，多理解理解吧","createdAt":"2023-06-20T11:25:35"},{"id":"01963de1-2033-702d-9b34-d659a02bcfa9","parentId":null,"rootId":null,"fromId":267,"content":"交流还坦率，你问问，多少次虚假面试刷业绩","createdAt":"2023-06-24T02:24:47"},{"id":"01963de1-208e-7097-9b13-4070ae23ba42","parentId":null,"rootId":null,"fromId":267,"content":"避开就好","createdAt":"2023-06-24T02:25:06"},{"id":"01963de1-216d-72d6-a371-9b8dab798e45","parentId":null,"rootId":null,"fromId":267,"content":"这种可以举报","createdAt":"2023-06-24T02:25:31"},{"id":"01963de1-21bc-700f-bca3-a761b4916aec","parentId":null,"rootId":null,"fromId":4033,"content":"单休，压榨员工，出个问题所有开发跟着加班，真让人恶心，小领导只会甩锅，面对大领导更是跪舔，天天早会全是废话，各种各样扣绩效，绩效永远不可能满，恶心走一波又一波的开发测试，遗留的问题那只能让剩下的人接手，这些经理真的是没有能力，完全就是呆的时间长提上去的，整个部门都让这些人领导的乌烟瘴气的","createdAt":"2023-07-11T15:49:27"},{"id":"01963de1-2038-70ad-8d77-b96dbf76745c","parentId":null,"rootId":null,"fromId":258,"content":"你可拉到吧","createdAt":"2023-08-09T10:16:02"},{"id":"01963de1-203c-7361-841d-e0f6005195fd","parentId":null,"rootId":null,"fromId":3749,"content":"10-15k招总监也是笑了，这个价格也就一个高级的价位，果断拒绝！","createdAt":"2023-08-09T15:38:08"},{"id":"01963de1-21b7-732c-9e1a-93e0e448e696","parentId":null,"rootId":null,"fromId":267,"content":"拖欠社保，HR自身不作为；该公司扣押员工那份劳动合同，态度十分恶劣","createdAt":"2023-08-10T11:28:47"},{"id":"01963de1-2040-70f7-bd28-2f9fc6c00497","parentId":null,"rootId":null,"fromId":267,"content":"我们保留了全过程的证据（图片、视频、聊天记录），你敢不敢在这里实名与我们对质？","createdAt":"2023-08-10T11:30:46"},{"id":"01963de1-2204-70d0-8a5a-b4d89298e8f3","parentId":null,"rootId":null,"fromId":267,"content":"拖欠工资，拖欠社保，不是举报根本就不给工资，管理十分混乱；扣押员工那份劳动合同","createdAt":"2023-08-10T11:33:33"},{"id":"01963de1-2209-736b-8a16-9bd4c630cd44","parentId":null,"rootId":null,"fromId":258,"content":"我离职后工资少发了两千，问之前的人事，人事说根据绩效发的，我直接举报，后来人事又说发错了。。。","createdAt":"2023-08-10T13:48:41"},{"id":"01963de1-225c-7026-8578-5b6bdad5ebce","parentId":null,"rootId":null,"fromId":267,"content":"后来给你了吗","createdAt":"2023-08-14T13:28:11"},{"id":"01963de1-2260-70cd-8b4d-7e4e4c5ad087","parentId":null,"rootId":null,"fromId":267,"content":"全部给你了吗","createdAt":"2023-08-28T15:47:48"},{"id":"01963de1-22aa-72ec-a507-34259d2ed6df","parentId":null,"rootId":null,"fromId":267,"content":"该起诉起诉","createdAt":"2024-12-19T23:07:52"},{"id":"019abe11-9144-72b3-a1ec-722aa261ef92","parentId":null,"rootId":null,"fromId":267,"content":"这家公司的人事很爱他们所谓的企业文化，你们懂的","createdAt":"2025-11-26T10:50:13"}]