[{"id":"01963de2-89f2-728d-8820-2e60cfb6a429","parentId":null,"rootId":null,"fromId":2801,"content":"我个人感觉是在刷kpi，\n首先，面完试之后不回复，我主动问，说是达不到我的期望薪资，只能给我到9\n然后我说9是不是可以给发offer，她又说不行，还得复试。我人都麻了。\n而且公司也不算太大，位置还比较偏，大家反正自己考虑再决定要不要去浪费时间吧","createdAt":"2023-06-15T08:46:05"},{"id":"01963de2-8a38-70a6-aaa2-41cdf1a8bbc3","parentId":null,"rootId":null,"fromId":6171,"content":"1.项目长期996没有加班费，不加班不行。\n2.社保公积金最低标准\n3.节假日福利很扣\n4.极其能画饼。\n5.人员不多，但是领导关系混乱，同事都是关系户","createdAt":"2024-01-08T08:35:55"},{"id":"01963de2-8a7d-73d4-aa97-e10d675df855","parentId":null,"rootId":null,"fromId":3529,"content":"还好当时待了两天就走了","createdAt":"2024-01-09T09:22:21"},{"id":"01963de2-8a8b-7376-899b-ff48caf27350","parentId":null,"rootId":null,"fromId":6268,"content":"强制996，面试好几轮，刷KPI","createdAt":"2024-03-05T17:34:18"},{"id":"01963de2-8ad0-73ee-9c6d-3c52a49da875","parentId":null,"rootId":null,"fromId":7206,"content":"老板和女领导搞一起了","createdAt":"2024-04-15T13:52:54"},{"id":"01963de2-8b17-7051-8241-e3518d85b224","parentId":null,"rootId":null,"fromId":5408,"content":"细讲，兄弟","createdAt":"2024-04-15T13:54:36"},{"id":"01963de2-8b1c-7121-8ba3-3933f132ebf6","parentId":null,"rootId":null,"fromId":2859,"content":"展开说说","createdAt":"2024-04-15T13:56:35"},{"id":"01963de2-8b1f-7049-bb6f-977c930d896e","parentId":null,"rootId":null,"fromId":5916,"content":"插眼","createdAt":"2024-04-17T09:28:46"},{"id":"01963de2-8b23-7334-bb3a-3506244344f1","parentId":null,"rootId":null,"fromId":4093,"content":"我插","createdAt":"2024-04-25T10:01:44"},{"id":"01963de2-8a82-7123-8112-591269761e84","parentId":null,"rootId":null,"fromId":7707,"content":"好兄弟，详细说说 在考虑要不要去","createdAt":"2024-05-31T10:55:40"},{"id":"01963de2-8b29-7247-bdbe-b198c2d36235","parentId":null,"rootId":null,"fromId":6091,"content":"直接标记不合适了，是我不配","createdAt":"2024-06-07T15:31:12"},{"id":"01963de2-8b6d-70b4-bf9e-426228d1a8fd","parentId":null,"rootId":null,"fromId":7287,"content":"两年前面过，当时就1个后端开发，明确告诉过我会加班，有两轮面试，当时觉得还可以哈哈哈","createdAt":"2024-06-11T09:33:33"},{"id":"01963de2-8bb1-73d9-aac