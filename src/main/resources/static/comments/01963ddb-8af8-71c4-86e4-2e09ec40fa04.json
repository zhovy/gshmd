[{"id":"01963ddb-8b99-7232-8095-81e2fabd9e0d","parentId":null,"rootId":null,"fromId":353,"content":"差点入职，幸亏没去，联通外包，党建网站啥的，拖欠工资无法忍啊，感谢自己决定没去，没去的原因是他们周六晚上人都在加班，感觉加班太多了","createdAt":"2022-08-10T11:27:42"},{"id":"01963ddb-8bdf-7103-951b-d0fa9e544d2b","parentId":null,"rootId":null,"fromId":1162,"content":"去面试，后来没信了。看来救了我自己。","createdAt":"2022-08-10T14:32:19"},{"id":"01963ddb-8c23-727b-a7cf-971468fcf140","parentId":null,"rootId":null,"fromId":712,"content":"给联通产护做外包，没人权","createdAt":"2022-08-10T15:57:36"},{"id":"01963ddb-8c67-72a6-873b-d3815d7aba57","parentId":null,"rootId":null,"fromId":1262,"content":"拖欠工资不能忍!","createdAt":"2022-08-11T10:01:55"},{"id":"01963ddb-8cac-722d-8840-ff50dced674a","parentId":null,"rootId":null,"fromId":1354,"content":"公司制度，从早9晚5改为早9晚6，并且8点之前不算加班，也就是说从晚6点干到晚10点，才算加班2小时。工资拖欠1个月属于正常，现在6月份工资直奔拖欠2个月去了。行政主管赵娜还天天叨叨程序员事多。这是做联通外的，被压榨到要统一加班到9点，这面公交到8点最后一班，到9点都回不去家，10点打车才给报。到家累的倒头就睡。公司就3、4个技术大神，新人来了，也学不到啥东西。想体验社会黑暗的，欢迎来面试。","createdAt":"2022-08-16T09:43:37"},{"id":"01963ddb-8cf2-727f-b109-e685a51dc759","parentId":null,"rootId":null,"fromId":1359,"content":"联通外包，需求多时间少，变相裁员，拖欠工资，领导层不管事，行政主管只手遮天中饱私囊，绩效考核不过重写，不写扣工资","createdAt":"2022-08-17T14:36:20"},{"id":"01963ddb-8d38-71d4-8e93-de2a6aa9079f","parentId":null,"rootId":null,"fromId":1145,"content":"破公司谁去谁倒了八辈子血霉","createdAt":"2022-08-17T17:26:54"},{"id":"01963ddb-8d82-703b-9027-d47f3a5aa3f8","parentId":null,"rootId":null,"fromId":1935,"content":"现在欠薪3月了，欢迎新人来[狗头]","createdAt":"2022-10-11T15:52:07"},{"id":"01963ddb-8dc8-70fc-87c3-6927b0f503a9","parentId":null,"rootId":null,"fromId":1546,"content":"我认为遇到问题应该先想想自己的原因而不是一味的抱怨，应该先考虑自己怎么样才能给公司创造更大的价值，公司为我们提供了提升自己能力的机会我们理应感恩，所以我提议刚毕业几年之内的年轻人应当交钱上班而不是一味的索取工资，这样既可以缓解社会上的就业压力，又可以缓解疫情对于小微企业的冲击，可谓一箭双雕，一石二鸟。","createdAt":"2022-10-16T12:29:41"},{"id":"01963ddb-8e0f-71e7-aaaa-8e810d673f89","parentId":null,"rootId":null,"fromId":455,"content":"我c， 刚约了面试，怎么找理由不去呢","createdAt":"2022-10-20T11:10:10"},{"id":"01963ddb-8e58-70c9-b9b8-8be9eccf01d2","parentId":null,"rootId":null,"fromId":2214,"content":"拖欠工资,还好跑得快,联通外包","createdAt":"2022-11-17T15:01:23"},{"id":"01963ddb-8ea0-716e-befd-fab4bd82417f","parentId":null,"rootId":null,"fromId":2244,"content":"早9晚6，加班到9点，并且8点之前不算加班，也就是说从晚7点干到晚10点，才算加班2小时。工资拖欠1个月属于正常，现在情况举个例子，大致是1月工资到3月份发。行政主管赵娜还天天叨叨程序员事多。这是做联通外的，被压榨到要统一加班到9点，10点打车才给报。公司就2、3个技术大神，新人来了，也学不到啥东西。想体验社会黑暗的，欢迎来面试。","createdAt":"2022-12-02T10:07:05"},{"id":"01963ddb-8eed-7223-8e66-804177ab09a7","parentId":null,"rootId":null,"fromId":3774,"content":"是不是搬到了舜泰2号楼911","createdAt":"2023-06-08T08:35:00"},{"id":"01963ddb-8f3a-7169-ac80-29c151a84e14","parentId":null,"rootId":null,"fromId":5602,"content":"济南的互联网环境这么差吗","createdAt":"2023-09-14T13:35:47"},{"id":"01963ddb-8f91-728d-8144-0ac0029d53d6","parentId":null,"rootId":null,"fromId":561,"content":"别说差，一会儿就有人顺着来喷你自己不努力","createdAt":"2023-09-14T14:12:18"},{"id":"01963ddb-8f9c-733b-8429-cd9c01425a7f","parentId":null,"rootId":null,"fromId":3500,"content":"这个公司工资发放及时吗","createdAt":"2023-11-07T11:50:23"},{"id":"01963ddb-8f98-7254-9f6b-7ee78273347d","parentId":null,"rootId":null,"fromId":4016,"content":"你自己不努力","createdAt":"2023-11-07T12:21:06"},{"id":"01963ddb-8fdf-737c-8c82-5117eaf604db","parentId":null,"rootId":null,"fromId":3500,"content":"千万别来 济南私企所有的问题都能找到 公积金100多点 不发工资 外包 大坑！","createdAt":"2023-12-07T09:29:55"},{"id":"01963ddb-9023-72a3-a73a-8ef8f6882200","parentId":null,"rootId":null,"fromId":3500,"content":"入职答应的年终奖一个月工资也是画饼 根本不发！","createdAt":"2023-12-07T09:31:01"},{"id":"01963ddb-9026-737b-bb3a-4aca28b2bf43","parentId":null,"rootId":null,"fromId":3500,"content":"试用期不交五险一金 五险一金也是按照最低交的 公积金一个月就200块钱不到","createdAt":"2024-01-05T13:48:28"},{"id":"01963ddb-906a-71f8-bc25-805d66408100","parentId":null,"rootId":null,"fromId":6616,"content":"拖欠工资明显，五险一金交济南最低，联通外包，联通不给钱就发不下来工资，联通说啥就是啥，没有人权，说是可以借公司的钱，但是公司的账上是一毛钱都没有，幸亏当时离职里的早","createdAt":"2024-02-21T19:38:53"},{"id":"01963ddb-90f1-7273-ae76-2c898c7f1eb5","parentId":null,"rootId":null,"fromId":371,"content":"什么情况了","createdAt":"2024-07-30T15:52:21"}]