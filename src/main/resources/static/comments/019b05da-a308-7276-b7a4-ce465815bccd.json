[{"id":"019b05e5-1c07-7145-88c7-c171be26fb40","parentId":null,"rootId":null,"fromId":22250,"content":"因为程序员的素质其实并不高，有些人在公司又天天被领导叼的跟孙子一样，甚至不敢顶嘴。有人被降薪，被勒令加班不给钱还不敢辞职，久而久之戾气越来越大，随即发泄到网上","createdAt":"2025-12-10T09:34:19"},{"id":"019b05e8-e93e-73bc-9167-54263db3dc7f","parentId":null,"rootId":null,"fromId":2572,"content":"不光这个圈子，眼光放大一些，是不是整个社会戾气都很重？土壤出了问题","createdAt":"2025-12-10T09:38:28"},{"id":"019b05ed-4b68-73c1-9764-72809ef04c7d","parentId":null,"rootId":null,"fromId":22250,"content":"太对了，挣不来钱急的","createdAt":"2025-12-10T09:43:16"},{"id":"019b0606-3a66-71bc-967e-f7dca1c7e35a","parentId":null,"rootId":null,"fromId":21818,"content":"经济下行各行各业都一样","createdAt":"2025-12-10T10:10:30"},{"id":"019b060a-4e18-7211-8fd3-ce97c73e335a","parentId":null,"rootId":null,"fromId":27587,"content":"活该找不到工作，活该被老板骂，活该回家被人看不起","createdAt":"2025-12-10T10:14:57"},{"id":"019b0610-be78-7292-8154-2493b0c6933c","parentId":null,"rootId":null,"fromId":7344,"content":"一针见血哈哈","createdAt":"2025-12-10T10:21:59"},{"id":"019b0619-c9f0-7355-88f4-fe6b7eeb2599","parentId":null,"rootId":null,"fromId":23959,"content":"没毛病","createdAt":"2025-12-10T10:31:52"},{"id":"019b061f-135b-73a7-8764-c615cab144e5","parentId":null,"rootId":null,"fromId":21818,"content":"这圈子还有人能共情老板啊","createdAt":"2025-12-10T10:37:38"},{"id":"019b068c-10ed-725a-a3e0-67d2e5b9a049","parentId":null,"rootId":null,"fromId":22250,"content":"这人脑子有病，估计被老板叼的六亲不认了","createdAt":"2025-12-10T12:36:41"}]