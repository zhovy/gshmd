[{"id":"01963ded-ec78-72d9-878b-2ec10dbe48cb","parentId":null,"rootId":null,"fromId":6050,"content":"可以先干着，后面看看情况再说","createdAt":"2024-04-16T13:09:48"},{"id":"01963ded-ecbe-7309-9d62-217327abd61a","parentId":null,"rootId":null,"fromId":7223,"content":"好的，感谢","createdAt":"2024-04-16T13:19:33"},{"id":"01963ded-ed06-709e-83be-fb080ab5bff7","parentId":null,"rootId":null,"fromId":7223,"content":"好的，感谢。虽然网络教育的本科已经毕业了，但是Boss和智联上多数HR还是直接pass。。","createdAt":"2024-04-16T13:30:23"},{"id":"01963ded-ed13-7384-a2c2-319743722078","parentId":null,"rootId":null,"fromId":6743,"content":"有点难呀，先干着吧。真想在换可以骑驴找马","createdAt":"2024-04-16T13:58:05"},{"id":"01963ded-ed0f-707c-8f4a-12b0321b9600","parentId":null,"rootId":null,"fromId":1039,"content":"网络教育有等于没有","createdAt":"2024-04-16T15:17:54"},{"id":"01963ded-ed57-706f-b396-6062ffcc544f","parentId":null,"rootId":null,"fromId":875,"content":"去大城市","createdAt":"2024-04-16T15:25:27"},{"id":"01963ded-ed9c-714b-a0ab-d776a3fcdc13","parentId":null,"rootId":null,"fromId":6039,"content":"这环境网络教育基本不认啊，统招本科都用不过来，等40之后，有可能学历卡研究生了","createdAt":"2024-04-16T15:39:58"},{"id":"01963ded-ede2-7038-bb24-f1ea6b140caa","parentId":null,"rootId":null,"fromId":3801,"content":"太难了","createdAt":"2024-04-16T16:08:12"},{"id":"01963ded-ee27-7236-915f-45b8b7388b0c","parentId":null,"rootId":null,"fromId":875,"content":"曾经有位领导和我说过，不管在什么企业，你35岁之前没有成家，基本上判定你这个人是没有责任感的，在公司是不能得到公司的认可和重用。\n\n同样的道理，35岁还要到处求职的人，在原有的公司是不被重用的。多年的习惯和职业素养很难融入下一家公司。\n\n好好创业吧，创业没有高低之分，挣钱养家不丢分子！","createdAt":"2024-04-16T23:35:15"},{"id":"01963ded-ee79-724c-a3b6-aa1e8732626e","parentId":null,"rootId":null,"fromId":1955,"content":"40岁老码农这几年的体会，就是先干着吧，别折腾了，努力干好工作，有些工作主动点，让领导还能看到你有用，多学习学习让别人在某些方面让其他人觉得只有你能做的了。别让领导觉得你没啥用了，就可以了。再坚持坚持这几年琢磨琢磨以后的路子？找找方向，做好几手准备，一旦失去IT行业之后怎么能继续活下去，家里的老夫老母，妻子孩子，都得琢磨到了。其实挺累的，这生活","createdAt":"2024-04-17T09:39:19"},{"id":"01963ded-eec0-726f-915d-4543c8b510bf","parentId":null,"rootId":null,"fromId":6743,"content":"老哥你这话听着真扎心，我今年37了，也快喽","createdAt":"2024-04-17T09:41:05"},{"id":"01963ded-ee70-712c-8352-15d66cc27e6e","parentId":null,"rootId":null,"fromId":5624,"content":"又开始了","createdAt":"2024-04-17T09:57:45"},{"id":"01963ded-eec5-7027-955f-f00d13dc8f5b","parentId":null,"rootId":null,"fromId":5790,"content":"好家伙 把站长都整出来了，，哈哈哈哈","createdAt":"2024-04-17T10:21:09"},{"id":"01963ded-eec8-7393-9d0e-34ac9137134f","parentId":null,"rootId":null,"fromId":1261,"content":"老哥，在这家几年了","createdAt":"2024-04-18T07:19:14"},{"id":"01963ded-ee75-72cf-a849-dc797b790fa0","parentId":null,"rootId":null,"fromId":6368,"content":"好一个pua,你还当真了，还35岁之前没得到重用，你要知道会有多少人再以同一时间到达35岁，哪那么多机会让你得到重用。你领导只不过生在了年轻时干软件不倦的年代，仅此而已。总有人把时代的红利归结于个人的成功法则然后PUA别人。","createdAt":"2024-04-18T15:51:41"},{"id":"01963ded-eed5-7011-bdc7-e4abd9cb3fd0","parentId":null,"rootId":null,"fromId":3749,"content":"39岁了转行卖房中介，国民链家！","createdAt":"2024-04-20T20:40:23"},{"id":"01963ded-eed0-7209-9a6f-d46a0a0d410f","parentId":null,"rootId":null,"fromId":576,"content":"别啊，我29刚报名的MBA。大哥们是不是都等着我去创业圈一波钱，然后开几个合适的岗位了？","createdAt":"2024-04-23T17:15:06"}]