[{"id":"019c0c93-7c0f-723f-b149-cc15e71068b3","parentId":null,"rootId":null,"fromId":24428,"content":"补缴了也好取，买房租房都能取出来，怕啥","createdAt":"2026-01-30T09:45:18"},{"id":"019c0c95-84f4-70e8-ac89-2bf1fa8fbedc","parentId":null,"rootId":null,"fromId":27024,"content":"自己的那部分，社保的需要补交。公积金不需要。","createdAt":"2026-01-30T09:47:31"},{"id":"019c0e01-f795-72a0-9f1a-2fdd86377a85","parentId":null,"rootId":null,"fromId":23223,"content":"社保和公积金投诉后，个人部分都需要补缴。另外社保补缴后公司还要出滞纳金。\n社保补缴主要是养老，（理论上）未来退休也不亏，但实际到时怎么样不好说，看你自己。\n公积金补缴更值当，补缴后可以以租房等理由提出来，或者贷款啥的都可以。","createdAt":"2026-01-30T16:25:35"},{"id":"019c1341-5a2a-7067-a418-85938dcb1b62","parentId":null,"rootId":null,"fromId":23942,"content":"举报成功了吗，最后怎么处理的","createdAt":"2026-01-31T16:52:55"},{"id":"019c1477-2c14-72f6-9f0e-add2846b1f38","parentId":null,"rootId":null,"fromId":2783,"content":"别听楼上胡说，公积金和社保都需要补缴的。","createdAt":"2026-01-31T22:31:20"},{"id":"019c1bc4-0a88-702d-965a-a6a3ed843659","parentId":null,"rootId":null,"fromId":6276,"content":"打个12345问问不就行了，在这瞎扯淡","createdAt":"2026-02-02T08:32:38"},{"id":"019c1d13-95fa-724b-899c-de69e5bcd793","parentId":null,"rootId":null,"fromId":27024,"content":"你知道个JB。社保需要补缴是因为只有个人补缴的进个人账户，公司补缴的不进个人账户，公司补了，个人不补缴，个人账户还有没钱。公积金都是进个人账户的，公司直接交就行了。脑瘫东西。","createdAt":"2026-02-02T14:39:08"}]