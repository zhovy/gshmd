[{"id":"01974ae3-45d4-70d2-a0a4-20a8de0c99fa","parentId":null,"rootId":null,"fromId":24827,"content":"然后本人也是被骗的，本来想着报警，联想到大学第一次济南报警经历，感觉济南蛇鼠一窝，报警也没用。给家里人说了，家里人态度是要不把贷交了，这事就过去了。然后一块被骗的全在那靠，相信会给找到工作，本来想的是我们联合，结果发现是一群沟槽的苟，顺便一提，班里有个江西的逆天（并非地域歧视），说交这些钱是应该的，我怀疑是狗托?","createdAt":"2025-06-07T22:54:58"},{"id":"01974ae8-6249-72ec-af48-4f7f0289c35b","parentId":null,"rootId":null,"fromId":24827,"content":"还得知了避雷平台被大学生坑了那事，得，自媒体也帮不了大学生了，码的，沟槽的济南，我祝你经济发展蒸蒸日上","createdAt":"2025-06-07T23:00:32"},{"id":"01974e13-e813-70a9-9e59-75de8b348bd8","parentId":null,"rootId":null,"fromId":23959,"content":"九年前我也是一样被济南培训骗，报警了只是登记一下。啥用没有。","createdAt":"2025-06-08T13:46:56"},{"id":"01974e15-0bdd-7034-9138-b66a7199e319","parentId":null,"rootId":null,"fromId":23959,"content":"哪个地方的  叫什么  避避雷","createdAt":"2025-06-08T13:48:11"},{"id":"01974f5a-dd4a-7277-97bb-743229f58480","parentId":null,"rootId":null,"fromId":24827,"content":"三庆齐盛广场，舜泰广场那边的基本都不用去，全是贷，说几个吧，领达（现在叫海德润），北海软件（弄了个分公司专门搞培训，那边的公司都往这里面送），兴汇（舜泰广场那边的），反正很多，举不过来的","createdAt":"2025-06-08T19:44:04"},{"id":"01974f5c-1555-7335-90c5-085069f0a622","parentId":null,"rootId":null,"fromId":24827,"content":"然后我只能说济南的一些lj公司但比较正规的在这些培训贷公司衬托下居然是比较好的?","createdAt":"2025-06-08T19:45:24"},{"id":"01974f82-79b8-70f5-b1b0-8704b61634eb","parentId":null,"rootId":null,"fromId":6517,"content":"我本地人，也觉得济南就业环境垃圾","createdAt":"2025-06-08T20:27:20"},{"id":"01975223-89de-7279-a1d5-139770bcb0cd","parentId":null,"rootId":null,"fromId":4367,"content":"看到你骂济南，我这本地人气冲冲的冲进来给你点个赞。这些lj公司和不作为的监管，要不是家是济南的，我早撤了","createdAt":"2025-06-09T08:42:30"},{"id":"01975226-9a20-704b-a837-642a385f557f","parentId":null,"rootId":null,"fromId":21267,"content":"报警要是有用，每天还会发生这么多牛鬼蛇神的事情吗","createdAt":"2025-06-09T08:45:51"},{"id":"0197523a-b34f-705b-b58b-a5f242b85d5e","parentId":null,"rootId":null,"fromId":6435,"content":"真的是沆瀣一气的，抖音有个避雷平台，专门帮大学生曝光、维权培训贷的，被他们联手搞掉了","createdAt":"2025-06-09T09:07:48"},{"id":"01975246-deaa-7197-b7fe-a9227b37b2d6","parentId":null,"rootId":null,"fromId":22186,"content":"切记，凡事说自己在济南 什么人才简历网，亦或者什么人才库获得的简历，一律培训班不去，只要是问他你是我在boss上投的哪家公司，不明说的，对不上的都是贷，第二，让你去了写谁介绍来的，大概率是贷","createdAt":"2025-06-09T09:21:05"},{"id":"01975249-eec2-71bc-baad-4b954d207cd8","parentId":null,"rootId":null,"fromId":7124,"content":"只记得15 16年有个叫什么鸟的","createdAt":"2025-06-09T09:24:26"},{"id":"0197528c-2bbc-73b7-bb36-185eae9b9ccb","parentId":null,"rootId":null,"fromId":6186,"content":"济南真就拉胯，租房也是大坑，这还和平年代呢","createdAt":"2025-06-09T10:36:47"},{"id":"0197529c-e11e-704f-88e7-a12c5fa36b3b","parentId":null,"rootId":null,"fromId":22702,"content":"我记得抖音有个培训贷避坑指南的号 人好心帮一些大学生 然后不止一次被大学生背刺 还有上面的不作为 还有这遍地开花的培训贷 然后被针对 被举报 好多人凝聚不起来 可能也是觉着没希望 现在人已经放弃了 不管了 我看到这些真的是无奈又意料中的事 当你你发现一个问题 仔细看 其实是从上到下的可恶 衍生的东西 你以为只是培训贷 更可恶的是周边的这些人","createdAt":"2025-06-09T10:55:02"},{"id":"0197529d-f8bf-7203-b6c9-7adc19c8746f","parentId":null,"rootId":null,"fromId":4357,"content":"济南的就业环境就是一坨","createdAt":"2025-06-09T10:56:14"},{"id":"019752b8-962e-70f6-9c79-ac9bb2e76e3d","parentId":null,"rootId":null,"fromId":1049,"content":"主要是上面不作为，没人管，小老百姓无奈","createdAt":"2025-06-09T11:25:18"},{"id":"019752bf-5321-736b-94d7-ff32871b68c5","parentId":null,"rootId":null,"fromId":6435,"content":"上面不是不作为，是有利益输送，上面都帮忙打压曝光他们的自媒体","createdAt":"2025-06-09T11:32:39"},{"id":"01975331-96a8-71ad-aed7-cacc39dc6e7e","parentId":null,"rootId":null,"fromId":21783,"content":"看看这个贷款上征信吗，很多放贷公司是不合法的，不还也没事","createdAt":"2025-06-09T13:37:28"},{"id":"01975399-4110-732f-9669-cc958c1b26ab","parentId":null,"rootId":null,"fromId":7100,"content":"啥时候面试我陪你们一起去，看看培训贷是啥样的","createdAt":"2025-06-09T15:30:42"},{"id":"01975e6c-a343-72eb-ad2e-077910015ae5","parentId":null,"rootId":null,"fromId":21742,"content":"+1","createdAt":"2025-06-11T17:57:47"},{"id":"01979ba5-b8c5-73c4-964d-85e697a9edb9","parentId":null,"rootId":null,"fromId":4002,"content":"很多","createdAt":"2025-06-23T15:16:58"}]