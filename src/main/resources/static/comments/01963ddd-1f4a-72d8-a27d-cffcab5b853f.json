[{"id":"01963ddd-2066-70c0-ba92-926249a41956","parentId":null,"rootId":null,"fromId":1111,"content":"相比去年，面试岗位少很多，基本都是不缺人的情况，所以公司也不是很着急，慢慢挑选。\n同时面试难度也大幅提升。","createdAt":"2022-10-20T00:31:39"},{"id":"01963ddd-20f3-7111-aad9-1738748e00c1","parentId":null,"rootId":null,"fromId":1959,"content":"失业一个月 不找外包面试没几个 工资稍微高一点连面试都不给 准备这几天不找了 下周再找","createdAt":"2022-10-20T09:57:17"},{"id":"01963ddd-2137-7355-be20-8ae3281b175f","parentId":null,"rootId":null,"fromId":247,"content":"现在基本上都是外包招人","createdAt":"2022-10-20T11:26:02"},{"id":"01963ddd-217f-73b8-a300-fe98f61bdd03","parentId":null,"rootId":null,"fromId":559,"content":"我们这一年的都九千了，现在确实公司不招人，十分饱和，我们都没有活干，还好公司有固定的产品，固定的收入来源","createdAt":"2022-10-20T13:20:52"},{"id":"01963ddd-21c2-737a-8f0b-b7c115e3c204","parentId":null,"rootId":null,"fromId":1656,"content":"啥公司老哥，一年给9k? ，约不到面试了，真的心态崩了","createdAt":"2022-10-20T15:04:20"},{"id":"01963ddd-2207-7086-988b-2585c0880cfe","parentId":null,"rootId":null,"fromId":1515,"content":"都是想低价捡漏","createdAt":"2022-10-22T14:43:35"},{"id":"01963ddd-224a-712b-9a66-3021215cf230","parentId":null,"rootId":null,"fromId":1515,"content":"唉，不好找！你看上的面试不上，你看不上的也tmd也面试不上","createdAt":"2022-10-22T16:40:04"},{"id":"01963ddd-228d-7163-af47-37a1205be6f5","parentId":null,"rootId":null,"fromId":1549,"content":"公司都快倒闭了，上哪找工作去","createdAt":"2022-10-24T11:14:31"},{"id":"01963ddd-22d5-7376-9c57-75961cd55f81","parentId":null,"rootId":null,"fromId":2056,"content":"两月了。有面试，嫌我工资要的高。 php岗和go岗少的可怜啊。 全是java。 心累","createdAt":"2022-10-24T15:48:52"},{"id":"01963ddd-231c-7251-ab9f-fcdc2a1fe808","parentId":null,"rootId":null,"fromId":2057,"content":"你们都几年经验啊  面试少的可怜","createdAt":"2022-10-24T16:04:37"},{"id":"01963ddd-2361-70a0-86b5-0e9da80c66bc","parentId":null,"rootId":null,"fromId":708,"content":"这个网站已经把济南的开发企业大部分收录了。都是黑名单企业。所以就业还是选择外地吧。济南的黑名单企业。赶紧倒闭吧。免得天天被骂","createdAt":"2022-10-26T10:12:02"},{"id":"01963ddd-23c5-70b8-b651-d0226773ab9e","parentId":null,"rootId":null,"fromId":34,"content":"大环境不好啊，我也是，投了简历，回复的很少","createdAt":"2022-10-31T11:31:32"},{"id":"01963ddd-241d-71b9-890b-a82a4c8f0dcb","parentId":null,"rootId":null,"fromId":1703,"content":"要的不多哦","createdAt":"2022-11-03T17:56:56"},{"id":"01963ddd-2464-7117-a53d-5b19d1d7a0e3","parentId":null,"rootId":null,"fromId":641,"content":"我之前6月底裸辞，10月底刚找到工作，之前也没怎么仔细找，主要是在家太安逸了，到后面才有危机感，让同事给内推了一下，就找到了。","createdAt":"2022-11-04T18:24:46"},{"id":"01963ddd-24a8-72cd-b5b1-1294f8962b11","parentId":null,"rootId":null,"fromId":522,"content":"2.5年 工资要的太少了，面试官会觉得实力不强或者培训班出来的","createdAt":"2022-12-07T12:46:40"},{"id":"01963ddd-2505-71a5-9963-a198d17707a3","parentId":null,"rootId":null,"fromId":2389,"content":"一年要了8  3年的时候要了12  ","createdAt":"2023-05-08T15:18:48"},{"id":"01963ddd-254c-7019-a850-dacc41d1b341","parentId":null,"rootId":null,"fromId":2640,"content":"找不到你很正常吗？基本上都是已读不回","createdAt":"2023-06-03T22:38:44"},{"id":"01963ddd-259a-7159-86c8-2ed9d0d81b12","parentId":null,"rootId":null,"fromId":3460,"content":"111","createdAt":"2023-06-15T22:21:27"},{"id":"01963ddd-25e5-7377-8d19-d28eb39188ec","parentId":null,"rootId":null,"fromId":3749,"content":"2年要个6-8之间比较合理，多了那就慢慢碰运气吧，大不了再多等几个月","createdAt":"2023-06-17T16:57:10"},{"id":"01963ddd-2631-71f8-ab51-ba898364a957","parentId":null,"rootId":null,"fromId":4086,"content":"20230714,下班时候领导找我谈话，让我月底离职。。。","createdAt":"2023-07-15T14:23:00"},{"id":"01963ddd-2676-71fd-9294-dbc2f2a170a6","parentId":null,"rootId":null,"fromId":3774,"content":"我靠，这是咋了","createdAt":"2023-07-16T15:29:43"},{"id":"01963ddd-267b-726a-bfde-4366c8c2478f","parentId":null,"rootId":null,"fromId":3369,"content":"月底了","createdAt":"2023-07-25T10:29:14"},{"id":"01963ddd-267f-72a3-a5f2-bfbfa7e9ae64","parentId":null,"rootId":null,"fromId":4182,"content":"让他辞退 N+1","createdAt":"2023-07-26T16:53:40"},{"id":"01963ddd-2683-73d3-a241-d9ea763ce792","parentId":null,"rootId":null,"fromId":7581,"content":"失业有段时间了，现在多少好点了，最起码有面试了，之前三四月份，几乎没有面试，据说都在降本增效，最后找了一家外包，但是感觉不稳定，明年还要再出来找工作，想着还不如今年找到一个稳定点的，明年的话，肯定更难，所以现在又在找工作了，但是感觉大多数都是外包，特别是鲁软的外包、云鼎的外包、浪潮的外包，几乎都是这三个的外包在招人，找个自研的公司，感觉有点困难。","createdAt":"2024-07-15T12:15:33"},{"id":"01963ddd-26c8-7246-9dc4-bd2420b7be8b","parentId":null,"rootId":null,"fromId":2367,"content":"你找的是研发岗位么？","createdAt":"2024-07-16T09:23:36"},{"id":"01963ddd-2716-7333-8cd8-c88dd84da109","parentId":null,"rootId":null,"fromId":21117,"content":"2020届，统招本科，4年前端8k找不到唉，之前面试过了一个，但是心测没过，基本都是投了简历已读不回的状态吧，或者面试过不去，也不知道为啥，基本面试问题都能回答上来的","createdAt":"2024-08-09T10:03:11"},{"id":"01963ddd-275b-732d-a3fd-58c311c2dd63","parentId":null,"rootId":null,"fromId":7550,"content":"兄弟你现在找到工作了吗","createdAt":"2024-08-20T10:48:53"},{"id":"01963ddd-275f-70f7-8961-cb4955c6ec2a","parentId":null,"rootId":null,"fromId":1591,"content":"不光是研发，济南现在都感觉像是一个大漏斗，谁进来就坑谁，投出去的简历先看个人工作经历，有一点不一样都不要；再就是工资，7-15K，大家别看15了，也别看10，就看7就行了，不然没人要。","createdAt":"2024-09-06T11:17:56"},{"id":"01963ddd-23c0-7388-9739-63ee1b0ef435","parentId":null,"rootId":null,"fromId":267,"content":"别胡说八道","createdAt":"2024-09-23T23:08:50"},{"id":"01963ddd-27a6-71fe-ade9-dbceac1f3054","parentId":null,"rootId":null,"fromId":22055,"content":"我这毕业一年没工作，考研失败。只会点交换机，路由器。包装1年经验，投了都是已读不会。?","createdAt":"2024-10-17T19:12:21"},{"id":"01963ddd-27f0-73ee-a52d-a64d4bf312d6","parentId":null,"rootId":null,"fromId":22439,"content":"10月份裸辞的，三年合同到期就走了，身心疲惫，现在休息了两个月开始找工作\n\n话说，不工作两个月又咋了，难道当一辈子牛马才正常","createdAt":"2024-12-12T17:53:06"},{"id":"01963ddd-2836-73cc-a507-edad56fd5970","parentId":null,"rootId":null,"fromId":22972,"content":"找到工作了吗？","createdAt":"2025-03-25T15:57:48"},{"id":"01963ddd-26cd-73cb-a732-c5c331408f21","parentId":null,"rootId":null,"fromId":7074,"content":"我们这自研，公司规模不大，不过研发已经饱和，大专比较多，研发工资15k+，项目忙的时候会加班，不忙的时候很轻松，双休，有事请假很容易便捷。","createdAt":"2025-03-25T16:27:19"},{"id":"019aa105-5ac2-70b2-8bbe-ff5147d0bd4d","parentId":null,"rootId":null,"fromId":2330,"content":"什么神仙公司","createdAt":"2025-11-20T19:27:54"},{"id":"019be36b-6b0c-70ab-82ee-d62996f6e7cb","parentId":null,"rootId":null,"fromId":557,"content":"大佬 公司还招人吗","createdAt":"2026-01-22T09:57:06"},{"id":"019c133a-9198-730e-8057-48993b3be002","parentId":null,"rootId":null,"fromId":23942,"content":"大神，你们是什么公司啊，还有固定产品","createdAt":"2026-01-31T16:45:31"}]