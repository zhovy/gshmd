[{"id":"01963df3-3602-734d-962b-79c473d91884","parentId":null,"rootId":null,"fromId":21529,"content":"去面试了吗 怎么样","createdAt":"2024-09-21T14:01:35"},{"id":"01963df3-3646-70cd-b0cd-03e3f09b3697","parentId":null,"rootId":null,"fromId":1517,"content":"只是在boss上看到了，想了解一下","createdAt":"2024-09-23T10:02:07"},{"id":"01963df3-364b-706f-87a4-e8f6b45eef09","parentId":null,"rootId":null,"fromId":1517,"content":"有熟悉的嘛？","createdAt":"2024-09-26T09:59:01"},{"id":"01963df3-368f-73d9-9af0-f4d671fbc1b5","parentId":null,"rootId":null,"fromId":1517,"content":"又给我发面试邀请了","createdAt":"2024-09-26T09:59:11"},{"id":"01963df3-36d4-7206-8e1f-f4e669627eea","parentId":null,"rootId":null,"fromId":6499,"content":"公积金双边210，0补贴，无年终！","createdAt":"2024-09-30T13:54:19"},{"id":"01963df3-3718-70cf-a2f8-7350b36eb15e","parentId":null,"rootId":null,"fromId":21945,"content":"双休吗？加班情况多吗","createdAt":"2024-10-21T13:35:51"},{"id":"01963df3-371c-704a-98c7-c22b632104ab","parentId":null,"rootId":null,"fromId":677,"content":"工资不及时。大小周。没有年终奖，最低公积金。看谁不顺眼就裁员。研发领导也是刚去的。是个二把刀。研发组有个姓李的小矮子。业务搞不明白，技术不咋滴，还爱装。招聘得时候说不加班，去了就是996。内斗很严重。","createdAt":"2024-12-04T21:20:30"},{"id":"01963df3-3761-722e-93dc-e89a8af486b9","parentId":null,"rootId":null,"fromId":22620,"content":"我就是你说的小矮子，别让我知道你是谁，有本事说出名字。加班咋了，我就是卷他们，技术不好咋了，工资高，反正又没人知道我技术不好，领导又不懂，上面有人，你混的不如别人就嫉妒。","createdAt":"2025-01-16T10:53:49"},{"id":"01963df3-3766-7218-9cf7-3cf1d285ba7e","parentId":null,"rootId":null,"fromId":6371,"content":"上面有人咋了，有种把上面的人名字说出来一块给你办了","createdAt":"2025-01-16T11:22:52"},{"id":"01963df3-376b-73c7-a6e2-38f738c6b8a9","parentId":null,"rootId":null,"fromId":22620,"content":"说了你又不认识，我组属于亲卫队，他们都不懂技术，懂技术的不敢惹我们组。","createdAt":"2025-01-16T15:57:34"},{"id":"01963df3-376f-7180-8f5e-b42831ef0e21","parentId":null,"rootId":null,"fromId":22620,"content":"敢不敢说出你们的名字  我截图给你们招聘人员看看","createdAt":"2025-01-16T16:08:15"},{"id":"01963df3-3773-7183-bfc5-683ab2daa7a6","parentId":null,"rootId":null,"fromId":6371,"content":"你就是个小卡拉米，你先说自己名字我在说我的，你不是有人吗？你说出来，我立马到你面前去","createdAt":"2025-01-16T16:15:43"},{"id":"01963df3-3778-73c6-b6d4-4b9984a38427","parentId":null,"rootId":null,"fromId":4084,"content":"你不是挺识趣，自己滚了吗？写个前端垃圾的一逼，还有脸在这唧唧歪歪？","createdAt":"2025-02-25T10:37:48"},{"id":"01963df3-377c-7365-a434-7db5a51708a8","parentId":null,"rootId":null,"fromId":7281,"content":"进去干了一个月扛不住，有个姓李的沙雕的侏儒要求员工加班，没活也得加，这种狗腿子没法治。","createdAt":"2025-02-25T17:59:48"},{"id":"01963df3-37bf-73c2-a933-dd93bb23f600","parentId":null,"rootId":null,"fromId":1398,"content":"扛不住是不是活特别多？","createdAt":"2025-02-26T07:11:27"},{"id":"01963df3-37c3-70d1-b465-caa8473eab8e","parentId":null,"rootId":null,"fromId":4084,"content":"又换了个马甲？还人身攻击别人？自己这一个多月干的啥样自己没点B数？专升本学历写本科，工作经历山东闻远这一段怎么不写呢，也是干了几个月吧？没拆穿你给你脸你要吗？没活也得加，那是你自己看不见别人有多忙，自己特么在浪潮这种垃圾公司时间长了，划水划多了吧？哪次下去抽烟碰不到你？安排你稍微加会儿班，不是特么媳妇来接你，就是你丈母娘过生日，还有家里被盗了得去公安局，还尼玛舔着脸不请假就出去一下午，真够不要脸的，就尼玛你事多！人家留下的几个，哪个不比你学历好能力强，自己多反思反思自己。济南圈子不大，别没事找事，做人留一线。","createdAt":"2025-02-26T11:30:57"},{"id":"01963df3-37c8-711c-b72d-b73606463d5c","parentId":null,"rootId":null,"fromId":22826,"content":"笑发财，看了这么多帖子，济南圈子也不大，第一次见技术总监亲自下场的呢，主要是还给自己标了“技术总监”的title，生怕别人不知道“郑学兵”老师是个技术总监似的，所以不好意思问一下，郑老师是第一次当技术总监吗？","createdAt":"2025-03-03T11:58:01"},{"id":"01963df3-37cc-735f-8695-a50ee6a124c2","parentId":null,"rootId":null,"fromId":4084,"content":"是啊，对这种不识好歹的玩意，必须亲自下场battle啊。总监不总监的，不能让人污蔑咱兄弟。","createdAt":"2025-03-03T14:58:02"},{"id":"01963df3-37d0-7292-9a00-655885620ec6","parentId":null,"rootId":null,"fromId":22976,"content":"老东家还是那么6，内战老传统了【捂脸笑】","createdAt":"2025-03-19T10:55:37"},{"id":"01967af7-83cf-71e4-9359-0c3f33970926","parentId":null,"rootId":null,"fromId":4084,"content":"兄弟是哪一批？","createdAt":"2025-04-28T13:56:03"},{"id":"019a94d0-dbb9-7360-8639-58cac13ca412","parentId":null,"rootId":null,"fromId":22976,"content":"咦，没人关注老东家了哇，也是好起来了","createdAt":"2025-11-18T10:35:07"},{"id":"019b2b6f-1ea2-7283-8f30-738fdd0ab4a3","parentId":null,"rootId":null,"fromId":26079,"content":"老东家还是有这么多瓜阿，多讲讲，爱听","createdAt":"2025-12-17T16:31:01"}]