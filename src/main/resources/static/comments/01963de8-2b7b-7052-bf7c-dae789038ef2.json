[{"id":"01963de8-2be4-7372-b38f-7a3e9d57605f","parentId":null,"rootId":null,"fromId":3651,"content":"联系方式是微信","createdAt":"2023-09-14T17:25:52"},{"id":"01963de8-2c29-70ea-90c3-46b7dc8c2b02","parentId":null,"rootId":null,"fromId":1997,"content":"直接去一线城市比较好！","createdAt":"2023-09-14T17:45:16"},{"id":"01963de8-2c6f-71b1-9cfc-a68a26cd1ece","parentId":null,"rootId":null,"fromId":2654,"content":"2楼说的有道理，直接去一线城市","createdAt":"2023-09-14T17:49:48"},{"id":"01963de8-2cb3-73ea-95e5-5e112f28881f","parentId":null,"rootId":null,"fromId":2408,"content":"去国企吧，或者考公吧","createdAt":"2023-09-14T20:49:20"},{"id":"01963de8-2cf9-73dc-8637-da33a16a4b51","parentId":null,"rootId":null,"fromId":875,"content":"来济南的话不要进私企，还是去一线城市吧","createdAt":"2023-09-15T00:19:05"},{"id":"01963de8-2d3d-7006-a66b-599591a1863c","parentId":null,"rootId":null,"fromId":4140,"content":"在济南很难找到工资很高的工作，建议去一线，这边估计10k差不多到头了，主要济南唯经验论很严重，没工作经验都不会给很高","createdAt":"2023-09-15T10:00:55"},{"id":"01963de8-2da0-72db-b5cc-962ed48a5ae6","parentId":null,"rootId":null,"fromId":2738,"content":"如果是济南，尽量不要考虑私企。重点放在国企央企（证券，银行，保险依次顺序）信息化岗位的秋招，不需要了解金融领域的东西，秋招前自己补习一点java相关知识，我这边有的也是python的，来了让干java","createdAt":"2023-09-15T13:26:37"},{"id":"01963de8-2df4-733b-a860-918239406564","parentId":null,"rootId":null,"fromId":2738,"content":"补充一下，中信的待遇算是比较好的。如果能面进去，应届生年包大概40W。中信不加班，6点准下班（自己愿意加也可以），而且周末永远不加班，法定假日周末的换休也可以休息，因为周末股市不开市。","createdAt":"2023-09-15T13:30:31"},{"id":"01963de8-2e63-7142-a18e-b3481cabb359","parentId":null,"rootId":null,"fromId":3651,"content":"因为家庭原因，不能考公，只考虑留在济南","createdAt":"2023-09-15T15:49:10"}]