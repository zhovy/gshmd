[{"id":"01963ddb-0939-71ca-8733-15bc7e184803","parentId":null,"rootId":null,"fromId":1038,"content":"同问，最好是软件园附近的，比如舜泰广场、汉峪金谷，或者是奥盛大厦、鑫盛大厦之类的","createdAt":"2022-07-20T09:15:43"},{"id":"01963ddb-097e-73a1-bf49-4c9a21f5ccc1","parentId":null,"rootId":null,"fromId":1039,"content":"华天软件、特来电都不错","createdAt":"2022-07-20T09:31:24"},{"id":"01963ddb-09c2-725c-a56a-d4aef76628fb","parentId":null,"rootId":null,"fromId":800,"content":"华天软件是外包吗， 大小周好像","createdAt":"2022-07-21T11:17:06"},{"id":"01963ddb-0a07-7354-ad87-332fdf5de419","parentId":null,"rootId":null,"fromId":1444,"content":"华天一般都是外包，应该是驻外那种，具体待遇咋样不清楚","createdAt":"2022-08-29T16:20:50"},{"id":"01963ddb-0a4c-7334-86cc-3580e171a436","parentId":null,"rootId":null,"fromId":801,"content":"软件园这边好多对日的企业,你可以去招聘软件上查一下,对日这几家都不错","createdAt":"2022-11-03T15:54:46"},{"id":"01963ddb-0a91-7353-840e-8288ec6cb333","parentId":null,"rootId":null,"fromId":1039,"content":"华天本部没有外包，最多是大项目有外派驻点，驻点补助非常高，最低住宿标准260，最高390，每天90餐补，夏天出差还有高温补贴，\n外派驻点只有项目组存在这种情况，产品部没有，至于工资，同等年限比其他公司高10%到40%，至于高多少，看你能力和项目紧张度","createdAt":"2023-01-10T16:09:36"}]