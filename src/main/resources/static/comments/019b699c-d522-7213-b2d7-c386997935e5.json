[{"id":"019b69a7-7985-729b-9117-a3f69e86979d","parentId":null,"rootId":null,"fromId":27572,"content":"让你做产品运营本职工作的基础上多干点测试的活","createdAt":"2025-12-29T18:29:01"},{"id":"019b6a1a-b80d-70bd-97d0-4681d1215ced","parentId":null,"rootId":null,"fromId":27703,"content":"怎么看着像客服呢……","createdAt":"2025-12-29T20:34:54"},{"id":"019b6c9f-16a0-73b5-8a04-596f8a89ba20","parentId":null,"rootId":null,"fromId":5480,"content":"当然是让你只拿一份钱，干两份活了","createdAt":"2025-12-30T08:18:44"},{"id":"019b6cb4-0e4c-7357-b9c7-2fea3aa49641","parentId":null,"rootId":null,"fromId":5725,"content":"实施、测试、运维","createdAt":"2025-12-30T08:41:38"},{"id":"019b6ccc-673b-73c1-a905-0173cebc30b6","parentId":null,"rootId":null,"fromId":7074,"content":"这不是写的很清楚么，人家招一个会做产品和运营的测试，只给一个岗位的工资哦","createdAt":"2025-12-30T09:08:13"},{"id":"019b6cdc-597c-7311-8467-22c3abdc65cd","parentId":null,"rootId":null,"fromId":27118,"content":"看起来像是   集测试，售后，需求一体的 “产品经理”","createdAt":"2025-12-30T09:25:38"},{"id":"019b6ce6-4144-736b-81b2-9fad9fc5e63f","parentId":null,"rootId":null,"fromId":27572,"content":"典型的既要又要还要","createdAt":"2025-12-30T09:36:27"},{"id":"019b6d18-1eb8-7305-8de2-edc21b68da56","parentId":null,"rootId":null,"fromId":24615,"content":"这确实是一个运营应该干的活，我给你翻译成大白话。\n1、处理日常客户反馈的问题\n2、将用户反馈的问题进行整理归纳，系统bug及功能优化定期交给研发解决\n3、根据第2项归纳的问题，等小组开会或者领导问你时，可以提出一些优化建议，别半天憋不出一个字来\n4、有时用户反馈了一个问题，但是描述不清晰，你反馈给研发后，研发反问了你一些细节，你需要再跟用户确认\n5、日常处理的问题，你需要将解决方式整理到文档中，方便自己和其他人也能处理\n6、有时需要给用户培训，你可以去，一个培训的ppt复用几十遍，你就是去讲讲，但一般用不上你","createdAt":"2025-12-30T10:30:55"},{"id":"019b6d54-05ac-73fa-ab21-9d45cec81695","parentId":null,"rootId":null,"fromId":27572,"content":"必须具备系统运维和测试经验","createdAt":"2025-12-30T11:36:21"}]