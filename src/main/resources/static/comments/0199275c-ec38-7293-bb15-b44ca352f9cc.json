[{"id":"01992851-46d0-70d0-bf1c-b3cbd57abe6c","parentId":null,"rootId":null,"fromId":2246,"content":"那不一定，气氛活跃，工位有乱七八糟的东西，还有下午茶的公司，一般996起来很猛。","createdAt":"2025-09-08T15:53:59"},{"id":"019928d1-1bd6-735f-af35-f53c56b935b6","parentId":null,"rootId":null,"fromId":22724,"content":"那咋判断这个公司值不值得待下去啊","createdAt":"2025-09-08T18:13:36"},{"id":"01992bcc-fe42-72f7-b63d-e4de284f1f80","parentId":null,"rootId":null,"fromId":2246,"content":"给你一个最直观的，看公司大姐大妈多不多，尤其是四十岁以上的。","createdAt":"2025-09-09T08:07:58"},{"id":"01992cff-5237-72f1-8c89-820385b45307","parentId":null,"rootId":null,"fromId":3319,"content":"多了好 还是少了好","createdAt":"2025-09-09T13:42:34"},{"id":"01992d26-9467-7287-8dce-f9d471591084","parentId":null,"rootId":null,"fromId":2246,"content":"多了好，女的经历过生孩子休产假，还能在公司干的，说明公司有经济实力，稳定。","createdAt":"2025-09-09T14:25:27"}]