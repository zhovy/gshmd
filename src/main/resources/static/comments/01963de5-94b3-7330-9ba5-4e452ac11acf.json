[{"id":"01963de5-951d-702c-a3ea-ad3452710353","parentId":null,"rootId":null,"fromId":3663,"content":"朋友也是大专，外包在某潮。学不到技术，3年经验9k。估计以后要想继续在这行发展又得卷学历又得卷经验。但是不干这行又该去干啥呢，好像也没啥可干的。","createdAt":"2023-07-28T15:05:40"},{"id":"01963de5-957a-730b-8171-1c4370a5c84f","parentId":null,"rootId":null,"fromId":2859,"content":"升本，专科已经没有竞争力了。","createdAt":"2023-07-28T15:10:03"},{"id":"01963de5-9561-7054-81e7-bdfad74e5751","parentId":null,"rootId":null,"fromId":2821,"content":"公积金多少","createdAt":"2023-07-28T15:10:11"},{"id":"01963de5-9565-73fa-ad69-cad7c1fbcf5d","parentId":null,"rootId":null,"fromId":3663,"content":"这个我不知道啊","createdAt":"2023-07-28T15:11:40"},{"id":"01963de5-95be-7287-b70c-5d6cff68c936","parentId":null,"rootId":null,"fromId":3663,"content":"升本然后呢，还得考研吗","createdAt":"2023-07-28T15:11:53"},{"id":"01963de5-95c3-734a-ab3e-317d42084348","parentId":null,"rootId":null,"fromId":3663,"content":"我报了升本的课程了","createdAt":"2023-07-28T15:12:02"},{"id":"01963de5-95cb-713f-8b9b-9aad92d4f598","parentId":null,"rootId":null,"fromId":3960,"content":"大专+非全日制的本科，工作四年多了。去年的话就业环境还挺好的，今年难死。有的公司要统招全日的，接了没几个面试，不着急就业挣钱结婚的话可以往上升升学历","createdAt":"2023-07-28T15:13:45"},{"id":"01963de5-9569-70b1-b586-7e561f836d6b","parentId":null,"rootId":null,"fromId":2197,"content":"外包基本都是济南最低标准吧，自己一个月交150~200？","createdAt":"2023-07-28T15:15:16"},{"id":"01963de5-95c7-71a1-b1e7-f32edbf7f43d","parentId":null,"rootId":null,"fromId":1421,"content":"嗯，考研，考公","createdAt":"2023-07-28T15:15:35"},{"id":"01963de5-9611-7355-9745-f4b11c67f8a4","parentId":null,"rootId":null,"fromId":3663,"content":"那你找到工作了吗","createdAt":"2023-07-28T15:16:57"},{"id":"01963de5-9616-7075-b3ac-442d34c398cc","parentId":null,"rootId":null,"fromId":3960,"content":"这么难，哪里敢辞职啊。狗公司扣绩效，还追扣上半年的绩效。得忍着，等找到工作再换","createdAt":"2023-07-28T15:27:47"},{"id":"01963de5-961e-73f2-baa4-03599bac2aea","parentId":null,"rootId":null,"fromId":1039,"content":"毋庸置疑   升本吧   现在全要求全日制本科，专科毕业=失业","createdAt":"2023-07-28T16:52:29"},{"id":"01963de5-9666-7337-88fe-bc94c880be5f","parentId":null,"rootId":null,"fromId":2714,"content":"没有什么好考虑的，升本","createdAt":"2023-07-28T17:03:08"},{"id":"01963de5-96ba-70f1-9930-9cd06536143d","parentId":null,"rootId":null,"fromId":1727,"content":"学历跟技术总得有一个吧，要不现在这社会出去不好干","createdAt":"2023-07-28T17:08:55"},{"id":"01963de5-9700-72df-aac3-af60e15e61f9","parentId":null,"rootId":null,"fromId":258,"content":"必须升本，专科学历基本连大公司的门都进不去","createdAt":"2023-07-28T17:14:41"},{"id":"01963de5-9744-70f7-9ae9-abbe76a6230c","parentId":null,"rootId":null,"fromId":1003,"content":"不应该是当警官吗","createdAt":"2023-07-28T17:19:32"},{"id":"01963de5-978c-70f4-bffb-0decd103246f","parentId":null,"rootId":null,"fromId":3671,"content":"专科根本入不了行，专升本现在也都不要，换行吧","createdAt":"2023-07-28T20:04:30"},{"id":"01963de5-97e1-7000-b434-9702c3204de9","parentId":null,"rootId":null,"fromId":2921,"content":"想混日子就升本，想走技术路线就工作。市场是公平的，不可能你既没学历又混日子别人还要你。至于楼里回复无脑升本的，多是混子，我就是专科，工作十多年了，只要技术好哪里都有人要，尤其是经济艰难的时候，技术是完爆学历的","createdAt":"2023-07-29T09:33:06"},{"id":"01963de5-9824-7063-8521-963265e2ae7f","parentId":null,"rootId":null,"fromId":4207,"content":"敢为阁下就职何公司，任职何职务，待遇何如，可顾家乎？最近寻职乎？可入国企乎？","createdAt":"2023-07-29T10:17:55"},{"id":"01963de5-982a-71f4-a022-7c3cb8315046","parentId":null,"rootId":null,"fromId":4207,"content":"在其它环境下，还有讨论的可能性，就济南这破环境，9成以上都是做业务的，技术牛逼和不牛逼的还能有多大个差距，时间越长差距越小。但是学历是时间越长，影响越大，有些公司有学历就能进，没学历的，你技术在牛逼也进不来。","createdAt":"2023-07-29T10:27:48"},{"id":"01963de5-97cf-714e-bc55-b50d5576fd98","parentId":null,"rootId":null,"fromId":3663,"content":"说得轻松，换行你给指路吗","createdAt":"2023-07-29T10:51:39"},{"id":"01963de5-9837-702a-a4b8-76e94ea6a153","parentId":null,"rootId":null,"fromId":875,"content":"还升本，济南hr会查你第一学历的","createdAt":"2023-07-29T11:30:33"},{"id":"01963de5-987b-706c-b064-5fedbcfe450d","parentId":null,"rootId":null,"fromId":3663,"content":"你懂吗？不懂就别说了吧，全日制专升本，第一学历就是本科","createdAt":"2023-07-29T15:30:10"},{"id":"01963de5-982e-734d-bc85-7f91573f52c2","parentId":null,"rootId":null,"fromId":1391,"content":"不要忽悠人了，学历是门槛，门槛都过不去，谈何就业，学历不同薪资 不同，专科的学历连上岸报名机会都没有","createdAt":"2023-07-29T17:13:40"},{"id":"01963de5-9570-73d2-afa3-dd508f6b7261","parentId":null,"rootId":null,"fromId":108,"content":"学历普遍都在提高，这是一个大趋势，不光是软件行业，其他行业也基本一样。学历是敲门砖，至少要有一个统招的本科学历，经验再慢慢积累。","createdAt":"2023-07-29T18:55:27"},{"id":"01963de5-988d-7380-85f3-73884681995b","parentId":null,"rootId":null,"fromId":1656,"content":"肯定升本科啊，可得是全日制本科，函授的就算逑了","createdAt":"2023-07-30T17:48:22"},{"id":"01963de5-9881-721e-9219-f1e777c5268f","parentId":null,"rootId":null,"fromId":875,"content":"专升本，第一学历是专科，hr不看的","createdAt":"2023-07-30T19:01:07"},{"id":"01963de5-98d3-713a-bca2-01c531dbfc34","parentId":null,"rootId":null,"fromId":3112,"content":"一定要升本！一定要升本！一定要升本！","createdAt":"2023-07-31T08:28:27"},{"id":"01963de5-9917-7279-b7a4-56bed064bc01","parentId":null,"rootId":null,"fromId":4057,"content":"你是来咨询的吗?说不到你心里就怼人?没礼貌","createdAt":"2023-07-31T09:45:11"},{"id":"01963de5-9966-729a-a34a-a80fbae2a4b7","parentId":null,"rootId":null,"fromId":2821,"content":"你是来咨询的吗?说不到你心里就怼人?没礼貌\n","createdAt":"2023-07-31T09:56:16"},{"id":"01963de5-99b2-73c2-a50d-78419a5d5956","parentId":null,"rootId":null,"fromId":2821,"content":"你是来咨询的吗?说不到你心里就怼人?没礼貌\n","createdAt":"2023-07-31T09:56:19"},{"id":"01963de5-99ff-7329-81f6-7ebfbd154acf","parentId":null,"rootId":null,"fromId":2821,"content":"流氓学院是这样的","createdAt":"2023-07-31T09:56:57"},{"id":"01963de5-9a49-7105-af02-395e1774b72f","parentId":null,"rootId":null,"fromId":2821,"content":"都给你们铐起来","createdAt":"2023-07-31T09:57:08"},{"id":"01963de5-9a8d-70dc-93af-a6685164b87b","parentId":null,"rootId":null,"fromId":2821,"content":"重开吧废物","createdAt":"2023-07-31T09:57:42"},{"id":"01963de5-9ad7-714f-9bf2-5154326b216b","parentId":null,"rootId":null,"fromId":21,"content":"可把你牛坏了，就你这样的，升也升不上，出来也找不到工作","createdAt":"2023-07-31T10:00:58"},{"id":"01963de5-9b25-71df-b424-f233b0c5220e","parentId":null,"rootId":null,"fromId":2821,"content":"什么叫专科没人要，专升本更没人要？本科不如专科？","createdAt":"2023-07-31T10:01:03"},{"id":"01963de5-9b6a-7138-a74b-d681ad637759","parentId":null,"rootId":null,"fromId":2821,"content":"马上本升专","createdAt":"2023-07-31T10:02:15"},{"id":"01963de5-9bae-711e-a4e0-1316fc2c8c94","parentId":null,"rootId":null,"fromId":2821,"content":"未来可期","createdAt":"2023-07-31T10:02:35"},{"id":"01963de5-9bf3-713e-a649-66ff7b59c5d0","parentId":null,"rootId":null,"fromId":2821,"content":"你既然认为专升本更没人要且含金量高还是得考研，你不先升本考你妈的研?","createdAt":"2023-07-31T10:04:50"},{"id":"01963de5-97d4-7011-9ccd-5bdf12beeadb","parentId":null,"rootId":null,"fromId":2821,"content":"换行给你指路？叫一声爹就给你指路","createdAt":"2023-07-31T10:11:07"},{"id":"01963de5-9c3c-7064-abac-b41ca40837f4","parentId":null,"rootId":null,"fromId":4086,"content":"专升本，考研","createdAt":"2023-07-31T10:29:16"},{"id":"01963de5-9885-70a8-8660-ae973ebe7d65","parentId":null,"rootId":null,"fromId":3671,"content":"兄弟，升本的学历公司都不认！！！升本之后再考研吧，要不然别升本！！！","createdAt":"2023-07-31T10:51:19"},{"id":"01963de5-9cf4-71fa-9be8-60c64807cd90","parentId":null,"rootId":null,"fromId":236,"content":"升本吧","createdAt":"2023-07-31T10:54:54"},{"id":"01963de5-97d8-7224-a2e4-862cd714b2e7","parentId":null,"rootId":null,"fromId":3671,"content":"没路可指，想入行，就要好好学，大三了才考虑升本和工作，有点晚，你现在要不就升本+考研，要不就花半年多时间自学一下，但是学了不一定有用，好好考虑吧，还不晚。","createdAt":"2023-07-31T10:55:12"},{"id":"01963de5-9d39-7093-a737-c723ff207330","parentId":null,"rootId":null,"fromId":4213,"content":"专升本吧 最起码以后找工作不说学历比其他人高吧 但是确实大专学历稍低了 我现在就处在没学历的尴尬上","createdAt":"2023-07-31T11:26:24"},{"id":"01963de5-9c37-7238-a5cf-a59f8b6fabc6","parentId":null,"rootId":null,"fromId":3663,"content":"我哪说我考研了，你脑子没事吧","createdAt":"2023-08-02T17:23:59"},{"id":"01963de5-9b1c-7180-811a-fbecd49af1cb","parentId":null,"rootId":null,"fromId":3663,"content":"？？我哪里牛了","createdAt":"2023-08-02T17:26:24"},{"id":"01963de5-97dc-71f3-ac5d-88d7fb86a684","parentId":null,"rootId":null,"fromId":3663,"content":"在出租屋吃你的泡面吧，傻逼","createdAt":"2023-08-02T17:27:25"},{"id":"01963de5-9dcb-71b8-b8fc-052520592381","parentId":null,"rootId":null,"fromId":3663,"content":"好的谢谢","createdAt":"2023-08-02T17:27:59"},{"id":"01963de5-9b21-7150-851d-cbedd6e54650","parentId":null,"rootId":null,"fromId":3663,"content":"你是多玻璃心，我哪里表现出牛了，没想明白。整天爬电脑前面不跟人交流趴傻了？","createdAt":"2023-08-02T17:28:48"},{"id":"01963de5-9dd0-71d4-a484-99f35de6d3e6","parentId":null,"rootId":null,"fromId":2821,"content":"可把你牛坏了，就你这样的，升也升不上，出来也找不到工作\n","createdAt":"2023-08-02T17:33:38"},{"id":"01963de5-9889-71de-95fd-1f57a23c681c","parentId":null,"rootId":null,"fromId":4010,"content":"虽说第一学历显示本科，但是学历证上显示是专科起步，就看公司卡不卡你了","createdAt":"2023-08-03T14:40:32"},{"id":"01963de5-9e13-72d2-98da-e64319717696","parentId":null,"rootId":null,"fromId":3663,"content":"哪个哥们裤拉链没拉紧把你给漏出来了","createdAt":"2023-08-03T23:19:02"},{"id":"01963de5-9ad3-735f-b76f-713979187fe6","parentId":null,"rootId":null,"fromId":3663,"content":"把你塞回你妈妈的13里吧","createdAt":"2023-08-03T23:19:35"},{"id":"01963de5-9962-728a-99d6-9e20aa36410e","parentId":null,"rootId":null,"fromId":3663,"content":"我怼谁了，我说专升本第一学历是本科有什么毛病？专科起点而已啊，跟高中起点一样的啊都是全日制本科，但是第一学历确实是本科啊。你咋了玻璃心","createdAt":"2023-08-03T23:21:02"},{"id":"01963de5-9e18-7039-a501-6867a197f4e4","parentId":null,"rootId":null,"fromId":2890,"content":"跟专科相关的我们统统不要","createdAt":"2023-08-04T09:05:58"},{"id":"01963de5-9574-728c-8156-9254c55a4121","parentId":null,"rootId":null,"fromId":457,"content":"俺也一样，从自研，离职了，只找到了浪潮外包的工作，浪潮低代码平台，根本啥也学不到，每天拖拉拽组件","createdAt":"2023-08-06T20:55:40"},{"id":"01963de5-961a-724a-80ba-42512c09e85a","parentId":null,"rootId":null,"fromId":457,"content":"确实，也不知道为啥，今年根本就没有面试机会，Boss直聘 智联招聘上，全是已读不回，根本就不让去面试，哎，不知道，找找之前的同事内推看怎么样？","createdAt":"2023-08-06T20:58:00"}]