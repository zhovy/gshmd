[{"id":"019b211c-22dc-73f6-9274-ca42af08b002","parentId":null,"rootId":null,"fromId":926,"content":"如果说压力小，钱多的话，应该是城商行首选，云鼎加班很多，神舟航天工资比较难涨","createdAt":"2025-12-15T16:24:10"},{"id":"019b2134-2be7-71cc-a6d8-4f69fd1819c9","parentId":null,"rootId":null,"fromId":22972,"content":"老弟，一线城市打拼一下吧","createdAt":"2025-12-15T16:50:25"},{"id":"019b213b-0c66-7268-b8c6-bf95ec9b7ae5","parentId":null,"rootId":null,"fromId":25783,"content":"同秋招，我是你的话会选神舟航天","createdAt":"2025-12-15T16:57:56"},{"id":"019b2217-5c50-7287-a7b7-3f95ca525431","parentId":null,"rootId":null,"fromId":2776,"content":"我专门登录一下回复，我比较赞同 2 楼的建议，在济南一个月拿 1w 根本没有性价比，又是工作环境差又是私企，去一线工作你就有一定可能实现人生价值的较大提升，当然机会越来越少，但是也是比山东这种多很多。说这么多，还是看个人，自己家庭条件尚可，可以选择济南。但是千万不要因为恋家离家近之类的原因选择济南。","createdAt":"2025-12-15T20:58:34"},{"id":"019b24ce-634c-72fb-b9f6-fe7f4aab9a0f","parentId":null,"rootId":null,"fromId":23959,"content":"选择哪里好一点","createdAt":"2025-12-16T09:37:44"},{"id":"019b24e0-853a-71d3-a5a4-2f24824d1e94","parentId":null,"rootId":null,"fromId":26709,"content":"985本硕，云鼎？山能那个？我也收到offer了","createdAt":"2025-12-16T09:57:32"},{"id":"019b250c-5530-701e-b1c9-ab97a0b60699","parentId":null,"rootId":null,"fromId":27591,"content":"是的，综合考虑感觉和城商行差不太多，我先决定不违约了","createdAt":"2025-12-16T10:45:23"},{"id":"019b250d-68e5-7177-9324-01d65caa6a79","parentId":null,"rootId":null,"fromId":27591,"content":"感谢建议。但是已经对大城市大厂祛魅了，这几家都算是央企国企，还是留在济南吧","createdAt":"2025-12-16T10:46:34"},{"id":"019b6ec2-7eff-7007-a4ba-b5ae44950933","parentId":null,"rootId":null,"fromId":26466,"content":"同学准备去云鼎嘛，了解的差评比较多。我也拿到了这家单位的offer，可以交流一下","createdAt":"2025-12-30T18:16:38"}]