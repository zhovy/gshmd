[{"id":"01963de9-932b-70b4-91d6-676653820c47","parentId":null,"rootId":null,"fromId":3892,"content":"唉，找个工作这么难，兄弟你找到合适的工作了吗？","createdAt":"2023-11-09T20:46:31"},{"id":"01963de9-9377-7320-a181-e78012b6898a","parentId":null,"rootId":null,"fromId":6090,"content":"出现狗了","createdAt":"2023-11-16T09:03:42"},{"id":"01963de9-937c-71d2-af7e-55d7edfd97d6","parentId":null,"rootId":null,"fromId":6315,"content":"这样的公司就要曝光，不诚信。","createdAt":"2023-12-19T18:19:57"},{"id":"01963de9-93f6-72e5-94a5-57a9d2133d16","parentId":null,"rootId":null,"fromId":6090,"content":"以上信息属实，现在实施与外地员工大裁员，让人家自己跑济南谈，而且车票不报销，可想而知，这帮牲口多么没底线","createdAt":"2024-02-25T16:00:40"},{"id":"01963de9-943f-701c-b728-fbc450f9be91","parentId":null,"rootId":null,"fromId":6090,"content":"现在 公司已经没有不行了，存在的产品只有合理用药，而且项目骨干都没了，基本就剩售后了，除了几个倒戈的墙头草，其他的都跟公司对立；目前项目运维也维持不住了；基本要倒闭或者搬了武汉去了。杨博雇了几个狗腿子打扫擦屁股；干些伤天害理遭天谴的事，估计这几个狗腿子也都没后代。","createdAt":"2024-03-10T20:58:29"},{"id":"01963de9-9488-727c-aed7-60ad5f88d1c0","parentId":null,"rootId":null,"fromId":6419,"content":"缝缝补补又仨月，好好干，来年给你换个嫂子。","createdAt":"2024-07-01T14:50:56"}]