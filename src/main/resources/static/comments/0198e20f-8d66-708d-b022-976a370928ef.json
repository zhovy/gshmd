[{"id":"0198e217-4ac3-7264-907e-2adf86ab1dd1","parentId":null,"rootId":null,"fromId":26605,"content":"没有没好消息的","createdAt":"2025-08-26T00:37:14"},{"id":"0198e219-1c17-72a1-9f93-ed2d23546299","parentId":null,"rootId":null,"fromId":26605,"content":"楼主是从济南入的，去日照培训","createdAt":"2025-08-26T00:39:13"},{"id":"0198e396-b5b0-72a8-b5de-d4b82ca20fb7","parentId":null,"rootId":null,"fromId":25859,"content":"据说是转正需要答辩，然后挑你毛病降薪，不同意就让你走，别的帖子有","createdAt":"2025-08-26T07:36:01"},{"id":"0198e3d6-c3b2-73e5-b7e4-be3ff9bf3254","parentId":null,"rootId":null,"fromId":22250,"content":"凡是培训的就别去了，不正规，借着培训的幌子搞你","createdAt":"2025-08-26T08:45:59"},{"id":"0198e428-4403-72da-8da0-bf21e32446d4","parentId":null,"rootId":null,"fromId":26605,"content":"我看也有干了好多年的人","createdAt":"2025-08-26T10:15:00"},{"id":"0198e428-ed25-73c0-80a0-912b9d400c0c","parentId":null,"rootId":null,"fromId":26605,"content":"培训，熟悉团队。给免费安排住的地方","createdAt":"2025-08-26T10:15:44"},{"id":"0198e61d-f95a-7129-859d-649682f6ac89","parentId":null,"rootId":null,"fromId":24615,"content":"放100%的心，入职去培训很正常","createdAt":"2025-08-26T19:23:00"},{"id":"0198e637-00e3-71a0-ba30-c5da8ef85419","parentId":null,"rootId":null,"fromId":26605,"content":"你去至信的吗？合同，offer都不写薪资，怎么搞啊","createdAt":"2025-08-26T19:50:21"},{"id":"0198e685-0596-73fe-adf6-34cb685c8bab","parentId":null,"rootId":null,"fromId":24615,"content":"我年纪大，这年头可跳槽不了，我觉得合同里不写薪资很正常，至少我目前公司合同里也不写薪资，但是入职时offer邮件会写明薪资。我看这家公司总部在外市，入职去培训，熟悉公司制度和产品开发流程很正常，回济南办公，远离总部，这属于开拓市场，压力应该会小一些，如果公司在走下坡路，也是最先放弃的地方","createdAt":"2025-08-26T21:15:34"},{"id":"0198e72e-37e0-709a-b5ac-3070cd6264e9","parentId":null,"rootId":null,"fromId":26605,"content":"唉，纠结要不要去","createdAt":"2025-08-27T00:20:22"},{"id":"019904e5-41d8-7148-a287-b8be30e32aad","parentId":null,"rootId":null,"fromId":3345,"content":"去了么朋友？我也在纠结这个","createdAt":"2025-09-01T18:49:17"},{"id":"019907dc-1935-72c7-96b2-f97c5f157427","parentId":null,"rootId":null,"fromId":3345,"content":"你去了么？ 路费报销么？","createdAt":"2025-09-02T08:38:08"},{"id":"019911d1-7df6-70af-b305-6e6ca50a0031","parentId":null,"rootId":null,"fromId":26605,"content":"报销个屁，我去了跟宿舍聊天。得知：从济南找人去日照干项目，日照招不到人。而且安排的宿舍连个风扇都没有，热的要死，第二天就走了","createdAt":"2025-09-04T07:02:46"},{"id":"019911d1-b885-72fe-935b-98436671c8c1","parentId":null,"rootId":null,"fromId":26605,"content":"跟舍友","createdAt":"2025-09-04T07:03:00"},{"id":"01991900-8843-7179-bde1-99212b792212","parentId":null,"rootId":null,"fromId":2540,"content":"如果你在这上面，看到了一些正面的评论，请仔细鉴别（可能是公司的领导发布的），如果你想不撞南墙不回头，欢迎入职～","createdAt":"2025-09-05T16:31:29"},{"id":"01991a3d-c425-70b9-a83a-0b9c82625fef","parentId":null,"rootId":null,"fromId":2540,"content":"一句话总结，宁愿去外包也不要来这家公司！ 不听劝的就来试一试，敢保证，你绝对会后悔！","createdAt":"2025-09-05T22:17:59"},{"id":"01996c4b-15bd-72c3-994c-eba166356929","parentId":null,"rootId":null,"fromId":22183,"content":"大家小心，刚开始说一星期，来了后就是各种理由不让走，在日照呆的太难受，每天下班没有一个走的，天天加班到9点半，只有到9点半才算加班","createdAt":"2025-09-21T20:41:24"},{"id":"019970ed-98ff-73af-b6ab-f6be9784c9ee","parentId":null,"rootId":null,"fromId":2558,"content":"都是纯牛马干技术 还需要了解培训公司  呵呵哒 什么公司这么牛逼 阿里 华为也没见去总部培训 一个月","createdAt":"2025-09-22T18:17:23"},{"id":"0199d09f-b523-739f-aa27-d80d9d70b2d6","parentId":null,"rootId":null,"fromId":27051,"content":"俺们报销啦嘻嘻","createdAt":"2025-10-11T08:15:51"}]