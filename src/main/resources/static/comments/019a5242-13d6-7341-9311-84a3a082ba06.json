[{"id":"019a52a0-87d3-7285-8882-0ec28d3a97d1","parentId":null,"rootId":null,"fromId":23067,"content":"m","createdAt":"2025-11-05T14:07:23"},{"id":"019a7fef-03f8-71bb-a105-9e7d50a7f38d","parentId":null,"rootId":null,"fromId":21819,"content":"这个公司正在走下坡路，硬件那边最近已经离职了好几个大牛了，现在就剩下几个小卡拉米。硬件的直属经理是一个做工业设计的漂亮女士，硬件知识基本不懂，剩下的你自己想吧。工作日肯定是要加班的，加班太少不但年底评优没有你而且大领导要找你谈话。双休基本能保证，但有什么事情你也必须要来，法定节假日正常放假，但也会遇到不分时间地点的电话轰炸。福利什么的一概没有，连续3年没发年终奖了。公司创始人去了济南重机，剩下的一个姓邓的销售出身的管理着公司，一直都在瞎折腾。","createdAt":"2025-11-14T09:16:01"},{"id":"019a7ff2-92db-73d5-8fe2-46d129486678","parentId":null,"rootId":null,"fromId":21819,"content":"有什么想知道的还可以继续问?","createdAt":"2025-11-14T09:19:55"},{"id":"019a872c-9d1d-733a-a171-a133d3d5e608","parentId":null,"rootId":null,"fromId":26789,"content":"工资能按时发吗，女生会不会容易被裁员啊今年应届","createdAt":"2025-11-15T19:00:39"},{"id":"019a94d4-02ba-729d-9486-e246b6320bc5","parentId":null,"rootId":null,"fromId":21819,"content":"薪资准时发放，从不拖欠。只要能进去，使劲卷肯定不会被裁。按时上下班的话就不好说了。","createdAt":"2025-11-18T10:38:33"},{"id":"019a94d4-5187-73f8-890d-bafe7301ff04","parentId":null,"rootId":null,"fromId":21819,"content":"不方便联系，有问题可以问。","createdAt":"2025-11-18T10:38:53"}]