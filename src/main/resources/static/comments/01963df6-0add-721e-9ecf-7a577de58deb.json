[{"id":"01963df6-0b44-710c-89ac-fc8245e0ad38","parentId":null,"rootId":null,"fromId":22552,"content":"济南现在为什么这么多外包，到处是","createdAt":"2025-01-03T10:40:42"},{"id":"01963df6-0b94-71a1-82ae-70c434675927","parentId":null,"rootId":null,"fromId":2104,"content":"让司机原路发回","createdAt":"2025-01-03T11:04:37"},{"id":"01963df6-0b86-72db-936e-f6303c6f3f55","parentId":null,"rootId":null,"fromId":3279,"content":"济南本来就是外包之城，所谓的工业强省，最强的就是吃苦耐劳且物美价廉的工程师，15年前给日韩外包，如今给国企外包。北京一个分包下来，杭州公司少了50万不做，济南公司30万就能拿还可以再掏10万茶水费。剩下的20万，再10万块钱外包给小团队。\n这也不能怨山东程序员不值钱，当年济南程序员的薪资和福利还是一众外包给拉起来的。本土自研项目被所谓的唯一国企大厂吃干抹净，你要真能形成规模也算是立起来，别人搞财务你也搞，搞稀碎，别人搞erp你也搞，搞半途而废把.net换java，自己垃圾抱怨微软来了？五年前开始搞AI，科大讯飞的大模型都免费开放了，你的大模型连发布会都没法真机测试，搞个PPT糊弄鬼呢？别人家科技产业园都是化景为园，要么山川流水要么科技感十足，谁家好人弄俩黑牌坊怼马路边上。","createdAt":"2025-01-03T11:05:54"},{"id":"01963df6-0bd7-73ce-8ce1-6c6b147cd7aa","parentId":null,"rootId":null,"fromId":3279,"content":"这哪是正式工的福利，这不就是给劳务派遣的给养嘛","createdAt":"2025-01-03T11:07:53"},{"id":"01963df6-0c1b-71d0-82ee-5a3b29e6f1c3","parentId":null,"rootId":null,"fromId":3892,"content":"到底那家公司啊？","createdAt":"2025-01-03T16:08:56"},{"id":"01963df6-0c60-7328-9765-cc3dcc5ed2f5","parentId":null,"rootId":null,"fromId":267,"content":"公司名字发出来，别怕什么","createdAt":"2025-01-04T17:39:00"},{"id":"01963df6-0cae-7335-b1d4-489b9d926f61","parentId":null,"rootId":null,"fromId":2246,"content":"鲁软外包吧","createdAt":"2025-01-07T11:29:02"},{"id":"01963df6-0b8f-7348-b266-a60c1eccb52b","parentId":null,"rootId":null,"fromId":6371,"content":"十年期外币值钱所以大家都搞也不内卷，现在货币贬值谁还搞呢，在搞就是死路一条","createdAt":"2025-01-07T17:07:01"},{"id":"01963df6-0cb2-73e9-bcd6-775bf1460491","parentId":null,"rootId":null,"fromId":557,"content":"你们这些傻逼，能力不行就只会怨天怨地怨社会，能力强的人在哪里都混得开，还不是因为你们菜，只会在网上逼逼赖赖。一群蠢猪。不服来辩。微信号：xhcaid","createdAt":"2025-01-08T10:19:57"}]