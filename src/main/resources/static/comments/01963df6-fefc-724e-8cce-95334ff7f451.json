[{"id":"01963df6-ff5f-72c6-90da-7afc228c35da","parentId":null,"rootId":null,"fromId":3279,"content":"经济下行期僧多粥少，高学历卷起来更有优势。同样两个688的妹子站面前，姿色技术都差不多，你选清华毕业的还是蓝翔毕业的？","createdAt":"2025-02-17T10:11:25"},{"id":"01963df6-ffa7-72fa-b892-a4f77584c120","parentId":null,"rootId":null,"fromId":3663,"content":"我是找不到好工作了 大专刚毕业 一个月扣除五险一金后5500 早8.30晚5点不加班 双休","createdAt":"2025-02-17T10:15:25"},{"id":"01963df6-ffee-73d1-8a20-46ff09ac683d","parentId":null,"rootId":null,"fromId":3279,"content":"这工作不错啊。够租房够吃喝，空闲时间多，边干边学。如果是程序员建议换个赛道或换个城市，看着隔壁还在卷java的就心疼。","createdAt":"2025-02-17T10:22:45"},{"id":"01963df6-fff2-7186-934b-10f1b7a776a3","parentId":null,"rootId":null,"fromId":22539,"content":"这已经不错了","createdAt":"2025-02-17T10:32:08"},{"id":"01963df6-fff7-72c1-81a3-86641a093749","parentId":null,"rootId":null,"fromId":21783,"content":"不加班还双休 你这工作不错了","createdAt":"2025-02-17T10:49:35"},{"id":"01963df6-fffa-7102-b5a6-02a05a58c238","parentId":null,"rootId":null,"fromId":5396,"content":"带专生何去何从？高中生何去何从？ 前些年学历卡的不严还好，这两年都卷起来了。不是本科第一关都过不去。即便现在有工作，但是一旦被裁员很可能就找不到工作了，除非你技术真就是大佬的那种水平还好说","createdAt":"2025-02-17T12:25:49"},{"id":"01963df6-ffa2-726a-ab01-5e29cb0d1285","parentId":null,"rootId":null,"fromId":1049,"content":"蚌埠住了，艹B也要艹高学历的【手动狗头】","createdAt":"2025-02-17T15:23:01"}]