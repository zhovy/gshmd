[{"id":"01963de7-e55e-7064-9c44-25651184d36a","parentId":null,"rootId":null,"fromId":5460,"content":"对，我八月份找十家有八家外包到鲁软，五险一金基本都是按最低缴纳，去的话找个工资高的","createdAt":"2023-09-11T08:33:52"},{"id":"01963de7-e5a7-726c-828b-e173465939f1","parentId":null,"rootId":null,"fromId":4152,"content":"我记得有个外包公司交六险一金，13薪，还有节假日福利，周六日加班费，平常超过七点也有加班费，年假什么的都有","createdAt":"2023-09-11T16:15:25"},{"id":"01963de7-e629-7185-9a0e-78acc886aa06","parentId":null,"rootId":null,"fromId":629,"content":"叫啥啊老哥，这才是关键","createdAt":"2023-09-11T19:57:29"},{"id":"01963de7-e62d-7004-95ab-97a8f7f33804","parentId":null,"rootId":null,"fromId":5545,"content":"金现代？\n","createdAt":"2023-09-12T08:41:31"},{"id":"01963de7-e631-7104-8a69-ad118f5a6f87","parentId":null,"rootId":null,"fromId":3199,"content":"金现代怎么可能有这待遇，加班从来没有加班费，没有年假","createdAt":"2023-09-12T14:21:50"},{"id":"01963de7-e636-724e-b23f-d4760d72cbe0","parentId":null,"rootId":null,"fromId":4152,"content":"山东思域，当时hr是这么说的，可以问问有没有这些","createdAt":"2023-09-12T23:42:48"},{"id":"01963de7-e63a-7339-8989-879223df1509","parentId":null,"rootId":null,"fromId":4152,"content":"金现代不行，但找不到工作的话，入职做项目外包还可以考虑，人力外包在任何公司都要慎重考虑","createdAt":"2023-09-12T23:43:54"}]