[{"id":"01963df3-b365-71dd-9044-1ebd77ae7286","parentId":null,"rootId":null,"fromId":2408,"content":"直接去浪潮","createdAt":"2024-10-13T00:31:24"},{"id":"01963df3-b3af-704c-9c44-7918c1134fbe","parentId":null,"rootId":null,"fromId":875,"content":"去北京吧济南的好一点的房子基本两万出头，好的楼盘房基本250万~300万，去北京一年搞二十万，再找个全额缴纳公积金的，北京上班济南还贷，不出10年贷款还完。在济南怕是要还30年房贷。。。","createdAt":"2024-10-13T11:52:32"},{"id":"01963df3-b3ff-7282-86b5-fcbe22bc5b0f","parentId":null,"rootId":null,"fromId":5913,"content":"直接回但不太建议去浪潮","createdAt":"2024-10-13T13:43:45"},{"id":"01963df3-b449-73c4-97d6-e8bcfce3efcf","parentId":null,"rootId":null,"fromId":5913,"content":"浪潮是最垃圾的","createdAt":"2024-10-13T13:44:21"},{"id":"01963df3-b44e-7151-8b43-9544a86f7b01","parentId":null,"rootId":null,"fromId":22017,"content":"是去运营商和银行吗","createdAt":"2024-10-13T14:59:32"},{"id":"01963df3-b452-70ee-9b46-2036e16c5a9b","parentId":null,"rootId":null,"fromId":22020,"content":"同问","createdAt":"2024-10-13T16:28:28"},{"id":"01963df3-b456-7050-b512-fcfab2e744c4","parentId":null,"rootId":null,"fromId":5913,"content":"看看校招的私企，比浪潮好的大有人在","createdAt":"2024-10-13T16:57:22"},{"id":"01963df3-b45b-720b-8776-bd769a7b9a1e","parentId":null,"rootId":null,"fromId":5913,"content":"浪潮就别说是国企了，一点国企的样子都没有","createdAt":"2024-10-13T16:57:49"},{"id":"01963df3-b45f-7178-9503-f837a99cdf66","parentId":null,"rootId":null,"fromId":5913,"content":"城商行都比浪潮强","createdAt":"2024-10-13T16:58:23"},{"id":"01963df3-b463-72d1-935e-555d67e3a056","parentId":null,"rootId":null,"fromId":5913,"content":"当然浪潮也看子公司，但是大多数都不咋样","createdAt":"2024-10-13T16:59:38"},{"id":"01963df3-b467-704d-a5ab-cd608d007121","parentId":null,"rootId":null,"fromId":3341,"content":"现在计算机本就不稳定建议先去北京挣钱再说 北京干五年 能力够的话 挣的钱 回济南 找个班 半躺平了就。家里给个30，自己北京五年搞个100来个问题不大 你对象小学老师 公积金也不低 两个人还贷款 轻轻松松\n当然前提是你给你媳妇的彩礼都是给你媳妇 不是给他家里。","createdAt":"2024-10-14T09:19:31"},{"id":"01963df3-b3f3-7174-834a-df6a64606b5c","parentId":null,"rootId":null,"fromId":22022,"content":"一年二十万，你是瞧不起985硕，还是瞧不起北京。","createdAt":"2024-10-14T09:35:47"},{"id":"01963df3-b4b1-7008-89fc-ddf8fcfae67b","parentId":null,"rootId":null,"fromId":21487,"content":"学习学累的建议直接城商行躺平 这边把硕士当爹当宝 某部门去年来的双非硕什么活不干都被领导当宝 马上休产假咯","createdAt":"2024-10-14T09:51:21"},{"id":"01963df3-b506-7248-a6c0-4fa14fd2372a","parentId":null,"rootId":null,"fromId":6714,"content":"兄弟，济南是真垃圾啊，我单2也是和媳妇异地，没啥好的工作，我现在还在上海，建议来一线，我在这一年能攒22w，打算多个几年尝试考进体制了","createdAt":"2024-10-14T10:02:45"},{"id":"01963df3-b554-719f-9992-64cca09be0aa","parentId":null,"rootId":null,"fromId":403,"content":"浪潮可以让你充分认识到济南环境有多烂","createdAt":"2024-10-14T10:08:04"},{"id":"01963df3-b3f7-71b5-b543-7d4e69e252d1","parentId":null,"rootId":null,"fromId":22028,"content":"在北京就算985硕一年除去开销攒20万也不容易","createdAt":"2024-10-14T15:56:04"},{"id":"01963df3-b59a-7049-ac7f-ff9d1376cd38","parentId":null,"rootId":null,"fromId":875,"content":"哈哈，","createdAt":"2024-10-14T16:43:06"},{"id":"01963df3-b59e-7075-9029-c95aeec15bfb","parentId":null,"rootId":null,"fromId":2572,"content":"进浪潮发展，你得会舔，否则在里面日子相当难过。建议直接考公考编","createdAt":"2024-10-15T09:53:15"},{"id":"01963df3-b5f3-7128-8603-08a9d337ae9f","parentId":null,"rootId":null,"fromId":3263,"content":"楼上都是基于薪资给的建议，北京挣钱多都知道，但是感情的事只有楼主自己清楚。想要少挣点钱多陪伴家人，还是多挣钱异地只有自己决定。","createdAt":"2024-10-15T09:54:57"},{"id":"01963df3-b4fd-7052-b182-f89fbb4cebdf","parentId":null,"rootId":null,"fromId":352,"content":"老哥，城商行好进吗，怎么进","createdAt":"2024-10-15T10:06:23"},{"id":"01963df3-b550-73bc-b11c-7ea357c2d3ef","parentId":null,"rootId":null,"fromId":875,"content":"一年给媳妇上交22万，我想就算是出差非洲媳妇也愿意哈","createdAt":"2024-10-15T12:49:24"},{"id":"01963df3-b3fb-7136-9d10-6b82b03f8e66","parentId":null,"rootId":null,"fromId":875,"content":"985硕咋地了，我说北京一年搞二十万难道说少了？你刚毕业去北京一年能搞一百万？","createdAt":"2024-10-15T12:51:32"},{"id":"01963df3-b501-7255-a009-91e726c4e012","parentId":null,"rootId":null,"fromId":5913,"content":"只要92","createdAt":"2024-10-15T14:25:04"},{"id":"01963df3-b3aa-73bf-8a4f-35b05626dd5a","parentId":null,"rootId":null,"fromId":5913,"content":"浪潮就是一坨屎","createdAt":"2024-10-15T14:25:31"},{"id":"01963df3-b4ad-7044-b792-20815dd3b823","parentId":null,"rootId":null,"fromId":21982,"content":"小学老师公积金很高吗","createdAt":"2024-10-15T22:27:03"},{"id":"01963df3-b67a-73a9-af55-bc3e8568cbe0","parentId":null,"rootId":null,"fromId":2341,"content":"如果你的交际能力很强，领导面前很会舔（加粗），客户面前很能吹，那你进浪潮准没错\n如果不行，那别来，一辈子搬砖，搞不好还搬不到40","createdAt":"2024-10-16T09:28:21"},{"id":"01963df3-b6bf-705b-82a2-bfb970b71ef6","parentId":null,"rootId":null,"fromId":2341,"content":"建议带上媳妇一起去北京","createdAt":"2024-10-16T09:29:57"},{"id":"01963df3-b704-70bb-aee8-208af67e3d06","parentId":null,"rootId":null,"fromId":2483,"content":"如果他对象有编制的话，是走不了的","createdAt":"2024-10-16T17:14:52"},{"id":"01963df3-b708-7273-bcf5-f1f79806615d","parentId":null,"rootId":null,"fromId":4396,"content":"兄弟，浪潮很多岗位也要出差的，而且长期出差。\n985能校招进浪潮的话待遇还是可以的，浪潮很多 人踩，实际到北京去不入流工作的概率也不小。\n建议留济南，边干边看机会。","createdAt":"2024-10-28T15:21:07"},{"id":"01963df3-b751-7319-87b5-ac2fb05c5dda","parentId":null,"rootId":null,"fromId":3801,"content":"同意，出去晃悠几年也就那样。","createdAt":"2024-10-28T17:04:29"},{"id":"01963df3-b799-71fe-b250-aaf5152fe9a1","parentId":null,"rootId":null,"fromId":3801,"content":"另外留济南的话给你几个方向，不用非得浪潮，如：电网(可能你学历不是很占优势)、银行科技岗(如城商、农信)、运营商科技岗（联通、移动、电信）、国企(这部分可能加班啥的就比较多了，但是福利待遇都属于靠前的，如云鼎、XXX控股、山东高速，浪潮原则上也属于这个)，最后就是比较大的民企了(如:齐鲁制药、银丰)，这些一般都有校招，你可以关注下，能进去的话，也是很好的选择。","createdAt":"2024-10-28T17:24:29"}]