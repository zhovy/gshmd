[{"id":"0198cb6d-b5b0-7211-b670-ed64cf59666b","parentId":null,"rootId":null,"fromId":25906,"content":"我发现很多人对35岁以上程序员不好找工作有误解，其实不只是对程序员，是在座的所有人，各行各业，35岁以上都不好找工作。","createdAt":"2025-08-21T15:00:21"},{"id":"0198cb6e-c48b-7066-a1b9-6acc8364a631","parentId":null,"rootId":null,"fromId":4140,"content":"已经跑路，回老家找了个9k的大公司混着了，目前看医疗器械行业应该没有什么失业危机，福利待遇都还是很好的，管吃住，干着副业，卖卖票一个月四五千，旺季1-2w，有的时候也思考失业干什么，回老家失业了能换的岗位确实就不多了，不像济南大把的外包","createdAt":"2025-08-21T15:01:30"},{"id":"0198cb81-92f1-73a6-b57f-908dee460f27","parentId":null,"rootId":null,"fromId":23279,"content":"卖什么票啊老哥","createdAt":"2025-08-21T15:22:03"},{"id":"0198cb81-d9e9-7185-b5ac-0c2cf56c353c","parentId":null,"rootId":null,"fromId":4140,"content":"景区门票","createdAt":"2025-08-21T15:22:21"},{"id":"0198cb95-aafa-7034-aa29-445499dcbcea","parentId":null,"rootId":null,"fromId":414,"content":"老家是哪里的，什么级别的城市，在济南看不到希望，哎，想换个城市了","createdAt":"2025-08-21T15:44:00"},{"id":"0198cbed-85f6-737d-9532-6732130d78ec","parentId":null,"rootId":null,"fromId":22459,"content":"一样  逃离济南已经一年半了","createdAt":"2025-08-21T17:19:57"},{"id":"0198cbf8-bddc-7236-a5c7-b00ea0833c3c","parentId":null,"rootId":null,"fromId":22970,"content":"大哥别闹，要不是我在医疗行业还就真信你了，干医疗器械的尤其是大公司都在苟活着，有能力的公司还能拿到些超长期国债的项目，大部分都是在吊着最后几口气……","createdAt":"2025-08-21T17:32:13"},{"id":"0198cf90-802f-726e-bbed-bd4d91b0b9c6","parentId":null,"rootId":null,"fromId":4140,"content":"威高还行吧，我确实不清楚医疗器械咋样，反正公司福利待遇没砍","createdAt":"2025-08-22T10:16:50"},{"id":"0198d02a-9a5f-7119-a461-7afaf0e5f07c","parentId":null,"rootId":null,"fromId":23959,"content":"没学外语吗？","createdAt":"2025-08-22T13:05:09"}]