[{"id":"019761f0-cde0-70cb-a8a3-0fb01f1da88b","parentId":null,"rootId":null,"fromId":6517,"content":"还可以的","createdAt":"2025-06-12T10:21:00"},{"id":"019761fa-4488-73a2-8179-3daeb0875631","parentId":null,"rootId":null,"fromId":22809,"content":"一般","createdAt":"2025-06-12T10:31:20"},{"id":"019761fc-84ca-71bb-bc51-1ba152f794d3","parentId":null,"rootId":null,"fromId":5471,"content":"你比那个230万都强","createdAt":"2025-06-12T10:33:48"},{"id":"01976201-913d-702a-a0c6-d0dad4d94705","parentId":null,"rootId":null,"fromId":23684,"content":"怎么赚的","createdAt":"2025-06-12T10:39:19"},{"id":"01976221-007c-7183-a69e-6d532d10fa0c","parentId":null,"rootId":null,"fromId":23274,"content":"纯好奇你这种人来这里问这个是啥心态呢？无非就是比大部分外地人强，比小部分外地人差；比小部分本地人强，比大部分本地人差呗。又凑巧这个行业大部分都是外地人，所以你比站里大部分人都强一些。这就是你想听到的结论吗？是生活压力大需要别人鼓励你一下，你才能舒服些吗？你拿着你的存款去非洲跟人家比，你可能超越的人更多。","createdAt":"2025-06-12T11:13:39"},{"id":"01976221-a274-72ba-8dd0-404a6ba092ff","parentId":null,"rootId":null,"fromId":21428,"content":"要是他自己赚的，就不会跑个这个地方问了","createdAt":"2025-06-12T11:14:20"},{"id":"01976222-3729-7087-853c-df6444160b2e","parentId":null,"rootId":null,"fromId":2846,"content":"有优越感呗，别理他就行了","createdAt":"2025-06-12T11:14:58"},{"id":"01976223-492d-72e3-8197-04f59395e4dc","parentId":null,"rootId":null,"fromId":460,"content":"嘿嘿","createdAt":"2025-06-12T11:16:09"},{"id":"01976225-da1c-716d-ad07-24ca90150dcd","parentId":null,"rootId":null,"fromId":801,"content":"算你睡得香","createdAt":"2025-06-12T11:18:57"},{"id":"01976227-3521-739c-8b41-cf969c8d653e","parentId":null,"rootId":null,"fromId":23959,"content":"发个抖音问问","createdAt":"2025-06-12T11:20:26"},{"id":"0197622a-fe54-71c7-9a2c-67c5b072e11c","parentId":null,"rootId":null,"fromId":23274,"content":"还嘿嘿呢，我就是3701的人，现在三本房产证上都是我的名，支付宝财富黑卡V3，不知道你有啥好找存在感的呢，我周围很多人都比我努力，为了养家糊口，工作也很卷，我很尊重他们，偶尔跟他们聊天的时候被他们说还是本地人好的时候，我甚至会有点不好意思，主动就岔开话题了。看你在他们身上找优越感，我是真看不惯，喜欢找软柿子捏吗，那我觉得你可以找霍金比跑步，跟特朗普比说中国话去了。","createdAt":"2025-06-12T11:24:34"},{"id":"01976231-0dcd-7388-9035-c50283671834","parentId":null,"rootId":null,"fromId":6827,