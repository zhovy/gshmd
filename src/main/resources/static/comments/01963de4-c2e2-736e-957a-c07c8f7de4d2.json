[{"id":"01963de4-c34d-71ca-b134-4ca936b4aacc","parentId":null,"rootId":null,"fromId":1039,"content":"说明人少","createdAt":"2023-07-10T16:33:03"},{"id":"01963de4-c396-70cd-895f-5a2eb08f4bd0","parentId":null,"rootId":null,"fromId":3506,"content":"几十个人的上市公司，人不多制度不少","createdAt":"2023-07-11T16:27:14"},{"id":"01963de4-c3db-7112-8688-c8d2dd3c0b28","parentId":null,"rootId":null,"fromId":3879,"content":"面试过，问了一堆没有意义的底层知识，，，感觉面试官有点装。","createdAt":"2023-07-12T09:49:42"},{"id":"01963de4-c421-7028-ba9a-440d17974de7","parentId":null,"rootId":null,"fromId":3824,"content":"都问的啥啊,让我下午微信面试呢","createdAt":"2023-07-26T09:55:16"},{"id":"01963de4-c479-73c2-a157-c79eccc5d9e8","parentId":null,"rootId":null,"fromId":6522,"content":"面试的很傲气 质问的语气 可能更年期了吧","createdAt":"2024-02-01T13:29:23"},{"id":"01963de4-c4c1-721d-80fd-7932b145182a","parentId":null,"rootId":null,"fromId":6659,"content":"挺恶心的，面试四五个人挨着问，人事那娘们更装，不会问就把项目经理的问题又问一遍","createdAt":"2024-06-25T16:43:01"},{"id":"01963de4-c507-7263-bba5-84c906b31962","parentId":null,"rootId":null,"fromId":22452,"content":"面试建一个群，把你拉进去，6个人挨着问，cpu原理，网络原理，深拷贝啥的，不是招聘，是一群人演戏的，女的叫田芳,更年期妇女","createdAt":"2025-01-24T15:02:51"},{"id":"01963de4-c54d-7185-ba2b-1ab91ec86bd1","parentId":null,"rootId":null,"fromId":22761,"content":"去年找工作面试的嵌入式开发，当时还不知道有这个网站，看了你们的评论我就不会去了，四个人面试，两个人事，一个不知道啥部门领导，一个技术，技术只在结束时候问了一个问题，你做开发的时候碰到过什么难题。其他都是人事女在问，语气和问题都不友好，面试体验很差，不问技术问题，就逮住你为啥离职，个人私事瞎吉儿问，最后都不愉快。建议搞研发的不要去，个人感觉在里面研发地位高不了。今年我项目组招人，我又刷了刷招聘平台，它们的招聘还在，我都怀疑我是不是被叫去刷KPI的。","createdAt":"2025-02-19T09:24:29"},{"id":"01993d38-c175-7098-944c-aff5dae12619","parentId":null,"rootId":null,"fromId":4002,"content":"同问这个公司怎么样，看着最近招硬件呢。硬件岗位全是干硬件吗，软件涉及吗？","createdAt":"2025-09-12T17:19:13"},{"id":"019a813a-712b-72c1-8b92-81496e39c131","parentId":null,"rootId":null,"fromId":26594,"content":"三个人面试，一个人事，一个技术，一个男的带眼镜。逮着简历写的使劲问，项目上的问题基本不问。问了我一些c++的基础，问的懵逼了，干了十几年基础东西基本忘了。","createdAt":"2025-11-14T15:18:02"}]