[{"id":"0198c53e-7ec9-73b2-9852-6cd46c16357f","parentId":null,"rootId":null,"fromId":6517,"content":"我也工作6年了，在济南没找过不双休的工作，目前3份工作都是双休不加班","createdAt":"2025-08-20T10:11:04"},{"id":"0198c53f-4dc5-70d4-8a6e-1849912a1b2e","parentId":null,"rootId":null,"fromId":21512,"content":"你们起来了   我怎么压迫你们？   操","createdAt":"2025-08-20T10:11:56"},{"id":"0198c54b-2ce6-70cc-a13c-350ea393c8ee","parentId":null,"rootId":null,"fromId":21818,"content":"结了婚，有了老婆孩子，背了车贷房贷。。。也是没办法","createdAt":"2025-08-20T10:24:55"},{"id":"0198c566-708e-7312-94c8-600b123f3e5e","parentId":null,"rootId":null,"fromId":7344,"content":"我们不是牛马，我们是人","createdAt":"2025-08-20T10:54:41"},{"id":"0198c56d-7f6d-716a-a3f1-2b6a41a78a96","parentId":null,"rootId":null,"fromId":629,"content":"唱出来了","createdAt":"2025-08-20T11:02:24"},{"id":"0198c591-5593-7244-84a3-a01d9a638cb2","parentId":null,"rootId":null,"fromId":22250,"content":"所有的问题都回归到一个问题上，中国人算不算人？","createdAt":"2025-08-20T11:41:32"},{"id":"0198c5a3-cd7e-71fc-827c-8e6a5fe5efdb","parentId":null,"rootId":null,"fromId":7344,"content":"","createdAt":"2025-08-20T12:01:43"},{"id":"0198c5de-3144-7055-9021-f8b061906bb0","parentId":null,"rootId":null,"fromId":24162,"content":"哈哈哈","createdAt":"2025-08-20T13:05:29"},{"id":"0198c9fa-52ba-7003-9712-111b2a15209e","parentId":null,"rootId":null,"fromId":2246,"content":"你这话说的不再理，双休的工作一大把，你自己找不到而已，不结婚不生孩子无房无贷，一月几千块过的也很滋润，何来反抗啊。","createdAt":"2025-08-21T08:14:42"},{"id":"0198c9fa-c577-7043-adce-c59b828ef468","parentId":null,"rootId":null,"fromId":2246,"content":"我工作十几年了，哪怕是北京，也是照样双休。","createdAt":"2025-08-21T08:15:11"},{"id":"0198ca1c-b74d-71c7-86f5-92b4997d850f","parentId":null,"rootId":null,"fromId":22250,"content":"你说的有道理。但你看到的只是表象而已，双休的工作一大把，但为什么就有单休的呢，他们找不到双休的是因为自己不够努力还是说需要碰运气，这难道不是本身问题所在？不结婚不生娃一个月几千块也只是止损罢了，不是不想而是不敢。所有的问题都归纳到一个问题上来：中国人算不算人？中国人就活该这样被对待？","createdAt":"2025-08-21T08:52:16"},{"id":"0198ca50-f7ec-7287-9e55-2ac2fe9b1ad8","parentId":null,"rootId":null,"fromId":2246,"content":"你要是讨论社会问题那没问题，我可以好好和你讨论。但你要是扯算不算人，那我就要问你，全球五十多个军事基地，总统可以操作股市让小弟一天赚25亿，那么打算两份工和卖血去游乐园的人，算不算人","createdAt":"2025-08-21T09:49:20"},{"id":"0198cc0b-0e19-7023-b278-8c822401e077","parentId":null,"rootId":null,"fromId":22250,"content":"你要讨论社会问题大可讨论，为什么要搞国家之间的对立，这对你有什么好处？有的国家好也罢坏也罢，和东大有关系？有好的不比，专门比烂？你要是工作辛苦就去休息，而不是比谁比你更累","createdAt":"2025-08-21T17:52:13"},{"id":"0198cd72-0a55-73eb-b4eb-bf873d4e4071","parentId":null,"rootId":null,"fromId":23223,"content":"这是个值得思考的问题","createdAt":"2025-08-22T00:24:19"},{"id":"0198cf34-302d-72f7-bb74-38c87d58bef6","parentId":null,"rootId":null,"fromId":22250,"content":"那你猜猜杨兰兰为什么有几万亿的存款","createdAt":"2025-08-22T08:36:00"},{"id":"0198de89-ae4a-7090-8af2-bb994c503dbe","parentId":null,"rootId":null,"fromId":2246,"content":"你信这东西，你的认知也就到这里了。","createdAt":"2025-08-25T08:03:41"}]