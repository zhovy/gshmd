[{"id":"01963df2-7086-73f4-9dc1-215ceff637a4","parentId":null,"rootId":null,"fromId":1733,"content":"公司不发工资了，怎么维权呢，过来人说说，亲测可行的","createdAt":"2024-08-21T11:19:11"},{"id":"01963df2-70cf-71e1-92ad-95aef085fb7d","parentId":null,"rootId":null,"fromId":3450,"content":"快跑","createdAt":"2024-08-21T11:24:02"},{"id":"01963df2-7115-72e8-969e-b099f74e7a5e","parentId":null,"rootId":null,"fromId":1733,"content":"我得把欠的工资要回来，再说。","createdAt":"2024-08-21T11:33:38"},{"id":"01963df2-711a-7133-8a2e-6079a6f9be87","parentId":null,"rootId":null,"fromId":21053,"content":"给公司发被迫离职通知书，然后劳动仲裁。或者在职劳动监察","createdAt":"2024-08-21T11:35:20"},{"id":"01963df2-70ca-7202-b9c9-fe527b911ad6","parentId":null,"rootId":null,"fromId":5584,"content":"公司叫啥？避雷","createdAt":"2024-08-21T12:25:38"},{"id":"01963df2-715e-7103-9f17-a582a7fc3ccf","parentId":null,"rootId":null,"fromId":2577,"content":"走被迫的流程一定要对，多刷刷教程，操作正确可以多拿好多钱了","createdAt":"2024-08-21T12:40:50"},{"id":"01963df2-7163-7238-bf89-d548c5957623","parentId":null,"rootId":null,"fromId":5987,"content":"如果欠的钱多，直接找律师就是，通常律师有两种形式，一种是给你那种仲裁指导，手把手教你写文件去仲裁，一种就是全权委托代理帮你去处理，另外这种东西你需要提前收集很多工作证明的证据，也不是随随便便就能赢。最重要的是，如果你维权成功了，公司还是不给你钱，你也确实是没办法的，这个走起诉啥的周期也非常长，一般是以年为单位的","createdAt":"2024-08-22T08:59:37"},{"id":"01963df2-71aa-71d3-8ccf-d22c8263565e","parentId":null,"rootId":null,"fromId":21363,"content":"哪个公司？","createdAt":"2024-08-23T14:32:40"},{"id":"01963df2-71ee-724b-a597-d996098b2233","parentId":null,"rootId":null,"fromId":875,"content":"维权？公司发不出来工资，还好意思要工资，公司挣钱一大把不发可以要，公司不挣钱的经营不善的，别要了，赶紧找下一家","createdAt":"2024-08-23T21:13:07"},{"id":"01963df2-7232-728f-a1c8-dac493e9fac9","parentId":null,"rootId":null,"fromId":1733,"content":"祝你出行平安，不会说话别乱说话。","createdAt":"2024-08-26T09:01:58"},{"id":"01963df2-7236-72c7-a9d2-0ec7edc4198a","parentId":null,"rootId":null,"fromId":21646,"content":"你们欠了几个月了","createdAt":"2024-08-27T19:27:24"}]