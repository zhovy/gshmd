[{"id":"019a9eec-9334-720e-959c-094575290ec1","parentId":null,"rootId":null,"fromId":1955,"content":"我想了想并看了一眼，我不太符合分析预测的标准，坐等那啥大的那个人出现","createdAt":"2025-11-20T09:41:35"},{"id":"019a9f02-7a36-7265-8d5f-ae1f04003c2c","parentId":null,"rootId":null,"fromId":7566,"content":"短时间内不会好了，这个短时间指的是三五年","createdAt":"2025-11-20T10:05:31"},{"id":"019a9f1e-d1a1-72f9-8f03-2e1292dc12a7","parentId":null,"rootId":null,"fromId":21302,"content":"不会好了，体制内都没多少需求哪来的好行情？该转行转行，该兼职兼职，具体参考90年代下岗潮。","createdAt":"2025-11-20T10:36:28"},{"id":"019a9f33-53ed-7043-958f-ba3f83b00fa2","parentId":null,"rootId":null,"fromId":793,"content":"那完蛋了，这样下去说不好哪天就失业了","createdAt":"2025-11-20T10:58:52"},{"id":"019a9f33-f40f-72e6-bcdf-09ac9eaad5ed","parentId":null,"rootId":null,"fromId":793,"content":"主要是失业后，房贷和生活的压力太大了","createdAt":"2025-11-20T10:59:33"},{"id":"019a9f41-2953-735a-8135-2c3b7bbd7ad4","parentId":null,"rootId":null,"fromId":23971,"content":"不行就润国外打工去","createdAt":"2025-11-20T11:13:59"},{"id":"019a9f70-6c4e-73d3-8ed6-2753ec01d284","parentId":null,"rootId":null,"fromId":5689,"content":"大学生的人数顶峰是2032年，读个三四年书，2035～2036年集中就业。那个时间作为拐点，就业压力慢慢变小，然后2045年回到2010年的水平。所以说，大家需要再当牛做马苟活20年。","createdAt":"2025-11-20T12:05:36"},{"id":"019a9f90-6ed4-71b1-8e5c-8cfb85c733f2","parentId":null,"rootId":null,"fromId":4140,"content":"2045年现在从事这个岗位的人还没退休，不可能回到2010年，只会比现在还糟糕","createdAt":"2025-11-20T12:40:34"},{"id":"019a9fbd-c54d-7216-9d1c-6b24fb8ee180","parentId":null,"rootId":null,"fromId":5689,"content":"兄弟多虑了，2045年的时候，之前在这个岗位的人要么饿死了，要么猝死了。","createdAt":"2025-11-20T13:30:05"},{"id":"019a9fc9-cd5a-7322-b626-b54e90b6d5ea","parentId":null,"rootId":null,"fromId":3319,"content":"房子卖了，一切生活成本降到最低","createdAt":"2025-11-20T13:43:14"},{"id":"019a9fe7-926a-703b-803a-b467d5268b64","parentId":null,"rootId":null,"fromId":875,"content":"行情好的很，换个机油工时费就好几十，换个滤芯也好几十，手拿把掐的事，一个小时七八百块钱没了，还是开养车店挣钱","createdAt":"2025-11-20T14:15:45"},{"id":"019a9fed-79b7-71ff-a454-c4f3e5fef388","parentId":null,"rootId":null,"fromId":7624,"content":"目前看通缩转滞涨的可能性极大。而且不是一年两年 三年五年的问题。","createdAt":"2025-11-20T14:22:11"},{"id":"019aa0c9-9f8b-7066-b6ba-d336aa144bac","parentId":null,"rootId":null,"fromId":7566,"content":"日本失去了三十年，中国从2018年开始算到现在才七八年。\n日本在1990年人均GDP是世界前列，中国现在账面才1.2万美元的人均GDP。\n日本在失去的三十年中跟欧美的关系不说多么好，但是不至于闹得很僵；中国现在跟欧美日韩的关系吧......\n日本在失去的三十年前就已经做到了在汽车、化工、机械、电子等高端制造领域独步天下，中国现在吧只能说遥遥领先。\n日本在2002年才开始人口负增长，中国去年就已经人口负增长。\n日本在泡沫破裂前大举投资世界各国，泡沫破裂后可以靠投资收益回血。\n就这日本都失去了三十年，这几年才刚缓过来。\n中国慢慢熬吧。","createdAt":"2025-11-20T18:22:39"},{"id":"019aa3d0-0f22-7353-b45e-6c730ac9e29e","parentId":null,"rootId":null,"fromId":793,"content":"这样说的话，失业的可能性很大啊","createdAt":"2025-11-21T08:28:32"},{"id":"019aa460-c8b8-7167-a2cc-2da8c1a6e8f8","parentId":null,"rootId":null,"fromId":25906,"content":"今年是未来十年最好的一年","createdAt":"2025-11-21T11:06:37"},{"id":"019ab3c5-5c62-7206-9b5e-7947aada0f86","parentId":null,"rootId":null,"fromId":27881,"content":"不是经济的问题，所以，一帮人还认为是经济问题，那经济就永远好不起来。已经多印了310万亿钱了，不管用。","createdAt":"2025-11-24T10:50:47"},{"id":"019ab44d-14cf-7284-84dd-352703cd692e","parentId":null,"rootId":null,"fromId":793,"content":"那大佬，具体是啥问题啊？分配问题吗？啥时候能好转啊","createdAt":"2025-11-24T13:19:01"},{"id":"019ac35c-d139-712b-b2ea-d30c56a2bb79","parentId":null,"rootId":null,"fromId":26964,"content":"开枪战服","createdAt":"2025-11-27T11:30:31"},{"id":"019ace67-c112-7270-a246-671e48c8159b","parentId":null,"rootId":null,"fromId":25256,"content":"不能细嗦的问题","createdAt":"2025-11-29T14:58:17"},{"id":"019ad772-e68b-70ec-aa6d-8f3094cc8436","parentId":null,"rootId":null,"fromId":27881,"content":"改天换地才能好，且熬着吧","createdAt":"2025-12-01T09:07:02"},{"id":"019adcee-e69a-737e-8595-6a72abd998d6","parentId":null,"rootId":null,"fromId":21742,"content":"三五年内别想了  而且现在ai写代码这么牛逼  济南短期内（3-5年）是不行了","createdAt":"2025-12-02T10:40:35"},{"id":"019b11b4-9340-715b-9543-32bf646fb28f","parentId":null,"rootId":null,"fromId":2527,"content":"今年可能是未来十年里最好的一年","createdAt":"2025-12-12T16:36:45"}]