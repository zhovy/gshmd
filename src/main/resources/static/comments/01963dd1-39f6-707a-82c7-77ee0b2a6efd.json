[{"id":"01963dd1-3a6a-73fd-a247-00bdbecd4855","parentId":null,"rootId":null,"fromId":14,"content":"本人有幸在这个公司面试过。1、那个经理（不晓得是不是经理，很瘦，最后谈薪资的就是他）有点地域黑，看不起河北人。  2、面试通过入职干了两天，技术部组长大胖子，推卸责任。另外他的代码要多烂有多烂。烂摊子扔给了我。于是周六的早上闹钟想起的时候，我没去哈哈哈哈。","createdAt":"2021-12-31T17:33:31"},{"id":"01963dd1-3aaf-7138-916a-6b36ce18318c","parentId":null,"rootId":null,"fromId":137,"content":"垃圾公司，当时面试的时候，说让我过去当个负责人，薪资太低，还单休，后来各种打电话让我过去，说给涨薪，幸亏没过去，哈哈","createdAt":"2022-03-14T11:51:47"},{"id":"01963dd1-3af3-71ca-955c-6e4f5a1209db","parentId":null,"rootId":null,"fromId":642,"content":"哈哈，是不是在大地锐城旁边那个啊","createdAt":"2022-06-02T09:49:42"},{"id":"01963dd1-3b39-727a-a315-e8bded124bf4","parentId":null,"rootId":null,"fromId":873,"content":"面试过 压低了2000工资 没去","createdAt":"2022-07-02T09:22:34"},{"id":"01963dd1-3b7e-7138-8db7-bde71beedffa","parentId":null,"rootId":null,"fromId":1279,"content":"垃圾公司，这个公司在工资和合同上各种骗人，打电话让去的时候，问问题还嫌烦，各种催，感觉像个传销公司","createdAt":"2022-08-11T09:15:43"}]