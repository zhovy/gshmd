[{"id":"01963df4-784d-71f1-9952-4ebcb25eeae5","parentId":null,"rootId":null,"fromId":6344,"content":"我先来一条，我去spa一般都选纹身的姑娘，因为她们不像无纹身的女孩一样金盆洗手之后还能考公考编找个老实人嫁了，她们一般退路不多，所以服务的时候格外的卖力","createdAt":"2024-11-07T10:36:41"},{"id":"01963df4-7891-708c-bd9c-af17e7f96e20","parentId":null,"rootId":null,"fromId":5471,"content":"6","createdAt":"2024-11-07T11:00:27"},{"id":"01963df4-7896-73b9-a29e-7161ab22e0fc","parentId":null,"rootId":null,"fromId":22024,"content":"专指服务的姑娘吗？","createdAt":"2024-11-07T11:04:25"},{"id":"01963df4-789a-73eb-9204-9188760287f9","parentId":null,"rootId":null,"fromId":6344,"content":"也不一定","createdAt":"2024-11-07T13:35:10"},{"id":"01963df4-78a3-702c-a3d6-a87a582cd7e8","parentId":null,"rootId":null,"fromId":21341,"content":"得看是哪种纹身。大面积纹的那种，观感极其不佳，像极了失足者。小面积的纹身，其实也是一种情调。","createdAt":"2024-11-07T14:55:05"},{"id":"01963df4-78e7-7224-a175-0f854ac30e13","parentId":null,"rootId":null,"fromId":875,"content":"进厂吧，就业不景气，厂里有好多小姑娘","createdAt":"2024-11-08T12:53:41"},{"id":"01963df4-792a-731a-9adb-32936c9baefb","parentId":null,"rootId":null,"fromId":875,"content":"年轻漂亮活泼可爱苗条","createdAt":"2024-11-08T12:58:31"},{"id":"01963df4-789f-71ea-8097-7a8f2a5c95ad","parentId":null,"rootId":null,"fromId":5481,"content":"学无止境，你就学吧，太深了","createdAt":"2024-11-08T15:12:24"},{"id":"01963df4-792e-7328-9765-47e906e6b0bd","parentId":null,"rootId":null,"fromId":59,"content":"确实","createdAt":"2024-11-09T10:24:41"}]