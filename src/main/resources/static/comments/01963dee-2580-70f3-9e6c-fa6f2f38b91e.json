[{"id":"01963dee-25e8-73b4-9b46-53cd747964bd","parentId":null,"rootId":null,"fromId":6939,"content":"补充下，第一条是学历造假问题","createdAt":"2024-04-22T17:31:40"},{"id":"01963dee-262d-72e2-ae5b-1d3e9a60ae5b","parentId":null,"rootId":null,"fromId":228,"content":"这个boss和智联在线简历都会显示教育经历,是不是全日制也会显示,HR筛简历不看吗?","createdAt":"2024-04-22T19:45:40"},{"id":"01963dee-2674-73e8-8c67-992af66aad9b","parentId":null,"rootId":null,"fromId":6939,"content":"最初的时候这些网站没这么完善，学校都是手填，感觉就因为卡学历才给你展示全和非全了。","createdAt":"2024-04-23T08:46:01"},{"id":"01963dee-2679-72c8-affe-ec86da6d88f7","parentId":null,"rootId":null,"fromId":2658,"content":"我想问一下,为什么学历低技术可以在企业都干1年了,为啥还要辞退呢,就硬卡学历吗  再说自考本不同于成考 自考本也是统招吧","createdAt":"2024-04-23T09:02:09"},{"id":"01963dee-26c3-73a9-9e70-131df25b163a","parentId":null,"rootId":null,"fromId":6580,"content":"自考本算哪门子统招","createdAt":"2024-04-23T09:07:57"},{"id":"01963dee-26c8-704d-a79b-eab76a9b89d3","parentId":null,"rootId":null,"fromId":4140,"content":"因为他们是外包，他们说了不算，甲方要求本科，你又不是经理他亲戚，为什么替你说话，把你卡了就完了","createdAt":"2024-04-23T09:09:39"},{"id":"01963dee-26cc-71b4-a1bc-c114a3e7607e","parentId":null,"rootId":null,"fromId":6939,"content":"据说刚开始的一年干的是公司自研的项目，公司自研不赚钱，去做外包了，甲方要求学历，查出来","createdAt":"2024-04-23T09:09:44"},{"id":"01963dee-26d1-7170-909a-24a975243fbc","parentId":null,"rootId":null,"fromId":6939,"content":"查出来的话肯定连公司都清退了，自己交待了走人了，这种你想干人家的活，就是要博士你也得听着。","createdAt":"2024-04-23T09:12:05"},{"id":"01963dee-2629-7241-862b-8a2e66942dd5","parentId":null,"rootId":null,"fromId":5768,"content":"假学历？","createdAt":"2024-04-23T09:27:29"},{"id":"01963dee-26d5-735b-9d16-1e5c791acf63","parentId":null,"rootId":null,"fromId":3297,"content":"现在普通本科在这一行也只能做牛马了","createdAt":"2024-04-26T16:17:01"},{"id":"01963dee-271b-72d0-9f68-a62bc0797186","parentId":null,"rootId":null,"fromId":7009,"content":"双非本科一文不值了","createdAt":"2024-04-30T00:49:46"}]