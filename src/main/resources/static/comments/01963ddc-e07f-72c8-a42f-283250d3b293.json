[{"id":"01963ddc-e0f9-7029-a027-6ad889558f82","parentId":null,"rootId":null,"fromId":14,"content":"公司厕所只能老板用，员工去别的楼层解决。\n\n这就很离谱","createdAt":"2022-10-11T16:00:47"},{"id":"01963ddc-e143-703c-ac08-f58bdf01a360","parentId":null,"rootId":null,"fromId":1931,"content":"这么扣下去，怕是不想给员工发工资了哈哈","createdAt":"2022-10-11T16:18:13"},{"id":"01963ddc-e1a1-711b-8d4f-23d459f11a02","parentId":null,"rootId":null,"fromId":965,"content":"多谢，逼坑","createdAt":"2022-10-11T17:13:37"},{"id":"01963ddc-e1ef-723b-8bfc-35c1949699fc","parentId":null,"rootId":null,"fromId":1368,"content":"公司厕所只能领导用，哈哈哈，长见识了。","createdAt":"2022-10-12T09:29:42"},{"id":"01963ddc-e235-73f9-82dc-5173370d759d","parentId":null,"rootId":null,"fromId":1749,"content":"去这公司干了一个月，工资拿不到不说，还得倒贴给公司。有趣，有趣。。。","createdAt":"2022-10-12T14:32:49"},{"id":"01963ddc-e27c-72d1-b7d2-e8ab5109b1a2","parentId":null,"rootId":null,"fromId":1857,"content":"刚毕业那会，在这公司实习过，当时看见那研发经理的B脸就不舒服","createdAt":"2022-10-13T09:18:37"},{"id":"01963ddc-e2c1-730a-bb30-addde91f9aa6","parentId":null,"rootId":null,"fromId":1955,"content":"曾经去面试过，一个所谓的技术经理给我面试，然后问我面试什么周围。\n丫的，是你们喊我来面试的，我回答我也是面试技术经理的，然后就没啥后了\n面试的人摆出一种舍我其谁的态度\n这公司不去也罢","createdAt":"2022-10-13T10:18:22"},{"id":"01963ddc-e308-7011-a37e-436a62d6f09e","parentId":null,"rootId":null,"fromId":880,"content":"有个负责人 叫赵什么博，他招聘人力，有两个目标\n1就是能做到让员工有感恩于公司的心和在公司里拼搏的精神；\n2就是新项目来能快速让新员工适应，快速出结果\n哈哈哈哈哈哈哈  笑死人了","createdAt":"2022-10-13T18:56:58"},{"id":"01963ddc-e34e-72e0-948b-892cb35ef8c6","parentId":null,"rootId":null,"fromId":880,"content":"只能老板用的厕所，厕所是老板的家吧，不许其他人侵犯的","createdAt":"2022-10-13T18:57:38"},{"id":"01963ddc-e394-72d2-a456-93f1d24fc234","parentId":null,"rootId":null,"fromId":880,"content":"给各位看官一个 法律 提示，公司不得以任何形式的罚款扣款，一旦有公司出现这种情况，要让公司明确罚款是什么，并要求企业给工资条明确扣罚款信息，然后就可以仲裁去了","createdAt":"2022-10-13T19:01:02"},{"id":"01963ddc-e3dc-70ff-99ca-5f193dc7a3f8","parentId":null,"rootId":null,"fromId":1486,"content":"随意克扣员工工资是侵犯劳动权益的违法行为，如果需要维权/仲裁咨询可以加VX“zyzg0531”，公益为大家提供咨询帮助。","createdAt":"2022-10-14T16:42:46"},{"id":"01963ddc-e42d-73de-8eea-9529fe87a4d5","parentId":null,"rootId":null,"fromId":1935,"content":"扣钱一次500起步，上不封顶，各种霸王条规神仙也难遵守，老板要的不是员工，是奴隶。\n老板始终觉得员工不是来帮他挣钱盈利的，是来挣他钱的。\n赵总官威很大，守着不足十人老实巴交的研发，摆着臭脸，随意使唤","createdAt":"2022-10-21T15:55:36"},{"id":"01963ddc-e47c-7363-a1c3-1b00921264c2","parentId":null,"rootId":null,"fromId":708,"content":"垃圾公司，垃圾员工，真是苍蝇进大粪坑。臭一窝里了","createdAt":"2022-10-31T09:29:06"},{"id":"01963ddc-e4c3-7323-8d08-d051582392bb","parentId":null,"rootId":null,"fromId":2410,"content":"老板是有关系的，没有员工这群人当努力照样很牛逼","createdAt":"2023-01-28T13:17:06"},{"id":"01963ddc-e509-7262-a0bb-8126ded8049c","parentId":null,"rootId":null,"fromId":2444,"content":"员工走的就还有10几个人，差的费劲","createdAt":"2023-02-01T13:14:56"},{"id":"01963ddc-e551-7128-965d-72e94853ad9f","parentId":null,"rootId":null,"fromId":2367,"content":"我看智联上这家公司标注的人员规模是100-299人呢。这家公司现在怎么样？","createdAt":"2023-02-02T10:54:17"},{"id":"01963ddc-e59a-70fa-806d-bd738a1e0bab","parentId":null,"rootId":null,"fromId":2492,"content":"刚收到这家公司的面试，要不要去看看呢，项目经理岗","createdAt":"2023-02-14T13:26:52"},{"id":"01963ddc-e5e1-726a-826c-d3971c6c1c89","parentId":null,"rootId":null,"fromId":3227,"content":"别去了太坑","createdAt":"2023-04-24T14:30:02"},{"id":"01963ddc-e478-71eb-8535-57673d5fba1a","parentId":null,"rootId":null,"fromId":4020,"content":"我也姓赵，但是我觉得这个人真该死啊","createdAt":"2023-07-10T14:37:59"},{"id":"01963ddc-e5e5-72c2-b689-a5152b9aef87","parentId":null,"rootId":null,"fromId":5511,"content":"兄弟们，这家公司现在什么情况","createdAt":"2023-08-29T17:38:58"},{"id":"01963ddc-e62f-73c4-bc36-e89691a5fc98","parentId":null,"rootId":null,"fromId":3705,"content":"公司厕所只能领导用，可能领导拉屎太臭了，怕晕到其他的员工，老板这是为员工号。","createdAt":"2023-08-29T17:53:30"},{"id":"01963ddc-e672-7069-b881-18dc87de56c4","parentId":null,"rootId":null,"fromId":5511,"content":"现在也这样吗","createdAt":"2023-08-29T23:49:56"},{"id":"01963ddc-e676-726e-ab20-da91abdb2cf3","parentId":null,"rootId":null,"fromId":5602,"content":"刚收到面试，吓的不敢去了","createdAt":"2023-09-13T17:32:19"},{"id":"01963ddc-e62a-71f3-8d82-18c2b35ceaf6","parentId":null,"rootId":null,"fromId":1935,"content":"千万别去，别抱有侥幸心理，我当时入职期间招了一个项目经理，来了三月被骂跑了。是真的骂，老板站办公室骂了一上午","createdAt":"2023-09-21T17:05:29"},{"id":"019bba28-6660-7180-be89-dda9b8b855ed","parentId":null,"rootId":null,"fromId":2410,"content":"老板有关系，测试系统流程走不下去就上线然后验收","createdAt":"2026-01-14T09:39:28"}]