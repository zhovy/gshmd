[{"id":"01963dd2-816d-70ec-8eae-dc84d19922a4","parentId":null,"rootId":null,"fromId":391,"content":"个人认为楼上提到的问题是“软件技术中心”一个部门存在的问题。这个公司是以硬件为主导的","createdAt":"2022-06-08T09:39:22"},{"id":"01963dd2-81b4-737e-8e77-b0cbcfc8010d","parentId":null,"rootId":null,"fromId":1100,"content":"整个公司氛围很卷，周天全天开会到晚上七八点不让请假，钱少活多","createdAt":"2022-07-25T16:03:34"},{"id":"01963dd2-81fb-71ca-b568-4f48d5912bbd","parentId":null,"rootId":null,"fromId":1257,"content":"超级卷,996","createdAt":"2022-08-09T16:33:37"},{"id":"01963dd2-8241-731b-b54b-82db598cb66e","parentId":null,"rootId":null,"fromId":2357,"content":"本来面试说的是在济南上班，去了之后天天在德州工厂陪领导加班，有事没事也得在那靠到十一点，都住厂里了，住宿环境差，堪比农民工宿舍，在厂里吃饭还得自己掏钱。这公司没有任何福利，五险一金比例极低，除了工资，别的毛都拿不到。","createdAt":"2023-01-09T17:05:58"},{"id":"01963dd2-8287-730c-9eab-3f31b6156962","parentId":null,"rootId":null,"fromId":2398,"content":"这公司硬件为主，不适合搞软件的","createdAt":"2023-01-17T17:06:31"},{"id":"01963dd2-82cc-72e2-8825-130b6290d006","parentId":null,"rootId":null,"fromId":2846,"content":"刚收到这家公司的offer，开发岗这公司值得去吗","createdAt":"2023-03-14T18:34:14"},{"id":"01963dd2-8314-7013-8619-3d51541fc141","parentId":null,"rootId":null,"fromId":2846,"content":"确实不适合搞软件的","createdAt":"2023-04-19T16:52:38"},{"id":"01963dd2-8310-7303-810b-f72d571e2357","parentId":null,"rootId":null,"fromId":5395,"content":"入职了感觉咋样啊兄弟","createdAt":"2023-08-18T00:51:19"},{"id":"01963dd2-8357-7151-8df0-bff45e256c62","parentId":null,"rootId":null,"fromId":5395,"content":"能细说下不","createdAt":"2023-08-18T00:51:45"},{"id":"01963dd2-835c-72c9-b447-ca94ec6bd1c1","parentId":null,"rootId":null,"fromId":6484,"content":"老哥，能详细说下嘛？算法岗咋样","createdAt":"2024-01-17T16:45:44"},{"id":"01971ada-9fc5-73f1-91df-b13f23097586","parentId":null,"rootId":null,"fromId":22724,"content":"人员流动很大，压榨人很厉害","createdAt":"2025-05-29T15:03:44"}]