[{"id":"019be42b-c4e9-73c4-ae55-026b7b5b954c","parentId":null,"rootId":null,"fromId":926,"content":"现在在裁员","createdAt":"2026-01-22T13:27:12"},{"id":"019be455-c9a9-7398-81e2-a8461e369338","parentId":null,"rootId":null,"fromId":7294,"content":"浪潮哪个公司部门？信息还可以的，还有年终奖。","createdAt":"2026-01-22T14:13:06"},{"id":"019be45a-5549-728f-999b-d0efa893bb12","parentId":null,"rootId":null,"fromId":6939,"content":"除了浪潮还有别的选择么，比如银行、电网啥的，如果没有好的选择或者甲方的选择，先去待两年吧，济南的乙方稍微大点的公司，现在都差不了多少，好处是见到的面比较广，学点东西的话，至少后面跳槽也很好跳，别看都吐槽，简历里有浪潮的经历还是比纯不认识的公司是有优势的。","createdAt":"2026-01-22T14:18:03"},{"id":"019be45c-affd-72f1-b51b-8bd64f6764fb","parentId":null,"rootId":null,"fromId":167,"content":"如果想出去，就去北上广看看，薪资和环境还不错，还能加个资历。\n如果就想在济南，就往国央企或者他们的下级单位去使劲。私立企业不好混，对员工的保障也差一些。加油吧","createdAt":"2026-01-22T14:20:38"},{"id":"019be4b7-d71b-7062-8d37-bb429be023d0","parentId":null,"rootId":null,"fromId":27910,"content":"在济南的话，浪潮算是不错的了，其它也没什么更好的，要么考虑央国企研究院","createdAt":"2026-01-22T16:00:12"},{"id":"019be988-a54c-7347-b009-1796867e0d06","parentId":null,"rootId":null,"fromId":25783,"content":"不是信息，北方健康数据部门","createdAt":"2026-01-23T14:26:45"},{"id":"019be98a-e2fc-71b5-9a8e-07f671b23f3d","parentId":null,"rootId":null,"fromId":25783,"content":"本来目标是银行的，奈何国有省行、城商行总全挂了，市行拿到了但估计不是真科技。请问前辈浪潮出来，还好往外跳吗。","createdAt":"2026-01-23T14:29:12"},{"id":"019be98c-c7ab-73b9-b25f-e195abe546f8","parentId":null,"rootId":null,"fromId":25783,"content":"嗯嗯家里人也说去浪潮的话不如先出去大厂闯两年再回来。也拿了个国企子公司的，但绩效占比60，工作内容也不太感兴趣，感觉没啥前景","createdAt":"2026-01-23T14:31:16"},{"id":"019be98d-ace4-723a-9c0d-7df59dd62bab","parentId":null,"rootId":null,"fromId":25783,"content":"正式的也才吗老师，听说外包才的狠","createdAt":"2026-01-23T14:32:14"},{"id":"019be997-56a6-70cb-87c7-d8e4f8dbbfd2","parentId":null,"rootId":null,"fromId":6939,"content":"乙方随便跳，甲方得看机会了，难度很大，同时也得等机会，不挑城市的话可以选择去外地看看，机会比济南多点。","createdAt":"2026-01-23T14:42:48"},{"id":"019bea0b-6d26-718d-a3df-233f2743bfc3","parentId":null,"rootId":null,"fromId":926,"content":"也裁","createdAt":"2026-01-23T16:49:36"},{"id":"019bea20-85ae-7039-a2c3-bfaec95a82fd","parentId":null,"rootId":null,"fromId":167,"content":"济南的国企子公司，目前绩效占比很大，多数是在40%-60%之间的。因为大环境不好，项目少，指标达不到，还自负盈亏，只能降本","createdAt":"2026-01-23T17:12:38"},{"id":"019beb8a-199e-71cd-86f9-0c42a297df7d","parentId":null,"rootId":null,"fromId":25783,"content":"好嘞明白了谢谢老师！","createdAt":"2026-01-23T23:47:34"},{"id":"019bf826-102b-73fe-a1a7-f0f68c2ddd09","parentId":null,"rootId":null,"fromId":21666,"content":"为啥不出去哥们，在济南浪潮算不错的了，其他的就是央企国企更好了，建议有选择别来济南，在浪潮干几年想跳槽也只能往其他城市跳，不如毕业直接去大城市大厂干几年钱也多，技能眼界也能磨炼","createdAt":"2026-01-26T10:33:22"},{"id":"019bf8f2-432d-723d-ae4e-f4be79d6e7df","parentId":null,"rootId":null,"fromId":28081,"content":"在济南的话，浪潮算不错的公司了，但不建议呆太久，最多两三年出来，也算有大厂背景了，如果还有心气，可以试试北上杭的公司","createdAt":"2026-01-26T14:16:25"},{"id":"019c0246-5841-733f-b054-040975446255","parentId":null,"rootId":null,"fromId":2941,"content":"适合来养老","createdAt":"2026-01-28T09:44:50"},{"id":"019c035b-1484-7132-9f86-32926e78c7f7","parentId":null,"rootId":null,"fromId":28087,"content":"说起来好听（手动狗头）这就够了，老铁","createdAt":"2026-01-28T14:47:06"},{"id":"019c03ff-566d-7166-b088-837009995a3e","parentId":null,"rootId":null,"fromId":21302,"content":"校招第一份工作就是浪潮，干几年保持学习的习惯，再跳槽去其他地方。","createdAt":"2026-01-28T17:46:31"},{"id":"019c0504-03da-72ce-bd91-818cc65af2d1","parentId":null,"rootId":null,"fromId":25783,"content":"是这个理","createdAt":"2026-01-28T22:31:15"},{"id":"019c0504-ab6b-70aa-a293-36cafca98fef","parentId":null,"rootId":null,"fromId":25783,"content":"哈哈哈哈浪潮还能躺嘛？","createdAt":"2026-01-28T22:31:58"},{"id":"019c0505-e468-7083-b912-20f1945e0fff","parentId":null,"rootId":null,"fromId":25783,"content":"有点面子 但感觉不多哈哈","createdAt":"2026-01-28T22:33:18"}]