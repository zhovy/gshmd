[{"id":"01963df2-afce-7059-b5c0-fde4148b9975","parentId":null,"rootId":null,"fromId":4261,"content":"400/8=50\n一小时50份面，不知道你是钓鱼的还是如何","createdAt":"2024-08-27T19:02:26"},{"id":"01963df2-b011-7177-9e9c-603afc75377a","parentId":null,"rootId":null,"fromId":875,"content":"一分钟一碗有什么问题？高峰期一分钟10碗都是小意思","createdAt":"2024-08-27T19:33:43"},{"id":"01963df2-b016-72a4-a8c9-21145d52ee2e","parentId":null,"rootId":null,"fromId":4261,"content":"嗯，8小时的高峰期，客户8小时不间断的就餐，自欺欺人不可取","createdAt":"2024-08-27T19:59:12"},{"id":"01963df2-b01a-7385-9647-a9e2062e079d","parentId":null,"rootId":null,"fromId":5841,"content":"看到这个帖子我想起了大跃进","createdAt":"2024-08-27T20:48:34"},{"id":"01963df2-b05e-7055-9505-66f81bf1f286","parentId":null,"rootId":null,"fromId":5841,"content":"肥猪赛大象，就是鼻子短，全社杀一头，足够吃半年","createdAt":"2024-08-27T20:50:28"},{"id":"01963df2-b0a1-72ff-817e-c3aecb130c1d","parentId":null,"rootId":null,"fromId":2577,"content":"支持，你去开吧。记得考虑成本，办证、租店面、人工、材料、水电、设备器械，注意卫生别被讹不然可能一个月白干","createdAt":"2024-08-27T21:39:30"},{"id":"01963df2-b0ea-7046-a4b8-90730046cc06","parentId":null,"rootId":null,"fromId":4367,"content":"经常看到这种不太聪明的帖子，我都怀疑是钓鱼，劝退同行竞争者","createdAt":"2024-08-28T08:38:36"},{"id":"01963df2-b14c-7108-9f6e-2274785d12f2","parentId":null,"rootId":null,"fromId":6939,"content":"卖房子去吧，跑外卖出去，开餐饮去吧，创业去吧，这年头没有傻逼，苟着是最明智的，不管一个月是几千还是上万至少是有收入。","createdAt":"2024-08-28T08:44:07"},{"id":"01963df2-b195-7198-bce9-6325f7f5b32e","parentId":null,"rootId":null,"fromId":1492,"content":"不考虑竞争吗?我小区不大，4个早点铺，4家面馆","createdAt":"2024-08-28T09:22:01"},{"id":"01963df2-b21d-71fd-bc04-20cc2eef27c7","parentId":null,"rootId":null,"fromId":3341,"content":"这不是商业论坛，是负面情绪垃圾桶，回收垃圾的。\n这种积极向上的事情 不建议在这个平台发表。\n本论坛的论点均是收集垃圾，垃圾公司，垃圾牛马的聚集地。","createdAt":"2024-08-28T10:56:57"},{"id":"01963df2-b266-71c4-9d56-99d014f98e40","parentId":null,"rootId":null,"fromId":297,"content":"开吧，一开一个不吱声","createdAt":"2024-08-28T15:34:18"},{"id":"01963df2-b261-73a6-ba5a-8e2d6c91be1c","parentId":null,"rootId":null,"fromId":2577,"content":"您天天看新闻联播","createdAt":"2024-08-28T19:08:07"},{"id":"01963df2-b2b0-717b-8c6b-542d448baaa9","parentId":null,"rootId":null,"fromId":1398,"content":"可以入股不?","createdAt":"2024-08-29T07:17:20"},{"id":"01963df2-b2f5-72b1-97e3-ca2975595e5a","parentId":null,"rootId":null,"fromId":7251,"content":"写字楼的面馆其实主要靠中午，晚上人都不多。你面馆几个位子啊？能翻3次台面那算是生意最好的那一批了，你自己算算可能吗？","createdAt":"2024-08-29T08:59:12"},{"id":"01963df2-b33a-729c-aa78-fb87f0d60a93","parentId":null,"rootId":null,"fromId":875,"content":"都不看外卖的嘛，一个个只看有几张桌子","createdAt":"2024-08-29T11:39:34"},{"id":"01963df2-b388-72d9-8ea8-e8bd9079b3f9","parentId":null,"rootId":null,"fromId":875,"content":"六点多吃板面，将近300号呢，坐着等了15分钟，一天100号的板面都是居民区，没多少人的，房租就得5000多块一个月，一天店面费就得200块，一天卖100碗面才1000多块钱，一天挣500块，一月一万五，核心地段人多的地方一个月估计收入五万","createdAt":"2024-08-29T19:25:51"},{"id":"01963df2-b38d-73d2-9f9c-390d8fda8719","parentId":null,"rootId":null,"fromId":1039,"content":"楼主你怎么算的1.5，节假日和周末你去了么","createdAt":"2024-08-29T19:28:50"}]