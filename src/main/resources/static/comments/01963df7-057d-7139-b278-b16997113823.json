[{"id":"01963df7-05e6-71de-812e-c9c3319eb158","parentId":null,"rootId":null,"fromId":7566,"content":"因为山东的营商环境问题导致有理想、有抱负、有能力、想要干一番大事业的山东人要么北上北京，要么南下两个三角，去这些地方大展宏图了。\n然后因为营商环境问题，普通的山东人在体制外找不到什么好工作，只能去考公考编，考上公务员或事业编后自然寻求稳定，也就不会做成成绩；如果只是寻求稳定也就罢了，更有甚者考上公务员和事业编后有了权力就喜欢通过为难别人来彰显自己的权力，这更破坏了山东的营商环境。","createdAt":"2025-02-17T11:23:29"},{"id":"01963df7-064b-7231-91ec-c7c0d7652ac4","parentId":null,"rootId":null,"fromId":3279,"content":"“扶持一个企业我没本事，干垮一个企业太简单了。“ --山东省成武县市场监督管理局执法人员","createdAt":"2025-02-17T11:45:03"},{"id":"01963df7-0642-7150-8721-bca4a79ce9dd","parentId":null,"rootId":null,"fromId":875,"content":"考个铁饭碗，之后躺着数钱熬到退休多好，要什么自行车","createdAt":"2025-02-17T11:50:24"},{"id":"01963df7-0698-7160-89fc-847e6e43cf2d","parentId":null,"rootId":null,"fromId":22539,"content":"山东有deepdrink, 深一点","createdAt":"2025-02-17T11:51:39"},{"id":"01963df7-06dd-7067-9eaf-45924894b49a","parentId":null,"rootId":null,"fromId":22424,"content":"确实，山东有drink就够了，用不着seek","createdAt":"2025-02-17T12:04:08"},{"id":"01963df7-06e2-7168-9aac-9390bf38f106","parentId":null,"rootId":null,"fromId":875,"content":"deepdrink,我一愣，这是啥，哈哈，喝喝喝，喝完这杯，还有下一杯","createdAt":"2025-02-17T13:08:18"},{"id":"01963df7-0646-72ef-8f5a-b5dfe2b2afb1","parentId":null,"rootId":null,"fromId":5624,"content":"2楼考上了？还是推搬砖车来","createdAt":"2025-02-17T14:04:42"},{"id":"01963df7-06e6-70eb-8fa0-8427d4dcbbe0","parentId":null,"rootId":null,"fromId":7381,"content":"山东？山东最大科技公司浪潮会去github上clone下来，部署到自己服务器上就算他牛逼了","createdAt":"2025-02-17T14:19:53"},{"id":"01963df7-072a-70df-8e02-efa14a960ca2","parentId":null,"rootId":null,"fromId":22751,"content":"这还不简单","createdAt":"2025-02-17T14:48:10"},{"id":"01963df7-072e-70b7-81ac-4529a94bfa4b","parentId":null,"rootId":null,"fromId":21526,"content":"鱼头朝哪还没搞明白那","createdAt":"2025-02-17T15:23:48"},{"id":"01963df7-0694-72e9-a9ea-ae68650847cb","parentId":null,"rootId":null,"fromId":21818,"content":"能被远洋捕捞的企业，其实也没一个好东西。顶多算狗咬狗，别一边倒反对远洋捕捞。就拿比较出名的原雷军下属的那个来说，开的平台涉及网赌，死不足惜","createdAt":"2025-02-17T16:00:25"},{"id":"01963