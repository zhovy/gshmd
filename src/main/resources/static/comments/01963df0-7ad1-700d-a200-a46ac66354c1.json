[{"id":"01963df0-7b3a-71d7-9276-c90432268b7e","parentId":null,"rootId":null,"fromId":7704,"content":"小公司，几年前在那干过，当时20来个人，在汉峪金谷，实施团队5-6个人，还做其他的业务，做的是纷享销客的产品，不加班，单双休，没什么福利，早上还跳操。","createdAt":"2024-06-06T17:13:50"},{"id":"01963df0-7b84-72b9-a9f4-68abb949f0c8","parentId":null,"rootId":null,"fromId":4261,"content":"雏鹰起飞？","createdAt":"2024-06-06T17:15:21"},{"id":"01963df0-7b89-7337-bd6a-d1f58bc3203a","parentId":null,"rootId":null,"fromId":3452,"content":"面试的时候感觉也就这些人，这几年没怎么扩张啊","createdAt":"2024-06-06T17:31:05"},{"id":"01963df0-7b91-7029-875f-30e01e99fb41","parentId":null,"rootId":null,"fromId":7704,"content":"济南crm  那时候 就那几家 这家还是代理商，还一个神州云动，你不会是云动的吧","createdAt":"2024-06-06T17:38:58"},{"id":"01963df0-7bda-71ee-a126-c77233db9f24","parentId":null,"rootId":null,"fromId":3452,"content":"我不是，第一次接触这个公司，老哥晓得这公司咋样不？","createdAt":"2024-06-06T17:52:13"},{"id":"01963df0-7bdf-72ec-aa9b-7fcad8aea921","parentId":null,"rootId":null,"fromId":7704,"content":"你是做crm的吗之前？crm实施不是传统实施，是免安装的，也不需要玩sql，用crm平台里自带的公式那一套写功能，公司还行吧 单双休 没什么福利那时候也，也没年终奖，你想问什么就直接问吧","createdAt":"2024-06-06T17:55:42"},{"id":"01963df0-7be3-71cb-b9c2-9878befe491e","parentId":null,"rootId":null,"fromId":7704,"content":"反正你之前要不是做crm实施的，如果一旦学的慢了 2个月就劝退 这是真的","createdAt":"2024-06-06T17:58:09"},{"id":"01963df0-7c2c-7354-bdd5-c285d2cd9f06","parentId":null,"rootId":null,"fromId":2367,"content":"楼主主要是找实施岗位的工作室吧，这个实施岗位现在行情咋样！","createdAt":"2024-06-07T11:51:00"},{"id":"01963df0-7b8d-73ed-8cac-11da94d8231f","parentId":null,"rootId":null,"fromId":3663,"content":"这几年不倒闭就算他厉害了，还扩张？","createdAt":"2024-06-08T14:51:28"},{"id":"01963df0-7c27-734e-96ff-516b156dd438","parentId":null,"rootId":null,"fromId":3452,"content":"明白了，之前做个erp和crm相关的工作，去看看吧，这年头不好混，谢谢前辈指导~","createdAt":"2024-06-18T11:03:31"},{"id":"01963df0-7c70-7217-ac1c-fadc9a80aa95","parentId":null,"rootId":null,"fromId":3452,"content":"马上今年的千万毕业生就进厂了，不好混啊","createdAt":"2024-06-18T11:04:14"}]