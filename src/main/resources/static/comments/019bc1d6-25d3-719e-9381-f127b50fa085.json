[{"id":"019bc413-9b7c-73dc-8775-f82a727bf58e","parentId":null,"rootId":null,"fromId":21294,"content":"能在这里问学区房，你大概率也是买不起。","createdAt":"2026-01-16T07:52:57"},{"id":"019bc44a-3e49-7148-afbd-459019758163","parentId":null,"rootId":null,"fromId":22250,"content":"为什么这么笃定？再说了你上来就喷粪大概也是个穷屌丝","createdAt":"2026-01-16T08:52:38"},{"id":"019bc44d-cd8d-7367-a1e2-c3764daccaaa","parentId":null,"rootId":null,"fromId":557,"content":"为什么这么笃定？再说了你上来就喷粪大概也是个穷屌丝","createdAt":"2026-01-16T08:56:31"},{"id":"019bc455-e930-71bb-85a7-45996779c9b2","parentId":null,"rootId":null,"fromId":6344,"content":"育英肯定好啊，小学这边直升的是经十一路小学、胜利大街小学、南上山街小学；经五路也挺好的，直升济南实验；历下高新的不清楚。过来人给你两个忠告：1、学区房贬值严重，近两年近乎腰斩，非必要别碰，我亲戚就是买的胜利大街的学区房2、孩子如果不是学习特别好，别去这些地方，差生在好学校是种煎熬，看看育英中学田老师的例子就知道了，学习不好天天整你","createdAt":"2026-01-16T09:05:23"},{"id":"019bc456-079b-7343-9e11-7cbf7fc2adc9","parentId":null,"rootId":null,"fromId":1049,"content":"为什么这么笃定？再说了你上来就喷粪大概也是个穷屌丝","createdAt":"2026-01-16T09:05:31"},{"id":"019bc458-db9f-715f-af9f-5d8ba637300d","parentId":null,"rootId":null,"fromId":3002,"content":"为什么这么笃定？再说了你上来就喷粪大概也是个穷屌丝","createdAt":"2026-01-16T09:08:36"},{"id":"019bc45c-8be0-729f-8a5c-ea8629c2abed","parentId":null,"rootId":null,"fromId":2783,"content":"话糙理不糙","createdAt":"2026-01-16T09:12:38"},{"id":"019bc46e-564f-7265-96ac-9c75f1e573b1","parentId":null,"rootId":null,"fromId":25906,"content":"上什么学校，毕业后也有可能送外卖","createdAt":"2026-01-16T09:32:04"},{"id":"019bc473-6aa1-7054-8e4b-b2bfc8239ca0","parentId":null,"rootId":null,"fromId":21294,"content":"还问育英中学好不好，你都知道了，能不好吗？多余问？","createdAt":"2026-01-16T09:37:36"},{"id":"019bc473-ecbc-7320-a0f7-aa2e8f5919a7","parentId":null,"rootId":null,"fromId":21294,"content":"你咋不问清华好还是北大好？","createdAt":"2026-01-16T09:38:10"},{"id":"019bc485-21c9-7301-a4f2-342fe198b671","parentId":null,"rootId":null,"fromId":25476,"content":"你把小孩放这里容易死，死好多个了","createdAt":"2026-01-16T09:56:57"},{"id":"019bc5a3-43a7-7203-88dc-49788096a547","parentId":null,"rootId":null,"fromId":27587,"content":"理想之城理想之城理想之城理想之城理想之城理想之城理想之城","createdAt":"2026-01-16T15:09:29"},{"id":"019bc5d6-5be2-7289-a4dd-54adadeea29d","parentId":null,"rootId":null,"fromId":6423,"content":"把买房的钱，给孩子存起来，或者用于孩子培养，比上个所谓名校强","createdAt":"2026-01-16T16:05:18"},{"id":"019bc601-ed0c-7379-8fc8-ae2f72ae85f5","parentId":null,"rootId":null,"fromId":481,"content":"前段时间刚爆出一个新闻来，你还刚让孩子去呢。别卷了，孩子如果能考上985 211，他不去育英也能考上，如果没那智商，去了也一样","createdAt":"2026-01-16T16:52:53"},{"id":"019bd449-eb73-7053-9331-10638d0754d8","parentId":null,"rootId":null,"fromId":1720,"content":"育英实验初中稼轩山大附中（后两个是私立）在济南第一档，有时候指标生分数线比统招分数线都高，剩下的就是什么燕山甸柳济南五中之类的第二档，能走指标上好高中的差不离也能走统招(可能低个十来分)，再剩下的就纯指着指标生名额上好高中了，排不到指标可能只能去读高职.\n但是楼上的老哥话糙理不糙，普通人不用给孩子花大价钱买学区房搞教培(有钱随手几十上百万的土豪随意)，别说中考考得好上好高中了，就是高考考得好上好大学，考研考得好读好的研究生又能怎么样呢？找工作不也就那样，不还是老老实实当打工人","createdAt":"2026-01-19T11:26:12"},{"id":"019bd44b-3880-721d-9be4-bb2db3c6dfba","parentId":null,"rootId":null,"fromId":1720,"content":"不如给孩子留点金银保险之类的投资，至少保证孩子有躺平的资本，不至于被领导上司随便拿捏","createdAt":"2026-01-19T11:27:38"},{"id":"019bd44e-ddb6-7364-a2d8-b1ba027f7e83","parentId":null,"rootId":null,"fromId":1720,"content":"还有就是你要是追求名校初高中，不如直接去读历城二的小学，但是孩子很受罪，也很花钱（我当年读高中的时候听老师说小学一年8万学费），中考成绩大概不差(平均能上历城二中的水平)，高考也差不多能保底本科吧，但是这意味着得小初高受12年的罪，自己掂量一下值不值吧","createdAt":"2026-01-19T11:31:37"},{"id":"019bd519-ebb1-7090-87f6-2a2eae2c4cdb","parentId":null,"rootId":null,"fromId":22250,"content":"什么新闻，小孩子被弄死了 ？","createdAt":"2026-01-19T15:13:24"},{"id":"019bd51a-4ddc-7250-a4f7-1a599f4ee031","parentId":null,"rootId":null,"fromId":22250,"content":"被老师给欺负死了？","createdAt":"2026-01-19T15:13:49"},{"id":"019be39c-ad26-71e9-b3c9-18e5df719830","parentId":null,"rootId":null,"fromId":6122,"content":"我也想了解一下","createdAt":"2026-01-22T10:50:54"}]