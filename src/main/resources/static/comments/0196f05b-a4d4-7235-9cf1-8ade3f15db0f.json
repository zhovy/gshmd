[{"id":"0196f063-426e-7112-af60-81e3e763dcac","parentId":null,"rootId":null,"fromId":1049,"content":"细说","createdAt":"2025-05-21T09:09:19"},{"id":"0196f07d-ddd6-73b5-a8d3-0e8ce6111524","parentId":null,"rootId":null,"fromId":21818,"content":"众阳那帮工贼天天骂众阳有几个离职的？现在的人啊，加班可以干，低工资也可以干，单休也可以干。。。","createdAt":"2025-05-21T09:38:22"},{"id":"0196f081-9d49-71bf-a6dc-e36e6b61aaa6","parentId":null,"rootId":null,"fromId":23300,"content":"都被工贼无底线惯的资本家们，无偿加班，单休，降薪，扣绩效扣年终奖，统统无所谓，只要还有个岗位，我就超越了市面上90%的牛马。所以资本家的态度就是，爱干不干，不干有的是人干。","createdAt":"2025-05-21T09:42:28"},{"id":"0196f5bf-f9f5-721c-89a5-b762b5cb8531","parentId":null,"rootId":null,"fromId":6266,"content":"是这样的，济南行情都是站长干爆炸的，因为站长是孙笑川。","createdAt":"2025-05-22T10:08:41"},{"id":"0196f6df-a189-71ab-aee7-6f48099f6746","parentId":null,"rootId":null,"fromId":23223,"content":"确实，工贼太多，只知道嘴上抱怨，抱怨完就继续加班了。不该干的还是乖乖干，该干的还是不去干。违法的垃圾公司就让他们凉啊","createdAt":"2025-05-22T15:22:53"},{"id":"0196f6f2-f114-70a3-b434-3744ce64046a","parentId":null,"rootId":null,"fromId":21267,"content":"95%是工贼吧，在这里骂的最狠的就是加班最多同时面对领导也是最乖的。领导让吃屎都喜欢去干的，回头私底下狂吠。有胆量就拿出实际行动来，带头抵制加班不就行了。还是奴性太重！","createdAt":"2025-05-22T15:43:58"},{"id":"0196f70b-0492-7389-8d62-8749a2f1665f","parentId":null,"rootId":null,"fromId":506,"content":"和网站有啥关系，就是不行。不是外包就是 包中包   政府国有性质的占比奇高","createdAt":"2025-05-22T16:10:16"},{"id":"01976803-93df-73cc-a122-47cc10accbdc","parentId":null,"rootId":null,"fromId":25066,"content":"大家顶住 别再往低要了   现在倒挂太严重了","createdAt":"2025-06-13T14:39:14"},{"id":"01976872-1c1a-7154-948d-7a7c6eededb6","parentId":null,"rootId":null,"fromId":23605,"content":"孙笑川是个干熊的","createdAt":"2025-06-13T16:39:58"},{"id":"01976873-adb5-72af-9ee0-e2ee22714bb5","parentId":null,"rootId":null,"fromId":23605,"content":"4k就干，卷死你们","createdAt":"2025-06-13T16:41:41"}]