[{"id":"019b29ce-891c-7336-a5fe-c262b52044bc","parentId":null,"rootId":null,"fromId":557,"content":"该拒绝的工作要拒绝","createdAt":"2025-12-17T08:56:00"},{"id":"019b29cf-6144-703a-8492-17ca73367bed","parentId":null,"rootId":null,"fromId":7566,"content":"倒也是，工作是工作，工作也就只是一份工作。","createdAt":"2025-12-17T08:56:55"},{"id":"019b29ea-6017-733e-83e6-d2d18b5ee54a","parentId":null,"rootId":null,"fromId":770,"content":"脾气太好，容易被欺负","createdAt":"2025-12-17T09:26:24"},{"id":"019b2a00-a558-7388-8d51-03a5308bae16","parentId":null,"rootId":null,"fromId":7566,"content":"人善被人欺，马善被人骑。老祖宗的话还是有几分道理的","createdAt":"2025-12-17T09:50:44"},{"id":"019b2c9f-5c64-7040-968a-d13b1845829f","parentId":null,"rootId":null,"fromId":22591,"content":"学会拒绝你越好用别人越用你","createdAt":"2025-12-17T22:03:20"},{"id":"019b2f15-8d5a-72b4-b6d8-28a358cd9c13","parentId":null,"rootId":null,"fromId":7566,"content":"有道理，太有道理了","createdAt":"2025-12-18T09:31:40"},{"id":"019b2f80-5faf-733f-8edb-24edb4e200af","parentId":null,"rootId":null,"fromId":875,"content":"不能老满足他，要让他吃不饱，后面就不会找你了","createdAt":"2025-12-18T11:28:20"},{"id":"019b2ff0-aac9-70ee-8a93-43e07a1cffda","parentId":null,"rootId":null,"fromId":27823,"content":"要有锋芒","createdAt":"2025-12-18T13:31:00"},{"id":"019b301b-aa6c-700d-80f9-4049933a93ee","parentId":null,"rootId":null,"fromId":7566,"content":"也是","createdAt":"2025-12-18T14:17:58"},{"id":"019b301b-e88b-7060-a0ae-f070efcbc5ea","parentId":null,"rootId":null,"fromId":7566,"content":"没有锋芒的善良不是善良，而是软弱","createdAt":"2025-12-18T14:18:14"},{"id":"019b43bd-1d5d-7185-943b-73cfbcf60400","parentId":null,"rootId":null,"fromId":27118,"content":"现在发现不晚","createdAt":"2025-12-22T09:47:05"},{"id":"019b4508-fa3c-707b-9662-37c22b6d823d","parentId":null,"rootId":null,"fromId":7566,"content":"亡羊补牢，犹未为晚。对人客气是对的，但是不能对人太客气。","createdAt":"2025-12-22T15:49:34"}]