[{"id":"01963dec-ebb0-7074-98db-007c3a6425b6","parentId":null,"rootId":null,"fromId":3892,"content":"装修现在不景气吧？我叔之前就是干装修的，现在干小区景观、排水之类的，还是从济南青岛来回跑，开发商也没有钱，拿房子顶账，现在在青岛有好几套房子了","createdAt":"2024-03-22T15:56:52"},{"id":"01963dec-ec05-7053-a563-198bad4b8455","parentId":null,"rootId":null,"fromId":3801,"content":"前几年挣钱，近两年不行。","createdAt":"2024-03-22T16:01:53"},{"id":"01963dec-ebf8-72f2-936e-6d6c3510068d","parentId":null,"rootId":null,"fromId":6266,"content":"6，这不能当包租公了","createdAt":"2024-03-22T16:06:22"},{"id":"01963dec-ec49-73dd-bce3-ca588d9a8373","parentId":null,"rootId":null,"fromId":6091,"content":"感觉得行吧，济南这么多新房、二手房装修","createdAt":"2024-03-22T16:23:54"},{"id":"01963dec-ec52-70a1-b78d-742eff0a2dd8","parentId":null,"rootId":null,"fromId":875,"content":"别的不知道，反正二房东挺挣钱，收毛坯房，然后简装出租，吃差价，收管理费","createdAt":"2024-03-22T19:52:10"},{"id":"01963dec-ebfc-7184-b1d9-27b719f0765c","parentId":null,"rootId":null,"fromId":2366,"content":"等过几年房产税出台，直接哭晕","createdAt":"2024-03-22T22:00:54"},{"id":"01963dec-ec4e-715b-a2d7-046d6cff8252","parentId":null,"rootId":null,"fromId":2366,"content":"近两年属于是啥啥都难挣钱?","createdAt":"2024-03-22T22:01:32"},{"id":"01963dec-ec01-713a-b467-14803dfd7758","parentId":null,"rootId":null,"fromId":122,"content":"房产税出台后 两级分化更严重 普通人还是别盼着房产税了（富哥除外）","createdAt":"2024-03-27T11:58:50"}]