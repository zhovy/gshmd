[{"id":"01963de6-0359-70e9-bff9-fa9a1bee15ce","parentId":null,"rootId":null,"fromId":922,"content":"应届的话升本吧，然后能考个研究生就再考一下","createdAt":"2023-08-07T16:52:11"},{"id":"01963de6-03a0-733a-a3a7-257d5ae3408e","parentId":null,"rootId":null,"fromId":3663,"content":"呃，高数太差了，别的还行","createdAt":"2023-08-07T16:56:29"},{"id":"01963de6-03a5-73be-b067-e98f9d2b2d34","parentId":null,"rootId":null,"fromId":258,"content":"能专升本的话一定要考，不然你会后悔的","createdAt":"2023-08-07T16:58:44"},{"id":"01963de6-03eb-700f-9c35-af1f6e953586","parentId":null,"rootId":null,"fromId":1398,"content":"多大了","createdAt":"2023-08-07T17:04:37"},{"id":"01963de6-0445-73af-b73d-e8e65014dfaa","parentId":null,"rootId":null,"fromId":3663,"content":"20","createdAt":"2023-08-07T17:07:43"},{"id":"01963de6-044a-7192-b30e-e3f37af2f9b1","parentId":null,"rootId":null,"fromId":1398,"content":"升本吧，高数再难也比找个好工作简单。","createdAt":"2023-08-07T17:48:44"},{"id":"01963de6-044e-72e4-b2c1-3e3cf1ba748a","parentId":null,"rootId":null,"fromId":875,"content":"干销售去吧","createdAt":"2023-08-07T23:08:17"},{"id":"01963de6-0496-7282-b5db-f4c196d444c3","parentId":null,"rootId":null,"fromId":3663,"content":"必普集团吗哈哈，坑逼集团","createdAt":"2023-08-07T23:21:41"},{"id":"01963de6-049b-7055-9ee2-d4ee3014e7c9","parentId":null,"rootId":null,"fromId":2613,"content":"为什么非要干软件呢，卷的很","createdAt":"2023-08-08T08:19:42"},{"id":"01963de6-04e3-7011-b221-65e777520ef3","parentId":null,"rootId":null,"fromId":1039,"content":"一句话：软件开发不要专科，学历最低本科是第一筛选条件","createdAt":"2023-08-08T09:58:35"},{"id":"01963de6-0529-70a0-824b-eb3ff20908f9","parentId":null,"rootId":null,"fromId":4286,"content":"年级还小，升个本，不着急工作","createdAt":"2023-08-08T10:18:19"},{"id":"01963de6-0570-710b-9de1-3f0792733017","parentId":null,"rootId":null,"fromId":4010,"content":"你还年轻，花点时间精力升本吧，不过不建议入这一行了","createdAt":"2023-08-08T15:52:25"},{"id":"01963de6-05bf-7151-aa75-fc1d7779c7c7","parentId":null,"rootId":null,"fromId":333,"content":"你想干就干 不用问别人 别人肯定都是劝退","createdAt":"2023-08-09T08:46:42"},{"id":"01963de6-04de-7161-aa0a-20624cdb6159","parentId":null,"rootId":null,"fromId":3663,"content":"那干啥去，别的还不如这个","createdAt":"2023-08-09T15:05:42"},{"id":"01963de6-0605-7219-9482-b87d8dde13ab","parentId":null,"rootId":null,"fromId":3663,"content":"我不得听听各位前辈的看法吗","createdAt":"2023-08-09T15:06:01"},{"id":"01963de6-060a-73e5-8724-a2686999bb21","parentId":null,"rootId":null,"fromId":3663,"content":"想干也得有公司要啊","createdAt":"2023-08-09T15:06:13"},{"id":"01963de6-060e-7134-b07c-947995da98c0","parentId":null,"rootId":null,"fromId":333,"content":"不好找 你实在不知道干啥可以试试 反正不好干 现在工作好几年的大专想跳槽都不好跳了 没公司要","createdAt":"2023-08-09T15:24:13"},{"id":"01963de6-0612-730c-bba9-7898a05192c7","parentId":null,"rootId":null,"fromId":2201,"content":"你前怕狼后怕虎还是别干了，直接回家种地吧，大老爷们磨磨唧唧的，要坚定自己的选择，为自己的选择买单，无论是入行还是不入行，我们人生努力的意义不就是让以前的选择变的正确吗？","createdAt":"2023-08-09T15:24:27"},{"id":"01963de6-062b-71a9-8461-405d9b93f917","parentId":null,"rootId":null,"fromId":1376,"content":"我只能说能找到工作，但是一定是不好的工作","createdAt":"2023-08-09T20:28:23"},{"id":"01963de6-0616-702a-877b-27fd5f332696","parentId":null,"rootId":null,"fromId":4037,"content":"理科类的大部分工作，第一要素就是学历专业。开发也是一样，多年开发经验的专科还稍微稍微好点。好公司都进不去。卡学历。没工作经验的。基本入不了行。很困难。","createdAt":"2023-08-10T10:12:31"},{"id":"01963de6-061b-717f-80f7-4bda64b38fa6","parentId":null,"rootId":null,"fromId":4037,"content":"尽量去提升学历。然后做开发。因为你开发做不了可以转运维，实施，测试。如果运维实施测试，你做不了，转岗可选择的就没啥岗位了。面对你的就只有跳出这个围墙了","createdAt":"2023-08-10T10:15:21"},{"id":"01963de6-066f-7300-8278-de19a5261d32","parentId":null,"rootId":null,"fromId":880,"content":"去国外升本或者升硕士吧，","createdAt":"2023-08-10T14:42:38"},{"id":"01963de6-061f-7395-b077-6b9745b2fc41","parentId":null,"rootId":null,"fromId":3663,"content":"你的意思是想个牲口一样不需要思维直接乱撞吗","createdAt":"2023-08-10T18:29:29"},{"id":"01963de6-0623-736b-b085-bcfeb3dce073","parentId":null,"rootId":null,"fromId":4360,"content":"听一句劝，研究生上一上吧，尽量好一点的，不然跟你同级别的月入少1+年入少20+","createdAt":"2023-08-11T10:17:43"},{"id":"01963de6-0627-7169-9e3c-16099a646b9e","parentId":null,"rootId":null,"fromId":3112,"content":"你这种想法最傻逼，人家考研的还直播间问问张雪峰呢，谁愿意和个傻逼一样拿自己的青春去赌博啊。","createdAt":"2023-08-14T09:48:36"}]