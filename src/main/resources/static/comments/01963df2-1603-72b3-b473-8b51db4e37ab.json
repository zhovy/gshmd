[{"id":"01963df2-166f-7145-bdbd-ffef3b2bcfbb","parentId":null,"rootId":null,"fromId":21546,"content":"资本家宁可把钱给律师团队,也不会给卑微打工人","createdAt":"2024-08-06T11:52:26"},{"id":"01963df2-16b2-7361-b681-ff5a0dcd699f","parentId":null,"rootId":null,"fromId":21341,"content":"我有个问题，公司账面上真没钱了，公司也没有什么固定资产。这种情况下，能让老板自掏腰包给赔付吗？","createdAt":"2024-08-06T12:56:01"},{"id":"01963df2-16f7-71c3-9953-5481bb24ea0d","parentId":null,"rootId":null,"fromId":5793,"content":"1、看看法律关系，起诉的时候能不能带上老板\n2、看股东数量，如果是一个人股东，可以让老板承担\n3、如果是认缴的，后期在认缴期限到期后（新公司法也规定期限），可以要求老板在认缴限额内支付","createdAt":"2024-08-06T14:15:56"},{"id":"01963df2-16fb-7247-8558-0bc21f774235","parentId":null,"rootId":null,"fromId":5793,"content":"站在员工的角度，介绍一下劳动法","createdAt":"2024-08-06T14:17:46"}]