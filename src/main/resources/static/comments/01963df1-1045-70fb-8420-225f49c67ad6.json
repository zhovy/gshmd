[{"id":"01963df1-10b5-73d8-9f80-3b0edce3cb5a","parentId":null,"rootId":null,"fromId":6517,"content":"9年 要15？","createdAt":"2024-06-21T14:12:28"},{"id":"01963df1-10fb-73e6-9eb3-819e130f2c3c","parentId":null,"rootId":null,"fromId":21010,"content":"啥岗？ 技术吗?","createdAt":"2024-06-21T14:14:44"},{"id":"01963df1-113e-729d-8890-8da3cd76ae1d","parentId":null,"rootId":null,"fromId":7550,"content":"前端","createdAt":"2024-06-21T14:19:16"},{"id":"01963df1-1143-7173-b613-559e292dec49","parentId":null,"rootId":null,"fromId":1955,"content":"前端？干9年了？？为啥还没转产品或是其它岗？还靠着前端？我不太懂啊，我就是问问","createdAt":"2024-06-21T14:20:22"},{"id":"01963df1-1187-7268-a265-48b36bed0af6","parentId":null,"rootId":null,"fromId":7550,"content":"转不了，不好转。","createdAt":"2024-06-21T14:21:22"},{"id":"01963df1-118b-71cd-babb-31d98a2faf4d","parentId":null,"rootId":null,"fromId":1955,"content":"没有绝对的事","createdAt":"2024-06-21T14:34:51"},{"id":"01963df1-1190-71d5-8ac5-9bf12b9c74aa","parentId":null,"rootId":null,"fromId":7550,"content":"人懒，要不都30了还当程序员嘛。\n转产品感觉也凉，转后端还得学习，而且也是搬砖的命，就干着前端能混一天是一天。","createdAt":"2024-06-21T14:40:00"},{"id":"01963df1-119c-70f4-982a-9584ec386cf0","parentId":null,"rootId":null,"fromId":21010,"content":"既然是外包到别的单位，就要看你外包到的这个单位加不加班，跟浪潮其实关系不大。","createdAt":"2024-06-21T14:40:51"},{"id":"01963df1-11e4-7271-9100-80f86bd0cc60","parentId":null,"rootId":null,"fromId":7226,"content":"现在给你开到多少,既然不在浪潮上班,就要看甲方那边要求或者经理要求了,之前我去的外包也是说的不加班,但是经理就要求加班,没办法","createdAt":"2024-06-21T14:51:41"},{"id":"01963df1-11e0-7027-8e95-e527ab2bcbbc","parentId":null,"rootId":null,"fromId":21010,"content":"主要能有几个不加班的单位呢？ 加班不严重、氛围比较好就烧高香了。","createdAt":"2024-06-21T14:53:29"},{"id":"01963df1-1194-71eb-93f4-fb65ac66d8e0","parentId":null,"rootId":null,"fromId":1955,"content":"30了为啥不能当程序员，你到这地步了，别否定自己就行了","createdAt":"2024-06-21T15:03:32"},{"id":"01963df1-1229-71c7-8ad7-8ef2f4bcf49b","parentId":null,"rootId":null,"fromId":2551,"content":"加不加班跟浪潮一毛钱关系没有，要看甲方加班多不","createdAt":"2024-06-21T15:40:23"},{"id":"01963df1-126d-70f3-9929-cbcb348c1bba","parentId":null,"rootId":null,"fromId":3592,"content":"兄弟如果还没入职。千万别来，我就在。来了你就会享受到浪潮和中建的双重折磨。不加班？不存在。只要开了项目，基本都是单休，晚上加班也是常态，而且不管你在休息还是请假，随时做好准备，因为他们随时会找你解决问题，恨不得要你24小时待命。要不是工作不太好找，估计这里根本留不住人。","createdAt":"2024-06-24T09:03:41"},{"id":"01963df1-12b1-714f-b956-c728ed6aa98a","parentId":null,"rootId":null,"fromId":3592,"content":"补充一句，哪怕找外包也别找浪潮的外包，都是半斤八两的玩意，缺人了就死命招人，用完就让你滚蛋。有个同事，因为五一不加班被开了","createdAt":"2024-06-24T09:05:44"},{"id":"01963df1-12b5-7295-abf1-f0b4419d0d2e","parentId":null,"rootId":null,"fromId":3592,"content":"哦对了，还有出差，说不定哪天就派你去北京或上海去了，不去？退场吧。去？报销等着吧，半年起步。","createdAt":"2024-06-24T09:09:27"},{"id":"01963df1-12ba-70bb-8196-d176e3d8d5f6","parentId":null,"rootId":null,"fromId":7550,"content":"我靠，太坑了，不去了，感谢。","createdAt":"2024-06-24T13:46:27"},{"id":"01963df1-12be-7120-a32d-d0f41b05b7fe","parentId":null,"rootId":null,"fromId":1039,"content":"我想知道五一被开这个有裁员补贴的N+1么","createdAt":"2024-06-24T13:55:34"},{"id":"01963df1-12c2-7314-accc-2703ad3a20f6","parentId":null,"rootId":null,"fromId":21010,"content":"外包猛如虎啊","createdAt":"2024-06-24T16:01:31"},{"id":"01963df1-1306-70dd-821e-045b0486f1f4","parentId":null,"rootId":null,"fromId":2289,"content":"数字服务就是之前的世科，我永远忘不了当初一个多月没有休息天天晚上到凌晨的日子.....更别说外包了","createdAt":"2024-06-25T11:29:50"},{"id":"01963df1-134a-71ad-b2b7-881b759ecefb","parentId":null,"rootId":null,"fromId":2367,"content":"楼主最后去了吗","createdAt":"2024-07-01T10:21:14"},{"id":"01963df1-138e-72f7-ab7c-4b49ab29bbc5","parentId":null,"rootId":null,"fromId":7550,"content":"没去，先在现在公司待着吧。","createdAt":"2024-07-01T13:28:27"},{"id":"01963df1-1198-714a-a1a6-c69533116752","parentId":null,"rootId":null,"fromId":3319,"content":"你多大了 什么岗位？","createdAt":"2024-07-16T16:57:31"}]