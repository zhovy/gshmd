[{"id":"01963ded-0f9c-71c6-a9b2-d664bd02ea85","parentId":null,"rootId":null,"fromId":875,"content":"哈哈，太正常了，同样从北京回来，之前在北京公司卫生有物业每天打扫工位，厕所每天都有人打扫，厕所卫生纸供应充足，回济南呆了三天公司了，上班每周都要轮流打扫卫生，卫生纸厕所都是没有的，需要自己买，电脑也是两家不给，一家补贴200块，另外一家给一台七八年的破旧电脑，不屑于用的就自己带电脑，反正公司是不会给配新的","createdAt":"2024-03-27T20:58:26"},{"id":"01963ded-0fe8-717b-9ca2-f47e0fafbdeb","parentId":null,"rootId":null,"fromId":1049,"content":"降薪了吗","createdAt":"2024-03-28T08:44:48"},{"id":"01963ded-1030-7230-ba55-f2d3df0dae6b","parentId":null,"rootId":null,"fromId":5768,"content":"楼主为什么内涵人人日","createdAt":"2024-03-28T08:48:42"},{"id":"01963ded-1078-7263-a0fe-b6447cacd4e7","parentId":null,"rootId":null,"fromId":1656,"content":"厕纸是物业给放的","createdAt":"2024-03-28T09:02:02"},{"id":"01963ded-0f87-706c-b1dc-c3333c0f17c0","parentId":null,"rootId":null,"fromId":2420,"content":"多给你多少钱啊这厮","createdAt":"2024-03-28T09:10:35"},{"id":"01963ded-0f90-7358-b12d-f16be0c89327","parentId":null,"rootId":null,"fromId":6517,"content":"我们公司电脑能翻墙的，各种破解都可以","createdAt":"2024-03-28T10:28:21"},{"id":"01963ded-1074-728d-b696-11a5f46459ab","parentId":null,"rootId":null,"fromId":3341,"content":"众阳吗哥哥 哈哈哈哈","createdAt":"2024-03-28T10:56:06"},{"id":"01963ded-10bd-7394-a9bb-0afe8564ddc0","parentId":null,"rootId":null,"fromId":875,"content":"物业放的，前提是公司的还是给物业公司买厕所只的钱，公司不给钱，厕所就没纸","createdAt":"2024-03-28T13:05:00"},{"id":"01963ded-0fe0-73bf-bd3b-331df4e5eab7","parentId":null,"rootId":null,"fromId":6631,"content":"哈哈哈。我主要是还没有形成去厕所自己带纸的习惯，想去厕所就自己去了。那次本来没有屎意，结果突然拉了。没有带纸，擦。无语死了。厕所臭气冲天，我好久才适应。","createdAt":"2024-03-29T08:36:38"},{"id":"01963ded-0f94-72a3-9757-0febe212a51b","parentId":null,"rootId":null,"fromId":6631,"content":"我一直感觉电脑是个人私人物品，不想和工作纠缠太多，哈哈哈，不然每次假期看到电脑就想到工作的事情。不爽。","createdAt":"2024-03-29T08:37:24"},{"id":"01963ded-102c-70c3-8200-2edc757a5c50","parentId":null,"rootId":null,"fromId":6631,"content":"那肯定的降薪，不降薪发现根本找不到工作，目前这份降没那么离谱，就过来了。适应中，纯后端的，需要会前端，还需要会运维。不知道你们公司啥样，这边好多公司为啥没有运维部署项目呢。都是开发一条龙了。我的天。","createdAt":"2024-03-29T08:41:24"},{"id":"01963ded-0f98-72c9-94f9-d684c394a58c","parentId":null,"rootId":null,"fromId":576,"content":"我们公司还缺个测试岗","createdAt":"2024-04-01T13:46:49"},{"id":"01963ded-0fe4-70e3-bb32-65918c548e5e","parentId":null,"rootId":null,"fromId":7052,"content":"我目前这家公司每日都安排打扫全公司卫生（包括男女卫生间），刚入职不到一个月，排了三次，我一次没打扫。估计会因为这个事成为导火点而离职！","createdAt":"2024-04-11T09:10:26"},{"id":"01963ded-10c2-7052-afd7-dbff0d1f654c","parentId":null,"rootId":null,"fromId":2859,"content":"有厕纸，有垃圾桶，有物业打扫，公司电脑双屏没任何限制和监控软件。","createdAt":"2024-04-11T16:14:40"}]