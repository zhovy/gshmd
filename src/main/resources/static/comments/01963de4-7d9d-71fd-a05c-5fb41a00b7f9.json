[{"id":"01963de4-7e01-7092-9089-4cdb57bf9be7","parentId":null,"rootId":null,"fromId":2815,"content":"济南有几个正常的公司啊","createdAt":"2023-07-04T09:44:28"},{"id":"01963de4-7e4f-73a0-bb6d-4692ca76194c","parentId":null,"rootId":null,"fromId":3671,"content":"面试过这个公司，幸好没去","createdAt":"2023-07-04T11:43:10"},{"id":"01963de4-7e98-72ba-aba1-a6b2793d064e","parentId":null,"rootId":null,"fromId":460,"content":"好几年之前面试过，说是出差很多，就没去，亏了没去","createdAt":"2023-07-04T14:25:57"},{"id":"01963de4-7edf-72ad-b0da-f902892ef3e9","parentId":null,"rootId":null,"fromId":258,"content":"要工资还得写申请？这他妈直接举报了 不能惯着。","createdAt":"2023-07-04T15:23:36"},{"id":"01963de4-7f28-71ad-a6bc-e3f4a13f3137","parentId":null,"rootId":null,"fromId":3355,"content":"该公司经常让员工办工资卡，有员工来了没一年加上信用卡办了6张卡了。\n其中有的卡一次都没发过工资。","createdAt":"2023-07-04T16:00:49"},{"id":"01963de4-7f7d-719c-9ade-6e46ac7c07c4","parentId":null,"rootId":null,"fromId":4143,"content":"要工资都得申请，这公司的员工是黑奴吗？还不走等着干啥","createdAt":"2023-07-24T15:40:51"},{"id":"01963de4-7e47-70ae-9ae4-2e79938dcebb","parentId":null,"rootId":null,"fromId":4016,"content":"都是精神病老板","createdAt":"2023-07-24T16:35:16"},{"id":"01963de4-7e4b-722a-b0e9-f7ed2deeadd5","parentId":null,"rootId":null,"fromId":4253,"content":"最近我在看boss 几乎都是黑名单，智联少点但是也很多，从软件上面一看挺好，但是经不起推敲，来这里一看直接gg ","createdAt":"2023-08-24T10:21:41"},{"id":"01963de4-7fc9-7145-8dbf-28b1927e4196","parentId":null,"rootId":null,"fromId":2353,"content":"真的假的。刚面试了 - - ","createdAt":"2023-09-07T11:08:50"},{"id":"01963de4-800f-7038-ad74-795dabca7e8e","parentId":null,"rootId":null,"fromId":6374,"content":"有没有在云天的老哥，出来分享下最新信息呀","createdAt":"2024-04-19T10:18:26"},{"id":"01963de4-805a-7359-9fe5-8d0bb50b8776","parentId":null,"rootId":null,"fromId":6374,"content":"日报、周报、月总结；无补卡机会；缺卡第一次50元，第二次100元，第三次150元，第四次按旷工半天； 迟到早退，5元/分钟；节假日加班不可调休，据说算进绩效里面去， 工作日晚上不算加班；工资的25%作为绩效浮动薪资；请假次数多了，扣绩效； 办公环境有些差，感觉特像外包，通风较差，味道久了就习惯了；同事间沟通声音非常洪亮，脑仁疼；接口基本没有文档；","createdAt":"2024-05-31T19:36:18"},{"id":"01963de4-80a2-73c2-8770-f5f1db4f03ea","parentId":null,"rootId":null,"fromId":6374,"content":"据说二月份工资好多没发的","createdAt":"2024-05-31T19:36:52"},{"id":"01963de4-809d-73c5-bd54-4da907b5db25","parentId":null,"rootId":null,"fromId":2367,"content":"我看这家公司有的岗位是外派到甲方去运维驻场，这种算不算外包？","createdAt":"2024-06-19T11:22:16"},{"id":"019658c0-be04-71ec-9851-cefa6dd3f737","parentId":null,"rootId":null,"fromId":23591,"content":"你好，你去云天了吗","createdAt":"2025-04-21T22:29:08"}]