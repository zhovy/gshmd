[{"id":"01963df0-7e35-71c1-9ce2-53d6d679edab","parentId":null,"rootId":null,"fromId":875,"content":"济南都是外行领导，不很正常吗，外行领导内行","createdAt":"2024-06-07T17:11:04"},{"id":"01963df0-7e7a-72eb-bfb9-2e32ceb7df40","parentId":null,"rootId":null,"fromId":2525,"content":"你去了嘛","createdAt":"2024-06-13T15:53:51"},{"id":"01963df0-7ebf-70f7-84de-79a9aaba3d2d","parentId":null,"rootId":null,"fromId":1553,"content":"没信了,估计给不起薪资,说再见见别人,感觉被耍了,啥都不懂,叫过去一通问,还拿本子记,然后说我现在的薪资可以了,别跳了","createdAt":"2024-06-13T16:21:27"},{"id":"01963df0-7ec4-728a-9340-3be44c28918e","parentId":null,"rootId":null,"fromId":2525,"content":"耍人玩呢，太过分了","createdAt":"2024-06-14T15:59:17"},{"id":"01963df0-7f0b-7019-afca-903cd55c2975","parentId":null,"rootId":null,"fromId":5911,"content":"boss是失信被执行人，重新组建团队是为了在三个月内重写外包留下的烂摊子代码，都失信被执行人了，很抠这不是很正常嘛，还有就是签的合同不是这家公司的，当然法人肯定不是这个boss的名字，哈哈","createdAt":"2024-06-17T11:21:34"},{"id":"01963df0-7f4f-7203-b7e4-ba8e7047dedc","parentId":null,"rootId":null,"fromId":21006,"content":"特别狗不要去。我去面了。等了半小时才有人来。一个女的啥都不懂就是过来骗方案。公司里边就两个人一个前端一个后端。水平不咋地。那个女的面试官啥都问还要你一一给他讲清楚不知道的以为给他上课来了。叽叽喳喳问了我将近2个小时。说白了公司没有成熟的技术人员，就是有问题了面试套方案。","createdAt":"2024-06-24T11:41:38"},{"id":"01963df0-7f93-7240-8cdb-08dc2a78e386","parentId":null,"rootId":null,"fromId":1372,"content":"能发下工资吗？今天刚面试了。","createdAt":"2024-07-07T19:01:23"},{"id":"01963df0-7fd8-73a7-9214-28483783b2c5","parentId":null,"rootId":null,"fromId":1372,"content":"刚面试了。绝对是套方案的。\n1、一个肥头大耳头发花白的男的给面的，一只在吹然后问你怎么实现。\n2、一个小不拉几的公司，看样子也给不起钱。\n傻逼公司一个。","createdAt":"2024-07-10T11:39:36"}]