[{"id":"01963de0-9b7b-7177-9aa9-e0dd712fcaac","parentId":null,"rootId":null,"fromId":1656,"content":"公司很大，加班是肯定要加班的","createdAt":"2023-03-23T15:34:37"},{"id":"01963de0-9bc4-71c0-b8ad-2f3bd6e862ec","parentId":null,"rootId":null,"fromId":838,"content":"这公司应该可以吧  我猜的","createdAt":"2023-03-23T18:18:17"},{"id":"01963de0-9c07-7103-8fba-0e19c438cc51","parentId":null,"rootId":null,"fromId":875,"content":"待遇不错，有同事在里面，月薪两万多，搞开发","createdAt":"2023-03-23T18:30:20"},{"id":"01963de0-9c4d-73a0-899c-9b21e7c1944f","parentId":null,"rootId":null,"fromId":886,"content":"互联网行业有不加班的？","createdAt":"2023-03-24T10:32:30"},{"id":"01963de0-9c91-7297-991d-71d1a8293c1e","parentId":null,"rootId":null,"fromId":2738,"content":"济南Jsp+Jquery SpringMVC +Jdbc 996 ，不如去北上广深Vue3  SpringCloud996","createdAt":"2023-03-24T15:20:50"},{"id":"01963de0-9cd8-727a-bc8a-a653e931f795","parentId":null,"rootId":null,"fromId":838,"content":"这公司是 jsp嘛","createdAt":"2023-04-04T06:36:11"},{"id":"01963de0-9d1e-7068-abf7-516b64d6aa10","parentId":null,"rootId":null,"fromId":5728,"content":"给的看起来不错，但是去了以后整天pua，说是不鼓励加班，但是你不加班领导就会找你，而且活多人少，去了就是加班的，基本上算下来一周至少加两个工作日的班，不在公司加班，也需要在家远程加班，尤其是终端研发中心，反正及其恶心，今时不同往日，那些之前的评论看看就行了，现在很多事都变了，毕竟做的市场太小，快要饱和了。想进军新领域，结果整天赔钱，员工每三个月就要没一次绩效，并且新领域部门的人没有年终奖。","createdAt":"2024-03-11T18:36:24"},{"id":"01963de0-9d64-71c1-be9b-1db8628651fc","parentId":null,"rootId":null,"fromId":6654,"content":"很赞同，研发参与回款考核，好的时候涨几十块，经常1000全部扣光。补充：没有年假但是研发初四就让来加班，有时候项目出差，普遍要到晚上九点，有时也会到 8 12 7 的程度，现在经费紧缺，一般不会招人，招人说明老员工走了。","createdAt":"2024-04-09T10:37:00"},{"id":"0197e953-0b58-70d1-90bd-1cd4db5d6b29","parentId":null,"rootId":null,"fromId":4002,"content":"公司电子硬件岗位怎么样呀","createdAt":"2025-07-08T17:17:03"}]