[{"id":"019b05ac-6be1-71b6-a3fe-d3ca8f547920","parentId":null,"rootId":null,"fromId":4137,"content":"还在里面继续干着？","createdAt":"2025-12-10T08:32:24"},{"id":"019b05b3-ab6b-72b1-8ebc-4275e7f9af5d","parentId":null,"rootId":null,"fromId":23959,"content":"跑了吗","createdAt":"2025-12-10T08:40:19"},{"id":"019b05d4-8efa-7166-8341-63828691bc66","parentId":null,"rootId":null,"fromId":22250,"content":"就坑刚出校门的呆萌大学生，久居象牙塔，让你们见识下社会主义的险恶","createdAt":"2025-12-10T09:16:14"},{"id":"019b06b0-c23f-7314-a928-5c46d09b2e63","parentId":null,"rootId":null,"fromId":270,"content":"跑了，准备维权","createdAt":"2025-12-10T13:16:46"},{"id":"019b06b2-08fe-7173-a08d-0bc202ab5db8","parentId":null,"rootId":null,"fromId":270,"content":"十几年的老油条都扛不住","createdAt":"2025-12-10T13:18:09"},{"id":"019b3487-2567-721d-9809-6a3c9919fc86","parentId":null,"rootId":null,"fromId":22105,"content":"我们以前合作过的一家公司，老板和他女朋友开的，有些小活都是给他们合作干的。\n他们有员工跳到我这边的，据他们说公司节奏非常快，氛围很压抑。无限压缩工期，今天分下去的任务就得让你做完，不管是不是新接手的。\n而且他们这种外包小公司，都是一次性接手n多个项目，就是要狠狠压缩工期才能把这多个项目干完。\n而且老板抠搜的，也不肯多招人，也不肯多加钱，就导致就有你们这些人被坑骗过去。\n给的工期都是正常拉满8小时都干不完的，必须要加班才能干完，超额给量","createdAt":"2025-12-19T10:53:50"},{"id":"019b3bfa-ae88-7280-9708-57b6a2e9aa25","parentId":null,"rootId":null,"fromId":270,"content":"确实如此","createdAt":"2025-12-20T21:37:23"},{"id":"019c2921-d2dd-7066-a429-c906860255f7","parentId":null,"rootId":null,"fromId":23975,"content":"老板纯恶心人的玩意，加班不说强制，但是早走了就恶心你，会给你增加工作量，别去傻逼公司","createdAt":"2026-02-04T22:50:08"}]