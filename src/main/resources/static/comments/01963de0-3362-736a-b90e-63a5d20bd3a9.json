[{"id":"01963de0-33d0-71b8-b98c-5d10e8c03d60","parentId":null,"rootId":null,"fromId":1656,"content":"要求挺高的，全栈，加班文化，有加班费","createdAt":"2023-03-09T09:08:16"},{"id":"01963de0-3415-7023-8af1-f3ee6ac26f8c","parentId":null,"rootId":null,"fromId":2543,"content":"看着公司不大，稳定不？","createdAt":"2023-03-09T10:55:18"},{"id":"01963de0-3459-731e-a79f-744de177477d","parentId":null,"rootId":null,"fromId":783,"content":"优点：虽然是伪国企，但好歹也是国企性质，福利待遇好，工资偏高\n缺点：全栈要求，导致公司的项目，前端做的不好，后端做的也不好。疯狂加班！！！付出与优点中的收益严重不成正比！！！\n公司很大，带来的问题就是很多伪国企的通病：牛马领导多，内卷严重，很多项目技术栈很落后。。。等等","createdAt":"2023-03-09T14:59:46"},{"id":"01963de0-349f-7253-b406-8267afa825b7","parentId":null,"rootId":null,"fromId":2495,"content":"福利好，工作量多，要求高。","createdAt":"2023-03-09T15:33:07"},{"id":"01963de0-34eb-726e-b531-560126231061","parentId":null,"rootId":null,"fromId":2613,"content":"破烂公司要求不少","createdAt":"2023-03-22T08:40:41"},{"id":"01963de0-3593-71cb-a4c3-abf28cbcfb85","parentId":null,"rootId":null,"fromId":21821,"content":"楼上可以详细说下吗？我也收到这个公司的面试邀请了","createdAt":"2025-02-08T14:59:12"},{"id":"01963de0-35d8-7152-b72b-0224efb1834c","parentId":null,"rootId":null,"fromId":1096,"content":"公司比较小，面试的时候HR及领导态度还可以，聊的不错。我要找项目经理岗位，HR在BOSS上问我软件实施能不能做，也有其它岗位可以面试聊聊，正好没事就去了。现在回头想想，应该是被HR刷业绩了。","createdAt":"2025-03-14T12:07:49"},{"id":"01963de0-3622-73dc-b9bb-ae2e3877423d","parentId":null,"rootId":null,"fromId":23008,"content":"这个公司怎么样啊？","createdAt":"2025-03-24T11:43:20"}]