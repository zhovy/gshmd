[{"id":"01963ddc-1ca0-7128-8dcf-a16001144a43","parentId":null,"rootId":null,"fromId":1559,"content":"给工商局打电话  一举报   一个准","createdAt":"2022-09-01T09:11:12"},{"id":"01963ddc-1ce5-7291-bc85-b658c36a7af8","parentId":null,"rootId":null,"fromId":193,"content":"是什么让你有勇气坚持下去的?","createdAt":"2022-09-01T15:30:41"},{"id":"01963ddc-1d2a-70d7-acf7-e5c2a439edd6","parentId":null,"rootId":null,"fromId":1401,"content":"太秀了，第一次见用支付宝发工资的","createdAt":"2022-09-03T23:04:45"},{"id":"01963ddc-1d6f-71fa-b29c-77035c3a1ed4","parentId":null,"rootId":null,"fromId":59,"content":"直接举报走一波啊","createdAt":"2022-09-08T09:15:12"},{"id":"01963ddc-1db5-729e-bfe4-4cef8276d607","parentId":null,"rootId":null,"fromId":2512,"content":"在这里工作压力真的很大，sb老板总是坚信着每个人工作都是有水分的，他必须让每一个人一直处在绷紧的状态来工作，就像要求美工一个月要做300个链接，美工每天都在为这300个链接努力，然而他还要求做的链接又细又精","createdAt":"2023-02-23T12:39:56"},{"id":"01963ddc-1df9-71bb-9bc8-12d064e9773c","parentId":null,"rootId":null,"fromId":2512,"content":"千万不要来，来了疯狂pua","createdAt":"2023-02-23T12:40:37"},{"id":"01963ddc-1e3e-7300-a760-1eee244f1aff","parentId":null,"rootId":null,"fromId":2512,"content":"超级喜欢找大学生，过来来了就给三千四千，然后一直干一直干,然后疯狂的pua人家，让人家多干活，少拿钱","createdAt":"2023-02-23T12:41:19"},{"id":"01963ddc-1e82-72bf-ad6c-d51e9942f1d4","parentId":null,"rootId":null,"fromId":2512,"content":"一月份的时候，让我们集体放假一整个月，然后扣掉全勤.然后一月份就不发工资了，真的是超级超级超级搞笑，而且年终奖也没有公司挣钱的时候不同甘.公司不卖钱的时候就一起共苦了","createdAt":"2023-02-23T12:42:57"},{"id":"01963ddc-1ec6-7121-afdb-01b07819faf6","parentId":null,"rootId":null,"fromId":2512,"content":"应届大学生擦亮眼睛，千万看好了，千万不要来，最近在疯狂招聘","createdAt":"2023-02-23T12:45:14"},{"id":"01963ddc-1f0d-7119-b4a8-9b7fbba49bd0","parentId":null,"rootId":null,"fromId":2512,"content":"这个老板超级喜欢把小肠，新来的每个员工他都会吐槽前面离职的员工，把每个人说的一文不值，他多么不容易，培养这么好，结果人家走了。公司里大部分人都认了他的脾气为了他好好干活，结果他闹来闹去的，一月份的时候他直接就不发工资，大家不用来，但是工作还要继续进行（他心里想的每个人24小时都必须为他服务）也就是1月份的时候大家没有工资还要为他工作。其中有一个人走了就是因为不发工资他还整天逼着人家出流程，人家之前可以为他尽职尽责的工作，即使工资低，也为了公司发展非常努力了，最后人家离职了给每一个人讲他后悔培养他，把他捧这么高，结果人家走了，以后带谁培训必须自己掏钱","createdAt":"2023-02-27T11:49:09"},{"id":"019762c5-487a-732a-8e53-0f3a2b4078c9","parentId":null,"rootId":null,"fromId":880,"content":"把小肠 是什么意思啊哈哈","createdAt":"2025-06-12T14:13:05"},{"id":"019762c5-ad38-71f1-9931-f731ad8629f2","parentId":null,"rootId":null,"fromId":880,"content":"现在别去了，他们人事 刷到面kpi","createdAt":"2025-06-12T14:13:31"}]