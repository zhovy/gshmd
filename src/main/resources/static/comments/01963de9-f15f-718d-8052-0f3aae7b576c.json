[{"id":"01963de9-f1c9-72f8-b2bc-e90adaa5a2f1","parentId":null,"rootId":null,"fromId":4140,"content":"除了有主营业务（烟草、电力、石油）的国企，双休不加班不出差，五险一金全额缴纳的私企，剩下都该避开","createdAt":"2023-12-04T10:44:30"},{"id":"01963de9-f212-732a-a7c1-53b8da9f26d6","parentId":null,"rootId":null,"fromId":6156,"content":"1、培训机构\n2、有试用期结束辞人案例的公司\n3、男的当老板女的当财务的夫妻店\n4、低于济南平均工资但实际业务都是北上广的，需要出差，工资浮动很大全靠出差补贴\n5、外包公司或者主要是外包业务的公司\n6、老板是泰安人的小公司","createdAt":"2023-12-06T08:45:47"},{"id":"01963de9-f20e-7347-a755-50343e437c9d","parentId":null,"rootId":null,"fromId":3716,"content":"你特码有几个这样的公司, 照你这标准那大部分人都得失业","createdAt":"2023-12-06T09:39:40"},{"id":"01963de9-f257-7161-937e-4460e4ad52b2","parentId":null,"rootId":null,"fromId":3716,"content":"第6条说的太精辟了. 泰安小公司老板死抠死抠的","createdAt":"2023-12-06T09:40:52"},{"id":"01963de9-f260-709e-87ff-3e788390c6c6","parentId":null,"rootId":null,"fromId":654,"content":"我很同意 ，不是地域黑，但真的作为老板的层面真的很抠。","createdAt":"2023-12-06T11:25:41"},{"id":"01963de9-f264-728e-a4bd-4eaad03714c3","parentId":null,"rootId":null,"fromId":3395,"content":"1、15号后发薪，很固定\n2、双休\n3、同楼主\n4、有餐补\n5、每天摸鱼，真正工作时间不超过1.5h\n\n所以这种属于该避开的么。。。。","createdAt":"2023-12-27T09:30:17"}]