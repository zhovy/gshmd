[{"id":"019afc00-114b-72ea-84a1-bc81af6783e4","parentId":null,"rootId":null,"fromId":25708,"content":"在哪都一个样","createdAt":"2025-12-08T11:27:34"},{"id":"019afc09-1815-7058-a403-de58c1c12049","parentId":null,"rootId":null,"fromId":24398,"content":"只要是打工就没有恶心的，只是想换个地方换个环境罢了","createdAt":"2025-12-08T11:37:25"},{"id":"019afc10-ff12-7146-b21e-78c902715acd","parentId":null,"rootId":null,"fromId":25953,"content":"不好找，环境变了，你试试就知道了","createdAt":"2025-12-08T11:46:03"},{"id":"019afc93-4c40-73c5-a332-e0b1495ab63a","parentId":null,"rootId":null,"fromId":27118,"content":"凑合干吧，这世界不一样了","createdAt":"2025-12-08T14:08:23"},{"id":"019afcb5-74d2-7251-b73e-298a658c7425","parentId":null,"rootId":null,"fromId":557,"content":"凑合不下去了，兄弟，太恶心了。","createdAt":"2025-12-08T14:45:41"},{"id":"019afcd7-b47a-7379-b4dd-c38cc958f035","parentId":null,"rootId":null,"fromId":23078,"content":"这么难顶吗现在公司","createdAt":"2025-12-08T15:23:06"},{"id":"019b0122-19c6-7312-bd52-56e464cdf039","parentId":null,"rootId":null,"fromId":27118,"content":"往南去，我离职的同事去南边找的工作，那边环境好，不像北边职场这么恶心","createdAt":"2025-12-09T11:22:50"},{"id":"019b0124-7853-725f-b8b6-631c7ee520aa","parentId":null,"rootId":null,"fromId":27118,"content":"像我们公司老板已经不装了，只不过大家都站着，要是都跪了，那就顶不住了，经济只是诱因，人始终是人，畜生的玩意不会装一辈子人","createdAt":"2025-12-09T11:25:25"},{"id":"019b024b-a1b6-70a5-9c88-c2a85a1facec","parentId":null,"rootId":null,"fromId":24428,"content":"经济只是诱因，人始终是人----说到点上了。同样是赚钱，有的可以参股，有的万年不涨薪，同样是倒闭，有的可以退卡退费，有的直接跑路。环境是一样的，只是人不同","createdAt":"2025-12-09T16:47:49"}]