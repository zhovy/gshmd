[{"id":"01963df4-c0d2-72ee-b7f4-0c2e4b84670f","parentId":null,"rootId":null,"fromId":2408,"content":"我求求你不要来打工了和我们卷了，去从政吧","createdAt":"2024-11-16T10:22:15"},{"id":"01963df4-c11b-7250-92d7-9b2bd6453f9e","parentId":null,"rootId":null,"fromId":330,"content":"去别的地级市走人才引进 济南这边人才引进都是博士","createdAt":"2024-11-16T10:53:42"},{"id":"01963df4-c163-7085-9583-61b464591214","parentId":null,"rootId":null,"fromId":875,"content":"契税方面，将现行享受1%低税率优惠的面积标准由90平方米提高到140平方米，并明确北京、上海、广州、深圳4个城市可以与其他地区统一适用家庭第二套住房契税优惠政策。调整后，在全国范围内，对个人购买家庭唯一住房和家庭第二套住房，只要面积不超过140平方米的，统一按1%的税率缴纳契税。","createdAt":"2024-11-16T11:15:09"},{"id":"01963df4-c116-7254-9e9d-12a9a2785f6b","parentId":null,"rootId":null,"fromId":1720,"content":"没那实力啊，现在考公卷麻了，我又没加入组织QAQ","createdAt":"2024-11-16T11:31:11"},{"id":"01963df4-c15f-71a9-b959-b7f0d9352782","parentId":null,"rootId":null,"fromId":1720,"content":"还是想尽量在济南QAQ","createdAt":"2024-11-16T11:31:47"},{"id":"01963df4-c1a7-73d2-9677-2b092459f42c","parentId":null,"rootId":null,"fromId":1720,"content":"可不敢买房子….","createdAt":"2024-11-16T11:32:10"},{"id":"01963df4-c1ab-70d7-99a8-102a0ed9104b","parentId":null,"rootId":null,"fromId":1398,"content":"走校招","createdAt":"2024-11-16T12:01:11"},{"id":"01963df4-c1ef-71d5-b4e0-195b2647e59b","parentId":null,"rootId":null,"fromId":1720,"content":"大佬请问校招研发岗之类的不怎么看实习吗？我之前看校招我们专业对口职业就是老师?我都不知道迪子能不能捞我（没对口职业）…..","createdAt":"2024-11-16T12:39:58"},{"id":"01963df4-c1fc-7341-a936-9de2f912a51d","parentId":null,"rootId":null,"fromId":5792,"content":"你可比我们强太多了，没必要问我们出路，大不了去后端岗呗，我就认识一个南开学硕去京东后端的，你家里有关系嘛，没关系走选调死路一条，把你弄到乡镇七八年也不调你，你能接受吗","createdAt":"2024-11-16T12:47:10"},{"id":"01963df4-c244-70ee-8203-6c8e0f53b7e0","parentId":null,"rootId":null,"fromId":5792,"content":"与其想着多挣，不如想着少花，至少是少花不该花的钱，现在一套房子浮亏一百多万的多的是，交往不慎被骗的更是多的是","createdAt":"2024-11-16T12:58:09"},{"id":"01963df4-c240-72c0-87a9-eaad67880064","parentId":null,"rootId":null,"fromId":1720,"content":"是啊，选调生竞争大不说还很吃关系（而且我不是dy大概率也考不了选调），我倒是想去后端，可是非科班出身转不了啊（当然也没有那个实力就是了）","createdAt":"2024-11-16T14:04:32"},{"id":"01963df4-c289-7256-98b1-6c30e0d637d8","parentId":null,"rootId":null,"fromId":1720,"content":"我本来也压力没那么大......家里有人突然欠了小贷很大一笔钱，家长都快急死了，我也不能就地躺平得过且过了......更何况都读了这么多年书了，总不能那么心安理得的啃老","createdAt":"2024-11-16T14:07:40"},{"id":"01963df4-c28e-733c-96c7-7668a8f236f3","parentId":null,"rootId":null,"fromId":5792,"content":"优先考虑银行吧，你这概率统计那不是金融行业最喜欢的嘛，做个精算模型啥的，还有编码能力","createdAt":"2024-11-16T14:46:23"},{"id":"01963df4-c2d1-71cf-9543-dc10ae98e306","parentId":null,"rootId":null,"fromId":5792,"content":"你又是本硕985，哪怕去不成四大行，去个恒丰，浙商，还是可以的吧","createdAt":"2024-11-16T14:50:20"},{"id":"01963df4-c2d6-72c5-879d-d726b268ebda","parentId":null,"rootId":null,"fromId":1720,"content":"也不容易啊，我春招秋招去看大多数都是招不限专业的管培生，进去练个几个月再定岗的，到时候定个柜员就凉凉了。给钱多号称要精算模型的都是一些不知名的私募基金，感觉今天入职明天就跑路了。而且银行不止看学历，也看dy身份和校园活动的......\n然后我真的实名制劝退我们这专业，和金融工程一样，考试难学的东西还没用，除非读博不然真的就一点用都没有，我师兄师姐就没有去银行的，基本上都是转机器学习或者大模型走的，人家去银行的都是偏经济向的，毕业论文写个实证分析就完事，小论文好发，奖学金能拿，工作导师还能安排，真就是人生赢家。前几年行情好还有能混去中泰证券的，这几年券商降薪，要是导师没门路真不容易进去。奉劝以后的师弟师妹真的要慎重考虑概率统计方向的导师，现在经济环境这么差真没那么多试错的机会。","createdAt":"2024-11-16T15:21:35"},{"id":"01963df4-c2da-7240-97da-1a990f858130","parentId":null,"rootId":null,"fromId":5792,"content":"要是真想转码，那就看你能不能拉下脸，去私企或者干外包了，等有两年工作经验，再跳槽去中厂，再干两年去大厂，首先你学历不是问题，缺的是工作经验，等工作经验补齐了，只要能过大厂面试，基本没问题了","createdAt":"2024-11-16T15:29:54"},{"id":"01963df4-c31e-72b1-83c2-bfb553d6c9ed","parentId":null,"rootId":null,"fromId":21427,"content":"学历是没问题 但是现在大环境不行 有经验的都找不到工作  而且快年底了 基本没有什么岗位了","createdAt":"2024-11-16T15:49:40"},{"id":"01963df4-c362-72ae-b921-b0a06538182f","parentId":null,"rootId":null,"fromId":21427,"content":"如果欠了很大一笔钱  那也不是一时半会能还完的 我还是觉得贴主 静下心来 想想以后的发展 是接着深造 还是 步入社会","createdAt":"2024-11-16T15:56:57"},{"id":"01963df4-c3a7-725d-b888-25f071841d08","parentId":null,"rootId":null,"fromId":5913,"content":"华为db怕是去不了","createdAt":"2024-11-16T15:58:02"},{"id":"01963df4-c1f4-707f-ae70-22ec298f5cef","parentId":null,"rootId":null,"fromId":5913,"content":"校招看你项目","createdAt":"2024-11-16T15:59:33"},{"id":"01963df4-c3f5-701e-b6e3-37df8a7d67e0","parentId":null,"rootId":null,"fromId":5913,"content":"你去转码怕是在济南也卷不过那些单二硕科班带项目的，还是试试银行运营商吧","createdAt":"2024-11-16T16:02:02"},{"id":"01963df4-c3f9-709a-9a7b-951a2e72b565","parentId":null,"rootId":null,"fromId":5913,"content":"现在学历高东西会的不多也不好找","createdAt":"2024-11-16T16:02:52"},{"id":"01963df4-c3fe-712b-9a5e-e3f82e0a549f","parentId":null,"rootId":null,"fromId":5913,"content":"可以明年去山大的线下招聘会碰碰运气","createdAt":"2024-11-16T16:03:22"},{"id":"01963df4-c402-71cf-907e-ec9da87c5ff3","parentId":null,"rootId":null,"fromId":5913,"content":"今年自学Java的那些研究生找的很差就北邮的也好不了哪去","createdAt":"2024-11-16T16:05:33"},{"id":"01963df4-c406-714e-b540-c8eba2f4ee75","parentId":null,"rootId":null,"fromId":5913,"content":"没准明年就好了呢这也不好说","createdAt":"2024-11-16T16:05:52"},{"id":"01963df4-c40a-70a1-9b8c-21bb45ebb1d7","parentId":null,"rootId":null,"fromId":21427,"content":"希望明年环境变好点吧 现在待得公司 从双休变单休，还变相降薪","createdAt":"2024-11-16T16:08:27"},{"id":"01963df4-c40f-7383-b325-243ea007d7d5","parentId":null,"rootId":null,"fromId":21948,"content":"楼上怕是同事吧","createdAt":"2024-11-16T16:19:44"},{"id":"01963df4-c1f8-712f-a89a-d6521b0c4ff1","parentId":null,"rootId":null,"fromId":1398,"content":"校招直接面国企，或者当辅导员","createdAt":"2024-11-16T16:45:27"},{"id":"01963df4-c413-718e-84cf-ef9915217dfc","parentId":null,"rootId":null,"fromId":1720,"content":"我也担心非科班出身很难转码qaq，明年除非有奇迹不然大概率会比今年还差......","createdAt":"2024-11-16T17:35:31"},{"id":"01963df4-c417-70d2-9bdd-d2160d331e56","parentId":null,"rootId":null,"fromId":1720,"content":"有无浪潮ai的前辈说说浪潮ai实习生干啥，面试严吗，我临时抱佛脚抱上半个月能混进去学点东西吗qaq","createdAt":"2024-11-16T17:37:52"},{"id":"01963df4-c45b-7292-a238-f167ecf19c57","parentId":null,"rootId":null,"fromId":5792,"content":"如果你想去了解具体情况，你去这个论坛是找错路了，这里大部分都是中低端码农，还有些根本就是喷子，你应该往智联，BOSS去问问，跟这些有啥好交流的，我知道的山科应届硕士，去青岛移动，给的11K，也有个济南的双非硕士，去的槐荫某私企，也是11K，你跟臭棋篓子下棋，那不是越下越臭","createdAt":"2024-11-16T19:24:35"},{"id":"01963df4-c4a0-7385-af29-9ae6234de4b5","parentId":null,"rootId":null,"fromId":5792,"content":"就那个QQ群里，一群人碰上问题，除了骂街啥都不会，解决问题的办法是一点不会想的，考研嫌累，考公嫌卷，学新技术说学了也用不上，去外地说有负担，出国打工说外语难学，那你到底想干啥","createdAt":"2024-11-16T19:32:33"},{"id":"01963df4-c4e3-70ff-8422-0deec721c400","parentId":null,"rootId":null,"fromId":875,"content":"学习在济南如果才能当领导，毕竟在济南当领导比较爽，啥都不懂，只要会人情世故就行","createdAt":"2024-11-16T21:32:35"},{"id":"01963df4-c4e9-7163-ab06-9dee26c8d2c3","parentId":null,"rootId":null,"fromId":875,"content":"转行产品经理，项目经理，销售经理，与人打交道多的岗位，才能升的快，在济南埋头写代码，谁看的见，写10年代码就失业退休了","createdAt":"2024-11-16T21:49:30"},{"id":"01963df4-c4ee-731a-9c74-c7f88899fae0","parentId":null,"rootId":null,"fromId":5792,"content":"那倒是行动起来啊，最起码得学学人际关系学，遇事会来事吧，嘴是不停的，事是不干的","createdAt":"2024-11-16T22:21:35"},{"id":"01963df4-c4f3-7007-ae48-100a88dddf2a","parentId":null,"rootId":null,"fromId":3785,"content":"我现在看见统计学和机械的就头大，全是搞算法，实际啥也没搞出来，一点实用编程知识也不学","createdAt":"2024-11-18T08:23:31"},{"id":"01963df4-c537-707b-95d4-35125c6a48c1","parentId":null,"rootId":null,"fromId":4367,"content":"那是你所处的环境档次太低","createdAt":"2024-11-18T11:43:01"},{"id":"01963df4-c53b-7234-8f2f-daedc5d83473","parentId":null,"rootId":null,"fromId":5913,"content":"不知道啥环境档次才算高","createdAt":"2024-11-18T12:03:34"},{"id":"01963df4-c540-713d-8ec9-5fe79f94ca0e","parentId":null,"rootId":null,"fromId":1933,"content":"除非校招能进大厂，不然优先考编，其次读博","createdAt":"2024-11-18T13:38:25"},{"id":"01963df4-c58f-73c3-ab9a-56c7f7825c9e","parentId":null,"rootId":null,"fromId":5913,"content":"济南哪有大厂","createdAt":"2024-11-18T14:39:46"},{"id":"01963df4-c593-7165-8afd-4fc72d151ff5","parentId":null,"rootId":null,"fromId":3446,"content":"想转码建议优先投大国企的专业子公司，985本硕专业没问题的话应该稳进的，国企不看实习也不太看项目，主要看学历和稳定，技术差不多就行，国企里除了少数几个人，走技术是没有前途的","createdAt":"2024-11-19T09:12:39"},{"id":"01963df4-c5df-7208-aea2-a5b38857653f","parentId":null,"rootId":null,"fromId":5913,"content":"他专业明显有问题","createdAt":"2024-11-19T10:36:01"},{"id":"01963df4-c5e3-712b-a9dc-ad2799d431a4","parentId":null,"rootId":null,"fromId":875,"content":"在济南搞技术不行的","createdAt":"2024-11-21T07:12:05"}]