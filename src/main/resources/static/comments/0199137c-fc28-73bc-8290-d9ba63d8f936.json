[{"id":"0199140c-e333-72c2-b5a7-3901d312e930","parentId":null,"rootId":null,"fromId":3450,"content":"被高速除名前还是相当不错的，除名后就不知道了","createdAt":"2025-09-04T17:26:52"},{"id":"019ae477-9278-7087-b43e-e2076f1ab337","parentId":null,"rootId":null,"fromId":414,"content":"满易物流也裁员吗，好像高速底下的子公司极少裁员，之前待过旗帜，很多同事在那待了N多年了都","createdAt":"2025-12-03T21:47:12"},{"id":"019bcee4-314d-7149-8565-eeb43b77bba1","parentId":null,"rootId":null,"fromId":22944,"content":"总体不错，听说待了很多年的有许多，瘦死骆驼比马大，前边降薪后边听说没多长时间部分又给涨回去了，这种大环境下相当不错了～","createdAt":"2026-01-18T10:16:59"},{"id":"019bd159-4d39-725f-86d0-bc443ba91f41","parentId":null,"rootId":null,"fromId":3450,"content":"你知道旗帜被裁的不剩几个人了吗","createdAt":"2026-01-18T21:44:09"},{"id":"019bdab0-67c1-71eb-86e9-3ab24b7ee55b","parentId":null,"rootId":null,"fromId":27572,"content":"面过了吗","createdAt":"2026-01-20T17:15:52"},{"id":"019bdaec-e591-71c8-ac6d-4b503a5a30cb","parentId":null,"rootId":null,"fromId":22944,"content":"没有，要求还挺高，但是感觉平台和技术人员的稳定性应该还挺好的，其他公司也面了很多打听了很多，现在都是什么乱七八遭的事儿都有，相对这个来说还挺好，但是该说不说，现在找工作是真挺难啊~","createdAt":"2026-01-20T18:21:57"}]