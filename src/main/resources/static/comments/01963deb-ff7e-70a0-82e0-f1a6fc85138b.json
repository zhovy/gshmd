[{"id":"01963deb-ffe2-72d8-977e-e4b388662f36","parentId":null,"rootId":null,"fromId":2408,"content":"红利没了，经济结构性差，没个十年八年缓不过来，普通人要早做打算","createdAt":"2024-03-04T21:28:26"},{"id":"01963dec-002f-7275-8953-78e84b2db731","parentId":null,"rootId":null,"fromId":1398,"content":"去年还好一点点，仅仅只是一点点?","createdAt":"2024-03-04T21:51:11"},{"id":"01963dec-0077-736d-a499-79ba1cd1da2a","parentId":null,"rootId":null,"fromId":875,"content":"资本不在济南，济南一年也没几个公司能上市，没人投钱，工资自然低，岗位少，外面北京杭州每年上市公司一大把，有人愿意投钱，股东赚上市钱，员工拿股东高薪，双赢","createdAt":"2024-03-05T08:25:39"},{"id":"01963dec-00bc-72a1-85c1-05df7c01f623","parentId":null,"rootId":null,"fromId":2658,"content":"经济不行了 房地产都啥样了","createdAt":"2024-03-05T09:03:09"},{"id":"01963dec-0027-7259-ab24-a469080ccf10","parentId":null,"rootId":null,"fromId":2367,"content":"啊，这么长惨淡的时间么！！！","createdAt":"2024-03-05T09:12:08"},{"id":"01963dec-014a-725f-9634-bcfcf3846f38","parentId":null,"rootId":null,"fromId":2367,"content":"见解独到","createdAt":"2024-03-05T09:52:43"},{"id":"01963dec-0153-7125-b63a-c5c0cbfc3b4d","parentId":null,"rootId":null,"fromId":3801,"content":"工资是供需关系影响的，我现在可以10k招一个3年的，凭什么要给13K，甚至可以压的更低，而且大部分稍微优质点的公司这两年的离职率很低，放出一个岗位，基本一天能收几百个简历，HR怎么筛，只能先卡学历了，普本现在竞争力不大，专科基本没竞争力了，比如城商联盟，外包都要求本科。很多投标类的项目，提供的人员也要求本科以上，当然这种可以造假，只要甲方不较真不查都好说，但是大部分公司都不愿意承担这种风险了。","createdAt":"2024-03-05T10:37:20"},{"id":"01963dec-01e5-71d9-9db5-fc8046cb4148","parentId":null,"rootId":null,"fromId":1049,"content":"很有道理","createdAt":"2024-03-05T13:28:50"},{"id":"01963dec-002b-707c-8304-92b231d92b37","parentId":null,"rootId":null,"fromId":2408,"content":"日本失去的30年，中国很有可能步入后尘，有过之而不及","createdAt":"2024-03-05T13:29:57"},{"id":"01963dec-01ea-736a-b4bc-c294ea048376","parentId":null,"rootId":null,"fromId":1656,"content":"就是人太多，僧多粥少","createdAt":"2024-03-05T14:03:03"},{"id":"01963dec-014e-7162-a26b-8ba8fa812880","parentId":null,"rootId":null,"fromId":3705,"content":"同感","createdAt":"2024-03-05T15:34:07"}]