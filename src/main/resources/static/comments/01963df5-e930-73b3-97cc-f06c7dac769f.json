[{"id":"01963df5-e994-714e-8271-69d971a0bb63","parentId":null,"rootId":null,"fromId":5876,"content":"我bob说了五年能拿50W","createdAt":"2024-12-30T17:04:59"},{"id":"01963df5-e9d9-72a2-b19a-68f1f5ed0599","parentId":null,"rootId":null,"fromId":701,"content":"看你想要多少 和 对应公司能给你多少， 同是五年程序员  差别比人和狗都大。有的五年 年薪40到60w 有的五年 年薪10w都费劲","createdAt":"2024-12-30T17:05:49"},{"id":"01963df5-ea73-7224-840c-73da3829a841","parentId":null,"rootId":null,"fromId":7425,"content":"你说的这些我都会","createdAt":"2024-12-30T17:12:33"},{"id":"01963df5-ea78-7268-8eaa-60059060f723","parentId":null,"rootId":null,"fromId":7425,"content":"我是开发平台的，这几个平常工作就做","createdAt":"2024-12-30T17:13:52"},{"id":"01963df5-ea7c-720f-a20b-48db39b4b5c2","parentId":null,"rootId":null,"fromId":6344,"content":"别说你会啥，先说啥学历，你要是给别人打工这就决定你上限","createdAt":"2024-12-30T17:38:52"},{"id":"01963df5-eac6-700c-9a87-4c12af2e8ab9","parentId":null,"rootId":null,"fromId":7425,"content":"公立双非本科","createdAt":"2024-12-30T18:13:43"},{"id":"01963df5-eaca-721b-bc52-772299a380df","parentId":null,"rootId":null,"fromId":875,"content":"你给公司创收的价值，除3差不多就是你能拿到的工资","createdAt":"2024-12-30T19:16:23"},{"id":"01963df5-eb19-7079-8674-e377ef0a6c94","parentId":null,"rootId":null,"fromId":403,"content":"你罗列的这些如果都精通的话，在济南年薪也不会超过20W（非996或外包情况下）。在济南纯靠做技术拿高薪是不可能的，薪水的多少取决于你的职位高低，一个程序员拿20W是天花板了。","createdAt":"2024-12-31T08:52:24"},{"id":"01963df5-eb0f-724f-9db2-5adb0c503bfa","parentId":null,"rootId":null,"fromId":3341,"content":"你不是做软件的","createdAt":"2024-12-31T09:29:32"},{"id":"01963df5-eb65-733e-944a-078b8beb43f6","parentId":null,"rootId":null,"fromId":3341,"content":"别说太满，只是少 不是一点没有","createdAt":"2024-12-31T09:30:13"},{"id":"01963df5-ec00-722e-bd44-f35502ef265c","parentId":null,"rootId":null,"fromId":3341,"content":"上不去","createdAt":"2024-12-31T09:30:25"},{"id":"01963df5-ec05-7328-85a4-758b19f2e34b","parentId":null,"rootId":null,"fromId":3341,"content":"你就是党国需要的全沾开发工程师","createdAt":"2024-12-31T09:31:02"},{"id":"01963df5-ec49-727b-8cd8-d95dc478bc02","parentId":null,"rootId":null,"fromId":2198,"content":"楼主是开发什么平台的，低代码开发平台 这种吗","createdAt":"2024-12-31T10:35:27"},{"id":"01963df5-ea1e-73b7-9c16-4466fff0acc7","parentId":null,"rootId":null,"fromId":3319,"content":"济南 哪来的 5年50-60万？","createdAt":"2024-12-31T10:37:49"},{"id":"01963df5-ea23-712d-8208-c5156d6006b3","parentId":null,"rootId":null,"fromId":701,"content":"只是想说 五年经验 技术好和技术不好差别大。 我们公司还真有接近40的开发  40-60确实夸张点（只是通过收入的差别体现 五年的工作经验之间技术的差别）","createdAt":"2024-12-31T11:15:18"},{"id":"01963df5-eb69-72ce-8119-acbc658d9cb4","parentId":null,"rootId":null,"fromId":403,"content":"当然不能说太满，就像一个人买了彩票问我能中大奖吗，我肯定会说“不能”。光看顶尖的那几个人没用，人家提问的本意也不是关注那个别几个人。","createdAt":"2024-12-31T13:12:56"},{"id":"01963df5-ec8e-72f1-a928-d005b1cee29a","parentId":null,"rootId":null,"fromId":7425,"content":"差不多吧，不过不是严格意义上的低代码，毕竟没做过代码生成器或者表单编辑器之类的东西。只是像类似消息服务、工作流服务、写一些工具类、注解、starter之类的","createdAt":"2024-12-31T16:30:57"},{"id":"01963df5-eb6e-710c-9e54-95b890c02364","parentId":null,"rootId":null,"fromId":7425,"content":"我现在只有12W左右，已经维持了三年了，我嫌少啊，不给我涨工资，就想听听兄弟们的评价，到底值不值得再高一些","createdAt":"2024-12-31T16:33:04"},{"id":"01963df5-eb13-72ba-a9cb-57a60c6da942","parentId":null,"rootId":null,"fromId":7425,"content":"照你这说法，那我得上百万了，毕竟我是做底层的，整个部门的项目都有我的份","createdAt":"2024-12-31T16:34:07"},{"id":"01963df5-ea27-734a-aa76-26c76ea5e5e6","parentId":null,"rootId":null,"fromId":21053,"content":"哪个公司，你说说","createdAt":"2024-12-31T17:00:04"},{"id":"01963df5-ec9b-7257-96e3-402f744b2773","parentId":null,"rootId":null,"fromId":3671,"content":"不知道，感觉挺牛逼的，但是收入跟技术关系不大，要看企业的需求","createdAt":"2025-01-01T21:22:12"},{"id":"01963df5-ece0-73fa-8552-152ab9a5aba7","parentId":null,"rootId":null,"fromId":1401,"content":"绝大部分人济南8-15k左右","createdAt":"2025-01-02T08:36:55"},{"id":"01963df5-eb72-721d-9980-3192b3744902","parentId":null,"rootId":null,"fromId":1049,"content":"不是哥们你懂这么多才12W??你是认真的？","createdAt":"2025-01-02T09:12:36"},{"id":"01963df5-ec92-7279-ae4e-fdc01e7f8c87","parentId":null,"rootId":null,"fromId":2198,"content":"看起来是类似于开发脚手架的平台。楼主是公司内部使用，还是公司的主营业务就是做这套平台的呢。","createdAt":"2025-01-02T09:41:41"},{"id":"01963df5-ed26-73c8-b33b-b3e5fe235420","parentId":null,"rootId":null,"fromId":3263,"content":"只能说下限是12k，上限就有太多因素了，包括公司是否有钱，职位是否匹配，面试临场发挥，个人技术能力。。。其实业务属性越低工资涨的约慢。阿里的业务部门升职比中间件部门快，还是要看给公司创造的价值。","createdAt":"2025-01-02T11:34:37"},{"id":"01963df5-ec97-70cf-90bc-8373e3b871aa","parentId":null,"rootId":null,"fromId":7425,"content":"公司内部使用，支撑公司业务的","createdAt":"2025-01-02T15:52:27"},{"id":"01963df5-ed6a-7125-ab4d-bf0f2585993a","parentId":null,"rootId":null,"fromId":3892,"content":"哥，你是在浪潮国际干产品或平台开发吗？","createdAt":"2025-01-02T16:49:00"},{"id":"01963df5-edb0-7318-acda-710054a4c3ef","parentId":null,"rootId":null,"fromId":1049,"content":"小黑子","createdAt":"2025-01-03T09:06:56"},{"id":"01963df5-edb4-7052-9a8e-b4a3228cecb4","parentId":null,"rootId":null,"fromId":7425,"content":"不是浪潮，在某1000人公司","createdAt":"2025-01-03T16:39:41"},{"id":"01963df5-edb9-7339-a059-2d933cdcffa5","parentId":null,"rootId":null,"fromId":22565,"content":"某什么某，直接说名字。","createdAt":"2025-01-03T16:55:18"},{"id":"01963df5-edbd-73ff-8b76-b63e736376a8","parentId":null,"rootId":null,"fromId":2366,"content":"13-15吧","createdAt":"2025-01-05T22:26:40"}]