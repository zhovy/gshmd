[{"id":"01963df4-2759-70b5-9126-cf72d340075b","parentId":null,"rootId":null,"fromId":5913,"content":"电车就是一坨屎","createdAt":"2024-10-26T10:36:56"},{"id":"01963df4-279d-70ca-bc01-36dc822f5cde","parentId":null,"rootId":null,"fromId":21948,"content":"看使用程度，电车省油，油车省电      买了混动有续航焦虑，买了电车长途有续航焦虑     一年到头开的少油车   开的多电车   自行斟酌","createdAt":"2024-10-26T10:39:12"},{"id":"01963df4-27e0-73a7-8ce6-ffb2ae2f834d","parentId":null,"rootId":null,"fromId":880,"content":"哈哈哈哈哈哈哈 电车省油  油车省电，和哈哈哈哈哈哈哈哈哈","createdAt":"2024-10-26T10:59:05"},{"id":"01963df4-27f5-73ff-92e3-c24e9d6f3258","parentId":null,"rootId":null,"fromId":875,"content":"不经常开买油车放着吃灰，市区经常开买电车，经常跑远途买混合动力，顺便说一下买小米SU7电车不错，好看","createdAt":"2024-10-26T12:55:33"},{"id":"01963df4-2838-72d0-98e9-42a4e8b54a6a","parentId":null,"rootId":null,"fromId":1517,"content":"油车有啥推荐的嘛？","createdAt":"2024-10-26T15:54:13"},{"id":"01963df4-287d-7087-b8a0-885367ec6362","parentId":null,"rootId":null,"fromId":875,"content":"上懂车帝上看，哪个卖的好，买哪个","createdAt":"2024-10-26T16:33:02"},{"id":"01963df4-2882-717a-b24c-30cde9a3f3ee","parentId":null,"rootId":null,"fromId":2408,"content":"我的话，选天籁，迈锐宝","createdAt":"2024-10-26T18:04:53"},{"id":"01963df4-28c6-7367-b06e-1c83a9822eab","parentId":null,"rootId":null,"fromId":3341,"content":"很简单 开的少油车 开得多电车 开长途多混动","createdAt":"2024-10-28T09:27:06"},{"id":"01963df4-2909-73c9-822a-0a04fb7f2e36","parentId":null,"rootId":null,"fromId":561,"content":"我建议：想省油，买电车；想省电，买油车；想省时间，买电动自行车；想省钱，买俩馒头吃。","createdAt":"2024-10-28T09:30:01"},{"id":"01963df4-294c-734d-aee9-7572cb70f73d","parentId":null,"rootId":null,"fromId":561,"content":"油车历史比较久了，针对油车我再补充几点：从个人需求出发来说，追求性能买卡罗拉，喜欢动力买轩逸，想省油买纳智捷，想保值买众泰，华晨，力帆，有越野需求买汉兰达，要大空间买昂克赛拉。","createdAt":"2024-10-28T09:37:03"},{"id":"01963df4-2951-7033-90c2-4c657d65c3c7","parentId":null,"rootId":null,"fromId":5790,"content":"中肯的！","createdAt":"2024-10-28T10:55:03"},{"id":"01963df4-299c-720b-a54a-94daefb862a3","parentId":null,"rootId":null,"fromId":2926,"content":"1.充电方便 2.通勤远 3.长途少  3条都满足就买电车 个人觉得10w块钱电车最划算 别买太贵的 否则买油车","createdAt":"2024-10-28T16:49:59"},{"id":"01963df4-29e4-708d-9588-3d8e7fd792d6","parentId":null,"rootId":null,"fromId":2926,"content":"放宽到15w内 可选择性还是挺多的","createdAt":"2024-10-29T09:11:07"},{"id":"01963df4-29e9-730e-be83-58beaabada93","parentId":null,"rootId":null,"fromId":22141,"content":"15w当首付，换个舒服点的车，别委屈自己","createdAt":"2024-10-29T09:22:47"},{"id":"01963df4-2a33-7192-b6b1-488a72d83f73","parentId":null,"rootId":null,"fromId":59,"content":"城区通勤电车，一年两桶油的油车就行，电车油车省不省钱在公里数多的时候才能体现出来，而且油车技术更成熟，电车迭代太快，而且电池有日历寿命，所以我买了油车","createdAt":"2024-10-31T17:36:07"},{"id":"01963df4-2a79-735f-9d5e-6eaf7023ae02","parentId":null,"rootId":null,"fromId":21642,"content":"如果家里有多余的车而且充电方便就买个电车，唯一一辆的话还是买个油车吧，今年可能会是买油车最便宜的一年","createdAt":"2024-11-01T11:45:52"},{"id":"01963df4-27e4-724c-9eda-773b96f4ddc6","parentId":null,"rootId":null,"fromId":2246,"content":"为啥混动会担心续航啊","createdAt":"2024-11-26T11:16:13"},{"id":"01963df4-27e9-7345-bf0f-8b53a6411cd9","parentId":null,"rootId":null,"fromId":6091,"content":"因为混动用电跑的近","createdAt":"2024-11-26T11:16:39"},{"id":"01963df4-27ed-71c8-83b9-6979596b970c","parentId":null,"rootId":null,"fromId":2104,"content":"这边建议不买省钱","createdAt":"2024-11-26T11:43:51"},{"id":"01963df4-27f1-7392-9f54-7fb7c1aa816d","parentId":null,"rootId":null,"fromId":6091,"content":"确实，不买省钱","createdAt":"2024-11-26T13:17:17"},{"id":"01963df4-2ac0-71dc-9610-2dcd49ae26ba","parentId":null,"rootId":null,"fromId":1607,"content":"混动的保险挺贵的，可以去咨询一下，有的保险公司不给保都","createdAt":"2024-11-26T13:48:57"}]