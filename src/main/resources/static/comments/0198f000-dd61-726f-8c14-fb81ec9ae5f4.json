[{"id":"0198f04c-2b70-73e0-b9f6-409db02a74f5","parentId":null,"rootId":null,"fromId":26104,"content":"能签正式的还是可以的","createdAt":"2025-08-28T18:49:40"},{"id":"0198f0e9-38c0-72db-a416-6fd31dfe9a94","parentId":null,"rootId":null,"fromId":26656,"content":"是正式的，但听说加班不少，每周会有一次上线，几乎是通宵","createdAt":"2025-08-28T21:41:13"},{"id":"0198f0e9-df24-7314-9d59-a2936b2fbd46","parentId":null,"rootId":null,"fromId":1225,"content":"啥学历啊","createdAt":"2025-08-28T21:41:55"},{"id":"0198f17b-3b44-704a-a38c-81e54f0171d0","parentId":null,"rootId":null,"fromId":26656,"content":"本科以上就可以","createdAt":"2025-08-29T00:20:41"},{"id":"0198f358-d2b3-71da-bf0a-5fdb43a29adf","parentId":null,"rootId":null,"fromId":24615,"content":"亚信啊，我跟他们在一块办公，能接受以下两点就可以。一、薪资入职即巅峰，不管是疫情前还是现在。二、能接受每周加班4天，其中一天因为凌晨升级系统要干到通宵，而且周末和节假日也别想休息，要值班全年无休","createdAt":"2025-08-29T09:02:21"},{"id":"0198f360-4e8e-7132-83c2-2e51f29329b8","parentId":null,"rootId":null,"fromId":3378,"content":"加班多，面试官很装","createdAt":"2025-08-29T09:10:31"},{"id":"0198f38f-63bf-730f-9f4e-93f5e9cf80f2","parentId":null,"rootId":null,"fromId":26656,"content":"我的天 这么狠吗？老哥你说的是亚信的哪个开发组？","createdAt":"2025-08-29T10:01:57"},{"id":"0198f4c6-299f-711b-b1f1-9dceabbf02b4","parentId":null,"rootId":null,"fromId":24615,"content":"想轻松点，就不要接触通信运营商这一行，这种行业全年24小时都是工作时间，而且各种检查和数据安全的事情超多","createdAt":"2025-08-29T15:41:24"},{"id":"0198f4cd-761e-70cf-a671-122e1ffe315f","parentId":null,"rootId":null,"fromId":24615,"content":"忘记说这一行的好处了，好处就是活很多，基本不用担心项目没了团队解散问题","createdAt":"2025-08-29T15:49:22"},{"id":"0198f504-7356-702d-9009-5440f19e3a29","parentId":null,"rootId":null,"fromId":26656,"content":"感谢大佬分享","createdAt":"2025-08-29T16:49:26"},{"id":"0199093d-399b-7338-ac79-776d4d52f863","parentId":null,"rootId":null,"fromId":23660,"content":"1","createdAt":"2025-09-02T15:03:51"},{"id":"01990d4f-6e8e-73d8-a9f2-fbdbc5f5f0c1","parentId":null,"rootId":null,"fromId":557,"content":"我在这干过。一年到头，每天24小时on call。特别心累。","createdAt":"2025-09-03T10:02:13"},{"id":"01990d9d-2084-73a5-9693-491e2fbc67c3","parentId":null,"rootId":null,"fromId":6317,"content":"我面试了三轮，说是124加班，其实都在家，24*7响应，可怕","createdAt":"2025-09-03T11:27:05"},{"id":"01990df7-f3a1-7111-8343-d9ab587d0335","parentId":null,"rootId":null,"fromId":26656,"content":"啊？这么离谱，是济南博晶大厦的亚信吗？","createdAt":"2025-09-03T13:06:17"}]